{
  "name": "VL / Vital Sandbox",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Los_Angeles}",
      "CLAUDE_CODE_VERSION": "latest"
    }
  },
  // NET_ADMIN + NET_RAW let init-firewall.sh program iptables/ipset inside the
  // container. This is what enforces the egress allowlist; without it the
  // sandbox guarantee does not hold.
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "denoland.vscode-deno",
        "rust-lang.rust-analyzer"
      ],
      "settings": {
        "deno.enable": true,
        "deno.lint": true,
        "deno.unstable": true,
        "terminal.integrated.defaultProfile.linux": "zsh",
        // Auto-run the Claude Code extension in bypass mode INSIDE the sandbox
        // only. Both are required: `allowDangerouslySkipPermissions` is the gate
        // (without it the extension silently downgrades bypass → default), and
        // `initialPermissionMode` starts each new conversation already bypassed.
        // The egress allowlist (init-firewall.sh) is the compensating control
        // that makes this safe despite the container having (scoped) internet.
        "claudeCode.allowDangerouslySkipPermissions": true,
        "claudeCode.initialPermissionMode": "bypassPermissions"
      }
    }
  },
  "remoteUser": "node",
  // Named volumes persist shell history and Claude's config/auth across rebuilds,
  // without writing into the host. Auth once inside; it sticks until you delete
  // the volume.
  "mounts": [
    "source=vl-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=vl-claude-config-${devcontainerId},target=/home/node/.claude,type=volume",
    // GitHub auth lives INSIDE the container (run `gh auth login` once) and
    // persists here across rebuilds — no host token passthrough needed. See the
    // README "GitHub auth" section.
    "source=vl-gh-config-${devcontainerId},target=/home/node/.config/gh,type=volume"
  ],
  "remoteEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  // Raise the firewall on every start (sudo is scoped to just this script).
  // postStartCommand runs on first creation *and* every restart, so it alone
  // covers all cases — the script is idempotent, but no need to run it twice.
  "postStartCommand": "sudo /usr/local/bin/init-firewall.sh"
}
