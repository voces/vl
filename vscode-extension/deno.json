{
  "tasks": {
    "build": "npx esbuild src/extension.ts src/server.ts --outdir=dist --bundle --format=cjs --external:vscode --sourcemap --platform=node --define:import.meta.url='_importMetaUrl' --banner:js=\"const _importMetaUrl=require('url').pathToFileURL(__filename)\"",
    "dev": "deno task build --watch"
  },
  "imports": {
    "std/": "https://deno.land/std@0.212.0/",
    "esbuild": "https://deno.land/x/esbuild@v0.19.11/mod.js",
    "esbuild-deno-loader": "https://deno.land/x/esbuild_deno_loader@0.8.3/mod.ts",
    "vscode": "npm:@types/vscode",
    "path": "node:path"
  },
  "nodeModulesDir": true,
  "compilerOptions": {
    "lib": [ "node", "dom", "es2022" ]
  },
  "lint": {"exclude": ["src/antlr"]}
}
