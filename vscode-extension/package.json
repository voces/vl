{
  "name": "vital-vscode",
  "displayName": "Vital",
  "description": "Syntax highlighting for Vital",
  "version": "0.0.1",
  "publisher": "verit",
  "engines": {
    "vscode": "^1.58.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "vital",
      "aliases": ["Vital", "vl"],
      "extensions": [".vl"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "vital",
      "scopeName": "source.vital",
      "path": "./syntaxes/vital.tmLanguage.json"
    }]
  }
}
