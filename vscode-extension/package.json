{
  "name": "vital-vscode",
  "displayName": "Vital",
  "description": "Syntax highlighting for Vital",
  "version": "0.0.1",
  "publisher": "verit",
  "scripts": {
    "postinstall": "patch-package"
  },
  "engines": {
    "vscode": "^1.58.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "dist/extension",
  "contributes": {
    "languages": [
      {
        "id": "vital",
        "aliases": [
          "Vital",
          "vl"
        ],
        "extensions": [
          ".vl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vital",
        "scopeName": "source.vital",
        "path": "./syntaxes/vital.tmLanguage.json"
      }
    ]
  },
  "devDependencies": {
    "antlr4": "^4.13.1-patch-1",
    "binaryen": "^116.0.0",
    "patch-package": "^8.0.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  }
}
