{
  "scopeName": "source.vital",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#numbers" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.vital", "match": "//.*" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.vital",
          "match": "\"(?:\\\\.|[^\"\\\\])*\""
        },
        {
          "name": "string.quoted.single.vital",
          "match": "'(?:\\\\.|[^'\\\\])*'"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.vital",
          "match": "\\b(function|if|then|else|elseif|while|for|to|step|in|const|let|return|await|break|continue|not|from|type)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.vital",
          "match": "\\+\\+|--|&&|\\|\\||!|==|>=|<=|>|<|\\+|-|\\\\|/|%|\\^|=|!="
        }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.vital", "match": "[\\(\\)\\{\\}\\[\\],.:]" }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.vital",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.vital",
          "match": "\\b[a-zA-Z_][a-zA-Z_0-9]*\\b"
        }
      ]
    }
  },
  "fileTypes": ["vl"]
}
