// `std:test` v1 — a pure-VL assertion library over the intrinsic floor
// (docs/std-design.md D5). The matcher surface reads jest-shaped through
// STRUCT-RECEIVER UFCS: `expect(x).toEqual(y)` builds an `Expectation` and
// `.toEqual` is a free `self`-function resolved by self+arity. A failed
// assertion calls `__trap__()` (jest's "a test stops at its first failed
// expectation"); a passing one is a no-op. Under bare `vl run` a green file
// exits 0 and a red one aborts; the runner half (`vl test`, per-test trap
// isolation, reporting — docs/test-runner-design.md) drives these from the host.
//
// `expect` takes a VALUE UNION over the comparable atoms, so ONE entry point
// covers every value kind — the value boxes into the union and `is`-narrows
// back out. (`toBe` referential identity is reserved for the future `===`,
// ROADMAP A15; `toThrow`/`toBeNull` wait on the error model / `null` in the
// value union — std-design OD6.)
type Expectation = {
  actual: i32 | i64 | f64 | boolean | string,
  negated: boolean
}

// `expect(value)` — the receiver for the matchers.
export function expect(value: i32 | i64 | f64 | boolean | string): Expectation {
  return { actual: value, negated: false }
}

// Inverts the pass/fail sense: `expect(5).not().toEqual(6)` passes. Returns a
// fresh `Expectation` (the receiver is a value; no aliasing).
export function not(self: Expectation): Expectation {
  return { actual: self.actual, negated: !self.negated }
}

// Aborts unless `ok` agrees with the current sense (`negated`). Factored so
// every matcher shares one pass/fail/`__trap__` decision. (No `: void`
// annotation — an explicit `void` return is mis-lowered on the current seed;
// the inferred void is correct.)
function adjudicate(self: Expectation, ok: boolean) {
  if self.negated {
    if ok { __trap__() }
  } else {
    if !ok { __trap__() }
  }
}

// `.toEqual` — structural equality, jest semantics. The union `==` compares the
// two values' live variants (a cross-variant pair, `expect(4).toEqual("4")`, is
// unequal). `self.actual` binds to a local first: union `==` requires binding
// operands, not a raw field read.
export function toEqual(self: Expectation, expected: i32 | i64 | f64 | boolean | string) {
  const a = self.actual
  adjudicate(self, a == expected)
}

// `.toBeTrue` — the receiver holds boolean `true`. A non-boolean receiver is
// never true (the `is` arm simply does not fire).
export function toBeTrue(self: Expectation) {
  const a = self.actual
  let ok = false
  if a is boolean { ok = a }
  adjudicate(self, ok)
}

// `.toBeFalse` — the receiver holds boolean `false`.
export function toBeFalse(self: Expectation) {
  const a = self.actual
  let ok = false
  if a is boolean { ok = !a }
  adjudicate(self, ok)
}
