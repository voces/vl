{
    "tasks": {
        "run": "deno run -A --no-check compiler/cli.ts",
        "build": "deno run -A --no-check compiler/cli.ts build",
        "check": "deno run -A --no-check compiler/cli.ts check",
        "fmt": "deno run -A --no-check compiler/cli.ts fmt",
        "lsp:build": "cd lsp && deno task build",
        "lsp:dev": "cd lsp && deno task dev",
        "test": "deno test -A --no-check --parallel tests/",
        "compile": "deno run -A scripts/build-binary.ts",
        "smoke": "deno run -A scripts/smoke-binary.ts",
        "perf": "deno run -A scripts/perf.ts",
        "perf:runtime": "deno run -A scripts/perf-runtime.ts",
        "perf:compare": "deno run -A scripts/perf-compare.ts",
        "install": "npm ci",
        "playground:build": "npm install && deno run -A playground/build.ts",
        "playground:verify": "deno run -A playground/verify.ts",
        "playground": "npm install && deno run -A playground/build.ts && deno run -A playground/serve.ts"
    },
    "exclude": ["lsp", "reference", ".claude"],
    "test": {
        "exclude": ["reference"]
    },
    "lint": {
        "exclude": ["reference"]
    },
    "imports": {
        "binaryen": "npm:binaryen@130",
        "esbuild": "https://deno.land/x/esbuild@v0.24.2/mod.js",
        "esbuild-deno-loader": "jsr:@luca/esbuild-deno-loader@0.11.1",
        "monaco-editor": "npm:monaco-editor@0.52.2"
    },
    "unstable": ["sloppy-imports"]
}
