function a(obj) {
    // obj = {a: 3}
    obj.a = 1
}
const a2: {bar: boolean | null} = {bar: null}
a({}) // Should work; the type should be either {} | {a: number} or {a: number | null}

function b(o: {b: number | null}) {}
const b2: {b: number} = {b: 3}
b(b2) // Should be an error; b should have to be flagged as a readonly prop

function c(o: {c: number}) {}
const c2: {c: number | null} = {c: null}
c(c2) // Should work if c is flagged as a writeonly prop