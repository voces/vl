// An imported module: exports a function and a type, and keeps a private helper
// that shares a name (`helper`) with the entry module to prove name isolation.
export type Point = { x: i32, y: i32 }

export function add(a: i32, b: i32): i32 {
  return a + helper(b)
}

// Module-private: NOT exported. Same name as the entry's `helper` — the two must
// not collide in the merged module.
function helper(n: i32): i32 {
  return n
}

function makePoint(x: i32, y: i32): Point {
  return { x: x, y: y }
}

export function originX(): i32 {
  let p = makePoint(0, 7)
  return p.x
}
