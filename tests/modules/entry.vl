// Entry module: imports an exported function AND an exported type from ./util,
// uses a rename (`add as plus`), and defines its OWN private `helper` with the
// same name as util's private helper (must not collide).
import { add as plus, originX } from "./util"
import { Point } from "./util"

function helper(n: i32) {
  return n * 100
}

// `Point` annotation kept on purpose — exercises using an *imported type* as an
// annotation (the "when you actually want it" case).
let p: Point = { x: 3, y: 4 }
print(plus(p.x, p.y))   // 3 + 4 = 7
print(helper(2))        // entry helper: 200
print(originX())        // util makePoint(0,7).x = 0
