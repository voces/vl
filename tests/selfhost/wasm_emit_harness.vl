// Print-driver for the VL-in-VL wasm emitter (Track H4 spike). VL has no module
// system yet, so the TS runner (`tests/selfhost_wasm_emit_test.ts`) concatenates
// `compiler/ast.vl` (for `i32ToStr`) and `compiler/wasmEmit.vl` ahead of this
// file before compiling. It builds each fixed module, then prints its bytes as a
// comma-joined decimal string. The TS runner parses that string back into a
// Uint8Array and instantiates it with the real `WebAssembly` engine.
//
// Two lines are printed, each `name: <comma-joined-bytes>`:
//   const: () -> i32 returning 42
//   id:    (i32) -> i32 returning local 0

function reportConst(): i32 {
  buildConstModule()
  print("const: " + bytesToStr())
  0
}

function reportId(): i32 {
  buildIdentityModule()
  print("id: " + bytesToStr())
  0
}

reportConst()
reportId()
