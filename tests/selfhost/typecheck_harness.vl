// Print-driver for the VL-in-VL type-checker. VL has no module system yet, so the
// TS runner (`tests/selfhost_typecheck_test.ts`) concatenates `compiler/ast.vl`,
// `compiler/parser.vl`, `compiler/typecheck.vl`, then this file before compiling.
// It therefore assumes the AST types/constructors, the global parser state `P`,
// the parse entry points, the global checker state `T`, the checker entry points
// (`initChecker`, `checkProgram`), the interned primitive indices, and `i32ToStr`
// are all already in scope.
//
// The harness hand-builds a TOKEN stream for a representative VL snippet, runs the
// REAL parser (`parseProgram`) to get an arena AST, then runs the REAL checker
// (`checkProgram`) over it — a genuine parser→typecheck pipeline, not a hand-built
// AST. It prints the diagnostic count and each diagnostic message. The TS runner
// diffs the whole output: a well-typed snippet must report zero diagnostics, and
// each seeded type error must report its expected message.
//
// NOTE on `checkProgram`: it is always called in VALUE-CONSUMING position
// (`i32ToStr(checkProgram(root))`). Calling it as a bare statement trips a codegen
// gap at module scale — see the gap note on `checkProgram` in `compiler/typecheck.vl`.

// Append a token to the stream (a lexer would produce these).
function tok(kind: string, text: string): i32 {
  P.toks.push({ kind: kind, text: text, pos: P.toks.length })
  P.toks.length - 1
}

// Build the token stream for a representative WELL-TYPED program:
//
//   function add(a: i32, b: i32): i32 {
//     let sum = a + b          // inferred i32 from the initializer
//     return sum
//   }
//   let r: i32 = add(1, 2)     // call: arity + arg types match, return i32
//   let ok: bool = r >= 2      // comparison yields bool
//   if ok {
//     let msg: string = "hi"   // annotation matches the string initializer
//   }
//
// Exercises: a function decl with typed params + return; inference of `sum` from
// `a + b`; a `return` checked against the declared return type; a call (arity +
// arg/param compatibility); a comparison producing bool; an annotated string
// binding; an `if` whose condition is bool; nested block scoping.
function buildWellTyped(): i32 {
  tok("FUNCTION", "function")
  tok("IDENT", "add")
  tok("LPAREN", "(")
  tok("IDENT", "a")
  tok("COLON", ":")
  tok("IDENT", "i32")
  tok("COMMA", ",")
  tok("IDENT", "b")
  tok("COLON", ":")
  tok("IDENT", "i32")
  tok("RPAREN", ")")
  tok("COLON", ":")
  tok("IDENT", "i32")
  tok("LBRACE", "{")
  tok("NEWLINE", "\n")
  tok("LET", "let")
  tok("IDENT", "sum")
  tok("EQUAL", "=")
  tok("IDENT", "a")
  tok("PLUS", "+")
  tok("IDENT", "b")
  tok("NEWLINE", "\n")
  tok("RETURN", "return")
  tok("IDENT", "sum")
  tok("NEWLINE", "\n")
  tok("RBRACE", "}")
  tok("NEWLINE", "\n")
  tok("LET", "let")
  tok("IDENT", "r")
  tok("COLON", ":")
  tok("IDENT", "i32")
  tok("EQUAL", "=")
  tok("IDENT", "add")
  tok("LPAREN", "(")
  tok("NUMBER", "1")
  tok("COMMA", ",")
  tok("NUMBER", "2")
  tok("RPAREN", ")")
  tok("NEWLINE", "\n")
  tok("LET", "let")
  tok("IDENT", "ok")
  tok("COLON", ":")
  tok("IDENT", "bool")
  tok("EQUAL", "=")
  tok("IDENT", "r")
  tok("GE", ">=")
  tok("NUMBER", "2")
  tok("NEWLINE", "\n")
  tok("IF", "if")
  tok("IDENT", "ok")
  tok("LBRACE", "{")
  tok("NEWLINE", "\n")
  tok("LET", "let")
  tok("IDENT", "msg")
  tok("COLON", ":")
  tok("IDENT", "string")
  tok("EQUAL", "=")
  tok("STRING", "\"hi\"")
  tok("NEWLINE", "\n")
  tok("RBRACE", "}")
  tok("NEWLINE", "\n")
  tok("EOF", "")
  P.toks.length
}

// Print the diagnostic count then each message (in order).
function report(): i32 {
  print("diags: " + i32ToStr(checkProgram(parseProgram())))
  let i = 0
  while i < T.diags.length {
    print(T.diags[i].tmsg)
    i = i + 1
  }
  0
}

// ── run ──────────────────────────────────────────────────────────────────────
buildWellTyped()
initChecker()
report()
