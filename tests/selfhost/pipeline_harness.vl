// End-to-end front-end pipeline driver for the VL-in-VL compiler (Track H3).
//
// Unlike `tests/selfhost/typecheck_harness.vl`, which HAND-BUILDS its token stream
// with a `tok(kind, text)` helper, this harness drives the WHOLE front end from raw
// SOURCE TEXT: it runs the real `compiler/lexer.vl` (`tokenize`) to produce a token
// stream, adapts those tokens into the shape the real `compiler/parser.vl` consumes
// (the `Tok`/`P.toks` model from `compiler/ast.vl`), runs the real parser
// (`parseProgram`) to build the arena AST, then runs the real type-checker
// (`checkProgram`, from `compiler/typecheck.vl`) over it. This proves the front end
// self-hosts from a string, not from a pre-tokenized fixture.
//
// VL has no module system yet, so the TS runner (`tests/selfhost_pipeline_test.ts`)
// concatenates `lexer.vl ++ ast.vl ++ parser.vl ++ typecheck.vl ++ this` before
// compiling. The lexer and parser were ported separately and DEFINE COLLIDING names
// (`Tok`, `Diag`, `advance`). The runner resolves the *name* collisions by renaming
// the lexer's three colliding symbols (`Tok`→`LexTok`, `Diag`→`LexDiag`,
// `advance`→`lexAdvance`) in the lexer SOURCE TEXT before concatenation — pure glue,
// no `.vl` compiler file is edited. The token-`kind` spellings now agree between the
// lexer and parser (gap #2 resolved), so no `mapKind` translation is needed.
//
// NOTE on `checkProgram`: it is always called in VALUE-CONSUMING position
// (`i32ToStr(checkProgram(...))`). Calling it as a bare statement trips a codegen
// gap at module scale — see the gap note on `checkProgram` in `compiler/typecheck.vl`.

// Run the real lexer over `src`, then materialize each lexed token into the parser's
// `P.toks` stream (the `Tok = {kind, text, pos}` model from `ast.vl`). The lexer's
// richer `LexTok` (renamed from `Tok` by the runner) carries `value`/`start`/`stop`/
// `line`/`col` too, but the parser only reads `kind` + `text`, and uses `pos` purely
// as the cursor index — so the adapter keeps `text` verbatim (the raw lexeme, which
// is exactly what the parser's literal/ident constructors store) and sets `pos` to
// the stream index. The lexer already EOF-terminates its stream, which is the
// terminator the parser's cursor primitives expect. Returns the token count.
// (No kind translation needed: the lexer now uses the same kind spellings as the
// parser — gap #2 resolved.)
function loadToks(src: string): i32 {
  let r = tokenize(src)
  let i = 0
  while i < r.tokens.length {
    let t = r.tokens[i]
    P.toks.push({ kind: t.kind, text: t.text, pos: i, start: t.start, line: t.line, col: t.col })
    i = i + 1
  }
  P.toks.length
}

// Print the diagnostic count then each message (in order) — mirrors the print style
// of `typecheck_harness.vl`. `checkProgram(parseProgram())` runs the genuine
// parse→typecheck chain over the AST the loaded tokens produced.
function report(): i32 {
  print("diags: " + i32ToStr(checkProgram(parseProgram())))
  let i = 0
  while i < T.diags.length {
    print(T.diags[i].tmsg)
    i = i + 1
  }
  0
}

// A representative WELL-TYPED program, given as raw SOURCE TEXT (the lexer tokenizes
// it). It exercises: a function decl with typed params + return; inference of `sum`
// from `a + b`; a `return` checked against the declared return type; a call (arity +
// arg/param compatibility); a comparison producing bool; an annotated string
// binding; an `if` whose condition is bool; nested block scoping.
//
//   function add(a: i32, b: i32): i32 {
//     let sum = a + b
//     return sum
//   }
//   let r: i32 = add(1, 2)
//   let ok: bool = r >= 2
//   if ok {
//     let msg: string = "hi"
//   }
let source = "function add(a: i32, b: i32): i32 {\n" +
  "  let sum = a + b\n" +
  "  return sum\n" +
  "}\n" +
  "let r: i32 = add(1, 2)\n" +
  "let ok: bool = r >= 2\n" +
  "if ok {\n" +
  "  let msg: string = \"hi\"\n" +
  "}\n"

// ── run: source text → lexer → parser → typecheck → diagnostics ──────────────
loadToks(source)
initChecker()
report()
