// Print-driver for the VL-in-VL parser. VL has no module system yet, so the TS
// runner (`tests/selfhost_parser_test.ts`) concatenates `compiler/ast.vl`, then
// `compiler/parser.vl`, then this file before compiling. It therefore assumes the
// AST types/constructors, the global parser state `P`, the parse entry points, and
// `i32ToStr` are already in scope.
//
// It hand-builds a token stream for a representative VL snippet (the PARSER is the
// subject under test, not an integrated lexer pipeline), runs `parseProgram`, and
// prints the AST as an indented tree — one `<indent><kind> <detail>` line per node
// — plus a node/diagnostics summary. The TS runner diffs the whole output.
//
// The walk discriminates the GENUINE union with `is` (the same idiom the parser
// uses): each `is`-arm prints the variant's own fields and recurses into its child
// slots. This is the proof the union AST round-trips: a mis-parse — wrong operator
// precedence, swapped operands, a dropped child, a mis-built node — changes the
// printed tree and the diff catches it. Like the parser, the tree walk is mutually
// recursive (`walk` ↔ `walkList`) and reads the global `P` directly.

// Append a token to the stream (a lexer would produce these).
function tok(kind: string, text: string): i32 {
  // Hand-built stream: no real source, so the source-position fields (rung 1 of
  // span threading) are filled with neutral placeholders (`start` 0, `line` 1,
  // `col` 0). The parser exercised here never reads them.
  P.toks.push({ kind: kind, text: text, pos: P.toks.length, start: 0, line: 1, col: 0 })
  P.toks.length - 1
}

// Build the token stream for this source:
//
//   function add(a: i32, b: i32): i32 {
//     let sum = a + b * 2
//     if sum >= 10 {
//       return sum
//     } else {
//       return -sum
//     }
//   }
//   const ok = add(1, 2) || flag
//   result = obj.field.method(x)
//
// Exercises: a function decl with typed params + return type, a block, a let-decl
// with a binary expr (precedence: `*` binds tighter than `+`), an if/else with a
// comparison and a unary minus, a const-decl with `||` and a call (multi-arg), and
// a bare expression statement: a right-assoc assignment whose RHS is a chained
// member access ending in a call.
function buildTokens(): i32 {
  // function add(a: i32, b: i32): i32 {
  tok("FUNCTION", "function")
  tok("IDENT", "add")
  tok("LPAREN", "(")
  tok("IDENT", "a")
  tok("COLON", ":")
  tok("IDENT", "i32")
  tok("COMMA", ",")
  tok("IDENT", "b")
  tok("COLON", ":")
  tok("IDENT", "i32")
  tok("RPAREN", ")")
  tok("COLON", ":")
  tok("IDENT", "i32")
  tok("LBRACE", "{")
  tok("NEWLINE", "\n")
  //   let sum = a + b * 2
  tok("LET", "let")
  tok("IDENT", "sum")
  tok("EQUAL", "=")
  tok("IDENT", "a")
  tok("PLUS", "+")
  tok("IDENT", "b")
  tok("STAR", "*")
  tok("NUMBER", "2")
  tok("NEWLINE", "\n")
  //   if sum >= 10 {
  tok("IF", "if")
  tok("IDENT", "sum")
  tok("GE", ">=")
  tok("NUMBER", "10")
  tok("LBRACE", "{")
  tok("NEWLINE", "\n")
  //     return sum
  tok("RETURN", "return")
  tok("IDENT", "sum")
  tok("NEWLINE", "\n")
  //   } else {
  tok("RBRACE", "}")
  tok("ELSE", "else")
  tok("LBRACE", "{")
  tok("NEWLINE", "\n")
  //     return -sum
  tok("RETURN", "return")
  tok("MINUS", "-")
  tok("IDENT", "sum")
  tok("NEWLINE", "\n")
  //   }
  tok("RBRACE", "}")
  tok("NEWLINE", "\n")
  // }
  tok("RBRACE", "}")
  tok("NEWLINE", "\n")
  // const ok = add(1, 2) || flag
  tok("CONST", "const")
  tok("IDENT", "ok")
  tok("EQUAL", "=")
  tok("IDENT", "add")
  tok("LPAREN", "(")
  tok("NUMBER", "1")
  tok("COMMA", ",")
  tok("NUMBER", "2")
  tok("RPAREN", ")")
  tok("OR", "||")
  tok("IDENT", "flag")
  tok("NEWLINE", "\n")
  // result = obj.field.method(x)   (assignment binary; RHS is a member chain + call)
  tok("IDENT", "result")
  tok("EQUAL", "=")
  tok("IDENT", "obj")
  tok("DOT", ".")
  tok("IDENT", "field")
  tok("DOT", ".")
  tok("IDENT", "method")
  tok("LPAREN", "(")
  tok("IDENT", "x")
  tok("RPAREN", ")")
  tok("NEWLINE", "\n")
  tok("EOF", "")
  P.toks.length
}

// Render `depth` levels of indentation.
function indent(depth: i32): string {
  let s = ""
  let i = 0
  while i < depth {
    s = s + "  "
    i = i + 1
  }
  s
}

// Print every node index in `kids`, each at `depth`.
function walkList(kids: i32[], depth: i32): i32 {
  let i = 0
  while i < kids.length {
    walk(kids[i], depth)
    i = i + 1
  }
  0
}

// Print node `i` and recurse into its children. A child slot of `-1` (absent) is a
// no-op, so optional children need no guard at the call site. Discriminates the
// union with `is` — the same soundness the parser relies on.
function walk(i: i32, depth: i32): i32 {
  if i < 0 {
    return 0
  }
  let n = P.nodes[i]
  let pad = indent(depth)
  let d1 = depth + 1

  if n is NumLit {
    print(pad + "num " + n.numText)
  } else if n is StrLit {
    print(pad + "str " + n.strText)
  } else if n is CharLit {
    print(pad + "char " + n.charText)
  } else if n is BoolLit {
    if n.boolVal == 1 {
      print(pad + "bool true")
    } else {
      print(pad + "bool false")
    }
  } else if n is Ident {
    print(pad + "ident " + n.identName)
  } else if n is Unary {
    print(pad + "unary " + n.unOp)
    walk(n.unArg, d1)
  } else if n is BinExpr {
    print(pad + "binary " + n.binOp)
    walk(n.binLeft, d1)
    walk(n.binRight, d1)
  } else if n is Call {
    print(pad + "call")
    walk(n.callFn, d1)
    walkList(n.callArgs, d1)
  } else if n is Member {
    print(pad + "member ." + n.memProp)
    walk(n.memObj, d1)
  } else if n is Paren {
    print(pad + "paren")
    walk(n.parInner, d1)
  } else if n is ErrExpr {
    print(pad + "error " + n.errWhat)
  } else if n is LetDecl {
    print(pad + n.letKw + " " + n.letName)
    walk(n.letType, d1)
    walk(n.letInit, d1)
  } else if n is Param {
    print(pad + "param " + n.parName)
    walk(n.parType, d1)
  } else if n is TypeRef {
    print(pad + "type " + n.tyName)
  } else if n is FuncDecl {
    print(pad + "function " + n.fnName)
    walkList(n.fnParams, d1)
    walk(n.fnRet, d1)
    walk(n.fnBody, d1)
  } else if n is IfStmt {
    print(pad + "if")
    walk(n.ifCond, d1)
    walk(n.ifThen, d1)
    walk(n.ifElse, d1)
  } else if n is RetStmt {
    print(pad + "return")
    walk(n.retArg, d1)
  } else if n is Block {
    print(pad + "block")
    walkList(n.blkStmts, d1)
  } else if n is Program {
    print(pad + "program")
    walkList(n.progStmts, d1)
  } else {
    print(pad + "??")
  }
  0
}

// ── run ──────────────────────────────────────────────────────────────────────
buildTokens()
let root = parseProgram()
walk(root, 0)

print("== nodes: " + i32ToStr(P.nodes.length) + " ==")
print("== diagnostics: " + i32ToStr(P.diags.length) + " ==")
let di = 0
while di < P.diags.length {
  print(P.diags[di].msg + " @ " + i32ToStr(P.diags[di].at))
  di = di + 1
}
