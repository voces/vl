// @run
// @log 1.5
// @log 2.5
// @log 7
// @log 3.5
// @log 4.5
// The rep-fuzz R6 "struct inside list / nullable-list" family signatures
// (`({f: f64} | null)[]`, `{f: {f: f64}[]}`, `{f: {f: {f: i32}[]}}`): the
// field-access classifier resolves a struct ELEMENT type STRUCTURALLY through the
// list / nullable-list wrapper (the ref-list slot layer's structural dedup +
// `structIndexOfExpr`'s Index arm stripping the element's `| null`), so a `.field`
// read on an element compiles and round-trips at every wrapper depth — including a
// chained read with no intermediate binding, a for-in element, and a list buried
// under a nullable struct.
function go() {
  // ({f: f64} | null)[] — a nullable-list element, narrowed binding read.
  const xs: ({f: f64} | null)[] = [{f: 1.5}]
  const e = xs[0]
  if (e != null) {
    print(e.f)
  }
  // {f: {f: f64}[]} — a struct field holding a struct-element list, chained read.
  const s: {f: {f: f64}[]} = {f: [{f: 2.5}]}
  print(s.f[0].f)
  // {f: {f: {f: i32}[]}} — struct → struct → struct-element list.
  const d: {f: {f: {f: i32}[]}} = {f: {f: [{f: 7}]}}
  print(d.f.f[0].f)
  // A for-in over a struct-list field binds the element as the struct.
  const t: {f: {f: f64}[]} = {f: [{f: 3.5}]}
  for it in t.f {
    print(it.f)
  }
  // A struct-element list buried under a NULLABLE struct.
  const n: {f: {f: f64}[]} | null = {f: [{f: 4.5}]}
  if (n != null) {
    print(n.f[0].f)
  }
}
go()
