// Regression: a list literal `[{f: {f: {f: "other"}}}]` bound to a NESTED-alias element
// annotation (`{f: {f: {f: f32 | string | {q: i64}}}}[]`, where `type T0` also registers
// the inner/outer pair) whose rows all share the ONE-field fieldset `{f}`. The literal's
// inner union field value `"other"` SOFTENS the recorded rep type to `{f: {f: {f: string}}}`
// (string is a member of the union — covariantly assignable, so the literal-aware adoption
// never ran). The softened canon key matched NO registered row and the structural resolver
// (`repRowOfTyStruct`) declined, so `structIndexOfObjCtx`'s ambiguity arm fell to the WRONG
// same-fieldset twin and the outer element built one level short: INVALID-WASM (fuzz sweep
// uM8vds declared leg, seed 15384050 case_00217, the `mix:` triple-nest cluster).
// `recordRepTyAdopt` now re-stamps the literal's rep with the union-bearing DESTINATION when
// the destination reaches a `TyUnion`, so the resolver keys the correct outer row.
// @run
// @log OTHER
// @log other
type T0 = {f: {f: {f: f32 | string | {q: i64}}}}
function useTwin(p: T0[]) {
  const t0 = p[0].f.f.f
  if t0 is f32 { print(t0) } else { print("OTHER") }
  const u0: f32 | string | {q: i64} = "other"
  if u0 is string { print(u0) } else { print("UOTHER") }
}
function go() {
  const w: {f: {f: {f: f32 | string | {q: i64}}}}[] = [
    {
      f: { f: { f: "other" } },
    },
  ]
  useTwin(w)
}
go()
