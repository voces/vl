// @run
// @log 5
// @log 4.5
// @log 5
// @log 5000000000
// @log 2.5
// @log 9
// @log 10
// @log 20
// A struct field whose type is a SCALAR list — `f64[]` / `i64[]` / `f32[]` — now lowers. Previously
// `fieldTypeCode` lumped every non-`i32[]`/`string[]` array field into the struct/union ref-list code
// (5), which emitted the WRONG wrapper heap type (an invalid-wasm soundness hole). These now classify to
// dedicated codes (25/26/27) that store the scalar-list wrapper (`$fl64`/`$il64`/`$fl32`), force that
// wrapper's collection (the field analogue of a ref-list field forcing `rlUsed`), and seed
// `pendingListKind` so the value's elements coerce (a bare `[5]` widens to i64, `[2.5]` re-encodes at
// f32). Works for both inline-shape annotations and nominal `type` declarations. Found by the rep-
// composition fuzzer (#667).

type IBox = { xs: i64[] }

function go() {
  // f64[] field — inline shape, single + multi-element + index.
  const a: { f: f64[] } = { f: [5.0] }
  print(a.f[0]) // 5
  const a2: { f: f64[] } = { f: [1.5, 2.5, 3.0] }
  print(a2.f[0] + a2.f[2]) // 4.5

  // i64[] field — bare-int literal coerces to i64, and a true-i64 value round-trips.
  const b: { f: i64[] } = { f: [5] }
  print(b.f[0]) // 5
  const b2: { f: i64[] } = { f: [5000000000] }
  print(b2.f[0]) // 5000000000

  // f32[] field — float element re-encodes at f32.
  const c: { f: f32[] } = { f: [2.5] }
  print(c.f[0]) // 2.5

  // Nominal struct with an i64[] field.
  const d: IBox = { xs: [7, 8, 9] }
  print(d.xs[2]) // 9

  // Two scalar-list fields of different element type in one struct.
  const e: { a: f64[], b: i64[] } = { a: [10.0], b: [20] }
  print(e.a[0]) // 10
  print(e.b[0]) // 20
}

go()
