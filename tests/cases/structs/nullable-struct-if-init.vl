// @run
// @log 5
// @log 0
// @log 8
// @log 0
// @log 7
// @log -1
// @log 1
// @log 4
// A nullable-struct binding from an IF-EXPRESSION (`const r: P | null = if c { {…} } else { null }`)
// emitted INVALID WASM — the join's two arms are `(ref $P)` and `(ref null $P)`, but `emitIfExprRef`
// declared the non-null `(ref $P)` blocktype, so the `null` arm mismatched ("expected (ref $type), found
// (ref null $type)"). And a `null` THEN arm wasn't classified a struct join at all (the kind came from
// the then-arm's rep only).
//
// Fixed by reading the CHECKER's recorded join type (`nodeTyIsNullableStruct`): it drives the NULLABLE
// blocktype (`fbValtypeNullable`), AND classifies the join kind-1 when the then arm is `null` (the inner
// struct then resolves via `nodeNulStructInnerName`). One checker signal covers both arm positions.

type P = { x: i32 }

// `null` in the THEN arm — the struct kind/index come from the checker's join, not the arm.
function pickThenNull(n: i32): i32 {
  const r: P | null = if n > 0 then null else { x: 8 }
  if r != null { return r.x }
  return 0
}

// `null` in the ELSE arm.
function pickElseNull(n: i32): i32 {
  const r: P | null = if n > 0 then { x: n } else null
  if r != null { return r.x }
  return -1
}

// Both arms non-null under a `P | null` binding (the value widens to nullable on store).
function bothNonNull(n: i32): i32 {
  const r: P | null = if n > 0 then { x: 1 } else { x: 2 }
  if r != null { return r.x }
  return -9
}

// A nullable-struct if-expression in RETURN position.
function mk(n: i32): P | null { return if n > 0 then { x: n } else null }

function go() {
  print(pickElseNull(5))  // 5  (n>0 → the struct arm)
  print(pickThenNull(5))  // 0  (n>0 → null → default)
  print(pickThenNull(-1)) // 8  (n<=0 → the struct arm)
  print(pickThenNull(2))  // 0  (n>0 → null → default)
  print(pickElseNull(7))  // 7
  print(pickElseNull(-2)) // -1 (null → default)
  print(bothNonNull(5))   // 1

  const r = mk(4)
  if r != null {
    print(r.x) // 4
  }
}

go()
