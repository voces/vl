// @run
// @log aa
// @log aa
// @log 1
// @log bb
// @log aa
// @log bb
// An ATOM-ARRAY struct field (`f: K[]`, `K` a literal union) IS the i32 list — its elements
// are interned atom ids, exactly like a bare `K[]` binding. The field code is 4 (i32 list)
// with the array name recorded (`sFieldIsLitUnionArray`), and construct/assign seed the
// atom-element context so a member literal builds the i32 backing — previously the literal
// self-classified as a STRING list (its elements are string exprs syntactically) whose
// wrapper ref mismatched the field's list type: invalid wasm as a local, an UNPARSEABLE
// module as a global initializer (the rep-fuzz `{f: K0[]}` global finding). Covers the
// inline shape, the declared struct, and the global-initializer constexpr. (The declared
// struct uses a DIFFERENT field name — a declared and an inline shape over the same
// field-name set is a separate, pre-existing interning limitation.)
type K0 = "aa" | "bb"
type S = {tags: K0[]}

const g: {f: K0[]} = {f: ["aa"]}
const gs: S = {tags: ["aa"]}

function go() {
  print(g.f[0])
  const l: {f: K0[]} = {f: ["aa"]}
  print(l.f[0])
  print(l.f.length)
  l.f = ["bb", "aa"]
  print(l.f[0])
  print(l.f[1])
  if gs.tags[0] == "aa" { print("bb") } else { print("aa") }
}
go()
