// @run
// @log 7
// @log 9
// @log 7
// @log 5
// @log -1
// An INLINE SHAPE used as a ref-list ELEMENT now interns as a struct, so the element read resolves it.
// Two forms: an inline-shape element of a struct FIELD (`{ f: {g:i32}[] }`), and a paren-grouped nullable
// inline-struct element of a top-level list (`({f:f64} | null)[]`). Both went through paths that recorded
// only the OUTER shape: `internInlineShape`'s parse loop didn't pre-intern a code-5 field's element shape,
// and `collectAnnShapes` didn't peel the grouping parens of a `(<shape>|null)[]` element. The element
// shape stayed un-interned, so `structIndexByName` missed it and the read failed ("receiver is not a
// struct"). The element shape is now pre-interned in the parse loop (safe — before the outer shape is
// pushed, so the flat `sField*` arrays aren't corrupted) and in `collectAnnShapes`. The NOMINAL forms
// (`{f: Inner[]}`, `(Inner|null)[]`) already worked. Found by the rep-composition fuzzer (#667).

function go() {
  // Inline-shape element of a struct field — single + multi + deep.
  const a: { f: { g: i32 }[] } = { f: [{ g: 7 }] }
  print(a.f[0].g) // 7
  const a2: { f: { g: i32 }[] } = { f: [{ g: 7 }, { g: 9 }] }
  print(a2.f[1].g) // 9
  const a3: { f: { g: { h: i32 }[] } } = { f: { g: [{ h: 7 }] } }
  print(a3.f.g[0].h) // 7

  // Paren-grouped nullable inline-struct element of a top-level list.
  const b: ({ f: f64 } | null)[] = [{ f: 5.0 }]
  const b0 = b[0]
  if b0 != null {
    print(b0.f) // 5
  } else {
    print(-1.0)
  }
  const c: ({ f: f64 } | null)[] = [null]
  const c0 = c[0]
  if c0 != null {
    print(c0.f) // -1
  } else {
    print(-1)
  }
}

go()
