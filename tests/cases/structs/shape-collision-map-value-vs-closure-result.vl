// @run
// @log dn
// @log dn
// @log 84082
// Two SAME-FIELD-NAME structs coexisting: a map's value struct (`{f: K0}` / `{f: i32}`)
// and a closure's inferred result struct (`{f: string}`). `structIndexOfObjCtx`'s
// name-only scan matched BOTH for the lambda's `{f: "dn"}` literal (a string literal
// legitimately initializes a litunion atom field, so no field-code axis can split
// them) and first-match won — the literal built with the MAP struct's layout: a
// silent MISMATCH printing the raw i32 (`{f: K0}`), or invalid wasm when the field
// valtypes differ (`{f: i32}`). On a 2+ match the resolution now consults the
// checker's recorded node type (fuzz frontier seed 42931513 d5 --branching).
type K0 = "vtn" | "84082"

function go() {
  const h0: {[string]: {f: K0}} = Map()
  h0["k"] = { f: "84082" }
  const v: {a: i64, f: () => {f: string}, z: {[string]: {f: K0}}} = {
    a: 570569038561872389,
    f: () => ({ f: "dn" }),
    z: h0,
  }
  print(v.f().f)
  // The i32-valued twin — first-match here built `{f: "dn"}` with an i32 field slot
  // (invalid wasm), the loud sibling of the mismatch above.
  const h1: {[string]: {f: i32}} = Map()
  h1["k"] = { f: 7 }
  const w: {f: () => {f: string}, z: {[string]: {f: i32}}} = {
    f: () => ({ f: "dn" }),
    z: h1,
  }
  print(w.f().f)
  // The map's own value struct still constructs and reads through its litunion layout.
  const r = h0["k"]
  if (r != null) { print(r.f) }
}
go()
