// @run
// @log 100
// @log 9000000000
// @log true
// @log a
// @log b
// NON-TWINS MUST STAY DISTINCT. The dedup keys slots on the canonical STRUCTURAL
// key (`repCanonKey`), guarded by an emitter field-code match — so two shapes that
// are NOT the same type keep separate heap types. This pins the boundary: a bad
// merge here would store an i64 into an i32 field (or an atom into a string slot).
//
// Different field TYPE under the same field NAME is a different structure — a
// different key AND different field codes — so `{f:i32}` and `{f:i64}` never share
// a heap type (the i64 stays 64-bit).
type I32Box = { f: i32 }
type I64Box = { f: i64 }
function readI32(x: I32Box) { return x.f }
function readI64(x: I64Box): i64 { return x.f }
const a: I32Box = { f: 100 }
const c: I64Box = { f: 9000000000 }
print(readI32(a))   // 100
print(readI64(c))   // 9000000000 (not truncated to i32)

// `boolean` vs `i32`: `repCanonKey` distinguishes them, so a `{f:boolean}` keeps
// its own slot even though the field CODE alone would not separate it.
type BoolBox = { f: boolean }
const d: BoolBox = { f: true }
print(d.f)          // true

// A declared litunion-alias field (`k: K`, an i32 ATOM rep) vs an inline litunion
// field (`k: "a"|"b"`, coded differently): the field-code guard keeps them apart
// so neither reads the other's backing rep.
type K = "a" | "b"
type WithAlias = { k: K }
type WithInline = { k: "a" | "b" }
const wa: WithAlias = { k: "a" }
const wi: WithInline = { k: "b" }
print(wa.k)         // a
print(wi.k)         // b
