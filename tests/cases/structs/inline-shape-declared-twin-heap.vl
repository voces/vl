// @run
// @log 5
// @log 6
// A FIELD's inline shape interned by `collectNestedFieldShapes` lands BEFORE the declared
// structs, so `annShapeIndexOf` cannot dedup it onto its declared twin — the shape minted a
// DUPLICATE struct heap type, and a declared-`A` value flowing into the `{v:i32}`-shaped
// field was INVALID WASM (`(ref $A)` vs `(ref null $shape)`), and an `A[]` into a
// `{v:i32}[]` field mismatched the ref-list wrapper the same way. The canonical structural
// key (`repCanonKey` via the shape spelling) now keys shape slots into `buildStructTwins`,
// and the ref-list twin sig follows the collapsed heap — one struct type, one wrapper pair.
type A = { v: i32 }
type H = { inner: { v: i32 } }
type L = { items: { v: i32 }[] }

function main() {
  const a: A = { v: 5 }
  const h: H = { inner: a }
  print(h.inner.v)
  const as: A[] = [{ v: 3 }, { v: 6 }]
  const l: L = { items: as }
  print(l.items[1].v)
}

main()
