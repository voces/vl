// A NULLABLE map struct FIELD (`{f: {[string]: V} | null}`) — field code 29, the map twin of
// the code-28 nullable ref-list field: the field stores a NULLABLE ref to the value type's map
// struct (`0x63 mapTypeIdxOf(slot)`), sharing the mv value slot with its non-null code-19 twin.
// A bare `null` field value lowers as `ref.null $mapStruct` (`pendingNulRefHeap`), a map value
// subtypes the slot, an OMITTED field completes to null, and `const t = v.f` infers the `nulmap`
// binding kind (`exprNullableMap`'s member arm) so `!= null` narrows and the narrowed map ops
// read the field's value rep (`mapShapeOfExpr`'s code-29 member arm). Covers: string-valued
// (null + value), a mixed-field struct with an i64-valued map field (null + value), an
// f32-valued map field through a RETURN boundary, and the omitted-field completion.
function strField() {
  const o: {f: {[string]: string} | null} = {f: null}
  const t0 = o.f
  if t0 != null {
    print(t0["k"] ?? "zz")
  } else {
    print("NULL")
  }
  const h: {[string]: string} = Map()
  h["k"] = "66"
  const o2: {f: {[string]: string} | null} = {f: h}
  const t1 = o2.f
  if t1 != null {
