// @run
// @log 7
// @log 7
// @log 3
// @log 9
// The soundness guard for an UN-INTERNABLE inline-shape binding (`{f: {g:i32}[] | null}` — a nullable
// struct-list field with no rep) rejects it cleanly at emit instead of mis-matching its object literal to
// a wrong same-field-named struct (which emitted invalid wasm — a construct-side hole the read-path fuzzer
// masked). This test pins the BOUNDARY: the adjacent VALID inline-shape bindings must still lower, i.e.
// the guard (`letAnnIsUninternedShape`, checked only after union / nullable-struct / struct classification)
// must NOT over-fire on a genuinely interned shape.

function go() {
  // A valid nested inline-shape field (interned) — must still work.
  const a: { f: { g: i32 } } = { f: { g: 7 } }
  print(a.f.g) // 7

  // A valid inline-shape STRUCT-LIST field (interned via the parse-loop pre-intern) — adjacent to the
  // rejected nullable struct-list field, must still work.
  const b: { f: { g: i32 }[] } = { f: [{ g: 7 }] }
  print(b.f[0].g) // 7

  // A valid nullable inline-struct binding (`{x}|null`) — classified before the guard, must still work.
  const c: { x: i32 } | null = { x: 3 }
  if c != null {
    print(c.x) // 3
  } else {
    print(-1)
  }

  // A plain multi-field inline-shape binding.
  const d: { p: i32, q: i32 } = { p: 4, q: 5 }
  print(d.p + d.q) // 9
}

go()
