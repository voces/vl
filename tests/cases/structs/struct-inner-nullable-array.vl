// @run
// @log 7
// @log -1
// @log 9
// A `({g:i32}[] | null)[]` — a list whose element is a NULLABLE array of an INLINE-SHAPE struct — now
// works. The inline shape `{g:i32}` sits under array + nullable + array + grouping wrappers, so the
// annotation-shape pre-pass must peel ALL of them to reach and intern it. `collectAnnShapes` now uses a
// recursive `internShapeDeep` (peels grouping parens, a trailing `| null`, and `[]` suffixes to any depth)
// instead of a single-level strip, so the element struct interns and the read resolves it. The nullable
// nested-array READ itself rides the kind-18 local rep. Found by the rep-composition fuzzer (#667).

function go() {
  const v: ({ g: i32 }[] | null)[] = [[{ g: 7 }], null, [{ g: 8 }, { g: 9 }]]

  const a = v[0]
  if a != null {
    print(a[0].g) // 7
  } else {
    print(-1)
  }

  const b = v[1]
  if b != null {
    print(b[0].g)
  } else {
    print(-1) // -1
  }

  const c = v[2]
  if c != null {
    print(c[1].g) // 9
  } else {
    print(-1)
  }
}

go()
