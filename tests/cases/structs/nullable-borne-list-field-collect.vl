// @run
// @log NULL
// @log NULL
// @log NULL
// @log NULL
// @log 0
// A scalar-list type mentioned ONLY inside a struct-field annotation whose every carried
// VALUE is null — no list literal ever seeds the wrapper, so collection must derive it
// from the interned field codes (`collectA`'s field re-walk): a `boolean[]` (code 4)
// inside a `{...} | null` param, an `f64[]` (code 25) inside a nullable-struct field,
// and an `i32[] | null` field (code 18) of a const GLOBAL whose init stores a bare
// `null` (the emitObj code-18 `ref.null $lTypeIdx` seed — a valid constexpr).
// rep-fuzz p1r `{f: {a: i64, f: boolean[], z: f32}} | null`,
// p1r `{f: {a: i64, f: f64[], z: boolean} | null}`, p3c/p3r `{a: f64, f: i32[] | null, z: i32}`.
const g: {a: f64, f: i32[] | null, z: i32} = { a: 2.5, f: null, z: 11 }
function useOuterNul(p: {f: {a: i64, f: boolean[], z: f32}} | null) {
  const t0 = p
  if t0 != null { print(t0.f.f[0]) } else { print("NULL") }
}
function useFieldNul(p: {f: {a: i64, f: f64[], z: boolean} | null}) {
  const t0 = p.f
  if t0 != null { print(t0.f[0]) } else { print("NULL") }
}
function go() {
  useOuterNul(null)
  useFieldNul({ f: null })
  const t0 = g.f
  if t0 != null { print(t0[0]) } else { print("NULL") }
  const v: {a: f64, f: i32[] | null, z: i32} = { a: 1.5, f: null, z: 3 }
  const t1 = v.f
  if t1 != null { print(t1[0]) } else { print("NULL") }
  print(0)
}
go()
