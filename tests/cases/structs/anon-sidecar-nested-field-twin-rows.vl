// Regression: a closure returning the STRUCT arm of a variant-box union whose arm
// carries a NESTED struct field with a WIDENED-literal leaf (`3.5` self-classifies
// f64 into an `f32` field; `3` self-classifies i32 into an `i64` field). The
// literal's anonymous rows intern with SELF-classified field layouts (`#anon`
// middle row referencing the f64/i32 inner twin) while their canon-key SIDECAR
// records the checker's ADOPTED type — byte-equal to the annotation row's key. The
// struct-layer twin guard (`structFieldCodesEq`) compared only TOP-LEVEL field
// codes, so the anon row and the annotation row merged (both `(i32, ref-null)`)
// even though their code-15 fields referenced DIFFERENT inner heap types — the
// adopted literal then stored a `(ref ${b:f32})` into a field typed
// `(ref null ${b:f64})`: INVALID-WASM (fuzz seed 451870974 d5 plain leg,
// `() => {f: {a: i64, f: {a: i32, f: boolean, z: f32}, z: boolean}} | f64`).
// `structFieldCodesEq` now applies the `variantFieldLayoutEq` referenced-layer
// discipline to code-15 fields: distinct elem names must resolve to rows that are
// themselves twins (coinductive over recursive shapes), else the merge declines.
// @run
// @log true
// @log 3.5
// @log 3
// @log OTHER
function useDraw(
  p: () => {f: {a: i64, f: {a: i32, f: boolean, z: f32}, z: boolean}} | f64,
) {
  const t0 = p()
  if t0 is {f: {a: i64, f: {a: i32, f: boolean, z: f32}, z: boolean}} {
    print(t0.f.f.f)
  } else {
    print("DRAW-OTHER")
  }
}
function useF32(p: () => {f: {a: i32, f: {b: f32}}} | f64) {
  const t0 = p()
  if t0 is {f: {a: i32, f: {b: f32}}} {
    print(t0.f.f.b)
  } else {
    print("F32-OTHER")
  }
}
function useI64(p: () => {f: {a: i32, f: {b: i64}}} | f64) {
  const t0 = p()
  if t0 is {f: {a: i32, f: {b: i64}}} {
    print(t0.f.f.b)
  } else {
    print("I64-OTHER")
  }
}
function useScalarArm(p: () => {f: {a: i32, f: {b: f32}}} | f64) {
  const t0 = p()
  if t0 is f64 { print("OTHER") } else { print("SCALAR-MISS") }
}
function go() {
  useDraw(
    () => ({ f: { a: 6000000000, f: { a: 11, f: true, z: 3.5 }, z: true } }),
  )
  useF32(() => ({ f: { a: 7, f: { b: 3.5 } } }))
  useI64(() => ({ f: { a: 7, f: { b: 3 } } }))
  useScalarArm(() => (14.5))
}
go()
