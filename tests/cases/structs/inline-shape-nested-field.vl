// @run
// @log 7
// @log 8
// @log 10
// @log 42
// @log 2
// @log 7
// A struct field whose type is an INLINE SHAPE (`type Box = { inner: {x:i32} }`) now lowers — the
// nominal `inner: Inner` form already worked. This is the structural-tolerant-emitter step: the field
// interner resolves the inline shape STRUCTURALLY (`structIndexOfTypeName`) instead of only by declared
// name (`structIndexByName`/`nameIsStructDecl`).
//
// The shape is interned BEFORE the struct decls that reference it (a `collectNestedFieldShapes` pre-pass
// — it can't be interned mid-`collectS` field loop without corrupting the flat `sField*` arrays). The
// pre-pass is a no-op for a program with no inline-shape fields (the compiler itself), so its struct
// layout — and the self-compile fixpoint — is unchanged.

type Box = { inner: { x: i32 } }
type Pair = { a: { x: i32 }, b: i32 }
type Deep = { a: { b: { c: i32 } } }
type NBox = { inner: { x: i32 } | null }

function go() {
  // Read a nested inline-shape field.
  const b: Box = { inner: { x: 7 } }
  print(b.inner.x) // 7

  // Two fields (one inline-shape, one scalar) + a nested write.
  const p: Pair = { a: { x: 3 }, b: 5 }
  print(p.a.x + p.b) // 8
  p.a.x = 10
  print(p.a.x) // 10

  // Three levels of inline nesting.
  const d: Deep = { a: { b: { c: 42 } } }
  print(d.a.b.c) // 42

  // An array of structs whose field is an inline shape.
  const bs: Box[] = [{ inner: { x: 1 } }, { inner: { x: 2 } }]
  print(bs[1].inner.x) // 2

  // A nullable inline-shape field, narrowed.
  const nb: NBox = { inner: { x: 7 } }
  if nb.inner != null {
    print(nb.inner.x) // 7
  }
}

go()
