// @run
// @log 2.5
// @log 1.5
// @log OTHER
// A NULLABLE inline shape whose field is a MAP-member union
// (`{a: f64, f: {[string]: {f: f32}} | {w: i32}, z: i32} | null`): the `| null` niche is the
// nulstruct machinery's, but the BASE shape's field union must still register
// (`registerInlineUnion`'s nullable single-shape descent) — un-registered, the field coded -1,
// the base shape failed to intern, and the init literal found no struct. Covers the map arm
// (narrowed map read of an f32-valued struct map) and the struct arm through the same field.
function go() {
  const h: {[string]: {f: f32}} = Map()
  h["k"] = {f: 2.5}
  const v: {a: f64, f: {[string]: {f: f32}} | {w: i32}, z: i32} | null = {a: 1.5, f: h, z: 3}
  if v != null {
    const t0 = v.f
    if t0 is {[string]: {f: f32}} {
      const t1 = t0["k"] ?? {f: 0.5}
      print(t1.f)
    } else {
      print("OTHER")
    }
    print(v.a)
  } else {
    print("NULL")
  }
  const w: {a: f64, f: {[string]: {f: f32}} | {w: i32}, z: i32} | null = {a: 0.5, f: {w: 7}, z: 1}
  if w != null {
    const t2 = w.f
    if t2 is {[string]: {f: f32}} {
      print("MAP")
    } else {
      print("OTHER")
    }
  } else {
    print("NULL")
  }
}
go()
