// @run
// @log 9
// @log 8
// @log 5
// @log -1
// @log true
// @log 2.5
// @log 8
// A struct field typed as an inline shape whose field is a REF LIST — `N[]` (struct element),
// `(i32 | null)[]` / `(f64 | null)[]` (nullable-scalar element), `(string | i32)[]` (value-union
// element) — now lowers. `internInlineShape` stored an EMPTY element name for a ref-list (code 5) field
// (it special-cased only codes 15/16/19), so `sFieldRefSlot` → `rlSlotByName("")` → -1 and the read
// failed ("receiver is not a struct") or the value mis-built (invalid wasm). Now it records the canonical
// element name (and interns a value-union element's box reps), and `collectA`'s struct-table scan interns
// each ref-list field's element (an inline field's element is never a standalone TypeRef `collectA` sees)
// + forces `rlUsed`/`raUsed`. The NOMINAL `type Box = { f: N[] }` form already worked; this brings the
// inline-shape form to par. Found by the rep-composition fuzzer (#667); closed the last invalid-wasm holes.

type Node = { x: i32 }

function go() {
  // Struct-element ref list — multi-element + index + nested struct field.
  const a: { f: Node[] } = { f: [{ x: 7 }, { x: 9 }] }
  print(a.f[1].x) // 9
  const a2: { f: { g: Node[] } } = { f: { g: [{ x: 8 }] } }
  print(a2.f.g[0].x) // 8

  // Nullable-i32 element list — non-null and null reads.
  const b: { f: (i32 | null)[] } = { f: [5, null] }
  const b0 = b.f[0]
  if b0 != null {
    print(b0) // 5
  } else {
    print(-1)
  }
  const b1 = b.f[1]
  if b1 != null {
    print(b1) // -1
  } else {
    print(-1)
  }

  // Value-union element list.
  const c: { f: (string | i32)[] } = { f: [5] }
  const c0 = c.f[0]
  print(c0 is i32) // true

  // Nullable-f64 element list.
  const d: { f: (f64 | null)[] } = { f: [2.5] }
  const d0 = d.f[0]
  if d0 != null {
    print(d0) // 2.5
  } else {
    print(-1.0)
  }

  // Two ref-list fields (struct element + scalar) coexisting.
  const e: { a: Node[], b: i32 } = { a: [{ x: 3 }], b: 5 }
  print(e.a[0].x + e.b) // 8
}

go()
