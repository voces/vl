// Regression: a struct-FIELD closure returning a struct with a PLAIN-STRUCT-ELEMENT
// LIST field (`{f: () => {a: i32, f: {a: string, f: i32, z: f64}[], z: f32}}`).
// `structElemFieldsPlain` had no TyArray arm, so the canon record declined, the field
// lambda stayed un-pinned, and its result-struct resolution fieldset-collided onto its
// OWN list-element twin row (`{a, f, z}` on both) — the f32 `z` field took the element
// row's f64 code: INVALID-WASM (fuzz post-#996 sweep plain leg, seed 849016038
// case_00055/00056; pre-existing). List fields (prim / litunion / plain-struct
// elements) now admit; the named-fn spelling lowers already.
// @run
// @log 3
// @log 3.5
// @log dx
// @log 2.5
const g: {f: () => {a: i32, f: {a: string, f: i32, z: f64}[], z: f32}} = {
  f: () => ({ a: 11, f: [{ a: "dx", f: 3, z: 2.5 }], z: 3.5 }),
}
function go() {
  print(g.f().f[0].f)
  const v = g.f()
  print(v.z)
  print(v.f[0].a)
  print(v.f[0].z)
}
go()
