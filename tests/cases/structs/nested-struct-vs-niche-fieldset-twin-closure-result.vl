// Regression: a nullable CLOSURE result struct with two SAME-FIELDSET `{f}` fields — one
// a NICHE-scalar struct (`{f: boolean | null}`, field code 21) and one a NESTED-struct
// struct (`{f: {a: boolean}}`, field code 15). The lambda's self-inferred `#anon` result
// resolved its `{f: {a: false}}` field value against the FIRST same-fieldset row (the
// niche twin) via `structIndexOfObjCtx`'s name-only field match — so the result struct's
// ref-typed field took the niche's i32 slot and the correct annotation struct TWINNED
// onto the wrong `#anon` layout: INVALID WASM at the nested `struct.new`
// ("expected (ref null $type), found (ref $type)"). The literal-vs-annotation twin only
// diverges through the CLOSURE-result path (a plain binding / annotated return already
// resolved correctly). `structIndexOfObjCtxGo` now discriminates a nested-struct field
// VALUE (code 15) against a scalar/niche field code. Fuzz sweep 3aJP7v multiobs, seed
// 250447487 (p2c/p2r), the nul-litunion-field + nested-`{f}`-twins closure result.
// @run
// @log false
// @log NONE
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// @hint Intentionally-unused parameter `_q2`
function makeIt(): (i32, i32, i32) => {a: {f: boolean | null}, f: {f: {a: boolean}}} | null {
  return (_q0, _q1, _q2) => ({ a: { f: null }, f: { f: { a: false } } })
}
function go() {
  const v = makeIt()
  const t0 = v(1, 1, 1)
  if (t0 != null) {
    print(t0.f.f.a)
    const t1 = t0.a.f
    if (t1 != null) { print(t1) } else { print("NONE") }
  } else {
    print("NONE")
  }
}
go()
