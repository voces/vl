// @log 2
// @log -9
// @log -1
// @log 6
// @run
// `recv?.field ?? default` where the RECEIVER is a nullable-struct FIELD read (`n.next`), not
// just a bare name. The lowering existed only for an Ident receiver; a member-chain receiver
// fell to "`??` is only supported on a map index get". `optRecvReReadable` now accepts any
// re-readable PLACE (a name, or a member chain bottoming out in a name — an effect-free
// struct.get), so it is re-read safely in the null-test + field arms. Nested chains
// (`a.next?.next?.val`) compose through the existing niche-link handling.

type N = { val: i32, next: N | null }

function go() {
  const a: N = { val: 1, next: { val: 2, next: null } }
  print(a.next?.val ?? -1) // 2  (next present)
  print(a.next?.next?.val ?? -9) // -9 (next.next is null)

  const b: N = { val: 5, next: null }
  print(b.next?.val ?? -1) // -1 (next null → default)

  // the value arm is used (non-default) and feeds further arithmetic.
  const c: N = { val: 0, next: { val: 4, next: null } }
  print((c.next?.val ?? 0) + 2) // 6
}
go()
