// @run
// @log 42
// @log 7
// @log 9
// @log hi
// Inline-shape structs whose field NAMES REPEAT across nesting levels (`{f:{f:{f:i32}}}`) now intern as
// distinct structs. The structural dedup (`annShapeIndexOf`) keyed only on each field's NAME + type
// CODE — but a recursively-nested same-name field produces an identical (name `f`, code 15 = nested
// struct) signature at every level, so the OUTER `{f:{f:{f:i32}}}` collapsed onto the MIDDLE
// `{f:{f:i32}}` (same name+code) and emission failed. The dedup now also compares the field's ELEMENT
// type, so two same-name/same-code fields with different nested elements stay distinct. (#665's `Deep`
// used distinct names a/b/c, so it never exercised this.)

function go() {
  const v3: { f: { f: { f: i32 } } } = { f: { f: { f: 42 } } }
  print(v3.f.f.f) // 42

  const v2: { f: { f: i32 } } = { f: { f: 7 } }
  print(v2.f.f) // 7

  // Four levels, same name throughout.
  const v4: { f: { f: { f: { f: i32 } } } } = { f: { f: { f: { f: 9 } } } }
  print(v4.f.f.f.f) // 9

  // Same-name nesting with a non-i32 leaf.
  const vs: { f: { f: string } } = { f: { f: "hi" } }
  print(vs.f.f) // hi
}

go()
