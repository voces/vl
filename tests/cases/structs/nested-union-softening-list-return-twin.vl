// Regression (return sibling of nested-union-softening-list-elem-twin): a function returns
// the inline-spelled array `{f: {f: f32 | string | {q: i64}}}[]` while a dead `type T0`
// alias registers the same shape — the inner `{f: union}` and outer `{f: {f: union}}` rows
// share the `{f}` fieldset. The `return [{f: {f: "other"}}]` literal's inner union field
// softens to `string`, mis-resolving the outer element onto the inner twin row: INVALID-WASM
// in `makeIt` (fuzz sweep uM8vds declared leg, seed 15384050 case_00218). The union-softening
// `recordRepTyAdopt` re-stamp corrects the emitter's structural row resolver.
// @run
// @log s
// @log 7
type T0 = {f: {f: f32 | string | {q: i64}}}
function makeIt(): {f: {f: f32 | string | {q: i64}}}[] {
  return [{ f: { f: "s" } }, { f: { f: { q: 7 } } }]
}
function go() {
  const v: {f: {f: f32 | string | {q: i64}}}[] = makeIt()
  const a = v[0].f.f
  if a is string { print(a) } else { print("NOTSTR") }
  const b = v[1].f.f
  if b is f32 { print("F32") }
  else if b is string { print("STR") }
  else { print(b.q) }
}
go()
