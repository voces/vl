// @run
// @log 5
// @log 7
// @log 9
// A struct FIELD whose type is a 2-D array now lowers — a value-union inner (`(i32|null)[][]`) and a
// struct inner (`{g:i32}[][]`). The field is a ref-list (code 5) whose ELEMENT is a NESTED ref array
// (kind 9), so `emitObj` must seed the value with `pendingListKind = 5` (build a ref list THROUGH the
// slot, like a `<ref-array>[]` local) — not `1` (struct), which mis-built the array elements as structs
// and emitted invalid wasm (the last construct-side soundness hole). The deep value-union `(i32|null)`
// inside the field is also registered via the recursive `internShapeDeep` (it peels to the leaf and
// registers the box, without mis-peeling the `| null` union atom). Found by the rep-composition fuzzer.

function go() {
  // value-union inner — construct + narrowed read.
  const a: { f: (i32 | null)[][] } = { f: [[5]] }
  const r = a.f[0]
  const x = r[0]
  if x != null {
    print(x) // 5
  } else {
    print(-1)
  }

  // struct inner — double index + field.
  const b: { f: { g: i32 }[][] } = { f: [[{ g: 7 }], [{ g: 8 }, { g: 9 }]] }
  print(b.f[0][0].g) // 7
  print(b.f[1][1].g) // 9
}

go()
