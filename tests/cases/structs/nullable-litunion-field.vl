// @run
// @log bb
// @log NULL
// @log cc
// @log aa
// @log NULL
// @log bb
// @log NULL
// @log 7
// A PLAIN struct field that is a NULLABLE LITERAL UNION (`f: K0 | null`) reps as the
// i32 atom NICHE with the spare value `-1` = `null` (field code 30, the field analogue
// of the standalone `K0 | null` binding niche): a member literal constructs as its
// interned atom id, `null` (written or omitted) as `-1`, a field read binds the niche
// (`exprNulLitUnion`'s Member arm) so `!= null` narrows against `-1` and `print` widens
// the atom to its member string. Covers the mixed-rep decoy struct (i64 + f32 siblings),
// the array-of-structs element read, the nested `{f: {f: K0 | null}}` return, the module
// GLOBAL, a param, field ASSIGN (null and member), and the omitted-field completion.
// rep-fuzz p0c/p0r `{a: string, f: K0 | null, z: f32}`, p0c/p0r
// `{a: i64, f: K0 | null, z: f32}[]`, p2c/p2r `{f: {f: K0 | null}}`,
// p2c/p2r `{f: {a: i64, f: {f: K0 | null}, z: f32}}` (were REJECT:
// "binding's inline-shape type has an unsupported field").
type K0 = "aa" | "bb" | "cc"
type S = {a: i32, f: K0 | null}

function mk(): {f: {a: i64, f: {f: K0 | null}, z: f32}} {
  return { f: { a: 6000000000, f: { f: "cc" }, z: 1.5 } }
}

function useIt(p: {f: K0 | null}) {
  const t = p.f
  if t != null { print(t) } else { print("NULL") }
}

const g: { a: string, f: K0 | null, z: f32 } = { a: "x", f: "aa", z: 2.5 }

function go() {
  // Array-of-structs element read (the i64 + f32 decoy siblings exercise the mixed reps).
  const v: { a: i64, f: K0 | null, z: f32 }[] = [
    {
      a: 6000000000,
      f: "bb",
      z: 1.5,
    },
  ]
  const t0 = v[0].f
  if t0 != null {
    print(t0) // bb
  } else {
    print("NULL")
  }

  // A `null` field value in a multi-field literal.
  const w: { a: string, f: K0 | null, z: f32 } = { a: "y", f: null, z: 3.5 }
  const t1 = w.f
  if t1 != null {
    print(t1)
  } else {
    print("NULL") // NULL
  }

  // Nested `{f: {f: K0 | null}}` through a named-function return.
  const m = mk()
  const t2 = m.f.f.f
  if t2 != null {
    print(t2) // cc
  } else {
    print("NULL")
  }

  // The module GLOBAL.
  const t3 = g.f
  if t3 != null {
    print(t3) // aa
  } else {
    print("NULL")
  }

  // A param position, with the alias spelling.
  useIt({ f: null }) // NULL

  // Field ASSIGN: a member RHS lowers as its atom id, a `null` RHS as the -1 sentinel.
  const s: S = { a: 7, f: null }
  s.f = "bb"
  const t4 = s.f
  if t4 != null {
    print(t4) // bb
  } else {
    print("NULL")
  }
  s.f = null
  const t5 = s.f
  if t5 != null {
    print(t5)
  } else {
    print("NULL") // NULL
  }

  print(s.a) // 7
}
go()
