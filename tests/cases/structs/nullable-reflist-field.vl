// @run
// @log 7
// @log -1
// @log 9
// @log 5
// A struct FIELD typed as a NULLABLE ref list — `S[] | null` (nominal), `{g:i32}[] | null` (inline-shape),
// `(i32|null)[] | null` (value-union element) — now lowers (field code 28, the ref-list analogue of code
// 18's nullable i32-list). Storage is `(ref null $elemWrapper)`; the value builds the list or `null`
// (`ref.null $elemWrapper`); the READ binds `const t = v.f` as the kind-18 nullable-ref-array local and
// narrows `t != null`. A buried inline shape / value union is interned via the recursive `internShapeDeep`
// (run BEFORE classification so `nameFieldCode` recognizes the ref array). Also fixes `nullablePartOf` to
// count parens (so `(i32|null)[] | null` splits at the OUTER `| null`, not the union atom). Found by the
// rep-composition fuzzer (#667).

type Node = { x: i32 }

function go() {
  // Nominal struct element, present + null.
  const a: { f: Node[] | null } = { f: [{ x: 7 }] }
  const ta = a.f
  if ta != null {
    print(ta[0].x) // 7
  } else {
    print(-1)
  }
  const a2: { f: Node[] | null } = { f: null }
  const ta2 = a2.f
  if ta2 != null {
    print(ta2[0].x) // -1
  } else {
    print(-1)
  }

  // Inline-shape struct element.
  const b: { f: { g: i32 }[] | null } = { f: [{ g: 8 }, { g: 9 }] }
  const tb = b.f
  if tb != null {
    print(tb[1].g) // 9
  } else {
    print(-1)
  }

  // Value-union element (nested narrowing).
  const c: { f: (i32 | null)[] | null } = { f: [5] }
  const tc = c.f
  if tc != null {
    const e = tc[0]
    if e != null {
      print(e) // 5
    } else {
      print(-2)
    }
  } else {
    print(-1)
  }
}

go()
