// Regression: a list literal `[{f: {f: null}}]` bound to a NESTED-alias element
// annotation (`{f: {f: i64 | null}}[]`, where `type T0` also registers the pair) whose
// inner/outer rows share the ONE-field fieldset `{f}`. The literal's own checked type
// carried a bare-`null` HOLE (`{f: {f: null}}` — covariantly assignable, so the
// literal-aware adoption never ran), and the ambiguity resolver's canon key read the
// hole render as a proven mismatch against EVERY row — first-match fell to the INNER
// row and the element built one level short: INVALID-WASM (fuzz sweep7 declared leg,
// seed 129301940 case_00201). `recordNullHoleObjAdopt` now re-stamps the literal with
// the DESTINATION type, and `structIndexOfObjCtx`'s ambiguity arm retries the
// CANONICAL render (the spaced render spells the nullable field `i64?`).
// @run
// @log NULL
type T0 = {f: {f: i64 | null}}
function useTwin(p: T0[]) {
  const t0 = p[0].f.f
  if (t0 != null) { print(t0) } else { print("NULL") }
}
function go() {
  const w: {f: {f: i64 | null}}[] = [{ f: { f: null } }]
  useTwin(w)
}
go()
