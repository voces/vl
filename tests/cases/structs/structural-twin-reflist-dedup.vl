// @run
// @log 42
// @log 10
// @log 10
// @log 30
// @log 10
// @log 6
// @log 6
// @log 9000000000
// STRUCTURAL REF-LIST DEDUP (roadmap Next#1, ref-list layer). Extends the struct
// heap-type dedup to the ref-LIST table. A ref-list's (backing, wrapper) pair —
// `(array (mut (ref null $elem)))` + `{backing, len, cap}` — is structurally uniform
// across every element kind, so two slots with the same element heap emit identical
// pairs. After struct dedup `A[]` and `B[]` already resolve to the same element heap
// (`sHeapIdx[A] == sHeapIdx[B]`), yet each interned its OWN list-wrapper type — so a
// `B[]` passed where an `A[]` is expected mismatched the wrapper `(ref $S)` (valid
// checker program, invalid wasm). Slots now dedup by resolved element heap (`rlTwin`
// → shared `rlBackIdx`/`rlWrapIdx`), so every crossing below is one `(ref $wrapper)`.
type A = { v: i32 }
type B = { v: i32 }

// PARAM: a `B[]` passed to an `A[]`-typed parameter.
function sumA(list: A[]) {
  let t = 0
  let i = 0
  while i < list.length { t = t + list[i].v; i = i + 1 }
  return t
}
const bs: B[] = [{ v: 5 }, { v: 7 }, { v: 30 }]
print(sumA(bs))                // 42

// RETURN: a function typed `A[]`, its result bound to a `B[]`.
function mkAs(): A[] { return [{ v: 1 }, { v: 9 }] }
const back: B[] = mkAs()
print(back[0].v + back[1].v)   // 10
print(sumA(back))              // 10

// FIELD: a struct field typed `A[]`, constructed and read through `B` values.
type Bag = { items: A[] }
const bag: Bag = { items: bs }
print(bag.items[2].v)          // 30
function bagSum(x: Bag) { return sumA(x.items) }
print(bagSum({ items: back })) // 10

// NESTED: `A[][]` vs `B[][]` — the inner slot's dedup propagates to the outer one.
function sumAA(rows: A[][]) {
  let t = 0
  let i = 0
  while i < rows.length {
    let j = 0
    while j < rows[i].length { t = t + rows[i][j].v; j = j + 1 }
    i = i + 1
  }
  return t
}
const grid: B[][] = [[{ v: 1 }, { v: 2 }], [{ v: 3 }]]
print(sumAA(grid))             // 6

// NON-TWIN CONTROL: `i32[]` and `i64[]` resolve to DIFFERENT element heaps, so they
// keep distinct list wrappers (the i64 list is not read through the i32 wrapper).
function sumI32(xs: i32[]) {
  let t = 0
  let i = 0
  while i < xs.length { t = t + xs[i]; i = i + 1 }
  return t
}
function sumI64(xs: i64[]): i64 {
  let t: i64 = 0
  let i = 0
  while i < xs.length { t = t + xs[i]; i = i + 1 }
  return t
}
print(sumI32([1, 2, 3]))                    // 6
print(sumI64([5000000000, 4000000000]))     // 9000000000
