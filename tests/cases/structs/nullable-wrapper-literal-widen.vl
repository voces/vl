// @run
// @log 2585.5
// @log a
// @log y
// @log 2585.5
// A struct LITERAL widens into a `T | null` target exactly as it does into a bare `T`. The
// literal-aware `assignableExpr` ObjLit path peels a NULLABLE wrapper before the field-wise
// recursion (the object dual of the ArrayLit nullable peel), so a re-encodable field literal
// reaches its target: an `f32` field literal re-encodes exactly at f32, and a string literal
// matches a litunion field member. Standalone `{f: f32}` / `{f: "a"|"b"}` already widened; the
// nullable wrapper was the specific blocker. This is LITERAL widening (exactly representable) —
// a genuinely-wider VALUE is still rejected (see `types/nullable-wrapper-lossy-reject.vl`).
// Covers f32 field, litunion field (aliased + inline), and the nested return / param positions.

type K = "a" | "b"

function mk(): {f: f32} | null {
  return {f: 2585.5}
}

function take(p: {f: f32} | null) {
  if p != null {
    print(p.f) // 2585.5
  }
}

function go() {
  const a: {f: f32} | null = {f: 2585.5}
  if a != null {
    print(a.f) // 2585.5
  }

  const b: {f: K} | null = {f: "a"}
  if b != null {
    print(b.f) // a
  }

  const c: {f: "x" | "y"} | null = {f: "y"}
  if c != null {
    print(c.f) // y
  }

  take(mk())
}

go()
