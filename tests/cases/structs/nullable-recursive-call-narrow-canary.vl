// @run
// @log n
// COMPILE-TIME CANARY (functional pin; no timing harness exists, so this documents the
// probe rather than gating on wall clock). A `const p = f()` binding of an ANNOTATED
// `S | null` return, where `S` is a struct with TWO recursive fields, once made EVERY
// narrowing consult of `p` render `S` structurally — `tyToStr` doubles per depth level
// (~5 K chars at the depth-8 cap) — and then re-walk that render through
// `splitUnionAtoms`'s per-code-point concat: O(len²) per consult, re-run per statement
// scan. THIS 40-line file took ~14 s of compile (a 27-field `Slot` variant took ~54 s;
// #912's fuzzgen: 62 s vs master's 3 s). Fixed by `retAtomsCheap` (decline a
// composite-leaf union in `valueUnionRetName` WITHOUT rendering) + slice-based
// `splitUnionAtoms`; now ~70 ms. If this case ever slows the corpus sweep noticeably,
// that class regressed — see the fix commit for the two sites and their shapes.
type S = {
  child: S | null,
  kids: S[],
  f0: string,
  f1: string,
  f2: string,
  f3: string,
  f4: string,
  f5: string,
  f6: string,
  f7: string,
  f8: string,
  f9: string,
}
function mk(): S {
  return {
    child: null,
    kids: [],
    f0: "x",
    f1: "x",
    f2: "x",
    f3: "x",
    f4: "x",
    f5: "x",
    f6: "x",
    f7: "x",
    f8: "x",
    f9: "x",
  }
}
function pick(s: S): S | null { return s.child }
function go(): string {
  const s = mk()
  const p = pick(s)
  let out = ""
  if p == null { return "n" }
  if s.f0 == "a" { out = out + s.f1 }
  if s.f1 == "a" { out = out + s.f2 }
  if s.f2 == "a" { out = out + s.f3 }
  if s.f3 == "a" { out = out + s.f4 }
  if s.f4 == "a" { out = out + s.f5 }
  return out
}
print(go())
