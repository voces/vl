// @run
// @log 5
// @log 42
// Reading a nullable-i32-list FIELD (`i32[] | null`, code 18) into an UN-ANNOTATED binding and narrowing
// it now works. `const t = v.f` took a non-null list kind because `letIsNulList` only consulted the
// binding's annotation — never the initializer — so the binding missed the nullable-list kind and
// `t != null` emitted a bare `null` with no list context ("bare null needs a struct-typed context"). The
// new `letIsNulListInfer` also infers from the init (`exprNullableList`, which already recognizes a code-18
// field read), mirroring `letIsNulString`'s init fallback. Found by the rep-composition fuzzer (#667).

function go() {
  const v: { f: i32[] | null } = { f: [5] }
  const t = v.f
  if t != null {
    print(t[0]) // 5
  } else {
    print(-1)
  }

  // `== null` narrowing form, list present → the else arm reads it.
  const w: { g: i32[] | null } = { g: [42, 43] }
  const u = w.g
  if u == null {
    print(-1)
  } else {
    print(u[0]) // 42
  }
}

go()
