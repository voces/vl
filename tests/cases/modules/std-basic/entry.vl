// The `std:` scheme end to end: the specifier resolves VERBATIM as the module
// key and the reader layer maps it to `std/seed.vl` (the repo dir in the TS
// host, $VL_STD / the exe-relative std dir in the native host). `std:seed` is
// the plumbing-only seed module (docs/std-design.md slice 1).
import { stdSmoke } from "std:seed"

print(stdSmoke())
