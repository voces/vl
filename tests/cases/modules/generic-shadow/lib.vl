// A top-level type named `T` coexists with generics whose type PARAMETER is
// also `T`: inside `pick<T>`'s annotations the segment `T` names the parameter
// and must NOT rewrite to the renamed top-level `T`.
export type T = { q: i32 }

function pick<T>(x: T): T x

export function pickQ(t: T): i32 {
  let v = pick(t)
  return v.q
}
