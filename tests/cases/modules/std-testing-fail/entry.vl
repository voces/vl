// @trap
// A failed `std:test` assertion ABORTS via `__trap__()` (std-design D5's
// record-print-trap, trap half): the first failing matcher stops the file with
// a wasm trap, so the trailing marker never runs. The passing assertion before
// it establishes that only the FAILING one trips the abort. (The mapped trap
// REASON is shared with every `__trap__`/bounds-check site — all lower to
// `unreachable` — so only the trap itself is pinned, not a message.)
import { expectI32, toEqual } from "std:test"

expectI32(1 + 1).toEqual(2)
expectI32(2 + 2).toEqual(5)
print("unreachable marker")
