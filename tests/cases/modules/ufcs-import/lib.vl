// An imported module exporting free `self`-functions used via UFCS from the
// entry. A `self`-function's FIRST parameter is named `self`, so the entry may
// dispatch `recv.fn(args)` as `fn(recv, args)` even across the module merge —
// the merge mangles `fn` (`shout` → `shout$mN`) but resolves the call's plain
// property back to the mangled function.
export function shout(self: string): string {
  return self + "!"
}

// A `self`-function WITH explicit arguments: the receiver fills `self`, the
// remaining arguments bind positionally after it.
export function lead(self: string, n: i32, fill: string): string {
  let out = ""
  let i = 0
  while i < n {
    out = out + fill
    i = i + 1
  }
  return out + self
}

// A VALUE-UNION receiver `self`-function: `(5).toStr()` / `true.toStr()`.
export function toStr(self: i32 | boolean): string {
  if self is i32 {
    return "i" + toString(self)
  }
  return "b"
}

// A `self`-function dispatched with NAMED arguments: the receiver is the unnamed
// slot-0 positional, the named arguments bind after it in parameter order.
export function band(self: string, pre: string, post: string): string {
  return pre + self + post
}
