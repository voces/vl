// @run
// @log hi!
// @log ---x
// @log i5
// @log b
// @log <mid>
// Cross-module UFCS: an IMPORTED free `self`-function called as a method on the
// receiver. Covers a string-receiver method, a method with extra arguments, a
// value-union receiver, and a named-argument dispatch — each resolving the plain
// call property back to the merge-mangled function.
import { shout, lead, toStr, band } from "./lib"

print("hi".shout())          // shout("hi")        = hi!
print("x".lead(3, "-"))      // lead("x", 3, "-")  = ---x
print((5).toStr())           // toStr(5)           = i5
print(true.toStr())          // toStr(true)        = b
print("mid".band(post: ">", pre: "<"))  // band("mid","<",">") = <mid>
