// @run
// @log 2
// @log -1
// @log 3
// @log true
// @log false
// @log 2
// @log 1
// @log true
// @log 0
// @log 1
// @log 80
// @log abc
// `std:array` exercised end to end through the `std:` scheme as generic UFCS
// methods on bound receivers: the SEARCH family — `indexOf` (hit + miss),
// `lastIndexOf`, `includes` (true / false), `count` — and `reduce` (an i32 sum and
// a string-accumulator fold), the same generic definitions serving `i32[]` and
// `string[]` (`==` resolves per element type; the closure param monomorphizes).
import { count, includes, indexOf, lastIndexOf, reduce } from "std:array"

const xs = [10, 20, 30, 20]
print(xs.indexOf(30))     // 2
print(xs.indexOf(99))     // -1 (absent)
print(xs.lastIndexOf(20)) // 3 (last match)
print(xs.includes(20))    // true
print(xs.includes(99))    // false
print(xs.count(20))       // 2

// The SAME generic definitions over a `string[]` receiver.
const ss = ["a", "b", "c"]
print(ss.indexOf("b"))    // 1
print(ss.includes("c"))   // true
print(ss.count("z"))      // 0
print(ss.count("a"))      // 1

// `reduce`: an i32 sum and a string fold (the generic closure param `(A, T) => A`
// monomorphizes per accumulator/element shape).
print(xs.reduce((a: i32, b: i32) => a + b, 0))         // 80
print(ss.reduce((acc: string, s: string) => acc + s, "")) // abc
