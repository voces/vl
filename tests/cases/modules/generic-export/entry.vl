// @run
// @log 1
// @log s
// @log 9
// @log hi
// Imports a generic function and a generic type alias and instantiates them at
// several shapes (i32, string) — the monomorphizer clones the imported generic
// per call shape from the merged program.
import { id, Box, unbox } from "./lib"

let bi: Box<i32> = { v: 9 }
let bs: Box<string> = { v: "hi" }
print(id(1))
print(id("s"))
print(unbox(bi))
print(unbox(bs))
