// Exports a generic function and a generic type alias. Importers instantiate
// both — per-call-shape monomorphization happens AFTER the module merge, so the
// mangled generic declarations must still resolve at every instantiation site.
export type Box<T> = { v: T }

export function id<T>(x: T): T x

export function unbox<T>(b: Box<T>): T b.v
