// @run
// @log 20
// @log 13
// @log 5
// Same-named private decls in two files do not collide.
import { fromUtil } from "./util"

type Tok = { name: i32 }

function helper(n: i32) {
  return n * 10
}

let t: Tok = { name: 5 }
print(helper(2))       // entry helper: 20
print(fromUtil(3))     // util helper(3)=4 + t.kind 9 = 13
print(t.name)          // entry's Tok: 5
