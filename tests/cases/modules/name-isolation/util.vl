// Private `helper` and private type `Tok` share names with the entry module's
// own private declarations but must NOT collide in the merged program.
type Tok = { kind: i32 }

function helper(n: i32) {
  return n + 1
}

export function fromUtil(n: i32) {
  let t: Tok = { kind: 9 }
  return helper(n) + t.kind
}
