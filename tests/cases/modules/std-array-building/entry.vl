// @run
// @log 30
// @log 10
// @log 5
// @log 50
// @log 32
// @log c
// @log 3.5
// @log 4
// `std:array` BUILDING family through the `std:` scheme — the generic methods that
// return a NEW list, now that a generic `const out: T[] = []` + `out.push(…)`
// propagates the element type `T` through monomorphization. `reverse` / `concat`
// (over `i32[]`, `string[]`, `f64[]` — one definition each), `mapIndexed` (a map
// with the element index, result type differing from the element), and `reduce`
// with an `f64` accumulator (previously deferred). The element type flows from each
// call's receiver, so `reverse` serves i32 AND string AND f64 in one program.
import { concat, mapIndexed, reduce, reverse } from "std:array"

const xs = [10, 20, 30]
const r = xs.reverse() // [30, 20, 10]
print(r[0])            // 30
print(r[2])            // 10

const c = xs.concat([40, 50]) // [10, 20, 30, 40, 50]
print(c.length)               // 5
print(c[4])                   // 50

// `mapIndexed`: f(element, i) — here element + index.
const mi = xs.mapIndexed((v: i32, i: i32) => v + i) // [10, 21, 32]
print(mi[2])                                        // 32

// the SAME generic `reverse` over a `string[]` and an `f64[]`.
print(["a", "b", "c"].reverse()[0]) // c
print([1.5, 2.5, 3.5].reverse()[0]) // 3.5

// `reduce` with an f64 accumulator (the generic closure monomorphizes at f64).
print([1.5, 2.5].reduce((a: f64, v: f64) => a + v, 0.0)) // 4
