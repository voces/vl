// A library exporting SEVERAL generics. A consumer that imports only one of them still
// pulls the whole module's functions into the program — the unused generics must be pruned
// (never instantiated → no `T`-param decl emitted), not left to fail at emit.

export function pick<T>(self: T[], i: i32): T {
  return self[i]
}

// Never called by the consumer below — its `<T>` template must be pruned.
export function lastOf<T>(self: T[]): T {
  return self[self.length - 1]
}

// Also unused — a two-type-param generic, to cover the multi-`<T>` shape.
export function constOf<A, B>(a: A, b: B): A {
  return a
}
