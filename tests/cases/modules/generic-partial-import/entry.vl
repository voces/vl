// @run
// @log 20
// @log b
// PARTIAL GENERIC IMPORT: import ONE generic (`pick`) from a module that exports several.
// `lib`'s other generics (`lastOf`, `constOf`) are pulled into the merged program but never
// called, so the monomorphizer never instantiates them. They must be pruned to no-op stubs
// rather than emitted with un-instantiated `T` params (which fails to lower). `pick` itself
// is instantiated per call shape (`i32[]` then `string[]`).
import { pick } from "./lib"

print([10, 20, 30].pick(1))      // 20  (i32 instance)
print(["a", "b", "c"].pick(1))   // b   (string instance — same generic, second shape)
