// An imported module: exports a function and a type, and keeps a private helper
// that shares a name (`helper`) with the entry module to prove name isolation.
// Callees are defined before their callers so return types infer with no
// annotations (VL's inference-first stance; a forward/mutual ref would still
// need one).
export type Point = { x: i32, y: i32 }

// Module-private: NOT exported. Same name as the entry's `helper` — the two must
// not collide in the merged module.
function helper(n: i32) {
  return n
}

function makePoint(x: i32, y: i32) {
  return { x: x, y: y }
}

export function add(a: i32, b: i32) {
  return a + helper(b)
}

export function originX() {
  let p = makePoint(0, 7)
  return p.x
}
