// @run
// @log 6
// @log hi
// Name isolation for generics: this module declares its OWN `Pair<T>` (different
// field names than lib's) and its OWN `dup<T>` (different signature). Neither may
// collide with lib's same-named privates in the merged program.
import { sumPair } from "./lib"

type Pair<T> = { x: T, y: T }

function dup<T>(v: T): T v

let p: Pair<string> = { x: "h", y: "i" }
print(sumPair(3))
print(dup(p.x) + p.y)
