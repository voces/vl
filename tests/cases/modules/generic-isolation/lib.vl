// Private generics share names with the entry's (`Pair`, `dup`) — and DIFFER in
// shape — so the per-module rename must keep the two sets distinct after merge.
type Pair<T> = { a: T, b: T }

function dup<T>(x: T): Pair<T> {
  return { a: x, b: x }
}

export function sumPair(n: i32): i32 {
  let p = dup(n)
  return p.a + p.b
}
