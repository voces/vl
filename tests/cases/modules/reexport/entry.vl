// @run
// @log 25
// @log 27
// A RE-EXPORT `export { a, b as c } from "./mod"` re-surfaces another module's
// exports under this module's public names (the emitter aliases the merged target
// function under the bare public name — a stable wasm export). The re-exported
// names are ALSO bound locally here (the merge pulls them in), so the entry can
// call them too — exercised below.
export { square, cube as cubed } from "./math"

print(square(5)) // 25
print(cubed(3))  // 27
