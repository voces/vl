// @run
// @log all green
// `std:test` v1 exercised end to end through the `std:` scheme: the single
// union-based `expect(value)` over every value kind it covers (i32, i64, f64,
// boolean, string), `.toEqual` structural equality, `.not()` inversion, and the
// `.toBeTrue`/`.toBeFalse` boolean shorthands. Every assertion PASSES, so none
// trap; the marker prints only because execution reaches the end (a single
// failed assertion would abort before it via `__trap__`).
import { expect, not, toEqual, toBeTrue, toBeFalse } from "std:test"

const big: i64 = 5000000000
expect(2 + 2).toEqual(4)
expect(big).toEqual(big)
expect(3.5).toEqual(3.5)
expect(true).toEqual(true)
expect("ab" + "c").toEqual("abc")

expect(5).not().toEqual(6)
expect("x").not().toEqual("y")

expect(1 < 2).toBeTrue()
expect(1 > 2).toBeFalse()
expect(true).not().toBeFalse()

print("all green")
