// @run
// @log all green
// `std:test` v1 exercised end to end through the `std:` scheme: the
// struct-receiver UFCS matchers (`expectI32(x).toEqual(y)`) over every value
// type v1 covers (i32, boolean, string), `.not()` inversion, and the boolean
// `.toBeTrue`/`.toBeFalse` shorthands. Every assertion here PASSES, so none
// trap; the marker prints only because execution reaches the end (a single
// failed assertion would abort before it via `__trap__`).
import {
  expectBool,
  expectI32,
  expectStr,
  not,
  toBeFalse,
  toBeTrue,
  toEqual,
} from "std:test"

expectI32(2 + 2).toEqual(4)
expectI32(40 + 2).toEqual(42)
expectI32(5).not().toEqual(6)

expectBool(true).toEqual(true)
expectBool(1 < 2).toBeTrue()
expectBool(1 > 2).toBeFalse()
expectBool(true).not().toBeFalse()
expectBool(false).not().toBeTrue()

expectStr("ab" + "c").toEqual("abc")
expectStr("x").not().toEqual("y")

print("all green")
