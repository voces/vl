// An imported free `self`-function whose name collides with a struct's callable
// FIELD in the entry. The field must win (host precedence): a `recv.inc(x)` where
// `recv` carries a function-valued field `inc` is a member-call on that field, not
// a UFCS dispatch — even though an imported `self`-function `inc` of matching
// arity exists. The +1000 marks the imported path so a precedence slip is visible.
export function inc(self: i32, by: i32): i32 {
  return self + by + 1000
}
