// @run
// @log 42
// A struct callable FIELD named `inc` shadows the imported `self`-function `inc`:
// `o.inc(41)` calls the field (41 + 1 = 42), NOT the imported `inc` (which would
// add 1000). The merge leaves the call property plain so the receiver-type field
// check decides precedence, exactly as the host parser does at parse time.
import { inc } from "./lib"

function plusOne(x: i32) x + 1
const o = { inc: plusOne }
print(o.inc(41))
