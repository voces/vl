// @run
// @log 2
// @log 3
// @log second
// A `match` that crosses the module boundary: the entry calls an imported `match`-bodied
// function, AND a statement-position `match` in the entry calls an IMPORTED function in its
// arm. Before the `modRwExpr` MatchExpr arm, the merge rename skipped match arm bodies, so
// the imported `note` (and the merged `rank`) were undeclared after their export rename.
import { Tag, rank, note } from "./lib"

print(rank("b")) // 2  — imported match-bodied function
print(rank("c")) // 3

function dispatch(t: Tag) {
  match t {
    "a" => note("a")
    "b" => note("b") // calls the IMPORTED `note` from a match arm
    "c" => note("c")
  }
}
dispatch("b") // second
