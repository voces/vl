// Exports a litunion type + a function whose body is a `match` over it. The merge
// renames this module's `tag` to `tag$mN`; the match's arm bodies (and any name they
// reference) must be rewritten by the SAME rename walk (`modRwExpr`'s MatchExpr arm) or
// they resolve to nothing in the merged program.
export type Tag = "a" | "b" | "c"

export function rank(t: Tag): i32 {
  match t {
    "a" => 1
    "b" => 2
    "c" => 3
  }
}

export function note(t: Tag) {
  match t {
    "a" => print("first")
    "b" => print("second")
    "c" => print("third")
  }
}
