// @run
// @log 42
// @log 7
// A MULTILINE braced import bearing an interior comment, an `as` rename, and a
// trailing comma — the shapes the parser's `ImportDecl` builder must consume
// exactly as the old token skip did (a NEWLINE inside the braces is legal; the
// comment must not derail the name list; the clause ends at the path STRING).
import {
  add as plus, // the rename form
  seven,
} from "./util"

print(plus(40, 2))
print(seven())
