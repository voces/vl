// @run
// @log 0
// @log 12345
// @log -45
// @log 2147483647
// @log -2147483648
// @log 9223372036854775807
// @log -9223372036854775808
// @log true
// @log false
// @log true
// @log 007
// @log hello
// @log aba5
// @log x
// @log ababab
// @log []
// @log a, b, c
// @log []
// @log solo
// @log -
// @log 3
// @log b
// @log [hello]
// @log 2
// @log [a][b][c]
// `std:fmt` exercised end to end through the `std:` scheme as UFCS methods on
// bound receivers: exact decimal rendering at both integer widths' extremes
// (min is the classic overflow trap — its magnitude is unrepresentable), the
// union `toStr` receiver covering i32/i64 with one method, and the
// string helpers' edge cases (short width, multi-codepoint fill truncation,
// empty fill, zero repeat, empty/singleton join). Empty results print inside
// [] so the @log lines carry no trailing whitespace.
import { join, padLeft, repeat, split, toStr } from "std:fmt"

const zero = 0
print(zero.toStr())
const mid = 12345
print(mid.toStr())
const neg = -45
print(neg.toStr())
const i32max = 2147483647
print(i32max.toStr())
const i32min = -2147483647 - 1
print(i32min.toStr())
const i64max: i64 = 9223372036854775807
print(i64max.toStr())
const i64min: i64 = -9223372036854775807 - 1
print(i64min.toStr())
const yes = true
print(yes.toStr())
const no = false
print(no.toStr())
print(true.toStr())
print("7".padLeft(3, "0"))
print("hello".padLeft(3, "0"))
print("5".padLeft(4, "ab"))
print("x".padLeft(3, ""))
print("ab".repeat(3))
print("[" + "ab".repeat(0) + "]")
print(["a", "b", "c"].join(", "))
const none: string[] = []
print("[" + none.join("-") + "]")
print(["solo"].join("-"))
print(["", ""].join("-"))
print("a,b,c".split(",").length)
print("a,b,c".split(",")[1])
print("[" + "hello".split(",")[0] + "]")
print("x::y".split("::").length)
const cs = "a,b,c".split(",")
print("[" + cs[0] + "][" + cs[1] + "][" + cs[2] + "]")
