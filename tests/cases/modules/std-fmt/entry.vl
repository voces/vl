// @run
// @log 0
// @log 12345
// @log -45
// @log 2147483647
// @log -2147483648
// @log 9223372036854775807
// @log -9223372036854775808
// @log true
// @log false
// @log 007
// @log hello
// @log aba5
// @log x
// @log ababab
// @log []
// @log a, b, c
// @log []
// @log solo
// @log -
// `std:fmt` exercised end to end through the `std:` scheme: exact decimal
// rendering at both integer widths' extremes (min is the classic overflow
// trap — its magnitude is unrepresentable), and the string helpers' edge
// cases (short width, multi-codepoint fill truncation, empty fill, zero
// repeat, empty/singleton join). Empty results print inside [] so the @log
// lines carry no trailing whitespace.
import { boolToStr, i64ToStr, join, padLeft, repeat, toStr } from "std:fmt"

print(toStr(0))
print(toStr(12345))
print(toStr(-45))
print(toStr(2147483647))
const i32min = -2147483647 - 1
print(toStr(i32min))
const i64max: i64 = 9223372036854775807
print(i64ToStr(i64max))
const i64min: i64 = -9223372036854775807 - 1
print(i64ToStr(i64min))
print(boolToStr(true))
print(boolToStr(false))
print(padLeft("7", 3, "0"))
print(padLeft("hello", 3, "0"))
print(padLeft("5", 4, "ab"))
print(padLeft("x", 3, ""))
print(repeat("ab", 3))
print("[" + repeat("ab", 0) + "]")
print(join(["a", "b", "c"], ", "))
const none: string[] = []
print("[" + join(none, "-") + "]")
print(join(["solo"], "-"))
print(join(["", ""], "-"))
