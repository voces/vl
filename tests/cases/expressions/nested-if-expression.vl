// @run
// @log 1
// @log 2
// @log 3
// @log 4
// @log 7
// @log 1.5
// @log 42
// @log 9
// An if-EXPRESSION nested as an ARM of another if-expression (`if c { if d { v1 } else { v2 } } else
// { v3 }`) was rejected: the checker typed the inner-if arm's block-tail as `void` (an `IfStmt` is a
// statement node, so the block dropped its value), giving "expected i32, got void" / "void | {x}"; and
// even past that, the emitter's arm extractor rejected a non-tail-value statement.
//
// Both halves now recognize a nested if-EXPRESSION (an `IfStmt` WITH an else, value arms) as a value:
//   - checker: a trailing `IfStmt` whose `joinTys` is non-void becomes the block's tail type.
//   - emitter: the if-expression arm emitters accept it via `ifArmIsValue` (→ `emitExpr` → `emitIfExpr`),
//     kept SEPARATE from `stmtIsTailValue` so the else-less nullable function-tail path is untouched.
// Restricted to else-ful value-`if`s, so an else-less nullable tail (`function f(c){ if c {5} }`) keeps
// its own lowering.

type P = { x: i32 }

// Nested in BOTH arms, runtime conditions — the 4 leaf values.
function pick(a: i32, b: i32): i32 {
  return if a > 0 { if b > 0 { 1 } else { 2 } } else { if b > 0 { 3 } else { 4 } }
}

function go() {
  print(pick(1, 1))   // 1
  print(pick(1, -1))  // 2
  print(pick(-1, 1))  // 3
  print(pick(-1, -1)) // 4

  // Nested if-expr arm producing a STRUCT, bound and field-read.
  const p: P = if 1 > 0 { if 2 > 0 { { x: 7 } } else { { x: 8 } } } else { { x: 9 } }
  print(p.x) // 7

  // Nested if-expr arm producing an f64 (the join coerces the arms).
  const f = if 3 > 1 { if 1 > 0 { 1.5 } else { 2.5 } } else { 3.5 }
  print(f) // 1.5

  // Three levels deep.
  const d = if 1 > 0 { if 2 > 0 { if 3 > 0 { 42 } else { 1 } } else { 2 } } else { 3 }
  print(d) // 42

  // Nested in the ELSE arm.
  const e = if 1 > 5 { 0 } else { if 2 > 9 { 1 } else { 9 } }
  print(e) // 9
}

go()
