// @run
// @log checking
// @log pos
// @log nonpos
// @log 3
// @log 0
// @log 1
// @log 2
// @log done
// `;` is an OPTIONAL statement separator (it lexes as `SEMI`, which the block / top-level
// statement loops already treat exactly like a NEWLINE). It lets several statements share one
// line — a guard `if c { f(); return x }`, `;`-joined top-level decls, a loop body — and a
// trailing / doubled `;` is a no-op.

function classify(x: i32): string {
  if x > 0 { print("checking"); return "pos" }
  return "nonpos"
}

print(classify(1)) // checking, pos
print(classify(-1)) // nonpos

const a = 1; const b = 2
print(a + b) // 3

let i = 0; while i < 3 { print(i); i = i + 1 } // 0 1 2

print("done");;
