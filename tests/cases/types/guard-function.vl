// @run
// @log 7
// @log 7
// @log 7
// @log -1
// Inferred type-guard functions (A6b, degenerate case): a function whose body is
// exactly `return <narrowing-predicate-on-a-param>` becomes a guard — calling it
// in a condition narrows the argument (inline, UFCS, and the guard-clause form).
// Sound by construction: the return value *is* the predicate.
function maybe(b: i32): { x: i32 } | null {
  if b > 0 { return { x: 7 } }
  return null
}
function present(self: { x: i32 } | null): boolean { return self != null }
function absent(p: { x: i32 } | null): boolean { return p == null }

let v = maybe(1)
if present(v) { print(v.x) }      // 7 (inline guard)
if v.present() { print(v.x) }     // 7 (UFCS guard — lowers to present(v))

function use(b: i32): i32 {
  let p = maybe(b)
  if absent(p) { return -1 }   // guard-clause: p non-null below
  return p.x
}
print(use(1))   // 7
print(use(0))   // -1
