// @run
// @log 5
// @log -1
// @log -2
// @log 7
// A bare ANNOTATED nullable value-union LIST local — `(i32 | null)[] | null` — now lowers (kind 18, the
// nullable-ref-array local). The annotation's value-union inner threads `pendingListKind` 2 (so `[5]`
// boxes its bare scalar) and the inner ref-list slot through `tyAnnRefListKind`/`Slot` (now peeling the
// `| null` wrapper); a bare `null` lowers as `ref.null $innerWrapper` (`pendingNulRefHeap`); `collectA`
// forces the value-union ref-list wrapper from the nullable annotation (the `[5]` value alone would not
// collect it). Completes the nested-nullable rep family (the FIELD and ARRAY forms already worked).

function go() {
  // present, narrowed twice (outer nullable, then the union element).
  const a: (i32 | null)[] | null = [5]
  if a != null {
    const e = a[0]
    if e != null {
      print(e) // 5
    } else {
      print(-1)
    }
  } else {
    print(-1)
  }

  // a null UNION element inside a present list.
  const b: (i32 | null)[] | null = [5, null]
  if b != null {
    const e = b[1]
    if e != null {
      print(e) // -1
    } else {
      print(-1)
    }
  } else {
    print(-2)
  }

  // the whole list is null.
  const c: (i32 | null)[] | null = null
  if c != null {
    print(0)
  } else {
    print(-2) // -2
  }

  // struct inner still works.
  const d: { g: i32 }[] | null = [{ g: 7 }]
  if d != null {
    print(d[0].g) // 7
  } else {
    print(-1)
  }
}

go()
