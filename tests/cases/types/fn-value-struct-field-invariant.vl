// @error cannot assign
// A function VALUE whose return struct's field is numerically NARROWER than the slot's
// (`mk(): {f: i32}` into `const v: () => {f: i64}`) is a CLEAN reject — the object dual
// of the scalar numeric invariance inside function types (`objNumWidens` in
// `fnSlotAssignable`). A function value's functype fixes the field rep; only a lambda
// LITERAL body can re-encode (the `objRetWidenAdopt` adoption), so the named-value
// spelling must not covariantly widen (it emitted an i32-field shape every call site
// mistrusted — invalid wasm).
function mk(): {f: i32} {
  return {f: 5}
}
const v: () => {f: i64} = mk
print(v().f)
