// @run
// @log 6
// @log 10
// Mutual recursion across SEPARATE `type` declarations (ROADMAP A11): `A`
// references `B` and `B` references `A`. Neither alias is self-recursive on its
// own; the cycle passes through the *other* named type. The type algebra must
// resolve each cross-reference lazily (an `Alias` leaf, not infinite expansion)
// and codegen must build the two mutually-referential WasmGC structs in one
// rec-group. Traversal null-narrows the recursive field to recurse only into
// present links.
type A = { tag: i32, b: B | null }
type B = { tag: i32, a: A | null }

function sumA(node: A): i32 {
  let total = node.tag
  if node.b != null {
    total = total + sumB(node.b)
  }
  return total
}

function sumB(node: B): i32 {
  let total = node.tag
  if node.a != null {
    total = total + sumA(node.a)
  }
  return total
}

// A(1) -> B(2) -> A(3): 1 + 2 + 3 = 6
const a: A = { tag: 1, b: { tag: 2, a: { tag: 3, b: null } } }
print(sumA(a))

// B(4) -> A(6): 4 + 6 = 10
const b: B = { tag: 4, a: { tag: 6, b: null } }
print(sumB(b))
