// Regression: a nested type ALIAS (`type T0 = {f: {f: i32 | string | {q: i64}}}`)
// registers the INNER `{f: <union>}` row before the OUTER `{f: {f: …}}` row. An
// inline-spelled nullable binding of the OUTER shape then resolved its struct index
// through the field-name-set scan, where the code-16 (union box) candidate field was
// LENIENT against the outer's inline-shape field spelling — the outer literal adopted
// the INNER row and built one level short: INVALID-WASM (fuzz sweep3 declared leg,
// seed 128787380 case_00053). A whole-span inline-shape spelling is now a PROVEN
// mismatch against a union-box field.
// @run
// @log OTHER
// @log other
type T0 = {f: {f: i32 | string | {q: i64}}}
function useTwin(p: T0 | null) {
  const t0 = p
  if (t0 != null) {
    const t1 = t0.f.f
    if (t1 is i32) { print(t1) } else { print("OTHER") }
    const u0: i32 | string | {q: i64} = "other"
    if u0 is string { print(u0) } else { print("UOTHER") }
  } else {
    print("NULL")
  }
}
function go() {
  const w: {f: {f: i32 | string | {q: i64}}} | null = { f: { f: "other" } }
  useTwin(w)
}
go()
