// @run
// @log 3
// @log hi
// @log 2
// @log neg
// @log 1
// A value union with a LIST member (`i32[] | string`) — inline, aliased, and as a return
// type. A list isn't a scalar atom, so it rides the union box's `value` (anyref) field as
// the i32-list WRAPPER ref directly, exactly like a string member (no scalar value box).
// `valueAtomKind` gains the `i32[]` ref-atom code (7); the coerce stores the wrapper ref
// and `is i32[]` casts it back. Previously rejected at emit ("union variant names an unknown
// struct type" / "narrowed union atom has no value box").

function pick(c: boolean): i32[] | string {
  if c { return [10, 20] }
  return "neg"
}

type Cell = i32[] | string

function go() {
  // inline, both members + narrow back out.
  let u: i32[] | string = [1, 2, 3]
  if u is i32[] {
    print(u.length) // 3
  }
  u = "hi"
  if u is string {
    print(u) // hi
  }

  // as a return type.
  const a = pick(true)
  if a is i32[] {
    print(a.length) // 2
  }
  const b = pick(false)
  if b is string {
    print(b) // neg
  }

  // aliased, with the `is i32[]` false branch for a string value.
  const s: Cell = "z"
  if s is i32[] {
    print(0) // 1
  } else {
    print(1)
  }
}
go()
