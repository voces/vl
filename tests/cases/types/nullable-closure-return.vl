// @run
// @log NULL
// @log 9
// A `((i32) => i32) | null` RETURN: `return null` is the niche `ref.null $cloStruct`,
// `return <closure>` the fat pointer widened to the nullable storage. `const f = mk(n)`
// infers the kind-19 nulclosure local (a closure-CALL result), `f != null` lowers to
// `ref.is_null`, and the narrowed `f(x)` recovers non-null.
function mk(n: i32): ((i32) => i32) | null {
  if n > 0 { return (x: i32) => x * 3 } else { return null }
}
function callIt(n: i32) {
  const f = mk(n)
  if f != null { print(f(3)) } else { print("NULL") }
}
function go() {
  callIt(0)
  callIt(1)
}
go()
