// @run
// @log 10
// @log 22
// A recursive structural type (ROADMAP A11): the alias `Tree` refers to itself
// through its `left`/`right` fields. The type algebra resolves the self-reference
// lazily (an `Alias` leaf, not infinite expansion) and codegen builds a
// self-referential WasmGC struct. Traversal uses null-narrowing on the recursive
// field (`if node.left != null { … }`) to recurse only into present children.
type Tree = { value: i32, left: Tree | null, right: Tree | null }

function sum(node: Tree): i32 {
  let total = node.value
  if node.left != null {
    total = total + sum(node.left)
  }
  if node.right != null {
    total = total + sum(node.right)
  }
  return total
}

let root: Tree = {
  value: 1,
  left: { value: 2, left: null, right: null },
  right: { value: 3, left: { value: 4, left: null, right: null }, right: null }
}
// 1 + 2 + 3 + 4 = 10
print(sum(root))

// A deeper tree, accumulated the same way: 5 + 6 + 7 + 4 = 22.
let bigger: Tree = {
  value: 5,
  left: { value: 6, left: { value: 4, left: null, right: null }, right: null },
  right: { value: 7, left: null, right: null }
}
print(sum(bigger))
