// @run
// @log 5
// @log true
// @log 999
// @log 42
// @log 7
// @log 13
// @log true
// A *value* union of same-representation members (`boolean | i32`, `i32 | null`)
// is a boxed `{ tag, value }` GC struct: the tag selects the variant, narrowing
// (`is T` / `== null`) reads the tag and unboxes the payload. (binaryen's
// Heap2Local scalarizes the box where it doesn't escape, so the common path
// costs no allocation.)
const u: boolean | i32 = 5
if u is i32 { print(u) }        // 5 (unboxed to i32)

const v: boolean | i32 = true
if v is boolean { print(v) }    // true (unboxed to boolean)

const w: i32 | null = null
if w == null { print(999) }     // 999 (null tag)

const x: i32 | null = 42
if x != null { print(x) }       // 42 (unboxed to i32)

// A union also crosses function boundaries: boxed as a return value and as an
// argument (the box is the uniform ABI), discriminated by the callee.
function pick(b: boolean): boolean | i32 {
  if b { return 7 }
  return false
}
const r = pick(true)
if r is i32 { print(r) }         // 7 (boxed return, then unboxed)

function describe(v: boolean | i32) {
  if v is i32 { print(v) }
  if v is boolean { print(v) }
}
describe(13)                     // 13 (boxed argument)
describe(true)                   // true
