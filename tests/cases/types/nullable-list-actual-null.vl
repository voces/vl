// @run
// @log -1
// @log -1
// @log -1
// @log 5
// @log -1
// @log 7
// @log true
// A nullable i32-list `i32[] | null` could be TYPED and narrowed, but an actual `null` VALUE could not
// flow into it — a bare `null` at the init / assignment / argument / return boundary hit "bare null needs
// a struct-typed context" (the existing kind-15 test only ever used non-null values, so the null arm was
// never exercised). Each boundary now seeds `pendingNulList` so a `null` lowers as `ref.null $lTypeIdx`
// (the slot's own valtype), and an un-annotated `const r = f(…)` over a nullable-list-returning call
// infers kind 15. `boolean[] | null` shares the i32-list rep, so it rides the same kind.

function firstOr(v: i32[] | null): i32 {
  // param boundary: a null ARGUMENT
  if v != null { return v[0] } else { return -1 }
}

function pick(b: i32): i32[] | null {
  // return boundary: a null / list RETURN
  if b > 0 { return [5] } else { return null }
}

function go() {
  const a: i32[] | null = null // init boundary
  if a != null {
    print(a[0]) // -1
  } else {
    print(-1)
  }

  let b: i32[] | null = [1, 2]
  b = null // assignment boundary
  if b != null {
    print(b[0]) // -1
  } else {
    print(-1)
  }

  print(firstOr(null)) // -1 (null argument)

  const r = pick(1) // un-annotated: infer kind 15 from the call
  if r != null {
    print(r[0]) // 5
  } else {
    print(-1)
  }
  const s = pick(0)
  if s != null {
    print(s[0]) // -1
  } else {
    print(-1)
  }

  // boolean[] | null rides the same i32-list rep.
  const bs: boolean[] | null = [false, true]
  if bs != null {
    if bs[1] {
      print(7) // 7
    } else {
      print(0)
    }
  } else {
    print(-1)
  }
  const bn: boolean[] | null = null
  print(bn == null) // true
}

go()
