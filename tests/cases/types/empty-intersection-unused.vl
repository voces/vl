// @check
// @error-at 14:9 Type `C` is `never` (an empty type — `A & B`, an object and a string literal, have no common values), so it has no values
// An UNUSED `type C = A & B` whose concrete operands are disjoint (`{ a: string }`
// intersected with the string literal `"foo"`) folds to `never`. There is NO use
// site — `C` is never referenced — yet it must STILL be a hard error at its
// declaration, exactly like `type D = D` (PR #189: "same issue of not error until
// used"). The alias resolves lazily, so the use-site never-value check in
// `ensureType` would never fire here; the error is raised by the parser at the
// declaration instead, ranged on the `A & B` expression (0-indexed `14:9`).
//
// Exactly ONE diagnostic: no separate `empty-intersection` warning piles on (the
// error supersedes the lint for a `type` alias).
type A = { a: string }
type B = "foo"
type C = A & B
print(1)
