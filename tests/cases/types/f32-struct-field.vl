// @run
// @log 1.5
// @log 2.5
// @log 6.25
// An f32 STRUCT FIELD (`{ x: f32 }`) — the f32 sibling of the f64 (code 17) / i64 (code 23)
// scalar fields, code 24 (the 0x7d f32 storage). Was previously REVERTED (the inline case was
// silently wrong: the checker emits no f32 typed-IR and `print(s.x)` fell back to i32). It
// works now that f32 is supported in compound positions: `exprIsF32` classifies a code-24
// field read, `sawF32` fires for any f32-mentioning annotation (so the f32 print import is
// pulled in), and the struct-literal float-match accepts a float value into an f32 field.
// `fieldTypeCode`/`nameFieldCode` map f32 → 24; the store re-encodes via `emitExprAsF32`.

type Vec = { x: f32, y: f32 }

function lenSq(v: Vec): f32 { return v.x * v.x + v.y * v.y }

function go() {
  // named type
  const v: Vec = { x: 1.5, y: 2.0 }
  print(v.x) // 1.5

  // inline annotation (the case the earlier revert got silently wrong)
  const p: { x: f32 } = { x: 2.5 }
  print(p.x) // 2.5

  // f32 field reads through a struct param + arithmetic
  print(lenSq(v)) // 1.5*1.5 + 2*2 = 6.25
}
go()
