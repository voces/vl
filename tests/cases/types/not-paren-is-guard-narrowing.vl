// @run
// @log 3
// @log 7
// Negated parenthesized type guard with an early exit (`if !(x is T) { return }`)
// narrows the fall-through to `T`. `!(c)` is the De Morgan dual of `c`, so its
// else-facts (the fall-through, where `!(c)` is false) are `c`'s then-facts — the
// same narrowing the positive `if x is T { … }` branch gets. The early return
// must make the guarded branch diverge, so control reaches the fall-through only
// when `x is T` held.
type Program = { progStmts: i32[] }
type Other = { x: i32 }
function f(n: Program | Other): i32 {
  if !(n is Program) { return -1 }
  // `n` is narrowed to `Program` here.
  return n.progStmts.length
}
// The then-branch itself narrows `n` to the complement (`Other`).
function g(n: Program | Other): i32 {
  if !(n is Program) { return n.x }
  return n.progStmts.length
}
print(f({ progStmts: [1, 2, 3] }))
print(g({ x: 7 }))
