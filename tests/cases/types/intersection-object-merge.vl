// @run
// @log 3
// @log 30
// Object-type structural intersection (A3): `{a} & {b}` merges field-wise to
// `{a, b}` — the value that is BOTH must carry every field of each side. A
// shared field is refined to the meet of the two sides (here `c: i32 & i32` =
// `i32`). The merged record type is a valid annotation target, so a literal with
// all the fields type-checks against it and its fields read back at their types.
type AB = { a: i32 } & { b: i32 }
function sum(o: AB) o.a + o.b
print(sum({ a: 1, b: 2 }))            // 3

// A field common to both sides survives (meet of identical field types), and the
// disjoint fields union together: `{a, c} & {b, c}` is `{a, b, c}`.
type ABC = { a: i32, c: i32 } & { b: i32, c: i32 }
function sum3(o: ABC) o.a + o.b + o.c
print(sum3({ a: 5, b: 10, c: 15 }))   // 30
