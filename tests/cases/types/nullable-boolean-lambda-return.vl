// @log NULL
// A bare `null` in an UN-annotated lambda whose `boolean | null` return type comes from
// the argument-expected param type. The lambda's return is pinned to the niche (i32
// sentinel 2 = null) via the checker's `#<nodeIx>` record + `synthRetAnnots`.
function useIt(p: () => boolean | null) {
  const t0 = p()
  if t0 != null { print(t0) } else { print("NULL") }
}
function go() { useIt(() => (null)) }
go()
