// @run
// @log a
// @log b
// @log c
// @log other
// Literal discrimination (A4): `== <literal>` narrows a place to that literal in
// the then-branch and subtracts it (a negation, simplified against the union) in
// the else — so an `==` / `!=` chain discriminates exactly like `is`, and the
// final else is narrowed by the complement of every prior literal.
function name(n: i32): string {
  if n == 1 {
    return "a"
  } else if n == 2 {
    return "b"
  } else if n == 3 {
    return "c"
  } else {
    return "other"
  }
}
print(name(1))   // a
print(name(2))   // b
print(name(3))   // c
print(name(9))   // other
