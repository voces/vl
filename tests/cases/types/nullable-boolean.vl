// @run
// @log true
// @log false
// @log true
// @log false
// @log true
// @log false
// `boolean | null` via a niche (no box): `boolean` is 0/1, so the spare value 2
// encodes `null` in a plain i32. `== null` is a sentinel compare; narrowing to
// non-null is purely type-level (the i32 is already 0/1 in the branch).
const a: boolean | null = null
const b: boolean | null = true
const c: boolean | null = false
print(a == null)   // true
print(b == null)   // false
print(b != null)   // true
print(c == null)   // false
if b != null { print(b) }   // true (narrowed to boolean)
if c != null { print(c) }   // false
