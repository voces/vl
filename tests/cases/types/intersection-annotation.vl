// @run
// @log 1
// @log 0
// @log 2
// Intersection type annotation `A & B` (A3) — surface syntax over the existing
// `intersectType` algebra. `&` binds tighter than `|` (so `A | B & C` is
// `A | (B & C)`), and the prefix `!A` (A4 negation) binds tighter than `&`, so
// `A & !B` reads as "A but not B". A finite annotation folds to a concrete type:
// `(0 | 1 | 2) & !2` simplifies to `0 | 1`, so it codegens as a plain union.
const a: (0 | 1 | 2) & !2 = 1
print(a)        // 1

function clamp(n: (0 | 1 | 2) & !2) {
  if n == 0 { return 0 }
  return n
}
print(clamp(0)) // 0

// `&` lower-precedence than a unary `!` and tighter than `|`: `0 | 1 & !1` parses
// as `0 | (1 & !1)` = `0 | never` = `0`. (Here we keep a member that survives.)
const b: i32 | (2 | 3) & !3 = 2
print(b)        // 2
