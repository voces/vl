// @run
// @log 1
// @log 2
// @log 3
// @log 4
// else-of-else-if chaining (A5): the final `else` (and each later `else if`) is
// narrowed by the *complement of every prior condition*, not just the first. A
// three-variant union is fully discriminated: after `is string` and `is i32`
// are excluded, `x` is `boolean` in the final else — so `if x` type-checks.
function classify(x: string | i32 | boolean) {
  if x is string {
    return 1
  } else if x is i32 {
    return 2
  } else {
    if x { return 3 }
    return 4
  }
}
print(classify("hi"))    // 1
print(classify(7))       // 2
print(classify(true))    // 3
print(classify(false))   // 4
