// @run
// @log 5000000000
// @log 9000000000
// @log 12000000000
// An i64 struct FIELD (`{ x: i64 }`) — was a soundness hole: the checker accepted it but
// emit had no i64 case in `fieldTypeCode`/`nameFieldCode`, so the field defaulted to an i32
// valtype slot and storing an i64 produced invalid wasm. Now codes 23 (the i64 valtype 0x7e
// dual of the f64 code-17 path): widen-at-store, struct.get load, and `exprIsI64` classifies
// a code-23 field read. Inline annotation, named alias, and a struct param all carry i64.
type Big = { v: i64 }

function field(b: Big): i64 { return b.v }

function go() {
  // inline annotation
  const s: { x: i64 } = { x: 5000000000 }
  print(s.x) // 5000000000

  // named alias + struct param
  const b: Big = { v: 9000000000 }
  print(field(b)) // 9000000000

  // arithmetic on i64 field reads
  const t: i64 = s.x + field(b) - 2000000000
  print(t) // 5000000000 + 9000000000 - 2000000000
}
go()
