// @run
// @log NULL
// @log 7
// A `(f64 | null)[]` / `(i32 | null)[]` list built inside an UN-annotated lambda whose
// return type is known only from its binding annotation. The element is a value-union
// `{tag, payload}` box; `synthRetAnnots` pins the lambda's return so `[null]` seeds the
// element rep, exactly as the annotated `function g(): (f64|null)[]` form does.
const g: () => (f64 | null)[] = () => ([null])
const h: () => (i32 | null)[] = () => ([7])
function go() {
  const t0 = g()[0]
  if t0 != null { print(t0) } else { print("NULL") }
  const t1 = h()[0]
  if t1 != null { print(t1) } else { print("NULL") }
}
go()
