// @run
// @log 2
// @log NULL
// A DECLARED struct alias whose field is a nullable-scalar-element list
// (`type T0 = {f: (f64 | null)[]}`), the whole binding nullable. The declared-TypeDecl
// field recorder (`fieldRefElemName` code-5 arm) kept the grouping-paren spelling
// `(f64|null)` while every other position keys the rl-slot table bare (`f64|null`) —
// the field literal's element seed then missed the slot and stored a RAW f64 into the
// box-ref backing (INVALID-WASM; fuzz-nightly 29875839073 declared leg, seed 240165064
// d6; same root as the twin:/mix: `(f32|null)[]` / `(i32|null)[]` field findings).
// Canonicalized via `refArrElemName` at the recorder, matching the inline interner (#670).
type T0 = {f: (f64 | null)[]}
const g: T0 | null = { f: [2.0, null] }
function go() {
  const t0 = g
  if t0 != null {
    const t1 = t0.f[0]
    if t1 != null { print(t1) } else { print("NULL") }
    const t2 = t0.f[1]
    if t2 != null { print(t2) } else { print("NULL") }
  } else {
    print("NULL")
  }
}
go()
