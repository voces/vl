// @run
// @log 1
// @log 1
// @info unreachable: the preceding `is` arms are exhaustive
// DISCRIMINATION RULE: VL is STRUCTURALLY typed and a struct variant's runtime
// tag is keyed on its field-name-aware SHAPE. Two `type` aliases with the SAME
// shape are therefore the same variant — a `B` value genuinely IS an `A` — so
// `v is A` is (soundly) always true over a same-shape `A | B`. A union whose
// members share a shape needs an explicit DISCRIMINANT field (a `kind`/`tag`
// the variants set to distinct values) to tell its variants apart; the shape
// alone cannot. (Distinct-shaped variants are discriminated — see
// soundness/is-struct-union-sound.vl.)
type A = { tag: i32, v: i32 }
type B = { tag: i32, v: i32 }   // identical shape to A

function f(x: A | B) {
  if x is A { return 1 } else { return 2 }  // else is dead: B IS an A
}
print(f({ tag: 1, v: 100 }))    // 1
print(f({ tag: 2, v: 200 }))    // 1  (sound: a same-shape B is an A)
