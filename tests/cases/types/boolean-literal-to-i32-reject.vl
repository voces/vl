// @check
// @error cannot assign bool to 'x' of type i32
// The boolean→i32 coercion (A7) applies to a boolean-typed VALUE (a variable, a
// comparison result, a parameter), NOT to a bare boolean LITERAL in an i32 slot.
// `let x: i32 = true` is far more likely a mistake than an intended coercion —
// write `1` / `0` — so the literal form stays rejected.
const x: i32 = true
print(x)
