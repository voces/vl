// @run
// @log 15
// @log hello
// @log true
// @log 5000000000
// @log 2.5
// @log 4
// @log 2
// @log 6
// A single-member type alias of a PRIMITIVE (`type Id = i32`, `type Name = string`) is TRANSPARENT —
// it denotes its member, not a one-variant union box. The parser accepts a bare `type N = A` as a
// one-member union; before this fix that box rep meant `x: Id` was NOT a plain `i32` (`x + 1` →
// "operator + not defined for i32 and i32") and `s: Name = "hi"` MISCOMPILED to invalid wasm (a
// checker-accepts / emitter-rejects soundness hole). Now the checker's `nameToTy` collapses a
// single PRIMITIVE member to the member, and the emitter's `canonEmitName` resolves the alias to the
// member's own vocabulary (so the rewritten arena never carries the alias name). Covers every scalar,
// an alias-of-an-alias, an array of the alias, and alias-typed function params/returns.
//
// (A struct / object / intersection single-member alias keeps its named union ty — the emitter
// resolves those through its named-struct path, so they are deliberately left untouched here.)

type Id = i32
type Name = string
type Flag = boolean
type Big = i64
type Real = f64
type Id2 = Id

function addId(a: Id, b: Id): Id { return a + b }

function go() {
  // Alias-typed function params + return, with `+` on the alias (was rejected as a union).
  const x: Id = 5
  print(addId(x, 10)) // 15

  // Every primitive scalar.
  const n: Name = "hello"
  print(n) // hello
  const f: Flag = true
  print(f) // true
  const b: Big = 5000000000
  print(b) // 5000000000
  const r: Real = 2.5
  print(r) // 2.5

  // Alias of an alias.
  const y: Id2 = 3
  print(y + 1) // 4

  // Array of the alias — `Id[]` resolves to `i32[]`, indexed + summed.
  const xs: Id[] = [1, 2, 3]
  print(xs[1]) // 2
  let total = 0
  let i = 0
  while i < xs.length {
    total = total + xs[i]
    i = i + 1
  }
  print(total) // 6
}

go()
