// @run
// @log 7
// @log -1
// @log 42
// Post-guard narrowing (A5): a guard clause whose then-branch diverges
// (`if x == null { return }`) leaves `x` non-null for the rest of the block —
// the idiomatic null-handling pattern. Works via `== null` and `is null`.
function maybe(b: i32): { x: i32 } | null {
  if b > 0 { return { x: 7 } }
  return null
}
function use(b: i32) {
  const p = maybe(b)
  if p == null { return -1 }
  return p.x
}
print(use(1))
print(use(0))
function use2(b: i32) {
  const p = maybe(b)
  if p is null { return 0 }
  const v = p.x
  return v + 35
}
print(use2(1))
