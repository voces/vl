// @run
// @log 4
// @log 0
// @log 7
// A NULLABLE union ALIAS (`type AB = A | B`; `AB | null`). The alias was not expanded with the
// `null` member, so `AB | null` was not recognized as a union (`isUName("AB|null")` is false)
// and fell to the i32-local default ("only i32 locals are supported"). The INLINE `(A|B)|null`
// already worked — it canonicalizes to `A|B|null`. `canonEmitName` now FLATTENS a union-alias
// member of an outer union (`unionAliasMembers`), so `AB | null` canonicalizes to the same
// `A|B|null` the inline form produces (and `nameNeedsCanon` lets a bare `|` name through so the
// member-canon loop runs). A bare `AB` annotation has no top-level `|`, so it stays the alias.

type A = { t: i32, a: i32 }
type B = { t: i32, b: i32 }
type AB = A | B

function go() {
  // a struct literal into a nullable union alias, narrowed.
  const u: AB | null = { t: 1, b: 4 }
  if u != null {
    if u is B { print(u.b) } // 4
  }

  // a `null` into the same slot.
  const w: AB | null = null
  if w != null { print(1) } else { print(0) } // 0

  // the bare alias (no null) still works.
  const v: AB = { t: 1, a: 7 }
  if v is A { print(v.a) } // 7
}
go()
