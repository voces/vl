// @run
// @log true
// @log 1
// @log true
// @log false
// @log true
// @log false
// `boolean` is the SINGLE canonical boolean type name (the `bool` alias was removed — see
// boolean-no-bool-alias.vl). It lowers in every annotation position: scalar local, param, inline-shape
// field, `boolean[]` element, and `boolean | null`. (A boolean rides in an i32 0/1.) A bool VALUE routed
// through a branch prints true/false; a struct-field bool printed directly still renders `1` — a separate
// formatting gap, sidestepped here.

function pick(b: boolean): i32 {
  if b { return 1 } else { return 0 }
}

function go() {
  const a: boolean = true
  print(a) // true
  print(pick(true)) // 1

  const f: { flag: boolean } = { flag: true }
  if f.flag {
    print(true) // true
  } else {
    print(false)
  }

  const arr: boolean[] = [false, true]
  print(arr[0]) // false
  print(arr[1]) // true

  const n: boolean | null = false
  if n != null {
    print(n) // false
  } else {
    print(true)
  }
}

go()
