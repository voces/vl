// @run
// @log NULL
// @log NULL
// @log NULL
// @log NULL
// @log NULL
// @log NULL
// @log NULL
// @log 3.5
// @log zz
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// The nulclosure-sig R2 family: a nullable closure binding (`(() => T) | null`) whose ONLY
// caller is through the null-narrow (`if f != null { f(...) }`) and whose value is only
// ever `null` — NO concrete lambda exists to intern the closure's `$fnsig`, so the
// narrowed call found no interned signature and rejected. `collectCloSigs` now interns
// the inner closure key from every nulclosure annotation (and `collectFnValUse` flips the
// closure machinery on for it), so the null-narrowed call lowers dead-correct. One
// spelling per graduated result flavor × position: f64/i32 (return), string/f64/struct
// (global), map/struct (param) — plus the LIVE-closure twins, so ONE interned sig serves
// both draws (the live lambda dedups onto the synthesized key).
function mkF(): (() => f64) | null {
  return null
}
function mkI(): (() => i32) | null {
  return null
}
const gs: ((i32) => string) | null = null
const gd: ((i32) => f64) | null = null
const gb: ((i32) => {f: boolean}) | null = null
function useMap(p: ((i32) => {[string]: f64}) | null) {
  const t0 = p
  if t0 != null {
    const m = t0(1)
    print(m["k"] ?? 9.5)
  } else {
    print("NULL")
  }
}
function useStruct(p: ((i32) => {a: boolean, f: f32, z: string}) | null) {
  const t0 = p
  if t0 != null {
    const r = t0(1)
    print(r.z)
  } else {
    print("NULL")
  }
}
function go() {
  const f = mkF()
  if f != null { print(f()) } else { print("NULL") }
  const i = mkI()
  if i != null { print(i()) } else { print("NULL") }
  const s = gs
  if s != null { print(s(1)) } else { print("NULL") }
  const d = gd
  if d != null { print(d(1)) } else { print("NULL") }
  const b = gb
  if b != null {
    const r = b(1)
    print(r.f)
  } else {
    print("NULL")
  }
  useMap(null)
  useStruct(null)
  // LIVE twins: the same signatures with a real closure — the null-only interning above
  // must not disturb the concrete-lambda path (the keys dedup onto one `$fnsig`).
  const h: {[string]: f64} = Map()
  h["k"] = 3.5
  useMap((_q0) => (h))
  useStruct((_q1) => ({a: true, f: 2.5, z: "zz"}))
}
go()
