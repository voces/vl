// @run
// @log nj
// @log false
type K0 = "60" | "nj" | "l"
function go() {
  const g: {[string]: {f: boolean}} = Map()
  g["k"] = { f: false }
  const h: {[string]: {f: K0} | null} = Map()
  h["k"] = { f: "nj" }
  const t = h["k"] ?? { f: "60" }
  if t != null { print(t.f) } else { print("NULL") }
  const u = g["k"] ?? { f: true }
  print(u.f)
}
go()
