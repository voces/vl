// @run
// @log nj
// @log false
type K0 = "60" | "nj" | "l"
function go() {
  const g: {[string]: {f: boolean}} = Map()
  g["k"] = { f: false }
  const h: {[string]: {f: K0} | null} = Map()
  h["k"] = { f: "nj" }
  // `?? {f:"60"}` (non-null default) coalesces the nullable-struct-value map read to a NON-null
  // `{f: K0}` (USER SEMANTICS RULING) — read `.f` directly, no `!= null` narrow.
  const t = h["k"] ?? { f: "60" }
  print(t.f)
  const u = g["k"] ?? { f: true }
  print(u.f)
}
go()
