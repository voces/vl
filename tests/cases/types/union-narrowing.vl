// @run
// @log 5
// @log hey
// @log 7
// @log a
// @log 42
// @log true
// @log 0
// @log 100
// Flow narrowing covers both branches and composes across nested `if`s. In the
// else branch a variable narrows to its *complement* — `if x is A { … } else
// { /* x: U − A */ }` — so a two-case union is fully discriminated by one `if`,
// and a three-case union peels one variant at a time. Tags are globally stable,
// so a value boxed as the wide union keeps its identity inside a sub-union.

// else-branch narrows to the other variant (no explicit second `is`)
function two(v: string | i32) {
  if v is i32 { print(v) } else { print(v) }
}
two(5)
two("hey")

// nested: the else leaves a sub-union, refined again by an inner `if`
function three(v: string | i32 | boolean) {
  if v is string {
    print(v)
  } else {
    if v is i32 { print(v) } else { print(v) }
  }
}
three(7)
three("a")
three(42)
three(true)

// nullness: the else branch of `== null` is non-null
function ornull(x: i32 | null) {
  if x == null { print(0) } else { print(x) }
}
ornull(null)
ornull(100)
