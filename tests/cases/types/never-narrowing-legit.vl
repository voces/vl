// @run
// @log 10
// @log 20
// A legitimate `never`: after `n == 0` and `n == 1` are handled, the literal
// union `0 | 1` is narrowed to `never` on the fall-through (an unreachable
// branch). That `never` is sound — no VALUE is being formed for a never-typed
// binding — so the never-value error must NOT fire here, and exhaustiveness /
// narrowing keep working. (The error targets *forming* a never value, not every
// `never` occurrence.)
function pick(n: 0 | 1): i32 {
  if n == 0 { return 10 }
  if n == 1 { return 20 }
  return -1
}
print(pick(0))
print(pick(1))
