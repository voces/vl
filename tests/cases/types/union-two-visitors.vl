// @run
// @log 12
// @log 5
// REGRESSION PIN: two distinct functions may `is`-narrow the SAME union and be
// mutually recursive through direct calls. This shape used to MISCOMPILE ("Object
// has no field …" / "Cannot read properties of undefined"), which forced the
// self-host checker (`compiler/typecheck.vl`) into a single mega-visitor with every
// per-variant body inlined (its "Finding 2"). The sharpest historical trigger — a
// narrowed multi-field variant carrying an UNACCESSED array field (`items`) read in
// both functions — is exactly this case.
type A = { av: i32, items: i32[] }
type B = { bv: i32 }
type N = A | B
const nodes: N[] = []
function walkA(ix: i32): i32 {
  const n = nodes[ix]
  if n is A { return n.av + walkB(1) }
  0
}
function walkB(ix: i32): i32 {
  const n = nodes[ix]
  if n is B { return n.bv }
  if n is A { return n.av }
  0
}
const seed: i32[] = [9]
nodes.push({ av: 5, items: seed })
nodes.push({ bv: 7 })
print(walkA(0))
print(walkB(0))
