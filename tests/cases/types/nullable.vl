// @run
// @log false
// @log true
// @log true
// @log false
// @log true
// @log 7
// @log 7
// @log 0
// Nullable reference types (`T | null`), `null`, `==`/`!=`/`is null` nullness
// tests, and flow narrowing (A5/A6): a member access is only valid after a
// guard narrows the value to non-null.
function maybe(b: i32): { x: i32 } | null {
  if b > 0 { return { x: 7 } }
  return null
}
let p = maybe(1)
let q = maybe(0)
print(p == null)   // false
print(q == null)   // true
print(p != null)   // true
print(p is null)   // false
print(q is null)   // true
if p != null { print(p.x) }          // 7 (narrowed via != null)
if p is { x: i32 } { print(p.x) }    // 7 (narrowed via `is`)
if q != null { print(q.x) }          // skipped (q is null)
print(0)
