// @run
// @log 7
// @log hello
// @log 100
// @log 9
// @log 42
// @log circle
// @log 5
// A union- or nullable-typed object field gets its boxed / niche representation
// (an object literal builds to the *annotated* field types, not the value's
// narrower inferred ones), and a field path narrows like a variable —
// `if o.v is T { o.v }` reads the narrowed variant directly. This is the
// discriminated-record pattern.

// field union, both variants, narrowed in place (then + else)
function show(o: {v: string | i32}) {
  if o.v is i32 { print(o.v) } else { print(o.v) }
}
show({v: 7})        // 7
show({v: "hello"})  // hello

// field union across a function parameter (boxed argument, instance keeps the
// declared field type)
function size(s: {kind: i32, dim: string | i32}) {
  if s.dim is i32 { print(s.dim) }
}
size({kind: 1, dim: 100})   // 100

// nullable struct field: guard, then a nested access on the narrowed field
const o: {v: {x: i32} | null} = {v: {x: 9}}
if o.v != null { print(o.v.x) }   // 9

// nested path: `o.a.b` narrows at depth
const n: {a: {b: string | i32}} = {a: {b: 42}}
if n.a.b is i32 { print(n.a.b) }  // 42

// a string-discriminated record
const shape: {kind: string, r: i32} = {kind: "circle", r: 5}
if shape.kind is string { print(shape.kind) }   // circle
print(shape.r)                                   // 5
