// @run
// @log 20
// @log 5
// @log 20
// @log 10
// @log 4
// A nullable LIST value (`T[] | null`), narrowed to non-null via `if x != null`,
// then used. The narrowed value keeps its nullable `(ref null $list)` wasm slot —
// narrowing is type-level only — so reading it into the NON-NULL `(ref $list)`
// local that list ops (`l[i]`, `l[i]=v`, `+`, `for…in`, `map`) allocate is an
// `isSubType` violation that crashed binaryen's `LocalSubtyping` pass. The lowering
// now `ref.as_non_null`s the list at each such read site (the narrowing guarantees
// non-null, so the cast can't trap). Non-recursive `i32[] | null` reproduces it.

// (1) a local: narrow then index.
const xs: i32[] | null = [10, 20, 30]
if xs != null {
  print(xs[1]) // 20
}

// (2) a struct field `{ rest: T[] | null }`: narrow the field, then index.
type Node = { rest: i32[] | null }
function firstRest(n: Node): i32 {
  if n.rest != null { return n.rest[0] }
  return -1
}
print(firstRest({ rest: [5, 6] })) // 5

// (3) a function parameter `xs: i32[] | null`: narrow then index.
function at1(ys: i32[] | null): i32 {
  if ys != null { return ys[1] }
  return -1
}
print(at1([10, 20, 30])) // 20

// (4) the other list-base reads over a narrowed param: `for…in`, `+`, `map`.
function sumPlus(zs: i32[] | null): i32 {
  if zs != null {
    let s = 0
    for z in zs {
      s = s + z // for…in over a narrowed list
    }
    const more = zs + [10] // concat a narrowed list
    return s + more.length // (1+2+3) + 4 = 10
  }
  return -1
}
print(sumPlus([1, 2, 3])) // 10

function mapFirst(ws: i32[] | null): i32 {
  if ws != null {
    const out = ws.map((w: i32) => w * 2)
    return out[0] // 2 * 2 = 4
  }
  return -1
}
print(mapFirst([2, 3])) // 4
