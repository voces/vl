// @run
// @log other
// @log str
// @log other
// @log 1
// @log 0
// An `is` guard on an un-annotated (generic) parameter is sound: the parameter
// is NOT pinned by the guard (each call monomorphizes independently), and `is T`
// on the per-call concrete type is statically decided at codegen — so the guard
// takes the right branch and calls don't cross-contaminate.
function describe(x) {
  if x is string { return "str" }
  return "other"
}
print(describe(5))      // other  (x is i32, not string)
print(describe("hi"))   // str
print(describe(5))      // other  (no contamination from the string call)

// The guard's runtime result is the static answer for the monomorphized type.
function isStr(x) {
  if x is string { return 1 }
  return 0
}
print(isStr("a"))   // 1
print(isStr(42))    // 0
