// @check
// @error expected
// A `K | null` value must be NARROWED before it flows into a bare-`K` position — the niche can hold the
// `-1` null sentinel, which is not a member atom. The checker rejects the un-narrowed `rank(r)` (passing
// `K | null` where `K` is required), proving the nullable litunion is a distinct, sound type — not an
// alias for the bare litunion.

type K = "a" | "b"

function rank(k: K): i32 {
  if k == "a" { return 1 }
  return 2
}

function go(r: K | null): i32 {
  return rank(r)
}

print(go("a"))
