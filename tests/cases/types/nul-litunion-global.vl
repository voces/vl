// Regression: `K | null` NICHE globals. The global cell classifier had no
// nullable-litunion arm, so a member-literal init fell to `letIsString`'s init
// fallback — a STRING-ref cell while every read classified the i32 niche:
// INVALID-WASM (fuzz post-#1000 sweep plain leg, `K0 | null` p3r). And the global
// init emit never seeded the atom context: the member init lowered as a string ref
// (`pendingLitUnion`) and a bare `null` init drew the "bare null needs a
// struct-typed context" loud reject (`pendingNulLitUnion`, the start-fn path).
// Cell kind, const-init, and start-fn-init all take the niche now — matching the
// local spelling, which worked all along.
// @run
// @log 404
// @log NULL
type K0 = "404" | "n" | "8"
const g: K0 | null = "404"
const h: K0 | null = null
function go() {
  const t0 = g
  if (t0 != null) { print(t0) } else { print("GNULL") }
  const t1 = h
  if (t1 != null) { print(t1) } else { print("NULL") }
}
go()
