// @run
// @log 5
// @log -1
// @log -1
// `&&`-chained guards (A5): the RHS of `&&` is type-checked with the LHS's
// narrowing already applied, and the then-branch sees *both* facts. Here the
// first guard makes `o` non-null (so `o.y` resolves at all) and the second
// discriminates the union field `o.y` to `i32` — neither works alone.
function f(o: {y: string | i32} | null): i32 {
  if o != null && o.y is i32 { return o.y }
  return 0 - 1
}
print(f({y: 5}))         // 5
print(f({y: "hello"}))   // -1  (o.y is a string, not i32)
print(f(null))           // -1  (o is null)
