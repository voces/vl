// @run
// @log 1
// @log 0
// @log 1
// @log 0
// @log 1
// A7: a `boolean`-typed VALUE coerces where an `i32` is expected — `true` is 1
// and `false` is 0 (boolean already rides in an i32 at runtime, so the coercion
// is a no-op in codegen; the typechecker just permits it). The coercion is
// one-directional — an arbitrary `i32` is NOT a `boolean` (see
// `boolean-to-i32-reject.vl`) — and applies to a boolean-typed VALUE, not a bare
// boolean literal in an i32 slot (see `boolean-literal-to-i32-reject.vl`).

// boolean variable into an i32-annotated binding.
const t: boolean = true
const n: i32 = t
print(n)                  // 1

const f: boolean = false
const z: i32 = f
print(z)                  // 0

// boolean value into an i32 parameter (the call-argument boundary).
function asI32(x: i32): i32 { x + 0 }
const one = asI32(t)
print(one)                // 1
const two = asI32(f)
print(two)                // 0

// A `boolean` comparison result coerced to an `i32` return (the return
// boundary).
function isEq(a: i32, c: i32): i32 { a == c }
const eq = isEq(5, 5)
print(eq)                 // 1
