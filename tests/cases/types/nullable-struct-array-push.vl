// @run
// @log 4
// @log -1
// @log 8
// @log 5
// Pushing a `null` / nullable VALUE into a `(P | null)[]`. The ref-push scratch frame's value
// slot was a non-null `(ref $P)`, so `xs.push(null)` (a `(ref null $P)` value) mismatched. The
// slot is now `(ref null $P)` for a nullable-struct element list (`fbBeginFunc` picks
// `fbRefNullRun` when the element kind is 1 and the slot key carries `| null`). A non-null `P[]`
// push is unchanged (its value slot stays non-null). Completes the `(P | null)[]` feature (#589).

type P = { v: i32 }

function go() {
  const xs: (P | null)[] = [{ v: 5 }]
  xs.push(null) // a bare null
  const m: P | null = null
  xs.push(m) // a nullable variable
  xs.push({ v: 8 }) // a non-null struct
  print(xs.length) // 4

  // xs = [{5}, null, null, {8}] — narrow each read.
  const a = xs[1]
  if a != null { print(a.v) } else { print(-1) } // -1 (null)
  const b = xs[3]
  if b != null { print(b.v) } // 8
  const c = xs[0]
  if c != null { print(c.v) } // 5
}
go()
