// @run
// @log 1.5
// @log hi
// @log 2.5
// An f32 VALUE-UNION atom (`f32 | string`) — the f32 value rides the shared union box's per-rep
// value box (`vbF32`, which already existed). The checker accepts a float literal into the f32
// union member (`dstAdmitsF32` descends unions); `emitUnionCoerce` picks the f32 atom for a
// float literal when the union's float atom is f32 (not f64), boxing into `vbF32`; and a
// narrowed `is f32` read prints via `__print_f32__` (`sawF32` now fires for any f32-mentioning
// annotation). Was rejected at the checker, then mis-boxed at emit.

function go() {
  let v: f32 | string = 1.5
  if v is f32 {
    print(v) // 1.5
  }
  v = "hi"
  if v is string {
    print(v) // hi
  }

  // reassign back to the f32 atom.
  v = 2.5
  if v is f32 {
    print(v) // 2.5
  }
}
go()
