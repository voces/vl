// @run
// @log 5
// @log 3.5
// @log 5
// @log 9000000000
// @log 1
// @log 2000000000000
// A union of numerics with *different* wasm reps (`i32 | f64`, `i32 | i64`).
// One-directional numeric coercion (`i32` ⊑ `f64`) would otherwise collapse
// these to the wider type during type normalization; they're kept distinct so
// each is a real, discriminable variant. They take the boxed representation
// (one `{ rep }` box per member behind an `anyref` payload).

let u: i32 | f64 = 5
if u is i32 { print(u) }       // 5
u = 3.5
if u is f64 { print(u) }       // 3.5

function show(v: i32 | i64) {
  if v is i32 { print(v) } else { print(v) }
}
show(5)                        // 5  (i32)
show(9000000000)               // 9000000000  (i64, beyond i32 range)

// i32 | i64 | null, discriminated three ways
let n: i32 | i64 | null = 1
if n is i32 { print(n) }       // 1
n = 2000000000000
if n is i64 { print(n) }       // 2000000000000
