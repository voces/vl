// @run
// @log false
// A `p()` where `p: () => boolean | null` is a call of a closure-typed PARAM (a value
// `fnIndexOf` can't see). Its result is the `boolean | null` niche i32, so `t0 != null`
// is the sentinel-2 compare — recognized by `calleeCloRetName` reading the param's
// function-type return, not the `$fnsig` key (`boolean|null` rides `>i`, like `boolean`).
function useIt(p: () => boolean | null) {
  const t0 = p()
  if t0 != null { print(t0) } else { print("NULL") }
}
function go() { useIt(() => (false)) }
go()
