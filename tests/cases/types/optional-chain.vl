// @run
// @log 5
// @log -1
// @log -1
// @log hi
// @log -1
// @log 9
// @log -1
// Optional chaining `x?.y` (null-safe, null-only): `null` if `x` is null, else
// `x.y`. As a guard `if x?.y is T` it narrows BOTH the receiver (`x` non-null)
// and the path (`x.y` is `T`), so the body reads `x.y` directly.

// As a guard: narrows x non-null AND x.y to i32.
function getInt(x: {y: string | i32} | null) {
  if x?.y is i32 { return x.y }
  return -1
}
print(getInt({y: 5}))        // 5
print(getInt({y: "no"}))     // -1 (y is a string, not i32)
print(getInt(null))          // -1 (x is null)

// `x?.y is string` narrows to the string arm.
function getStr(x: {y: string | i32} | null) {
  if x?.y is string { return x.y }
  return "-1"
}
print(getStr({y: "hi"}))     // hi
print(getStr({y: 5}))        // -1

// As a value, combined with `??` for a default.
const o: {y: i32} | null = {y: 9}
print(o?.y ?? -1)         // 9
const n: {y: i32} | null = null
print(n?.y ?? -1)         // -1
