// @run
// @log 12
// REGRESSION PIN: a per-variant helper may take the NARROWED variant struct as a
// parameter and recurse back into the union visitor (the `visitA(n: A)` shape the
// self-host checker could not use — `typecheck.vl` "Finding 2" forced inlining).
type A = { av: i32, kids: i32[] }
type B = { bv: i32 }
type N = A | B
const nodes: N[] = []
function visit(ix: i32): i32 {
  const n = nodes[ix]
  if n is A { return visitA(n) }
  if n is B { return n.bv }
  0
}
function visitA(a: A): i32 {
  const kids = a.kids
  let sum = a.av
  let i = 0
  while i < kids.length {
    sum = sum + visit(kids[i])
    i = i + 1
  }
  sum
}
nodes.push({ bv: 7 })
const k1: i32[] = [0]
nodes.push({ av: 5, kids: k1 })
print(visit(1))
