// @run
// @log 6
// @log 10
// Recursion through an ARRAY element type (ROADMAP A11): the named type `List`
// references itself through the *element type* of an array field (`rest: List[]`),
// rather than through a plain or nullable field. The type algebra must resolve
// the self-reference lazily (an `Alias` leaf, not infinite expansion) even when
// the back-edge is buried inside an array element type, and codegen must build
// the self-referential WasmGC array-of-struct in one rec-group. Traversal walks
// the `rest` array, recursing into each child node, so the array element back-edge
// is exercised at both construction and read time.
type List = { value: i32, rest: List[] }

function total(node: List): i32 {
  let sum = node.value
  let i = 0
  while i < node.rest.length {
    const child = node.rest[i]
    sum = sum + total(child)
    i = i + 1
  }
  return sum
}

// 1 + 2 + 3 = 6 — a node whose `rest` holds two leaf children.
const a: List = {
  value: 1,
  rest: [
    { value: 2, rest: [] },
    { value: 3, rest: [] },
  ],
}
print(total(a))

// 4 + 6 = 10 — a node with a single nested child that itself has an empty `rest`.
const b: List = {
  value: 4,
  rest: [
    { value: 6, rest: [] },
  ],
}
print(total(b))
