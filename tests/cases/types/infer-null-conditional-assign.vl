// @run
// @log 10
// @log -1
// CONDITIONAL-ASSIGN IDIOM (A-infer-null): `let x = null` then `if c { x = f() }`.
// The hole's `T` is filled to `i32` from the branch assignment, so `x` is `i32 |
// null`. The assignment is INSIDE the branch, so on the fall-through (where `x`
// wasn't written) it keeps its `| null` — a use after the `if` still requires a
// null check (`x != null`), which narrows it to `i32` in the then-branch. This is
// the motivating annotation-free pattern.
function f(): i32 { 9 }
function use(c: boolean): i32 {
  let x = null
  if c { x = f() }
  if x != null { return x + 1 }
  return -1
}
print(use(true))
print(use(false))
