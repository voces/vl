// @run
// @log 1
// @log 0
// @log a
// @log b
// @log none
// @log c
// @log none
// @log b
// A NULLABLE LITERAL-UNION (`K | null`): the i32 atom NICHE — the member ids are interned ≥ 0 and the
// spare value `-1` encodes `null` (no box, the litunion dual of the `boolean | null` sentinel). Exercises
// the scalar positions in order: a `K | null` PARAM narrowed and dispatched through a bare-`K` param, a
// `== null` sentinel compare, a `K | null` RETURN (`return "a"` / `return null`), and a `K | null` LOCAL
// with reassignment (`v = null` / `v = "b"`). `canonEmitName` preserves the litunion — it would otherwise
// soften the members to `string` and mis-route the type to the `string | null` ref box.

type K = "a" | "b" | "c"

// A `K | null` PARAM narrowed to the bare litunion, then passed to a `K` param.
function rank(k: K): i32 {
  if k == "a" { return 1 }
  return 2
}
function rankOr(r: K | null): i32 {
  if r == null { return 0 }
  return rank(r)
}

// A `K | null` RETURN: a member atom or `null`.
function pick(x: i32): K | null {
  if x == 0 { return "a" }
  if x == 1 { return "b" }
  return null
}

// A `K | null` PARAM print: a narrowed atom widens to its member string; `null` prints a sentinel word.
function show(r: K | null) {
  if r == null { print("none") } else { print(r) }
}

// A `K | null` LOCAL with reassignment (`v = null` / `v = "b"`), then a narrowed print.
function tag(x: i32) {
  let v: K | null = "c"
  if x == 1 { v = null }
  if x == 2 { v = "b" }
  if v == null { print("none") } else { print(v) }
}

print(rankOr("a")) // 1  — narrowed, dispatched through `rank`
print(rankOr(null)) // 0  — `== null` sentinel compare

show(pick(0)) // a  — return a member atom, widened on print
show(pick(1)) // b
show(pick(9)) // none — return null

tag(0) // c  — local init, no reassignment
tag(1) // none — `v = null`
tag(2) // b  — `v = "b"`
