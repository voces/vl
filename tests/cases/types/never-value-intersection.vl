// @check
// @error is `never` (an empty type — `A & B`, an object and a string literal, have no common values), so it has no values
// A binding whose annotated type folds to `never` — here `C = A & B`, an object
// intersected with a disjoint string literal — has NO values: nothing inhabits
// the empty type. Forming one (`let c: C = { … }`) is a clean type error at the
// value/binding site, NOT a codegen crash (`Unhandled AST -> WASM "Never" type`).
type A = { a: string }
type B = "foo"
type C = A & B
let c: C = { a: "x" }
print(c)
