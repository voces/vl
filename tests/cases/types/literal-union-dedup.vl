// @run
// @log 1
// @log 2
// @log 3
// Duplicate literal members collapse and distinct ones are kept — pins the O(n)
// all-literal dedup fast path in `flattenType` (which replaced the O(n²) pairwise
// scan, dropping a left-folded N-member literal union from O(n³) to O(n²)).
function k(s: "a" | "a" | "b") {
  if s == "a" {
    return 1
  }
  return 2
}
print(k("a"))   // 1 — the duplicate "a" collapsed, still narrows
print(k("b"))   // 2

// A multi-member numeric-literal union still discriminates correctly.
function big(n: 0 | 1 | 2 | 3 | 4 | 5) {
  if n == 5 {
    return 3
  }
  return 0
}
print(big(5))   // 3
