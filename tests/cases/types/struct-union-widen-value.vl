// @run
// @log 70
// @log 4
// @log 70
// @log 4
// @log 7
// @log 4
// @log 4
// Widen a concrete STRUCT VALUE into a struct-union BOX position — a call argument, a return,
// and an assignment. A struct that is a union member is itself allocated as a kind-8 VARIANT
// local (so it narrows in place), but that raw `(ref $variant)` does NOT match the boxed
// `(ref $uBox)` rep a union param / return / kind-4 local expects — passing or returning one
// was invalid wasm ("expected (ref $type), found (ref $type)"). `emitUnionBoxArg` boxes the
// existing variant ref into the shared `{tag, payload}` rep (the variant ref IS the payload
// type, so no field copy), exactly as a struct LITERAL is boxed. Only box-typed positions use
// it: a let-init to a variant-init local stays a raw kind-8 variant (it narrows fine and now
// boxes at the boundary). Narrowing back discriminates the right variant for BOTH members.

type C = { kind: i32, r: i32 }
type S = { kind: i32, side: i32 }

function area(sh: C | S): i32 {
  if sh is C { return sh.r * 10 } else { return sh.side }
}

// RETURN a concrete variant where the return type is the union.
function pick(useC: i32): C | S {
  if useC == 1 {
    const c: C = { kind: 0, r: 7 }
    return c
  } else {
    const s: S = { kind: 1, side: 4 }
    return s
  }
}

function go() {
  const c: C = { kind: 0, r: 7 }
  const s: S = { kind: 1, side: 4 }

  // call ARGUMENT: a concrete struct local widened to the union param, both variants.
  print(area(c)) // C → 70
  print(area(s)) // S → 4

  // a variant-RETURNING call feeding the union param.
  print(area(pick(1))) // returns C → 70
  print(area(pick(0))) // returns S → 4

  // round-trip: returned-then-boxed value narrows back to the right variant.
  const u1 = pick(1)
  if u1 is C { print(u1.r) } else { print(99) } // 7

  // ASSIGNMENT: a variant into a kind-4 union-box local (init was a literal).
  let u: C | S = { kind: 0, r: 1 }
  u = s
  if u is S { print(u.side) } else { print(88) } // 4

  // via an intermediate union local passed on as an argument.
  const v: C | S = s
  print(area(v)) // 4
}
go()
