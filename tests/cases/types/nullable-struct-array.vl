// @run
// @log 3
// @log -1
// @log 3
// @log 7
// @log 7
// @log 9
// @log 2
// An array of NULLABLE structs (`(P | null)[]`). Its element is a nullable-struct NICHE (a `(ref
// null $P)` slot), NOT a union box — but `parenUnionArrElemName` (a 2-member union) mis-routed
// it to the union-box path, so the narrowed element read failed ("field access receiver is not a
// struct"). `nullStructArrElem` now routes a `(<struct> | null)[]` to a STRUCT ref-list (kind 1)
// whose slot keys on the full "P | null" — so a read can tell it from a non-null `P[]` (distinct
// slot) and keep the element nullable (no `ref.as_non_null`). The bound element binds the kind-9
// niche, narrowed with `e != null`. Covers store (with `null` ANYWHERE), `.length`, indexed read
// + narrow, indexed-assign (struct AND null), `for`-in (kind-9 loop var), and a param. (Pushing a
// `null` / nullable VALUE needs a nullable push scratch — a follow-up; pushing a struct works.)

type P = { v: i32 }

function sumNonNull(xs: (P | null)[]): i32 {
  let t = 0
  for e in xs {
    if e != null { t = t + e.v }
  }
  return t
}

function go() {
  // store with `null` first, middle, and a struct; read + narrow.
  const xs: (P | null)[] = [null, { v: 3 }, null]
  print(xs.length) // 3
  const a = xs[0]
  if a != null { print(a.v) } else { print(-1) } // -1 (null)
  const b = xs[1]
  if b != null { print(b.v) } // 3

  // indexed-assign a struct, then null, then read via narrowing.
  const ys: (P | null)[] = [{ v: 1 }, { v: 2 }]
  ys[0] = { v: 7 }
  const y0 = ys[0]
  if y0 != null { print(y0.v) } // 7
  ys[1] = null
  print(sumNonNull(ys)) // ys = [{7}, null] → 7

  // push a non-null struct (push of null is a follow-up).
  const zs: (P | null)[] = [{ v: 5 }]
  zs.push({ v: 4 })
  let zt = 0
  for e in zs {
    if e != null { zt = zt + e.v }
  }
  print(zt) // 5 + 4 = 9

  // a `(P | null)[]` param, summed via for-in narrowing.
  print(sumNonNull([{ v: 2 }, null, null])) // 2
}
go()
