// @run
// @log 30
// @log -1
// `||` guard clause (A5, De Morgan): `if a == null || b == null { return }` is
// the negation of a conjunction, so after the divergent then-branch *both* `a`
// and `b` are non-null for the rest of the block (post-guard narrowing applied
// to every place the `||` excludes).
function add(a: {v: i32} | null, b: {v: i32} | null): i32 {
  if a == null || b == null { return 0 - 1 }
  return a.v + b.v
}
print(add({v: 10}, {v: 20}))   // 30
print(add({v: 10}, null))      // -1
