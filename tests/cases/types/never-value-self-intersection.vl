// @check
// @error is `never` (an empty type — `A & E`, an object and a type, have no common values), so it has no values
// A self-referential intersection `type E = A & E` also folds to `never`. A
// binding annotated `E` is rejected with the same clean never-value error rather
// than the previous confusing "expected {a:any}, got never" / codegen crash.
type A = { a: string }
type E = A & E
let e: E = { a: "x" }
print(e)
