// @run
// @log 7
// @log 4
// @log 74
// @log 4
// @log 9
// @log 40
// @log 2
// @log 7
// @log 74
// Completes union-element collections: `for`-in over a `(C | S)[]`, maps of union ARRAYS
// (`{[string]: (C | S)[]}`), and `push` / indexed-assign of a concrete variant into a union
// array. Each is the variant-box rep meeting a store/iterate path that previously emitted the
// element raw (push / indexed-assign), refused the iterable (`for`-in), or rejected the map
// value type. The stores box via `emitUnionBoxArg` (a variant widens like a call arg); the
// `for`-in loop var binds as a kind-4 union box and resolves its member set from the iterable
// so `x is C` narrows; the map value is a list of union boxes (kind 6, inner element kind 2).
// `area(C)` returns `r * 10`, `area(S)` returns `side`.

type C = { kind: i32, r: i32 }
type S = { kind: i32, side: i32 }

function area(sh: C | S): i32 {
  if sh is C { return sh.r * 10 } else { return sh.side }
}

function go() {
  const s: S = { kind: 1, side: 4 }

  // (1) for-in over a union array, narrowing the loop var in the body.
  const arr: (C | S)[] = [{ kind: 0, r: 7 }, s]
  for x in arr {
    if x is C { print(x.r) } else { print(x.side) } // 7, then 4
  }
  let total = 0
  for x in arr { total = total + area(x) }
  print(total) // area(C{7}) 70 + area(S{4}) 4 = 74

  // (3) push + indexed-assign of a concrete variant.
  const ps: (C | S)[] = [{ kind: 0, r: 1 }]
  ps.push(s) // push a variant
  print(area(ps[1])) // S{4} → 4
  ps[0] = { kind: 1, side: 9 } // indexed-assign a literal
  print(area(ps[0])) // S{9} → 9
  const c: C = { kind: 0, r: 4 }
  ps[0] = c // indexed-assign a variant
  print(area(ps[0])) // C{4} → 40

  // (2) map of union arrays: store (literal + variant), read, narrow, for-in over inner list.
  const m: {[string]: (C | S)[]} = Map()
  m["a"] = [{ kind: 0, r: 7 }, s]
  const xs = m["a"] ?? []
  print(xs.length) // 2
  const e = xs[0]
  if e is C { print(e.r) } // 7
  let inner = 0
  for v in xs { inner = inner + area(v) }
  print(inner) // 70 + 4 = 74
}
go()
