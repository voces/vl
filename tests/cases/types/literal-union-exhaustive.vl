// @run
// @log 12
// @log 1
// @log 0
// @log 10
// @log 30
// @log first
// @log second
// @log num
// @log str
// Literal unions behave like enums: a numeric-literal union supports arithmetic
// and comparison (it's its base scalar), and an `==`/`is` chain that covers every
// case is *exhaustive* — no spurious `| null` on the fall-through, so it returns
// a non-null type with no dummy `else`.

// Numeric-literal union is its base scalar for arithmetic / comparison.
function bump(n: 0 | 1 | 2) { return n + 10 }
print(bump(2))                          // 12
function low(n: 0 | 1 | 2) { if n < 2 { return 1 } return 0 }
print(low(1))                           // 1
print(low(2))                           // 0

// Exhaustive numeric discrimination — no `else`, no `| null`.
function score(n: 0 | 1 | 2): i32 {
  if n == 0 { return 10 }
  else if n == 1 { return 20 }
  else if n == 2 { return 30 }
}
print(score(0))                         // 10
print(score(2))                         // 30

// Exhaustive string-literal discrimination.
function rank(s: "first" | "second"): string {
  if s == "first" { return "first" }
  else if s == "second" { return "second" }
}
print(rank("first"))                    // first
print(rank("second"))                   // second

// Exhaustive `is` discrimination over a general union.
function classify(x: i32 | string): string {
  if x is i32 { return "num" }
  else if x is string { return "str" }
}
print(classify(5))                      // num
print(classify("a"))                    // str
