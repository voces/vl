// @check
// @error-at 7:4 cannot assign string to i32
// PIN GUARD (A-infer-null boundary): only `null` is hole-bearing. A COMPLETE type
// still pins — `let x = 7` is `i32` (a complete type, not a hole), so a later
// `x = "foo"` is a genuine type conflict, NOT hole-filling. The nullable-hole
// inference must not widen a complete-typed binding into a union.
let x = 7
x = "foo"
