// @run
// @log 9
// @log 90
// @log 50
// @log 7
// @log 2
// @log 3
// @log 4
// @log 12
// A CONCRETE union VARIANT type used as a first-class value — a local, a param, a return,
// an argument, and an array element — NOT boxed into the union. Each rides the variant
// struct `(ref $(uVarIdx + vi))` directly (kind 8), so field access reads it with no box
// unwrap. The object-literal construction is context-driven (`pendingVariantIdx`): a literal
// in a variant CONTEXT builds the bare variant; the same literal in a union context still
// boxes (the boxing path is untouched).

type Cat = { meow: i32 }
type Dog = { woof: i32 }
type Animal = Cat | Dog

// variant PARAM + field read.
function loud(c: Cat): i32 { return c.meow * 10 }
// variant RETURN (a `return { … }` builds the bare variant).
function mk(n: i32): Cat { return { meow: n } }
// variant ARRAY param.
function total(cs: Cat[]): i32 {
  let t = 0
  let i = 0
  while i < cs.length {
    t = t + cs[i].meow
    i = i + 1
  }
  return t
}

function go() {
  // variant LOCAL value.
  const c: Cat = { meow: 9 }
  print(c.meow) // 9

  // pass a variant VALUE and a variant LITERAL to a variant param.
  print(loud(c)) // 40
  print(loud({ meow: 5 })) // 50

  // a variant-returning call, bound and field-read.
  const m = mk(7)
  print(m.meow) // 7

  // variant ARRAY local: literal elements build bare variants; index + field read.
  const cs: Cat[] = [{ meow: 2 }, { meow: 3 }, { meow: 4 }]
  print(cs[0].meow) // 2
  print(cs[1].meow) // 3
  print(cs[2].meow) // 4
  print(total([{ meow: 5 }, { meow: 7 }])) // 12
}
go()
