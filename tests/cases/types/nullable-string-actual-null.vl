// @run
// @log -1
// @log -1
// @log -1
// @log -1
// @log x
// @log -1
// @log -1
// A `string | null` (kind 16) could be typed and narrowed, but an actual `null` VALUE compiled to INVALID
// wasm (or trapped). Two root causes, both fixed:
//  1. COLLECTION: `collectA` never forced the string backing (`$aTypeIdx`) for a `string | null`
//     annotation/field (only a plain `string` did), so with no other string in the module the kind-16
//     slot valtype + its `ref.null` referenced a stale type index. Now a `string | null` standalone
//     annotation AND a `string | null` field (code 20, incl. inline shapes) force `aUsed`, like `string`.
//  2. EAGER RECOVERY: reading a kind-16 ident / code-20 field AS A VALUE always `ref.as_non_null`'d it.
//     When the value flows into ANOTHER nullable-string target (`pendingNulString` — `const t = s`, an
//     arg/return, `const g = r.f`), that recovery traps on a real null. Now it keeps the raw nullable ref,
//     mirroring the kind-15 list read. (The i32/boolean LIST analogue was #683.)

function firstOr(s: string | null): i32 {
  // param: a null ARGUMENT
  const t = s // via-temp: bind the nullable param, then narrow
  if t != null { return 1 } else { return -1 }
}

function pick(b: i32): string | null {
  // return: a null / string RETURN
  if b > 0 { return "x" } else { return null }
}

function go() {
  const a: string | null = null // init
  if a != null {
    print(a) // -1
  } else {
    print(-1)
  }

  let b: string | null = "y"
  b = null // assignment
  if b != null {
    print(b) // -1
  } else {
    print(-1)
  }

  print(firstOr(null)) // -1

  if pick(0) != null {
    print(1) // -1 (null return)
  } else {
    print(-1)
  }
  const got: string | null = pick(1) // annotated binding of a string return
  if got != null {
    print(got) // x
  } else {
    print(-1)
  }

  // a `string | null` field holding null, narrowed directly.
  const r: { f: string | null } = { f: null }
  if r.f != null {
    print(r.f) // -1
  } else {
    print(-1)
  }

  // via-temp: bind the nullable field/ident, then narrow (used to trap on the eager recovery).
  const g = r.f
  if g != null {
    print(g) // -1
  } else {
    print(-1)
  }
}

go()
