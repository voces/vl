// @error cannot assign {f: f64} to 'o' of type {f: f32}?
// The nullable-wrapper widening is LITERAL-ONLY: a struct LITERAL whose field is an exactly
// re-encodable literal widens into `{f: f32} | null` (see
// `structs/nullable-wrapper-literal-widen.vl`), but a genuinely-wider field VALUE must still
// reject — an arbitrary `f64` narrowed to `f32` is a lossy demote no re-encode can recover.
// The nullable peel in `assignableExpr`'s ObjLit path only reaches the target; the per-field
// `assignableExpr` recursion still refuses the non-literal f64, so no lossy hole opens. This
// rejects identically to the bare `{f: f32}` spelling (the wrapper does not relax the rule).

function src(): f64 {
  return 2585.5
}

const o: {f: f32} | null = {f: src()}
