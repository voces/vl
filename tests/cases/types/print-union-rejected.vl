// @check
// @error print does not accept a union value
// CONTRACT (must-error): `print(<value-union>)` was a SOUNDNESS hole — the checker accepted
// it but emit produced invalid wasm (a union has no fixed scalar rep). Now a clean checker
// rejection: the union must be narrowed with `is` first. The inference itself is sound — a
// bound `const v = pick(...)` + `if v is i32 { print(v) }` compiles and runs.
function pick(c: boolean): i32 | string {
  if c { return 1 }
  return "x"
}
function go() {
  print(pick(true))
}
go()
