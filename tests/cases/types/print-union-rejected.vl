// @check
// @error print of a union value (i32 | string) is type-valid but not yet supported by codegen
// CONTRACT (must-error): `print(<value-union>)` was a SOUNDNESS hole — the checker accepted
// it but emit produced invalid wasm (a union has no fixed scalar rep). Now a clean rejection
// on the UNSUPPORTED-LOWERING channel (an emitter-capability admission carrying the stable
// `unsupported-lowering` code, not a type-soundness verdict): the union must be narrowed
// with `is` first. The inference itself is sound — a bound `const v = pick(...)` +
// `if v is i32 { print(v) }` compiles and runs.
function pick(c: boolean): i32 | string {
  if c { return 1 }
  return "x"
}
function go() {
  print(pick(true))
}
go()
