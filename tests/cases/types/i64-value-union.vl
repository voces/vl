// @run
// @log 5
// @log ok
// @log 9
// @log 7
// An i64 as a VALUE-UNION atom (`i64 | string`, `i64 | null`). Reading the i64 out via a
// direct `print(u)` after `is i64` narrowing emitted invalid wasm: the print-import detection
// only flagged a BARE `i64` annotation (`tyName == "i64"`), so a union/array annotation like
// `i64 | string` did not pull in `__print_i64__` — and `print(u)` then routed `fbCall(4)` to a
// non-existent import. The detection now fires for ANY i64-mentioning annotation
// (`strContains(tyName, "i64")`, mirroring the f32 rule), so `i64 | string` / `i64 | null` /
// `i64[]` all import the i64 print. (Storing / narrowing / binding to a typed `i64` local
// already worked — only the direct print of the narrowed union ident was broken.)

function pick(): i64 | string { return 9 }

function go() {
  // i64 | string holding an i64, printed directly after narrowing.
  const u: i64 | string = 5
  if u is i64 { print(u) } // 5

  // the string arm still prints.
  const w: i64 | string = "ok"
  if w is string { print(w) } // ok

  // an i64 | string returned from a function.
  const r = pick()
  if r is i64 { print(r) } // 9

  // i64 | null via `??`.
  const n: i64 | null = 7
  print(n ?? 0) // 7
}
go()
