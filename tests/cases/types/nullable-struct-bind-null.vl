// @run
// @log none
// @log 7
// @log 1
// A bare `null` INITIALIZER for a nullable-struct local (`let b: P | null = null`). The
// slot is kind 9 (`(ref null $P)`); the bare `null` previously failed emit ("bare null
// needs a struct-typed context") because the union annotation names no standalone struct,
// so `letAnnStructIdx` gave -1 and nothing seeded `pendingStructIdx`. The let path now
// falls back to the slot's recorded struct index (`localStructIdx`) for a kind-9 binding,
// so the `null` lowers as `ref.null $P` — mirroring the global nullable-struct cell.

type P = { x: i32 }

function go() {
  // bare null init, then a null check.
  const a: P | null = null
  if a == null {
    print("none") // none
  } else {
    print(a.x)
  }

  // non-null struct-literal init still builds the struct.
  const b: P | null = { x: 7 }
  if b != null {
    print(b.x) // 7
  }

  // null init, conditionally assigned, then narrowed.
  let c: P | null = null
  const cond = true
  if cond { c = { x: 1 } }
  if c != null {
    print(c.x) // 1
  }
}
go()
