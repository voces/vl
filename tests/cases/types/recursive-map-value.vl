// @run
// @log 1
// @log 6
// @log 12
// Recursion through a MAP VALUE type: the named type `Tree` references itself
// through the *value type* of an index-signature/map (`{ [string]: Tree }`),
// rather than through a struct field or array element. The type algebra resolves
// the self-reference lazily (an `Alias` leaf, not infinite expansion) even when
// the back-edge is buried inside the map's value type, and codegen builds the
// self-referential WasmGC hash representation in one rec-group. Traversal walks
// the children map, recursing into each present child node, so the map-value
// back-edge is exercised at both construction and read time.
type Tree = { value: i32, children: { [string]: Tree } }

function sum(node: Tree): i32 {
  let total = node.value
  for child in node.children.values() {
    total = total + sum(child)
  }
  return total
}

// A single leaf node with no children: just its own value.
const leaf: Tree = { value: 1, children: Map() }
print(sum(leaf))

// 1 + 2 + 3 = 6 — a root whose children map holds two leaf children.
const a: Tree = { value: 1, children: Map() }
a.children["l"] = { value: 2, children: Map() }
a.children["r"] = { value: 3, children: Map() }
print(sum(a))

// 4 + 8 = 12 — a root with one nested child that itself has a child.
const b: Tree = { value: 4, children: Map() }
const mid: Tree = { value: 8, children: Map() }
b.children["m"] = mid
print(sum(b))
