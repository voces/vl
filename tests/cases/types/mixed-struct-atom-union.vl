// @run
// @log 4
// @log hi
// @log 7
// @log 9
// @log 2
// A MIXED value union — a STRUCT variant alongside a value ATOM (`{v:i32} | string`,
// `{id:i32} | i32`), via a `type` ALIAS. Was a soundness hole: the checker accepted it but
// emit either rejected the atom variant at union registration ("unknown struct type") or,
// for the atom member, stored a raw scalar where the union box was expected (invalid wasm).
// Two fixes: (1) the `UnionDecl` registration now skips non-struct atoms + interns their
// value boxes, matching the inline-annotation path; (2) `emitUnionCoerce` resolves a union
// ALIAS to its member set so the value-atom boxing sees the atoms. The box stores a struct
// ref under the variant tag, a boxed scalar / string ref under the atom tag.

type Box = { v: i32 } | string
type Tagged = { id: i32 } | i32

function go() {
  // struct member, then atom (string) member — both boxed, narrowed back out.
  let b: Box = { v: 4 }
  if b is { v: i32 } {
    print(b.v) // 4
  }
  b = "hi"
  if b is string {
    print(b) // hi
  }

  // struct member, then atom (i32) member.
  let t: Tagged = { id: 7 }
  if t is { id: i32 } {
    print(t.id) // 7
  }
  t = 9
  if t is i32 {
    print(t) // 9
  }

  // a struct-typed local flowing into the union (no reassign).
  const b2: Box = { v: 2 }
  if b2 is { v: i32 } {
    print(b2.v) // 2
  }
}
go()
