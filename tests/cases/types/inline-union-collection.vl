// @run
// @log 4
// @log 7
// @log 74
// @log 4
// @log 70
// @log 9
// An INLINE struct union used ONLY inside a collection — `(C | S)[]` and `{[string]: C | S}`
// — registers itself. `collectInlineUnions` only scanned param / return / let / field
// annotations, so a union appearing nowhere but a collection element was never interned: `is`
// over a read element failed ("`is` test but no union type declared") and the inline array
// name was not recognized as a ref array. `registerInlineUnion` now RECURSES into a
// collection name — the element via `parenUnionArrElemName` (broadened to struct unions) and
// the map value via `mapValNameOf` — and an array-LITERAL element / map store boxes a
// concrete variant via `emitUnionBoxArg`. Brings inline unions to parity with a `type Shape =
// C | S` alias for literal construction, indexed read, narrow, and map store. (`for`-in over
// a union-element array, maps-of-union-ARRAYS, and `push` / indexed-assign of a variant into a
// union array remain unsupported for named aliases too — orthogonal follow-ups.)

type C = { kind: i32, r: i32 }
type S = { kind: i32, side: i32 }

function area(sh: C | S): i32 {
  if sh is C { return sh.r * 10 } else { return sh.side }
}

function go() {
  // A standalone inline `(C | S)[]` — the union appears in NO other annotation. The literal
  // mixes a concrete VARIANT value (`s`) with a struct literal element.
  const s: S = { kind: 1, side: 4 }
  const arr: (C | S)[] = [s, { kind: 0, r: 7 }]

  const e0 = arr[0]
  if e0 is S { print(e0.side) } // 4
  const e1 = arr[1]
  if e1 is C { print(e1.r) } // 7

  // index reads dispatched through the union helper: S{4} → 4, C{7} → 70.
  print(area(arr[0]) + area(arr[1])) // 4 + 70 = 74

  // A standalone inline `{[string]: C | S}` — union only as the map value.
  const m: {[string]: C | S} = Map()
  m["a"] = { kind: 1, side: 4 } // a struct literal
  m["b"] = s                    // a concrete variant value (boxes on store)

  const ga = m["a"] ?? { kind: 0, r: 0 }
  if ga is S { print(ga.side) } // 4
  const c: C = { kind: 0, r: 7 }
  m["c"] = c
  const gc = m["c"] ?? { kind: 1, side: 0 }
  print(area(gc)) // C{r:7} → 70

  // overwrite a key with the other variant, then read.
  m["a"] = { kind: 1, side: 9 }
  const ga2 = m["a"] ?? { kind: 0, r: 0 }
  if ga2 is S { print(ga2.side) } // 9
}
go()
