// @run
// @log 7
// @log 99
// @log 42
// @log 0
// @log 3
// Null-coalescing `x ?? y`: `x` when non-null, else `y`. Result type is the
// non-null part of `x` unioned with `y`'s type.

// Nullable scalar with a default.
function orDefault(a: i32 | null) {
  return a ?? 99
}
print(orDefault(7))     // 7
print(orDefault(null))  // 99

// Nullable object field, defaulted.
const o: {n: i32} | null = {n: 42}
print(o?.n ?? 0)        // 42
const m: {n: i32} | null = null
print(m?.n ?? 0)        // 0

// Chained `??` falls through to the first non-null.
const a: i32 | null = null
const b: i32 | null = 3
print(a ?? b ?? 100)    // 3
