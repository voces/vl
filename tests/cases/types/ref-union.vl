// @run
// @log 7
// @log hi
// @log true
// @log world
// @log 10
// @log 20
// @log 9000000000
// @log true
// A union with a reference member, or members of differing wasm reps, boxes
// into a `{ tag, value: anyref }` struct: a reference rides in `value` directly,
// a scalar in a one-field box. `is T` reads the tag and `ref.cast`s the payload
// back. (Same-rep value unions keep the cheaper unboxed-payload form — see
// value-union.vl.)

// reference | scalar, including null
function show(v: string | i32 | null) {
  if v is i32 { print(v) }
  if v is string { print(v) }
  if v == null { print(true) }
}
show(7)
show("hi")
show(null)
let n: string | i32 | null = "world"
if n is string { print(n) }

// reference | reference (distinct shapes), across a function boundary
function make(b: boolean): {x: i32} | {y: i32} {
  if b { return {x: 10} }
  return {y: 20}
}
let p = make(true)
if p is {x: i32} { print(p.x) }      // 10
let q = make(false)
if q is {y: i32} { print(q.y) }      // 20

// scalar | scalar of differing reps (boolean is i32-wide, i64 is not) → boxed
let w: boolean | i64 = 9000000000
if w is i64 { print(w) }             // 9000000000 (full i64 range)
w = true
if w is boolean { print(w) }         // true
