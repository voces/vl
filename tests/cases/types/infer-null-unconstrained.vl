// @run
// @log 1
// @hint Intentionally-unused variable `_x`
// UNCONSTRAINED `let x = null` (A-infer-null): a lone `let x = null` that is never
// reassigned or otherwise used to pin its `T` resolves to the plain `null` type. A
// lone `null` IS fully determined (unlike an empty `[]`, whose element is genuinely
// unknown), so it must NOT raise the "cannot infer — annotate" floor diagnostic —
// the absence of any `@error` here asserts the floor stays silent. (The lone null
// lives in an un-called function so its degenerate `null` value isn't lowered; the
// point is the type-check floor, not codegen of a bare null.)
function unused() {
  let _x = null
  print(0)
}
print(1)
