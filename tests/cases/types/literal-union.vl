// @run
// @log 1
// @log 2
// @log 10
// @log 20
// @log 30
// @log circle
// Literal-union types (`"a" | "b"`, `0 | 1 | 2`) discriminate with `==` / `!=`,
// yielding a boolean and narrowing the place in the branch. (They lower through
// the softened base type's equality — string or numeric — at runtime.)

// String-literal union.
function kind(s: "expense" | "reimbursement") {
  if s == "expense" { return 1 }
  return 2
}
print(kind("expense"))        // 1
print(kind("reimbursement"))  // 2

// Numeric-literal union, discriminated by an `==`/`else if` chain.
function score(x: 0 | 1 | 2) {
  if x == 0 { return 10 }
  else if x == 1 { return 20 }
  return 30
}
print(score(0))   // 10
print(score(1))   // 20
print(score(2))   // 30

// A string-literal-tagged record: discriminate on the tag field.
const shape: {tag: "circle" | "square", r: i32} = {tag: "circle", r: 5}
if shape.tag == "circle" { print("circle") } else { print("square") }
