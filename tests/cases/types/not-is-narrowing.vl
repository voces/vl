// @run
// @log 6
// @log other
// @log 105
// @log 7
// @log 0
// Negated type guard `x !is T` (A4) — the mirror image of `x is T` (A6). It
// yields the inverted boolean and swaps the branch narrowings: in the THEN
// branch `x` is `typeof x − T` (the complement), in the ELSE branch it is `T`.
// So `!is` discriminates a union exactly like `is`, just from the other side.

// THEN narrows to the complement (`i32`), so `v + 1` typechecks and unboxes.
function inc(v: string | i32): i32 {
  if v !is string { return v + 1 }
  return 0
}
print(inc(5))      // 6
function tag(v: string | i32): string {
  if v !is i32 { return v } else { return "other" }
}
print(tag("other"))  // other (THEN: v is string)

// ELSE narrows to `T` (here `i32`), so `v + 100` typechecks there.
function bonus(v: string | i32): i32 {
  if v !is i32 { return 0 } else { return v + 100 }
}
print(bonus(5))    // 105

// `!is null` is the non-null narrowing, inverted: THEN is the non-null view.
function unwrap(x: i32 | null): i32 {
  if x !is null { print(x) } else { print(0) }
  return 0
}
unwrap(7)          // 7
unwrap(null)       // 0
