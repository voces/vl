// @error cannot assign () -> i32 to 'v' of type () -> i64
// Numeric prims are INVARIANT inside a function type: a NAMED function value's wasm
// functype fixes its result rep and no adapter thunk exists at the assignment seam, so
// `() => i32` must not flow into a `() => i64` slot (accepted, it emitted an i32-result
// functype every i64-expecting call site mistrusts — invalid wasm). A lambda LITERAL in
// the same position still widens: its body adopts the contextual return (see
// `tests/cases/closures/lambda-return-widens-i64.vl`).

function g(): i32 {
  return 5
}

const v: () => i64 = g
print(v())
