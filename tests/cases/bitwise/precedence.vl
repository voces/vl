// @run
// @log 3
// @log 24
// @log 6
// @log 5
// Mixed-operator precedence (C/JS family):
//   `1 | 2 & 3`  = `1 | (2 & 3)` = `1 | 2` = 3    (& binds tighter than |)
//   `1 + 2 << 3` = `(1 + 2) << 3` = `3 << 3` = 24 (shift looser than +)
//   `2 | 1 << 2` = `2 | (1 << 2)` = `2 | 4` = 6   (shift binds tighter than |)
//   `1 ^ 2 ^ 6`  = `(1 ^ 2) ^ 6` = `3 ^ 6` = 5    (^ is left-associative)
print(1 | 2 & 3)
print(1 + 2 << 3)
print(2 | 1 << 2)
print(1 ^ 2 ^ 6)
