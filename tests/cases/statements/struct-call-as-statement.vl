// @run
// @log 99
// @log 7
// A struct-returning function called as a bare statement (purely for effect):
// its non-numeric (`ref`) result is unconsumed and must be dropped. Before the
// fix this left a struct value on the stack → wasm validation error.
type Point = { x: i32, y: i32 }
let sideEffect = 0
function make(): Point {
  sideEffect = 99
  return { x: 1, y: 2 }
}
make() // discarded; runs for its side effect
print(sideEffect) // 99 — the call really executed
print(7)
