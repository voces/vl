// @run
// @log 1
// @log 5
// @log 8
// P1-3: `let r = f()` where `f` returns a struct or `T | null`, with the call's
// result NOT directly consumed in a builtin. The initializer must lower under the
// binding's own (inferred) type — not a spurious numeric desired-type default
// that mis-lowered to `Expected numeric type` at module scale.
type Point = { x: i32, y: i32 }
function make(): Point { return { x: 1, y: 2 } }
function find(): i32 | null { return 5 }

let p = make() // struct result, un-annotated let
print(p.x) // 1

let n = find() // `i32 | null` result, un-annotated let
if n != null {
  print(n) // 5
}

// inside a function body too (block-inferred, not just module scope)
function go(): i32 {
  let q = make()
  return q.x + q.y + 5
}
print(go()) // 8
