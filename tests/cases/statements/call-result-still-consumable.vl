// @run
// @log 42
// @log 43
// @log 42
// Don't-regress guard: a call whose result IS consumed must still work — both
// when nested directly in a builtin call (the one form that compiled before the
// fix) and when its struct result is read via a field access. A `void`-returning
// call used as a statement also still works (nothing to drop).
type Box = { v: i32 }
function box(): Box { return { v: 42 } }
function inc(x: i32) { return x + 1 }
let logged = 0
function noteOnly() { logged = 1 } // returns void

print(box().v) // 42 — struct result consumed via field access
print(inc(box().v)) // 43 — result consumed directly in a call
noteOnly() // void call as a statement: nothing to drop
print(box().v) // 42 — still works after a void-call statement
