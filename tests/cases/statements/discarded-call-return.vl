// @run
// @log 42
// REGRESSION PIN: a non-void call may be DISCARDED at statement position, and its
// result may be `let`-bound — both used to mis-lower at module scale ("Expected
// numeric type"), forcing `checkProgram`'s callers into expression position
// (`compiler/typecheck.vl` PR #5 gap).
function work(): i32 {
  42
}
function f(): i32 {
  work()
  const r = work()
  r
}
print(f())
