// @run
// @log 2
// @log 1
// P1-4, the exact spike shape: `.pop()` on a STRUCT-FIELD array in statement
// position. `s.scopes.pop()` returns `i32 | null`; discarded, its value must be
// dropped or the binaryen validator rejects the module.
type State = { scopes: i32[] }
let s: State = { scopes: [] }
s.scopes.push(1)
s.scopes.push(2)
print(s.scopes.length) // 2
s.scopes.pop() // for effect; result undropped before the fix
print(s.scopes.length) // 1
