// @run
// @log 2
// @log 1
// `arr.pop()` used as a bare statement: it returns `T | null`, but its result is
// discarded, so the value left on the wasm stack must be `drop`-ed (a non-final
// block element that returns a value is invalid wasm). Regression for P1-4 —
// before the fix this leaked an undropped value (`non-final block elements
// returning a value must be dropped`); the workaround was `let _ = arr.pop()`.
const xs: i32[] = []
xs.push(10)
xs.push(20)
print(xs.length) // 2
xs.pop() // discarded for effect — no validation error
print(xs.length) // 1
