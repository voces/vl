// @run
// @log abc
// @log y
// @log 6.5
// @log 10.5
// @log a
// @log 10
// An un-annotated (hole) PARAM whose element flows into a RETURNED scalar LOCAL now lowers for
// non-i32 elements. The monomorphizer pins the param per call shape (`self: string[]` / `f64[]`),
// but the emitter's return-kind inference runs BEFORE locals are collected and the checker's
// typed-IR is stale for a hole-derived node — so a `return <local>` whose local is a scalar
// element of the hole param defaulted the instance's functype result to i32 and clashed with the
// string/f64 ref the body returns. The instance now re-checks the body with its params pinned
// (`monoInferLocalScalar`) and types the un-annotated return from the resolved scalar. i32 keeps
// `nret = -1` (its inference already handles it) → byte-identical.

// A string-element FOLD: the accumulator is a returned scalar local built over the hole element.
function join(self) {
  let acc = ""
  let i = 0
  while i < self.length {
    acc = acc + self[i]
    i = i + 1
  }
  return acc
}
print(join(["a", "b", "c"])) // abc

// `const t = self[i]; return t` — binding the hole element to a returned local.
function second(self) {
  const t = self[1]
  return t
}
print(second(["x", "y"])) // y

// The f64 analogue: an f64-element fold returning the accumulator.
function sumf(self) {
  let acc = 0.0
  let i = 0
  while i < self.length {
    acc = acc + self[i]
    i = i + 1
  }
  return acc
}
print(sumf([1.5, 2.0, 3.0])) // 6.5

// f64 element bound to a returned local.
function firstf(self) {
  const t = self[0]
  return t
}
print(firstf([10.5, 20.5])) // 10.5

// The SAME hole function instantiated at string[] AND i32[]: each instance's return is typed
// from its own pinned element (the i32 instance keeps the byte-identical inferred path).
function first(self) {
  const t = self[0]
  return t
}
print(first(["a", "b"])) // a
print(first([10, 20])) // 10
