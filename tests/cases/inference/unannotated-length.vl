// @run
// @log 3
// @log 30
// @log z
// @log 10
// NORTH-STAR step 2: `self.length` on an UN-ANNOTATED parameter infers as the i32 length an
// array / string / map exposes — so an un-annotated param used as a collection (`self[i]`
// from step 1 PLUS `self.length`) drives real length-based logic with no `<T>` / `: T[]`.
// The checker treats `.length` on an inference-hole receiver as i32 directly (rather than
// growing a `{length}` struct shape an array argument can't satisfy); a non-`length` field
// still grows the hole's struct shape. The emitter monomorphizes per call shape.
//
// (Combined with step 1 + the inferred `[]`-build, the fully un-annotated `reverse(self)`
// now TYPE-CHECKS; lowering it is blocked only on the un-annotated-list-return under
// monomorphization — the remaining follow-up. Scalar-returning length/index logic lowers.)

// Bare `.length`.
function count(self) {
  return self.length
}
print(count(["a", "b", "c"])) // 3

// `.length` AND indexing together: the last element via a length-derived index.
function lastEl(self) {
  return self[self.length - 1]
}
print(lastEl([10, 20, 30]))   // 30
print(lastEl(["x", "y", "z"])) // z  (same definition, string element)

// A length-bounded loop reducing over the elements.
function sum(self) {
  let s = 0
  let i = 0
  while i < self.length {
    s = s + self[i]
    i = i + 1
  }
  return s
}
print(sum([1, 2, 3, 4])) // 10
