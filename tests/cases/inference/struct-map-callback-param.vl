// @run
// @log 2
// @log 22
// @log b
// @log 9
// An un-annotated `.map` callback param over a STRUCT array infers its struct type from the
// receiver element (`ps.map((p) => p.x)`), so `p.x` — and passing `p` whole to a struct fn —
// lower without the explicit `(p: P)` annotation. Covers single-field, multi-field (the
// field-set match had a separator-space bug), and a string field.

type P = { x: i32 }
type Pt = { x: i32, y: i32 }
type Rec = { name: string, age: i32 }

function id(p: P) { return p.x }

function go() {
  const ps: P[] = [{ x: 1 }, { x: 2 }]
  print(ps.map((p) => p.x)[1]) // 2

  const pts: Pt[] = [{ x: 1, y: 10 }, { x: 2, y: 20 }]
  print(pts.map((p) => p.x + p.y)[1]) // 22  (multi-field shape resolves to Pt)

  const rs: Rec[] = [{ name: "a", age: 1 }, { name: "b", age: 2 }]
  print(rs.map((r) => r.name)[1]) // b   (string field)

  // The inferred struct param passed WHOLE to a struct-typed function.
  const sum = ps.map((p) => id(p))
  print(sum[0] + ps[1].x + 6) // 9  (1 + 2 + 6)
}
go()
