// @run
// @log 3
// @log 2
// @log 1
// @log c
// @log 6
// @log x
// THE NORTH STAR: a FULLY un-annotated `reverse(self)` — no `<T>`, no `: T[]` anywhere —
// type-checks AND lowers. `self` is inferred as an array from `self[i]` / `self.length`
// (steps 1 & 2); `out` is inferred from the pushes and the inferred `[]`-build; and the
// un-annotated `return out` is typed under monomorphization by tracing the returned list back
// to the indexed param (`out.push(self[i])` ⇒ `out` shares `self`'s array type), giving the
// instance its concrete return type. One definition serves i32 and string — instantiated
// independently in the SAME program (each instance carries its own return type).
//
// (f64 / struct element reverses are a known follow-up: an un-annotated function's body is
// SHARED across instances, so the inferred list local can't carry a per-instance annotation;
// i32/string classify per instance through usage, f64/struct would need the per-rep usage
// path. Those reverses fail loudly at emit, never miscompile.)

function reverse(self) {
  const out = []
  let i = self.length - 1
  while i >= 0 {
    out.push(self[i])
    i = i - 1
  }
  return out
}

// i32 — reversed order verified element by element.
const r = reverse([1, 2, 3])
print(r[0]) // 3
print(r[1]) // 2
print(r[2]) // 1

// string — the SAME definition, a second instance in the same program.
print(reverse(["a", "b", "c"])[0]) // c

// A different build-and-return shape (push without a length loop) infers too.
function take2(self) {
  const out = []
  out.push(self[0])
  out.push(self[1])
  return out
}
print(take2([5, 6, 7])[1])         // 6
print(take2(["x", "y", "z"])[0])   // x
