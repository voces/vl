// @run
// @log 3
// @log 2
// @log 1
// @log c
// @log 3.5
// @log 2
// @log 6
// @log x
// THE NORTH STAR: a FULLY un-annotated `reverse(self)` — no `<T>`, no `: T[]` anywhere —
// type-checks AND lowers, for EVERY element type. `self` is inferred as an array from
// `self[i]` / `self.length`; `out` is inferred from the pushes and the inferred `[]`-build;
// and the un-annotated `return out` is typed under monomorphization by tracing the returned
// list back to the indexed param (`out.push(self[i])` ⇒ `out` shares `self`'s array type).
//
// Each call shape gets its OWN cloned instance body, so the inferred list local carries a
// per-instance annotation (`out: f64[]` in the f64 instance, `out: P[]` in the struct one) —
// that is what lets i32 / string / f64 / struct reverses coexist in one program.

type P = { v: i32 }

function reverse(self) {
  const out = []
  let i = self.length - 1
  while i >= 0 {
    out.push(self[i])
    i = i - 1
  }
  return out
}

// i32 — reversed order verified element by element.
const r = reverse([1, 2, 3])
print(r[0]) // 3
print(r[1]) // 2
print(r[2]) // 1

// string / f64 / struct — the SAME definition, four independent instances in ONE program.
print(reverse(["a", "b", "c"])[0])         // c
print(reverse([1.5, 2.5, 3.5])[0])         // 3.5
print(reverse([{ v: 1 }, { v: 2 }])[0].v)  // 2

// A different build-and-return shape (push without a length loop) infers too.
function take2(self) {
  const out = []
  out.push(self[0])
  out.push(self[1])
  return out
}
print(take2([5, 6, 7])[1])       // 6
print(take2(["x", "y", "z"])[0]) // x
