// @run
// @log 6
// @log 5
// @log 20
// @log 2
// LIFTING THE ELEMENT-HOLE CEILING: an inferred empty-list local built from a NON-TRIVIAL
// expression over an un-annotated param's element — `out.push(self[i] * 2)`, not a bare
// `out.push(self[i])` — now type-checks AND lowers for every element type. The shared
// definition body is checked once with the element as an opaque hole, so the pushed
// expression (`hole * 2`) can't pin `out`'s element there; the monomorphizer re-checks the
// body per call shape with the parameter bound CONCRETELY, and the checker's own list-element
// inference resolves the local (`out: i32[]` in the i32 instance, `out: f64[]` in the f64 one).
//
// This generalizes the pass-through trace (`reverse(self)`, where the build is a bare index)
// to ANY pushed expression — arithmetic here, but the same isolated re-check types calls,
// field reads, and nested forms — so element-operating builds are handled generically rather
// than by a per-expression-shape trace in the emitter.

function scaleAll(self) {
  const out = []
  let i = 0
  while i < self.length {
    out.push(self[i] * 2)
    i = i + 1
  }
  return out
}

// i32 and f64 — two independent instances of the SAME un-annotated definition in ONE program.
print(scaleAll([1, 2, 3])[2])    // 6   (3 * 2)
print(scaleAll([1.5, 2.5])[1])   // 5   (2.5 * 2.0)
print(scaleAll([10, 20, 30])[0]) // 20  (10 * 2)

// A single push (no length loop) over an element expression infers too.
function firstPlusOne(self) {
  const out = []
  out.push(self[0] + 1)
  return out
}
print(firstPlusOne([1, 2, 3])[0]) // 2   (1 + 1)
