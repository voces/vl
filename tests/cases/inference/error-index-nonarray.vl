// @check
// @error argument 1: expected an array, got i32
// An un-annotated parameter that the body INDEXES (`self[0]`) is inferred to demand an array
// (the indexing analogue of `self.x` demanding a struct shape). A scalar argument therefore
// can't be indexed, so it is rejected at CHECK time — instead of type-checking and only
// failing later at emit. `head([1, 2, 3])` is fine; `head(5)` is not.

function head(self) {
  return self[0]
}

print(head(5))
