// @run
// @log ok
// @hint Intentionally-unused variable `_v`
// @hint Intentionally-unused variable `_w`
// An un-annotated field LAMBDA in a struct literal that flows into a UNION infers its
// parameter type from the matching struct ARM of the union — the object dual of the
// closure-arm seeding (`() => 5` into `(() => i64) | {w:i32}`). Before the fix, `seedExpected`
// descended a struct literal only against a bare `TyObj` target, so a struct literal against a
// `{f: (i32) => T, …} | X` union left the field lambda's param un-seeded and the checker failed
// "cannot infer a type for parameter `q`". Now it picks the covering object arm and seeds the
// field lambda's param from that arm's field type; assignability still gates the whole literal,
// and the arm boxes into the union's `{tag, value}` rep (valid wasm — construction is exercised
// here; a narrowed READ of a closure-valued field is a separate, still-loud emit gap).

function makeIt(): {f: (i32) => i32} | i32 {
  return {f: (q) => (q + 47)}
}

function multi(): {a: i32, f: (i32) => i32, z: boolean} | i32 {
  return {a: 3, f: (n) => (n + 1), z: true}
}

function go() {
  const _v = makeIt()
  const _w = multi()
  print("ok")
}

go()
