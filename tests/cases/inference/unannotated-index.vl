// @run
// @log 1
// @log a
// @log 1.5
// @log 7
// @log 103
// NORTH-STAR step 1: an UN-ANNOTATED parameter that is INDEXED (`self[i]`) is inferred to
// be an array — no `<T>`, no `: T[]`. The checker treats the param as an inference hole and,
// on `self[i]`, demands an array and returns the element as a derived `?elem.<hole>` hole,
// resolved per call site against the pinned argument's element type (mirroring how `self.x`
// already infers a struct). The emitter monomorphizes per call shape, so ONE definition
// serves i32 / string / f64 / struct element arrays. (`self.length` — and thus a full
// un-annotated `reverse(self)` — is the next step; an indexed non-array arg is rejected at
// emit, not yet at check.)

function head(self) {
  return self[0]
}

print(head([1, 2, 3]))         // 1     (i32 element)
print(head(["a", "b"]))        // a     (string element)
print(head([1.5, 2.5]))        // 1.5   (f64 element — mono synthesizes the f64 return)

type P = { v: i32 }
print(head([{ v: 7 }, { v: 8 }]).v) // 7  (struct element, field read on the result)

// The inferred element participates in arithmetic like any i32.
print(head([3, 4]) + 100)      // 103
