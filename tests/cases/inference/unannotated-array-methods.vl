// @run
// @log 6
// @log 4
// @log 3
// @log 4
// COLLECTION METHODS ON AN UN-ANNOTATED PARAM: `self.map(...)` / `self.filter(...)` /
// `self.push(...)` on a parameter with no annotation now type-check and lower — the method
// analogue of `self[i]` and `self.length`. The receiver hole is recognized as an array (its
// element a derived hole, `?elem.self`), so the existing array-method machinery — including
// the contextual callback-param inference (`(x) => …` infers `x` from the element) — applies
// unchanged, and the call site pins the param to the concrete array per shape. Previously the
// hole grew a `{map: any}` struct shape that no array argument could satisfy, so a bare
// `function dbl(self) { return self.map((x) => x * 2) }` was rejected at check.

// `.map` with an UN-annotated callback — `x` is inferred as the element type.
function dbl(self) {
  return self.map((x) => x * 2)
}
print(dbl([1, 2, 3])[2]) // 6  (3 * 2)

// `.filter` with an un-annotated predicate, then index the result.
function bigs(self) {
  return self.filter((x) => x > 2)
}
print(bigs([1, 2, 3, 4])[1]) // 4

// `.map` result `.length`.
print(dbl([10, 20, 30]).length) // 3

// `.push` + `.length` mutate-and-measure on an un-annotated array param.
function addOne(self) {
  self.push(99)
  return self.length
}
print(addOne([1, 2, 3])) // 4
