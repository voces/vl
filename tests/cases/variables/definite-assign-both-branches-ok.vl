// @run
// @log 1
// @log 2
// Path join: an uninitialized `let x` assigned on BOTH branches of an `if`/`else`
// is definitely assigned at the merge, so the later read is sound — it compiles
// and produces the value written on whichever branch ran.
function f(c: boolean): i32 {
  let x: i32
  if c { x = 1 } else { x = 2 }
  return x
}
print(f(true))
print(f(false))
