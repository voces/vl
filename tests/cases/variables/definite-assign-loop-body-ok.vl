// @run
// @log 0
// @log 1
// @log 2
// @log 3
// @log 0
// A read INSIDE a loop body, after the in-body assignment, is definitely
// assigned on that path — sound. (The after-loop read is the separate
// zero-iteration case, covered by `definite-assign-after-loop-error`.)
function f(): i32 {
  let x: i32
  for i in 0 to 3 {
    x = i
    print(x)
  }
  return 0
}
print(f())
