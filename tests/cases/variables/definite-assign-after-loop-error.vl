// @check
// @error `x` is used before it is assigned
// Zero-iteration loops: a `while`/`for` body may run zero times, so an
// assignment inside it does NOT make `x` definitely assigned after the loop —
// the read after the loop is an error.
function f(c: boolean): i32 {
  let x: i32
  while c { x = 1 }
  return x
}
print(f(false))
