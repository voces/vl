// @run
// @log 1
// Divergence: a branch that `return`s does not need to assign for the join — its
// end is unreachable. After `if c { return 0 }` only the fall-through survives,
// where `x = 1` assigns it, so the final read is sound.
function f(c: boolean): i32 {
  let x: i32
  if c { return 0 }
  x = 1
  return x
}
print(f(false))
