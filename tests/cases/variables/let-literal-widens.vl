// @run
// @log 1
// @log hi
// A `let` binding inferred from a literal widens to the literal's base type
// (`0` → `i32`, `""` → `string`), because the binding is reassignable — so a
// later assignment of a different value of the same base type type-checks
// against the cell, not against the initializer's singleton literal type.
let n = 0
n = 1
print(n)
let s = ""
s = "hi"
print(s)
