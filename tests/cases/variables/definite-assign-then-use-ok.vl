// @run
// @log 7
// The straight-line case: an uninitialized `let x` written before it is read is
// definitely assigned at the read — sound. The declaration being uninitialized is
// fine; only a read that PRECEDES every assignment is an error.
function f(): i32 {
  let x: i32
  x = 7
  return x
}
print(f())
