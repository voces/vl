// @check
// @error `x` is used before it is assigned
// Definite assignment (A-definite-assign): an uninitialized `let x: T` starts
// UNassigned and is NON-null. Reading it before it is written is an error — this
// closes the silent-`0` soundness gap (`let x: i32; return x` used to compile and
// return a fabricated 0). The declaration is fine; the READ is what's gated.
function f(): i32 {
  let x: i32
  return x
}
print(f())
