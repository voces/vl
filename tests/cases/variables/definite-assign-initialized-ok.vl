// @run
// @log 8
// An initialized `let x = …` and a `const` are assigned from the start, so the
// definite-assignment check never touches them — reads are always sound. (The
// uninitialized `let x: T` is the only form gated.)
function f(): i32 {
  let x = 5
  const y = 3
  x = x + y
  return x
}
print(f())
