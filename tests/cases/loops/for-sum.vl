// @run
// @log 10
// @skip BUG: for codegen re-declares the loop variable (= from) inside the loop
// @skip body every iteration, so it never advances; this sums to 0 instead of
// @skip iterating. Also `step` is ignored (hardcoded +1). Expected: sum of
// @skip 0..4 = 10 (inclusive semantics TBD). Fix the For case in toWasm.ts.
let s = 0
for i in 0 to 4 {
  s = s + i
}
__store_i32__(0, 0)
__store_i32__(4, s)
__log__(0, 8)
