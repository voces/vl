// @run
// @log 100
// @log 9
// for…in over an array (ROADMAP B8): the `to`-less `for x in arr` binds `x` to
// each element, lowered to a 0..length index loop over array.get (iterable
// evaluated once). Works over a variable and a literal; the body can branch.
let a = [10, 20, 30, 40]
let s = 0
for x in a {
  s = s + x
}
__store_i32__(0, 0)
__store_i32__(4, s)
__log__(0, 8)
let t = 0
for v in [1, 2, 3, 4, 5] {
  if v > 3 then t = t + v
}
__store_i32__(4, t)
__log__(0, 8)
