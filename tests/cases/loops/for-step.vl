// @run
// @log 12
// @log 15
// `step` controls both the increment and the loop direction. Ascending: 0,2,4,6
// → 12. A negative step counts down (5,4,3,2,1 → 15) — the exit test flips with
// the step's sign.
let s = 0
for i in 0 to 6 step 2 {
  s = s + i
}
__store_i32__(0, 0)
__store_i32__(4, s)
__log__(0, 8)
let d = 0
for i in 5 to 1 step -1 {
  d = d + i
}
__store_i32__(4, d)
__log__(0, 8)
