// @run
// @log 12
// @log 8
// `continue` skips the rest of the body. In a for loop the step still runs.
let ws = 0
let i = 0
while i < 5 {
  i = i + 1
  if i == 3 then continue
  ws = ws + i
}
__store_i32__(0, 0)
__store_i32__(4, ws)
__log__(0, 8)

let fs = 0
for j in 0 to 4 {
  if j == 2 then continue
  fs = fs + j
}
__store_i32__(4, fs)
__log__(0, 8)
