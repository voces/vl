// @check
// @no-error
// @warning range is empty and never iterates
// A provably-empty literal range warns (not errors): it still compiles and runs,
// but the body never executes, which is almost always a bug. (Descending needs a
// negative step — `5 to 1 step -1` would not warn.)
let s = 0
for i in 5 to 1 {
  s = s + i
}
