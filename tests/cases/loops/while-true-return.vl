// @run
// @log 0
// @log 7
// @log 4
// A `while true` with no escaping `break` diverges (it only leaves via `return`),
// so it never contributes a `… | null` to the function's type (B11). With a
// `break`, it falls through normally.
function countdown(n: i32): i32 {
  let i = n
  while true {
    if i <= 0 { return 0 }
    i = i - 1
  }
}
print(countdown(5))

function firstHit(n: i32): i32 {
  let i = 0
  while true {
    if i == n { break }
    i = i + 1
  }
  return i
}
print(firstHit(7))

// Inferred return through a divergent `while true` (return value is a local i32).
function findIndex(n) {
  let i = 0
  while true {
    if i >= n { return i }
    i = i + 1
  }
}
print(findIndex(4))
