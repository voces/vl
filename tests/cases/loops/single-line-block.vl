// @run
// @log 6
// @log 9
// Single-line block bodies parse as blocks, not object literals: block braces no
// longer require a leading newline, so `object` (tried first, fails on a non-pair
// like `s = …`) falls back to `block`. Object literals still win on key:value
// contents (`{ x: 4, y: 5 }`).
let s = 0
for i in 0 to 3 { s = s + i }
__store_i32__(0, 0)
__store_i32__(4, s)
__log__(0, 8)
let p = { x: 4, y: 5 }
let t = 0
if p.x > 0 { t = p.x + p.y }
__store_i32__(4, t)
__log__(0, 8)
