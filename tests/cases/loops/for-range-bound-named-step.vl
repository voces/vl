// @run
// @log 10
// Disambiguation: `step` here is a `const`-bound *variable* used as the range's
// (inclusive) upper bound, not the `step` soft keyword. The body is
// `{`-delimited, so the greedy bound expression (`step`) ends at `{` and there
// is no step-clause — the loop runs 0,1,2,3,4 → 10 with an implicit step of 1.
const step = 4
let total = 0
for i in 0 to step {
  total = total + i
}
print(total)
