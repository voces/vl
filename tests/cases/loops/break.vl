// @run
// @log 15
// @log 25
// @log 2
// `break` exits the innermost loop; a labelled `break outer` exits that loop.
// (Coexists with `continue`.)

// break in a `for`: sums 1..5, then i > 5 breaks.
let s = 0
for i in 1 to 100 {
  if i > 5 { break }
  s = s + i
}
print(s)

// break + continue in a `while`: add odd i until i > 9 (1+3+5+7+9 = 25).
let t = 0
let i = 0
while i < 100 {
  i = i + 1
  if i % 2 == 0 { continue }
  if i > 9 { break }
  t = t + i
}
print(t)

// Labelled break exits the OUTER loop: i=1 runs j=1,2 then j==3 breaks out.
let count = 0
outer: for a in 1 to 5 {
  for b in 1 to 5 {
    if b == 3 { break outer }
    count = count + 1
  }
}
print(count)
