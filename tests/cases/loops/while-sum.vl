// @skip BUG: while codegen is inverted — it branches back to the loop when the
// @skip condition is TRUE with the body placed AFTER the branch, so the body
// @skip never runs and the loop spins forever (this program hangs). Expected:
// @skip sum of 0..4 = 10. Fix the While case in compiler/toWasm.ts, then unskip.
let s = 0
let i = 0
while i < 5 {
  s = s + i
  i = i + 1
}
__store_i32__(0, 0)
__store_i32__(4, s)
__log__(0, 8)
