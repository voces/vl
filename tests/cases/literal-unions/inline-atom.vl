// @run
// @log a
// @log green
// @log x
// @log match
// @log hi-a
// An INLINE (un-aliased) literal union — `: "a" | "b"` written directly at the annotation, with no
// `type K = …` alias. Same interned-i32 atom rep and `string`-widening as a named literal union:
// works for a local, a param, a return, `==`, and value widening (concat). The annotation carries
// its members in the synthetic name `"a"|"b"`, so the checker + emitter read them straight from it.

function show(k: "red" | "green") { print(k) }

function pick(): "x" | "y" { return "x" }

function go() {
  const k: "a" | "b" = "a"
  print(k) // a

  show("green") // green

  print(pick()) // x

  const c: "a" | "b" = "a"
  if c == "a" { print("match") } else { print("no") } // match

  print("hi-" + k) // hi-a (concat widening over an inline-typed atom)
}

go()
