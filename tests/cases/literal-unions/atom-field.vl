// @run
// @log green
// @log G
// @log blue
// @log B
// @log blue
// @log col=blue
// A literal-union atom STRUCT FIELD (`c: Color`) — stored as an interned-i32 atom (code 0, the i32
// rep), NOT a value-union box, while the checker enforces membership. Exercises construction, read
// (atom widens in `print`), `==` dispatch on a field (incl. through a param), field reassign, a
// field read into a litunion local, and a field read widened to `string`. With literal-union ARRAYS
// (already landed) this completes the C2 prerequisite: the compiler's kind-codes live in i32 arrays
// AND struct fields, both of which can now hold a named literal union.

type Color = "red" | "green" | "blue"
type Cell = { c: Color, n: i32 }

function tag(cell: Cell): string {
  if cell.c == "red" { return "R" }
  if cell.c == "green" { return "G" }
  return "B"
}

function go() {
  const x: Cell = { c: "green", n: 1 }
  print(x.c) // green (read widens the atom)
  print(tag(x)) // G (== dispatch on a field through a param)

  x.c = "blue" // field reassign
  print(x.c) // blue
  print(tag(x)) // B

  const cs: Color = x.c // field read into a litunion local
  print(cs) // blue

  const s: string = x.c // field read widened to string
  print("col=" + s) // col=blue
}

go()
