// @run
// @log a
// @log b
// @log a
// @log a
// @log c
// @log matched
// @log val-a
// A literal-union VALUE returned from a call, consumed DIRECTLY in an argument / print
// context (`print(pick(ks))`, `useK(pick(ks))`) or bound WITHOUT an annotation
// (`const r = pick(ks)`). An aliased litunion (`type K`) reps as an i32 ATOM, so the
// function's functype result is i32; but the return was ALSO flagged `fRetStr` (every
// litunion widens to "string" for print rendering), so the call-result consumers
// (`fnRetString` -> `exprString`, the inferred-return chain) routed the returned atom to
// the string-ref path -> invalid wasm (`expected (ref $type), found i32`). Indexing the
// result first (`mk()[0]`) lowered fine. The atom widens to its member string at the
// print seam (`exprIsLitAtom`), not by claiming a string return; an un-annotated GLOBAL
// binding off an atom init is recognized the same way (the global dual of the
// `localLitUnion` init classification), so `print(r)` widens the id to its member.

type K = "a" | "b" | "c"

function first(p: K[]): K {
  return p[0]
}

function second(p: K[]): K {
  return p[1]
}

function useK(k: K): K {
  return k
}

const ks: K[] = ["a", "b", "c"]

// Direct call result into print.
print(first(ks)) // a

// Call result straight into another call, then print.
print(useK(second(ks))) // b

// Un-annotated GLOBAL binding off the call result — print widens the atom.
const rc = first(ks)
print(rc) // a

// Un-annotated GLOBAL binding off an index atom (the same widening path).
const ri = ks[0]
print(ri) // a

// Annotated binding still works, and a later member.
const ra: K = ks[2]
print(ra) // c

// The returned atom compares by member and widens in concat.
if first(ks) == "a" { print("matched") } else { print("no") } // matched
print("val-" + first(ks)) // val-a
