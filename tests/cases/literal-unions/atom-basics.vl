// @run
// @log 1
// @log 0
// @log 1
// @log 1
// @log 2
// @log 3
// @log 1
// @log 9
// A string-literal union `type K = "a" | "b"` lowers as an i32-backed interned ATOM (one id per distinct
// member string), NOT a value-union box. Cheap `==` (an i32 compare) and compact storage — the kind-code
// use case. The literal members come from the CHECKER (which preserves them; the emit-side `udVariants`
// are widened to `"string"`, so the checker bridge `nameIsLitUnionType` / `nodeTyIsLitUnion` is the source
// of truth). Works as: const global, typed / reassigned local, param, return, and `==`/`!=`.
// (Slice 1: scalar atoms + equality. Implicit widening to `string` for `print`/concat, and bitmask-backed
// sets, are follow-ups.)

type Kind = "i32" | "str" | "bool"

const DEFAULT: Kind = "i32" // const global

function classify(k: Kind): i32 {
  // param + dispatch
  if k == "i32" { return 1 }
  if k == "str" { return 2 }
  return 3
}

function flip(k: Kind): Kind {
  // return
  if k == "i32" { return "bool" }
  return "i32"
}

function go() {
  const a: Kind = "i32"
  if a == "i32" {
    print(1) // 1
  } else {
    print(0)
  }
  if a == "str" {
    print(1) // 0
  } else {
    print(0)
  }
  if a != "str" {
    print(1) // 1
  } else {
    print(0)
  }

  let k: Kind = DEFAULT // global -> local
  print(classify(k)) // 1
  k = "str" // reassign
  print(classify(k)) // 2
  k = "bool"
  print(classify(k)) // 3

  if flip("i32") == "bool" {
    print(1) // 1 (return roundtrip)
  } else {
    print(0)
  }

  if DEFAULT == "i32" {
    print(9) // 9 (global compare)
  } else {
    print(0)
  }
}

go()
