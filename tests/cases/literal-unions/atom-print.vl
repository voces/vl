// @run
// @log a
// @log b
// @log c
// @log green
// @log i32
// @log str
// `print(k)` over a literal-union ATOM WIDENS it to its member STRING (the atom -> string widening,
// statement form): a per-member `if id == <id> { print "<name>" }` chain. The atom stays a cheap i32 for
// `==`/storage; only the print site pays the widening. Works for a local, a param, and after reassign.
// (The VALUE form — concat `"x" + k`, a `string` arg/return — and INLINE/un-aliased literal unions are
// follow-up slices.)

type K = "a" | "b" | "c"
type Color = "red" | "green" | "blue"
type Kind = "i32" | "str"

function show(k: K) { print(k) }

function go() {
  show("a") // a
  show("b") // b
  const c: K = "c"
  print(c) // c

  const col: Color = "green"
  print(col) // green

  let kind: Kind = "i32"
  print(kind) // i32
  kind = "str"
  print(kind) // str
}

go()
