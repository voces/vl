// @check
// @error cannot assign string to 'k' of type "a" | "b"
// An INLINE (un-aliased) literal union enforces membership too: a non-member string is a type error
// at the annotated binding, exactly as a named `type K = "a" | "b"` does.
function go() {
  const k: "a" | "b" = "z"
  if k == "a" { print(1) }
}
go()
