// @run
// @log null-at-neg
// @log got-a
// @log got-b
// A `const` bound to a `K | null`-returning CALL, declared INSIDE a `for` loop body, followed by a
// `== null` test. Pins a bug where `plBuildLetMap` (backing `parentLetOf`) recursed into `if`/
// `while` bodies but NOT `for` bodies — so the loop-scoped `const` was invisible, `exprNulLitUnion`
// returned false, and `x == null` mis-lowered as a struct-null (`emitProgram: bare null needs a
// struct-typed context`). wasm locals are function-scoped, so the binding must be found regardless
// of nesting. (Surfaced by the VKind for-in element-kind conversion, which is exactly this shape.)

type K = "a" | "b" | "c"

function pick(n: i32): K | null {
  if n < 0 { return null }
  if n == 0 { return "a" }
  "b"
}

function classify(ns: i32[]) {
  for n in ns {
    const x = pick(n)
    if x == null { print("null-at-neg") }
    else if x == "a" { print("got-a") }
    else { print("got-b") }
  }
}

const ns: i32[] = []
ns.push(-1)
ns.push(0)
ns.push(1)
classify(ns)
