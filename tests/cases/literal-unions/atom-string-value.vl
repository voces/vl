// @run
// @log hi-a
// @log b-bye
// @log c
// @log green
// @log red
// A literal-union ATOM is a `string` SUBTYPE: it widens to its member STRING in any `string`-typed
// VALUE position (slice 2b, the value form). A `select` tower maps the atom's interned id back to its
// member-name string. Exercised through concat (`"x" + k` / `k + "y"`), a `string` PARAM, and a
// `string` RETURN. The atom stays a cheap i32 for `==`/storage; only these widening sites pay the cost.

type K = "a" | "b" | "c"
type Color = "red" | "green" | "blue"

function takesStr(s: string) { print(s) }

function nameOf(c: Color): string { return c }

function go() {
  const a: K = "a"
  print("hi-" + a) // hi-a (concat, atom on the right)

  const b: K = "b"
  print(b + "-bye") // b-bye (concat, atom on the left)

  const c: K = "c"
  takesStr(c) // c (atom into a `string` param)

  const col: Color = "green"
  print(nameOf(col)) // green (atom out of a `string` return)

  takesStr(nameOf("red")) // red (return-widened value back into a `string` param)
}

go()
