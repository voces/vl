// @run
// @log 3
// @log c
// @log 2
// @log 3
// @log a
// @log a
// @log a
// A literal-union ARRAY (`K[]`) — its elements are interned-i32 ATOMS, so it shares the `i32[]`
// backing/rep exactly (cheap, no boxing) while the checker enforces membership. Exercises the full
// surface: a literal + empty-then-`push` construction, indexed read (atom widens in `print`), `==`
// on a read element, indexed assign, and `for k in xs` (the loop var is an atom — widens). The
// prerequisite for the compiler to replace its `i32[]` kind-code arrays (`localIsRef`, etc.) with a
// named literal union (review finding C2).

type K = "a" | "b" | "c"

function count(xs: K[], want: K): i32 {
  let n = 0
  let i = 0
  while i < xs.length {
    if xs[i] == want { n = n + 1 }
    i = i + 1
  }
  return n
}

function make(): K[] {
  const xs: K[] = []
  xs.push("a")
  xs.push("c")
  xs.push("a")
  return xs
}

function go() {
  const xs = make()
  print(xs.length) // 3
  print(xs[1]) // c (indexed read widens the atom)

  print(count(xs, "a")) // 2
  xs[1] = "a"
  print(count(xs, "a")) // 3
  for k in xs { print(k) } // a a a
}

go()
