// @run
// @log other
// @log is-b
// @log alpha
// @log charlie
// A `const`/`let` bound to a literal-union ARRAY ELEMENT (`const sk = xs[i]`) holds an i32 ATOM,
// not a `string` ref — so it must take the i32 atom slot, and `== "b"` / a `match` over it lowers
// as an atom compare. TWO bugs this pins: (1) `anyLitUnionUsed` must count a litunion used ONLY as
// `K[]` (else atom detection short-circuits, storing the i32 atom into a `(ref $array)` cell —
// invalid wasm); (2) the un-annotated `const sk = xs[i]` local must be flagged a litunion atom.

type K = "a" | "b" | "c"

const xs: K[] = []
xs.push("a")
xs.push("b")
let i = 0
while i < xs.length {
  const sk = xs[i] // bound litunion-array element — an i32 atom
  if sk == "b" { print("is-b") } else { print("other") }
  i = i + 1
}

const ys: K[] = []
ys.push("a")
ys.push("c")
let j = 0
while j < ys.length {
  const k = ys[j]
  match k {
    "a" => print("alpha")
    "b" => print("bravo")
    "c" => print("charlie")
  }
  j = j + 1
}
