// @run
// @log a
// A `const` bound to a `K | null`-returning CALL, declared inside an `else if` ARM, with a
// `== null` test. Companion to nullable-litunion-in-for-loop: `plBuildLetMap` (backing
// `parentLetOf`) recursed into an `if`'s THEN block but treated the ELSE slot as a `Block` only —
// an `else if` is a nested `IfStmt`, not a `Block`, so its lets were invisible. `exprNulLitUnion`
// then returned false and `x == null` mis-lowered (`emitProgram: bare null needs a struct-typed
// context`). Both arms of an `if`/`else if` chain share the function scope and must be scanned.

type K = "a" | "b" | "c"

function pick(n: i32): K | null {
  if n < 0 { return null }
  "a"
}

function classify(tag: i32, n: i32) {
  if tag == 0 {
    print("zero")
  } else if tag == 1 {
    const x = pick(n)
    if x == null { print("null") }
    else if x == "a" { print("a") }
    else { print("other") }
  }
}

classify(1, 5)
