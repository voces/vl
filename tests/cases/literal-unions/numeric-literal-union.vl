// @run
// @log 2.5
// @log 1.5
// @log 1
// @log 2
// A HOMOGENEOUS NUMERIC literal union (`1.5 | 2.5` all-float, `1 | 2` all-int) is NOT a string-atom
// litunion and NOT a value-union box — it canon-collapses to its base scalar (`softenLitTy`): a float
// union reps as f64, an int union as i32/i64. The int case always worked (i32 is the ladder default);
// the FLOAT case used to fall to the i32 default in `vtKindOfType` while the returned/passed value was
// an f64 — INVALID WASM. Now both ride their base scalar in every position. (A MIXED-kind literal union
// `"a" | 7` is a genuine value-union box — a separate rep, not covered here.)

function pickF(): 1.5 | 2.5 { return 2.5 }
function echoF(x: 1.5 | 2.5): f64 { return x }
function pickI(): 1 | 2 { return 1 }
function echoI(x: 1 | 2): i64 { return x }

function go() {
  print(pickF())    // 2.5
  print(echoF(1.5)) // 1.5
  print(pickI())    // 1
  print(echoI(2))   // 2
}

go()
