// @run
// @log green
// @log red
// @log blue
// A literal-union ATOM widens to its member STRING at the INITIALIZATION boundaries too (slice 2c):
// a `string`-typed LOCAL binding (`const s: string = k`) and a `string` struct FIELD (`{ name: k }`).
// Completes the value-form widening alongside concat / arg / return — the atom is a `string` subtype
// everywhere a `string` value is expected. (Field REASSIGN and global-init are follow-ups.)

type Color = "red" | "green" | "blue"

type Named = { name: string }

function go() {
  const c: Color = "green"
  const s: string = c // local-init widening
  print(s) // green

  const n: Named = { name: "red" } // a plain string field — unchanged
  print(n.name) // red

  const b: Color = "blue"
  const n2: Named = { name: b } // struct-field widening (atom -> member string)
  print(n2.name) // blue
}

go()
