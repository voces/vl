// @run
// @log green
// @log blue
// A literal-union ATOM initializing a `string` GLOBAL widens to its member string — the last
// `string`-typed value boundary. A module-global `const`/`let` with a non-constant init (a
// reference to another global) runs in the synthetic start FUNCTION, so the runtime widening tower
// applies (a truly const init — a constexpr — would need folding; an atom init is never const).
// Also a regression guard: a `: string` cell whose init is a literal-union atom stays a `string`
// cell (kind 3), NOT a value-union box — the annotation is authoritative over the init's union-ness.

type Color = "red" | "green" | "blue"

const A: Color = "green"
const B: string = A // global string init widened from an atom

let G: string = "init"

function go() {
  print(B) // green

  const c: Color = "blue"
  G = c
  print(G) // blue
}

go()
