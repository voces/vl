// @run
// @log 16
// @log 32
// Literal-type identity compares VALUES, not raw source spellings: an integer
// literal in any base (hex / binary / octal, `_` separators) is a member of a
// numeric literal union when its VALUE is. Before normalization `0x10` was
// rejected from `16 | 32` because the lexemes differed.
const x: 16 | 32 = 0x10
print(x)
const y: 16 | 32 = 0b10_0000
print(y)
