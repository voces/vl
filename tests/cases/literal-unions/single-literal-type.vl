// @run
// @log world
// @log 7
// @log 1.5
// @log world
// @log 1.5
// @log 7
// @log world
// @log 1.5
// @log world
// @log world
// @log 1.5
// A SINGLE-member literal type (`"world"`, `7`, `1.5` — no `|`) reps as its BASE scalar: a string
// literal is a string ref, a float literal an f64, an int literal an i32/i64. This matches the
// softening `canonEmitName` applies to the annotation NAME (`litBaseName`), which since C1 the arena
// classifiers must AGREE with — a bare `TyLit` used to fall to the i32 default in `vtKindOfType`
// while its returned/passed VALUE emitted a string/f64, producing INVALID WASM ("expected i32, found
// (ref $type)"). Covered in every annotation position: return, param, let, field; inline AND aliased.
// (A string-atom litunion ALIAS `type K = "a"|"b"` stays the interned i32 atom — see atom-basics.vl.)

// return position — inline single literals
function helloR(): "world" { return "world" }
function sevenR(): 7 { return 7 }
function halfR(): 1.5 { return 1.5 }

// param position — inline single literals (the value flows through and back out)
function strP(x: "world"): string { return x }
function fltP(x: 1.5): f64 { return x }
function intP(x: 7): i64 { return x }

// aliased single literals — a `type W = "world"` / `type W = 1.5` alias
type WStr = "world"
type WFlt = 1.5
function strAlias(): WStr { return "world" }
function fltAlias(): WFlt { return 1.5 }

// field position — a single-literal struct field
type Row = { w: "world" }

function go() {
  print(helloR())      // world
  print(sevenR())      // 7
  print(halfR())       // 1.5
  print(strP("world")) // world
  print(fltP(1.5))     // 1.5
  print(intP(7))       // 7

  const lx: "world" = "world"
  print(lx) // world
  const lf: 1.5 = 1.5
  print(lf) // 1.5

  const row: Row = { w: "world" }
  print(row.w) // world

  print(strAlias()) // world
  print(fltAlias()) // 1.5
}

go()
