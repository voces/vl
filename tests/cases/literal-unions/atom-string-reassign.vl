// @run
// @log green
// @log blue
// @log red
// A literal-union ATOM widens to its member STRING at the ASSIGNMENT (reassign) boundaries too:
// a `string` LOCAL, a `string` GLOBAL, and a `string` struct FIELD. Completes the string-subtype
// story alongside init / concat / arg / return. (`exprString` over the lvalue picks all three.)

type Color = "red" | "green" | "blue"

type Named = { name: string }

let gName: string = "init"

function go() {
  let s: string = "init"
  const c: Color = "green"
  s = c // local string reassign
  print(s) // green

  const c2: Color = "blue"
  gName = c2 // global string reassign
  print(gName) // blue

  const n: Named = { name: "init" }
  const c3: Color = "red"
  n.name = c3 // struct-field reassign
  print(n.name) // red
}

go()
