// @run
// @log 11
// @log 9
// Soft keywords work as function names and parameter names. `from` is the
// function name; `to` and `step` are its parameters; `as`/`in`/`then` are
// locals — none of which collide with the keyword positions in the grammar.
function from(to: i32, step: i32): i32 {
  return to + step
}
print(from(4, 7))

let as = 1
let in = 2
let then = 3
as = 2
in = 3
then = 4
print(as + in + then)
