// @run
// @log 21
// @log 42
// The six contextual ("soft") keywords — `step`, `to`, `in`, `then`, `as`,
// `from` — lex as plain `ID`, so they are usable as ordinary identifiers
// everywhere outside their one grammar slot. Here all six are mutable
// let-bindings, read in an expression and then reassigned.
let from = 1
let to = 2
let step = 3
let in = 4
let then = 5
let as = 6
print(from + to + step + in + then + as)
from = 2
to = 4
step = 6
in = 8
then = 10
as = 12
print(from + to + step + in + then + as)
