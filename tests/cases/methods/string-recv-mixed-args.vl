// @run
// @log ---x
// UFCS on a STRING receiver with MIXED string + i32 arguments (the `padLeft`
// shape): `"x".lead(3, "-")` lowers to `lead("x", 3, "-")`. The i32 and string
// args sit side by side in the rewritten vector, each keeping its own rep.
function lead(self: string, width: i32, fill: string): string {
  let out = self
  let i = 0
  while i < width {
    out = fill + out
    i = i + 1
  }
  return out
}
print("x".lead(3, "-"))
