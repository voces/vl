// @run
// @log i2
// @log b7
// UFCS on a VALUE-UNION receiver WITH an argument: `(5).tag(2)` lowers to
// `tag(5, 2)`. The union-boxed receiver at slot 0 and the i32 argument at slot 1
// both keep their reps through the rewritten vector.
function tag(self: i32 | boolean, n: i32): string {
  if self is i32 { return "i" + toString(n) }
  return "b" + toString(n)
}
print((5).tag(2))
print(true.tag(7))
