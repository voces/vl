// @run
// @log ab
// UFCS on a STRING receiver with a STRING argument: the free `self`-function
// `joinS` is reached via `"a".joinS("b")` and lowers to `joinS("a", "b")`. The
// string-typed second argument must keep its (ref) representation through the
// rewritten arg vector — the pre-collect rewrite sizes the scratch frame for it.
function joinS(self: string, other: string): string { return self + other }
print("a".joinS("b"))
