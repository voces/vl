// @run
// @log a-b-c
// @log 6
// A free `self`-function whose first parameter is an array type is callable as
// a UFCS method on an array receiver (`parts.joinL(sep)`, `xs.total()`) — the
// array dual of string/struct/union receivers. The receiver shifts into slot 0.
function joinL(self: string[], sep: string): string {
  let out = ""
  let i = 0
  while i < self.length {
    if i > 0 { out = out + sep }
    out = out + self[i]
    i = i + 1
  }
  out
}
function total(self: i32[]): i32 {
  let s = 0
  let i = 0
  while i < self.length {
    s = s + self[i]
    i = i + 1
  }
  s
}
print(["a", "b", "c"].joinL("-"))
print([1, 2, 3].total())
