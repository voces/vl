// @run
// @log i
// @log b
// @log L
// UFCS on a VALUE-UNION receiver with ZERO extra arguments: `(5).toS()` lowers
// to `toS(5)`, and the `self` param is a value union so the receiver must be
// boxed into the union rep at slot 0 — a decision the pre-collect rewrite makes
// before scratch-frame sizing freezes.
function toS(self: i32 | i64 | boolean): string {
  if self is i32 { return "i" }
  if self is boolean { return "b" }
  return "L"
}
print((5).toS())
print(true.toS())
const big: i64 = 9000000000
print(big.toS())
