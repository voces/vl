// @run
// @log ---y
// NAMED-arg UFCS on a string receiver: `"y".lead(fill: "-", width: 3)` lowers to
// `lead("y", fill: "-", width: 3)`. The injected receiver rides an UNNAMED slot 0
// ("" prepended to the name list), so the named args still bind to their params
// around it.
function lead(self: string, width: i32, fill: string): string {
  let out = self
  let i = 0
  while i < width {
    out = fill + out
    i = i + 1
  }
  return out
}
print("y".lead(fill: "-", width: 3))
