// @run
// @log 1
// @log 3
// PRECEDENCE: a struct receiver whose callable FIELD `tag` shadows a free
// `self`-function of the same name calls the FIELD (`call_ref`), NOT the free
// function — the real-field check keeps the UFCS rewrite off for the struct
// (`o.tag()` prints the field's 1). A NON-struct receiver (string) has no such
// field, so the free `self`-function is reached (`"xyz".tag()` prints length 3).
function tag(self: string): i32 { return self.length }
function fieldFn(): i32 { return 1 }
const o = { tag: fieldFn }
print(o.tag())
print("xyz".tag())
