// @run
// @log 6030
// @log OTHER
// A closure result that is a LIST of union-field structs (`() => {f: {f: f64} | boolean}[]`)
// fed a bare lambda whose body array literal self-infers the PLAIN element (`{f:{f:f64}}[]`
// — no boxed field slot). Un-pinned, the element literal stored a struct ref into the boxed
// field's i32 tag slot — INVALID-WASM "expected i32, found ref" (fuzz-nightly run
// 29874629450, seed 214588500 d6). The checker now adopts + records the list name
// (`structFieldBoxElemListRetName`) and `synthRetAnnots` pins the lambda's `fnRet`, so the
// elements box exactly as the annotated `(): {f:…|boolean}[]` spelling (which lowered
// already) does — both arms read back through the `is`-narrow.
const g: () => {f: {f: f64} | boolean}[] = () => ([{ f: { f: 6030.0 } }, { f: true }])
function go() {
  const a = g()
  const t0 = a[0].f
  if t0 is {f: f64} { print(t0.f) } else { print("OTHER") }
  const t1 = a[1].f
  if t1 is {f: f64} { print(t1.f) } else { print("OTHER") }
}
go()
