// @run
// @log 2
// @log 4
// @log 6
// @log 8
// @log false
// @log false
// @log true
// @log true
// @log 2
// @log 13
// @log 14
// @log 4
// @log 1
// @log 0
// @log 0
// @log 2
// @log 1
// @log 2
// @log 3
// @log 6
// @log 11
// @log 21
// Higher-order list producers (ROADMAP A10, collections-design §VL.4): `map` and
// `filter` build a NEW list and never touch the receiver. `map`'s result element
// type is the callback's RETURN type (`U` inferred through the closure); `filter`
// returns a `T[]` of the elements where the predicate held.

// map i32 -> i32 (same length, out[i] = f(xs[i])).
const xs = [1, 2, 3, 4]
const doubled = xs.map(function(n: i32) n * 2)
print(doubled[0]) // 2
print(doubled[1]) // 4
print(doubled[2]) // 6
print(doubled[3]) // 8

// map to a DIFFERENT element type (i32 -> boolean): `U` is pinned from `f`.
const flags = xs.map(function(n: i32) n > 2)
print(flags[0]) // false (1 > 2)
print(flags[1]) // false (2 > 2)
print(flags[2]) // true  (3 > 2)
print(flags[3]) // true  (4 > 2)

// chaining: map(+10) -> [11,12,13,14], filter(>12) -> [13,14].
const chained = xs.map(function(n: i32) n + 10).filter(function(n: i32) n > 12)
print(chained.length) // 2
print(chained[0])     // 13
print(chained[1])     // 14

// the original is untouched by either op.
print(xs.length) // 4
print(xs[0])     // 1

// empty input: map/filter of `[]` are empty.
const e: i32[] = []
print(e.map(function(n: i32) n * 2).length)  // 0
print(e.filter(function(n: i32) n > 0).length) // 0

// filter keeps the survivors compactly; length = survivor count.
const big = [5, 1, 6, 2, 7]
const small = big.filter(function(n: i32) n < 5)
print(small.length) // 2 — only 1 and 2 pass
print(small[0])     // 1
print(small[1])     // 2

// a named function (param named `n`, not the synthetic `_`) is a valid callback.
function inc(n: i32) n + 1
const base = [1, 5, 10, 20]
const bumped = base.filter(function(n: i32) n > 4).map(inc)
print(bumped.length) // 3 — [5,10,20] pass the filter, then +1 each
print(bumped[0])     // 6
print(bumped[1])     // 11
print(bumped[2])     // 21
