// @run
// @log 5
// @log -1
// @log 8
// A `(i32[] | null)[]` — a list whose ELEMENT is a nullable i32-list — now lowers. It reuses the
// `i32[][]` (kind 4) ref-list rep: the ref backing is already `(ref null $lTypeIdx)`, so the `| null`
// element rides for free. It differs from `i32[][]` only in that the slot key keeps the `| null`, which
// makes the index READ stay nullable (no `ref.as_non_null`) so `xs[i] != null` narrows, and lets a bare
// `null` element lower as `ref.null $lTypeIdx` (a new `pendingNulList` seed). Previously rejected as
// "nested arrays are not supported" (it was mis-classified as a value-union list). Found by the
// rep-composition fuzzer (#667); closes the `(i32[] | null)[]` nested-array cases.

function go() {
  const v: (i32[] | null)[] = [[5], null, [9, 8]]

  // Present element → narrow true, read the inner list.
  const a = v[0]
  if a != null {
    print(a[0]) // 5
  } else {
    print(-1)
  }

  // Null element → narrow false.
  const b = v[1]
  if b != null {
    print(b[0])
  } else {
    print(-1) // -1
  }

  // Present element after a null → still reads correctly.
  const c = v[2]
  if c != null {
    print(c[1]) // 8
  } else {
    print(-1)
  }
}

go()
