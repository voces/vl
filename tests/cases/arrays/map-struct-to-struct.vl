// @run
// @log 2
// @log 2
// @log 3
// @log 5
// @log 50
// @log 2
// @log 50
// @log 20
// A struct-returning `.map` that produces a DIFFERENT element type (`P[].map((p) => Q-shape)`
// ⇒ `Q[]`). The result is a NEW ref list whose element is the callback's return struct — its
// slot is interned even though no `Q[]` annotation forces it (a result-only struct), and the
// callback `$fnsig` carries the struct result (`>sN;`). The result binds, indexes, and chains.

type P = { x: i32 }
type Q = { y: i32 }
type Pt = { a: i32, b: i32 }

function go() {
  const ps: P[] = [{ x: 1 }, { x: 2 }]

  // map P -> Q (a different single-field struct).
  const qs = ps.map((p) => { y: p.x + 1 })
  print(qs.length) // 2
  print(qs[0].y) // 2
  print(qs[1].y) // 3

  // map P -> Pt (a wider struct), reading both fields.
  const wide: P[] = [{ x: 1 }, { x: 5 }, { x: 2 }]
  const pts = wide.map((p) => { a: p.x, b: p.x * 10 })
  print(pts[1].a) // 5
  print(pts[1].b) // 50

  // chain: map P -> Pt, filter Pt, map Pt -> i32.
  const r = wide.map((p) => { a: p.x, b: p.x * 10 }).filter((q) => q.a > 1).map((q) => q.b)
  print(r.length) // 2
  print(r[0]) // 50
  print(r[1]) // 20
}
go()
