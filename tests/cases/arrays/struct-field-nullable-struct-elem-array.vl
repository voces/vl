// @run
// @log ENULL
// @log WHOLENULL
// @log hi
// @log U2NULL
// @log DEEP
// @log MENULL
// A STRUCT FIELD typed `(S | null)[] | null` — a nullable ref-list whose ELEMENTS are nullable
// structs. `emitObj`'s code-28 (nullable-ref-list) field arm seeds `pendingNulRefHeap` with the
// OUTER list wrapper heap so a `{f: null}` whole-field null lowers as `ref.null $wrapper`. That
// is a WHOLE-VALUE null seed and is now GATED on the field VALUE being a bare `null` (the #964
// SEED-LEAK discipline): a `{f: [null]}` LIST-literal value's null ELEMENTS must take the
// per-element seed (`ref.null $S` via the element's `pendingStructIdx`) — un-gated, the wrapper
// heap leaked through the array literal's element context and stored `ref.null $wrapper` into
// the nullable-struct element backing, so `array.new_fixed $S` failed "expected (ref null $S),
// found (ref null $wrapper)" (INVALID-WASM). The struct-FIELD twin of the kind-18 binding seed
// (`localIsRef[slot] == "nulreflist"`, #964), the emitArr element seed (#1008), and the return
// seed (#1020) — completing the seed-leak family at the struct-field position.
type S = {a: boolean, f: boolean, z: string}
type F1 = {f: (S | null)[] | null}
type F2 = {f: ((S | null)[] | null)[] | null}
function go() {
  // Base leak: a `[null]` list value into the `(S | null)[] | null` field.
  const w1: F1 = { f: [null] }
  const t0 = w1.f
  if t0 != null {
    const t1 = t0[0]
    if t1 != null { print(t1.z) } else { print("ENULL") }
  } else {
    print("FNULL")
  }
  // The whole-field null still lowers as `ref.null $wrapper`.
  const w2: F1 = { f: null }
  if w2.f != null { print("HASF") } else { print("WHOLENULL") }
  // A mixed `[{…}, null]` list value: the non-null struct element and the null element both
  // lower on the element rep, not the wrapper.
  const w3: F1 = { f: [{ a: true, f: false, z: "hi" }, null] }
  const u0 = w3.f
  if u0 != null {
    const u1 = u0[0]
    if u1 != null { print(u1.z) } else { print("U1NULL") }
    const u2 = u0[1]
    if u2 != null { print("U2") } else { print("U2NULL") }
  } else {
    print("U0NULL")
  }
  // One nesting level deeper — `((S | null)[] | null)[] | null` field with `[[null]]`: the outer
  // field seed is still gated, and the inner `[null]` rebuilds its own list whose null element
  // takes the element rep.
  const w4: F2 = { f: [[null]] }
  const d0 = w4.f
  if d0 != null {
    const d1 = d0[0]
    if d1 != null {
      const d2 = d1[0]
      if d2 != null { print(d2.z) } else { print("DEEP") }
    } else {
      print("D1NULL")
    }
  } else {
    print("D0NULL")
  }
  // Composed: the same field nested as a MAP VALUE (`{[string]: {f: (S|null)[]|null} | null}`).
  // `emitObj` clears the map-value whole-value wrapper seed per field, then the gated field arm
  // keeps the `[null]` value on the element rep.
  const m: {[string]: F1 | null} = Map()
  m["k"] = { f: [null] }
  const mv = m["k"] ?? null
  if mv != null {
    const ml = mv.f
    if ml != null {
      const me = ml[0]
      if me != null { print(me.z) } else { print("MENULL") }
    } else {
      print("MLNULL")
    }
  } else {
    print("MNULL")
  }
}
go()
