// @run
// @log 99
// @log 4
// @log 9.5
// @log 4
// @log 9.5
// @log 4
// @log hit
// @log 4
// @log 99
// @log 4
// @log 99
// @log 4
// @log c
// @log 4
// @log false
// @log 4
// @log b
// @log 4
// Eval-order list-store family, per ELEMENT TYPE: every backing flavor (scalar
// i64/f64/f32, string, struct ref, union box, litunion atom, nullable-boolean
// niche, nullable-litunion niche) resolved its backing before the RHS and lost
// the write into the stale array when the RHS pushed past cap. All printed the
// STALE element 0 pre-fix.

// i64 elements.
let xi: i64[] = [10, 20]
function fi(): i64 {
  xi.push(30)
  xi.push(40)
  99
}
xi[0] = fi()
print(xi[0])     // 99
print(xi.length) // 4

// f64 elements.
let xf: f64[] = [1.5, 2.5]
function ff(): f64 {
  xf.push(3.5)
  xf.push(4.5)
  9.5
}
xf[0] = ff()
print(xf[0])     // 9.5
print(xf.length) // 4

// f32 elements (a LOCAL list — mutation via the param).
function bumpF32(zs: f32[]): f32 {
  zs.push(3.5)
  zs.push(4.5)
  9.5
}
function viaF32(): i32 {
  const zs: f32[] = [1.5, 2.5]
  zs[0] = bumpF32(zs)
  print(zs[0])     // 9.5
  print(zs.length) // 4
  0
}
viaF32()

// string elements.
let xs: string[] = ["x", "y"]
function fs(): string {
  xs.push("z")
  xs.push("w")
  "hit"
}
xs[0] = fs()
print(xs[0])     // hit
print(xs.length) // 4

// struct-ref elements.
type P = { v: i32 }
let xp: P[] = [{ v: 1 }, { v: 2 }]
function fp(): P {
  xp.push({ v: 3 })
  xp.push({ v: 4 })
  { v: 99 }
}
xp[0] = fp()
print(xp[0].v)   // 99
print(xp.length) // 4

// union-BOX elements.
type A = { tag: i32 }
type B = { name: string }
type U = A | B
let xu: U[] = [{ tag: 1 }, { name: "x" }]
function fu(): U {
  xu.push({ tag: 3 })
  xu.push({ name: "y" })
  { tag: 99 }
}
xu[0] = fu()
const eu = xu[0]
if eu is A { print(eu.tag) } // 99
print(xu.length)             // 4

// litunion ATOM elements.
type K = "a" | "b" | "c"
let xk: K[] = ["a", "b"]
function fk(): K {
  xk.push("c")
  xk.push("a")
  "c"
}
xk[0] = fk()
print(xk[0])     // c
print(xk.length) // 4

// (boolean | null) NICHE elements (a null RHS through the sentinel).
let xb: (boolean | null)[] = [true, false]
function fb(): boolean | null {
  xb.push(null)
  xb.push(true)
  null
}
xb[0] = fb()
print(xb[0] ?? false) // false — the stored null defaults
print(xb.length)      // 4

// (K | null) NICHE elements.
let xn: (K | null)[] = ["a", null]
function fn(): K | null {
  xn.push("b")
  xn.push(null)
  "b"
}
xn[0] = fn()
const en = xn[0]
if en == null { print("none") } else { print(en) } // b
print(xn.length)                                   // 4
