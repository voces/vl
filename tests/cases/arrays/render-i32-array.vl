// @check
// @error expected string, got i32[]
// @error expected string, got i32[]
// REPRESENTATION (type display): an array renders as `T[]`, not the raw
// `{i32: T}` index signature. An array LITERAL (`[1, 2]`) and an `A-infer-empty`
// array (`[]` later pinned by `.push`) used to be keyed by the integer type
// `i32` and so fell through to the generic object render `{i32: i32}`; they now
// build the CANONICAL `number`-keyed array shape — identical to a `T[]`
// annotation — so all three render `i32[]`. These deliberate string mismatches
// force the renderer to print the array type in the diagnostic. Regression guard
// for the `i32[]` (vs `{i32: i32}`) display in hover / inlay / error messages.
const a = [1, 2]
const x: string = a

const c = []
c.push(1)
const y: string = c
