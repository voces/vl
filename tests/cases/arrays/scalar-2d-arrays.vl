// @run
// @log 4
// @log 1
// @log 2
// @log 7
// @log 3.5
// @log c
// @log 2
// Nested NON-i32 scalar / string 2D arrays (`i64[][]` / `f64[][]` / `string[][]`), plus a fix
// for `i32[][]` literals. Only `i32[][]` was a recognized ref array; the others hit `checkArrName`.
// They reuse the LIST-valued-map element kinds (8 / 7 / 6 = the inner i64 / f64 / string list
// wrapper): `nameIsRefArray` / `refArrElemName` recognize the names, the annotation forces the
// inner list's backing, `emitArr` seeds each inner element's list kind, and `exprI64Array` /
// `exprF64Array` / `exprStringArray` re-classify `g[i]` as the inner list so `g[i][j]` reads the
// scalar. The inner-kind seed also FIXES `i32[][]` literals: the `pendingListKind == 1` isRefLit
// force (#589) made a `[1,2]` inner of an `i32[][]` build as a ref-list — it now resets to the
// i32-list kind per element. (`for`-in over a nested array stays a follow-up — it is unsupported
// for `i32[][]` too.)

function go() {
  // i32[][] — the regressed case: indexed read + length.
  const gi: i32[][] = [[1, 2], [3, 4]]
  print(gi[1][1]) // 4
  print(gi[0][0]) // 1
  print(gi.length) // 2

  // i64[][] — indexed read of the i64 scalar.
  const g64: i64[][] = [[1, 2], [3, 7]]
  print(g64[1][1]) // 7

  // f64[][].
  const gf: f64[][] = [[1.5], [3.5, 4.5]]
  print(gf[1][0]) // 3.5

  // string[][].
  const gs: string[][] = [["a", "b"], ["c", "d"]]
  print(gs[1][0]) // c
  print(gs[0].length) // 2
}
go()
