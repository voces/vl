// @run
// @log 2
// @log 4
// @log 6
// @log 2
// @log 2
// @log 3
// map/filter over an `f64[]` (a distinct backing element wasm type from i32 —
// the per-element loop and fresh-backing allocation are monomorphized per type).
let fs: f64[] = [1.0, 2.0, 3.0]
let doubled = fs.map(function(x: f64) x * 2.0)
print(doubled[0]) // 2
print(doubled[1]) // 4
print(doubled[2]) // 6

// filter keeps the f64 survivors; chained map then re-reads them.
let kept = fs.filter(function(x: f64) x > 1.5)
print(kept.length) // 2
print(kept[0])     // 2
print(kept[1])     // 3
