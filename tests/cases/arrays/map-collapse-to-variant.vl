// @run
// @log 2
// @log 1
// @log 2
// @log 3
// @log 1
// @log 5
// @log 0
// A `.map` over a union array whose callback COLLAPSES to a single concrete variant — the
// checker types the result `Cat[]` (every arm produces a `Cat`), so the emitter must too,
// NOT widen to the union box. The callback return is inferred as the variant
// (`cbRetVariantIdx`, from the checker's recorded return shape); the result is a ref list of
// bare variant structs; mixed-rep arms (a narrowed-union arm + a literal arm) land in one
// variant rep via `emitVariantCoerce`. The element then field-reads directly, and `is` over
// a concrete variant folds statically.

type Cat = { meow: i32 }
type Dog = { woof: i32 }
type Animal = Cat | Dog

function go() {
  const xs: Animal[] = [{ meow: 1 }, { woof: 2 }]

  // Both arms are Cat (the then keeps the narrowed Cat, the else builds a Cat from a Dog).
  const cats = xs.map((a) => if a is Cat { a } else { { meow: a.woof } })
  print(cats.length) // 2
  print(cats[0].meow) // 1  (the Cat passes through)
  print(cats[1].meow) // 2  (Dog {woof: 2} -> {meow: 2})

  // `is` over a concrete-variant element folds to a compile-time constant.
  const c0 = cats[0]
  if c0 is Cat { print(c0.meow + 2) } else { print(-1) } // 3
  if c0 is Dog { print(99) } else { print(1) } // 1 (statically not a Dog)

  // Chain the collapsed result through another map.
  const doubled = cats.map((c) => c.meow * 2 + 1)
  print(doubled[1]) // 5

  // Filter-all-out an empty variant list.
  print(cats.filter((c) => c.meow > 100).length) // 0
}
go()
