// @run
// @log 2
// @log 2
// @log 5
// @log 2.5
// @log 9
// @log yo
// `.push` onto an INNER list reached by INDEXING (`g[0].push(x)`, `g[0][0].push(x)`) — pushing onto
// a nested array's inner list. The push receiver could previously only be a bare local/param or a
// struct field (`xs.push`, `p.items.push`); an INDEXED receiver was rejected ("must be a local or
// struct field"), so an inner list could only grow via a temp (`const row = g[0]; row.push(x)`).
// An indexed receiver now evaluates the inner wrapper ref once into the push scratch slot, exactly
// like a struct-field receiver: the wrapper is mutated IN PLACE (a growth swaps its backing on the
// same shared ref), so the change is visible through the outer array with no write-back. Works for
// every element kind the classifiers recognize on a nested `g[i]` read, at any depth.

function go() {
  // i32 2D — value lands and the inner length grows (`[1]` → push 2 → length 2).
  const a: i32[][] = [[1]]
  a[0].push(2)
  print(a[0][1])     // 2
  print(a[0].length) // 2

  // struct 2D — push a struct literal onto the inner list.
  const s: S[][] = [[{ n: 1 }]]
  s[0].push({ n: 5 })
  print(s[0][1].n) // 5

  // f64 2D.
  const f: f64[][] = [[1.5]]
  f[0].push(2.5)
  print(f[0][1]) // 2.5

  // 3D — push onto the innermost list reached by two indexes.
  const g: i32[][][] = [[[1]]]
  g[0][0].push(9)
  print(g[0][0][1]) // 9

  // string 2D.
  const t: string[][] = [["hi"]]
  t[0].push("yo")
  print(t[0][1]) // yo
}

type S = { n: i32 }

go()
