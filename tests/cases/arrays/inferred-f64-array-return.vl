// @run
// @log 3.5
// @log 2.5
// @log 5
// @log 4
// An UN-ANNOTATED function returning an `f64[]` now lowers — the f64 analogue of the inferred
// `string[]` return. The general inferred-return classifier had no f64-array form (no
// `fRetF64Arr` flag, no `exprF64Array` check), so an un-annotated `f64[]` return declared an
// i32 result while the body yielded the f64-list ref. The new flag mirrors `fRetStrArr` across
// the classifier, the functype result valtype (kind 12), `cloRet*`, and the caller-side
// `fnRetF64Array` lookup — covering a literal, a built list, and a `.map`/`.filter` result.

// f64 array LITERAL return.
function lit() {
  return [1.5, 2.5, 3.5]
}
print(lit()[2]) // 3.5

// f64 list BUILT then returned.
function built() {
  const out: f64[] = []
  out.push(1.5)
  out.push(2.5)
  return out
}
print(built()[1]) // 2.5

// A `.map` RESULT returned from an ANNOTATED-param function with an inferred return — this is
// the case that previously failed even with the param annotated (the return was the gap).
function dbl(self: f64[]) {
  return self.map((x) => x * 2.0)
}
print(dbl([1.5, 2.5])[1]) // 5

// A CALLER classifies the f64-array-returning call (`fnRetF64Array`) — `r` is an f64 list.
const r = lit()
print(r[0] + r[1]) // 4  (1.5 + 2.5)
