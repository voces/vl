// @run
// @log false
// @log true
// @log hi
// @log INULL
// @log ONULL
// @log NULL
// An ARRAY of nullable-arrays-of-nullable-structs — `(({a,f,z} | null)[] | null)[]`, one
// nesting level deeper than `(S | null)[] | null`. The OUTER emitArr classifies each element
// as a kind-9 nested ref list and seeds `pendingNulRefHeap = rlWrapIdx[innerSlot]` (the inner
// `(S|null)[]|null` wrapper) so a bare-`null` outer element lowers as `ref.null $wrapper`. That
// seed is a WHOLE-VALUE null seed and is now GATED on the element BEING a bare NullLit (the #964
// discipline): an inner LIST literal element (`[null]`) rebuilds its own `(S|null)[]` whose OWN
// `null` element would otherwise CONSUME the leaked wrapper heap and store `ref.null $wrapper`
// into the struct backing — `array.new_fixed` then fails "expected (ref null $S), found (ref
// null $wrapper)" (INVALID-WASM, declared-leg seed 205425905, p0c + p0r).
function go() {
  const v: (({a: boolean, f: boolean, z: string} | null)[] | null)[] = [
    [
      {
        a: true,
        f: false,
        z: "hi",
      },
      null,
    ],
    null,
    [null],
  ]
  const t0 = v[0]
  if t0 != null {
    const t1 = t0[0]
    if t1 != null {
      print(t1.f)
      print(t1.a)
      print(t1.z)
    } else {
      print("E0")
    }
    const t2 = t0[1]
    if t2 != null { print(t2.a) } else { print("INULL") }
  } else {
    print("E0null")
  }
  const t3 = v[1]
  if t3 != null { print("E3") } else { print("ONULL") }
  // The seed-leak case in isolation: a `[[null]]` build, inner bare `null` struct element.
  const w: (({a: boolean, f: boolean, z: string} | null)[] | null)[] = [[null]]
  const u0 = w[0]
  if u0 != null {
    const u1 = u0[0]
    if u1 != null { print(u1.z) } else { print("NULL") }
  } else {
    print("WNULL")
  }
}
go()
