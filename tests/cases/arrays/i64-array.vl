// @run
// @log 5000000000
// @log 3
// @log 12000000000
// @log 3
// @log 5000000000
// @log 9000000000
// An `i64[]` array — the i64 sibling of `f64[]`, added through the unified scalar-list
// descriptor (element kind 10, wrapper `il64TypeIdx` / backing `ia64TypeIdx`). Declared
// local + literal (bare-integer elements widen to i64 at the store), indexing, `.length`,
// an `i64[]` PARAM, `.push` (the i64 push quad), and `for v in` iteration — all share the
// descriptor-driven list ops, so this is the same code paths as i32/f64 with a kind arm.

function sum(xs: i64[]): i64 {
  let t: i64 = 0
  let i = 0
  while i < xs.length {
    t = t + xs[i]
    i = i + 1
  }
  return t
}

function go() {
  const xs: i64[] = [5000000000, 7000000000]
  print(xs[0]) // 5000000000
  print(xs.length + 1) // 3

  print(sum(xs)) // 12000000000

  const ys: i64[] = []
  ys.push(5000000000)
  ys.push(9000000000)
  ys.push(1)
  print(ys.length) // 3
  for v in ys {
    if v > 1000000000 {
      print(v) // 5000000000, 9000000000
    }
  }
}
go()
