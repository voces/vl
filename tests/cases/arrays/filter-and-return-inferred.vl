// @run
// @log 2
// @log 3
// @log 5
// @log 9
// An INFERRED ref-array return: a function returning a struct array (a filtered list, or a
// passed-through param) without an explicit `: P[]` return annotation. The inferred functype
// result resolves its ref-list wrapper slot from the return's element type (the ref-array
// analogue of the inferred scalar/list returns).

type P = { x: i32 }

// Filter a param struct array and return it (return type inferred).
function positives(ps: P[]) { return ps.filter((p) => p.x > 0) }

// Pass a struct array straight through (the simplest inferred ref-array return).
function identity(ps: P[]) { return ps }

function go() {
  const r = positives([{ x: -1 }, { x: 3 }, { x: 5 }])
  print(r.length) // 2
  print(r[0].x) // 3
  print(r[1].x) // 5

  const id = identity([{ x: 9 }])
  print(id[0].x) // 9
}
go()
