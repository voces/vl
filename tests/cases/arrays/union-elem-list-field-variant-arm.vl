// @run
// @log 77
// @log 14.5
// @log STRUCT
type T0 = {a: (f64 | {w: i32})[][]}
function makeIt(): T0 | i64 { return { a: [[{ w: 77 }], [14.5]] } }
function makeInline(): {b: (f64 | {q: i64})[]} | f64 { return { b: [2.5] } }
function go() {
  const v = makeIt()
  if v is T0 {
    const e = v.a[0][0]
    if e is {w: i32} { print(e.w) } else { print("EOTHER") }
    const f = v.a[1][0]
    if f is f64 { print(f) } else { print("FOTHER") }
  } else {
    print("I64")
  }
  const u = makeInline()
  if u is f64 { print("F64") } else { print("STRUCT") }
}
go()
