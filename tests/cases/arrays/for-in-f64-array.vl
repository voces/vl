// @run
// @log 1.5
// @log 2.5
// @log 3.5
// @log 7
// @log 1.5
// @log 2.5
// `for x in <f64[]>` now lowers — the loop var binds as a scalar f64 local (kind 11) and
// each element is read with `array.get $fa64TypeIdx` (no `ref.as_non_null`). `forInElemKind`
// recognizes the f64 list through `exprF64Array`, which (since the typed-IR foundation)
// trusts the checker's recorded type — so iterating an `f64[]`-RETURNING call works too,
// not just a literal or param. Previously every f64 for-in failed "unsupported for-in
// iterable". i32 / string / struct iteration is unchanged.

// Over an f64 array LITERAL.
for x in [1.5, 2.5, 3.5] {
  print(x)
}

// Over an f64[] PARAM, accumulating — the loop var participates in f64 arithmetic.
function sum(xs: f64[]): f64 {
  let s = 0.0
  for x in xs {
    s = s + x
  }
  return s
}
print(sum([1.5, 2.5, 3.0])) // 7

// Over an f64[]-RETURNING call (the typed-IR recognition path).
function mk(): f64[] {
  return [1.5, 2.5]
}
for x in mk() {
  print(x)
}
