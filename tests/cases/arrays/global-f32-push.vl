// @run
// @log 2
// @log 2.5
// @log 3.5
// @log 3
// @log 2.25
// @log 7000000000
// @log b
// @log 9.5
// Global `f32[]` `.push` — the #922-observed hole: an `f32[]`-ANNOTATED global with
// a float-literal init was claimed by BOTH `exprF32Array` (the annotation) and
// `exprF64Array` (`globalIsF64Array`'s init fallback — `[1.5]` reads as an f64
// array), and `emitPush`'s kind ladder picked f64 first, so the f64 push frame's
// typed scratch locals mismatched the f32 cell's wrapper ref — invalid wasm, at top
// level AND from inside a function. The annotation is authoritative now
// (`letIsF64Array` answers false for an `f32[]` annotation).
const gs: f32[] = [1.5]
gs.push(2.5) // top-level push onto the global f32 cell
print(gs.length) // 2
print(gs[1])     // 2.5

function grow(): f32 {
  gs.push(3.5) // push from inside a function
  gs[gs.length - 1]
}
print(grow())    // 3.5
print(gs.length) // 3

// Neighbor pins (worked before the fix): global f64 / i64 / string pushes, and a
// LOCAL f32 push (`buildLocals` already ordered f32 before f64 — only the global
// classifiers double-claimed).
const gd: f64[] = [1.25]
gd.push(2.25)
print(gd[1]) // 2.25
const gi: i64[] = [6000000000]
gi.push(7000000000)
print(gi[1]) // 7000000000
const gt: string[] = ["a"]
gt.push("b")
print(gt[1]) // b

function localPush(): f32 {
  const xs: f32[] = [0.5]
  xs.push(9.5)
  xs[1]
}
print(localPush()) // 9.5
