// @run
// @log 10
// @log 15
// @log 3
// @log 7
// @log 4
// `for`-in over a NESTED array — the loop variable binds the INNER list. Was unsupported for
// EVERY nested array (`i32[][]` included): `forInElemKind` only handled scalar / struct / union
// elements, so a list element (kind 4/6/7/8 = the inner i32/string/f64/i64 list wrapper) fell to
// "unsupported for-in iterable". It now maps those to the inner-list loop-var kind (2/7/12/20);
// the element read recovers the inner list wrapper non-null (like a struct element), and the
// inner `for x in row` iterates the inner list normally.

function sum64(g: i64[][]): i64 {
  let t: i64 = 0
  for row in g {
    for x in row { t = t + x }
  }
  return t
}

function go() {
  // i32[][] — the loop var `row` is an i32 list.
  const gi: i32[][] = [[1, 2], [3, 4]]
  let ti = 0
  for row in gi {
    for x in row { ti = ti + x }
  }
  print(ti) // 1+2+3+4 = 10

  // i64[][] via a param.
  print(sum64([[1, 2, 3], [4, 5]])) // 15

  // string[][] — count elements across rows.
  const gs: string[][] = [["a", "b"], ["c"]]
  let n = 0
  for row in gs {
    for s in row { n = n + 1 }
  }
  print(n) // 3

  // f64[][].
  const gf: f64[][] = [[1.5, 2.5], [3.0]]
  let tf: f64 = 0.0
  for row in gf {
    for x in row { tf = tf + x }
  }
  print(tf) // 7

  // the inner list is a real list — `.length` / index work on the loop var.
  let cells = 0
  for row in gi {
    cells = cells + row.length
  }
  print(cells) // gi has 2 rows of 2 cells → 2 + 2 = 4
}
go()
