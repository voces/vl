// @run
// @log 5
// @log 1
// @log 5
// @log 2
// @log 3
// @log 5
// @log 10
// @log 40
// @log 3
// List concat `a + b` (collections-design §VL.4): a *new* `T[]` sized exactly
// len(a) + len(b) in one allocation (two bulk array.copy). The originals are
// untouched (concat is non-mutating). `a.extend(b)` instead appends `b`'s
// elements to `a` in place (one grow-to-fit, one bulk copy).
let a = [1, 2]
let b = [3, 4, 5]
let c = a + b
print(c.length)  // 5  — len(a) + len(b)
print(c[0])      // 1  — copied from a (offset 0)
print(c[4])      // 5  — copied from b (offset len(a))
print(a.length)  // 2  — a untouched (concat is non-mutating)
print(b.length)  // 3  — b untouched

// extend mutates the receiver in place (aliases would see the growth).
let xs = [10, 20]
let ys = [30, 40, 50]
xs.extend(ys)
print(xs.length) // 5  — grew to fit
print(xs[0])     // 10 — original element preserved across the grow
print(xs[3])     // 40 — appended from ys
print(ys.length) // 3  — ys untouched
