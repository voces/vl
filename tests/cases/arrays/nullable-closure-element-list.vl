// @run
// @log NIL
// @log true
// @log 4
// @log true
// @log SET-NIL
// @log true
// @log 2
// @log true

// An array whose ELEMENT is a NULLABLE CLOSURE (`(((i32) => boolean) | null)[]`) — the
// kind-5 niche ref list: the element rides the shared closure fat-pointer backing a plain
// closure element already uses, made nullable (`(ref null $cloStruct)`, the
// `rlElemNullable` bit — the closure dual of the `(P | null)[]` nullable-struct element).
// The slot keys the full `"<closure> | null"` name, so the index read stays nullable for
// the `const f = xs[i]; if f != null { f(3) }` narrow, and the narrowed call resolves the
// ELEMENT's real `$fnsig` (`identFnTypeAnnName`'s kind-5 Index arm / `cloArrSlotSigKey`).
// A bare `null` lowers as `ref.null $cloStruct` at every construct position: the literal
// element, `.push(null)`, and the indexed assign. Covers the global (p3), local (p0) and
// param (p1) positions the rep fuzzer exercises. (rep-fuzz: `p3c`/`p3r
// (((i32) => boolean) | null)[]` were `a nullable-((i32)=>boolean) list element has no
// rep` rejects.)

const gxs: (((i32) => boolean) | null)[] = [(x) => x > 0, null]

function use(xs: (((i32) => boolean) | null)[]) {
  const f = xs[0]
  if f != null { print(f(3)) }
  print(xs.length)
}

function go() {
  const xs: (((i32) => boolean) | null)[] = [(q) => q > 2, null]
  const f = xs[1]
  if f == null { print("NIL") }
  const g = xs[0]
  if g != null { print(g(5)) }
  xs.push(null)
  xs.push((q) => q < 0)
  print(xs.length)
  const h = xs[3]
  if h != null { print(h(-1)) }
  xs[0] = null
  if xs[0] == null { print("SET-NIL") }
  use(gxs)
  const gf = gxs[0]
  if gf != null { print(gf(7)) }
}
go()
