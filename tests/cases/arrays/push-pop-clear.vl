// @run
// @log 0
// @log 1
// @log 10
// @log 9
// @log 8
// @log 42
// @log -1
// @log 0
// @log 0
// @log 2
// @log 0
// @log 30
// @log 50
// @log 6
// Growth (B6, collections-design §VL.2): an empty `[]` starts empty; `push` grows
// the backing on demand (floor 4, then doubling). `.length` tracks the logical
// size; `pop` returns the last element (or `null` on empty) and shrinks length;
// `clear` resets length to 0, retaining the backing so a refill reuses it. Growth
// is verified by reading elements back across the doubling boundary.
const xs: i32[] = []
print(xs.length)   // 0

xs.push(0)
print(xs.length)   // 1

let i = 1
while i < 10 {
  xs.push(i)
  i = i + 1
}
print(xs.length)   // 10

// pop: returns the last, shrinks len.
print(xs.pop() ?? -1) // 9 — last pushed
print(xs.pop() ?? -1) // 8

// pop to empty, then pop-empty → null (defaulted to -1).
const one: i32[] = []
one.push(42)
print(one.pop() ?? -1) // 42
print(one.pop() ?? -1) // -1 — empty → null
print(one.length)       // 0

// clear resets length; refill reuses the backing.
const c: i32[] = []
c.push(7)
c.push(8)
c.push(9)
c.push(10)
c.push(11) // forces a grow
c.clear()
print(c.length)    // 0
c.push(100)
c.push(200)
print(c.length)    // 2

// A grow must preserve earlier elements (array.copy into the new backing):
// index-read across the doubling boundary.
const g: i32[] = []
let k = 0
while k < 6 {
  g.push(k * 10)
  k = k + 1
}
print(g[0])  // 0   — survived 4→8 grow
print(g[3])  // 30
print(g[5])  // 50  — last
print(g.length)   // 6
