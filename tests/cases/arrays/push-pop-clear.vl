// @run
// @log 0
// @log 0
// @log 1
// @log 4
// @log 10
// @log 16
// @log 4
// @log 4
// @log 5
// @log 8
// @log 10
// @log 9
// @log 8
// @log 42
// @log -1
// @log 0
// @log 8
// @log 0
// @log 2
// @log 0
// @log 30
// @log 50
// @log 6
// @log 8
// Growth (B6, collections-design §VL.2): an empty `[]` starts `len = cap = 0`;
// the first `push` grows `cap` to the floor of 4, then doubles (4 → 8 → 16) each
// time `len == cap`. `.length` tracks the logical size, `.capacity` the
// allocated slots — asserted across the doubling boundary. `pop` returns the
// last element (or `null` on empty); `clear` resets `len` to 0 but retains
// capacity (no realloc), so a refill reuses the existing backing.
let xs: i32[] = []
print(xs.length)   // 0
print(xs.capacity) // 0

xs.push(0)
print(xs.length)   // 1
print(xs.capacity) // 4 — floor on first push

let i = 1
while i < 10 {
  xs.push(i)
  i = i + 1
}
print(xs.length)   // 10
print(xs.capacity) // doubled 4 → 8 → 16

// Snapshots of the doubling ladder via a fresh fill:
let a: i32[] = []
a.push(1)
a.push(2)
a.push(3)
a.push(4)
print(a.length)    // 4
print(a.capacity)  // 4
a.push(5)
print(a.length)    // 5
print(a.capacity)  // 8 — doubled past the boundary

// pop: returns the last, shrinks len, retains cap.
print(xs.length)   // 10 (re-asserted before popping)
print(xs.pop() ?? -1) // 9 — last pushed
print(xs.pop() ?? -1) // 8

// pop to empty, then pop-empty → null (defaulted to -1).
let one: i32[] = []
one.push(42)
print(one.pop() ?? -1) // 42
print(one.pop() ?? -1) // -1 — empty → null
print(one.length)       // 0

// clear retains capacity; refill reuses the backing.
let c: i32[] = []
c.push(7)
c.push(8)
c.push(9)
c.push(10)
c.push(11) // forces a grow to cap 8
c.clear()
print(c.capacity)  // 8 — retained after clear
print(c.length)    // 0
c.push(100)
c.push(200)
print(c.length)    // 2

// A grow must preserve earlier elements (array.copy into the new backing):
// index-read across the doubling boundary.
let g: i32[] = []
let k = 0
while k < 6 {
  g.push(k * 10)
  k = k + 1
}
print(g[0])  // 0   — survived 4→8 grow
print(g[3])  // 30
print(g[5])  // 50  — last
print(g.length)   // 6
print(g.capacity) // 8
