// @run
// @log hi
// @log 2
// @log true
// @log b
// @log 2
// @log 2
// @hint Intentionally-unused parameter

// NULLABLE-closure array elements whose closure RESULT is composite: a curried element
// (`(i32) => (() => string)` — the narrowed call yields another closure, called in turn)
// and a struct-with-litunion-field element (`(i32) => {a: boolean, f: K0, z: i32}`). The
// kind-5 niche slot keys the full `"<closure> | null"` element name; the rebound narrow
// (`const f = xs[0]; if f != null`) resolves the element's `$fnsig` through
// `identFnTypeAnnName`'s kind-5 Index arm, so the chained call (`f(1)()`, via the `g`
// rebind) and the struct-result reads classify exactly as the annotated binding forms do.
// (rep-fuzz: `p1c`/`p1r (((i32) => (() => string)) | null)[]` and `p1c`/`p1r
// (((i32) => {a: boolean, f: K0, z: i32}) | null)[]` were emit rejects.)

type K0 = "a" | "b"

function useCurried(xs: (((i32) => (() => string)) | null)[]) {
  const f = xs[0]
  if f != null {
    const g = f(1)
    print(g())
  }
  print(xs.length)
}

function useStruct(xs: (((i32) => {a: boolean, f: K0, z: i32}) | null)[]) {
  const f = xs[0]
  if f != null {
    const o = f(1)
    print(o.a)
    print(o.f)
    print(o.z)
  }
  print(xs.length)
}

useCurried([(_q) => (() => "hi"), null])
useStruct([(q) => ({ a: true, f: "b", z: q + 1 }), null])
