// @run
// @log 2
// @log 4
// @log 6
// @log 8
// @log false
// @log false
// @log true
// @log true
// @log 2
// @log 13
// @log 14
// @log 3
// @log 6
// @log 11
// @log 21
// @log 0
// @log 0
// Contextual parameter inference: an UN-annotated function-literal callback
// infers its param type from the expected callback type at the call site, so
// `function(n) …` needs no `n: i32`. This is the same surface as
// `arrays/map-filter.vl`, with every callback param de-annotated to demonstrate
// the inference; the receiver `i32[]` pins `n: i32` and the body type-checks.

// map i32 -> i32 (param `n` inferred as i32 from `xs: i32[]`).
const xs = [1, 2, 3, 4]
const doubled = xs.map(function(n) n * 2)
print(doubled[0]) // 2
print(doubled[1]) // 4
print(doubled[2]) // 6
print(doubled[3]) // 8

// type-changing map (i32 -> boolean): `n` still inferred as i32; the RESULT
// element type `U` is the callback's return type (boolean), as before.
const flags = xs.map(function(n) n > 2)
print(flags[0]) // false (1 > 2)
print(flags[1]) // false (2 > 2)
print(flags[2]) // true  (3 > 2)
print(flags[3]) // true  (4 > 2)

// chaining: each callback in the chain infers from the element type flowing
// through it (map's result `i32[]` feeds filter's `(i32) -> boolean`).
const chained = xs.map(function(n) n + 10).filter(function(n) n > 12)
print(chained.length) // 2
print(chained[0])     // 13
print(chained[1])     // 14

// filter with an inferred predicate param.
const small = xs.filter(function(n) n < 4)
print(small.length) // 3 — 1, 2, 3 pass

// a named function (with the receiver's element type) chains after inferred
// callbacks unchanged.
function inc(n: i32) n + 1
const base = [1, 5, 10, 20]
const bumped = base.filter(function(n) n > 4).map(inc)
print(bumped[0]) // 6
print(bumped[1]) // 11
print(bumped[2]) // 21

// empty input with inferred callbacks: still empty.
const e: i32[] = []
print(e.map(function(n) n * 2).length)   // 0
print(e.filter(function(n) n > 0).length) // 0
