// @run
// @log 300
// @log 400
// @log 8
// @log 9
// @log 2.5
// @log 3.5
// @log 2
// @log 5
// The OUTER `.push` / row-assign of a 2-D array with a distinct-backing scalar leaf: the
// pushed/stored inner-list LITERAL must build the receiver's INNER list kind — `b.push([300])`
// over `i64[][]` builds an i64 inner list (the plain-`emitExpr` default built the i32 list, a
// wrapper-heap mismatch → INVALID WASM); same for `d.push([2.5])` over `f32[][]` (the literal
// self-classified f64), an int-leaf `[2]` into `f64[][]`, and the row-assign `b[i] = [7, 8]`.
// `refElemValueCtx` (the push/assign twin of `emitArr`'s per-element seeds) threads the inner
// kind; a kind-9 receiver (`i32[][][]`) seeds the inner ref-list slot recursively.

function go() {
  // i64[][]: outer push of int-literal rows + row-assign.
  const b: i64[][] = [[100]]
  b.push([300, 400])
  print(b[1][0]) // 300
  print(b[1][1]) // 400
  b[0] = [7, 8]
  print(b[0][1]) // 8
  b[0][0] = 9
  print(b[0][0]) // 9

  // f32[][]: outer push of a float-literal row (self-classifies f64 without the seed).
  const d: f32[][] = [[1.25]]
  d.push([2.5])
  print(d[1][0]) // 2.5
  d[0] = [3.5]
  print(d[0][0]) // 3.5

  // f64[][]: an int-leaf row widens at the build.
  const a: f64[][] = [[1.5]]
  a.push([2])
  print(a[1][0]) // 2

  // 3-D (kind-9 recursion): the pushed row is itself a ref list.
  const t: i32[][][] = [[[1]]]
  t.push([[5]])
  print(t[1][0][0]) // 5
}
go()
