// @run
// @log 6
// @log 5
// @log 2.5
// @log 2
// @log 6
// An UN-ANNOTATED function that `.map`/`.filter`s its parameter now lowers for f64 — the same
// definition serving i32 and f64 receivers. The shared body's inline callback (`(x) => x * 2`)
// is checked ONCE with the element as a hole, so its param defaulted to i32 at emit; now each
// monomorphized instance whose receiver pins to a NON-i32 element CLONES the callback with its
// param pinned to that element type (`self: f64[]` ⇒ `x: f64`). The un-annotated RETURN is
// typed per instance too: `.filter` preserves the element, and a `.map` with an element-wise
// arithmetic callback preserves it, so the instance returns the concrete `f64[]` (the
// inferred-return path has no f64-array map/filter-result form). i32 instances are unchanged.

function scale(self) {
  return self.map((x) => x * 2)
}
print(scale([1, 2, 3])[2])  // 6   (i32 instance — same definition)
print(scale([1.5, 2.5])[1]) // 5   (f64 instance — cloned callback, x: f64)

function bigs(self) {
  return self.filter((x) => x > 2.0)
}
print(bigs([1.5, 2.5, 3.5])[0])     // 2.5
print(bigs([1.5, 2.5, 3.5]).length) // 2

// The f64 map result is a real f64 list — usable in further f64 arithmetic.
const r = scale([1.0, 2.0])
print(r[0] + r[1]) // 6  (2.0 + 4.0)
