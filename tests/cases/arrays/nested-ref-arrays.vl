// @run
// @log 2
// @log 7
// @log 5
// @log bc
// @log 20
// @log 1
// @log 5
// @log 6
// @log 15
// @log 9
// @log 3
// NESTED REF ARRAYS of any leaf type at any depth — `S[][]`, `S[][][]`, `((i32)=>i32)[][]`,
// `string[][]`, `(P|null)[][]`, `(Cat|Dog)[][]`. The emitter's ref-list machinery is now driven
// by a RECURSIVE name resolver: `nameIsRefArray`/`refArrElemKind`/`refArrElemName` recurse on the
// element, `ensureRefElem` interns inner list slots inner-first, and the kind-9 heap resolution
// (the inner list's wrapper) was already recursive — so arbitrary nesting × diverse leaf types
// falls out for literal build, index, field access, for-in, push, params, and returns alike.

type C = { v: i32 }
type Cat = { meow: i32 }
type Dog = { bark: i32 }

function sumGrid(g: C[][]): i32 {
  let t = 0
  for row in g {
    for c in row { t = t + c.v }
  }
  return t
}

function makeGrid(): C[][] { return [[{ v: 9 }]] }

function go() {
  // STRUCT 2D — literal, index, field.
  const g: C[][] = [[{ v: 1 }, { v: 2 }], [{ v: 3 }]]
  print(g[0][1].v) // 2

  // STRUCT 3D.
  const g3: C[][][] = [[[{ v: 7 }]]]
  print(g3[0][0][0].v) // 7

  // i32 3D (scalar leaf, deep).
  const ints: i32[][][] = [[[1, 2]], [[3]]]
  print(ints[0][0][1] + ints[1][0][0]) // 2 + 3 = 5

  // STRING 2D.
  const ss: string[][] = [["a", "b"], ["c"]]
  print(ss[0][1] + ss[1][0]) // bc

  // CLOSURE 2D — index then call.
  const fs: ((i32) => i32)[][] = [[(x) => x + 1], [(x) => x * 2]]
  print(fs[1][0](10)) // 20

  // NULLABLE-struct 2D — narrow the element.
  const ns: (P | null)[][] = [[{ x: 1 }, null], [{ x: 3 }]]
  const r = ns[0][0]
  if r != null {
    print(r.x) // 1
  } else {
    print(-1)
  }

  // inline UNION 2D — narrow with `is`.
  const us: (Cat | Dog)[][] = [[{ meow: 5 }], [{ bark: 2 }]]
  const a = us[0][0]
  if a is Cat {
    print(a.meow) // 5
  } else {
    print(-1)
  }

  // for-in over a struct 2D.
  print(sumGrid(g)) // 1+2+3 = 6

  // a 2D ARGUMENT (literal passed to a `C[][]` param).
  print(sumGrid([[{ v: 4 }, { v: 5 }], [{ v: 6 }]])) // 15

  // a 2D RETURN.
  print(makeGrid()[0][0].v) // 9

  // PUSH an inner list onto a struct 2D.
  const gg: C[][] = [[{ v: 1 }]]
  gg.push([{ v: 2 }, { v: 3 }])
  print(gg[1][1].v) // 3
}

type P = { x: i32 }

go()
