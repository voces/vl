// @run
// @log 42
// @log 3
// @log 99
// @log b
// @log 2.5
// @log 7
// @log 3
// @log 2
// In-`len` list index reads/writes still work after `.push` grows the backing
// capacity past `len` — the bounds guard compares against the wrapper's `len`
// field, not the backing's physical length, and leaves in-range accesses
// untouched. Exercises every list kind's guard frame in one function (i32,
// string, f64, ref-struct, nested list-of-lists) plus a nested-index index.
function f() {
  const xs: i32[] = []
  xs.push(42)
  print(xs[0])       // 42 — in-len read after growth (len=1, cap=4)
  const ys = [1, 2, 3]
  print(ys[2])       // 3 — literal-seeded list, last element
  ys[1] = 99
  print(ys[1])       // 99 — in-len write then read back
  const ss = ["a", "b"]
  print(ss[1])       // b — string-list read
  const fs = [1.5, 2.5]
  print(fs[1])       // 2.5 — f64-list read
  const os = [{v: 7}]
  print(os[0].v)     // 7 — ref-list read + member
  const g = [[1, 2], [3, 4]]
  print(g[1][0])     // 3 — nested read (ref-list outer, i32-list inner)
  print(g[0][g[1][1] - 3]) // 2 — an index that is itself an index read
}
f()
