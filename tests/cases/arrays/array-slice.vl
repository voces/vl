// @run
// @log 2
// @log 2
// @log 3
// @log 3
// @log b
// @log c
// @log 2.5
// @log 7
// @log 2
// An array `.slice(start, end?)` — a NEW list over the half-open clamped range, of the
// SAME element kind. JS semantics: a missing `end` runs to the length, negatives count
// from the end, the out length is `max(end - start, 0)`. Rides the `.map`/`.filter`
// scratch frame (`mfScan`'s slice branch reserves the src wrapper + dst backing); one
// `array.copy` fills the fresh backing. Works for i32/boolean, f64, string, and struct
// (ref) lists. Previously the checker rejected `.slice` on an array.

function go() {
  const xs = [1, 2, 3, 4]
  const ys = xs.slice(1, 3)
  print(ys.length) // 2
  print(ys[0]) // 2
  print(ys[1]) // 3

  // 1-arg form slices to the end.
  print(xs.slice(1).length) // 3

  // string[] elements.
  const ss = ["a", "b", "c", "d"]
  const sub = ss.slice(1, 3)
  print(sub[0]) // b
  print(sub[1]) // c

  // f64[] elements.
  const fs = [1.5, 2.5, 3.5]
  print(fs.slice(1, 2)[0]) // 2.5

  // negative bounds count from the end.
  const ns = [5, 6, 7, 8]
  print(ns.slice(-2, -1)[0]) // 7

  // struct (ref) elements.
  const ps = [{ x: 1 }, { x: 2 }, { x: 3 }]
  print(ps.slice(1, 2)[0].x) // 2
}
go()
