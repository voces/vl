// @run
// @log 2
// @log 5
// @log 8
// @log 2
// @log 5
// @log 9
// @log 0
// `.filter` over a STRUCT array yields a struct array (the element type is preserved). The
// result binds/indexes/chains as a ref list, and the map/filter scratch frame tracks a per-slot
// ref-list dest so two filters of different element types don't collide. Also covers an INFERRED
// ref-array return (filter-and-return without annotating the return type).

type P = { x: i32 }
type Pt = { x: i32, y: i32 }

function go() {
  const ps: P[] = [{ x: 1 }, { x: 5 }, { x: 2 }, { x: 8 }]
  const big = ps.filter((p) => p.x > 2)
  print(big.length) // 2
  print(big[0].x) // 5
  print(big[1].x) // 8

  // `.filter(...).map(...)` chain over structs.
  const r = ps.filter((p) => p.x > 2).map((p) => p.x)
  print(r.length) // 2
  print(r[0]) // 5

  // Two DIFFERENT struct types filtered in one function (distinct dest backing slots).
  const pts: Pt[] = [{ x: 1, y: 4 }, { x: 9, y: 2 }]
  const fpt = pts.filter((p) => p.x > 5)
  print(fpt[0].x) // 9

  // Filter-all-out yields an empty list.
  print(ps.filter((p) => p.x > 100).length) // 0
}
go()
