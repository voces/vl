// @run
// @log true
// @log false
// @log true
// @log 2
// @log 3
// A `boolean[]` array — annotated local, param, return, `.push`, indexing, `.length`.
// A boolean is an i32 0/1 at the wasm level, so a `boolean[]` shares the i32-list rep
// exactly (`nameIsI32Array` accepts it); only the element PRINT formatting recovers
// boolean-ness (`exprIsBool` over an Index of a declared `boolean[]`), so `bs[i]` prints
// true/false, not 1/0. Previously the `boolean[]` annotation failed emit ("only i32[]
// arrays and struct/union element arrays are supported").

function countTrue(bs: boolean[]): i32 {
  let n = 0
  let i = 0
  while i < bs.length {
    if bs[i] { n = n + 1 }
    i = i + 1
  }
  return n
}

function mk(): boolean[] {
  const out: boolean[] = []
  out.push(true)
  out.push(false)
  out.push(true)
  return out
}

function go() {
  const bs: boolean[] = [true, false, true]
  print(bs[0]) // true
  print(bs[1]) // false
  print(bs[2]) // true
  print(countTrue(bs)) // 2
  print(mk().length) // 3
}
go()
