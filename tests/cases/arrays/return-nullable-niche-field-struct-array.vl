// @run
// @log NULLret
// @log 3
// @log true
// @log ENULL
// @log FNULL
// A function RETURNING `({f: boolean | null} | null)[] | null` — a nullable array of nullable
// structs whose field is a NULLABLE BOOLEAN (an i32 niche). `emitReturnValue` seeds the outer
// `| null` wrapper heap (`retCtx.nulRefHeap`) so a `return null` lowers as `ref.null $wrapper`.
// That whole-value seed is now GATED on the return VALUE being a bare `null` (the #964
// discipline): a `return [null]` LIST literal's null struct ELEMENT takes the per-element
// `pendingStructIdx` seed (`ref.null $S`) instead — un-gated, the wrapper heap leaked through
// the array literal's element context and stored `ref.null $wrapper` into the struct-element
// backing, so `array.new_fixed $S` failed "expected (ref null $S), found (ref null $wrapper)"
// (INVALID-WASM, plain gating seed 181842559 d5, p2c + p2r). The return twin of the kind-18
// binding seed at `localIsRef[slot] == "nulreflist"`.
function mkNull(): ({f: boolean | null} | null)[] | null { return null }
function mkArr(): ({f: boolean | null} | null)[] | null {
  return [{ f: true }, null, { f: null }]
}
function go() {
  const a = mkNull()
  if a != null { print(a.length) } else { print("NULLret") }
  const b = mkArr()
  if b != null {
    print(b.length)
    const e0 = b[0]
    if e0 != null {
      const f0 = e0.f
      if f0 != null { print(f0) } else { print("F0NULL") }
    } else {
      print("E0NULL")
    }
    const e1 = b[1]
    if e1 != null { print("E1") } else { print("ENULL") }
    const e2 = b[2]
    if e2 != null {
      const f2 = e2.f
      if f2 != null { print(f2) } else { print("FNULL") }
    } else {
      print("E2NULL")
    }
  } else {
    print("ARRNULL")
  }
}
go()
