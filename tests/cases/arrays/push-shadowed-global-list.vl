// @run
// @log 42
// @log 2
// @log 1
// @log 9
// @log 1
// @log 11
// @log 1
// @log 2
// @log 2
// @log 2.5
// @log 2
// `.push` whose receiver NAME shadows a module-GLOBAL list of a DIFFERENT element
// kind — the #922-observed hole: the `expr*Array` classifiers consulted the GLOBAL
// tables even when the name was bound to a param / declared local of the frame, so
// the push routed through the GLOBAL's element kind and its typed push frame
// mismatched the receiver's actual wrapper ref — invalid wasm. Scope shadows now: a
// param or declared local blocks the classifiers' global fallback
// (`identShadowedByFrame`), so the receiver classifies by ITS binding's kind.

const xs: string[] = ["g"]
const ys: f64[] = [1.5]
const zs: string[] = ["z"]

// Param i32[] shadowing the global string[] `xs`.
function pushI32(xs: i32[]): i32 {
  xs.push(42)
  xs[xs.length - 1]
}

// Param i32[] shadowing the global f64[] `ys`.
function pushOverF64(ys: i32[]): i32 {
  ys.push(9)
  ys[ys.length - 1]
}

// Declared LOCAL i32[] shadowing the global string[] `zs`.
function localShadow(): i32 {
  const zs: i32[] = [7]
  zs.push(11)
  zs[zs.length - 1]
}

// Reverse pins (worked before the fix — the param's own kind claims first): a
// param string[] / f64[] shadowing the global i32[] `ps`.
const ps: i32[] = [1, 2]
function pushStr(ps: string[]): i32 {
  ps.push("hello")
  ps.length
}
function pushF64(ps: f64[]): f64 {
  ps.push(2.5)
  ps[ps.length - 1]
}

function go() {
  const a: i32[] = [7]
  print(pushI32(a)) // 42 — pushed onto the param's i32 list
  print(a.length)   // 2
  print(xs.length)  // 1 — the shadowed global string list is untouched
  const b: i32[] = [1]
  print(pushOverF64(b)) // 9
  print(ys.length)      // 1
  print(localShadow())  // 11
  print(zs.length)      // 1
  const c: string[] = ["a"]
  print(pushStr(c)) // 2
  print(c.length)   // 2
  const d: f64[] = [0.5]
  print(pushF64(d)) // 2.5
  print(ps.length)  // 2 — the shadowed global i32 list is untouched
}
go()
