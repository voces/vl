// @run
// @log 2
// @log hi
// @log c
// @log x
// @log 30
// Usage-driven element inference for an un-annotated empty `[]` now follows a push of
// any STRING-typed expression, not only a string LITERAL: `const out = []; out.push(s)`
// over a string variable (or `out.push(self[i])` over a `string[]`) classifies `out` as
// `string[]` — both the local SLOT (`collectLocals`) and the `[]` literal's built rep
// (the `emitArr` seeding) agree (kind 7 / string-list), where before the slot inferred
// string but the `[]` defaulted to the i32 list and the store trapped wasm validation.
// This unblocks a generic build-loop (`slice`/`reverse`) over `string[]`.

// Concrete: push a string VARIABLE (not a literal).
function dup(s: string): string[] {
  const out = []
  out.push(s)
  out.push(s)
  return out
}
print(dup("hi").length) // 2
print(dup("hi")[0])     // hi

// Generic `reverse` over a `string[]` (push `self[i]`, an index into a string[] param).
function reverse<T>(self: T[]): T[] {
  const out = []
  let i = self.length - 1
  while i >= 0 {
    out.push(self[i])
    i = i - 1
  }
  return out
}
print(reverse(["a", "b", "c"])[0]) // c

// Generic `slice` over a `string[]`.
function slice<T>(self: T[], lo: i32, hi: i32): T[] {
  const out = []
  let i = lo
  while i < hi {
    out.push(self[i])
    i = i + 1
  }
  return out
}
print(slice(["w", "x", "y", "z"], 1, 3)[0]) // x

// The SAME generic definitions still serve `i32[]` (the i32 list is the default rep).
print(reverse([10, 20, 30])[0]) // 30
