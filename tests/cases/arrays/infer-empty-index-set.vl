// @run
// @log 9
// @log 4
// USAGE-DRIVEN INFERENCE via an index-set: `xs[i] = v` on an un-annotated empty
// `[]` pins the element type to `typeof v` (here `i32`). The list is grown with a
// push first so the index is in range, then written through `[]=` and read back.
const xs = []
xs.push(0)
xs[0] = 9
xs.push(4)
print(xs[0])
print(xs[1])
