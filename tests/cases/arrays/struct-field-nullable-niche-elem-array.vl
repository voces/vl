// @run
// @log fjlrl
// @log NULL
// @log bxpb
// @log WHOLENULL
// @log true
// @log 9
// @log false
// A STRUCT FIELD holding a nullable ARRAY of nullable-litunion-niche elements —
// `{f: (K0 | null)[] | null}` (K0 a litunion alias). `(K0 | null)[]` reps as an i32-niche
// array (each element the interned atom id, `null` = the spare `-1`), wrapped in the
// nullable-nullist field (code 18). The construction `{f: [null]}` / `{f: ["fjlrl", null]}`
// was INVALID-WASM: the whole ObjLit is covariantly `assignable` to the field type, so
// `assignableExpr`'s field-wise recursion (which re-stamps the inner niche array with its
// destination type) never runs, and `recordNicheNulElemArrayLit` did not descend into
// ObjLit fields — so the inner `[null]` kept its `null[]` self-inference. `emitArr` then
// missed the `pendingNulLitUnion` seed and the nullable-field's whole-value `pendingNulRefHeap`
// (`ref.null $wrapper`) leaked into the i32-array element ("expected i32, found (ref null
// $type)"). The fix descends `recordNicheNulElemArrayLit` into ObjLit fields (the niche-array
// sibling of `recordNullHoleObjAdopt`), so the inner array re-stamps and its `null` elements
// lower as the `-1` sentinel. Pre-existing (reproduced identically pre-#1008); NOT a #1008
// regression.
type K0 = "0" | "fjlrl" | "bxpb"
const g: {f: (K0 | null)[] | null} = { f: ["fjlrl", null, "bxpb"] }
const gnull: {f: (K0 | null)[] | null} = { f: null }
// The boolean-niche sibling (`(boolean | null)[]`, sentinel `2`) — the same field-descent
// path, proving the fix generalizes beyond the litunion atom niche.
const gb: {f: (boolean | null)[] | null} = { f: [true, null, false] }

function go() {
  const t0 = g.f
  if t0 != null {
    let i = 0
    while i < t0.length {
      const t1 = t0[i]
      if t1 != null { print(t1) } else { print("NULL") }
      i = i + 1
    }
  } else {
    print("EMPTY")
  }
  const w = gnull.f
  if w != null { print("NOTNULL") } else { print("WHOLENULL") }
  const b0 = gb.f
  if b0 != null {
    let j = 0
    while j < b0.length {
      const b1 = b0[j]
      if b1 != null { print(b1) } else { print(9) }
      j = j + 1
    }
  } else {
    print(9)
  }
}

go()
