// @run
// @log 3
// @log 20
// @log -1
// @log -1
// @log 2.5
// @log 7
// @log 0
// The growable `T[]` rep (B6): a `[...]` literal seeds `len = N`. The safe accessor
// `.get(i): T | null` returns the element in range, else `null` (no trap — that is
// the unrecoverable-bug signal reserved for `a[i]`), composed with `??` to default
// the absent case.
const a = [10, 20, 30]
print(a.length)        // 3 — struct.get len
print(a.get(1) ?? -1)  // 20 — in range
print(a.get(3) ?? -1)  // -1 — past len → null
print(a.get(-1) ?? -1) // -1 — negative → null (unsigned bound check)

// `.get` works for non-i32 elements too (f64 here).
const f = [1.5, 2.5, 3.5]
print(f.get(1) ?? 0.0) // 2.5

// Reference elements exercise the niche-nullable-ref `.get` encoding: the
// payload is a `ref null $struct`, narrowed by `?.`/`??`.
const objs = [{v: 7}, {v: 8}]
print(objs.get(0)?.v ?? 0) // 7 — present
print(objs.get(5)?.v ?? 0) // 0 — out of range → null
