// @run
// @log 0
// @log 7
// @log 12
// USAGE-DRIVEN INFERENCE from sources OTHER than `push`. The element type of an
// un-annotated empty `[]` is pinned by:
//   1. passing it to a `T[]` parameter (`len(empty)` — NO push at all, pure
//      downstream-usage inference: `empty` is `i32[]` solely from the call site),
//   2. an annotated assignment (`const ys: i32[] = zs`),
//   3. a `T[]`-returning function whose tail is the empty (`mk(): i32[]`).
function len(a: i32[]): i32 { a.length }
function mk(): i32[] {
  const inner = []
  inner
}

const empty = []
print(len(empty))

const zs = []
const ys: i32[] = zs
ys.push(7)
print(ys[0])

const r = mk()
r.push(12)
print(r[0])
