// @run
// @log 1
// @log 2
// @log 2
// USAGE-DRIVEN INFERENCE (A-infer-empty), headline case: an un-annotated empty
// `[]` infers its element type from a downstream `xs.push(v)`. Here the `push(1)`
// pins `xs`'s element to `i32`, so `xs` is `i32[]` — it compiles and runs (this
// used to crash with the opaque `Unhandled "Unknown" type`, or, with the floor in
// place, refuse to infer). Read back the pushed element and the length.
const xs = []
xs.push(1)
xs.push(2)
print(xs[0])
print(xs[1])
print(xs.length)
