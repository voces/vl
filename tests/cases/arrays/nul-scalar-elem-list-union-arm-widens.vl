// @run
// @log 167234547
// @log OTHER
// @log 887.5
// @log NULL
// A list LITERAL flowing into a union whose matching arm is a NULLABLE-SCALAR-element
// ref array (`(i64 | null)[] | i64` fed `[167234547]`, `(f32 | null)[] | boolean` fed
// `[887.5]`). The arm-route probe classifies the bare int literal "i32" and the float
// literal "f64", so the exact-atom arm match missed and the literal fell to the
// value-atom LADDER — boxed as a RAW scalar list with a non-matching tag, every
// `is (i64|null)[]` on it silently FALSE (a live MISMATCH, fuzz-nightly seed
// 104984070 d6). `unionRefArrayArmSlotForElem` now admits the checker-granted
// literal widening (i32→i64/f64/f32, f64→f32) after the exact pass, routing the
// literal through the arm's build (which re-encodes at the element width, as the
// annotated binding form already did).
const g: (i64 | null)[] | i64 = [167234547]
function useF(v: (f32 | null)[] | boolean) {
  const t0 = v
  if t0 is (f32 | null)[] {
    const t1 = t0[0]
    if t1 != null { print(t1) } else { print("NULL") }
  } else {
    print("OTHER")
  }
}
function go() {
  const t0 = g
  if t0 is (i64 | null)[] {
    const t1 = t0[0]
    if t1 != null { print(t1) } else { print("NULL") }
  } else {
    print("OTHER")
  }
  useF(true)
  useF([887.5])
  useF([null])
}
go()
