// @run
// @log 7
// @log hi
// @log 1.5
// @log 3.5
// An un-annotated empty `[]` whose element a downstream `.push` pins now lowers for ANY
// SCALAR element, not just i32/string. The checker records the binding's inferred array
// type; the emitter synthesizes the equivalent `<elem>[]` annotation from that recorded
// type (`nodeArrayElemName`, built on the typed-IR `nodeTyIxOf` foundation), so the slot
// classifier, the `[]`-seeding, the push, and the return ALL read one annotation and agree —
// instead of each re-deriving the element with its own per-rep usage predicate. Previously
// an f64 build (`const o = []; o.push(1.5)`) produced invalid wasm (slot/seeding disagreed).

// i32 (already worked — now routes through the same synthesized annotation, unchanged).
function geti(): i32[] {
  const o = []
  o.push(7)
  return o
}
print(geti()[0]) // 7

// string (already worked — same).
function gets(): string[] {
  const o = []
  o.push("hi")
  return o
}
print(gets()[0]) // hi

// f64 — the newly-unblocked case.
function getf(): f64[] {
  const o = []
  o.push(1.5)
  o.push(2.5)
  o.push(3.5)
  return o
}
const r = getf()
print(r[0]) // 1.5
print(r[2]) // 3.5
