// @run
// @log 99
// @log 4
// @log 40
// @log 42
// @log 4
// @log 8
// @log 9
// @log 2
// @log 98
// @log 4
// @log 77
// @log 4
// Eval-order list-store family (the #918 map-SET family, list flavor): the old
// lowering resolved the target's BACKING + len (the `i u< len` guard) BEFORE
// evaluating the RHS, so an RHS that pushes onto the target list past its cap
// reallocated the backing and the store landed in the STALE pre-reallocation
// array — a silent lost write. The fix evaluates receiver, index, VALUE in
// source order and resolves the backing after the value.

// Global i32 list, RHS pushes past cap (silently printed 10 pre-fix).
let a: i32[] = [10, 20]
function f(): i32 {
  a.push(30)
  a.push(40)
  99
}
a[0] = f()
print(a[0])     // 99
print(a.length) // 4
print(a[3])     // 40

// Struct-FIELD receiver: the wrapper rides a struct field; same reallocation.
type S = { xs: i32[] }
const s: S = { xs: [5, 6] }
function h(): i32 {
  s.xs.push(7)
  s.xs.push(8)
  42
}
s.xs[1] = h()
print(s.xs[1])     // 42
print(s.xs.length) // 4
print(s.xs[3])     // 8

// Grow-into-bounds: the index equals the OLD len; the RHS push makes it
// in-bounds by store time. The stale-len guard TRAPPED here pre-fix.
let c: i32[] = [1]
function k(): i32 {
  c.push(0)
  9
}
c[1] = k()
print(c[1])     // 9
print(c.length) // 2

// LOCAL list mutated through a param-passing call (no globals involved).
function bump(xs: i32[]): i32 {
  xs.push(3)
  xs.push(4)
  98
}
function viaParam(): i32 {
  const xs: i32[] = [1, 2]
  xs[0] = bump(xs)
  print(xs[0])     // 98
  print(xs.length) // 4
  0
}
viaParam()

// INDEX-expr mutation (always worked — the guard already ran after the index
// expr; pinned so it stays that way).
let b: i32[] = [1, 2]
function g(): i32 {
  b.push(3)
  b.push(4)
  0
}
b[g()] = 77
print(b[0])     // 77
print(b.length) // 4
