// @run
// @log 3
// @log 7
// An INLINE-SHAPE ref-list param (`bs: {v:i32}[]`) given a DECLARED twin's `A[]` — the
// declared-vs-inline variant of ref-list slot dedup. `collectAnnShapes` dedups the
// annotation's element shape ONTO the declared struct, so the spelling has no `sNames`
// entry of its own: the structural bridge (`structIndexOfTypeName`, layout-guarded)
// must resolve it at `nameIsRefArray` / `refArrElemName` / the element read, and the
// shape-keyed slot must twin with the `A` slot at the heap layer (one wrapper + one
// backing). Used to REJECT at `checkArrName` ("only i32[] arrays ... supported").
type A = { v: i32 }

function sumShape(bs: { v: i32 }[]): i32 {
  let t = 0
  let i = 0
  while i < bs.length {
    t = t + bs[i].v
    i = i + 1
  }
  return t
}

function main() {
  const as: A[] = [{ v: 1 }, { v: 2 }]
  print(sumShape(as))
  const direct: { v: i32 }[] = [{ v: 7 }]
  print(sumShape(direct))
}

main()
