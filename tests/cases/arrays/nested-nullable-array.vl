// @run
// @log 5
// @log -1
// @log 9
// A `(i32[][] | null)[]` — a list whose element is a NULLABLE NESTED array — now reads after narrowing.
// The element `i32[][] | null` reads as `(ref null $innerWrapper)`; binding `const t = v[i]` infers a new
// LOCAL kind 18 (nullable ref-array), the ref-array analogue of kind 15 (nullable i32-list): valtype
// `(ref null $innerWrapper)`, `t != null` lowers to `ref.is_null`, and a narrowed `t[j][k]` recovers
// non-null (`ref.as_non_null`) then indexes the inner ref-array via its slot (stored in `localStructIdx`,
// like a kind-5 ref-array local). Built on the structured `rlElemNullable` niche bit (#676), which keeps
// the read-skip from mis-firing on value-union boxes. Found by the rep-composition fuzzer (#667).

function go() {
  const v: (i32[][] | null)[] = [[[5]], null, [[8], [9, 10]]]

  const a = v[0]
  if a != null {
    print(a[0][0]) // 5
  } else {
    print(-1)
  }

  const b = v[1]
  if b != null {
    print(b[0][0])
  } else {
    print(-1) // -1
  }

  const c = v[2]
  if c != null {
    print(c[1][0]) // 9
  } else {
    print(-1)
  }
}

go()
