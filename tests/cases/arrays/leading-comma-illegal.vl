// @check
// @error unexpected ","
// @error expected RBRACK but found "1"
// @error unexpected "]"
// A leading comma in an array literal (`[,1]`) is still a syntax error: the
// trailing-comma relaxation only permits ONE comma immediately before `]`. The
// leading comma derails the literal, so the recovery cascade is declared in full.
let a = [, 1]
