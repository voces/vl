// @check
// @error expected an expression but found COMMA
// @error expected `]` but found `1`
// A leading comma in an array literal (`[,1]`) is still a syntax error: the
// trailing-comma relaxation only permits ONE comma immediately before `]`. The
// leading comma derails the literal; recovery resyncs at the `]`, so the
// cascade stops there.
let a = [, 1]
