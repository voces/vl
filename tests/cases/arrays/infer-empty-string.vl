// @run
// @log hi
// @log 2
// USAGE-DRIVEN INFERENCE: the element type comes from whatever is pushed — a
// `string` argument makes the empty `[]` a `string[]` (not a hardwired `i32[]`
// default). The inferred element flows through to `print` (string sink) and a
// second push of a string is accepted.
const xs = []
xs.push("hi")
xs.push("yo")
print(xs[0])
print(xs.length)
