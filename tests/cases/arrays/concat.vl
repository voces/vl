// @run
// @log 5
// @log 1
// @log 5
// @log 2
// @log 3
// List concat `a + b` (collections-design §VL.4): a *new* `T[]` sized exactly
// len(a) + len(b) in one allocation (two bulk array.copy). The originals are
// untouched (concat is non-mutating). In-place bulk append is intentionally NOT
// a method — `extend` was dropped in favour of `xs.push(...ys)` once variadics
// land; `a += b` (value-style rebind) covers the value form meanwhile.
const a = [1, 2]
const b = [3, 4, 5]
const c = a + b
print(c.length)  // 5  — len(a) + len(b)
print(c[0])      // 1  — copied from a (offset 0)
print(c[4])      // 5  — copied from b (offset len(a))
print(a.length)  // 2  — a untouched (concat is non-mutating)
print(b.length)  // 3  — b untouched
