// @run
// @log 2
// @log 4
// @log 6
// @log 1
// @log 3
// Arrow lambdas as array callbacks — the headline ergonomic use. The un-annotated
// param `n` infers `i32` from the receiver `i32[]` (contextual callback inference,
// see map-filter-inferred-callbacks.vl), so `(n) => n * 2` needs no annotation.
// map and filter both accept the arrow form.
const xs = [1, 2, 3]
const doubled = xs.map((n) => n * 2)
print(doubled[0]) // 2
print(doubled[1]) // 4
print(doubled[2]) // 6

const odds = xs.filter((n) => n % 2 == 1)
print(odds[0]) // 1
print(odds[1]) // 3
