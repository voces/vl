// @run
// @log true
// @log false
// @log true
// @log false
// @log true
// Regression (B6): a `boolean` element type uses the i32 *sentinel* nullable
// encoding, not a reference. So `.get`/`.pop` returning `boolean | null` must
// build the absent value via that sentinel — the `ref.null` path throws
// "Nullable of non-reference type boolean needs boxing". `nullableSome` already
// handled boolean; `nullableNull` did not, until this case pinned it.
let b = [true, false, true]
print(b.get(0) ?? false)   // true  — in range
print(b.get(9) ?? false)   // false — past len → null → ?? false
let x = b.pop()
print(x ?? false)          // true  — popped last element (true)
let e = [true]
let one = e.pop()          // true
let none = e.pop()         // null  — pop on empty
print(none ?? false)       // false
print(one ?? false)        // true
