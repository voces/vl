// @run
// @log 5
// @log 2.5
// @log 4
// @log 3
// @log 3
// f64-element `.map` / `.filter` with an UN-ANNOTATED callback now lower. The callback param
// (`(x) => …`) carries no annotation, and the emitter previously defaulted every un-annotated
// param to i32 — so the f64 element flowing in mismatched the i32 the callback's body assumed
// ("expected f64, found i32"). The checker already pins the param's type from the receiver's
// element (contextual inference, `x: f64`); that recorded type is now read back at emit and
// synthesized into the param's annotation, so its functype valtype follows the element.
// (Annotated `(x: f64) => …` already worked — this brings the un-annotated form to parity.)

const xs = [1.5, 2.5, 3.5]

print(xs.map((x) => x * 2.0)[1])    // 5    (2.5 * 2.0)
print(xs.filter((x) => x > 2.0)[0]) // 2.5  (first element > 2.0)

// Chained: map then filter, both un-annotated f64 callbacks.
print(xs.map((x) => x + 0.5).filter((x) => x > 3.0)[0]) // 4  (3.5 + 0.5)

// Bound to a local, then read.
const doubled = xs.map((x) => x * 2.0)
print(doubled[0])     // 3  (1.5 * 2.0)
print(doubled.length) // 3
