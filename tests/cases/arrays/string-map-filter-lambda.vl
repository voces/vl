// @run
// @log a!
// @log b!
// @log 3
// @log cc
// @log 3
// @log big
// @log c!
// STRING-element `.map` / `.filter` now lower. The map/filter emit machinery previously
// supported only i32 and f64 element kinds — a string list source / result was rejected
// (`mfRecvKindOf` returned -1), so a string callback fell through to a plain call and failed
// ("callee is not a function name"). A string list is now a first-class element kind (3): its
// source/result use the string-list wrapper (`$mkListIdx`) and backing (`$mkArrIdx`), and a
// string element — itself a ref (an `array i32` of code points) — is recovered with
// `ref.as_non_null` after `array.get`, exactly like a ref-list element. A string-RETURNING
// callback selects the string-list RESULT kind via `cloRetIsString` (which `cloRetKindOf`
// folds into -1, being outside the i32/f64 value ABI). (The callback param's `string` type is
// already synthesized from the receiver's element by the un-annotated-param-annotation pass.)

const r = ["a", "b", "c"].map((s) => s + "!")
print(r[0])     // a!
print(r[1])     // b!
print(r.length) // 3

// `.filter` over a string list keeps the string element kind.
print(["aa", "b", "cc"].filter((s) => s.length > 1)[1]) // cc

// String SOURCE, i32 result (`.length` per element).
print(["aa", "bbb", "c"].map((s) => s.length)[1]) // 3

// i32 SOURCE, string result — the result list is the program's only string list.
print([1, 2, 3].map((n) => if n > 1 { "big" } else { "small" })[2]) // big

// Chained: filter then map, both over string elements.
print(["a", "bb", "c"].filter((s) => s.length == 1).map((s) => s + "!")[1]) // c!
