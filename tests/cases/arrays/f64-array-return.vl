// @run
// @log 2.5
// @log 1.5
// @log 4.5
// @log 9.5
// FIRST CONSUMER of the typed-IR table (`nodeTyIxOf`): indexing the result of an
// `f64[]`-returning function used to fail emit ("index access but array type not
// collected"). The syntactic `exprF64Array` only recognized f64 array LITERALS / params /
// globals — a CALL fell through `calleeRetKind`, which never mapped an `f64[]` return to the
// f64-list kind, so the index defaulted to the i32 path over a program with no i32 array.
// The checker, however, already typed the call as `f64[]`; `exprF64Array` now trusts that
// recorded type first, so the index lowers as an f64-list read — no new bespoke predicate.

function mk(): f64[] {
  return [1.5, 2.5]
}

// Index the call result directly.
print(mk()[1]) // 2.5

// And through a binding (the binding's recorded type is `f64[]` too).
const xs = mk()
print(xs[0]) // 1.5

// The existing f64 array paths (literal, param) still work unchanged.
const lit = [3.5, 4.5]
print(lit[1]) // 4.5

function g(a: f64[]): f64 {
  return a[0]
}
print(g([9.5, 8.5])) // 9.5
