// @run
// @log 20
// @log 99
// @log 3
// @log 12
// WasmGC arrays (ROADMAP B6): an `i32`-indexed collection compiles to a WasmGC
// array. `[..]` → array.new_fixed, `a[i]` → array.get, `a[i] = v` → array.set,
// and `a.length` is intrinsic → array.len (no stored field). Bounds are
// natively trap-checked. Verified read, write, length, and a loop sum.
let a = [10, 20, 30]
__store_i32__(0, 0)
__store_i32__(4, a[1])
__log__(0, 8)
a[2] = 99
__store_i32__(4, a[2])
__log__(0, 8)
__store_i32__(4, a.length)
__log__(0, 8)
let b = [3, 4, 5]
let s = 0
for i in 0 to 2 {
  s = s + b[i]
}
__store_i32__(4, s)
__log__(0, 8)
