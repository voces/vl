// @run
// @log 10
// @log 30
// @log 3
// Trailing comma in an array literal (`[a, b,]`). The trailing `,` before `]` is
// allowed and ignored; a single-element list with a trailing comma and a
// multi-line form both produce the same array as the comma-free version.
const a = [10, 20, 30,]
const one = [10,]
const multi = [
  1,
  2,
  3,
]
print(one[0])
print(a[2])
print(multi[2])
