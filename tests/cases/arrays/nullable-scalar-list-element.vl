// @run
// @log 1.5
// @log 0
// @log x
// @log 42
// @log 1.25
// @log 1
// @log 2.5
// @log 3.5
// @log 0
// @log 9
// A nullable DISTINCT-BACKING scalar/string inner list as an array ELEMENT — `(f64[] | null)[]`,
// `(string[] | null)[]`, `(i64[] | null)[]`, `(f32[] | null)[]` — and the 2-D composition
// `(f64[] | null)[][]` (rep-fuzz R4 remnant p0c/p0r). The element reuses the leaf list's
// wrapper SINGLETON (`$fl64` / `$mkList` / `$il64` / `$fl32`) over an already-nullable
// `(ref null $wrapper)` backing, exactly like the shipped `(i32[] | null)[]` kind-4 niche:
// `nullArrayArrElem` admits inner kinds 6/7/8/10, the interned `rlElemNullable` bit keeps the
// index READ nullable (`const e = v[i]; if e != null` narrows to the leaf list — the read
// classifies as the `nulf64list`-family binding), a `null` element/push/row-assign lowers as
// `ref.null $wrapper`, and the push VALUE scratch slot is nullable for any niche element kind.

function useIt(p: (f64[] | null)[][]) {
  const row = p[0]
  const e = row[0]
  if e != null {
    print(e[0]) // 1.5
  }
  if row[1] == null {
    print(0) // 0
  }
}

function go() {
  useIt([[[1.5], null]])

  // The other distinct-backing leaves, at the local position.
  const s: (string[] | null)[] = [["x"], null]
  const se = s[0]
  if se != null {
    print(se[0]) // x
  }
  const b: (i64[] | null)[] = [[42], null]
  const be = b[0]
  if be != null {
    print(be[0]) // 42
  }
  const c: (f32[] | null)[] = [null, [1.25]]
  const ce = c[1]
  if ce != null {
    print(ce[0]) // 1.25
  }

  // Mutation: push null / a row, row-assign null then a row.
  const v: (f64[] | null)[] = [[1.5]]
  v.push(null)
  v.push([2.5])
  if v[1] == null {
    print(1) // 1
  }
  const ve = v[2]
  if ve != null {
    print(ve[0]) // 2.5
  }
  v[0] = [3.5]
  const v0 = v[0]
  if v0 != null {
    print(v0[0]) // 3.5
  }
  v[0] = null
  if v[0] == null {
    print(0) // 0
  }

  // Return position.
  print(readBack()) // 9
}

function mk(): (i64[] | null)[] { return [[9], null] }

function readBack(): i64 {
  const r = mk()
  const e = r[0]
  if e != null { return e[0] }
  return -1
}
go()
