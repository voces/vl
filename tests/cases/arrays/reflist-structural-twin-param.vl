// @run
// @log 3
// @log 30
// Structurally-identical DECLARED element types share ONE ref-list wrapper + backing heap
// type (the ref-list layer of structural slot dedup, `rlTwin`): an `A[]` passed where a
// `B[]` is expected — `sumA(bs: B[])` given an `A[]` — used to mismatch the wrapper
// `(ref $S)` at the call seam. Pins the declared-vs-declared shape in BOTH directions
// (param and return), including the element field read through the twin's slot.
type A = { v: i32 }
type B = { v: i32 }

function sumB(bs: B[]): i32 {
  let t = 0
  let i = 0
  while i < bs.length {
    t = t + bs[i].v
    i = i + 1
  }
  return t
}

function mkAsB(): B[] {
  const as: A[] = [{ v: 10 }, { v: 20 }]
  return as
}

function main() {
  const as: A[] = [{ v: 1 }, { v: 2 }]
  print(sumB(as))
  print(sumB(mkAsB()))
}

main()
