// @run
// @log 2
// @log 2
// @log 1
// @log 3
// @log 99
// @log 1
// @log 7
// @log 42
// A reflist whose ELEMENT is itself a VALUE-UNION / heterogeneous union, nested under a nullable
// wrapper and/or another array, previously lost its element rep and emitted INVALID-WASM.
//
// Shape 1 — `((f64 | {w: i32})[] | null)[]`: an array whose element is a nullable array of a
// value-union. `ensureRefElem` re-formed the inner element's array name as `f64 | {w: i32}[]`
// (no grouping parens), which `refArrElemKind` mis-split — paren-blind — into a plain struct
// element (kind 1) instead of the kind-2 union box, so the backing held `{w: i32}` refs and the
// raw f64 arm stored into a ref slot. `ensureRefElem` now peels grouping parens for a top-level-
// union element. Found by the rep-composition fuzzer (graduated INVALID-WASM p0c + REJECT p0r).
//
// Shape 2 — `(K0[] | {w: i32})[] | null`: a nullable array of a heterogeneous union element.
// `registerInlineUnion` never descended through the `| null` niche into the inner element union,
// so the element union box was never interned. It now strips a `<ref-array> | null` and recurses
// on the non-null ref-array name (graduated INVALID-WASM p0c).

type K0 = "aa" | "bb"

// Shape 1: read back an array of (nullable value-union arrays).
function go1() {
  const v: ((f64 | {w: i32})[] | null)[] = [[89.5, {w: 3}], null]
  print(v.length) // 2
  const inner = v[0]
  if inner != null {
    print(inner.length) // 2
    const e0 = inner[0]
    if e0 is f64 { print(1) } else { print(0) } // 1 (the f64 arm)
    const e1 = inner[1]
    if e1 is { w: i32 } { print(e1.w) } else { print(-1) } // 3 (the struct arm)
  }
  const inner1 = v[1]
  if inner1 == null { print(99) } // 99 (the null element)
}

// Shape 2: a nullable array of (K0[] | {w: i32}) elements. The struct arm + the whole-`null`
// arm are the soundly-constructible carriers; a literal `K0[]` element stays a clean loud
// REJECT ("nested arrays are not supported") — a distinct hole, never invalid wasm.
function go2() {
  const v: (K0[] | {w: i32})[] | null = [{ w: 7 }]
  if v != null {
    print(v.length) // 1
    const e0 = v[0]
    if e0 is { w: i32 } { print(e0.w) } else { print(0) } // 7
  }
  const n: (K0[] | {w: i32})[] | null = null
  if n == null { print(42) } // 42
}

go1()
go2()
