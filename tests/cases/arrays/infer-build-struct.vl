// @run
// @log 9
// @log 2
// @log 7
// An un-annotated empty `[]` whose element a downstream `.push` pins now lowers for a
// STRUCT element too, completing the inferred build for every element type (scalars landed
// earlier). The checker records the binding's inferred array type; the emitter synthesizes
// the equivalent annotation from it (`nodeArrayElemName`). A struct element renders as a
// structural shape (`{v: i32}`), but the ref-list machinery keys on the DECLARED struct
// name, so the synthesis resolves the shape to its interned struct's name (`P`) before
// stamping `P[]` — and the slot classifier, the `[]`-seeding, the push, and the return all
// agree. Previously an inferred struct build produced invalid wasm (the structural name
// wasn't recognized as a ref-list).

type P = { v: i32 }

// Push an object LITERAL into an un-annotated build.
function mk(): P[] {
  const o = []
  o.push({ v: 9 })
  return o
}
print(mk()[0].v) // 9

// Several pushes, read back through a binding.
function pair(): P[] {
  const o = []
  o.push({ v: 1 })
  o.push({ v: 2 })
  return o
}
const r = pair()
print(r[1].v) // 2

// Push a struct-typed VARIABLE (not a literal).
function wrap(p: P): P[] {
  const o = []
  o.push(p)
  return o
}
print(wrap({ v: 7 })[0].v) // 7
