// @run
// @log 24202
// @log 2.5
// @log 7
// @log INULL
// @log ONULL
// @log INULL
// The MIXED-REP field variant of the 2-D `(({a,f,z} | null)[] | null)[]` seed-leak family
// (companion to arrays/nested-nullable-struct-elem-array.vl, whose fields are boolean/string).
// Here the element struct's fields mix three reps — `a: f64`, `f: K0` (a litunion atom, i32
// niche) and `z: i32`. The OUTER `emitArr` classifies each element as a kind-9 nested ref list
// and seeds `pendingNulRefHeap = rlWrapIdx[innerSlot]` (the inner `(S|null)[]|null` wrapper) so a
// bare-`null` OUTER element lowers as `ref.null $wrapper`. That whole-value null seed is gated
// (since #1008, the #964 discipline) on the element BEING a bare NullLit — otherwise the inner
// `[null]` list literal's OWN bare-`null` STRUCT element consumes the leaked wrapper heap and
// stores `ref.null $wrapper` where `ref.null $S` is expected (INVALID-WASM "expected (ref null
// $type), found (ref null $type)"). The field reps are NOT load-bearing: the seed is the
// whole-struct-element heap, so #1008's gate covers this mixed f64+K0+i32 spelling identically to
// the boolean/string kin. Pre-existing (INVALID-WASM offset 650 pre-#1008 at f49377b, fixed by
// #1008 at 42fe650); NOT a #1021 regression, and the null-seed audit table (PR #1021) is correct —
// this is the already-closed emitArr-element position, not a missed one. (fuzz-sweep.YKq9Jw
// plain leg p1c+p1r, seed 179407594 — a stale draw against a pre-#1008 compiler build.)
type K0 = "ln" | "24202"

function useIt(p: (({a: f64, f: K0, z: i32} | null)[] | null)[]) {
  let k = 0
  while k < p.length {
    const t0 = p[k]
    if t0 != null {
      let i = 0
      while i < t0.length {
        const t1 = t0[i]
        if t1 != null {
          print(t1.f)
          print(t1.a)
          print(t1.z)
        } else {
          print("INULL")
        }
        i = i + 1
      }
    } else {
      print("ONULL")
    }
    k = k + 1
  }
}

function go() {
  useIt([[{ a: 2.5, f: "24202", z: 7 }, null], null])
  // The seed-leak case in isolation: a `[[null]]` build whose inner bare-`null` STRUCT element
  // must not consume the outer element's leaked wrapper heap.
  useIt([[null]])
}

go()
