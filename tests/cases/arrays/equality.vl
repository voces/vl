// Arrays compare by value: equal length + equal elements (recursively). Works
// for numeric, string, nested-array, and struct-with-array-field elements; an
// array is equatable iff its element type is.
let a = [1, 2, 3]
let b = [1, 2, 3]
print(a == b)        // true
print(a == [1, 2, 4]) // false (element differs)
print(a == [1, 2])    // false (length differs)
print(a != [1, 2, 4]) // true

let s = ["hi", "yo"]
print(s == ["hi", "yo"]) // true
print(s == ["hi", "no"]) // false

let m = [[1, 2], [3, 4]]
print(m == [[1, 2], [3, 4]]) // true (nested)
print(m == [[1, 2], [3, 5]]) // false
