// @check
// @error Unknown property `get`
// REGRESSION (B6a, C2.2): a `Set<T>` does NOT expose the Map `.get` method. The
// old `{[T]: boolean}` spelling shared the Map surface, so `.get` returned a
// nonsensical `boolean | null` (the membership flag, never a real stored value).
// A set is now its own type with no `.get`.
let s: {[string]: boolean} = Set()
let v = s.get("a")
