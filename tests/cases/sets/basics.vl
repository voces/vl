// @run
// @log 0
// @log 2
// @log true
// @log false
// @log 2
// @log red
// @log green
// @log true
// @log 1
// @log false
// @log green
// A `Set<T>` (B6a) is spelled as a boolean-valued map `{[T]: boolean}` (provisional
// surface). `Set()` constructs it; `.add(x)` inserts (idempotent — re-adding is a
// no-op), `.has`/`.delete`/`.size` work, and `.keys()` iterates in INSERTION
// ORDER (the deterministic-replay requirement). `add`/`delete` keep the order of
// the surviving elements.
let s: {[string]: boolean} = Set()
print(s.size)            // 0

s.add("red")
s.add("green")
s.add("red")             // duplicate — no-op
print(s.size)            // 2

print(s.has("red"))      // true
print(s.has("blue"))     // false
print(s.size)            // 2 — has doesn't mutate

for k in s.keys() {
  print(k)               // red, green — insertion order
}

// delete then re-check size + membership; survivors keep order.
print(s.delete("red"))   // true
print(s.size)            // 1
print(s.delete("red"))   // false — already gone
for k in s.keys() {
  print(k)               // green — red removed, order preserved
}
