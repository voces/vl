// @run
// @log 0
// @log 2
// @log true
// @log false
// @log 2
// @log red
// @log green
// @log true
// @log 1
// @log false
// @log green
// A `Set<T>` (B6a, C2) is its OWN type with its OWN surface — internally a
// boolean-valued hash map `{[T]: boolean}` (the boolean carries membership), but
// it exposes ONLY `.add`/`.has`/`.delete`/`.length`/`.values()`, NOT the Map
// surface (`.set`/`.get`/`.keys()`). `Set()` constructs it; `.add(x)` inserts
// (idempotent — re-adding is a no-op), `.has`/`.delete`/`.length` work, and
// `.values()` yields the ELEMENTS (a `T[]`, NOT the membership booleans) in
// INSERTION ORDER (the deterministic-replay requirement). `add`/`delete` keep the
// order of the surviving elements.
const s: {[string]: boolean} = Set()
print(s.length)          // 0

s.add("red")
s.add("green")
s.add("red")             // duplicate — no-op
print(s.length)          // 2

print(s.has("red"))      // true
print(s.has("blue"))     // false
print(s.length)          // 2 — has doesn't mutate

for x in s.values() {
  print(x)               // red, green — insertion order (elements, not booleans)
}

// delete then re-check size + membership; survivors keep order.
print(s.delete("red"))   // true
print(s.length)          // 1
print(s.delete("red"))   // false — already gone
for x in s.values() {
  print(x)               // green — red removed, order preserved
}
