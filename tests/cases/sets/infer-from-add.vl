// @run
// @log 2
// @log true
// @log false
// @log x
// @log y
// USAGE-DRIVEN INFERENCE (A-infer-map-set), Set headline: an un-annotated
// `const s = Set()` infers its element type from a downstream `s.add(x)` — the
// element from `"x"` (`string`) — materialising the binding into the real
// `Set<string>` representation (`{[string]: boolean}`, the boolean carrying
// membership). The Set surface (`.add`/`.has`/`.length`/`.values()`) then works
// unchanged; `.values()` yields the ELEMENTS in insertion order.
const s = Set()
s.add("x")
s.add("y")
s.add("x")                 // duplicate — no-op
print(s.length)            // 2
print(s.has("x"))          // true
print(s.has("z"))          // false
for v in s.values() {
  print(v)                 // x, y — insertion order
}
