// @run
// @log 1
// @log 0
// @log 0
// @log true
// @log true
// @log true
// The f32 flavors of the exponent clamp: overflow to ±infinity at the 8-bit
// biased-exponent ceiling, gradual underflow below 2^-126 (rounded once at the
// subnormal precision, ties-to-even). The power-of-two scalings are exact, and
// infinity is asserted structurally (hosts render it differently).
const p75: f32 = 37778931862957161709568.0
const p74: f32 = 18889465931478580854784.0
const x: f32 = 0.00000000000000000000000000000000000000000000140129846432481707092372958328991613128026194187651577175706828388979108268586060148663818836212158203125
print(x * p75 * p74) // 1 — the smallest positive f32 subnormal (2^-149), scaled by 2^149
const y: f32 = 0.00000000000000000000000000000000000000000000001
print(y) // 0 — below half the smallest subnormal rounds to zero
const t: f32 = 0.000000000000000000000000000000000000000000000700649232162408535461864791644958065640130970938257885878534141944895541342930300743319094181060791015625
print(t) // 0 — exactly half the smallest subnormal: ties-to-even
const a: f32 = 340282346638528860000000000000000000000.0
const c: f32 = 340282360000000000000000000000000000000.0
print(c > a) // true — past the f32 overflow midpoint (~3.40282357e38) encodes +infinity
const d: f32 = -340282360000000000000000000000000000000.0
print(d < 0.0 - a) // true — the negative literal encodes -infinity
print(a < c) // true — the max-finite f32 literal itself stays finite
