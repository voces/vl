// @run
// @log 1.5
// @log 3.5
// @log 3
// @log 1.5
// @log 2.5
// @log 4
// @log 4
// f32 ARRAYS (`f32[]`) — a new scalar list type family (`fa32TypeIdx` `(array (mut f32))`
// backing + `fl32TypeIdx` `{backing,len,cap}` wrapper), interned after the i64-list pair.
// f32 is the checker's weak spot (a float literal types f64), so an `f32[]` value is f32
// only when its declared type says so: the checker accepts a float-literal array into an
// `f32[]` slot (`assignableExpr`), and the emit threads `pendingListKind = 7` so the literal
// re-encodes its elements at f32 (a bare `[1.5]` stays f64). Covers declare, index read,
// `.length`, direct `print`, for-in, and an `f32[]` param + `f32` return.

function sum(xs: f32[]): f32 {
  let t: f32 = 0.0
  for x in xs { t = t + x }
  return t
}

function go() {
  const xs: f32[] = [1.5, 2.5, 3.5]
  print(xs[0]) // 1.5
  print(xs[2]) // 3.5
  print(xs.length) // 3

  // for-in over an f32 list.
  for x in xs {
    if x < 3.0 {
      print(x) // 1.5, 2.5
    }
  }

  // an f32[] param, summed and returned as f32.
  print(sum([1.5, 2.5])) // 4

  // a fresh f32 list built from a wider expression count.
  const ys: f32[] = [4.0]
  print(sum(ys)) // 4
}
go()
