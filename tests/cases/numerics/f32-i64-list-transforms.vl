// @run
// @log 3
// @log 2
// @log 2
// @log 4.5
// @log 10000000000
// @log 2
// @log 2
// @log 11000000000
// @log 7
// `.map` / `.filter` / `.slice` over an `f32[]` and an `i64[]` — the scalar-list transform family
// extended to the two element kinds it was missing (i32/f64/string/ref already worked). The
// dispatcher `mfRecvKindOf` now classifies an f32 list (mf-kind 13) and an i64 list (mf-kind 4),
// `mfResultKindOf` carries those through `.filter`/`.slice` (preserve) and `.map` (the callback's
// return kind), and `emitMapFilter`/`emitArrSlice` select the f32/i64 backing+wrapper. ALSO fixes
// a pre-existing soundness hole the map callbacks exposed: an inferred f32 return carrying a float
// LITERAL (`(v: f32) => v * 2.0`) emitted f64 against an f32 functype result — now coerced to f32.

function go() {
  // ── f32 ──
  const xs: f32[] = [1.5, 2.5, 3.5]
  // map with a LITERAL in the callback (the inferred-f32-return fix).
  print(xs.map((v: f32) => v + v)[0]) // 1.5 + 1.5 → 3
  print(xs.filter((v: f32) => v > 2.0).length) // 2.5, 3.5 → 2
  print(xs.slice(0, 2).length) // [1.5, 2.5] → 2
  // chain: filter then map (a float-literal callback), read the survivor.
  print(xs.filter((v: f32) => v > 2.0).map((v: f32) => v + 2.0)[0]) // 2.5 + 2.0 → 4.5

  // ── i64 ──
  const ys: i64[] = [5000000000, 1, 2]
  print(ys.map((v: i64) => v + v)[0]) // 5000000000 + 5000000000 → 10000000000
  print(ys.filter((v: i64) => v > 1).length) // 5000000000 and 2 keep (1 drops) → 2
  print(ys.slice(1, 3).length) // [1, 2] → 2
  // map with a literal callback over i64.
  print(ys.map((v: i64) => v + 6000000000)[0]) // 5000000000 + 6000000000 → 11000000000

  // map RESULT bound to a typed list, then summed via for-in.
  const zs: f32[] = xs.map((v: f32) => v * 2.0) // [3.0, 5.0, 7.0]
  let t: f32 = 0.0
  for v in zs {
    t = t + v
  }
  print(t - 8.0) // 15.0 - 8.0 → 7
}

go()
