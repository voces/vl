// @run
// @log 5000000000
// @log 0
// @log 10.5
// @log 0
// @log 0
// @log 7
// @log 3
// Soundness: an i32 value flowing into an i64/f64 slot is WIDENED at emit (the checker accepts
// the lattice widening, so a bare `i32.const` would emit invalid wasm). Two positions: an
// INFERRED i64/f64 RETURN (`return 0` in a function whose other branch is wide), and an
// ASSIGNMENT into an i64/f64 LOCAL.

// Inferred i64 return — one branch is a big i64 literal, the other a bare `0` (i32).
function big(n: i32) {
  if n < 0 { return 0 }
  return 5000000000
}

// Inferred f64 return — one branch f64, the other `0`.
function half(x: f64) {
  if x < 0.0 { return 0 }
  return x / 2.0
}

function go() {
  print(big(1)) // 5000000000
  print(big(-1)) // 0          (the widened `return 0`)
  print(half(21.0)) // 10.5
  print(half(-1.0)) // 0

  // Assignment of an i32 literal into i64 / f64 locals.
  let a: i64 = 5000000000
  a = 0
  print(a) // 0
  a = 7
  print(a) // 7
  let b: f64 = 1.5
  b = 3
  print(b) // 3
}
go()
