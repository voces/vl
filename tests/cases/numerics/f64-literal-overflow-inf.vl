// @log true
// @log true
// An f64 literal past the largest finite double must encode ±infinity — the
// biased exponent no longer fits its 11-bit field, and packing it unclamped
// would mask the high bits into an arbitrary finite value. A literal at the
// largest finite double stays FINITE (strictly below +infinity). Infinity is
// asserted structurally (hosts render it differently): it exceeds the largest
// finite double and is unchanged by halving.
const a = .0
const c = .0
print(c > a) // true — c encoded above every finite double
print(c * 0.5 == c) // true — only infinity is unchanged by halving (nonzero)
const d = -.0
print(d < 0.0 - a) // true — the negative literal encodes -infinity
print(a < c) // true — the max-finite literal itself stays finite
