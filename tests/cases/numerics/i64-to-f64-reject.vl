// @check
// @error i64 doesn't fit in f64 — the conversion is lossy and must be made explicit
// LOSSY implicit widening is REJECTED at typecheck. i64→f64 looks like a widening
// (same total bit-width), but an f64 has only 53 bits of mantissa, so an i64 above
// 2^53 rounds to the nearest f64 — the value is NOT preserved. Only the lossless
// edges (i32→i64, i32→f64, f32→f64) coerce implicitly; this one needs an explicit
// conversion (no syntax for it yet). A runtime i64 VALUE (not a literal) triggers
// the rule — a literal would type-check by value.
function id(n: i64): i64 { n + 1 }
const a: i64 = id(1)
const x: f64 = a
print(x)
