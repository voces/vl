// @run
// @log 2.5
// @log 3.5
// @log 2
// @log 3
// @log 2.5
// @log 3
// @log 7.5
// @log 1.5
// @log 2.5
// @log 3.5
// Nested f32 arrays (`f32[][]`, `f32[][][]`) — the f32 sibling of the scalar 2D arrays
// (`i64[][]`/`f64[][]`/`string[][]`). The outer ref-list's element is the inner f32-list
// WRAPPER (`fl32TypeIdx`), recognized as element kind 10 across `refArrElemKind`/`refArrElemName`
// /`nameIsRefArray`/`ensureRefElem`/collectA + the rlElemHeap second-pass; the literal seeds each
// inner element's `pendingListKind = 7` so a bare `[1.5]` builds an f32[] (not the f64 default);
// `g[i]` re-classifies as `f32[]` (`exprF32Array` Index case) so `g[i][j]` reads the f32 scalar.
// The index of an inner read clears `pendingF32` (an enclosing f32 context must not turn the
// integer index into an `f32.const`). At parity with f64[][]: read, multi-row, 3D, `.length`,
// f64-mixing, an `f32[][]` param, and a LOCAL nested for-in all work.

function s2(g: f32[][]): f32 {
  return g[0][0] + g[1][0]
}

const G: f32[][] = [[1.5, 2.5, 3.5]]

function go() {
  // global read + multi-row local.
  print(G[0][1]) // 2.5
  const xs: f32[][] = [[1.5], [2.5, 3.5]]
  print(xs[1][1]) // 3.5
  print(xs.length) // 2 (outer rows)
  print(G[0].length) // 3 (inner length)

  // 3D nesting.
  const cube: f32[][][] = [[[2.5]]]
  print(cube[0][0][0]) // 2.5

  // an f32 inner element mixed with a genuine f64 widens to f64.
  const y: f64 = 1.5
  print(xs[0][0] + y) // 1.5 + 1.5 → 3

  // an f32[][] param, inner-indexed.
  print(s2([[1.5], [6.0]])) // 1.5 + 6.0 → 7.5

  // a LOCAL nested for-in (the loop var binds the inner f32 list).
  for row in xs {
    for v in row {
      print(v) // 1.5 | 2.5, 3.5
    }
  }
}

go()
