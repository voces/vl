// @run
// @log 3.5
// @log 1
// @log 2.5
// An `f32[]`-valued map (`{[string]: f32[]}`) — the f32 sibling of the i64[]/f64[]-valued maps.
// `mvShapeOfValName` now classifies an `f32[]` value as a list (kind 6), `mvListValKind` maps the
// f32-inner ref-list element (kind 10) to the f32-list rep (21), the store seeds `pendingListKind`
// = 7 so a bare `[2.5]` builds an `f32[]` (not the f64 default), and `exprF32Array` recognizes the
// `m[k] ?? []` read. The float-literal array also adapts into the NULLABLE value slot (`f32[]?`)
// via the checker's array-literal element recursion peeling the nullable wrapper.

function go() {
  const m: {[string]: f32[]} = Map()
  m["a"] = [2.5, 3.5]
  m["b"] = [1.5]
  print((m["a"] ?? [])[1]) // 3.5
  print((m["b"] ?? []).length) // 1
  // overwrite a key, read back.
  m["a"] = [9.5, 2.5]
  print((m["a"] ?? [])[1]) // 2.5
}

go()
