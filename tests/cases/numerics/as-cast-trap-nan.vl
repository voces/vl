// @trap
// A float‚Üíint `as` cast uses the TRAPPING `trunc` family (deliberate ‚Äî VL's
// principle is "traps are for bugs"). Casting a NaN to an integer has no defined
// value, so `nan as i32` (`i32.trunc_f64_s`) aborts with a wasm trap; the trailing
// print never runs. NaN is produced at runtime as `0.0 / 0.0` (float division, not
// the integer divide-by-zero trap).
function ff64(x: f64): f64 { x }
const z: f64 = ff64(0.0)
const nan: f64 = z / z
print(nan as i32)
print(-1)
