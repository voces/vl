// @run
// @log 8000000000
// @log 2000000000
// @log 10000000000
// @log true
// @log 6.5
// @log 10
// @log 2
// @log true
// @log 3.5
// @log true
// i64 and f32 binary arithmetic (B2), plus newly-enabled float division and
// comparison. A literal operand coerces to the other side's numeric type
// (`a * 2` lowers `2` as i64; `x + 4.0` lowers `4.0` as f32).
let a: i64 = 5000000000
let b: i64 = 3000000000
print(a + b)
print(a - b)
print(a * 2)
print(a > b)
let x: f32 = 2.5
let y: f32 = 5.0
print(x + 4.0)
print(x * 4.0)
print(y / x)
print(x < y)
let p = 7.0
let q = 2.0
print(p / q)
print(p >= q)
