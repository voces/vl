// @run
// @log 2
// @log 1.5
// @log 2.5
// @log 3.5
// @log 3
// @log 11.5
// @log 2
// f32-list MUTATION — `.push` over an `f32[]`, the f32 sibling of the f64/i64 push frames.
// The emitter reserves a 4-slot f32 push quad (`fnUsesF32Push` / `f32PushScratchBase`: val f32
// / cap i32 / backing `$fa32TypeIdx` / recvRef `$fl32TypeIdx`) and `emitPush` coerces the
// pushed value to f32 (a float literal re-encodes). Covers push of a literal and of an f32 var,
// a grow past the initial capacity, and a module-GLOBAL push (driven by the start function).

const g: f32[] = []

function go() {
  const xs: f32[] = []
  xs.push(1.5)
  xs.push(2.5)
  print(xs.length) // 2

  // grow past the first capacity bump, then read each slot back.
  xs.push(3.5)
  print(xs[0]) // 1.5
  print(xs[1]) // 2.5
  print(xs[2]) // 3.5
  print(xs.length) // 3

  // push from an f32 VAR (not a literal) — the value coerces through the f32 slot.
  const a: f32 = 4.0
  xs.push(a)
  let t: f32 = 0.0
  for v in xs { t = t + v }
  print(t) // 1.5 + 2.5 + 3.5 + 4 = 11.5
}

go()

// a module-global f32 push (driven from the start function's push-detection).
g.push(9.5)
g.push(8.5)
print(g.length) // 2
