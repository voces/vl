// @check
// @error i32 doesn't fit in f32 — the conversion is lossy and must be made explicit
// LOSSY implicit widening is REJECTED at typecheck. i32→f32 looks like a widening
// (same total bit-width), but an f32 has only 24 bits of mantissa, so an i32 above
// 2^24 rounds to the nearest f32 — the value is NOT preserved. Only the lossless
// edges (i32→i64, i32→f64, f32→f64) coerce implicitly; this one needs an explicit
// conversion (no syntax for it yet). A runtime i32 VALUE (not a literal) triggers
// the rule — a literal would type-check by value.
function id(n: i32): i32 { n + 1 }
const a: i32 = id(1)
const x: f32 = a
print(x)
