// @run
// @log 2.5
// @log 4.5
// @log 1.5
// @log 7.5
// An f32 float-LITERAL inside an object-literal field of an ARRAY element now adapts to the
// struct's `f32` field — `const ps: P[] = [{ x: 2.5 }]` with `P = { x: f32 }`. The float literal
// re-encodes exactly at f32, so it fits, exactly as `const p: P = { x: 2.5 }` already did at a
// scalar binding. The fix generalizes the literal-aware assignability: `assignableExpr` now
// recurses element-wise into an array LITERAL (the array dual of its existing object-literal
// recursion), so a bare element adapts as it would at a binding — at any element type and any
// nesting depth. A non-literal f64 value element is still rejected (a lossy demote is not silent).

type P = { x: f32, y: f32 }

function go() {
  const ps: P[] = [{ x: 2.5, y: 4.5 }]
  print(ps[0].x) // 2.5
  print(ps[0].y) // 4.5

  // multiple elements, read across rows.
  const qs: P[] = [{ x: 1.5, y: 2.5 }, { x: 3.5, y: 7.5 }]
  print(qs[0].x) // 1.5
  print(qs[1].y) // 7.5
}

go()
