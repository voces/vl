// @run
// @log -1.5
// @log -2.5
// @log -3.5
// @log -4.5
// @log -1.5
// @log -3
// A NEGATIVE float literal (`-1.5`) flows into every f32 position, exactly like its positive
// twin. `-1.5` parses as `Unary "-"` over a float `NumLit`, so it is NOT a bare `NumLit` —
// the checker's `isFloatLitExpr` (the f32-admission exception) and the emitter's
// `emitExprAsF32` both peel the leading `-`. Negation is exact in IEEE-754, so the value
// re-encodes at single precision directly (`f32.const -1.5`, no `f32.neg`, no lossy f64
// round-trip). Was rejected as a lossy f64→f32 demote in every f32 slot.

type V = { x: f32 }

function go() {
  // scalar f32
  const a: f32 = -1.5
  print(a) // -1.5

  // f32-valued map
  const m: {[string]: f32} = Map()
  m["k"] = -2.5
  print(m["k"] ?? 0.0) // -2.5

  // f32 union atom
  const u: f32 | string = -3.5
  if u is f32 { print(u) } // -3.5

  // f32 struct field
  const v: V = { x: -4.5 }
  print(v.x) // -4.5

  // f32 array element (and a negated integer literal coerces too)
  const xs: f32[] = [-1.5, 2.0, -3.0]
  print(xs[0]) // -1.5
  print(xs[2]) // -3
}
go()
