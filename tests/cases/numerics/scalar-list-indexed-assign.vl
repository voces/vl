// @run
// @log 9.5
// @log 6
// @log 5000000000
// @log 7
// @log 3.5
// @log 8.5
// Indexed assignment `xs[i] = v` over the scalar non-i32 lists (`f64[]` / `i64[]` / `f32[]`) —
// the same unwrap-to-backing + `array.set` spine the i32 and string lists already used, with the
// stored value coerced to the element valtype. The dispatch gained `isF64`/`isI64`/`isF32` branches
// (selecting the fl64/fa64, il64/ia64, fl32/fa32 wrapper+backing) and the value emits via
// `emitExprAsF64`/`AsI64`/`AsF32`, so a bare-int / int-literal value widens into the slot. Was a
// loud "indexed assignment but list type not collected" (the value fell into the i32-list path).

const G: f64[] = [1.5]

function go() {
  const fs: f64[] = [1.5, 2.5]
  fs[0] = 9.5
  print(fs[0]) // 9.5

  // assign from an expression, in a loop.
  const ds: f64[] = [1.0, 2.0, 3.0]
  let i = 0
  while i < 3 {
    ds[i] = ds[i] * 2.0
    i = i + 1
  }
  print(ds[2]) // 3.0 * 2.0 → 6

  // i64: a big value, and a bare-int literal that widens.
  const ns: i64[] = [0, 0]
  ns[0] = 5000000000
  ns[1] = 7
  print(ns[0]) // 5000000000
  print(ns[1]) // 7 (the int literal widens to i64)

  // f32: assign a mixed expression (an f32 var + a float literal).
  const gs: f32[] = [1.5]
  const y: f32 = 2.0
  gs[0] = y + 1.5
  print(gs[0]) // 2.0 + 1.5 → 3.5
}

go()

// a module-GLOBAL f64 list indexed-assigned from the start function.
G[0] = 8.5
print(G[0]) // 8.5
