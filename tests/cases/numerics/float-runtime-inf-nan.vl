// @run
// @log true
// @log true
// @log 0
// @log false
// Overflowing LITERALS are a compile error, but runtime arithmetic keeps full
// IEEE-754 semantics: multiplying past the finite range yields ±infinity and
// 0.0/0.0 yields NaN (floats never trap). Asserted structurally — hosts render
// infinity/NaN spellings differently.
const big = .0
const inf = big * 10.0
print(inf > big)       // true — +infinity exceeds every finite double
print(0.0 - inf < 0.0 - big) // true — -infinity below every finite double
print(1.0 / inf)       // 0 — division by infinity
const nan = 0.0 / 0.0
print(nan == nan)      // false — NaN compares unequal to itself
