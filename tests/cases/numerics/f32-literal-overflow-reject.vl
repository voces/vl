// @check
// @error f64 doesn't fit in f32
// @error f64 doesn't fit in f32
// A float literal whose magnitude overflows f32 gets NO float-literal→f32
// grant (it does not re-encode exactly at f32 — it would encode ±infinity), so
// it takes the normal lossy-demote rejection at the flow site. The max-finite
// f32 literal still flows.
const a: f32 = 340282360000000000000000000000000000000.0
const b: f32 = -340282360000000000000000000000000000000.0
const c: f32 = 340282346638528860000000000000000000000.0
print(a)
print(b)
print(c > 0.0) // true — the largest finite f32 literal still compiles clean
