// @run
// @log 12
// @log -90
// An UNANNOTATED binding initialized from an i64 expression infers i64 — the
// host gives the local the initializer's width; the native emitter
// materializes an i32 local and produces invalid wasm (type mismatch:
// expected i32, found i64). Annotating the binding (`const m: i64 = n`)
// sidesteps it; `let` infers identically.
function tenth(n: i64): i64 {
  const m = n
  return m / 10
}
const v: i64 = 123
print(tenth(v))
const w: i64 = -900
print(tenth(w))
