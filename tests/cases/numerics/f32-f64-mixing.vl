// @run
// @log 4
// @log 4
// @log 1
// @log 1
// @log 9
// @log 4
// @log 4
// @log 4
// Mixing an f32 and a GENUINE f64 in one expression now computes in f64 (the f32 side widens),
// instead of emitting invalid wasm. The bug: `exprIsF32` claimed any op with an f32 operand was f32,
// and the f32 emit slice fired and tried to demote the f64 — but `f32var + f64var` is f64. A genuine
// (non-literal) f64 operand now makes the op f64 in both the classifier and the emit slice
// (`binMixHardF64`), while a float LITERAL still adapts DOWN to an f32 operand (`f32 + 1.0` stays
// f32). Covers arithmetic in both orders, comparisons, a chain, nesting, a return, and an argument.
function retMix(): f64 {
  const a: f32 = 2.5
  const b: f64 = 1.5
  return a + b // 2.5 + 1.5 → 4
}

function takeF64(v: f64): f64 { return v }

function go() {
  const x: f32 = 3.0
  const y: f64 = 1.0

  print(x + y) // f32 + f64 → 4
  print(y + x) // f64 + f32 → 4

  // comparisons compare as f64.
  if x < y {
    print(0) // 3 < 1 false → 1
  } else {
    print(1)
  }
  if y < x {
    print(1) // 1 < 3 true → 1
  } else {
    print(0)
  }

  // a longer chain with f32 on both ends, computed in f64.
  print(x * y * x) // 3 * 1 * 3 → 9

  // nesting: an inner all-f32 sub-expression widens when added to an f64.
  const a: f32 = 1.0
  const b: f32 = 2.0
  print((a + b) + y) // (1 + 2) + 1 → 4

  // a return that mixes, and a mixed argument into an f64 parameter.
  print(retMix()) // 4
  print(takeF64(x + y)) // 4
}

go()
