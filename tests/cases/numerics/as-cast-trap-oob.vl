// @trap
// A floatâ†’int `as` cast TRAPS when the value is out of the integer's range (the
// trapping `trunc` family, not a saturating clamp). 1e27 is far beyond i32's
// ~2.1e9 max, so `huge as i32` (`i32.trunc_f64_s`) aborts; the trailing print never
// runs. The out-of-range value is built at runtime (a passthrough call defeats
// constant folding).
function ff64(x: f64): f64 { x }
const big: f64 = ff64(1000000000.0)
const huge: f64 = big * big * big
print(huge as i32)
print(-1)
