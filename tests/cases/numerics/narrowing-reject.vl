// @check
// @error f64 doesn't fit in i32 — the conversion is lossy and must be made explicit
// LOSSY numeric narrowing is REJECTED at typecheck — never silently truncated,
// never reaching codegen (no crash). A runtime `f64` value flowing into an
// `i32`-annotated binding would drop the fractional part, so it requires an
// explicit conversion (the explicit-cast syntax is future B2 work).
function asF64(x: f64): f64 { x + 0.5 }
const a: f64 = asF64(1)
const b: i32 = a
print(b)
