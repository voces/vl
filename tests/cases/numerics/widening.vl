// @run
// @log 1.25
// @log 1.5
// @log 1000001
// @log 3
// @log 3.5
// @log -99
// Numeric widening (B2): a NON-literal numeric value implicitly coerces to a
// same-or-wider numeric slot at every value boundary — binding, argument, return,
// operand — with codegen inserting the matching wasm convert. Only the LOSSLESS
// edges are permitted: i32→i64, i32→f64, f32→f64 (each preserves the value
// exactly). The lossy widenings i32→f32 (>2^24) and i64→f64 (>2^53) are rejected
// and need an explicit conversion (no syntax for it yet — see the *-reject.vl
// conformance cases). Every value below stays exact, so each prints back unchanged.

// i32 variable into an f64-annotated binding (`i32` → `f64`).
const a = 1
const b: f64 = a
print(b + 0.25)

// i32 variable into an f64 parameter (the call-argument boundary).
function asF64(thing: f64): f64 { thing + 0.5 }
print(asF64(a))

// i32 → i64 keeps a value, then arithmetic in the wider type.
const big = 1000000
const big64: i64 = big
print(big64 + 1)

// f32 → f64 promotion through a return value.
function asF64FromF32(x: f32): f64 { return x }
const small: f32 = 2.5
print(asF64FromF32(small) + 0.5)

// Mixed-operand arithmetic widens the narrower operand (`f64 + i32`).
function mixed(p: f64, q: i32): f64 { p + q }
print(mixed(1.5, 2))

// A negative i32 widens with sign preserved (signed conversion, i32 → f64).
function negate(n: i32): i32 { n - 100 }
const neg: f64 = negate(1)
print(neg)
