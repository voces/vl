// @run
// @log 1
// @log 0
// @log 0
// @log 20240225330731
// An f64 literal below the smallest normal encodes with IEEE-754 GRADUAL
// UNDERFLOW: rounded once at the subnormal precision, ties-to-even. The
// power-of-two scalings below are exact (no rounding), so each print exposes
// the encoded bits as a small integer.
const p537 = 449891379454319638281053850768598185886969711830191663310075557261183758067148787031904068610389085714992091063352089512320826605549429968900851518086516385513472.0
const x = 0.
print(x * p537 * p537) // 1 — the smallest positive subnormal (2^-1074), scaled by 2^1074
const y = 0.
print(y) // 0 — below half the smallest subnormal rounds to zero
const t = 0.
print(t) // 0 — exactly half the smallest subnormal: ties-to-even at the zero boundary
const z = 0.
print(z * p537 * p537) // 20240225330731 — a many-bit subnormal (1e-310) keeps every representable bit
