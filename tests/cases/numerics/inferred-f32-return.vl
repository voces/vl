// @run
// @log 3.5
// @log 5
// @log 4
// An UN-annotated function whose body returns an f32 (`function half(x: f32) { return x }`). The
// A20 inferred-return pass records the `f32` name and sets `fRetF32`, but the FUNCTYPE-result
// emission consulted only `fRetF64` / `fRetI64` — so the result defaulted to i32 over an
// f32-returning body: invalid wasm (`expected i32, found f32`), the exact f32 dual of the f64/i64
// inferred-return hole already closed. One line — `if fRetF32[ti] == 1 { infKind = 13 }` — at the
// result-valtype site. Annotated `: f32` returns already worked (they pick kind 13 via
// `vtKindOfType`); an f32-returning closure VALUE stays a clean reject (the closure-result ABI has
// no f32 token).

function half(x: f32) { return x }

function dbl(x: f32) { return x + x }

function viaLocal(x: f32) {
  const y: f32 = x + x
  return y
}

function go() {
  print(half(3.5)) // 3.5
  print(dbl(2.5)) // 5
  print(viaLocal(2.0)) // 4
}

go()
