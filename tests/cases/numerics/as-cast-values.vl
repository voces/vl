// @run
// @log 100
// @log 100
// @log 100
// @log 100
// @log 410065408
// @log 9000000000
// @log 100
// @log 9000000000
// @log 3
// @log 3
// @log 3.5
// @log 3.5
// @log -2
// @log 7
// @log 7
// @log 7.9
// @log 2.5
// @log -8
// Explicit numeric casts `x as T` (B2) — the full 4×4 scalar conversion matrix over
// RUNTIME values (a passthrough call, so the checker cannot fold it to a literal).
// `as` permits EVERY numeric direction: the lossless widenings the implicit rule
// already takes, PLUS the lossy widenings (i32→f32, i64→f32/f64), the narrowings
// (i64→i32 wrap, f64→f32 demote) and int↔float conversions. Float→int TRUNCATES
// toward zero (the trapping `trunc` family — NaN/out-of-range abort, tested
// separately in as-cast-trap-*.vl). Same-type is a no-op.
function fi32(n: i32): i32 { n }
function fi64(n: i64): i64 { n }
function ff32(x: f32): f32 { x }
function ff64(x: f64): f64 { x }

// i32 → {i32 no-op, i64, f32, f64}
const a: i32 = fi32(100)
print(a as i32)
print(a as i64)
print(a as f32)
print(a as f64)

// i64 → {i32 WRAP, i64 no-op, f32, f64}. `big` exceeds 2^31, so the wrap drops the
// high bits: 9000000000 mod 2^32 = 410065408.
const big: i64 = fi64(9000000000)
print(big as i32)
print(big as i64)
const smallBig: i64 = fi64(100)
print(smallBig as f32)
print(big as f64)

// f32 → {i32 trunc, i64 trunc, f32 no-op, f64 promote}, and a negative trunc.
const pf: f32 = ff32(3.5)
print(pf as i32)
print(pf as i64)
print(pf as f32)
print(pf as f64)
const nf: f32 = ff32(-2.9)
print(nf as i32) // truncation is toward zero: -2, not -3

// f64 → {i32 trunc, i64 trunc, f64 no-op, f32 DEMOTE}, and a negative trunc.
const pd: f64 = ff64(7.9)
print(pd as i32)
print(pd as i64)
print(pd as f64)
const dd: f64 = ff64(2.5)
print(dd as f32)
const nd: f64 = ff64(-8.5)
print(nd as i64) // toward zero: -8
