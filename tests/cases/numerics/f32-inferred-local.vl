// @run
// @log 1.5
// @log 1.5
// @log 0.5
// @log 3.5
// @log 3
// @log 3.5
// An UN-ANNOTATED local initialized from an f32 SOURCE infers an f32 slot (`const y = s.x`,
// not `const y: f32 = s.x`). f32 is the checker's weak spot — it emits no f32 typed-IR, so
// `letIsF32` is annotation-only; without the init fallback `letInfersF32` (the f32 dual of
// the inference `i64`/`f64` locals already do) the binding defaulted to an i32 slot and
// stored an f32 into it → invalid wasm ("expected i32, found f32"). Covers the f32 sources:
// a struct field read, an `f32[]` index, an f32-returning call, and f32 arithmetic — and the
// inferred local then participates in further f32 ops / re-binds as a kind-13 f32 local.

type V = { x: f32, y: f32 }

function half(): f32 { return 0.5 }

function go() {
  const v: V = { x: 1.5, y: 2.0 }

  // inferred from a struct field read
  const a = v.x
  print(a) // 1.5

  // inferred from an f32[] index read
  const xs: f32[] = [1.5, 2.5]
  const i0 = xs[0]
  print(i0) // 1.5

  // inferred from an f32-returning call
  const h = half()
  print(h) // 0.5

  // inferred from f32 arithmetic, then used + re-bound (all stay f32)
  const b = v.y
  const s = a + b
  print(s)     // 3.5
  print(a * b) // 1.5 * 2.0 = 3
  const c = s
  print(c)     // 3.5
}
go()
