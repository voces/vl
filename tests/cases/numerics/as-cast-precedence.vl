// @run
// @log 3
// @log 3
// @log 1
// @log 2.5
// @log -2
// @log 10.5
// Precedence + parsing of the `x as T` cast (B2). `as` binds TIGHTER than every
// binary operator, so `a + b as f64` groups as `a + (b as f64)`; explicit parens
// force the other grouping. A prefix `-` binds LOOSER than `as` (`-b as i64` is
// `-(b as i64)`). Casts are CHAINABLE and usable directly in a call argument.
function fi32(n: i32): i32 { n }
function takeF64(x: f64): f64 { x + 0.5 }
const a: i32 = fi32(1)
const b: i32 = fi32(2)

print(a + b as f64)   // a + (b as f64) = 1 + 2.0 = 3
print((a + b) as f64) // (1 + 2) as f64 = 3
print(a as i64 as f64) // chained: i32 → i64 → f64 = 1
print(takeF64(b as f64)) // cast in a call argument: takeF64(2.0) = 2.5
print(-b as i64)      // -(b as i64) = -2
const c: i32 = fi32(10)
print(c as f64 + 0.5) // (c as f64) + 0.5 = 10.5
