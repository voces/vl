// @run
// @log 2
// @log -7
// An i32 VARIABLE argument widens into an i64 parameter — the same permitted
// value-preserving edge as an annotated let (`let w: i64 = n`), applied at
// the call site. The host inserts the extension; the native emitter passes
// the operand unextended and produces invalid wasm (type mismatch: expected
// i64, found i32). Literal arguments are unaffected (they lower at the
// parameter's width); declaration-site widening is unaffected.
function low(d: i64): i64 {
  return d % 10
}
const small: i32 = 42
print(low(small))
const neg: i32 = -7
print(low(neg))
