// @log 5
// List-of-list global FIRST, struct-list global SECOND — the mirror ordering of
// two-reflist-globals.vl, so whichever element type interns as slot 0 the OTHER
// global still declares its own wrapper type.
const grid = [[4, 8], [1, 2]]
const pts = [{ x: 9, y: 5 }]

print(grid[0][0])
print(grid[1][1])
print(pts[0].x)
print(pts[0].y)
