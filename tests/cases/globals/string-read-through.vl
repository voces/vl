// @run
// @log hello
// A *reference-typed* (string) module global read through a function: the
// binding lowers to a shared wasm global holding a (nullable) ref, and the
// function reads it via `global.get` + `ref.as_non_null` — seeing the
// initialized value, not a stale captured copy. (The self-hosted compiler's
// "current source string" idiom: module state a helper reads.)
let cur = "hello"
function read(): string {
  return cur
}
print(read())
