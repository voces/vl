// @run
// @log 0
// @log 3
// @log 7
// Mutating a *field* of a global object through a function: the binding holds a
// shared reference, so `struct.set` from inside a function updates the heap the
// caller sees. (The compiler's interning-table idiom: a module-level record
// whose fields are bumped from helpers.)
const state = { count: 0, mark: 0 }
function bump() {
  state.count = state.count + 1
}
function setMark(v: i32) {
  state.mark = v
}
print(state.count)
bump()
bump()
bump()
setMark(7)
print(state.count)
print(state.mark)
