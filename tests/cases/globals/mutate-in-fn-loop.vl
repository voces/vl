// @run
// @log 0
// @log 10
// A function loops internally, writing through to a module global each
// iteration. (A trailing `print` keeps the loop off the function's tail
// position, which is an unrelated known limitation.)
let sum = 0
function accumulate(upto: i32) {
  let i = 1
  while i <= upto {
    sum = sum + i
    i = i + 1
  }
  print(sum)
}
print(sum)
accumulate(4)
