// @run
// @log -2
// @log 2
// @log -2
// @log 3
// @log 6000000000
// @log -6000000000
// @log -1.5
// @log 2.5
// @log 7000000000
// @log -3.5
// A module GLOBAL whose type is a scalar `i64[]` / `f32[]` list. Its cell valtype is the
// scalar-list wrapper (`il64TypeIdx` / `fl32TypeIdx`); a small-magnitude element (`-2`)
// is an i32-typed literal widened at the store, a large one (`6000000000`) is a genuine
// i64. A NEGATIVE element is `-x` (a unary), which is not a constexpr — so such a global
// routes through the synthetic start function, where the cell must still type as the
// scalar-list ref (the nullable-cell / ref-null paths carry the i64-list and f32-list
// arms, not a bare-i32 fallthrough). Both `const` and `let` module globals, annotated and
// inferred from an i64 literal.
const cs: i64[] = [-2]
const cl: i64[] = [2]
let ms: i64[] = [-2, 3]
// Un-annotated i64-literal globals infer the i64-list cell from the initializer.
const inferred = [6000000000]
const inferredNeg = [-6000000000]
// f32-list globals — the negative element makes the init non-const like the i64 case.
const fs: f32[] = [-1.5]
let fl: f32[] = [2.5]

function go() {
  print(cs[0])
  print(cl[0])
  print(ms[0])
  print(ms[1])
  print(inferred[0])
  print(inferredNeg[0])
  print(fs[0])
  print(fl[0])
  // The mutable `let` cells accept a fresh scalar-list value.
  ms = [7000000000]
  fl = [-3.5]
  print(ms[0])
  print(fl[0])
}
go()
