// @run
// @log 0
// @log 2
// The `++` / `--` operators on a module global, applied from inside a function,
// mutate the shared cell (the position-advance idiom: `advance()` bumps `pos`).
let pos = 0
function advance() {
  pos++
}
function retreat() {
  pos--
}
print(pos)
advance()
advance()
advance()
retreat()
print(pos)
