// @run
// @log 7
// @log 3
// @log 2
// Two un-annotated ref-list `const` globals of DISTINCT element types in one module:
// each global's declared cell valtype must select ITS OWN element wrapper (inferred
// from the initializer), not the first ref-list slot's.
const os = [{ v: 7 }]
const g = [[1, 2], [3, 4]]

print(os[0].v)
print(g[1][0])
print(g.length)
