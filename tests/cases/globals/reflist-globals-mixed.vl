// A string-list global BETWEEN two ref-list globals of distinct element types, plus a
// third distinct struct element type — every ref-list global cell must carry its own
// element wrapper, with the string-list family interleaved in declaration order.
const names = ["a", "b"]
const boxes = [{ w: 11 }]
const rows = [[6, 7]]
const tags = [{ id: 3, label: "ok" }]

print(names[1])
print(boxes[0].w)
print(rows[0][0])
print(tags[0].id)
print(tags[0].label)
