// @run
// @log 7
// @log 100
// Read-through: a function reads the *current* value of a module global (set
// after the function was declared), not a snapshot captured at any earlier
// point. Mutating from module scope is then seen by the function too.
let base = 7
function show() {
  print(base)
}
show()
base = 100
show()
