// @run
// @log 0
// @log 10
// @log 10
// One function mutates a module global; a *different* function reads it back —
// both must share the one wasm global, not private copies.
let total = 0
function add(n: i32) {
  total = total + n
}
function current(): i32 {
  return total
}
print(total)
add(4)
add(6)
print(current())
print(total)
