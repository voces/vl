// @run
// @log NULL
// @log hi
// @log hi
// @log dflt
// @log hi
// A `string | null` module GLOBAL whose value is ACTUALLY null. The cell is always a
// nullable ref (kind 16), and a VALUE read normally recovers non-null with
// `ref.as_non_null` — but a read flowing into a NULLABLE-string TARGET
// (`pendingNulString`: `const t = g` binding `string | null`, a `string | null`
// arg/return) must keep the raw nullable ref, exactly like the param/local read path:
// the eager recover trapped (`null reference`) on `const t0 = g` when `g` held null
// (fuzz-nightly run 29801667445, seed 796537820 d5 — `TRAP p3r string | null`).
const g: string | null = null
const h: string | null = "hi"

function go() {
  const t0 = g
  if (t0 != null) { print(t0) } else { print("NULL") }
  const t1 = h
  if (t1 != null) { print(t1) } else { print("NULL") }
  // A narrowed value read still recovers non-null (the cast is correct here).
  if (h != null) { print(h) }
  // The `??` default read keeps the raw ref on the null-check side.
  print(g ?? "dflt")
  print(h ?? "dflt")
}
go()
