// @run
// @log a
// @log b
// A string module global reassigned in one function and read in another: both
// share the one wasm global cell, so the reassignment (`global.set`) in `setit`
// is visible to `read` (`global.get`), not lost to a private captured copy.
// This is the ref counterpart of the scalar `cross-function` test — the
// bootstrap motivation, where module-level string state (accumulators, the
// current token text) is mutated by helpers.
let cur = "a"
function setit() {
  cur = "b"
}
function read() {
  return cur
}
print(read())
setit()
print(read())
