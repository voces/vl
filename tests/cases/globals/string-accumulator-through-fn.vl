// @run
// @log abc
// A string module global used as an accumulator: a helper reassigns it to a
// value *derived from the global itself* (`acc = acc + s`), so each call reads
// the shared cell (`global.get`) and writes the new string back
// (`global.set`). The caller and every helper see the running result — the
// self-hosted compiler's output-buffer / interning-string idiom.
let acc = ""
function emit(s: string) {
  acc = acc + s
}
function out() {
  return acc
}
emit("a")
emit("b")
emit("c")
print(out())
