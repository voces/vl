// @run
// @log 0
// @log 15
// A module global mutated through a function that is called repeatedly from a
// loop: each call writes through to the shared global, so the accumulated total
// is what the caller sees (the interning-counter idiom).
let sum = 0
function add(n: i32) {
  sum = sum + n
}
print(sum)
for i in 1 to 5 {
  add(i)
}
print(sum)
