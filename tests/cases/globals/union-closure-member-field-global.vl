// @run
// @log other
// @log 0
// A GLOBAL whose struct field is a UNION carrying a CLOSURE member
// (`{f: (() => i32) | string}`) — the field's arrow is NESTED in parens, so the field
// classifier must not claim it as a bare closure (code 14): the depth-aware arrow test
// (`annArrowAt`) leaves it to the union/box classification. Previously the substring
// `=>` test coded the field as a closure fat-pointer while the initializer built a
// different ref — the emitted MODULE failed to parse (the rep-fuzz composite-global
// finding `{a, f: (() => {[string]: i64}) | string, z}`).
const g: {f: (() => i32) | string} = {f: "other"}
const g3: {a: boolean, f: (() => i32) | string, z: i32} = {a: true, f: "other", z: 11}

function go() {
  const t = g.f
  if t is string { print(t) } else { print("fn") }
  print(g3.z - 11)
}
go()
