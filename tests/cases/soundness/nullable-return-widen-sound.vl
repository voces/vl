// @run
// @log 7
// @log -1
// CONTRACT (must-not-error): a function declared to return `T | null` can return
// either a concrete `T` value (widened to nullable at the return boundary) or
// `null` directly. The caller narrows the result with a null guard before use.
// Pins the nullable return widening contract end-to-end.
function maybe(n: i32): { x: i32 } | null {
  if n > 0 { return { x: n } }   // struct widened to struct | null
  return null
}
const a = maybe(7)
if a != null { print(a.x) }   // 7
const b = maybe(0)
print(b?.x ?? -1)              // -1 (b is null → default)
