// @check
// @error expected 0 | 1, got
// CONTRACT (must-error): passing a NEGATED value to an intersection-type parameter
// is rejected — `(0 | 1 | 2) & !2` excludes `2` from the accepted set, so
// calling with `2` is a type error. Mirrors the must-not-error case
// (intersection-param-sound.vl) to confirm both sides of the contract.
function nonTwo(n: (0 | 1 | 2) & !2): i32 {
  if n == 0 { return 0 }
  return 1
}
print(nonTwo(2))   // UNSOUND: 2 is excluded by !2
