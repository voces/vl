// @run
// @log 1
// @log -1
// A flat `if v is A {} else if v is B {} else {}` chain over a union that
// includes `null` (`A | B | null`) discriminates correctly — the `null` value
// falls through to the `else`. Narrowing changes a value's static type but NOT
// its runtime representation: inside the `is B` arm `v` has narrowed to
// `B | null`, but it is still the boxed `{tag, anyref}` union it was passed as,
// so `is` reads the box's tag rather than re-deriving a niche null layout from
// the narrowed type (which traps on the boxed struct).
// (Regression: previously trapped "illegal cast" on null input. See
// docs/soundness-findings.md, struct-union-null-is-chain RESOLVED.)
type A = { kind: i32, x: i32 }
type B = { kind: i32, y: i32 }

function read(v: A | B | null): i32 {
  if v is A { return v.x }
  else if v is B { return v.y }
  else { return -1 }
}
print(read({ kind: 0, x: 1 }))
print(read(null))
