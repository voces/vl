// @run
// @log 42
// @log 7
// @log 9
// @log 0
// @log 1
// @log 2
// CONTRACT (must-not-error, SOUNDNESS): the AST-node pattern — an `is`-chain
// dispatch over a 3+-member struct union, the idiom a self-hosted parser needs.
// Each variant has a distinct shape and a distinct runtime tag, so every `is`
// arm selects the correct variant and reads its own field. A shared `kind` field
// (present on all three, at differing struct indices) is also readable directly.
type NumLit = { kind: i32, value: i32 }
type BinExpr = { kind: i32, op: i32 }
type Call = { kind: i32, fn: i32, argc: i32 }

function eval(n: NumLit | BinExpr | Call): i32 {
  if n is NumLit { return n.value }
  else if n is BinExpr { return n.op }
  else { return n.argc }
}
print(eval({ kind: 0, value: 42 }))     // 42  (NumLit)
print(eval({ kind: 1, op: 7 }))          // 7   (BinExpr)
print(eval({ kind: 2, fn: 3, argc: 9 })) // 9   (Call)

// The shared `kind` tag is readable on the union without narrowing — and `Call`
// sorts its fields {argc, fn, kind}, so `kind` is index 2 there, vs index 0 in
// NumLit/BinExpr; the tag dispatch reads each from the right slot.
function kindOf(n: NumLit | BinExpr | Call): i32 {
  return n.kind
}
print(kindOf({ kind: 0, value: 42 }))     // 0
print(kindOf({ kind: 1, op: 7 }))          // 1
print(kindOf({ kind: 2, fn: 3, argc: 9 })) // 2
