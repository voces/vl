// @check
// @error argument 1: expected {x: i32, y: i32}, got {x: i32, y: string}
// CONTRACT (must-error): STRUCTURAL DEPTH — a field that has the right NAME but
// the wrong VALUE TYPE is rejected. Width subtyping accepts extra fields, but it
// does not loosen field types — a string in a field declared as i32 is a type
// error at depth. This pins that structural assignability checks field values,
// not just field presence.
function f(p: { x: i32, y: i32 }): i32 { return p.x + p.y }
print(f({ x: 1, y: "hello" }))  // UNSOUND: y expects i32, not string
