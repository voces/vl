// @run
// @log 5
// @log 7
// @log true
// The must-not-error twin of union-unknown-member-reject: union annotations
// whose members ALL resolve still accept members, narrow, and run.
const a: string | i32 = 5
if a is i32 { print(a) }
const c: i32 | null = null
print(c ?? 7)
type Pet = { name: string }
const p: Pet | null = { name: "rex" }
print(p != null)
