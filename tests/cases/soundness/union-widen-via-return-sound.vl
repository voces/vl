// @run
// @log 5
// @log hello
// CONTRACT (must-not-error): a function declared to return `string | i32` can
// return either a bare `i32` or a bare `string` — each is widened to the union
// at the return boundary. The caller receives a proper union value that can be
// discriminated with `is`. Pins that widening at RETURN is sound, not just at
// assignment.
function wrap(n: i32): string | i32 {
  if n > 0 { return n }      // i32 widened to string | i32
  return "hello"             // string widened to string | i32
}
const a = wrap(5)
if a is i32 { print(a) }    // 5
const b = wrap(0)
if b is string { print(b) } // hello
