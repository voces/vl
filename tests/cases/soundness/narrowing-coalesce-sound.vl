// @run
// @log 5
// @log -1
// CONTRACT (must-not-error): `x ?? d` produces a non-null value — `x` when it is
// present, the default `d` otherwise — so the result type is the non-null base
// and feeds an `i32` slot directly. The `??` lowering is the value-level dual of
// a null guard: it never lets a `null` reach the consumer.
function f(x: i32 | null): i32 {
  return x ?? -1
}
print(f(5))                      // 5    (present)
print(f(null))                   // -1   (defaulted)
