// @check
// @error argument 1: expected string, got i32
// @error argument 2: expected string, got i32
// A generic (un-annotated-param) function value assigned to a CONCRETE function-typed binding is
// PINNED to that type — the binding's annotation, not the function's holes, governs its calls. So
// `const c: (string, string) => string = add` accepts the generic `add` (its hole params/return
// unify with the concrete type), but a call that disagrees with the annotation is rejected. This
// guards that opening generic-function-value assignability (a hole return is assignable to any
// concrete return) did not also let the binding be called off its declared type — the concrete
// annotation is the contract the call site is checked against.
function add(a, b) a + b

const c: (string, string) => string = add

print(c(3, 4)) // REJECTED: c is pinned to (string, string) — an i32 argument doesn't fit
