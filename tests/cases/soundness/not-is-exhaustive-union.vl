// @run
// @log num
// @log str
// @log bool
// CONTRACT (must-not-error): `!is`-narrowing is the complement of `is`, so a
// chain of `!is` guards can discriminate a union just as an `is` chain does. Here
// each arm uses `!is` to peel one variant, leaving the complement in the
// then-branch where it is used. The final `else` holds the last remaining type.
// This pins that the complement algebra works symmetrically to the is-algebra.
function tag(x: i32 | string | boolean): string {
  if x !is i32 {
    if x !is string { return "bool" }  // then: complement of string = boolean
    return "str"                        // else falls through: x is string
  }
  return "num"                          // else: x is i32
}
print(tag(5))      // num
print(tag("hi"))   // str
print(tag(true))   // bool
