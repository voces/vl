// @run
// @log 10
// @log 20
// @log 30
// @log 40
// CONTRACT (must-not-error, SOUNDNESS): `is`-dispatch over a FOUR-member struct
// union. Each variant has a distinct structural shape (different field name
// beyond the shared `tag`), so the tag-per-shape discrimination gives each a
// unique runtime tag. The final `else` holds the last remaining type soundly —
// no spurious `| null` in the fall-through. Extends the 3-member
// `is-struct-union-dispatch.vl` to confirm the algebra scales.
type S1 = { tag: i32, a: i32 }
type S2 = { tag: i32, b: i32 }
type S3 = { tag: i32, c: i32 }
type S4 = { tag: i32, d: i32 }

function pick(v: S1 | S2 | S3 | S4): i32 {
  if v is S1 { return v.a }
  else if v is S2 { return v.b }
  else if v is S3 { return v.c }
  else { return v.d }
}
print(pick({ tag: 1, a: 10 }))  // 10
print(pick({ tag: 2, b: 20 }))  // 20
print(pick({ tag: 3, c: 30 }))  // 30
print(pick({ tag: 4, d: 40 }))  // 40
