// @run
// @log zero
// @log one
// @log two
// CONTRACT (must-not-error): an `if/else if/else` chain that covers every member
// of a closed numeric-literal union is EXHAUSTIVE — the fall-through carries no
// spurious `| null`, so the function returns a non-null `string` and needs no
// dummy trailing value. The mirror of exhaustive-missing-literal-case.vl (which
// errors because a member is dropped): a covering chain is sound, a partial one
// stays nullable.
function name(c: 0 | 1 | 2): string {
  if c == 0 { return "zero" }
  else if c == 1 { return "one" }
  else { return "two" }
}
print(name(0))                   // zero
print(name(1))                   // one
print(name(2))                   // two
