// @run
// @log 1
// @log 2
// @log 3
// CONTRACT (must-not-error, SOUNDNESS — P0-1, array-element half): a union-typed
// element read out of an array (`arr[i]`, where `arr: (A|B|C)[]`) and then
// `is`-narrowed reads the narrowed variant's field. Pins the ArrayLiteral boxing
// fix in isolation (single narrower): a `[{a:1}, …]` literal infers a bare
// variant element, but the slot of an `(A|B|C)[]` holds the boxed `{tag,value}`
// union; the literal's elements must be boxed into that rep so a later `arr[i]`
// read — and any narrowing of it — sees the box, not a raw variant struct.
// Pre-fix this produced a WasmGC `struct.get`/`ref.cast` type mismatch.
type A = { k: i32, a: i32 }
type B = { k: i32, b: i32 }
type C = { k: i32, c: i32 }
type N = A | B | C

function readAt(arena: N[], ix: i32): i32 {
  const n = arena[ix]
  if n is A { return n.a }
  else if n is B { return n.b }
  else { return n.c }
}

const arena: N[] = [
  { k: 0, a: 1 },
  { k: 1, b: 2 },
  { k: 2, c: 3 }
]
print(readAt(arena, 0))  // 1  (A.a)
print(readAt(arena, 1))  // 2  (B.b)
print(readAt(arena, 2))  // 3  (C.c)
