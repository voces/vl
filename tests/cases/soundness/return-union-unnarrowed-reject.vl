// @check
// @error i32 | string
// CONTRACT (must-error): using a union-return value AS an i32 WITHOUT narrowing
// is unsound — the function may return either variant. The caller must `is`-narrow
// before passing to an i32-typed context. This is the counterpart of
// return-union-narrowed-at-call-site.vl: narrowed is sound, unnarrowed is rejected.
function make(n: i32): i32 | string {
  if n > 0 { return n }
  return "hello"
}
const a: i32 = make(42)  // UNSOUND: may return a string
