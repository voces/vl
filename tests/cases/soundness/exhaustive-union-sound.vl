// @run
// @log num
// @log str
// @log bool
// CONTRACT: an `is` chain that covers EVERY variant of the union is exhaustive —
// the fall-through type carries no spurious `| null`, so the function returns a
// non-null type with no dummy `else`. Sound because every input takes a branch.
function classify(x: i32 | string | boolean): string {
  if x is i32 { return "num" }
  else if x is string { return "str" }
  else if x is boolean { return "bool" }
}
print(classify(5))               // num
print(classify("hi"))            // str
print(classify(true))            // bool
