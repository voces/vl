// @check
// @error expected {x: i32, y: i32}, got {x:
// CONTRACT (must-error): a struct literal that is MISSING a required field cannot
// satisfy the target type. Width subtyping allows EXTRA fields, but not MISSING
// fields — every field declared in the target type must be present in the value.
// An `{ x: i32 }` value cannot satisfy `{ x: i32, y: i32 }` because `y` is absent.
function f(p: { x: i32, y: i32 }): i32 { return p.x + p.y }
print(f({ x: 1 }))   // UNSOUND: y is missing
