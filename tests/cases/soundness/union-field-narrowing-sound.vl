// @run
// @log 10
// @log 0
// @log hello
// CONTRACT (must-not-error): narrowing a UNION-TYPED FIELD of a struct — `o.v is
// T` — refines the field path in the then-branch, making the narrowed field
// readable as `T` directly. This is the discriminated-record pattern where the
// union lives in a field, not at the top level. The else-branch sees the
// complement, and a non-matching branch returns a default.
function extract(o: { v: i32 | string }): i32 {
  if o.v is i32 { return o.v }
  return 0
}
print(extract({ v: 10 }))      // 10  (then: o.v is i32)
print(extract({ v: "hello" })) // 0   (else: o.v is string, fallback)

// Complement in else reads the string variant.
function show(o: { v: i32 | string }): string {
  if o.v is string { return o.v }
  return "0"
}
print(show({ v: "hello" }))    // hello  (then: o.v is string)
