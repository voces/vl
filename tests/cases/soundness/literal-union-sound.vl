// @run
// @log 1
// @log 2
// @log 30
// CONTRACT: a literal union (`"a" | "b"`, `0 | 1 | 2`) is its base scalar for
// `==`/`!=` discrimination, and only its listed members are assignable. Valid
// members flow through and discriminate correctly at runtime.
function kind(s: "expense" | "reimbursement"): i32 {
  if s == "expense" { return 1 }
  return 2
}
print(kind("expense"))           // 1
print(kind("reimbursement"))     // 2

function score(x: 0 | 1 | 2): i32 {
  if x == 0 { return 10 }
  else if x == 1 { return 20 }
  return 30
}
print(score(2))                  // 30
