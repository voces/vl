// @check
// @error "a" | "b"
// CONTRACT (must-error): even the comparison must stay inside the set —
// `s == "c"` against a `"a" | "b"` place can never be true, so it is rejected
// rather than silently always-false. Discrimination is total over the union.
function k(s: "a" | "b"): i32 {
  if s == "c" { return 1 }
  return 2
}
