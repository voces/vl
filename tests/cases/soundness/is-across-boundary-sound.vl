// @run
// @log int
// @log str
// CONTRACT (must-not-error): a union value keeps its variant identity as it
// crosses a function boundary. `relay` passes its `string | i32` straight to
// `tag`, which discriminates with `is i32`. Because tags are interned globally
// (not per-union) and `coerceUnion` re-boxes at the call boundary into the same
// representation, the `is` in the callee reads the right variant — discrimination
// is sound through the boundary, not just at the original construction site.
function tag(x: string | i32): string {
  if x is i32 { return "int" }
  return "str"
}
function relay(v: string | i32): string {
  return tag(v)
}
print(relay(7))                  // int
print(relay("hi"))               // str
