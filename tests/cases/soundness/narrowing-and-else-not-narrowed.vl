// @check
// @error expected {v: any}, got {v: i32} | null
// CONTRACT (must-error): `if a != null && b != null { … }` narrows BOTH places in
// the then-branch, but the ELSE/fall-through is the De Morgan complement
// `a == null || b == null` — which proves NEITHER place non-null on its own (the
// failing conjunct could be `a` OR `b`). So `a.v` after the guard is unsound: `a`
// may still be null. Contrast nullable-access-guarded.vl, where the field IS read
// inside the then-branch.
function f(a: { v: i32 } | null, b: { v: i32 } | null): i32 {
  if a != null && b != null { return a.v + b.v }
  return a.v                     // UNSOUND: a is not proven non-null here
}
