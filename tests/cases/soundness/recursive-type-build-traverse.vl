// @run
// @log 1
// @log 3
// CONTRACT (must-not-error): a self-referential `type` (a linked list via a
// nullable `next` field) constructs and traverses soundly. The recursive field
// `next: Node | null` is narrowed with a null guard on each step, so the walk
// recurses only into a present `next` and stops when it is `null`. Pins the A11
// contract for a list-shaped (single-self-reference) recursive type, distinct
// from the binary-tree case in types/recursive-tree.vl.
type Node = { value: i32, next: Node | null }

function len(n: Node): i32 {
  if n.next != null { return 1 + len(n.next) }
  return 1
}

const single: Node = { value: 7, next: null }
print(len(single))               // 1

const list: Node = { value: 7, next: { value: 8, next: { value: 9, next: null } } }
print(len(list))                 // 3
