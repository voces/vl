// @run
// @log 0
// @log 9
// CONTRACT (must-not-error): `is` discriminates a VALUE-KIND union — one whose
// members share a scalar wasm rep (`boolean | i32`, encoded as a tagged value
// struct that Heap2Local usually scalarizes away) — just as it does a boxed
// reference union. The else-branch narrows to the complement `i32`, so `return x`
// is sound there. Pairs with narrowing-is-sound.vl (boxed) to pin both encodings.
function f(x: boolean | i32): i32 {
  if x is boolean { return 0 }
  return x                       // else: complement is i32
}
print(f(true))                   // 0   (then: x is boolean)
print(f(9))                      // 9   (else: x is i32)
