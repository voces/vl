// @run
// @log 7
// @log -1
// @log 30
// CONTRACT: a null guard makes the value non-null for the dependent use. Two
// idioms, both sound: the positive `if x != null { … }`, and the divergent
// guard-clause `if x == null { return … }` that leaves `x` non-null below it.
function maybe(b: i32): { x: i32 } | null {
  if b > 0 { return { x: 7 } }
  return null
}

// positive guard: body only runs when non-null.
function read(b: i32): i32 {
  let p = maybe(b)
  if p != null { return p.x }
  return 0 - 1
}
print(read(1))                   // 7
print(read(0))                   // -1

// `||` guard clause (De Morgan): after it, BOTH a and b are non-null.
function add(a: { v: i32 } | null, b: { v: i32 } | null): i32 {
  if a == null || b == null { return 0 - 1 }
  return a.v + b.v
}
print(add({ v: 10 }, { v: 20 })) // 30
