// @run
// @log 9
// @log 0
// CONTRACT (must-not-error): narrowing a NULLABLE FIELD of a struct —
// `if o.inner != null { … o.inner.value … }` — makes `o.inner` non-null in
// the then-branch, so the nested field access `o.inner.value` is valid.
// This extends the basic nullable-access-guarded.vl (which narrows a local
// variable) to a nullable FIELD PATH, confirming that field-path narrowing
// works for nested access.
type Inner = { value: i32 }
type Outer = { inner: Inner | null }

function readInner(o: Outer): i32 {
  if o.inner != null { return o.inner.value }
  return 0
}
print(readInner({ inner: { value: 9 } }))  // 9   (inner present)
print(readInner({ inner: null }))           // 0   (inner null)
