// @run
// @log 42
// @log 6
// @log 4
// @log 9
// The must-not-error twin of hole-arg-concrete-param-reject: legitimate
// generic flows through a hole still work. A hole forwarded to a concrete
// callee with a MATCHING argument type runs; a hole forwarded into a
// function-typed param's concrete signature runs; a derived field hole
// forwarded with the right type runs; array HOFs still infer their lambda
// params and monomorphize per call site.
function twice(n: i32) { return n * 2 }
function f(x) { return twice(x) }
print(f(21))

function apply(fn: (i32) => i32, a) { return fn(a) }
print(apply((n) => n + 1, 5))

function len(s: string) { return s.length }
function g(o) { return len(o.name) }
print(g({ name: "four" }))

const xs = [1, 2, 3]
const doubled = xs.map((n) => n * 2)
print(doubled[0] + doubled[1] + doubled[2] - 3)
