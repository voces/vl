// @run
// @log 1
// @log 0
// @log 100
// @log 200
// CONTRACT (must-not-error, SOUNDNESS): `x is A` over a union of DISTINCT-shaped
// struct types is correct — true iff the runtime value really is an `A`, false
// for a `B`. Each struct variant gets a distinct runtime tag keyed on its
// FIELD-NAME-AWARE structural shape (WasmGC erases field names, so a wasm-type
// key would give `{tag,x}` and `{tag,y}` the same tag and make `is A` wrongly
// true for a `B`). Discrimination is by structural shape; the narrowed branch
// then reads the variant's own field soundly.
type A = { tag: i32, x: i32 }
type B = { tag: i32, y: i32 }

// `is A` true for an A value, false for a B value.
function isA(v: A | B): i32 {
  if v is A { return 1 } else { return 0 }
}
print(isA({ tag: 1, x: 100 }))   // 1  (an A IS an A)
print(isA({ tag: 2, y: 200 }))   // 0  (a B is NOT an A)

// Narrowed branch reads the right variant field both ways.
function field(v: A | B): i32 {
  if v is A { return v.x } else { return v.y }
}
print(field({ tag: 1, x: 100 })) // 100  (then: v.x)
print(field({ tag: 2, y: 200 })) // 200  (else: v.y)
