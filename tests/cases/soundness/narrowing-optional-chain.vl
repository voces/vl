// @run
// @log 5
// @log -1
// @log -1
// CONTRACT (must-not-error): `if x?.y != null { … }` narrows BOTH the receiver
// (`x` non-null) AND the path (`x.y` non-null) in the THEN-branch only, so the
// body may read `x.y.z` directly with no further guard. The optional chain folds
// a `null` receiver into the `!= null` test (it is false), so the body never runs
// on a null `x` or a null `x.y`. Sound across all three runtime shapes.
function f(o: { y: { z: i32 } | null } | null): i32 {
  if o?.y != null { return o.y.z }
  return 0 - 1
}
print(f({ y: { z: 5 } }))        // 5   (both present)
print(f({ y: null }))            // -1  (x.y is null → guard false)
print(f(null))                   // -1  (x is null → guard false)
