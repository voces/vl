// @check
// @error expected i32, got i32 | string
// CONTRACT (must-error): reading a UNION-TYPED FIELD without narrowing is
// unsound — the field may hold either variant and no use can assume a specific
// one. Here `o.v` is `string | i32` and feeding it to an `i32`-expecting context
// must be rejected, since it may be a string at runtime.
function extract(o: { v: i32 | string }): i32 {
  return o.v  // UNSOUND: o.v is still string | i32, not narrowed to i32
}
