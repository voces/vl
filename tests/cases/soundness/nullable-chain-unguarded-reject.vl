// @check
// @error member access '.c' on non-object {c: i32}?
// CONTRACT (must-error): accessing `a.b.c` when only `a` is guarded non-null but
// `a.b` is still nullable is unsound — the second nullable level must also be
// guarded. Without the inner guard, `a.b` may be null and the field access traps.
type Inner = { c: i32 }
type Mid = { b: Inner | null }

function read(a: Mid | null): i32 {
  if a != null { return a.b.c }  // UNSOUND: a.b may be null
  return -1
}
