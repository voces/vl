// @run
// @log 6
// @log 13
// CONTRACT (must-not-error): a numeric-literal union (`1 | 2 | 3`) is its base
// scalar (`i32`) for ARITHMETIC. `n + n` and `n + 10` soften the literal-union
// operand to `i32`, so the result is a plain `i32` that flows into an `i32`
// return — the union constraint governs only what may be ASSIGNED to `n`, not the
// type of expressions computed FROM it. (Contrast literal-union-reject-* which
// pin the closed-set rule on assignment / comparison.)
function f(n: 1 | 2 | 3): i32 {
  const doubled = n + n
  return doubled
}
print(f(3))                      // 6

function g(n: 1 | 2 | 3): i32 {
  return n + 10
}
print(g(3))                      // 13
