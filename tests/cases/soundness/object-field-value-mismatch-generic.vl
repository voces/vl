// @check
// @error {value: i32}
// CONTRACT (must-error): the field-value check also fires through a generic
// `type` alias application (`Box<i32>`). After `instantiateAlias` substitutes
// `i32` for `T`, the expected field type is the concrete `i32`, so a `"x"`
// value is a genuine mismatch (not the recursive-alias-leaf false-negative the
// fix deliberately stays lenient on).
type Box<T> = { value: T }
let b: Box<i32> = { value: "x" }
print(b.value)
