// @check
// @error unknown type
// A union annotation with an UNRESOLVED member must poison the whole
// annotation, exactly like `Bad[]` does. Before this was enforced the -1
// sentinel leaked into the member list and `assignable` treated the negative
// side as "accept anything" — `Bogus | i32` accepted a string.
let x: Bogus | i32 = "not an i32"
print(x is i32)
