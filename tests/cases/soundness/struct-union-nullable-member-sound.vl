// @run
// @log 1
// @log 0
// @log -1
// CONTRACT (must-not-error): a struct union that includes `null` as an explicit
// variant (`A | B | null`). Guarding with `v != null` first, then `is A`, gives
// the correct value in each branch. All three runtime shapes are handled soundly.
// Note: the flat `if v is A … else if v is B … else` form over `A | B | null`
// hits a codegen bug (see docs/soundness-findings.md, struct-union-null-is-chain)
// so this test uses the null-first guard idiom.
type A = { kind: i32, x: i32 }
type B = { kind: i32, y: i32 }

function read(v: A | B | null): i32 {
  if v != null {
    if v is A { return v.x }
    else { return v.y }
  }
  return -1  // null branch
}
print(read({ kind: 0, x: 1 }))  // 1   (A)
print(read({ kind: 1, y: 0 }))  // 0   (B)
print(read(null))                // -1  (null)
