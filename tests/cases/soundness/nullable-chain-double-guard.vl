// @run
// @log 42
// @log -1
// @log -1
// CONTRACT (must-not-error): a two-level nullable chain `a?.b?.c` requires TWO
// successive null guards before the leaf field `c` is readable. After
// `if a != null && a.b != null { … }` both places are narrowed in the then-branch
// so `a.b.c` is valid. The else-branch does NOT expose either non-null fact.
type Inner = { c: i32 }
type Mid = { b: Inner | null }

function read(a: Mid | null): i32 {
  if a != null && a.b != null { return a.b.c }
  return -1
}
print(read({ b: { c: 42 } }))   // 42  (both present)
print(read({ b: null }))         // -1  (a.b is null)
print(read(null))                // -1  (a is null)
