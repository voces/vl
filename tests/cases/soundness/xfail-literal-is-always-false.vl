// @run
// @log one
// KNOWN-BUG — xfail (see docs/soundness-findings.md, literal-is-always-false).
// `is <literal>` on a literal-union type ALWAYS takes the else branch —
// regardless of the actual value. The type-checker accepts the program (no
// compile errors) but runtime produces the wrong output.
//
// EXPECTED: prints "zero" (n is 0, so `n is 0` is true → then branch).
// ACTUAL: prints "one" (then branch never taken → falls through to else).
//
// The `==` form works: `n == 0` correctly returns true. Use `==` for literal
// discrimination until this is fixed.
//
// Captured as @run/@log so the regression guard fires when the output changes
// (i.e. when the bug is fixed → the log will be "zero" instead of "one").
// When fixed: flip @log to "zero".
const n: 0 | 1 = 0
if n is 0 { print("zero") } else { print("one") }
