// @check
// @error is not a variant
// CONTRACT (must-error): `x is T` is only meaningful when `T` is one of the
// value's possible variants (or `null`). Testing `x is boolean` on a `string |
// i32` value can never be true — `boolean` is not in the union — so it is
// rejected rather than compiled to an always-false branch. Discrimination is
// total over the declared variants, not an open runtime type test.
function f(x: string | i32): i32 {
  if x is boolean { return 0 }
  return 0
}
