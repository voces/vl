// @run
// @log 1
// CONTRACT (must-not-error, SOUNDNESS / A11): a nullable-headed recursive type —
// the natural "maybe-empty list/tree" shape — traverses soundly. The parameter
// is `Node | null` and the recursive call passes the alias's OWN nullable field
// `n.next` (also `Node | null`): the SAME type. This must unify with itself
// across the self-reference.
//
// HISTORY: this was a known over-rejection (xfail) under A11 — the assignability
// check expanded the parameter's expected type one level
// (`{value: i32, next: Node | null} | null`) while leaving the argument as the
// bare alias (`Node | null`), then failed the structural compare through the
// self-reference. D8 carries a resolved `type` alias as a named `Type` wrapper
// and unwraps it uniformly in `ensureType`/`getConcreteType`, so the recursive
// `Node | null`-vs-`Node | null` comparison now resolves through the alias and
// succeeds — the sound program compiles. (Previously the documented workaround
// was to make the parameter the non-null `Node` and guard the field at the call
// site; see recursive-type-build-traverse.vl.)
type Node = { value: i32, next: Node | null }
function len(n: Node | null): i32 {
  if n == null { return 0 }
  return 1 + len(n.next)
}
const list: Node = { value: 7, next: null }
print(len(list))
