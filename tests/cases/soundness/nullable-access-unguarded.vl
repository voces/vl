// @check
// @error expected {x: any}, got {x: i32} | null
// CONTRACT (must-error): a member access `p.x` on a `{ x } | null` value with no
// guard is unsound — `p` might be null at runtime. The access must be rejected
// until a guard narrows `p` to the object variant.
function maybe(b: i32): { x: i32 } | null {
  if b > 0 { return { x: 7 } }
  return null
}
let p = maybe(1)
print(p.x)
