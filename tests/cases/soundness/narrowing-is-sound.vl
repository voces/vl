// @run
// @log 7
// @log num
// @log str
// CONTRACT: after `if x is T { … }` the narrowed value really is `T`, in BOTH
// the then-branch and (by complement) the else-branch. A use that depends on
// that fact is sound — it compiles and produces the right value at runtime.

// then-branch: `p` is the non-null object, so `p.x` reads its field.
function getX(p: { x: i32 } | null): i32 {
  if p is { x: i32 } { return p.x }
  return 0
}
print(getX({ x: 7 }))            // 7

// then + else over a two-case union: each branch sees the right variant.
function classify(v: string | i32): string {
  if v is i32 { return "num" } else { return "str" }
}
print(classify(5))               // num   (then: v is i32)
print(classify("hi"))            // str   (else: complement is string)
