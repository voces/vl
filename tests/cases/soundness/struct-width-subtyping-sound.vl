// @run
// @log 3
// @log 7
// @log hello
// CONTRACT (must-not-error): STRUCTURAL WIDTH SUBTYPING — an object with MORE
// fields than the declared parameter type satisfies the narrower type. The extra
// field is silently ignored at the call boundary (the callee only reads its own
// declared fields). This is the core of structural typing: `{ x, y }` is a
// subtype of `{ x }` because it has at least those fields. The same applies
// across three-field → two-field and mixed-scalar-and-string cases.
function xOf(p: { x: i32 }): i32 { return p.x }
function sumXY(p: { x: i32, y: i32 }): i32 { return p.x + p.y }

// Two extra fields — only `x` is needed.
print(xOf({ x: 3, y: 4, z: 5 }))     // 3

// One extra field over a two-field signature.
print(sumXY({ x: 3, y: 4, z: 5 }))   // 7

// Mixed types — extra string field is ignored.
function greet(p: { name: string }): string { return p.name }
print(greet({ name: "hello", id: 42 })) // hello
