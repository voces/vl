// @check
// @error not all code paths return a value in 'f'
// The totality rule applies to an INFERRED non-void return too: `f` has a value return
// (`return 5` → inferred `i32`) but falls through when `b` is false, so it is rejected
// even with no `: T` annotation. A function with NO value returns infers `void` and is
// exempt (see missing-return-ok.vl).
function f(b: boolean) {
  if b { return 5 }
}
print(f(true))
