// @check
// @error non-exhaustive `is`-chain falls through with no `else` — missing boolean (add the arm(s) or an `else`; expected string)
// CONTRACT (must-error): same rule for an `is` chain over a general union —
// dropping the `boolean` case leaves a `| null` fall-through, so returning it
// where `string` is declared is rejected. Mirrors the literal-union case: a
// missing variant stays nullable.
function classify(x: i32 | string | boolean): string {
  if x is i32 { return "i" }
  else if x is string { return "s" }
}
