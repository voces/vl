// @check
// @error cannot assign i32 to 'x' of type string
// SOUNDNESS (was a latent miscompile). A generic function's return is instantiation-dependent:
// `add(3, 4)` returns i32, `add("a", "b")` returns string. Previously the checker collapsed every
// `a + b` over holes to `string` (a hole is permissively assignable to string, so the string-concat
// fast path always fired), so `const x: string = add(3, 4)` type-checked — but the emitter
// monomorphizes `add` at (i32, i32) and stores an i32 result into a string slot: INVALID WASM. The
// return now defers to the operand type per call site, so the checker sees i32 here and rejects the
// assignment to a `string` binding — a clean type error instead of a codegen crash.
function add(a, b) a + b

const x: string = add(3, 4) // REJECTED: add(3, 4) is i32, not string
print(x)
