// @run
// @log 1
// @log 2
// @log 3
// @log 100
// @log 200
// `v is <literal>` dispatch over a union PARAMETER that stays boxed at runtime,
// including a mixed-representation union (`"a" | "b" | 1`) where same-rep string
// literals share a tag — so the `is` test must compare the unboxed payload value
// after the tag selects the representation. (literal-is-always-false coverage.)
function classify(v: "a" | "b" | 1): i32 {
  if v is "a" { return 1 } else if v is "b" { return 2 } else if v is 1 {
    return 3
  } else { return 0 }
}
print(classify("a"))
print(classify("b"))
print(classify(1))

function pick(v: 0 | 1): i32 {
  if v is 0 { return 100 } else { return 200 }
}
print(pick(0))
print(pick(1))
