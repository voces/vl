// @run
// @log 3
// @log 10
// @log 99
// CONTRACT (must-not-error): CHAINED `??` — `a ?? b ?? default` returns `a` when
// present, else `b` when present, else `default`. The result is always non-null
// because the rightmost operand is non-nullable. This pins the left-to-right
// evaluation and that the triple-chain produces the correct non-null type.
function first(a: i32 | null, b: i32 | null): i32 {
  return a ?? b ?? 99
}
print(first(3, 10))    // 3   (a present)
print(first(null, 10)) // 10  (b present)
print(first(null, null)) // 99 (default)
