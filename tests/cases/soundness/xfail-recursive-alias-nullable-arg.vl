// @check
// @error expected {value: i32, next: Node | null} | null, got Node | null
// KNOWN-INCOMPLETE — xfail (ROADMAP A11 recursive types). This program is SOUND
// and SHOULD compile, but currently errors. It is an OVER-rejection (the compiler
// refuses a valid program), not an unsoundness, so it is captured as a "should-
// compile-but-errors" xfail rather than a silent compiler fix.
//
// THE GAP: the parameter is `Node | null`, and the recursive call passes the
// alias's OWN field `n.next` — which is also declared `Node | null`. These are
// the SAME type, but the assignability check expands the parameter's expected
// type one level (`{value: i32, next: Node | null} | null`) while leaving the
// argument as the bare alias (`Node | null`), then fails the structural compare
// through the self-reference. So a nullable-headed recursive traversal — the
// natural shape for "maybe-empty list/tree" — is rejected.
//
// Note the workaround that DOES compile (recursive-type-build-traverse.vl): make
// the parameter the non-null alias `Node` and guard the field at the call site
// (`if n.next != null { len(n.next) }`) so the argument is the narrowed non-null
// `Node`, sidestepping the `Node | null`-vs-`Node | null` alias mismatch.
//
// EXPECTED: compiles + runs (`Node | null` is assignable to `Node | null`).
// ACTUAL: `error expected {value: i32, next: Node | null} | null, got Node|null`.
//
// TODO(A11): compare recursive-alias types by alias identity (or memoize the
// in-progress pair) instead of one-sided expansion, so `Node | null` unifies with
// itself across the recursion. When fixed, flip this to `// @run`.
type Node = { value: i32, next: Node | null }
function len(n: Node | null): i32 {
  if n == null { return 0 }
  return 1 + len(n.next)
}
let list: Node = { value: 7, next: null }
print(len(list))
