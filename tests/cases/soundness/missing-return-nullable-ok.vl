// @run
// @log 1
// @log 0
// @log hi
// @log x
// A NULLABLE annotated return (`: T | null`) MAY fall through: the fall-through path
// yields `null` (emitted as the rep's null by `emitNullForRet`), which is assignable to
// the declared type, so no error. Covers the value-union box (`i32 | null`) and the
// string niche (`string | null`). The non-nullable `: i32` form of this body is the
// rejected case (missing-return-reject.vl) — the TS `noImplicitReturns` situation.
function fi(n: i32): i32 | null {
  if n > 0 { return 1 }
}
function fs(n: i32): string | null {
  if n > 0 { return "hi" }
}
const a = fi(7)
const b = fi(-1)
const s = fs(7)
const t = fs(-1)
print(a ?? 0)
print(b ?? 0)
print(s ?? "x")
print(t ?? "x")
