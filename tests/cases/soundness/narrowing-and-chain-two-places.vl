// @run
// @log 30
// @log -1
// @log -1
// CONTRACT (must-not-error): `&&`-chained null guards narrow BOTH operands
// simultaneously — `if a != null && b != null { … }` makes both `a` and `b`
// non-null in the then-branch. The De Morgan complement in else guarantees
// neither is definitely non-null: at least one is null. Accessing both in the
// then-branch is sound; falling through after is correctly rejected.
// (This pins the then-branch soundness; narrowing-and-else-not-narrowed.vl
// pins the else-branch unsoundness.)
function sumBoth(a: { v: i32 } | null, b: { v: i32 } | null): i32 {
  if a != null && b != null { return a.v + b.v }
  return -1
}
print(sumBoth({ v: 10 }, { v: 20 })) // 30  (both present)
print(sumBoth(null, { v: 20 }))      // -1  (a is null)
print(sumBoth({ v: 10 }, null))      // -1  (b is null)
