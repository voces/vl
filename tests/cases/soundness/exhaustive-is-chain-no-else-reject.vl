// @check
// @error expected i32, got 1 | 2 | null
// CONTRACT (must-error / guard): a NON-exhaustive `is`-chain with no `else` and a
// typed return must STILL error. Dropping the `1` variant leaves the fall-through
// reachable, so the body types as `1 | 2 | null` — returning that where `i32` is
// declared is the soundness signal "you forgot a case". This guards the
// exhaustiveness acceptance (exhaustive-is-chain-no-else-returns.vl) from
// over-firing: only a chain that truly covers every variant may drop its `else`.
function classify(v: "a" | "b" | 1): i32 {
  if v is "a" { return 1 } else if v is "b" { return 2 }
}
