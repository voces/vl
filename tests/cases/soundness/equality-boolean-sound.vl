// @run
// @log true
// @log false
// @log true
// @log false
// CONTRACT (must-not-error): comparing a boolean to a boolean literal (`true` /
// `false`) is always well-typed. `==` and `!=` on booleans work at the type level
// and narrows the place in the branch. Pins that boolean equality is equatable
// and produces a boolean result (not a type error).
const a: boolean = true
const b: boolean = false
print(a == true)   // true
print(a == false)  // false
print(b != true)   // true
print(b != false)  // false
