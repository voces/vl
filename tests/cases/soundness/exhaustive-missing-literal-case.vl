// @check
// @error expected i32, got 10 | 20 | null
// CONTRACT (must-error): a NON-exhaustive literal-union chain leaves a nullable
// fall-through. Here the `2` case is missing, so the result is `10 | 20 | null`;
// returning that where `i32` is declared must error. The `| null` is precisely
// the soundness signal "you forgot a case" — silencing it would let a function
// fall off its end with no value.
function score(n: 0 | 1 | 2): i32 {
  if n == 0 { return 10 }
  else if n == 1 { return 20 }
}
