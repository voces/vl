// @run
// @log a
// @log 5
// @log 7
// CONTRACT (must-not-error): assigning a narrower type into a wider union is
// sound (every `string` is a `string | i32`), so it type-checks. Upgraded from a
// pure type-level check to also verify codegen + runtime: each value is read back
// through an `is` narrowing and printed, exercising the union's representation.
let w: string | i32 = "a"
if w is string { print(w) } // "a"
w = 5
if w is i32 { print(w) } // 5
const n: i32 = 7
const w2: string | i32 = n
if w2 is i32 { print(w2) } // 7
