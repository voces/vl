// @run
// @log 6
// @log 0
// @log 3
// CONTRACT (must-not-error): a singly-linked list pattern — a recursive `Node`
// type with a nullable `next` — traverses and folds soundly. Both `sum` (which
// accumulates) and `count` (which counts nodes) are correct because the null
// guard in each step ensures the recursive call only happens when `next` is
// non-null. Pins the A11 contract for a sum-accumulation pattern, distinct from
// the length-only case in recursive-type-build-traverse.vl.
type Node = { value: i32, next: Node | null }

function sum(n: Node): i32 {
  if n.next != null { return n.value + sum(n.next) }
  return n.value
}
function count(n: Node): i32 {
  if n.next != null { return 1 + count(n.next) }
  return 1
}

const three: Node = { value: 1, next: { value: 2, next: { value: 3, next: null } } }
const empty: Node = { value: 0, next: null }

print(sum(three))    // 6   (1+2+3)
print(sum(empty))    // 0   (single node)
print(count(three))  // 3
