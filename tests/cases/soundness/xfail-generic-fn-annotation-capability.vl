// @check
// @error cannot assign (any, any) -> any to 'c' of type ({n: i32}, {n: i32}) -> {n: i32}
// SOUNDNESS. A generic function value is assignable to a concrete function type only when its body's
// CAPABILITY is satisfiable at the target's param types. `add`'s body `a + b` needs `+`, which is
// not defined for the struct `Cat` (no `+` operator) — so binding it to a `(Cat, Cat) => Cat` slot
// is rejected. Without the instantiation check the holes would match structurally and the emitter
// would try to lower `+` over a struct: invalid wasm. `genericFnAssignable` re-validates the
// deferred `+` constraint at the target param types (`binCstrsHold`).
type Cat = { n: i32 }
function add(a, b) a + b

const c: (Cat, Cat) => Cat = add // REJECTED: `+` is not defined for Cat
print(1)
