// @run
// @log 1
// @log 2
// @log 3
// CONTRACT (must-not-error): a function whose body is an exhaustive `is`-chain
// over a mixed literal union (`"a" | "b" | 1`) where EVERY arm returns needs no
// trailing `else`. The chain subtracts every variant to `Never`, so the
// fall-through is unreachable and all paths return — accepted with no redundant
// catch-all. Reuses `conditionsExhaust` (the no-`else` exhaustive path). The
// mirror guard is exhaustive-is-chain-no-else-reject.vl (a dropped variant still
// errors / types as nullable).
function classify(v: "a" | "b" | 1): i32 {
  if v is "a" { return 1 } else if v is "b" { return 2 } else if v is 1 {
    return 3
  }
}
print(classify("a"))  // 1
print(classify("b"))  // 2
print(classify(1))    // 3
