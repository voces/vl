// @run
// @log a
// @log b
// @log c
// @log d
// CONTRACT (must-not-error): an `is`-chain over a FOUR-member union is
// exhaustive when all four variants are covered — the fall-through carries no
// spurious `| null` so the function returns non-null with no dummy else. Extends
// the 3-member case (exhaustive-union-sound.vl) to confirm exhaustiveness scales.
function name(x: "a" | "b" | "c" | "d"): string {
  if x == "a" { return "a" }
  else if x == "b" { return "b" }
  else if x == "c" { return "c" }
  else { return "d" }
}
print(name("a"))  // a
print(name("b"))  // b
print(name("c"))  // c
print(name("d"))  // d
