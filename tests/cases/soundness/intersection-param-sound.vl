// @run
// @log 1
// @log 0
// CONTRACT (must-not-error): an INTERSECTION type annotation as a parameter
// type — `(0 | 1 | 2) & !2` admits only `0` or `1` at the call site and folds
// to a concrete union. The function body works with the narrowed union and the
// return value is an `i32`. Pins that intersection-annotated parameters are
// usable, not just writable, and that the algebra `(0 | 1 | 2) & !2 = 0 | 1`
// reduces correctly at the call boundary.
function nonTwo(n: (0 | 1 | 2) & !2): i32 {
  if n == 0 { return 0 }
  return 1
}
print(nonTwo(1))   // 1
print(nonTwo(0))   // 0
