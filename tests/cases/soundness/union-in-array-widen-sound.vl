// @run
// @log 1
// @log hello
// @log 3
// CONTRACT (must-not-error): a `(string | i32)[]` array holds union values that
// retain their variant identity across array store and load. Writing an `i32` or
// `string` into a union array widens it at the write boundary; reading back via
// `arr[i]` produces a union value that can be narrowed with `is`. This pins the
// round-trip: write → store in union array → load → narrow.
const arr: (string | i32)[] = [1, "hello", 3]
const a = arr[0]
if a is i32 { print(a) }     // 1
const b = arr[1]
if b is string { print(b) }  // hello
const c = arr[2]
if c is i32 { print(c) }     // 3
