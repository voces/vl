// @run
// @log 7
// @log 8
// @log 9
// @log 9
// @log 8
// @log 7
// CONTRACT (must-not-error, SOUNDNESS — P0-1 / the H3 typechecker blocker): TWO
// distinct functions may each `is`-narrow the SAME union-of-structs and read a
// narrowed variant's own field. This is the visitor idiom a self-hosted checker
// needs (`checkExpr`/`checkStmt` each discriminating the AST `Node` union).
//
// Pre-fix this MISCOMPILED with a WasmGC "Object has no field …": the codegen
// `narrowed` overlay is keyed by bare NAME and a function body is instantiated
// LAZILY at its first call. When the second narrowing function was first reached
// from inside the first function's narrowed branch (a call), its body was lowered
// while the caller's `narrowed["n"]` (a different, same-named local narrowed to a
// DIFFERENT variant) was still live — so the callee's `n` cast to the wrong
// struct. The fix snapshots/clears/restores `narrowed` at each function boundary,
// making every narrowing function-local. (#69 keeps `is` answers + shared-field
// access sound; this generalizes to any number of narrowers.)
type N1 = { kind: i32, x: i32 }
type N2 = { kind: i32, y: i32 }
type N3 = { kind: i32, z: i32 }
type N = N1 | N2 | N3

// First narrower: reads each variant's own field directly.
function readOwn(n: N): i32 {
  if n is N1 { return n.x }
  else if n is N2 { return n.y }
  else { return n.z }
}

// Second narrower over the SAME union, narrowing in a DIFFERENT order and
// reading the same per-variant fields — must not collide with the first.
function readOwn2(n: N): i32 {
  if n is N3 { return n.z }
  else if n is N2 { return n.y }
  else { return n.x }
}

const a: N = { kind: 0, x: 7 }
const b: N = { kind: 1, y: 8 }
const c: N = { kind: 2, z: 9 }
print(readOwn(a))   // 7  (N1.x)
print(readOwn(b))   // 8  (N2.y)
print(readOwn(c))   // 9  (N3.z)
print(readOwn2(c))  // 9  (N3.z)
print(readOwn2(b))  // 8  (N2.y)
print(readOwn2(a))  // 7  (N1.x)
