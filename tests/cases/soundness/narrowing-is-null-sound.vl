// @run
// @log -1
// @log 7
// CONTRACT (must-not-error): `if x is null` is the guard-clause form of a null
// check — the then-branch is the null path, and the fall-through (or else) is
// the non-null path. After `if x is null { return }`, the value is non-null below.
// This is the `is null` spelling of the same contract tested with `== null` in
// narrowing-null-guard.vl; both must work.
function unwrap(x: { v: i32 } | null): i32 {
  if x is null { return -1 }
  return x.v                     // x is non-null here (post-guard)
}
print(unwrap(null))              // -1  (null branch)
print(unwrap({ v: 7 }))         // 7   (non-null, post-guard)
