// @run
// @log cat
// @log dog
// CONTRACT (must-not-error): two struct types with the SAME field shape need
// an explicit DISCRIMINANT field to tell them apart at runtime. A `kind`
// field set to distinct values per variant is the standard idiom. The `is A`
// check then sees the structural shape (which IS the same), but the discriminant
// field value tells variants apart. Here: `Animal` vs `Pet` both have `{kind, name}`
// — the `kind` value `1` vs `2` is what the caller reads to distinguish them.
// This tests the SHARED-FIELD-ACCESS path: `kind` is shared across both, so it
// can be read without narrowing.
type Cat = { kind: i32, name: string }
type Dog = { kind: i32, name: string }

// Same shape — `is Cat` is always true for both (structural typing: Dog IS a Cat).
// So we discriminate by the `kind` field value, which is shared and readable.
function animalKind(v: Cat | Dog): string {
  if v.kind == 1 { return "cat" }
  return "dog"
}
print(animalKind({ kind: 1, name: "Whiskers" })) // cat
print(animalKind({ kind: 2, name: "Rex" }))       // dog
