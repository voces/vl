// @check
// @error {value: i32}
// CONTRACT (must-error): an object literal whose field VALUE has the wrong type
// is rejected when checked against an annotated object type. Previously the
// `Object` case of `ensureType` returned a bare `false` on a field-value
// mismatch (no diagnostic pushed), so the assignment path — which relies on
// `ensureType` recording the error, not on its boolean return — silently
// accepted `{ value: "x" }` for a `{ value: i32 }` target. See DECISIONS.md.
type Box = { value: i32 }
let b: Box = { value: "x" }
print(b.value)
