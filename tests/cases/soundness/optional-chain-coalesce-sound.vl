// @run
// @log 42
// @log 0
// CONTRACT (must-not-error): `x?.field ?? default` — optional chaining combined
// with null-coalescing — is a common idiom that must produce the non-null base
// type. The `?.` short-circuits to `null` when the receiver is null, and `??`
// turns that `null` into the default. The result type is the non-null field type.
// Two cases: receiver present (field is i32), receiver null (defaults to 0).
// Note: uses inline struct type (named alias form hits a known bug — see
// docs/soundness-findings.md, optional-chain-named-alias).
function getPort(cfg: { port: i32 } | null): i32 {
  return cfg?.port ?? 0
}
print(getPort({ port: 42 })) // 42  (receiver present)
print(getPort(null))          // 0   (receiver null → default)
