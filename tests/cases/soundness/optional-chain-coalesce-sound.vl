// @run
// @log 42
// @log 0
// @log 99
// @log 0
// @log 7
// @log -1
// @log -1
// CONTRACT (must-not-error): `x?.field ?? default` — optional chaining combined
// with null-coalescing — is a common idiom that must produce the non-null base
// type. The `?.` short-circuits to `null` when the receiver is null, and `??`
// turns that `null` into the default. The result type is the non-null field type.
// Works for a NAMED `type` alias receiver as well as an inline struct type: the
// `?.` member lookup unwraps the alias (optional-chain-named-alias RESOLVED, see
// docs/soundness-findings.md), so `Config | null` reads `port` exactly like the
// inline `{ port: i32 } | null` does. Also covers a CHAINED `?.` over nested
// aliases (`o?.inner?.v`), where every receiver is alias-typed.

// Inline struct receiver.
function getPortInline(cfg: { port: i32 } | null): i32 {
  return cfg?.port ?? 0
}
print(getPortInline({ port: 42 })) // 42  (receiver present)
print(getPortInline(null))          // 0   (receiver null → default)

// Named-alias receiver (previously a false-positive type error).
type Config = { port: i32 }
function getPort(cfg: Config | null): i32 {
  return cfg?.port ?? 0
}
print(getPort({ port: 99 })) // 99
print(getPort(null))          // 0

// Chained `?.` over nested named aliases.
type Inner = { v: i32 }
type Outer = { inner: Inner | null }
function deep(o: Outer | null): i32 {
  return o?.inner?.v ?? -1
}
print(deep({ inner: { v: 7 } })) // 7
print(deep({ inner: null }))      // -1 (mid-chain null)
print(deep(null))                 // -1 (head null)
