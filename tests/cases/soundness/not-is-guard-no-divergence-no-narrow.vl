// @check
// @error expected {progStmts: any}, got {progStmts: i32[]} | {x: i32}
// @error expected {length: any}, got never
// CONTRACT (must-error): a negated type guard whose then-branch does NOT diverge
// must NOT narrow the fall-through. Here `if !(n is Program) { print(0) }` falls
// through both when `n is Program` and when it is not, so `n` keeps its full
// `Program | Other` union after the `if` — accessing `n.progStmts` (a `Program`-
// only field) on the un-narrowed union is correctly rejected. Soundness guard for
// the negated-guard post-narrowing: it only fires across a diverging branch.
type Program = { progStmts: i32[] }
type Other = { x: i32 }
function f(n: Program | Other): i32 {
  if !(n is Program) { print(0) }
  return n.progStmts.length
}
