// @run
// @log 42
// @log hello
// CONTRACT (must-not-error): a function that RETURNS a union type produces a
// value that the caller must narrow before using as a specific variant. The
// caller can `is`-narrow the return value just like any other union — the tag
// survives the function boundary (coerceUnion boxes at the return, the caller's
// `is` reads the tag). Pins the round-trip: produce → return → narrow → use.
function make(n: i32): i32 | string {
  if n > 0 { return n }
  return "hello"
}

const a = make(42)
if a is i32 { print(a) }    // 42    (then: a is i32)

const b = make(0)
if b is string { print(b) } // hello (then: b is string)
