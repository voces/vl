// @check
// @error expected i32, got string
// CONTRACT (must-error): the else-branch of `if x is i32` narrows `x` to the
// COMPLEMENT (`string`), so using it where an `i32` is required is unsound and
// must be rejected. If this ever compiles, the complement narrowing has
// regressed and a `string` could flow into an `i32` slot at runtime.
function f(x: string | i32): i32 {
  if x is i32 { return 0 }
  return x
}
