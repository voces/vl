// @check
// @error member access '.v' on non-object {v: i32}?
// CONTRACT (must-error): a null-guard narrows `x` ONLY inside the then-branch.
// The narrowing must NOT leak past the branch — below the `if`, `x` is back to
// its declared `{ v: i32 } | null`, so the unguarded `x.v` is unsound and must be
// rejected. If this ever compiles, a narrowing has leaked out of its branch and a
// `null` could reach a field access at runtime.
function f(x: { v: i32 } | null): i32 {
  if x != null { print(x.v) }    // sound here: x narrowed in-branch
  return x.v                     // UNSOUND: x is nullable again out here
}
