// @check
// @error member access '.x' on non-object {tag: i32, x: i32} | {tag: i32, y: i32}
// CONTRACT (must-error): a field that is NOT present on every member of a struct
// union is NOT accessible on the union directly — it requires an `is`/`==`
// narrowing first. `x` is only on `A`, so `(A | B).x` is rejected (reading it off
// a `B` value would be unsound). Only the SHARED fields are reachable unguarded.
type A = { tag: i32, x: i32 }
type B = { tag: i32, y: i32 }
function f(v: A | B): i32 {
  return v.x                     // x is not on B — reject
}
