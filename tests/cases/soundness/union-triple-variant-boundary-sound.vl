// @run
// @log 1
// @log 2
// @log 3
// CONTRACT (must-not-error): a 3-variant union (`i32 | string | boolean`) passes
// through a function boundary intact — the variant identity is preserved as the
// value flows from caller to callee and back. The callee discriminates with `is`
// and returns an i32 label; the caller reads the label. Pins the union-boundary
// contract for three distinct wasm reps (scalar, ref, scalar with distinct tag).
function label(v: i32 | string | boolean): i32 {
  if v is i32 { return 1 }
  else if v is string { return 2 }
  else { return 3 }   // boolean
}
function relay(v: i32 | string | boolean): i32 {
  return label(v)
}
print(relay(42))     // 1
print(relay("hi"))   // 2
print(relay(true))   // 3
