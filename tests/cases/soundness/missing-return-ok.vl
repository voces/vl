// @run
// @log 1
// @log 7
// @log 9
// @log 0
// @log 0
// The totality rule must NOT false-positive on functions that DO return on every path:
// an `if`/`else` where both arms return; a guard-`if` followed by a tail value (implicit
// return); a `while true { … }` that returns from inside (never falls through); and a
// void function with no return at all. Pairs with the missing-return-*-reject cases.
function both(n: i32): i32 {
  if n > 0 { return 1 } else { return 2 }
}
function guardThenTail(n: i32): i32 {
  if n < 0 { return -1 }
  7
}
function loopReturns(n: i32): i32 {
  while true {
    if n >= 0 { return 9 }
    return 0
  }
}
function noReturn(n: i32) {
  print(n)
}
print(both(5))
print(guardThenTail(5))
print(loopReturns(5))
print(loopReturns(-1))
noReturn(0)
