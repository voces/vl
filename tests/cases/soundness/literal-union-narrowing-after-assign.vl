// @run
// @log one
// @log two
// @log three
// CONTRACT (must-not-error): narrowing a LITERAL UNION through successive
// reassignment — after `x = "two"`, the narrowing `x == "one"` is false and
// the else-branch sees `"two" | "three"`. Each leg of the if/else chain has the
// right narrowed type, and the final else is the last remaining literal.
// Pins that literal-union discrimination works correctly at the value level.
function name(x: "one" | "two" | "three"): string {
  if x == "one" { return "one" }
  else if x == "two" { return "two" }
  else { return "three" }
}
let v: "one" | "two" | "three" = "one"
print(name(v))   // one
v = "two"
print(name(v))   // two
v = "three"
print(name(v))   // three
