// @check
// @error cannot assign string to "ok" | "err"
// CONTRACT (must-error): a literal union is a CLOSED SET — a literal that is
// not listed in the union is never assignable to it. `"unknown"` is not in
// `"ok" | "err"`, so it is rejected at assignment. Extends the existing
// literal-union-reject-assign.vl to confirm the closed-set rule applies to
// reassignment (not just initialization).
let status: "ok" | "err" = "ok"
status = "unknown"   // UNSOUND: "unknown" is not in the union
