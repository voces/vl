// @check
// @error isn't equatable
// CONTRACT (must-error): structural `==` is sound only when EVERY field is itself
// value-comparable. A field whose type is an unresolved union (`string | i32`)
// is not — comparing it would require discriminating the variant first — so the
// object is non-equatable and the default structural `==` is rejected with the
// "define a `==` operator" diagnostic. (A function-valued field, by contrast,
// stays equatable: functions compare by reference — see objects/equality-
// function-field.vl. The gap is specifically a non-discriminated union field.)
function mk(b: i32): { v: string | i32 } {
  if b > 0 { return { v: "a" } }
  return { v: 1 }
}
let a = mk(1)
let b = mk(0)
print(a == b)
