// @run
// @log true
// @log false
// @log true
// CONTRACT (must-not-error): structural `==` recurses through BOTH nested structs
// AND array elements. Two objects are equal iff their scalar fields match, their
// nested struct fields are structurally equal, and their array fields have equal
// length with equal elements. A single differing array element makes the whole
// object unequal. This pins the recursive `valueEq` / `arrayEq` contract end to
// end (`isEquatable` first proves it is sound to do so).
let a = { tags: [1, 2, 3], pos: { x: 1, y: 2 } }
let b = { tags: [1, 2, 3], pos: { x: 1, y: 2 } }
let c = { tags: [1, 2, 9], pos: { x: 1, y: 2 } }
print(a == b)                    // true   (all fields + elements equal)
print(a == c)                    // false  (one array element differs)
print(a != c)                    // true
