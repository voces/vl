// @check
// @error argument 1: expected "a" | "b", got string
// CONTRACT (must-error): a literal union accepts ONLY its listed members. Passing
// `"c"` to a `"a" | "b"` parameter must be rejected — the union is a closed set,
// not an open string type.
function k(s: "a" | "b"): i32 {
  if s == "a" { return 1 }
  return 2
}
print(k("c"))
