// @run
// @log zero
// @log one
// @log a
// @log notB
// @log f15
// `v is <literal>` on a literal-union type is a RUNTIME value test (same answer
// as `v == <literal>`). Literal variants that share a representation share a tag
// (`0`/`1` both ride the i32 tag; `"a"`/`"b"` both ride the string tag), so the
// `is` codegen compares the VALUE, not just the tag.
// (Regression: previously `is <literal>` was always false — every value took the
// else branch. See docs/soundness-findings.md, literal-is-always-false RESOLVED.)
const n: 0 | 1 = 0
if n is 0 { print("zero") } else { print("one") }

const m: 0 | 1 = 1
if m is 0 { print("zero") } else { print("one") }

const s: "a" | "b" = "a"
if s is "a" { print("a") } else { print("b") }

if s !is "b" { print("notB") } else { print("isB") }

const f: 1.5 | 2.5 = 1.5
if f is 1.5 { print("f15") } else { print("f25") }
