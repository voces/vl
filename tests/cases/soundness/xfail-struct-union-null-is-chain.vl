// @run
// @trap illegal cast
// KNOWN-BUG — xfail (see docs/soundness-findings.md, struct-union-null-is-chain).
// A flat `if v is A … else if v is B … else` chain over `A | B | null` SHOULD
// compile and run correctly (the else is null), but currently TRAPS at runtime
// with "illegal cast" when the discriminated value is a non-null struct.
//
// The type-checker accepts the program (no compile errors), so this is a CODEGEN
// BUG: the `is A` check over a value whose declared type includes `null` alongside
// the struct variants appears to use the wrong representation path.
//
// EXPECTED: runs, returning 1 / 0 / -1 for A / B / null respectively.
// ACTUAL: runtime trap "illegal cast" when a non-null struct value is passed.
//
// Captured as @trap so the regression guard fires the moment the trap disappears
// (i.e. when the bug is fixed). When fixed, flip to @run + @log directives and
// drop the @trap.
type A = { kind: i32, x: i32 }
type B = { kind: i32, y: i32 }

function read(v: A | B | null): i32 {
  if v is A { return v.x }
  else if v is B { return v.y }
  else { return -1 }
}
print(read({ kind: 0, x: 1 }))
print(read(null))
