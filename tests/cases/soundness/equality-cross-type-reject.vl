// @check
// @error cannot compare string with i32
// CONTRACT (must-error): comparing a `string` with an `i32` is a type error —
// VL has no cross-type equality. This extends equality-type-mismatch.vl
// (i32 vs string literal) to the symmetric direction: a string variable vs an
// integer constant. Neither direction of cross-type == is legal.
let s: string = "hello"
print(s == 42)  // UNSOUND: string == i32 is never allowed
