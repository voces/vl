// @run
// @log hi
// @log x
// @log true
// @log false
// NICHE INFERENCE: an un-annotated function whose returns join to a niche nullable
// (`string | null` / `boolean | null`) lowers WITHOUT an annotation — the A20 table
// carries the canonical niche name and the emitter seeds the rep (string `ref.null
// $array` / boolean sentinel `2`) from it. The fall-through path yields `null`; a caller
// narrows with `??`. (The box-able `i32 | null` case is missing-return-inferred-nullable.vl;
// only a nullable STRUCT ref still floors — needs the variant-boxed rep.)
function fs(n: i32) {
  if n > 0 { return "hi" }
}
function fb(n: i32) {
  if n > 0 { return true }
}
const s1 = fs(5)
const s2 = fs(-5)
const b1 = fb(5)
const b2 = fb(-5)
print(s1 ?? "x")
print(s2 ?? "x")
print(b1 ?? false)
print(b2 ?? false)
