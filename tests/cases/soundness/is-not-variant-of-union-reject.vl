// @check
// @error is not a variant
// CONTRACT (must-error): `x is T` where `T` is not a variant of `x`'s type is
// rejected — it can never be true, so the compiler disallows it rather than
// silently compiling an always-false test. This extends is-non-variant-reject.vl
// (which tests `boolean` on a `string | i32`) to confirm the same rule applies
// to a STRUCT type that is not in the union.
type A = { x: i32 }
type B = { y: i32 }
type C = { z: i32 }

function f(v: A | B): i32 {
  if v is C { return 0 }   // C is not a variant of A | B
  return 1
}
