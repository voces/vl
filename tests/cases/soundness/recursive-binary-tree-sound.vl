// @run
// @log 6
// @log 2
// CONTRACT (must-not-error): a BINARY TREE pattern — a recursive `Tree` type
// with two nullable child references. `sum` and `height` both recurse through
// the tree soundly, using null guards on `left`/`right` before each recursive
// call. Pins the A11 two-reference-per-node contract; the single-reference case
// is covered by recursive-type-build-traverse.vl and recursive-linked-list-sound.vl.
type Tree = { value: i32, left: Tree | null, right: Tree | null }

function sum(t: Tree): i32 {
  let s = t.value
  if t.left != null { s = s + sum(t.left) }
  if t.right != null { s = s + sum(t.right) }
  return s
}
function height(t: Tree): i32 {
  let lh = 0
  let rh = 0
  if t.left != null { lh = height(t.left) }
  if t.right != null { rh = height(t.right) }
  if lh > rh { return 1 + lh }
  return 1 + rh
}

//       1
//      / \
//     2   3
const tree: Tree = {
  value: 1,
  left: { value: 2, left: null, right: null },
  right: { value: 3, left: null, right: null }
}
print(sum(tree))     // 6
print(height(tree))  // 2 (root + one level of leaves)
