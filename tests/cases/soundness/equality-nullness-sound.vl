// @run
// @log false
// @log true
// @log true
// @log false
// CONTRACT: `== null` / `!= null` are always well-typed on a nullable value and
// report the runtime nullness, and the result narrows the place in the branch.
function maybe(b: i32): { x: i32 } | null {
  if b > 0 { return { x: 7 } }
  return null
}
const p = maybe(1)
const q = maybe(0)
print(p == null)                 // false
print(q == null)                 // true
print(p != null)                 // true
print(q != null)                 // false
