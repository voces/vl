// @check
// @error expected i32, got string | i32
// CONTRACT (must-error): passing a UNION-typed value to a function that expects
// a concrete type is unsound — the union may hold either variant. The caller must
// narrow the union to the specific variant first. This is the argument-passing
// form of the wider→narrower rule (union-narrow-reject.vl covers assignment).
function double(n: i32): i32 { return n + n }
const v: string | i32 = 5
print(double(v))  // UNSOUND: v may be a string
