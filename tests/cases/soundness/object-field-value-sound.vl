// @run
// @log 5
// @log 9
// @log 1
// CONTRACT (must-NOT-error): the field-value tightening must not reject
// well-typed object literals. Runnable companion cases that must keep passing:
//   1. correct field types against a generic alias,
//   2. nullable field assignment (a `null` value into an `i32 | null` field),
//   3. permissive width subtyping — an excess property on the supplied object
//      is still allowed; only a wrong field VALUE is rejected.
// (Numeric field coercion is asserted at the type level in
// object-field-value-coerce.vl; codegen of an i32-literal-into-f64-field is a
// separate, pre-existing limitation unrelated to this check.)
type Box<T> = { value: T }
const b: Box<i32> = { value: 5 }
print(b.value) // 5

type Opt = { v: i32 | null }
const o: Opt = { v: null } // nullable field accepts null — no error
print(o.v ?? 9) // null field reads back, defaulted via `??` — 9

// Width subtyping: { x, y } satisfies the narrower { x: i32 } param. The excess
// `y` is allowed; only a wrong field VALUE would be rejected.
function fst(p: { x: i32 }): i32 p.x
print(fst({ x: 1, y: 2 })) // 1
