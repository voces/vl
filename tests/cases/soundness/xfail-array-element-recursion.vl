// @run
// @log 1
// @log 10
// CONTRACT (must-not-error, ROADMAP A11): a `type` that recurses THROUGH an
// ARRAY element type now compiles and runs. `Tree` references itself through the
// element type of its `kids` array (spelled here with the explicit
// `{ [i32]: Tree }` index-signature form — equivalent to `Tree[]`). Recursion
// through a *nullable struct field* already worked (the rec-group ties the
// self-reference, see recursive-type-build-traverse.vl); this pins the
// array-element back-edge, which previously overflowed the stack at codegen
// ("Maximum call stack size exceeded").
//
// The element struct, its list `{backing,len,cap}` wrapper, and the backing
// array are now built in ONE WasmGC rec group, so the self-reference is a
// forward reference rather than an unbounded re-entry. An empty `kids` array is
// the recursion base case (a leaf); traversal walks the array, recursing into
// each child.
type Tree = { value: i32, kids: { [i32]: Tree } }

function total(t: Tree): i32 {
  let sum = t.value
  let i = 0
  while i < t.kids.length {
    sum = sum + total(t.kids[i])
    i = i + 1
  }
  return sum
}

// A leaf — an empty `kids` array, so just its own value.
const leaf: Tree = { value: 1, kids: [] }
print(total(leaf))               // 1

// 2 + 3 + 5 = 10 — a root with two children, both leaves.
const t: Tree = {
  value: 2,
  kids: [
    { value: 3, kids: [] },
    { value: 5, kids: [] },
  ],
}
print(total(t))                  // 10
