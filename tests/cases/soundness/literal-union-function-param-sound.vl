// @run
// @log 1
// @log 2
// @log 3
// CONTRACT (must-not-error): a literal-union PARAMETER — `"x" | "y" | "z"` —
// accepts any listed member at the call site and passes it through correctly.
// The function can discriminate with `==` and the narrowed literal flows as a
// concrete string. Pins literal-union parameters as fully functional, not just
// as annotations.
function rank(s: "x" | "y" | "z"): i32 {
  if s == "x" { return 1 }
  else if s == "y" { return 2 }
  else { return 3 }
}
print(rank("x"))  // 1
print(rank("y"))  // 2
print(rank("z"))  // 3
