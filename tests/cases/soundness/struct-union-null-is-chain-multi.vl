// @run
// @log 10
// @log 20
// @log 30
// @log -1
// A longer `is`-chain over `A | B | C | null` reaches each non-first variant
// (so the bug's "second condition mis-compiled as a niche null test" path is
// exercised for B and C) and the `null` case still falls through to the else.
// (struct-union-null-is-chain coverage.)
type A = { kind: i32, x: i32 }
type B = { kind: i32, y: i32 }
type C = { kind: i32, z: i32 }

function read(v: A | B | C | null): i32 {
  if v is A { return v.x }
  else if v is B { return v.y }
  else if v is C { return v.z }
  else { return -1 }
}
print(read({ kind: 0, x: 10 }))
print(read({ kind: 1, y: 20 }))
print(read({ kind: 2, z: 30 }))
print(read(null))
