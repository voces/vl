// @run
// @log 7
// @log -1
// CONTRACT (must-not-error): a type-guard FUNCTION used as a guard-clause —
// `if absent(p) { return }` — narrows `p` non-null in the rest of the block
// below the guard. The guard function's return value IS the predicate, so its
// truth implies the post-guard narrowing. This pins the post-guard + guard-
// function interaction: after `if isNull(p) { return }`, `p.x` is valid.
function maybe(b: i32): { x: i32 } | null {
  if b > 0 { return { x: 7 } }
  return null
}
function isNull(p: { x: i32 } | null): boolean { return p == null }

function readX(b: i32): i32 {
  const p = maybe(b)
  if isNull(p) { return -1 }  // guard-clause: p non-null below
  return p.x
}
print(readX(1))   // 7  (non-null)
print(readX(0))   // -1 (null, early return)
