// @run
// @log 30
// @log -1
// @log -1
// CONTRACT (must-not-error): `||`-guard clause — `if a == null || b == null
// { return }` is the De Morgan negation of `a != null && b != null`. After the
// divergent then-branch, BOTH `a` and `b` are narrowed non-null for the rest of
// the block (post-guard narrowing). Reads `a.v + b.v` soundly below the guard.
// Mirrors narrowing-null-guard.vl's `||` example with explicit types annotated.
function sumOrReturn(a: { v: i32 } | null, b: { v: i32 } | null): i32 {
  if a == null || b == null { return -1 }
  return a.v + b.v               // both narrowed non-null here
}
print(sumOrReturn({ v: 10 }, { v: 20 })) // 30
print(sumOrReturn(null, { v: 20 }))      // -1
print(sumOrReturn({ v: 10 }, null))      // -1
