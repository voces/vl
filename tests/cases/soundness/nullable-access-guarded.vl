// @run
// @log 9
// @log 5
// CONTRACT: the same nested access is sound once the nullable field is guarded.
let o: { v: { x: i32 } | null } = { v: { x: 9 } }
if o.v != null { print(o.v.x) }  // 9 (o.v narrowed to the object)

// `&&` composes the guards: first non-null, then discriminate the field union.
function f(o: { y: string | i32 } | null): i32 {
  if o != null && o.y is i32 { return o.y }
  return -1
}
print(f({ y: 5 }))               // 5
