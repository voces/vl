// @check
// @error non-exhaustive `is`-chain falls through with no `else` — add the missing variant(s) or an `else` (expected string)
// CONTRACT (must-error): an `is`-chain over a four-member union that covers only
// three variants is NOT exhaustive — the missing variant leaves a nullable
// fall-through, so returning it where a non-null type is expected is rejected.
// Mirrors exhaustive-missing-is-case.vl but for a larger union.
function name(x: "a" | "b" | "c" | "d"): string {
  if x == "a" { return "a" }
  else if x == "b" { return "b" }
  else if x == "c" { return "c" }
  // "d" is missing — fall-through is nullable
}
