// @run
// @log yes
// @log no
// @log yes
// @log no
// CONTRACT (must-not-error): using a boolean expression as an `if` condition is
// the simplest narrowing form — `if b { … }` is typed as `if b == true { … }`.
// Both the positive and negative (`!`) forms must work, and a boolean result from
// a comparison must be usable as a condition. Pins that boolean-typed conditions
// compile and produce the right branch.
function yesNo(b: boolean): string {
  if b { return "yes" } else { return "no" }
}
print(yesNo(true))   // yes
print(yesNo(false))  // no

// Boolean from a comparison used as a condition value.
function ge(a: i32, b: i32): string {
  const ok = a >= b
  if ok { return "yes" } else { return "no" }
}
print(ge(3, 2))  // yes
print(ge(1, 2))  // no
