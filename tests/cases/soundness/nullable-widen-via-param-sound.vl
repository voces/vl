// @run
// @log 5
// @log -1
// CONTRACT (must-not-error): a non-null `T` value is assignable to `T | null`
// at the argument-passing boundary. Widening at return was tested in
// union-widen-via-return-sound.vl; this pins the PARAMETER form: passing a
// concrete `{ v: i32 }` to a `{ v: i32 } | null` parameter is sound.
function read(p: { v: i32 } | null): i32 {
  if p != null { return p.v }
  return -1
}
const obj: { v: i32 } = { v: 5 }
print(read(obj))   // 5   (non-null widened at call)
print(read(null))  // -1  (null)
