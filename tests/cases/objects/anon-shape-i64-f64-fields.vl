// @run
// @log 6000000000
// @log 1.5
// @log 6000000000
// An UN-ANNOTATED object literal whose field value is an i64-magnitude literal, an
// f64-element list, or an i64-element list. The anonymous shape's field codes come from
// the literal VALUES (`anonFieldCode`), which lacked the i64 (23) and f64/i64-list
// (25/26) arms — the shape coded i32/i32-list and the built value's rep mismatched the
// field storage. The i64-element list also forces its wrapper/backing at collect
// (`arrLitIsI64`, the i64 sibling of the f64 branch). (Distinct field names: literals
// resolve shapes by field-name set.)
function go() {
  const a = {big: 6000000000}
  print(a.big)
  const b = {floats: [1.5]}
  print(b.floats[0])
  const c = {bigs: [6000000000]}
  print(c.bigs[0])
}
go()
