// @run
// @log 10
// @log 3
// @log 30
// Method shorthand alongside ordinary fields: a normal value field (`base`), a
// shorthand method (`addBase`), and an expression-body shorthand (`triple`).
const obj = {
  base: 7,
  addBase(x: i32) { return x + 7 },
  triple(x: i32) x + x + x
}
print(obj.addBase(3))
print(obj.base - 4)
print(obj.triple(10))
