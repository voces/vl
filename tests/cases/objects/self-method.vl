// @run
// @log 4
// @log 6
// @log 25
// Methods via `self` + UFCS (ROADMAP B14): a free function whose first parameter
// is the `self` marker is callable as `o.f(args)` — rewritten to `f(o, args)`,
// reusing the call machinery so `self` monomorphizes to the receiver's shape.
// (Field methods win over UFCS; a non-`self` function is not reachable via an
// instance — see self-method-pollution.vl.)
function add(self, b) { x: self.x + b.x, y: self.y + b.y }
function sumsq(self) self.x * self.x + self.y * self.y
const a = {x: 1, y: 2}
const c = a.add({x: 3, y: 4})
print(c.x)
print(c.y)
const p = {x: 3, y: 4}
print(p.sumsq())
