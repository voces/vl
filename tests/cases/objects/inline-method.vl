// @run
// @log 7
// @log 12
// Inline function literals as object fields (ROADMAP B15/B5): an object used as a
// container/namespace. `foo.add(a, b)` reads the field's closure and calls it —
// no receiver passed (the container case, distinct from a `self` method). This is
// the inline-literal form of the already-working function-reference field.
const foo = {
  add: function(a: i32, b: i32) a + b
}
print(foo.add(3, 4))
print(foo.add(5, 7))
