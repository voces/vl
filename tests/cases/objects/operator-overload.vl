// @run
// @log 12
// @log 18
// @log 2
// @log 3
// User-defined operator overloading (ROADMAP B13): a structural object carries a
// method field named for the operator (`"*"`, `"/"`). `a * s` dispatches through
// it — struct.get the method closure, indirect-call with the operand — reusing
// the member-call machinery. (Operands are primitives here; object-shaped
// operands like `vec + vec` need the wider inference/monomorphization of A13.)
function vec(x: i32, y: i32) {
  "*": function(s: i32) { x: x * s, y: y * s },
  "/": function(s: i32) { x: x / s, y: y / s },
  x: x,
  y: y
}
let a = vec(6, 9)
let b = a * 2
print(b.x)
print(b.y)
let c = a / 3
print(c.x)
print(c.y)
