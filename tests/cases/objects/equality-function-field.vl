// @check
// @error isn't equatable
// An object with a function-valued field is NOT auto-equatable: closures can't
// be soundly value-compared (they may capture different hidden state), so the
// default structural `==` is a clean error — define a custom `==` if you need it.
let a = { x: 1, f: function(n: i32) n }
let b = { x: 1, f: function(n: i32) n }
let r = 0
if a == b { r = 1 }
