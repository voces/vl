// @run
// @log 1
// @log 1
// @log 1
// Objects with function-valued fields ARE equatable: a function compares by
// reference — same function (table index) AND same captured env (`ref.eq`) — not
// by value (closures can't be value-compared). So same data + same function is
// equal; a different function, or different data, is not.
function inc(n: i32) n + 1
function dec(n: i32) n - 1
let a = { x: 1, f: inc }
let b = { x: 1, f: inc }
let c = { x: 1, f: dec }
let e = { x: 9, f: inc }
let r = 0
if a == b { r = 1 }
__store_i32__(0, 0)
__store_i32__(4, r)
__log__(0, 8)
let s = 0
if a != c { s = 1 }
__store_i32__(4, s)
__log__(0, 8)
let t = 0
if a != e { t = 1 }
__store_i32__(4, t)
__log__(0, 8)
