// @run
// @log 1
// @log 2
// @log 3
// Trailing comma in an object literal (`{ x: 1, y: 2, }`) and in an object TYPE
// annotation (`{ x: i32, y: i32, }`). Both allow one trailing `,` before `}`,
// ignored, producing the same value/type as the comma-free form.
let o: { x: i32, y: i32, z: i32, } = {
  x: 1,
  y: 2,
  z: 3,
}
print(o.x)
print(o.y)
print(o.z)
