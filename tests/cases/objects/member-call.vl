// @run
// @log 7
// @log 42
// @log 105
// Member-call syntax `o.f(args)`: call a function-valued object field directly
// (previously you had to hop through a local, `let h = o.f; h()`). The field may
// hold a plain function or an escaping closure — the call dispatches through the
// closure struct either way.
function seven() 7
function add1(x: i32) x + 1
let o = { a: seven, b: add1 }
__store_i32__(0, 0)
__store_i32__(4, o.a())
__log__(0, 8)
__store_i32__(4, o.b(41))
__log__(0, 8)
function makeO(k: i32) {
  function add(x: i32) x + k
  { go: add }
}
let c = makeO(100)
__store_i32__(4, c.go(5))
__log__(0, 8)
