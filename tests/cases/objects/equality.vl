// @run
// @log true
// @log false
// @log true
// @log false
// @log true
// Structural object equality (ROADMAP: by value). `a == b` compares fields
// recursively — native for numerics, `__string_eq__` for strings, a per-shape
// helper for nested structs. (An object with a function-valued field compares
// that field by IDENTITY — see equality-function-field.vl. Referential identity
// `is` is a separate, deferred operator.) `print` renders the booleans directly.
const a = { x: 1, y: 2 }
const b = { x: 1, y: 2 }
print(a == b)
const c = { x: 1, y: 9 }
print(a == c)
const p = { pos: { x: 1 }, name: "jo" }
const q = { pos: { x: 1 }, name: "jo" }
const diff = { pos: { x: 2 }, name: "jo" }
print(p == q)
print(p == diff)
print(p != diff)
