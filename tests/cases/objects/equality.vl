// @run
// @log 1
// @log 5
// @log 1001
// Structural object equality (ROADMAP: by value). `a == b` compares fields
// recursively — native for numerics, `__string_eq__` for strings, a per-shape
// helper for nested structs. (An object with a function-valued field is not
// auto-equatable — see equality-function-field.vl. Referential identity `is` is
// a separate, deferred operator.)
let a = { x: 1, y: 2 }
let b = { x: 1, y: 2 }
let r = 0
if a == b { r = 1 }
__store_i32__(0, 0)
__store_i32__(4, r)
__log__(0, 8)
let c = { x: 1, y: 9 }
let s = 5
if a == c { s = 0 }
__store_i32__(4, s)
__log__(0, 8)
let p = { pos: { x: 1 }, name: "jo" }
let q = { pos: { x: 1 }, name: "jo" }
let diff = { pos: { x: 2 }, name: "jo" }
let t = 0
if p == q { t = 1 }
if p == diff { t = t + 10 }
if p != diff { t = t + 1000 }
__store_i32__(4, t)
__log__(0, 8)
