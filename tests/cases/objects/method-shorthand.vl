// @run
// @log 7
// @log 12
// Method-shorthand object syntax (ROADMAP B5/B15): `add(a, b) { … }` is sugar
// for the function-valued field `add: function(a, b) { … }`. It desugars in the
// parser to the same anonymous-function AST, so member-call works unchanged.
const foo = {
  add(a: i32, b: i32) { return a + b }
}
print(foo.add(3, 4))
print(foo.add(5, 7))
