// @run
// @log 7
// @log 9
// @log 5
// Objects across boundaries: passed to / returned from functions, nested reads,
// and reassignment. Excess properties are allowed (permissive width subtyping):
// `getx` infers `o: {x}` from `o.x` yet accepts `{x, y}`.
function getx(o) o.x
function makePoint() { x: 3, y: 4 }
let nested = { a: { x: 7 }, b: 2 }
__store_i32__(0, 0)
__store_i32__(4, nested.a.x)
__log__(0, 8)
__store_i32__(4, getx({ x: 9, y: 1 }))
__log__(0, 8)
let p = makePoint()
p = { x: 5, y: 6 }
__store_i32__(4, p.x)
__log__(0, 8)
