// @run
// @log 20
// @log 20
// Shorthand and longhand are equivalent: both objects expose the same method and
// produce the same result when called via `o.method(args)`.
let shorthand = {
  scale(x: i32) { return x * 2 }
}
let longhand = {
  scale: function(x: i32) { return x * 2 }
}
print(shorthand.scale(10))
print(longhand.scale(10))
