// @run
// @log 5
// @log hi
// @log yes
// A plain (un-narrowed) read of a VALUE-UNION struct field yields the field's
// union BOX — a union value usable wherever a union is expected: returned into a
// union-typed result, bound to a `const`, passed as a union arg, then `is`-narrowed.
// (Returning it into a SCALAR slot stays rejected — soundness/union-field-unnarrowed-reject.)
// The union covers the full atom set (i32/i64/f64/boolean/string) and the receiver
// reads both as a free call and via UFCS method syntax.
type Box = { v: i32 | string }
function getV(b: Box): i32 | string {
  return b.v
}

type Exp = { actual: i32 | i64 | f64 | boolean | string }
function actualOf(self: Exp): i32 | i64 | f64 | boolean | string {
  return self.actual
}

const b: Box = { v: 5 }
const got = getV(b)
if got is i32 {
  print(got)
}

const e: Exp = { actual: "hi" }
const ga = actualOf(e)
if ga is string {
  print(ga)
}

const e2: Exp = { actual: true }
const g2 = e2.actualOf()
if g2 is boolean {
  if g2 { print("yes") }
}
