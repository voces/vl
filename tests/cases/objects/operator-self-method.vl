// @run
// @log 4
// @log 6
// @log 5
// Operator overloading via a `self`-method (ROADMAP B13 + B14): grammar allows an
// operator-named function (`function +(self, b)`), and `a + b` on a user object
// dispatches to `+(a, b)` — reusing the call path, so it monomorphizes per call.
// This makes `vec + vec` (object operands) work, where a stored-closure operator
// field hit the WasmGC width wall. Chains like any call; native numeric `+`
// keeps its inlined path.
function +(self, b) { x: self.x + b.x, y: self.y + b.y }
let a = { x: 1, y: 2 }
let b = { x: 3, y: 4 }
let c = a + b
__store_i32__(0, 0)
__store_i32__(4, c.x)
__log__(0, 8)
__store_i32__(4, c.y)
__log__(0, 8)
let e = (a + b) + a
__store_i32__(4, e.x)
__log__(0, 8)
