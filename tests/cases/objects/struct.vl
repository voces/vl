// @run
// @log 3
// @log 7
// @log 14
// Objects compile to WasmGC structs: literal -> struct.new, `p.x` -> struct.get,
// `p.x = …` -> struct.set. Fields are interned by shape (sorted field order).
// Also exercises the parser precedence fix (`p.x + p.y` is not `(p.x + p).y`).
let p = { y: 4, x: 3 }
__store_i32__(0, 0)
__store_i32__(4, p.x)
__log__(0, 8)
__store_i32__(4, p.x + p.y)
__log__(0, 8)
p.x = 10
__store_i32__(4, p.x + p.y)
__log__(0, 8)
