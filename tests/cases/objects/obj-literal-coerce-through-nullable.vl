// @run
// @log 77
// @log 3.5
// @log NULL
// @log 5
// @log 8.5
// An object literal adapts field-wise into a NULLABLE struct target (`S | null`) — the ObjLit dual
// of the array-literal nullable peel in `assignableExpr`. A float literal re-encodes at an `f32`
// field THROUGH the `| null` wrapper, exactly as the non-null target already coerces. Without the
// peel the `f32` field's `3.5` stayed f64 and the assignment failed the type check
// (`expected {…, z: f32}?, got {…, z: f64}`). Covers the param and local positions.

// A struct | null param whose struct has an f32 field — the float literal coerces.
function useIt(p: { a: string, f: i32, z: f32 } | null) {
  if p != null {
    print(p.f) // 77
    print(p.z) // 3.5
  } else {
    print("NULL")
  }
}
useIt({ a: "dx", f: 77, z: 3.5 })
useIt(null) // NULL

// A struct | null LOCAL with an f32 field.
function go() {
  const v: { a: i32, f: string, z: f32 } | null = { a: 5, f: "hi", z: 8.5 }
  if v != null {
    print(v.a) // 5
    print(v.z) // 8.5
  } else {
    print("NULL")
  }
}
go()
