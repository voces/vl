// @check
// @error Unknown property `plain`
// A non-`self` free function is NOT a method — it is not reachable through an
// instance, so `o.plain(2)` doesn't resolve to the global `plain`. This is what
// the `self` marker buys: no namespace pollution (vs a type-directed UFCS where
// every global would become a method on every object).
function plain(x: i32) x + 1
let o = { x: 5 }
let r = o.plain(2)
