// @run
// @log NULL
// @log T
// @log F
// @log F
// @log NULL
// @log 4
// @log NULL
// A `(boolean | null)[]` — a list of the boolean SENTINEL niche (false=0, true=1, the
// spare value 2 = null), repped as a plain i32 list (the SAME backing as `boolean[]`),
// NOT a union box. Scalar `boolean | null` is itself an i32 niche, so boxing the element
// would rep-split the type name (a boxed element read into a niche-repped local); the
// niche list keeps ONE rep. Construct (mixed + all-`null`), element read, `!= null`
// narrow, `.push(null)`, and `p[i] = null` all round-trip through the sentinel.
function show(t: boolean | null) {
  if t != null {
    if t { print("T") } else { print("F") }
  } else {
    print("NULL")
  }
}
function go() {
  const p: (boolean | null)[] = [null, true, false]
  show(p[0]) // NULL
  show(p[1]) // T
  show(p[2]) // F
  p[1] = false
  show(p[1]) // F
  p.push(null)
  show(p[3])      // NULL
  print(p.length) // 4
  const q: (boolean | null)[] = [null]
  show(q[0]) // NULL
}
go()
