// @run
// @log 8161.5
// @log 6000000000
// @log 7
// A `(K | null)[]` list of nullable-scalar VALUE-union elements (rep-fuzz F2, shapes
// `p0c (f64 | null)[]` / `(i64 | null)[]`): each element boxes into the shared union
// box (kind-2 ref list), like `(i32 | null)[]` always did. Two seams broke the f64/i64
// forms: the scalar-list `let` classifiers' INIT fallback claimed the binding as a
// scalar f64/i64 list against its REF-array annotation (slot valtype mismatch with the
// boxed literal — invalid wasm), and `emitArr`'s kind-2 override cleared the f64/string
// literal claims but not the i64 one (an i64-typed first element took the scalar i64-
// list path into a "type not collected" fail).
function go() {
  const v: (f64 | null)[] = [8161.5]
  const t0 = v[0]
  if t0 != null { print(t0) } else { print("NULL") }
  const w: (i64 | null)[] = [6000000000]
  const t1 = w[0]
  if t1 != null { print(t1) } else { print("NULL") }
  const x: (i32 | null)[] = [7]
  const t2 = x[0]
  if t2 != null { print(t2) } else { print("NULL") }
}
go()
