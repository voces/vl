// @run
// @log 0
// REGRESSION PIN: `.pop()` in STATEMENT position on a struct-field array — the
// discarded return value must be dropped, not fail wasm validation. (Forced the
// `let _dropped = T.scopes.pop()` workaround in `compiler/typecheck.vl`, PR #4.)
type Box = { xs: i32[][] }
const b: Box = { xs: [] }
function f(): i32 {
  const inner: i32[] = [1, 2]
  b.xs.push(inner)
  b.xs.pop()
  b.xs.length
}
print(f())
