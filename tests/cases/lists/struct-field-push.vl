// @run
// @log 1
// @log 2
// @log 2
// Push onto a growable `T[]` that lives in a STRUCT FIELD (`obj.field.push(x)`),
// the AST-arena pattern that blocks the self-hosting port — a compiler's node
// arena / symbol table naturally lives in a struct field, not a bare local. The
// object literal `{ nodes: [] }` constructs the field's list from an empty `[]`,
// whose inferred element type is an empty union; reconciling that against the
// declared `i32[]` field used to crash codegen. The list struct is shared by
// reference, so `push`'s in-place `struct.set`s are visible through the field.
type Arena = { nodes: i32[] }

let a: Arena = { nodes: [] }
a.nodes.push(1)
a.nodes.push(2)
print(a.nodes[0])      // 1
print(a.nodes[1])      // 2
print(a.nodes.length)  // 2
