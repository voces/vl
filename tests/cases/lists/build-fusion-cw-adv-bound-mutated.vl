// @run
// @log 3
// @log 0
// @log 2
// ADVERSARIAL: the loop bound `n` is mutated inside the body, so the trip count is
// not the entry value of `n`. Body has an extra statement → must fall back to push.
const a: i32[] = []
let n = 5
let i = 0
while i < n {
  a.push(i)
  n = n - 1
  i = i + 1
}
print(a.length)   // 3 — i<n with n shrinking: 0<5,1<4,2<3, stop
print(a[0])       // 0
print(a[2])       // 2
