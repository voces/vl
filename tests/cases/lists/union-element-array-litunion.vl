// @run
// @log a
// @log 3
// @log NULL
// @log a
// @log 5
// An ARRAY whose ELEMENT is a union carrying litunion members — `(K[] | {w: i32})[]`
// (each element is itself a union box holding an atom LIST or a struct) and
// `(K | i32 | null)[]` (a value-union element with a litunion atom), composed under a
// nullable / an outer union. The element read binds the union box; `is K[]` narrows to
// the kind-7 atom list (indexable, atom widening at print), `is K` to the boxed string
// atom. The array literal's elements adopt their union member-wise in the checker
// (`assignableExpr`'s ArrayLit union arm, recursing element-wise).

type K = "a" | "b"

function go() {
  const xs: (K[] | {w: i32})[] | null = [["a"], { w: 3 }]
  if xs != null {
    const e0 = xs[0]
    if e0 is K[] { print(e0[0]) } else { print("OTHER") } // a
    const e1 = xs[1]
    if e1 is {w: i32} { print(e1.w) } else { print("OTHER") } // 3
  }
  const none: (K[] | {w: i32})[] | null = null
  if none != null { print("SOME") } else { print("NULL") } // NULL
  const v: (K | i32 | null)[] | {w: i32} = ["a", 5]
  const t0 = v
  if t0 is (K | i32 | null)[] {
    const u0 = t0[0]
    if u0 != null {
      if u0 is K { print(u0) } else { print("OTHER") } // a
    } else {
      print("NULL")
    }
    const u1 = t0[1]
    if u1 != null {
      if u1 is i32 { print(u1) } else { print("OTHER") } // 5
    } else {
      print("NULL")
    }
  } else {
    print("OTHER")
  }
}
go()
