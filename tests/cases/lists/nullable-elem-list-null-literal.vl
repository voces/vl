// @run
// @log 1
// @log NULL
// @log NULL
// @log NULL
// @log aa
// @log NULL
// @log 0
// An ALL-`null` literal (`[null]`) under a NICHE-nullable scalar element annotation —
// `(string | null)[]` / `(K | null)[]` / `(boolean | null)[]` — has no rep-classifying
// element, so the emitter's only signal is the checker's CONTEXT-ADOPTION recording
// (`recordNicheNulElemArrayLit`): the destination array type is recorded on the literal
// (and through its grouping Paren chain) at EVERY assignableExpr position — a binding, a
// struct field, a named-function return, a lambda body tail, an argument. The literal then
// builds the niche list (a string-ref list with `ref.null $a` elements / the i32 list with
// the `-1` or 2 sentinel) instead of self-inferring `null[]` and tripping the bare-null
// error. The lambda RESULT adoption (`nulElemListRetName`'s niche leaves) pins the same
// rep for `() => (K | null)[]` closure values, keyed `>a`/`>A` consistently on both sig
// producers.
type K0 = "aa" | "bb"

function mkStr(): (string | null)[] {
  return [null]
}

function useIt(p: () => (K0 | null)[]) {
  const t0 = p()[0]
  if (t0 != null) { print(t0) } else { print("NULL") }
}

const gObj: {a: f64, f: {a: f32, f: (string | null)[], z: i64}, z: i64} = {
  a: 2.5,
  f: { a: 3.5, f: [null], z: 6000000000 },
  z: 6000000000,
}

function go() {
  // A local all-null literal builds the string-ref niche list.
  const v: (string | null)[] = [null]
  print(v.length) // 1
  const t0 = v[0]
  if (t0 != null) { print(t0) } else { print("NULL") } // NULL

  // The named-function return position.
  const r = mkStr()
  const t1 = r[0]
  if (t1 != null) { print(t1) } else { print("NULL") } // NULL

  // The lambda-argument position (expr-bodied tail, the adoption + recording seam).
  useIt(() => ([null])) // NULL

  // A MEMBER-literal lambda body keys the SAME i32 atom-list rep as the annotation side
  // (the sig would else intern the string list and the value call finds no signature).
  const w: () => (K0 | null)[] = () => (["aa"])
  const t2 = w()[0]
  if (t2 != null) { print(t2) } else { print("NULL") } // aa

  // The struct-field-literal position (a global composite init with an all-null field).
  const t3 = gObj.f.f[0]
  if (t3 != null) { print(t3) } else { print("NULL") } // NULL
  print(0) // 0
}
go()
