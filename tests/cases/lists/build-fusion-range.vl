// @run
// @log 5
// @log 0
// @log 40
// @log 100
// Build fusion (positive): `const a = []` then a `for i in A to B` whose body is a
// single `a.push(e)`. Lowering may fuse this into a pre-sized indexed fill, but the
// result must equal the per-element push build exactly — length and the values in
// order.
const a: i32[] = []
for i in 0 to 4 {
  a.push(i * 10)
}
print(a.length)    // 5
print(a[0])        // 0
print(a[4])        // 40
let s = 0
let j = 0
while j < a.length {
  s = s + a[j]
  j = j + 1
}
print(s)           // 100
