// @run
// @log bb
// @log bb
// @log cc
// @log true
// @log false
// @log 6
// @log cc
// A 2-D array whose ELEMENT is an i32-backed scalar list — a literal-union `K[][]` or a
// `boolean[][]` — shares the `i32[][]` rep EXACTLY (element kind 4, the `lTypeIdx` i32-list
// wrapper), because `i32[]`, `boolean[]` and a litunion `K[]` share one i32[] backing. The three
// ref-array classifiers (`nameIsRefArray` / `refArrElemKind` / `refArrElemName`) each special-cased
// only the literal name `"i32[][]"`, so `K[][]` / `boolean[][]` (the R4 fuzz family) were rejected
// ("only i32[] arrays and struct/union element arrays are supported"). One shared predicate
// (`nameIsI32ListArray`) generalizes the arm to the atom/boolean leaf. Covers a param, a local
// (multi-element inner lists), a return, and a struct field; a deeper `i32[][][]` (kind-9 ref
// recursion) still lowers as the control.
type K = "aa" | "bb" | "cc"

// Param position: index the buried atom back out (a void reader — the atom is printed
// directly from the index read, not returned through the call boundary).
function useIt(p: K[][]) {
  print(p[0][1])
}

// Return position: the 2-D array is returned and indexed at the call site.
function mk(): K[][] {
  return [["cc", "aa"]]
}

type Box = { grid: boolean[][] }

function go() {
  useIt([["aa", "bb"]])
  // Local + multi-element inner lists.
  const v: K[][] = [["aa", "cc"], ["bb"]]
  print(v[1][0])
  print(v[0][1])
  // boolean[][] in a struct field.
  const b: Box = { grid: [[true, false]] }
  print(b.grid[0][0])
  print(b.grid[0][1])
  // Control: a deeper i32[][][] (element is itself a ref array, kind 9) still lowers.
  const cube: i32[][][] = [[[6]]]
  print(cube[0][0][0])
}
go()

// Return-position read: index the returned 2-D atom array.
print(mk()[0][0])
