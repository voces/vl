// @run
// @log 3
// @log 0
// @log 2
// ADVERSARIAL: a conditional push means push-count != iteration-count. The fusion
// must NOT fire (body is an `if`, not a bare push); the per-element push build is
// the only correct lowering.
const a: i32[] = []
for i in 0 to 5 {
  if i < 3 {
    a.push(i)
  }
}
print(a.length)   // 3 — not 6
print(a[0])       // 0
print(a[2])       // 2
