// @run
// @log NULL
// @log true
// @log false
// @log zz
// A NULLABLE LIST of structs carrying a typed-value MAP field
// (`{a: f64, f: {[string]: boolean}, z: string}[] | null`): the element shape's
// code-19 map field interns its mv slot and forces the shared map machinery in
// the `collectA` field pass — even when the null carrier is the only value the
// module produces. Both carriers: a bare `null` (the niche `!= null` read), and
// a real list whose narrowed element read chains struct field → fused map get.
function makeNull(): {a: f64, f: {[string]: boolean}, z: string}[] | null {
  return null
}
function makeSome(): {a: f64, f: {[string]: boolean}, z: string}[] | null {
  const h: {[string]: boolean} = Map()
  h["k"] = true
  return [{ a: 1.5, f: h, z: "zz" }]
}
function go() {
  const v = makeNull()
  if v != null { print(v[0].f["k"] ?? true) } else { print("NULL") }
  const w = makeSome()
  if w != null {
    print(w[0].f["k"] ?? false)
    print(w[0].f["nope"] ?? false)
    print(w[0].z)
  } else {
    print("NULL")
  }
}
go()
