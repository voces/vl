// @run
// @log 6
// @log 8
// @log 0
// @log 10
// @log 30
// @log 50
// @log 1
// @log 15
// Push enough struct elements from empty to force a regrow (floor 4, then double
// to 8 on the 5th push), then read elements back across the doubling boundary to
// prove the `array.copy` in the grow path preserved the earlier struct refs (the
// nullable-widened backing copies + narrows soundly). This is the core
// AST-accumulation guarantee: a node pushed before a regrow is still readable
// (and still its non-null struct) afterward.
type Node = { kind: i32, weight: i32 }

const nodes: Node[] = []
let i = 0
while i < 6 {
  nodes.push({ kind: i * 10, weight: i })
  i = i + 1
}

print(nodes.length)   // 6
print(nodes.capacity) // 8 — grew 4 → 8 past the boundary

// Elements pushed before the 4 → 8 regrow survived the copy:
print(nodes[0].kind)  // 0
print(nodes[1].kind)  // 10
print(nodes[3].kind)  // 30
print(nodes[5].kind)  // 50  — last, pushed after the regrow

// Iterate (for-in reads the backing) and sum a field to prove all 6 survived.
const firstWeight = nodes[1].weight
print(firstWeight)    // 1

let total = 0
for n in nodes {
  total = total + n.weight
}
print(total)          // 0+1+2+3+4+5 = 15 — for-in read all 6 survivors
