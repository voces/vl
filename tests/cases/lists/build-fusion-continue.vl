// @run
// @log 4
// @log 99
// @log 4
// The fused result is an ordinary List: pushing more after the build works and
// reuses the spare capacity (len 3, cap 4 → push fits without a regrow).
const a: i32[] = []
for i in 0 to 2 {
  a.push(i)
}
a.push(99)
print(a.length)   // 4
print(a[3])       // 99
print(a.capacity) // 4
