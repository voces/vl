// @run
// @log 4
// @log 99
// @log 0
// @log 1
// The fused result is an ordinary List: pushing more after the build works, and all
// elements (built + appended) read back correctly.
const a: i32[] = []
for i in 0 to 2 {
  a.push(i)
}
a.push(99)
print(a.length)   // 4
print(a[3])       // 99 — appended after the fused build
print(a[0])       // 0  — built element
print(a[1])       // 1
