// @run
// @log 1
// @log 2
// @log 2
// Pushing struct/reference elements into a growable `T[]` (the AST-accumulation
// pattern that blocks the H3 self-hosting port — e.g. `nodes.push(astNode)`).
// A `Node[]` backing array's slot type is `(ref $Node)`, which is *non-defaultable*,
// so the grow path's `array.new_default` used to reject it. The backing is now
// nullable-widened to `(ref null $Node)` (default `ref.null`); reads off the live
// `[0, len)` region narrow back with `ref.as_non_null`, so the surface element
// type stays the non-null `Node`.
type Node = { kind: i32 }

const xs: Node[] = []
xs.push({ kind: 1 })
xs.push({ kind: 2 })
print(xs[0].kind) // 1
print(xs[1].kind) // 2
print(xs.length)  // 2
