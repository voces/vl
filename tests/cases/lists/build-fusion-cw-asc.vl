// @run
// @log 5
// @log 0
// @log 4
// @log 5
// Counter-while build (positive): `const a = []; let i = 0; while i < N { a.push(e); i = i + 1 }`
// — the dominant build idiom. Fuses like a for-range; the counter's post-loop value
// must be preserved (i == N after the loop).
const a: i32[] = []
let i = 0
while i < 5 {
  a.push(i)
  i = i + 1
}
print(a.length)   // 5
print(a[0])       // 0
print(a[4])       // 4
print(i)          // 5 — counter left at its post-loop value
