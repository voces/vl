// @run
// @log a
// @log b
// @log x
// @log y
// @log p
// A nullable literal-union list (`K[] | null`, inline `("x"|"y")[] | null`) rides the SAME nullable
// i32-list rep as `i32[] | null` / `boolean[] | null`: a litunion's atoms are interned i32 ids, so its
// list shares the i32-list backing exactly (the nullable dual of `nameIsI32Array`'s litunion arm). It
// round-trips as a binding AND as a struct field; `if xs != null` narrows off the nullable niche and the
// index read yields the atom. (Scalar-elem `f64[]|null` / ref-elem `S[]|null` keep a distinct backing —
// still a loud reject.)

type K = "a" | "b"

function go() {
  const xs: K[] | null = ["a", "b"]
  if xs != null {
    print(xs[0]) // a
    print(xs[1]) // b
  }
  const ys: ("x" | "y")[] | null = ["x", "y"]
  if ys != null {
    print(ys[0]) // x
    print(ys[1]) // y
  }
  const o: { f: K[] | null } = { f: ["a", "b"] }
  if o.f != null { print("p") } // p — the field narrows off the niche
}
go()
