// @run
// @log aa
// @log NULL
// @log 5
// @log NULL
// A list whose ELEMENT is a NULLABLE map (`({[string]: V} | null)[]`): a MAP ref list
// (element kind 3) whose slot key keeps the `| null` — the backing is the same
// `(ref null $mapStruct)` the non-null map element uses (the nullable-map dual of the
// `(P | null)[]` struct niche; `rlElemNullable` drives the nullable index read + the
// `[null]` literal element, which lowers as `ref.null $mapStruct`). `const e = xs[i]`
// binds kind `nulmap` and narrows with `!= null`; the narrowed map ops read the
// element's value rep (a typed atom map here, the mono i32 map for the i32 case).
type K0 = "aa" | "bb"
function go() {
  const h: {[string]: K0} = Map()
  h["k"] = "aa"
  const xs: ({[string]: K0} | null)[] = [h]
  const t0 = xs[0]
  if t0 != null {
    print(t0["k"] ?? "bb")
  } else {
    print("NULL")
  }
  const ys: ({[string]: K0} | null)[] = [null]
  const t1 = ys[0]
  if t1 != null {
    print(t1["k"] ?? "bb")
  } else {
    print("NULL")
  }
  const hi: {[string]: i32} = Map()
  hi["k"] = 5
  const zs: ({[string]: i32} | null)[] = [hi, null]
  const t2 = zs[0]
  if t2 != null {
    print(t2["k"] ?? 0)
  } else {
    print("NULL")
  }
  const t3 = zs[1]
  if t3 != null {
    print(t3["k"] ?? 0)
  } else {
    print("NULL")
  }
}
go()
