// @run
// @log 3
// @log 30
// @log 10
// @log -1
// @log 20
// @log -1
// @log 1
// @log 2
// @log 2
// The nullable-returning (`pop`/`get`) and copying (`map`) list paths over struct
// elements: each reads a backing slot whose widened `(ref null $T)` type is
// narrowed back to the non-null `$T`. `.get(i)` and `pop()` return `Node | null`
// (narrowed via `if x != null`); `map` allocates a fresh struct backing via
// `array.new_default` (now legal — the slot defaults to `ref.null`).
type Node = { id: i32 }

const xs: Node[] = []
xs.push({ id: 10 })
xs.push({ id: 20 })
xs.push({ id: 30 })
print(xs.length)              // 3

// pop returns the last struct (Node | null), narrowed with `if`.
const last = xs.pop()
if last != null {
  print(last.id)             // 30
}

// checked .get(i): in range yields the struct; OOB yields null.
const first = xs.get(0)
if first != null {
  print(first.id)            // 10
} else {
  print(-1)
}
const oob = xs.get(9)
if oob != null {
  print(oob.id)
} else {
  print(-1)                  // -1 — OOB
}

// .get after the pop: index 1 still present, index 2 gone (len shrank to 2).
const g1 = xs.get(1)
if g1 != null {
  print(g1.id)               // 20
} else {
  print(-1)
}
const g2 = xs.get(2)
if g2 != null {
  print(g2.id)
} else {
  print(-1)                  // -1 — popped
}

// map over a struct list — the source reads each `(ref null $Node)` slot and
// narrows it before the callback (struct -> i32 here, extracting the field):
const ids: Node[] = []
ids.push({ id: 1 })
ids.push({ id: 2 })
const extracted = ids.map(function(n: Node) n.id)
print(extracted[0])          // 1
print(extracted[1])          // 2
print(extracted.length)      // 2
