// @run
// @log aa
// @log 1
// @log bb
// @log 2
// @log bb
// @log aa
// @log 1
// @log aa
// @log bb
// @log 3
// @log aa
// A LITERAL-UNION array literal (`const ks: K[] = ["aa", "bb"]`) IS the i32 atom-id list —
// the checker adopts the annotation's `K[]` onto the literal node (its elements are string
// exprs syntactically, so its own type is `string[]`), and `arrLitIsStr` defers to that
// recorded type. Previously the literal claimed the STRING-list slot/collect/build while
// every consumer (a `: K` binding, a `K` param, `==` member compare, the for-in loop var's
// atom flag) read the i32 atom rep — invalid wasm. Covers local + global bindings, the
// call-arg and return positions, indexed reads, for-in (function-body AND top-level — the
// start-fn locals pass classifies its own loop vars), and a plain `string[]` control.
type VK = "aa" | "bb"

function useK(k: VK): i32 {
  if k == "aa" { return 1 }
  return 2
}

function mk(): VK[] {
  return ["bb", "aa"]
}

const g: VK[] = ["aa", "bb"]

function go(ks: VK[]) {
  for k in ks {
    print(k)
    print(useK(k))
  }
  const made = mk()
  print(made[0])
  const s: VK = made[1]
  print(s)
  print(useK(g[0]))
}
go(["aa", "bb"])

// Top-level (start-fn) for-in over the global: the loop var is the same i32 atom.
for k in g {
  print(k)
}

// Control: a plain string[] literal keeps the string-list rep.
const strs: string[] = ["cc"]
print(strs.length + 2)
if strs[0] == "cc" { print("aa") } else { print("bb") }
