// @run
// @log 5
// @log 0
// @log 8
// @log 10
// ADVERSARIAL: the counter is advanced twice per iteration. A naive matcher that
// read the stride from the first increment (+1) would count 10 and push 0..9; the
// true behavior strides by 2. Body is not [push, single increment] → must fall back.
const a: i32[] = []
let i = 0
while i < 10 {
  a.push(i)
  i = i + 1
  i = i + 1
}
print(a.length)   // 5 — 0,2,4,6,8
print(a[0])       // 0
print(a[4])       // 8
print(i)          // 10
