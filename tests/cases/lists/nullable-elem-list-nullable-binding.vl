// @run
// @log ndh
// @log NULL
// @log false
// @log N0
// @log x
// @log NONE
// A NULLABLE binding OVER a niche-nullable-element list — `(K | null)[] | null`,
// `(boolean | null)[] | null`, `(string | null)[] | null` (the fuzzer's p3r `(K0 |
// null)[] | null`). The i32-backed elements' null rides IN the i32 (the `-1` / 2
// sentinel), so the OUTER `| null` is the same `(ref null $lTypeIdx)` nullist niche as
// `i32[] | null` — `nodeTyIsNulI32List` admits the niche-nullable elements structurally;
// the string form rides `nulstrlist` over the shared `$mkListIdx` wrapper. A narrowed
// receiver's ELEMENT read classifies through the peeled receiver type
// (`nodeArrayElemPeelTy`), so `t0[0]` binds the scalar `K | null` / `boolean | null` /
// `string | null` niche and `!= null` compares the sentinel (or `ref.is_null`).
type K0 = "488" | "ndh"
const g: (K0 | null)[] | null = ["ndh", null]

function go() {
  const t0 = g
  if (t0 != null) {
    const t1 = t0[0]
    if t1 != null { print(t1) } else { print("NULL") } // ndh
    const t2 = t0[1]
    if t2 != null { print(t2) } else { print("NULL") } // NULL
  } else {
    print("NONE")
  }

  const b: (boolean | null)[] | null = [false, null]
  const b0 = b
  if b0 != null {
    const b1 = b0[0]
    if b1 != null { print(b1) } else { print("NULL") } // false
    if b0[1] == null { print("N0") } // N0
  } else {
    print("NONE")
  }

  const s: (string | null)[] | null = ["x"]
  const s0 = s
  if s0 != null {
    const s1 = s0[0]
    if s1 != null { print(s1) } else { print("NULL") } // x
  } else {
    print("NONE")
  }

  const e: (K0 | null)[] | null = null
  if e != null { print(e.length) } else { print("NONE") } // NONE
}
go()
