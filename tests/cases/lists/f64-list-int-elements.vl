// @run
// @log 2
// @log -2
// @log 3.5
// @log 7
// @log 6
// @log 255
// An INT-element literal under an `f64[]` annotation: the annotation is authoritative
// (`pendingListKind` 4 forces the f64 backing for a NON-empty literal too, mirroring the
// i64/f32 kinds), each element re-encoding exactly — a bare int literal directly as
// `f64.const`, which also keeps a CONST-GLOBAL init a valid constexpr. Without this
// `const xs: f64[] = [2]` built the i32-backed wrapper against the f64-list slot
// (invalid wasm); the global spelling emitted a non-constant `f64.convert_i32_s`.

const g: f64[] = [2]
print(g[0])

const gn: f64[] = [-2]
print(gn[0])

function go() {
  const xs: f64[] = [2, 3.5]
  print(xs[1])

  const ys: f64[] = [7]
  print(ys[0])

  ys.push(6)
  print(ys[1])

  const hx: f64[] = [0xFF]
  print(hx[0])
}
go()
