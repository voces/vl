// @run
// @log nbbf
// @log a
// @log NULL
// @log c
// @log z
// @log NULL
// @log c
// A `(string | null)[]` — a list of the string ref made nullable. A `string[]` element is ALREADY a
// `(ref null $aTypeIdx)` string ref at the wasm level, so the nullable-element list shares the EXACT
// string-list backing (`$mkListIdx` wrapper), NOT a union box (`string | null` is a ref niche, not a
// value union). Construct (mixed + `null`), element read (kept `(ref null)` = a `nulstr`), the
// `!= null` narrow, and non-null `.push` / index-assign all round-trip. (A `null` `.push` / index-
// assign stays a clean loud reject — the string-push scratch path is left for a follow-up.)
function first(p: (string | null)[]) {
  const t0 = p[0]
  if t0 != null { print(t0) } else { print("NULL") }
}
function show(t: string | null) {
  if t != null { print(t) } else { print("NULL") }
}
function go() {
  first(["nbbf"]) // nbbf
  const xs: (string | null)[] = ["a", null, "c"]
  show(xs[0]) // a
  show(xs[1]) // NULL
  show(xs[2]) // c
  xs.push("b")
  xs[0] = "z"
  show(xs[0]) // z
  show(xs[1]) // NULL
  show(xs[2]) // b
}
go()
