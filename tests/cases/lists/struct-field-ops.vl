// @run
// @log 3
// @log 99
// @log 30
// @log 2
// @log 0
// The other mutating list ops on a struct-field array share the same lvalue
// gap as `push`: index-assign (`obj.field[i] = v`), `pop()`, and `clear()` all
// mutate the list struct in place through the field. Struct elements too
// (`Node[]` field), to cover the non-defaultable-ref backing alongside i32.
type Node = { id: i32 }
type Arena = { nodes: Node[] }

const a: Arena = { nodes: [] }
a.nodes.push({ id: 10 })
a.nodes.push({ id: 20 })
a.nodes.push({ id: 30 })
print(a.nodes.length)        // 3

// index-assign through the field, then read back.
a.nodes[0] = { id: 99 }
print(a.nodes[0].id)         // 99

// pop the last element through the field (Node | null, narrowed).
const last = a.nodes.pop()
if last != null {
  print(last.id)             // 30
}
print(a.nodes.length)        // 2 — pop shrank the field's list

// clear through the field retains capacity but empties length.
a.nodes.clear()
print(a.nodes.length)        // 0
