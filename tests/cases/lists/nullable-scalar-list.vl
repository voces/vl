// @run
// @log NULL
// @log hi
// @log 65.5
// @log 976189674125056329
// @log 9838969
// @log 3.5
// @log NULL
// A DISTINCT-backing nullable scalar list (`string[]|null`, `f64[]|null`, `i64[]|null`,
// `f32[]|null`) — each leaf's own `(ref null $wrapper)` niche over the leaf-list wrapper (the
// nullable dual of the i32-backed `i32[]|null`). A bare `= null` init/return is `ref.null $wrapper`;
// a list value stores its (non-null) wrapper ref, which subtypes the nullable slot; `t != null`
// narrows and `t[i]` recovers non-null before the element read. Covers the local (bare-null),
// return, global, and small-literal-into-i64/f32 (the const-global wrapper-build) positions.

// LOCAL bound to a bare `null`.
function go0() {
  const v: string[] | null = null
  const t0 = v
  if t0 != null { print(t0[0]) } else { print("NULL") } // NULL
}
go0()

// LOCAL string list value.
function go1() {
  const v: string[] | null = ["hi", "yo"]
  const t0 = v
  if t0 != null { print(t0[0]) } else { print("NULL") } // hi
}
go1()

// RETURN position — a function returning `f32[] | null`, bound + read.
function mkF32(): f32[] | null { return [65.5] }
function go2() {
  const v = mkF32()
  if v != null { print(v[0]) } else { print("NULL") } // 65.5
}
go2()

// GLOBAL — a large i64 list, and a SMALL i64 literal (the const-cell wrapper-build edge).
const gBig: i64[] | null = [976189674125056329]
const gSmall: i64[] | null = [9838969]
function go3() {
  const a = gBig
  const b = gSmall
  if a != null { print(a[0]) } else { print("NULL") } // 976189674125056329
  if b != null { print(b[0]) } else { print("NULL") } // 9838969
}
go3()

// f64 list local + a `null`-returning function (the `ref.null` return path).
function mkF64(): f64[] | null { return null }
function go4() {
  const v: f64[] | null = [3.5, 4.5]
  if v != null { print(v[0]) } else { print("NULL") } // 3.5
  const w = mkF64()
  if w != null { print(w[0]) } else { print("NULL") } // NULL
}
go4()
