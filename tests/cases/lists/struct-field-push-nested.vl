// @run
// @log 2
// @log 7
// @log 8
// @log 1
// @log 42
// The struct-field array comes from a FUNCTION (a constructor returning the
// arena) and from a DEEPER field-of-field nesting (`w.arena.nodes`). Both
// build the inner `{ nodes: [] }` via an object literal whose empty-array field
// must reconcile to the declared list type — the deeper nesting exercises the
// recursive reconciliation, which must not crash descending through a nested
// degenerate empty-`[]` field.
type Node = { id: i32 }
type Arena = { nodes: Node[] }
type Wrap = { arena: Arena }

function makeArena(): Arena {
  return { nodes: [] }
}

let a = makeArena()
a.nodes.push({ id: 7 })
a.nodes.push({ id: 8 })
print(a.nodes.length)        // 2
print(a.nodes[0].id)         // 7
print(a.nodes[1].id)         // 8

let w: Wrap = { arena: { nodes: [] } }
w.arena.nodes.push({ id: 42 })
print(w.arena.nodes.length)  // 1
print(w.arena.nodes[0].id)   // 42
