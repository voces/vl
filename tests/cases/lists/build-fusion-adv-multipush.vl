// @run
// @log 6
// @log 0
// @log 10
// @log 12
// ADVERSARIAL: two pushes per iteration. Fusion must not assume one-push-per-iter
// (that would under-size and mis-order); body is not a single push → fall back.
const a: i32[] = []
for i in 0 to 2 {
  a.push(i)
  a.push(i + 10)
}
print(a.length)   // 6
print(a[0])       // 0
print(a[1])       // 10
print(a[5])       // 12
