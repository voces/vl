// @run
// @log a
// @log NULL
// @log b
// @log b
// @log NULL
// @log 4
// @log NULL
// A `(K | null)[]` — a list of the litunion atom NICHE (member ids ≥ 0, the spare value -1 = null),
// repped as a plain i32 list (the SAME backing as `K[]` / `i32[]`), NOT a union box. Scalar `K | null`
// is itself an i32 niche, so boxing the element would rep-split the type name; the niche list keeps ONE
// rep. Construct (mixed, member-FIRST `["a", null]`, and all-`null`), element read, `!= null` narrow,
// `.push("a")` / `.push(null)`, and `p[i] = "b"` / `p[i] = null` all round-trip through the sentinel.
// (Ref-elem `S[]|null` and the nullable-OUTER read `(K|null)[] | null` keep their distinct/loud paths.)
type K = "a" | "b" | "c"

function show(t: K | null) {
  if t != null {
    print(t)
  } else {
    print("NULL")
  }
}
function go() {
  // member-FIRST literal — the atom path is authoritative even though `["a", …]` reads
  // string-first (which the string-list classifier would otherwise claim).
  const p: (K | null)[] = ["a", null, "b"]
  show(p[0]) // a
  show(p[1]) // NULL — the -1 sentinel narrows to null
  show(p[2]) // b
  p[1] = "b"
  show(p[1]) // b
  p[0] = null
  show(p[0])      // NULL
  p.push(null)
  print(p.length) // 4
  // all-`null` literal (self-infers `null[]`, typed by the annotation).
  const q: (K | null)[] = [null]
  show(q[0]) // NULL
}
go()
