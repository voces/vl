// @emit-error a nullable-boolean list element has no rep
// A `(boolean | null)[]` element is a NICHE nullable (one non-null member + null —
// deliberately not a value union, so it has NO list rep); constructing the list is a
// loud EMIT-stage reject, never invalid wasm (the rep-fuzz wave-4 finding, previously
// pinned only in the fuzz baseline because the corpus could not assert emit errors).
function go() {
  const xs: (boolean | null)[] = [true, null]
  print(xs.length)
}
go()
