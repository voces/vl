// @run
// @log 10
// @log 16
// @log 0
// @log 18
// @log 90
// Push enough onto a struct-field `i32[]` to force two regrows (floor 4 → 8 →
// 16), then read elements back across the doubling boundaries. This proves the
// grown list is still seen THROUGH the field: `push` grows the backing in place
// on the shared list struct, so a regrow that reallocates the backing array is
// still observed by later `obj.field[i]` reads (the field holds the list struct
// by reference; the backing pointer it carries is updated in place).
type Arena = { nodes: i32[] }

let a: Arena = { nodes: [] }
let i = 0
while i < 10 {
  a.nodes.push(i * 2)
  i = i + 1
}

print(a.nodes.length)   // 10
print(a.nodes.capacity) // 16 — grew 4 → 8 → 16 past two boundaries
print(a.nodes[0])       // 0  — pushed before any regrow, survived both
print(a.nodes[9])       // 18 — last, pushed after the final regrow

// Sum through the field to prove all ten survived the reallocations.
let total = 0
let j = 0
while j < a.nodes.length {
  total = total + a.nodes[j]
  j = j + 1
}
print(total)            // 2*(0+1+...+9) = 2*45 = 90 — all ten survived
