// @run
// @log 3
// @log 0
// @log 10
// Reference (struct) elements: the backing is a nullable-ref array; every slot is
// written, and index reads narrow back to non-null.
const a: {v: i32}[] = []
for i in 0 to 2 {
  a.push({v: i * 5})
}
print(a.length)   // 3
print(a[0].v)     // 0
print(a[2].v)     // 10
