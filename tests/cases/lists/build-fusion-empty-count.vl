// @run
// @log 0
// @log 0
// A zero-iteration build leaves the list empty (length 0, capacity 0) — same as no
// pushes at all. `n` is runtime so the range isn't statically flagged empty.
const n = 0 - 1
const a: i32[] = []
for i in 0 to n {
  a.push(i)
}
print(a.length)    // 0
print(a.capacity)  // 0
