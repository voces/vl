// @run
// @log 4
// @log 0
// @log 3
// ADVERSARIAL: the pushed expression reads `a` (its growing length). A fused fill
// that pre-sets len would observe the wrong value mid-build → fusion must not fire
// when `e` references the list being built.
const a: i32[] = []
for i in 0 to 3 {
  a.push(a.length)
}
print(a.length)   // 4
print(a[0])       // 0 — length was 0 at first push
print(a[3])       // 3 — length was 3 at last push
