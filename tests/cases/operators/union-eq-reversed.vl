// @run
// @log 1
// @log 1
// @log 2
// @log 2
// @log 2
// @log 1
// Equality is symmetric, so `==`/`!=` accept a value-union on EITHER operand:
// `v == 7` and `7 == v` must both type-check and run identically. Codegen (PR
// #200) already lowers both orders; this case pins the checker's symmetry.

// The box holds the `7` arm, so both orders are true.
const v: "x" | 7 = 7
if 7 == v { print(1) } else { print(2) }   // 1 (reversed)
if v == 7 { print(1) } else { print(2) }   // 1 (forward) — already worked

// The box holds the `"x"` arm, so both orders are false.
const w: "x" | 7 = "x"
if 7 == w { print(1) } else { print(2) }   // 2 (reversed, different arm)
if w == 7 { print(1) } else { print(2) }   // 2 (forward, different arm)

// `!=` reversed is the negation of `==` reversed.
if 7 != v { print(1) } else { print(2) }   // 2 (v holds 7, so `!=` is false)
if 7 != w { print(1) } else { print(2) }   // 1 (w holds "x", so `!=` is true)
