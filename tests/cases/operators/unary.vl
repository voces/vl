// @run
// @log 6
// @log 6
// @log 7
// @log 6
// @log 4
// @log true
// @log false
// Unary operators (ROADMAP B10): prefix/postfix `++`/`--` mutate a variable —
// prefix yields the new value, postfix the old; `!` is logical not on a boolean.
// `print` renders the boolean results of `!` directly.
let x = 5
print(++x)
print(x++)
print(x)
print(--x)
let n = 0
let i = 0
while i < 4 {
  n++
  i++
}
print(n)
print(!(2 > 3))
print(!(5 > 3))
