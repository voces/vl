// @run
// @log 6
// @log 6
// @log 7
// @log 6
// @log 4
// @log 10
// Unary operators (ROADMAP B10): prefix/postfix `++`/`--` mutate a variable —
// prefix yields the new value, postfix the old; `!` is logical not on a boolean
// (an i32 0/1).
let x = 5
__store_i32__(0, 0)
__store_i32__(4, ++x)
__log__(0, 8)
__store_i32__(4, x++)
__log__(0, 8)
__store_i32__(4, x)
__log__(0, 8)
__store_i32__(4, --x)
__log__(0, 8)
let n = 0
let i = 0
while i < 4 {
  n++
  i++
}
__store_i32__(4, n)
__log__(0, 8)
let t = 0
if !(2 > 3) { t = t + 10 }
if !(5 > 3) { t = t + 100 }
__store_i32__(4, t)
__log__(0, 8)
