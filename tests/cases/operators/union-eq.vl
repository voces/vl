// @run
// @log 2
// @log 1
// @log 1
// @log 2
// @log 2
// @log 1
// @log 30
// `==`/`!=` are structural (by value), so they work directly on a value-union
// operand: `v == 7` is true iff the box `v` currently holds a value structurally
// equal to `7`. The comparison reads the box's tag (to pick the matching arm)
// and value-compares the unboxed payload — a cross-type arm (a `string` held vs.
// an `i32` compared) is structurally unequal. Shown on a mixed-rep boxed union
// (`string | i32`), with both `==` and `!=`.

// The product owner's repro: the box holds the `"x"` arm, so `v == 7` is false.
const v: "x" | 7 = "x"
if v == 7 { print(1) } else { print(2) }   // 2

// The other arm: the box holds `7`, so `v2 == 7` is true.
const v2: "x" | 7 = 7
if v2 == 7 { print(1) } else { print(2) }  // 1

// `!=` is the negation: `v != 7` is true (it holds `"x"`).
if v != 7 { print(1) } else { print(2) }   // 1
// `v2 != 7` is false (it holds `7`).
if v2 != 7 { print(1) } else { print(2) }  // 2

// union == union: equal iff the same arm (tag) holds AND the unboxed payloads
// are structurally equal. Short-circuits the right payload's unbox on its tag.
function ueq(a: "x" | 7, b: "x" | 7) {
  if a == b { print(1) } else { print(2) }
}
ueq(v, v2)   // 2 ("x" vs 7 — different arm)
ueq(v2, v2)  // 1 (both 7)

// Regression guard: a same-rep literal union (`0 | 1 | 2`) still compares fine
// through the existing literal-union path (collapses to a bare `i32`).
function score(x: 0 | 1 | 2) {
  if x == 0 { return 10 }
  else if x == 1 { return 20 }
  return 30
}
print(score(2))   // 30
