// @run
// @log num
// @log str
// Explicit-type-param analogue of soundness/is-generic-param-sound: an `is` guard
// on a generic parameter `T` is decided statically per monomorphized call site.
function describe<T>(x: T) {
  if x is i32 { return "num" }
  return "str"
}
print(describe(5))
print(describe("hi"))
