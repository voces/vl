// @run
// @log 7
// @log 7
// @log 42
// A generic call used as the ARGUMENT to another generic call (`box(box(7))`) — the inner
// instance's return STRUCT becomes the outer's type-param binding. Was rejected ("field
// access receiver is not a struct"): `monoWalk` instantiates the inner call first (args-first),
// but during monomorphization the instance's `fRet*` / struct tables are not built yet
// (buildFnMap is post-mono), so `monoArgTyName` could not classify the struct return and the
// type param defaulted to i32 — the outer field came out i32 and `.v.v` failed.
//
// `monoArgTyName` now resolves a call argument's type from the callee's already-substituted
// return ANNOTATION (and an ident bound to such a call via its `let` init), so the nested bind
// resolves. (3-deep nesting is bounded by the SEPARATE general nested-struct-field depth limit,
// which caps hand-written `{v:{v:{v:i32}}}` too.)

function box<T>(x: T): { v: T } { return { v: x } }
function wrap<T>(x: T): { item: T } { return { item: x } }

function go() {
  // direct double-nesting.
  print(box(box(7)).v.v) // 7

  // via an intermediate local (the outer arg is an ident, not a call).
  const inner = box(7)
  const outer = box(inner)
  print(outer.v.v) // 7

  // a different generic, bound + field-accessed.
  const w = wrap(wrap(42))
  print(w.item.item) // 42
}
go()
