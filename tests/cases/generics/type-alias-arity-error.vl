// @check
// @error expects 2 type arguments but got 1
// A generic alias must be applied with exactly its declared number of type
// arguments. `Pair<i32>` is missing `B`, so it is a clean arity diagnostic — not
// a crash or a silently-half-applied type.
type Pair<A, B> = { a: A, b: B }

let p: Pair<i32> = { a: 1, b: 2 }
