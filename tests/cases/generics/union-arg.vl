// @run
// @log 5
// @log 9
// @log 7
// A generic instantiated at a UNION type argument — `id<T>(v: T): T` called with a
// `Cat | Dog` (inline or alias) or a value union (`i32 | string`). `monoArgTyName` resolved a
// struct / struct-array annotation but not a union one, so the type param defaulted to i32 and
// the call failed. It now binds `T` to the union NAME (`isUName` — a registered inline union or a
// `type … = … | …` alias), so the instance's param/return ride the union box and the result
// narrows with `is`. Continues #599 / #600 / #602.

type Cat = { meow: i32 }
type Dog = { bark: i32 }
type Animal = Cat | Dog

function id<T>(v: T): T { return v }

function go() {
  // an INLINE struct-union annotation.
  const a: Cat | Dog = { meow: 5 }
  const ra = id(a)
  if ra is Cat {
    print(ra.meow) // 5
  } else {
    print(-1)
  }

  // a union ALIAS.
  const b: Animal = { bark: 9 }
  const rb = id(b)
  if rb is Dog {
    print(rb.bark) // 9
  } else {
    print(-1)
  }

  // a VALUE union.
  const c: i32 | string = 7
  const rc = id(c)
  if rc is i32 {
    print(rc) // 7
  } else {
    print(-1)
  }
}
go()
