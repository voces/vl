// @run
// @log 1
// @log 2
// @log 5
// Trailing comma in generic type-argument lists (`Pair<i32, i32,>`) and in a
// type-parameter list (`function id<T,>(...)`). One trailing `,` before `>` is
// allowed and ignored, leaving arity and instantiation unchanged.
type Pair<A, B> = { a: A, b: B }
function id<T,>(x: T) x
let p: Pair<i32, i32,> = { a: 1, b: 2 }
print(p.a)
print(p.b)
print(id(5))
