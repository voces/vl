// @run
// @log 7
// @log 8
// @log 5
// @log 42
// A generic instantiated at a struct type whose ARGUMENT is an INDEX (`id(xs[0])`) or a struct
// FIELD (`id(o.inner)`), not a bare local. `monoArgTyName` runs before `buildLocals`, so the
// `structIndexOfExpr` classifiers can't see those forms and the type param defaulted to i32
// ("field access receiver is not a struct"). It now resolves the array's ELEMENT struct (strip
// `[]` off the annotation) and a nested-struct field's TARGET struct (the struct table's code-15
// `sFieldElemName`) — recursively, so a deep chain (`o.inner.deep`) resolves level by level.
// Continues #599 (bare struct) / #600 (struct array).

type D = { n: i32 }
type Inner = { deep: D, v: i32 }
type Outer = { inner: Inner }

type P = { x: i32 }

function id<T>(v: T): T { return v }

function go() {
  // INDEX argument — an element of a struct array.
  const xs: P[] = [{ x: 7 }, { x: 8 }]
  print(id(xs[0]).x) // 7
  const i = 1
  print(id(xs[i]).x) // 8

  // MEMBER argument — a nested struct field.
  const o: Outer = { inner: { deep: { n: 42 }, v: 5 } }
  print(id(o.inner).v) // 5

  // a DEEP member chain — each level resolves recursively.
  print(id(o.inner.deep).n) // 42
}
go()
