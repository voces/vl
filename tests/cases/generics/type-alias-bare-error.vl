// @check
// @error-at 8:7 Generic type `Box` expects type arguments but was used without any
// A bare reference to a generic alias with NO type arguments is an error: the
// alias needs its parameter to become a concrete type. Reported cleanly rather
// than leaving an unresolved hole (or crashing). Positioned at the annotation
// (the `let`'s TypeRef, anchored through `annotDiagAt`).
type Box<T> = { value: T }

let b: Box = { value: 5 }
