// @run
// @log 1
// @log two
// Two DISTINCT type parameters: `type Pair<A, B> = { a: A, b: B }`. Each names
// its own shared hole, so `Pair<i32, string>` substitutes `A` -> i32 and
// `B` -> string independently. The fields keep their distinct types.
type Pair<A, B> = { a: A, b: B }

let p: Pair<i32, string> = { a: 1, b: "two" }
print(p.a)
print(p.b)
