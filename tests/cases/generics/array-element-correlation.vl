// @check
// @error expected i32
// The element type is inferred from the argument array and correlated to the
// return: `first(["s"])` pins `T` to string, so its result is a string. The
// element inference would be unsound if it silently widened `T` to a hole that
// accepts anything — assigning the string result to an `i32` must be rejected.
function first<T>(xs: T[]): T xs[0]
let n: i32 = first(["s"])
