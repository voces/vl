// @run
// @log 5
// @log hi
// Explicit type parameter (A10 stage 1): `T` names a single shared inference
// hole spanning the param annotation and the return. The existing per-call
// monomorphization instantiates it at i32 and string from the two call sites.
function id<T>(x: T): T x
print(id(5))
print(id("hi"))
