// @run
// @log 1
// @log 2
// @log 3
// @log a
// @log b
// `for x in xs` iterates a generic array inside `function f<T>(xs: T[])`. The
// loop variable `x` takes the inferred element type `T`, monomorphized at i32
// and string from the two call sites; `print(x)` resolves per instance.
function printAll<T>(xs: T[]) {
  for x in xs {
    print(x)
  }
}
printAll([1, 2, 3])
printAll(["a", "b"])
