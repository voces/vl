// @run
// @log 7
// @log yo
// A generic alias applied with a function type parameter ties the alias
// machinery to Stage 1/2 inference: `unwrap<T>(b: Box<T>): T` annotates its
// parameter as `Box<T>`, where `T` is the function's own shared hole. Applying
// the alias substitutes that *same* hole into the body's `value` field, so the
// parameter and the return stay correlated — `T` is inferred per call site from
// the argument's element type (i32, then string).
type Box<T> = { value: T }

function unwrap<T>(b: Box<T>): T b.value

const bi: Box<i32> = { value: 7 }
print(unwrap(bi))

const bs: Box<string> = { value: "yo" }
print(unwrap(bs))
