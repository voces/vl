// @run
// @log 5
// @log a
// @log 1.5
// @log 9
// @log 3
// @log b
// @log 2
// A GENERIC function's BODY may now name its type parameter in a `LetDecl` annotation
// (`const x: T`, `const out: T[]`). The type params are kept in scope while the body is
// checked (so `T` resolves instead of failing "unknown type 'T'"), and the monomorphizer
// rewrites the instance body's annotations through the binding (`const out: T[]` →
// `const out: f64[]`) — reusing the concrete annotated path for EVERY element type, rather
// than per-rep usage inference. The clone touches only the statement spine; leaf
// expressions (including any nested lambda) are shared, so nothing needs re-lifting.

// An annotated LOCAL of the element type — i32 / string / f64.
function first<T>(self: T[]): T {
  const x: T = self[0]
  return x
}
print(first([5, 6]))       // 5
print(first(["a", "b"]))   // a
print(first([1.5, 2.5]))   // 1.5

// An annotated BUILD `const out: T[] = []` — i32 / string / struct (the generic build
// reuses the concrete `T[]` path; reverse builds a fresh list).
function reverse<T>(self: T[]): T[] {
  const out: T[] = []
  let i = self.length - 1
  while i >= 0 {
    out.push(self[i])
    i = i - 1
  }
  return out
}
print(reverse([7, 8, 9])[0])           // 9  (reversed [7,8,9] → [9,8,7], [0] = 9)
print(reverse([1, 2, 3]).length)       // 3
print(reverse(["a", "b"])[0])          // b
type P = { v: i32 }
print(reverse([{ v: 1 }, { v: 2 }])[0].v) // 2
