// @run
// @log x
// @log 1
// Two DISTINCT type parameters (`A`, `B`) instantiated at i32 + string. The
// returned object swaps them, so `first` carries B (string) and `second` A (i32).
function swap<A, B>(a: A, b: B): {first: B, second: A} { first: b, second: a }
let s = swap(1, "x")
print(s.first)
print(s.second)
