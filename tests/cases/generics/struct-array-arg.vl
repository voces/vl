// @run
// @log 7
// @log 9
// @log 7
// A generic over arrays (`first<T>(xs: T[]): T`) instantiated at a STRUCT element type — the
// argument is a struct-array LOCAL/PARAM (`xs: P[]`), not a literal. `monoArgTyName` resolved an
// array argument's element only from a literal (`first([1, 2, 3])`); a struct-array binding fell
// through (the locals table is unbuilt mid-monomorphization), so the call failed with "expected
// an array argument for `xs`". It now reads a struct / struct-array ANNOTATION directly
// (`monoStructAnnName`), so `T` binds to the element struct and the returned element classifies
// as that struct. i32 / string element arrays already worked (`generics/first.vl`).

type P = { x: i32 }

function first<T>(xs: T[]): T { return xs[0] }

function last<T>(xs: T[]): T { return xs[xs.length - 1] }

// the struct-array PARAM branch — `ps` is a `P[]` param handed to a generic.
function head(ps: P[]): P { return first(ps) }

function go() {
  const xs: P[] = [{ x: 7 }, { x: 8 }, { x: 9 }]
  print(first(xs).x) // 7  (first element)
  print(last(xs).x) // 9  (last element)
  print(head(xs).x) // 7  (param branch → first)
}
go()
