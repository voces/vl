// @check
// @error expected i32, got string
// CONTRACT (must-error): a generic alias really pins its parameter. `Box<i32>`
// makes `unwrap`'s `T` = i32, so `unwrap(bi)` is an i32 and `unwrap(bi) + s`
// (i32 + string) must be rejected. If application leaked a widened/`any` hole
// instead of substituting i32, this mismatch would slip through.
type Box<T> = { value: T }

function unwrap<T>(b: Box<T>): T b.value

let bi: Box<i32> = { value: 5 }
let s: string = "x"
let c = unwrap(bi) + s
