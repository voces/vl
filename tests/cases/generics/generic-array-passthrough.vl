// @run
// @log 10
// @log 3
// A generic array flows through a second generic function unchanged and is read
// back. `get<T>(xs: T[]): T[]` returns its array argument (element type `T`
// inferred from the i32 literal), then `first<T>` indexes it and `.length`
// reports its length — exercising returning, passing, indexing, and `.length`
// of a monomorphized generic array.
function first<T>(xs: T[]): T xs[0]
function get<T>(xs: T[]): T[] xs
const ys = get([10, 20, 30])
print(first(ys))
print(ys.length)
