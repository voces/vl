// @run
// @log 3
// @log x
// @log 1
// @log y
// Nested application: a generic alias may appear as another's type argument
// (`Box<Pair<i32, string>>`) and at array-element position (`Pair<…>[]`). The
// inner alias is applied first (to a concrete object type), which then flows in
// as the outer alias's argument — substitution composes. `>>` closing two nested
// applications lexes as two `>` tokens, so each level closes cleanly.
type Box<T> = { value: T }
type Pair<A, B> = { a: A, b: B }

const nested: Box<Pair<i32, string>> = { value: { a: 3, b: "x" } }
print(nested.value.a)
print(nested.value.b)

const ps: Pair<i32, string>[] = [{ a: 1, b: "y" }]
print(ps[0].a)
print(ps[0].b)
