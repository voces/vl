// @run
// @log 5
// @log hi
// A10 stage 3 (generic type aliases): `type Box<T> = { value: T }` is a
// parameterized alias. Applying it (`Box<i32>`, `Box<string>`) substitutes the
// argument for `T` in the body, yielding a concrete object type. Building a value
// and reading `.value` lowers exactly like a hand-written `{ value: … }`.
type Box<T> = { value: T }

let bi: Box<i32> = { value: 5 }
print(bi.value)

let bs: Box<string> = { value: "hi" }
print(bs.value)
