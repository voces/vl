// @run
// @log 5
// @log 5
// @log 5
// @log 9
// @log 42
// A generic function instantiated at a STRUCT type argument (`id<T>(v: T): T` called with a
// `P`). The per-call monomorphizer resolves the type argument from `monoArgTyName`, but for an
// ANNOTATED struct local/param arg (`const p: P`, `v: P`) it fell back to `exprStruct` /
// `structIndexOfExpr` — which can't classify during monomorphization (buildLocals is post-mono),
// so the type param defaulted to i32 and the instance's return mis-typed (`id(p).x` → "field
// access receiver is not a struct"; passing the result as a struct arg → invalid wasm). It now
// reads the struct ANNOTATION directly (the struct DECL table is built pre-mono). i32 / string /
// array instantiations were already fine.

type P = { x: i32, y: i32 }

function id<T>(v: T): T { return v }

function get(p: P): i32 { return p.x }

// a generic call THROUGH a struct param — exercises the param-annotation branch.
function wrap(p: P): P { return id(p) }

function go() {
  const p: P = { x: 5, y: 42 }

  // direct field access on a generic struct result.
  print(id(p).x) // 5

  // the generic struct result flows straight into a struct PARAM.
  print(get(id(p))) // 5

  // bind, then read.
  const q = id(p)
  print(q.x) // 5

  // the generic struct result flows into another struct param.
  print(wrap(p).x + 4) // 9

  // the second field reads correctly (full layout resolved, not just field 0).
  print(id(p).y) // 42
}
go()
