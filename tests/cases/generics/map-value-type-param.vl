// @check
// @error cannot assign i32? to 'bad' of type string?
// A generic flowing THROUGH a map: `{[string]: T}` binds `T` from the
// argument's value type (bindGenWalk) and the return substitutes through
// (substTyDeep), so the instantiated map keeps its concrete value type
// instead of silently keeping the hole. The matching read checks clean; the
// mismatched annotation is rejected — before the map walk existed, both
// passed (the hole accepted anything).
function idmap<T>(m: {[string]: T}) { return m }
const m: {[string]: i32} = Map()
m["a"] = 1
const r = idmap(m)
const ok: i32 | null = r["a"]
print(ok ?? 0)
const bad: string | null = r["a"] // REJECTED: the value type is i32, not string
print(bad ?? "none")
