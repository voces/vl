// @run
// @log 1.5
// @log 3.5
// @log 10
// @log a
// @log 4
// A GENERIC function called with an `f64[]` ARGUMENT now binds its type parameter to
// `f64` (and the element reads / return lower as f64). The monomorphizer's argument-type
// classifier (`monoArgTyName`) named a string / struct / i32 array argument but FELL
// THROUGH an f64 array literal to the i32-list default (`"i32[]"`), so `head([1.5, 2.5])`
// instantiated `head<i32>` — the instance's functype declared an i32-list param while the
// caller passed the f64-list, trapping wasm validation. An `exprF64Array` check before the
// i32 default binds `T = f64`. (The SAME generic definitions still serve `i32[]` /
// `string[]`.)

function head<T>(self: T[]): T {
  return self[0]
}
print(head([1.5, 2.5])) // 1.5

// f64 element reached through a local + index, returned generically.
function last<T>(self: T[]): T {
  const n = self.length
  const x = self[n - 1]
  return x
}
print(last([1.5, 2.5, 3.5])) // 3.5

// The same generics over i32[] and string[].
print(head([10, 20]))        // 10
print(head(["a", "b"]))      // a

// A generic length-like over f64[] (no element return — exercises the f64-list param).
function count<T>(self: T[]): i32 {
  return self.length
}
print(count([1.5, 2.5, 3.5, 4.5])) // 4
