// @run
// @log hey
// A union `(() => K0 | null) | i64` whose closure arm returns a NULLABLE literal-union. The closure
// member's parens wrap a `|`-bearing result (`K0 | null`), so `splitUnionAtoms` must keep the member
// whole for its closure atom to be recognized. Round-trips: narrow the outer union to the closure,
// call it, then narrow the `K0 | null` result away from null.
type K0 = "hey" | "yo"

function makeIt(): (() => K0 | null) | i64 {
  return () => ("hey")
}

function go() {
  const v: (() => K0 | null) | i64 = makeIt()
  if v is () => K0 | null {
    const r = v()
    if r != null { print(r) } else { print("NULL") }
  } else {
    print("I64")
  }
}

go()
