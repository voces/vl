// Regression: an UN-ANNOTATED binding of a multi-field plain-struct CALL, then flowed into a
// variant-box union `{…} | scalar` by RETURN (a), call ARGUMENT (b), and union FIELD (c).
// `const s = mk3()` (mk3 returns the PLAIN struct) shape-matched a variant arm via
// `exprVariantIndex`, so `letIsVariant`'s init fallback CLAIMED the un-annotated binding as a
// concrete kind-8 variant local `(ref $uVarHeap)` — but mk3's value is the plain struct
// `(ref $sHeapIdx)`, a DISTINCT (layout-twin) heap, so `local.set` stored a plain ref into a
// variant-typed cell (invalid wasm). The value IS a plain struct at the binding; only its
// later flow into the union reboxes (#1005). `letInitReboxesToVariant` now also fires for
// un-annotated bindings, routing the binding to a plain STRUCT (kind 1) instead of a variant.
// The annotated-binding twin is unions/call-struct-arm-into-variant-box-local.vl.
// @run
// @log 7
// @log 9
// @log 7
// @log 9
// @log 7
// @log 9
function mk3(): {a: i32, f: i32} { return { a: 7, f: 9 } }
function ret(): {a: i32, f: i32} | i64 {
  const s = mk3()
  return s
}
function take(u: {a: i32, f: i32} | i64) {
  if u is {a: i32, f: i32} {
    print(u.a)
    print(u.f)
  } else {
    print("TAKEOTHER")
  }
}
function go() {
  // (a) RETURN of the un-annotated binding into the union.
  const r = ret()
  if r is {a: i32, f: i32} {
    print(r.a)
    print(r.f)
  } else {
    print("RETOTHER")
  }
  // (b) call ARGUMENT position.
  const s1 = mk3()
  take(s1)
  // (c) union FIELD position.
  const s2 = mk3()
  const w: {u: {a: i32, f: i32} | i64} = { u: s2 }
  if w.u is {a: i32, f: i32} {
    print(w.u.a)
    print(w.u.f)
  } else {
    print("FIELDOTHER")
  }
}
go()
