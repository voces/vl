// @run
// @log 1
// @log OTHER
// A union whose member is a MAP alongside another arm, used as a LIST ELEMENT
// (`({[string]: i32} | boolean)[]`): the map arm boxes as its map-struct ref on the union box's
// anyref (tagged by `mapSlotTag`), the boolean arm as a value box. A list of such unions stores the
// BOX per element (kind 2), NOT a list-of-maps — `v[0] is {[string]: i32}` then discriminates and
// the narrowed read sees the map. This exact rep-fuzz shape once lost the map variant's tag and
// silently mis-`is`'d; now it is a real rep. Covers the map arm + the boolean arm.
function listArm(v: ({[string]: i32} | boolean)[]) {
  const t = v[0]
  if t is {[string]: i32} {
    print(t["k"] ?? -1)
  } else {
    print("OTHER")
  }
  const b = v[1]
  if b is {[string]: i32} {
    print("MAP")
  } else {
    print("OTHER")
  }
}
function go() {
  const h: {[string]: i32} = Map()
  h["k"] = 1
  listArm([h, true])
}
go()
