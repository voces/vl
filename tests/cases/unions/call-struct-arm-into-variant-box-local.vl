// Regression: a named-function CALL returning the STRUCT arm of a variant-box union
// `{…} | scalar`, bound to a UNION-annotated LOCAL (a) and GLOBAL (b). The init's
// `exprVariantIndex(mkS())` matched the arm, so `letIsVariant`'s init fallback CLAIMED the
// union-annotated binding as a concrete kind-8 variant local `(ref $variant)` — while the
// value (correctly per #1005) coerced to the union box `(ref $uBox)`, so the box store hit
// a variant-typed cell (invalid wasm). The annotation is now AUTHORITATIVE: a union
// annotation binds the box regardless of the init's variant-ness (the init fallback is only
// for un-annotated bindings). The IDENT-init spelling already worked (an ident is not
// variant-classified) — see unions/struct-ident-into-variant-box-union.vl.
// @run
// @log 55
// @log 55
function mkS(): {w: i32} { return { w: 55 } }
const g: {w: i32} | i32 = mkS()
function go() {
  const t: {w: i32} | i32 = mkS()
  if t is {w: i32} { print(t.w) } else { print("TOTHER") }
  if g is {w: i32} { print(g.w) } else { print("GOTHER") }
}
go()
