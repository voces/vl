// @run
// @log hi
// @log OTHER
// A union whose member is a MAP alongside another arm (`{[string]: string} | f64`): the map arm
// boxes as its map-struct ref on the union box's anyref (tagged by `mapSlotTag`), the f64 arm as a
// value box. `v is {[string]: string}` discriminates; the narrowed `v[k]` reads the map. Covers the
// map arm (read) + the other arm, across a return position and a param position.
function makeMap(): {[string]: string} | f64 {
  const h: {[string]: string} = Map()
  h["k"] = "hi"
  return h
}
function readArm(v: {[string]: string} | f64) {
  if v is {[string]: string} {
    print(v["k"] ?? "zz")
  } else {
    print("OTHER")
  }
}
readArm(makeMap())
readArm(3.5)
