// @run
// @log 42
// @log hi
// @log 1.5
// @log true
// A value union with a `string` MEMBER but whose program constructs NO string (`string | i32 = 42`):
// the narrowed string read's `ref.cast $aTypeIdx` is still EMITTED (in the `is string` arm — dead when
// the value is the other member, but it must still VALIDATE). Without forcing the string-array type
// (`aUsed`) for a string-member value union, that cast pointed at an unallocated heap index — invalid
// wasm (`expected funcref, found anyref`). Now the box round-trips whichever member it holds, even
// when the string arm never runs.

function go0() {
  const r: string | i32 = 42
  if r is string { print(r) } else { print(r) } // 42 — i32 value, string arm dead but validates
}
go0()

function go1() {
  const r: string | i32 = "hi"
  if r is string { print(r) } else { print(r) } // hi
}
go1()

function go2() {
  const r: string | f64 = 1.5
  if r is string { print(r) } else { print(r) } // 1.5 — no string constructed
}
go2()

function go3() {
  const r: string | boolean = true
  if r is string { print("S") } else { print(r) } // true
}
go3()
