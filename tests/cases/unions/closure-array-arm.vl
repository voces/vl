// @run
// @log 1943.5
// @log 42
// @log 2.5
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// A union whose ARM is a CLOSURE ARRAY (`((i32) => f32)[] | i32`), reached from an array
// LITERAL of bare element lambdas. `seedExpected` descends an array literal flowing into a
// union into the closure-array arm (`unionClosureArrayArmForLit`), so a bare element lambda
// (`(_q0) => 1943.5`) infers its param/result from the arm's element function type instead of
// failing "cannot infer a type for parameter". The arm boxes into the shared `{tag, value}`
// union rep (the reflist wrapper riding the box anyref), and a narrowed indexed call
// (`v[0](1)` after `v is ((i32) => f32)[]`) unboxes + `call_ref`s the closure element. The
// argument `1` is coerced by the closure's OWN param type — an enclosing `f32`-context call
// no longer leaks its wide-scalar pending flag into the arg spine (that lowered a bare i32
// arg as `f32.const`: invalid). The scalar arm (`i32`) still narrows away. (rep-fuzz p0c/p0r
// `(((i32) => f32)[] | i32)[]`.)

// The closure-array arm, read back through an `is` narrow + indexed call. The indexed call's
// `f32` result means the enclosing return is `f32` context — the arg-spine flag clear keeps
// the `1` argument an i32.
function readClosureArm(v: ((i32) => f32)[] | i32): f32 {
  if v is ((i32) => f32)[] { return v[0](1) }
  return 0.0
}

// The scalar arm of the same union still reads.
function readScalarArm(v: ((i32) => f32)[] | i32) {
  if v is i32 { return v }
  return -1
}

// The exact fuzzer shape: an ARRAY of the closure-array-or-scalar union, read at an element.
function readRow(rows: (((i32) => f32)[] | i32)[]): f32 {
  const a = rows[0]
  if a is ((i32) => f32)[] { return a[0](1) }
  return 0.0
}

function go() {
  // A bare element lambda flows through the argument into the closure-array arm.
  print(readClosureArm([(_q0) => (1943.5)])) // 1943.5
  print(readScalarArm(42)) // 42
  print(readRow([[(_q1) => (2.5)], 7])) // 2.5
}

go()
