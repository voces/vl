// @run
// @log 5
// @log 42
// @log hi
// @log true
// Extracting a NARROWED value-union member into a fresh EXPLICITLY-TYPED local (`const x: i32 = r`
// where `r: i32 | boolean` is narrowed to `i32`): the annotation pins `x` to the concrete type and
// the init UNBOXES the narrowed atom into it. Without respecting the annotation, `letIsUnion`
// classified `x` as a union BOX from its union-typed init and stored the unboxed scalar into a
// `(ref $box)` slot — invalid wasm (`expected (ref …), found i32`). The init's union-ness now
// applies ONLY when no annotation pinned the cell.

function go0() {
  const r: i32 | boolean = 5
  if r is boolean { print(1) } else {
    const x: i32 = r
    print(x) // 5
  }
}
go0()

function go1() {
  const r: string | i32 = 42
  if r is string { print(0) } else {
    const x: i32 = r
    print(x) // 42
  }
}
go1()

function go2() {
  const r: string | i32 = "hi"
  if r is i32 { print(0) } else {
    const x: string = r
    print(x) // hi
  }
}
go2()

function go3() {
  const r: i32 | boolean = true
  if r is i32 { print(0) } else {
    const b: boolean = r
    print(b) // true
  }
}
go3()
