// @run
// @log 1
// @log 2
// @log 1
// @log 2
// @log 9
// A struct-UNION (`Cat | Dog`) if-EXPRESSION join whose ARMS are concrete VARIANT values
// (`if c then cat else dog`). The if-value's result is the union BOX `(ref $uBox)`, but a kind-8
// variant arm is a raw `(ref $variant)` — the arm-coerce sites (`emitUnionIfArm` for a value-`if`
// join, `emitNulArmToLocal` for a union-annotated `let`/`const` if-init) called `emitUnionCoerce`,
// which emits a variant struct RAW, so the boxed blocktype saw the wrong ref ("expected (ref
// $uBox), found (ref $variant)" — invalid wasm). They now route through `emitUnionBoxArg`, which
// boxes a variant ref (defers object-literal / passthrough-union / scalar arms unchanged), as a
// variant RETURN / ARGUMENT already did. Covers return, binding, and argument positions.

type Cat = { meow: i32 }
type Dog = { bark: i32 }
type Animal = Cat | Dog

// RETURN position — an annotated function returning a variant if-join.
function pick(c: i32): Animal {
  const cat: Cat = { meow: 1 }
  const dog: Dog = { bark: 2 }
  return if c > 1 then cat else dog
}

// ARGUMENT position — the if-join passed to a union param.
function tag(a: Animal): i32 {
  if a is Cat { return a.meow }
  if a is Dog { return a.bark }
  return -1
}

function go() {
  if pick(5) is Cat {
    print(1) // 1 (then arm)
  }
  if pick(0) is Dog {
    print(2) // 2 (else arm)
  }

  // BINDING position — a union-annotated `let`/`const` with a variant if-init.
  const x: Cat = { meow: 1 }
  const y: Dog = { bark: 2 }
  let a: Animal = if 5 > 1 then x else y
  if a is Cat {
    print(a.meow) // 1
  }
  a = if 0 > 1 then x else y
  if a is Dog {
    print(a.bark) // 2
  }

  // ARGUMENT — the if-join handed straight to a union-typed parameter.
  const cat: Cat = { meow: 9 }
  const dog: Dog = { bark: 8 }
  print(tag(if 1 > 0 then cat else dog)) // 9
}
go()
