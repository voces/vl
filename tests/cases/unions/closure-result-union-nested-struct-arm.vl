// @run
// @log 309050161876985
// @log dx
// @log 2.5
// A closure whose RESULT is a union one of whose arms is itself a closure returning a
// struct with a NESTED-struct field (`(i32) => (() => {a: i64, f: {a: string, f: i64,
// z: f64}, z: f32}) | i64`). The inner struct's shape is interned once by the constructed
// literal (a synthetic `#anonN` name) and once by the union-arm annotation; the annotation
// path keys the nested `f` field by its CANONICAL registered name, so the two dedup onto a
// single struct instead of minting a duplicate whose element name is `structIndexByName`-
// unresolvable — which read `sHeapIdx[-1]` out of bounds at type-section emit (a compiler
// crash). Narrowing the value-call result to the closure arm and chaining a second call
// reads the nested field back.
// @warning Unused parameter
function go() {
  const v: (i32) => (() => {a: i64, f: {a: string, f: i64, z: f64}, z: f32}) | i64 = (q0) => (() => ({ a: 6000000000, f: { a: "dx", f: 309050161876985, z: 2.5 }, z: 3.5 }))
  const t0 = v(1)
  if t0 is () => {a: i64, f: {a: string, f: i64, z: f64}, z: f32} {
    const s = t0()
    print(s.f.f)
    print(s.f.a)
    print(s.f.z)
  } else {
    print("OTHER")
  }
}

go()
