// @run
// @log NULL
// @log 2.5
// @log OTHER
// A REBIND under a `!= null` narrow of a MAP-member union (`{[string]: V} | string | null`):
// the narrow lands on the member SET `{[string]: V}|string` — a name that STARTS with `{[`, so
// `nameIsMap` matches it — and `narrowedMapOf` (missing the `nameIsMapMemberUnion` guard every
// other classifier site carries) claimed the rebound local (`const t1 = t0`) as a bare MONO map:
// the box ref was then read with the mono-map rep — invalid wasm ("expected i32, found ref").
// Regression: the rebound local stays a union box; `is` narrows it to the map arm (typed f64
// values resolve their mv slot) or the string arm.
function goNull() {
  const v: {[string]: f64} | string | null = null
  const t0 = v
  if t0 != null {
    const t1 = t0
    if (t1 is {[string]: f64}) { print("MAP") } else { print(t1) }
  } else {
    print("NULL")
  }
}
function goMap() {
  const h0: {[string]: f64} = Map()
  h0["k"] = 2.5
  const v: {[string]: f64} | string | null = h0
  const t0 = v
  if t0 != null {
    const t1 = t0
    if (t1 is {[string]: f64}) {
      print(t1["k"] ?? 3.5)
    } else {
      print("OTHER")
    }
  } else {
    print("NULL")
  }
}
// A LIST-valued map arm (`{[string]: f64[]}`) — the mv slot resolves through the same rebind.
function goListVals() {
  const v: {[string]: f64[]} | string | null = "s"
  const t0 = v
  if t0 != null {
    const t1 = t0
    if (t1 is {[string]: f64[]}) {
      const t2 = t1["k"] ?? [14.5]
      print(t2[0])
    } else {
      print("OTHER")
    }
  } else {
    print("NULL")
  }
}
goNull()
goMap()
goListVals()
