// @run
// @log 2
// @log x
// @log 0
// @log 5
// @log 6000000000
// Shape 3 — `{a: f64, f: {a: f64, f: K0 | {w: i32}, z: string}[], z: i64}`: a struct whose FIELD
// is an ARRAY of a struct that itself carries a value-union FIELD (`f: K0 | {w: i32}`). This
// emitted INVALID-WASM: `registerInlineUnion`'s array branch only recursed when the stripped
// element was ITSELF an array, so a 1D array-of-inline-shape element never registered its element
// shape's field union. That field then coded -1 in `internInlineShape`, the inner struct FAILED to
// intern, and the reflist element resolved to the OUTER struct — all three shapes share field
// names a/f/z, so the field-name match silently picked the wrong struct and stored the wrong reps.
// `registerInlineUnion` now also recurses on a single-inline-shape element (`nameIsSingleShape`),
// the union-registration twin of the `internShapeDeep` single-`[]` peel. Found by the rep-
// composition fuzzer (graduated INVALID-WASM p3c + REJECT p3r, plus the bonus `{f: K0|{w:i32}}[]`).

type K0 = "aa" | "bb"

const g: {a: f64, f: {a: f64, f: K0 | {w: i32}, z: string}[], z: i64} = {a: 1.0, f: [{a: 2.0, f: "aa", z: "x"}, {a: 3.0, f: {w: 5}, z: "y"}], z: 6000000000}

function go() {
  print(g.f.length) // 2
  const e0 = g.f[0]
  print(e0.z) // x
  // e0.f is the litunion arm ("aa") — the `{w: i32}` narrow is false.
  const u0 = e0.f
  if u0 is { w: i32 } { print(u0.w) } else { print(0) } // 0
  // e1.f is the struct arm ({w: 5}).
  const e1 = g.f[1]
  const u1 = e1.f
  if u1 is { w: i32 } { print(u1.w) } else { print(-1) } // 5
  print(g.z) // 6000000000
}

go()
