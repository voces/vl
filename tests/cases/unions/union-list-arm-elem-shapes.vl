// @run
// @log yes
// @log 9
// @log yes
// @log 5
// @log bs
// @log if
// @log exact
// The element-shape family of the list-of-union arm fix (paren-aware `splitUnionAtoms`
// + `emitUnionCoerce`'s union-box-element literal routing + the arm element-union
// registration recursion in `registerInlineUnion`):
// (1) a STRUCT element union `(C | D)[] | {w: i32}` — the `[{a:1}]` literal
//     self-classifies as the concrete `C[]` (its slot matches no arm), so it routes
//     through the arm's box-element build; the element union's variants register so
//     `objVariantName` resolves the element literal and `e is D` narrows;
// (2) a NAMED value-union alias element `N[] | {w: i32}` — same coerce gap without
//     parens (was invalid wasm: the raw `string[]` wrapper stored into the box slot);
// (3) TWO union-box ref-array arms `(boolean | string)[] | (i32 | f64)[]` — the whole
//     name starts with `(` and ends with `[]`, so `parenUnionArrElemName` used to slice
//     an UNBALANCED inner and derail registration ("no union type declared");
// (4) the union's OWN exact list atom still wins over a union-box arm
//     (`(i32 | string)[] | i32[]` boxes `[1]` as the `i32[]` value atom).
type C = {a: i32}
type D = {b: i32}

function structElem() {
  const x: (C | D)[] | {w: i32} = [{a: 1}, {b: 9}]
  if x is (C | D)[] {
    print("yes")
    const e = x[1]
    if e is D { print(e.b) } else { print("c") }
  } else { print("no") }
}
structElem()

type N = i32 | string

function namedElem() {
  let x: N[] | {w: i32} = ["other"]
  if x is N[] { print("yes") } else { print("no") }
  x = {w: 5}
  if x is {w: i32} { print(x.w) } else { print("list") }
}
namedElem()

function twoArms() {
  const x: (boolean | string)[] | (i32 | f64)[] = [true]
  if x is (boolean | string)[] { print("bs") } else { print("if") }
  const y: (boolean | string)[] | (i32 | f64)[] = [1.5]
  if y is (i32 | f64)[] { print("if") } else { print("bs") }
}
twoArms()

function exactAtomWins() {
  const x: (i32 | string)[] | i32[] = [1]
  if x is i32[] { print("exact") } else { print("union") }
}
exactAtomWins()
