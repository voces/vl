// @run
// @log 147452945
// @log OTHER
// @log 5
// @log 41
// @log 55
// @log null
// @log 99
// @log 7
// A union whose member is a BARE CLOSURE arm alongside another arm — the closure sibling of the
// array-member (#863) and map-member (#865) features. A function type is value-atom KIND 11 (a REF
// atom riding the box anyref as the `$cloStructIdx` fat-pointer), so it boxes into the shared
// `{tag, value}` rep, `is () => T` discriminates by its `scalarTagOf`, and the narrowed CALL
// unboxes the fat-pointer and `call_ref`s it. Covers a STRUCT-FIELD arm (`(() => i64) | {w:i32}`),
// a SCALAR union (`(() => i64) | i32`, both directions incl. the else-branch complement read), a
// NULLABLE closure param, and RETURN position — read + other-arm, with a bare LAMBDA adopting the
// arm (the checker `seedExpected` union seam) as well as a pre-typed closure binding.

// STRUCT-FIELD closure arm: a bare lambda `() => (147452945)` adopts the `() => i64` arm.
function fieldArm(p: { a: boolean, f: (() => i64) | { w: i32 }, z: i32 }) {
  const t0 = p.f
  if t0 is () => i64 { print(t0()) } else { print("OTHER") }
}

// SCALAR union `(() => i64) | i32`, closure direction — the narrowed call.
function scalarArm(p: (() => i64) | i32) {
  if p is () => i64 { print(p()) } else { print(p) }
}

// NULLABLE closure param — the closure arm, else `null`.
function nulArm(p: (() => i64) | null) {
  if p is () => i64 { print(p()) } else { print("null") }
}

// RETURN position — a function returning `(() => i64) | i32`, each branch a distinct arm.
function mk(b: boolean): (() => i64) | i32 {
  if b { return () => 99 } else { return 7 }
}

function go() {
  // struct-field arm: lambda adopts `() => i64`, then the other-arm `{w:i32}` reads OTHER.
  const g: () => i64 = () => 147452945
  fieldArm({ a: true, f: g, z: 11 })
  fieldArm({ a: false, f: { w: 3 }, z: 0 })
  // scalar union: closure branch calls; i32 branch reads the else-complement scalar.
  scalarArm(() => 5)
  scalarArm(41)
  // nullable closure: call, then null.
  nulArm(() => 55)
  nulArm(null)
  // return position: closure then i32.
  const r0 = mk(true)
  if r0 is () => i64 { print(r0()) } else { print(r0) }
  const r1 = mk(false)
  if r1 is () => i64 { print(r1()) } else { print(r1) }
}

go()
