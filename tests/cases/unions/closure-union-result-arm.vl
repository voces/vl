// @hint Intentionally-unused variable `_v`
// A union whose closure arm RETURNS A UNION: `((i32) => {f: boolean}[] | {w: i32}) | f64`. The
// closure member is spelled in grouping parens and its OWN result is a 2-member union, so the `|`
// between `{f: boolean}[]` and `{w: i32}` sits inside the member's parens. `splitUnionAtoms` must
// keep the parenthesized closure member WHOLE (not tear it on that inner `|`) so its kind-11
// closure atom is recognized and the fat-pointer boxes with the arm's tag. The pre-fix brace-only
// `|` split produced bogus atoms, no closure arm was found, and the box defaulted to a scalar tag
// — invalid wasm at the union return of `makeIt`.
function makeIt(): ((i32) => {f: boolean}[] | {w: i32}) | f64 {
  return (_q0) => ([{f: false}])
}

function go() {
  const _v: ((i32) => {f: boolean}[] | {w: i32}) | f64 = makeIt()
  print(0)
}

go()
