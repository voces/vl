// @run
// @log OTHER
// A NULLABLE union of a struct (carrying a DOUBLY-nested map field) and i64
// (`{a: f32, f: {f: {[string]: boolean | string}}, z: i64} | i64 | null`). After the
// `!= null` + `is {…}` narrow, the map read `t1.f.f["k"]` reaches the map through TWO
// code-15 nested-struct hops — the frame pre-pass must spot it (walk the whole member
// chain, not just the single-hop `t1.f[k]`) so the map scratch frame is reserved; else
// `mapScratchBase` points past the locals (an `invalid local index`).
function makeIt(): {a: f32, f: {f: {[string]: boolean | string}}, z: i64} | i64 | null {
  return 5000000077
}
function go() {
  const v: {a: f32, f: {f: {[string]: boolean | string}}, z: i64} | i64 | null = makeIt()
  const t0 = v
  if (t0 != null) {
    const t1 = t0
    if t1 is {a: f32, f: {f: {[string]: boolean | string}}, z: i64} {
      const t2 = t1.f.f["k"] ?? false
      const t3 = t2
      if t3 is boolean { print(t3) } else { print("OTHER") }
    } else {
      print("OTHER")
    }
  } else {
    print("NULL")
  }
}
go()
