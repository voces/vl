// @run
// @log 97.5
// @log 3.5
// @log 2.5
// A struct LITERAL adopts a union's struct ARM even when a field must WIDEN to
// reach it — a float literal re-encoding at f32 (`{f: 97.5}` into `{f: f32} |
// {w: i32}`), which the plain `assignable` membership check (an exact-rep match)
// cannot see. The checker tries each struct arm field-wise (`assignableExpr`) and
// records the concrete arm on the literal so the emitter boxes the same rep it
// already lowers for the i32-field spelling. Restricted to arms of scalar / string
// / boolean / literal-union-atom / nested-plain-struct fields (`unionArmBoxSafe`):
// any other composite field has no union-boxed rep and stays a loud reject (the
// litunion-atom arm is covered by `variant-litunion-field.vl`).
// (Field names are kept DISTINCT per struct: two same-field-named different-typed
// structs boxed into unions collide in the emitter's shape interner — a PRE-EXISTING
// emit limitation, independent of this checker adoption.)
function fArm() {
  const g: {f: f32} | {w: i32} = {f: 97.5}
  const t = g
  if (t is {f: f32}) {
    print(t.f)
  } else {
    print("W")
  }
}

// A struct arm alongside a NON-struct (boolean) arm, with an f32 field.
function structOrBool() {
  const g: {aa: i32, bb: i32, cc: f32} | boolean = {aa: 1, bb: 2, cc: 3.5}
  const t = g
  if (t is {aa: i32, bb: i32, cc: f32}) {
    print(t.cc)
  } else {
    print("B")
  }
}

// The adoption also fires ELEMENT-WISE through an array literal: each element is a
// struct literal adopting the `{...} | i64` element union.
function arrayOfUnion() {
  const g: ({dd: f32, ee: f32, ff: i64} | i64)[] = [{dd: 1.5, ee: 2.5, ff: 6000000000}]
  const e = g[0]
  if (e is {dd: f32, ee: f32, ff: i64}) {
    print(e.ee)
  } else {
    print("I")
  }
}

fArm()
structOrBool()
arrayOfUnion()
