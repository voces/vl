// @run
// @log 7
// @log i64x
// @log 1
// @log s
// @log 2500
// @log yes
// @log b
// A union with a MAP member across the SOUND map VALUE kinds (mono i32, string, i64, f64) and
// spellings (inline, named map-LAST alias). Each map arm's per-value map struct is tagged distinctly
// by its interned mv slot (`mapSlotTag`), so two DISTINCT map arms in one union discriminate. A
// map-FIRST named alias (`type = {[...`) is a pre-existing PARSER limitation, so the alias is
// map-last. (Ref-VALUE map arms — struct / nested-map / union / closure values — are a deferred
// heap-type-identity family and stay a LOUD reject.)
type NamedU = boolean | {[string]: string}

function monoArm(v: {[string]: i32} | i64) {
  if v is {[string]: i32} { print(v["a"] ?? -1) } else { print("i64x") }
}
function twoArms(v: {[string]: i32} | {[string]: string}) {
  if v is {[string]: i32} { print(v["a"] ?? -1) } else { print(v["a"] ?? "z") }
}
function f64Arm(v: {[string]: f64} | boolean) {
  if v is {[string]: f64} { print(v["a"] ?? 0.0) } else { print("bool") }
}
function namedArm(v: NamedU) {
  if v is {[string]: string} { print(v["k"] ?? "z") } else { print("b") }
}
function mkI(): {[string]: i32} | i64 {
  const h: {[string]: i32} = Map()
  h["a"] = 7
  return h
}
function mkI2(): {[string]: i32} | {[string]: string} {
  const h: {[string]: i32} = Map()
  h["a"] = 1
  return h
}
function mkS2(): {[string]: i32} | {[string]: string} {
  const h: {[string]: string} = Map()
  h["a"] = "s"
  return h
}
function mkF(): {[string]: f64} | boolean {
  const h: {[string]: f64} = Map()
  h["a"] = 2500.0
  return h
}
function mkNamed(): NamedU {
  const h: {[string]: string} = Map()
  h["k"] = "yes"
  return h
}
monoArm(mkI())
monoArm(9000000000)
twoArms(mkI2())
twoArms(mkS2())
f64Arm(mkF())
namedArm(mkNamed())
namedArm(true)
