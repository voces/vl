// @run
// @log 42
// @log OTHER
// @log 7
// A union whose member is a REF-ELEMENT (struct) ARRAY alongside another arm
// (`S[] | {w: i32}`): the array arm boxes as its reflist WRAPPER ref on the box anyref,
// tagged distinctly, so `is S[]` discriminates and the narrowed `t[0].a` read casts the
// box payload back to the reflist wrapper. Covers BOTH the passing-an-array branch (read)
// and the other-arm branch, in a NAMED alias (no struct arm — a ref-array + i64) too.
type S = { a: i32 }

function readArm(p: S[] | { w: i32 }) {
  const t = p
  if t is S[] {
    print(t[0].a)
  } else {
    print("OTHER")
  }
}

function fromArray() {
  const xs: S[] = [{ a: 42 }]
  readArm(xs)
}

function fromStruct() {
  readArm({ w: 1 })
}

// A NAMED alias with a ref-array arm and NO struct member (`S[] | i64`) — the box exists
// even with zero variant structs; the array arm still boxes + narrows + reads.
type U = S[] | i64

function readNamed(p: U) {
  if p is S[] {
    print(p[0].a)
  } else {
    print("i64")
  }
}

function fromNamed() {
  const ys: S[] = [{ a: 7 }]
  readNamed(ys)
}

fromArray()
fromStruct()
fromNamed()
