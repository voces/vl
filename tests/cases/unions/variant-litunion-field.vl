// @run
// @log pbf
// @log OTHER
// @log v
// @log 840
// @log OTHER
// @log pbf
// @log 11
// @log OTHER
// @log v
// @log 840
// A union VARIANT whose struct arm carries a literal-union ATOM field (`{f: K0} | i64`)
// boxes, tags, and reads back through `is`. The arm's `K0` field is the interned-i32 atom
// rep (code 0): the variant tables record the union name (`uFieldElemName`, the
// `sFieldElemName` twin), the variant construct path lowers a member literal as its atom
// id, and a narrowed `t.f` read widens the atom to its member string at print. Also covers
// the null-carrying union, the union as a struct FIELD / array ELEMENT / map VALUE, and a
// kind-8 variant VALUE binding passing through the union coerce un-boxed.

type K0 = "840" | "pbf" | "v"

// A GLOBAL union initializer whose struct arm has the atom field (p3), both arms.
const g: { f: K0 } | i64 = { f: "pbf" }
const gi: { f: K0 } | i64 = 6000000000
function readG() {
  const t0 = g
  if t0 is { f: K0 } {
    print(t0.f)
  } else {
    print("OTHER")
  }
}
function readGi() {
  const t0 = gi
  if t0 is { f: K0 } {
    print(t0.f)
  } else {
    print("OTHER")
  }
}
readG()  // pbf
readGi() // OTHER

// A LOCAL null-carrying union (`{f: K0} | i64 | null`, p0).
function readNul() {
  const v: { f: K0 } | i64 | null = { f: "v" }
  const t0 = v
  if t0 != null {
    const t1 = t0
    if t1 is { f: K0 } {
      print(t1.f)
    } else {
      print("OTHER")
    }
  } else {
    print("NULL")
  }
}
readNul() // v

// The union as a struct FIELD (`{f: {f: K0} | i64}`), read off the field.
const s3: { f: { f: K0 } | i64 } = { f: { f: "840" } }
function readField() {
  const t0 = s3.f
  if t0 is { f: K0 } {
    print(t0.f)
  } else {
    print("OTHER")
  }
}
readField() // 840

// A PARAM array of structs whose middle field is the union (p1) — both arms.
function useIt(p: { a: boolean, f: { f: K0 } | string, z: string }[]) {
  const t0 = p[0].f
  if t0 is { f: K0 } {
    print(t0.f)
  } else {
    print("OTHER")
  }
}
useIt([{ a: true, f: "dx", z: "dz" }])    // OTHER
useIt([{ a: false, f: { f: "pbf" }, z: "dz" }]) // pbf

// An ARRAY of the union whose struct arm nests a multi-field struct carrying the atom
// (`({f: {a: f64, f: K0, z: i32}} | string)[]`, p3) — the decoy siblings keep their reps.
const g5: ({ f: { a: f64, f: K0, z: i32 } } | string)[] = [
  { f: { a: 2.5, f: "v", z: 11 } },
  "plain",
]
function readElem(i: i32) {
  const t0 = g5[i]
  if t0 is { f: { a: f64, f: K0, z: i32 } } {
    print(t0.f.z)
  } else {
    print("OTHER")
  }
}
readElem(0) // 11
readElem(1) // OTHER

// The union as a MAP VALUE (`{[string]: {f: K0} | i64}`) — the value's `V?` slot boxes
// through the same variant seam; the `??` default is the OTHER member shape.
function makeIt(): { [string]: { f: K0 } | i64 } {
  const h0: { [string]: { f: K0 } | i64 } = Map()
  h0["k"] = { f: "v" }
  return h0
}
function readMap() {
  const v = makeIt()
  const t0 = v["k"] ?? { f: "840" }
  if t0 is { f: K0 } {
    print(t0.f)
  } else {
    print("OTHER")
  }
}
readMap() // v

// A kind-8 VARIANT value binding (`const s: {f: K0} = …` then `const u: {f: K0} | i64 = s`):
// the variant-init binding's slot IS the raw variant ref, so the union coerce passes it
// through un-boxed (the scalar atom ladder must not claim the ref).
function readVariantValue() {
  const s: { f: K0 } = { f: "840" }
  const u: { f: K0 } | i64 = s
  const t0 = u
  if t0 is { f: K0 } {
    print(t0.f)
  } else {
    print("OTHER")
  }
}
readVariantValue() // 840
