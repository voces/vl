// @run
// @log 285
// @log 2.5
// @log 2.5
// @log true
// @log 285
// @log 42
// @log OTHER
// A map-member union stored in a LOCAL binding whose other arm is a NON-STRUCT scalar/boolean
// (`{[string]: i32} | boolean`, `{[string]: f64} | i32`, …). The local's INIT is the bare map
// ARM (`const v: {[string]: i32} | boolean = h`), so the local-slot classifier must NOT reclaim
// the union box as a bare map off its init (`letIsMap`'s init fall-through): the annotation is
// authoritative — the cell rides the union box, and `v is {[string]:V}` narrows to read the map.
// Regression for the invalid-wasm hole where the local slot was typed as the map struct while the
// RHS boxed into the union (a `(ref $box)` stored into a `(ref $map)` cell).
function go() {
  const h0: {[string]: i32} = Map()
  h0["k"] = 285
  const a: {[string]: i32} | boolean = h0
  if a is {[string]: i32} { print(a["k"] ?? 12121) } else { print("OTHER") }

  const h1: {[string]: f64} = Map()
  h1["k"] = 2.5
  const b: {[string]: f64} | boolean = h1
  if b is {[string]: f64} { print(b["k"] ?? 0.0) } else { print("OTHER") }

  const h2: {[string]: f64} = Map()
  h2["k"] = 2.5
  const c: {[string]: f64} | i32 = h2
  if c is {[string]: f64} { print(c["k"] ?? 0.0) } else { print("OTHER") }

  const h3: {[string]: boolean} = Map()
  h3["k"] = true
  const d: {[string]: boolean} | i32 = h3
  if d is {[string]: boolean} { print(d["k"] ?? false) } else { print("OTHER") }

  const h4: {[string]: i64} = Map()
  h4["k"] = 285
  const e: {[string]: i64} | boolean = h4
  if e is {[string]: i64} { const r: i64 = e["k"] ?? 0; print(r) } else { print("OTHER") }

  // Composite-VALUE map arm (a struct value) boxed in a union with a boolean other arm.
  const h5: {[string]: {a: i32, f: i32, z: f64}} = Map()
  h5["k"] = { a: 42, f: 7, z: 1.5 }
  const g: {[string]: {a: i32, f: i32, z: f64}} | boolean = h5
  if g is {[string]: {a: i32, f: i32, z: f64}} {
    const rec = g["k"]
    if rec != null { print(rec.a) } else { print("OTHER") }
  } else {
    print("OTHER")
  }

  // The OTHER (non-map) arm actually carried.
  const f: {[string]: i32} | boolean = false
  if f is {[string]: i32} { print(f["k"] ?? 0) } else { print("OTHER") }
}
go()
