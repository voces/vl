// ONE renderer (`refArmUnionRetName`): the contextual-return ladder ADOPTS the union at
// the lambda boundary, `synthRetAnnots` PINS it (the lambda boxes at the return seam and
// its `$fnsig` keys `>u`), and `nodeUnionName`'s Call fallback resolves the binding's
// union name so the narrowed read unboxes like any other union binding.
type T = { f: boolean }
function makeIt(): ((i32) => T[] | { w: i32 }) | f64 {
  return (_q0) => ([{ f: true }])
}
function go() {
  // The #911 INVALID-WASM spelling: t1 INFERRED from the narrowed closure-value call.
  const v: ((i32) => T[] | { w: i32 }) | f64 = makeIt()
