// @run
// @log aa
// @log bb
// @log OTHER
// @log bb
// @log OTHER
// A UNION-typed struct FIELD narrowed to a litunion ALIAS by a MEMBER `is` test
// (`if a.f is K0 { … a.f … }`, `type K0 = "a"|"b"`, field `f: K0 | f64`) unboxes the
// narrowed `a.f` READ as the STRING ref the box stores its member as — mirroring the
// bind-then-narrow (`const t = a.f; t is K0`) and the ident-receiver disciplines. Before
// the fix `emitMem`'s code-16 field unbox keyed the RAW `narrowVariantFor`/`valueAtomKind`
// (which decline a litunion alias) instead of `narrowedValueAtomOf` (which maps the alias
// to `string`), so the narrowed member read flowed the raw box where the string array was
// expected — invalid wasm. (The else-arm complement over a litunion alias is a SEPARATE
// pre-existing value-union gap — shared with the ident spelling — so the else prints a
// constant here.)

type K0 = "aa" | "bb"

function go(a: { f: K0 | f64 }) {
  if a.f is K0 { print(a.f) } else { print("OTHER") }
}

function main() {
  const a1: { f: K0 | f64 } = { f: "aa" }
  go(a1) // aa
  const a2: { f: K0 | f64 } = { f: "bb" }
  go(a2) // bb
  const a3: { f: K0 | f64 } = { f: 3.5 }
  go(a3) // OTHER — the f64 arm, K0 tag distinct
}
main()

// A directly-constructed LOCAL (not a param), mixed-rep sibling fields.
function go2() {
  const o: { a: i64, f: K0 | i64, z: f64 } = { a: 1, f: "bb", z: 2.5 }
  if o.f is K0 {
    print(o.f) // bb
  } else {
    print("OTHER")
  }
}
go2()

// A GLOBAL struct receiver.
const g: { f: K0 | f64 } = { f: 9.5 }
function go3() {
  if g.f is K0 {
    print(g.f) // OTHER — the f64 arm
  } else {
    print("OTHER")
  }
}
go3()
