// Regression: a union ARM whose NESTED single-shape field carries a heterogeneous
// ELEMENT union one level down (`{z: {a: {f: i64}, f: (boolean | {w: i32} | {q: i64})[]}}
// | i64`). `registerVariantArmFieldUnions` never descended into the nested shape, so the
// element union was NEVER REGISTERED: its boolean arm's i32 value box was never minted
// (`vbI32Used` stayed false — the outer union's own scalar is i64) and the narrowed
// `is boolean` element read `ref.cast`ed an UN-MINTED box index — INVALID-WASM (fuzz
// sweep5 declared leg, seed 20262378 case_00111). The arm path now descends through
// `registerInlineUnion`'s single-shape arm, exactly as a plain annotation of the same
// shape would.
// @run
// @log I64
// @log true
// @log 7
// @log 88
function useIt(
  p: {z: {a: {f: i64}, f: (boolean | {w: i32} | {q: i64})[]}} | i64,
) {
  const t0 = p
  if t0 is {z: {a: {f: i64}, f: (boolean | {w: i32} | {q: i64})[]}} {
    const t320 = t0.z.f[0]
    if (t320 is boolean) { print(t320) } else { print("NOTBOOL") }
    const t321 = t0.z.f[1]
    if (t321 is {q: i64}) { print(t321.q) } else { print("NOTQ") }
    print(t0.z.a.f)
  } else {
    print("I64")
  }
}
function go() {
  useIt(5000000077)
  useIt({ z: { a: { f: 88 }, f: [true, { q: 7 }] } })
}
go()
