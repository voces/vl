// Regression: a struct-typed IDENT (a plain-struct binding) coerced into a variant-box
// union `{…} | scalar` in a call ARG, a union LET-init, and a named-function RETURN. The
// value was built as the plain struct — a layout TWIN of but a DISTINCT heap type from the
// union arm's variant struct — so the raw ref boxed into the union position emitted invalid
// wasm (the box local / return / param wanted the variant struct type the narrow
// `ref.cast (ref $variant)` reads). The emitter now rebuilds the variant struct from the
// source (`emitStructExprAsVariantBox`). The closure-result twin of this family (incl. the
// single-field CALL-result runtime-trap path) lives in
// closures/closure-result-struct-arm-rebox.vl.
// @run
// @log 42
// @log 42
// @log 7
function take(x: {w: i32} | i32) {
  if x is {w: i32} { print(x.w) } else { print("TAKEOTHER") }
}
function mk(): {w: i32} | i32 {
  const s = { w: 7 }
  return s
}
function go() {
  // (a) struct ident as a union call ARGUMENT.
  const s = { w: 42 }
  take(s)
  // (b) struct ident into a union LET-init, then narrow + read.
  const u: {w: i32} | i32 = s
  if u is {w: i32} { print(u.w) } else { print("UOTHER") }
  // (c) named function RETURNING the struct arm via an ident binding.
  const r = mk()
  if r is {w: i32} { print(r.w) } else { print("ROTHER") }
}
go()
