// @run
// @log bb
// @log NULL
// @log 1.5
// @log NULL
// @log OTHER
// A value-union STRUCT variant carrying a NULLABLE-litunion field (`f: K0 | null`,
// the code-30 i32 niche) or a nullable-f32 field (`f: f32 | null`, the code-16 value
// box a plain struct field already carries): `unionArmBoxSafe` admits both nullable
// field types, so a WIDENING object literal (`f: "bb"` inferring `{f: string}`,
// `f: 1.5` inferring `{f: f64}`) adopts the union's struct arm field-wise, and
// `emitVariantStruct`'s code-30 arm seeds the atom + null-sentinel context exactly
// like the plain struct-literal path. Covers the deep-nested variant arm, a `null`
// field value, the nullable UNION carrier (`| f64 | null`) at the global position,
// and the non-struct arm. rep-fuzz p2c/p2r
// `{a: i32, f: {f: {a: i32, f: K0 | null, z: boolean}}, z: f64} | i32` and
// p3c/p3r `{f: f32 | null} | f64 | null` (were REJECT).
type K0 = "aa" | "bb" | "cc"

function makeIt(): {a: i32, f: {f: {a: i32, f: K0 | null, z: boolean}}, z: f64} | i32 {
  return { a: 1, f: { f: { a: 2, f: "bb", z: true } }, z: 1.5 }
}

const g: { f: f32 | null } | f64 | null = { f: 1.5 }
const gn: { f: f32 | null } | f64 | null = { f: null }
const gd: { f: f32 | null } | f64 | null = 2.5

function go() {
  // The deep-nested variant arm: `is` narrows, the chained member read binds the niche.
  const v = makeIt()
  if v is { a: i32, f: { f: { a: i32, f: K0 | null, z: boolean } }, z: f64 } {
    const t0 = v.f.f.f
    if t0 != null {
      print(t0) // bb
    } else {
      print("NULL")
    }
  } else {
    print("OTHER")
  }

  // A `null` litunion field value in the variant construct.
  const w: { f: K0 | null } | i32 = { f: null }
  if w is { f: K0 | null } {
    const t1 = w.f
    if t1 != null {
      print(t1)
    } else {
      print("NULL") // NULL
    }
  } else {
    print("OTHER")
  }

  // The nullable-f32 field through the nullable union carrier (global position).
  const t2 = g
  if t2 != null {
    if t2 is { f: f32 | null } {
      const t3 = t2.f
      if t3 != null {
        print(t3) // 1.5
      } else {
        print("NULL")
      }
    } else {
      print("OTHER")
    }
  } else {
    print("NULLV")
  }
  const t4 = gn
  if t4 != null {
    if t4 is { f: f32 | null } {
      const t5 = t4.f
      if t5 != null {
        print(t5)
      } else {
        print("NULL") // NULL
      }
    } else {
      print("OTHER")
    }
  } else {
    print("NULLV")
  }
  const t6 = gd
  if t6 != null {
    if t6 is { f: f32 | null } {
      print("S")
    } else {
      print("OTHER") // OTHER (the f64 arm)
    }
  } else {
    print("NULLV")
  }
}
go()
