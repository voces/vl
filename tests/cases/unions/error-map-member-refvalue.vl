// @emit-error a map union member is not supported
// A union whose MAP member has a REF-VALUE (`{[string]: {w: i32}}` struct value, or nested-map /
// union / closure value) is a DEFERRED shape: its per-value map struct's ref vals list has a
// heap-type-identity hazard in the union-box composite (the map struct minted for the box arm does
// not dedup with the one a read/field/global expects — invalid wasm). So the emitter rejects it
// LOUDLY at registration rather than emit silent invalid wasm. (A SCALAR / string / mono map value
// — `{[string]: string} | X`, `{[string]: i32} | X` — IS supported; see map-member-*.vl.)
function makeIt(): {[string]: {w: i32}} | boolean {
  const h: {[string]: {w: i32}} = Map()
  h["k"] = {w: 9}
  return h
}
function go() {
  const v: {[string]: {w: i32}} | boolean = makeIt()
  if v is {[string]: {w: i32}} {
    print("M")
  } else {
    print("B")
  }
}
go()
