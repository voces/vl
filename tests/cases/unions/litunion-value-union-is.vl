// @run
// @log hvjjv
// @log 42
// @log rldv
// @log 080
// @log OTHER
// @log hvjjv
// A literal-union ALIAS member of a VALUE union (`K0 | boolean`, `K0 | i32`, `K0 | {w: i32}`,
// and as a struct field `{f: K0 | i64}`) round-trips through a positive `is K0` test. The box
// stores a litunion member as a STRING ref (its members are string literals), so `is K0` is the
// string-tag compare and the narrowed read unboxes that string. A real `string` member cannot
// coexist (`K0 | string` collapses to `string`), so the string tag never collides.

type K0 = "080" | "hvjjv" | "rldv"

function pickBool(): K0 | boolean { return "hvjjv" }
function go1() {
  const v: K0 | boolean = pickBool()
  if v is K0 { print(v) } else { print("OTHER") } // hvjjv
}
go1()

function go2() {
  const v: K0 | i32 = 42
  if v is i32 { print(v) } else { print("K") } // 42 — the i32 arm, K0 tag distinct
}
go2()

function go3() {
  const v: K0 | f64 = "rldv"
  if v is K0 { print(v) } else { print("OTHER") } // rldv
}
go3()

const g: K0 | { w: i32 } = "080"
function go4() {
  if g is K0 { print(g) } else { print("OTHER") } // 080
}
go4()

// A struct value is NOT a K0 — the tag distinguishes it (the else-branch struct-field read
// is a separate pre-existing value-union gap, shared with `string | { w: i32 }`).
const g2: K0 | { w: i32 } = { w: 9 }
function go5() {
  if g2 is K0 { print("K") } else { print("OTHER") } // OTHER — the struct arm
}
go5()

// A litunion union carried in a struct FIELD (a multi-field struct with mixed-rep siblings).
function go6() {
  const o: { a: f64, f: K0 | i64, z: i64 } = { a: 1.5, f: "hvjjv", z: 5 }
  const t0 = o.f
  if t0 is K0 { print(t0) } else { print("I") } // hvjjv
}
go6()
