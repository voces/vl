// @run
// @log 9
// @log NULL
// @log OTHER
// @log 5
// @log NULL
// @log OTHER
// @log 6
// @log NULL
// @log OTHER
// A union whose STRUCT variant carries a NULLABLE-LIST field — both field codes: 28
// (`{[string]: i64}[] | null`, a nullable ref-list) and 18 (`i32[] | null`, the nullable
// i32-list), across the inline-shape and named-TypeDecl variant paths. The variant path
// interns the code-28 element ref-list slot (`collectA`'s variant field re-walk) and
// forces the code-18 i32-list pair, so the variant struct's field storage, the narrowed
// field read, and construction (list value, bare `null`, and the other arm) all lower.
// rep-fuzz p1c/p1r `{a: f64, f: {[string]: i64}[] | null, z: i32} | {w: i32}`.
function useMap(p: {a: f64, f: {[string]: i64}[] | null, z: i32} | {w: i32}) {
  const t0 = p
  if t0 is {a: f64, f: {[string]: i64}[] | null, z: i32} {
    const t1 = t0.f
    if t1 != null {
      const t2 = t1[0]["k"] ?? 13131313131
      print(t2)
    } else {
      print("NULL")
    }
  } else {
    print("OTHER")
  }
}
function useI32(p: {f: i32[] | null} | {w: i32}) {
  const t0 = p
  if t0 is {f: i32[] | null} {
    const t1 = t0.f
    if t1 != null { print(t1[0]) } else { print("NULL") }
  } else {
    print("OTHER")
  }
}
type A = {f: i32[] | null}
type B = {w: i32}
type U = A | B
function useNamed(p: U) {
  const t0 = p
  if t0 is A {
    const t1 = t0.f
    if t1 != null { print(t1[0]) } else { print("NULL") }
  } else {
    print("OTHER")
  }
}
function go() {
  const m: {[string]: i64} = Map()
  m["k"] = 9
  useMap({ a: 1.5, f: [m], z: 3 })
  useMap({ a: 2.5, f: null, z: 4 })
  useMap({ w: 77 })
  useI32({ f: [5] })
  useI32({ f: null })
  useI32({ w: 1 })
  useNamed({ f: [6] })
  useNamed({ f: null })
  useNamed({ w: 2 })
}
go()
