// @run
// @log a
// @log OTHER
// @log b
// @log LIST
// @log a
// A union with a LITERAL-UNION ARRAY member (`K[] | {w: i32}`, `K[] | i64`) rides the
// value-atom machinery: a litunion array's elements are interned i32 atom ids, so `K[]`
// shares the exact `i32[]` backing and is value-atom kind 7 (`boolean[]`'s pattern) —
// the `is K[]` tag, the narrowed unbox, and the narrowed index read all follow. The
// array LITERAL adopts the `K[]` arm member-wise in the checker (`assignableExpr`'s
// ArrayLit-into-union arm), and the arm's reflist/atom tag resolves through the
// litunion→string emit canon where a slot is keyed. Positions: param, global, struct
// field — construct AND `is`-read each.

type K = "a" | "b"

function useIt(p: K[] | {w: i32}) {
  if p is K[] { print(p[0]) } else { print("OTHER") }
}

const g: K[] | i64 = ["b"]

function go() {
  useIt(["a"]) // a — the literal adopts the K[] arm; the atom list boxes + tags
  useIt({w: 7}) // OTHER — the struct arm still discriminates
  if g is K[] {
    const t = g
    print(t[0]) // b — the narrowed global unboxes to the atom list; print widens the atom
  } else {
    print("OTHER")
  }
  const s: { a: boolean, f: K[] | {w: i32}, z: i32 } = { a: true, f: ["a"], z: 4 }
  const t0 = s.f
  if t0 is K[] {
    print("LIST") // LIST — the field's union arm tags the atom list
    print(t0[0]) // a — the narrowed field read indexes the atom list
  } else {
    print("OTHER")
  }
}
go()
