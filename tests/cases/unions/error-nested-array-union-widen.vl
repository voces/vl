// @emit-error does not match any array member of the union
// A nested int-array literal `[[50183]]` infers as `i32[][]` (leaf ints default to i32), but the
// union arm is `i64[][]` — a WIDER leaf scalar the nested-list constructor cannot widen in-place. The
// element slots (`i32[]` vs `i64[]`) mismatch, so the value cannot ride the union box as a ref-array
// wrapper. Pre-fix the emitter mis-boxed the wrapper ref through the scalar value-atom ladder
// (`struct.new` a scalar box on a ref → "expected i32, found (ref $type)", invalid wasm). Must be a
// CLEAN reject, never invalid wasm. (rep-fuzz p1c/p1r `i64[][] | boolean | null`.)
function useIt(p: i64[][] | boolean | null) {
  print(0)
}
useIt([[50183]])
