// @run
// @log 0
// @warning Unused variable `g`
// A closure whose RESULT struct SHARES field names with an ENCLOSING union arm.
// The closure field `f: () => {a: i32, f: i64, z: f64}` returns an inner struct
// `{a, f, z}` whose field-name SET collides with the enclosing union-arm struct
// `{a: boolean, f: () => …, z: i32}` (also `{a, f, z}`). `cbRetVariantIdx` resolved
// the closure's inferred return NAME to a union variant by field NAMES ONLY
// (`variantIndexOfTypeName`), so the lambda body wrongly built the enclosing arm's
// heap type — `struct.new`/result against `{i32, ref, i32}` while pushing
// `{i32, i64, f64}` operands: invalid wasm ("expected i32, found f64").
// Fix: `variantIndexOfTypeName` now also requires each field's TYPE code
// (`nameFieldCode`, via `shapeFieldParse` + `shapeFieldTypeCompat`) to match the
// variant field, so the shared-field-name shapes no longer collide. (rep-fuzz p3c
// `{a: boolean, f: () => {a: i32, f: i64, z: f64}, z: i32} | {w: i32}`.)
const g: {a: boolean, f: () => {a: i32, f: i64, z: f64}, z: i32} | {w: i32} = {
  a: true,
  f: () => ({a: 11, f: 56323814985252741, z: 2.5}),
  z: 11,
}

function go() {
  print(0)
}

go()
