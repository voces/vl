// @run
// @log 3.5
// @log 1.5
// @log 4
// A shape-text union VARIANT whose field is a STRUCT-element REF LIST
// (`{a, f: {f: f64}[], z} | i32` inline, `{a, f: S[], z} | i32` via a declared
// alias): `shapeFieldElemName` records the field's element key even while the
// struct table is still empty (`collectU` registers shape-text variants before
// `collectS` runs) — the stripped element text, canonical for exactly the
// named / inline-shape sorts `refArrElemName` cannot resolve yet — and
// `collectA`'s variant field pass interns the element (an inline SHAPE element
// first, then its ref-list slot), so `variantFieldRefSlot` resolves at the
// type-section emit and the narrowed field read chains into the element struct.
// Without either seam the emit fails loudly
// ("ref-list field element type is not interned").
type S = {g: f64}
type U = {a: i32, f: S[], z: i32} | i32
function go() {
  // An inline union annotation with an inline-shape element.
  const t: {a: i32, f: {f: f64}[], z: i32} | i32 = {a: 1, f: [{f: 3.5}], z: 2}
  if (t is {a: i32, f: {f: f64}[], z: i32}) {
    const t0 = t.f
    print(t0[0].f)
  }
  // The declared alias with a NAMED struct element — direct chained read.
  const u: U = {a: 1, f: [{g: 1.5}], z: 2}
  if (u is {a: i32, f: S[], z: i32}) {
    print(u.f[0].g)
  }
  // The scalar arm of the same union still narrows and reads.
  const w: U = 4
  if (w is i32) {
    print(w)
  }
}
go()
