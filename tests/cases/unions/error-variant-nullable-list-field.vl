// @emit-error a nullable-list union-variant field is not supported
// A struct with a NULLABLE-LIST field (`f: {[string]: i64}[] | null` — a nullable array-of-map)
// used as a UNION arm. The nullable-list field codes (18 nullable-i32-list, 28 nullable-ref-list)
// have their element ref-list slot deep-interned only on the STANDALONE-struct path, never on the
// union-variant path — so a later field READ (`t1[0]`, `t1.length` after narrowing) indexed an
// un-interned slot: a compiler-internal OOB trap (the map-array case) or invalid wasm (the i32-list
// case). Until the variant path interns those element shapes, this is a CLEAN reject, never a trap.
// (The standalone `{a: f64, f: {[string]: i64}[] | null, z: i32}` struct — not union-ed — compiles
// and reads fine.) rep-fuzz p1r `{a: f64, f: {[string]: i64}[] | null, z: i32} | {w: i32}` (was TRAP).
function useIt(p: {a: f64, f: {[string]: i64}[] | null, z: i32} | {w: i32}) {
  if p is {a: f64, f: {[string]: i64}[] | null, z: i32} {
    const t1 = p.f
    if (t1 != null) {
      const t2 = t1[0]["k"] ?? 13131313131
      print(t2)
    } else {
      print("NULL")
    }
  } else {
    print("OTHER")
  }
}
useIt({w: 77})
