// @run
// @log 3.5
// @log 2
// @log 0
// @log 3.5
// @log 2
// @log 1.5
// @log 7
// @log 5
// @log true
// @log 1
// A VALUE-UNION element carrying a LIST member, under a list — `(i32[] | f64)[]` — and
// under a 2-D array — `(i32[] | f64)[][]` (rep-fuzz R4 p2c/p2r). The union-box element
// loop no longer blanket-rejects an array VALUE ("nested arrays are not supported"):
// with a union arm to box into, the element routes through `emitUnionBoxArg` →
// `emitUnionCoerce` (which keeps its own loud rejects for a list the union cannot box),
// and the OUTER literal's list threading is cleared around the box so the inner `[1, 2]`
// builds its own value-atom i32 list, not the outer slot's ref build. The SAME seam
// under a map VALUE (`{[string]: (f64[] | i32)[]}`) and a struct FIELD
// (`{a: i32, f: (i32[] | boolean)[], z: f32}`) — the p2c/p2r shapes that graduated with
// this fix — is pinned below.
function mkMap(): { [string]: (f64[] | i32)[] } {
  const m: { [string]: (f64[] | i32)[] } = Map()
  m["a"] = [[1.5], 7]
  return m
}

function mkStruct(): { a: i32, f: (i32[] | boolean)[], z: f32 } {
  return { a: 1, f: [[4, 5], true], z: 2.5 }
}

function go() {
  const v: (i32[] | f64)[] = [[1, 2], 3.5]
  const e = v[1]
  if e is f64 { print(e) } // 3.5
  const e2 = v[0]
  if e2 is i32[] { print(e2[1]) } // 2

  const w: (i32[] | f64)[][] = [[[1, 2], 3.5]]
  print(w.length - 1) // 0
  const we = w[0][1]
  if we is f64 { print(we) } // 3.5
  const we2 = w[0][0]
  if we2 is i32[] { print(we2[1]) } // 2

  // Map-value + struct-field positions of the same union-box-list-element rep.
  const m = mkMap()
  const mv = m["a"] ?? []
  const me = mv[0]
  if me is f64[] { print(me[0]) } // 1.5
  const me2 = mv[1]
  if me2 is i32 { print(me2) } // 7
  const s = mkStruct()
  const f0 = s.f[0]
  if f0 is i32[] { print(f0[1]) } // 5
  const f1 = s.f[1]
  if f1 is boolean { print(f1) } // true
  print(s.a) // 1
}
go()
