// @run
// @log 1
// @log 2
// @log 2
// @log 7
// An UN-annotated function whose inferred return is a struct-UNION (`Cat | Dog`) — returning a
// concrete variant from each branch, via explicit `return`s or a tail `if`-value. The emitter
// boxes a variant `return` into the union `{tag, payload}` rep only when it knows the return is a
// union; for an un-annotated function that came from the checker's inferred-return NAME, but
// `emitReturnValue` accepted only a VALUE union (`i32 | string`) there — a struct-union inferred
// name was ignored, so the raw variant ref was returned (invalid wasm). It now also accepts a
// registered struct-union name (`isUName`), so the variant boxes exactly as the annotated
// `: Cat | Dog` path does. A bare `i32 | string` value-union return already worked.

type Cat = { meow: i32 }
type Dog = { bark: i32 }

// explicit per-branch returns, un-annotated (inferred `Cat | Dog`).
function viaReturns(c: i32) {
  const x: Cat = { meow: 1 }
  const y: Dog = { bark: 2 }
  if c > 1 { return x } else { return y }
}

// a tail `if`-value join, un-annotated.
function viaIf(c: i32) {
  const x: Cat = { meow: 1 }
  const y: Dog = { bark: 2 }
  return if c > 1 then x else y
}

function go() {
  const a = viaReturns(5)
  if a is Cat {
    print(a.meow) // 1
  }

  const b = viaReturns(0)
  if b is Dog {
    print(b.bark) // 2
  }

  const d = viaIf(0)
  if d is Dog {
    print(d.bark) // 2
  }

  // narrow the THEN arm of the if-join.
  const e = viaIf(9)
  if e is Cat {
    print(e.meow + 6) // 7
  }
}
go()
