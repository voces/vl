// @run
// @log NULL
// @log hi
// @log 9
// @log NULL
// A value-union whose STRUCT variant carries a niche-nullable field (`{f: string | null} | {w: i32}`)
// builds correctly when that field is `null`: `emitVariantStruct` seeds the field's null context
// (`ref.null $aTypeIdx` for a `string | null` field), exactly as the plain struct-literal path does.
// Without it a `{f: null}` variant hit `bare null needs a struct-typed context`. Covers the global +
// local positions, the null and non-null field values, and the other (`{w}`) variant.

const g: { f: string | null } | { w: i32 } = { f: null }
function go0() {
  const t0 = g
  if t0 is { f: string | null } {
    const t1 = t0.f
    if t1 != null { print(t1) } else { print("NULL") } // NULL
  } else {
    print("OTHER")
  }
}
go0()

function go1() {
  const v: { f: string | null } | { w: i32 } = { f: "hi" }
  if v is { f: string | null } {
    const t1 = v.f
    if t1 != null { print(t1) } else { print("NULL") } // hi
  } else {
    print("OTHER")
  }
}
go1()

const gw: { f: string | null } | { w: i32 } = { w: 9 }
function go2() {
  const t0 = gw
  if t0 is { w: i32 } { print(t0.w) } else { print("A") } // 9
}
go2()

// A boolean|null niche field variant — the sentinel-2 seed.
function go3() {
  const v: { b: boolean | null } | { w: i32 } = { b: null }
  if v is { b: boolean | null } {
    const t1 = v.b
    if t1 != null { print(t1) } else { print("NULL") } // NULL
  } else {
    print("OTHER")
  }
}
go3()
