// @run
// @log 9
// @log -1
// A union MAP arm spelled as one layout twin, carrying the OTHER spelling: the
// arm says `{[string]: {v: i32}}` (inline shape value), the carrier is a
// `{[string]: A}` with `type A = {v: i32}`. The box tag (`mapSlotTag`), the
// arm-slot guard (`unionHasMapArmSlot`), and the map-struct heap type
// (`mvTwin`) all canonicalize through the ONE map-value representative
// (`mvCanonRepOf`), so the carrier boxes with the arm's tag, the `is` compare
// hits, and the narrowed read casts to the shared heap type. Before the dedup
// this was a loud REJECT ("a map value is not a supported union member"): the
// carrier's nominal mv slot matched no arm slot, so the box path refused it.
type A = { v: i32 }

function pick(p: {[string]: {v: i32}} | string): i32 {
  if p is {[string]: {v: i32}} {
    const s = p["k"] ?? { v: 0 }
    return s.v
  }
  -1
}

function go() {
  const m: {[string]: A} = Map()
  m["k"] = { v: 9 }
  print(pick(m))     // 9 — twin-spelled carrier boxes + narrows
  print(pick("str")) // -1 — the other arm still discriminates
}
go()
