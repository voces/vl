// @run
// @log 0
// @log 0
// @log 0
// @hint Intentionally-unused variable `_v`
// @hint Intentionally-unused variable `_s`
// @hint Intentionally-unused variable `_u`
// A union VARIANT whose field is a SCALAR-element list (`{a: i32, f: i64[]} | i32` —
// rep-fuzz F3). Two seams: the variant-field collectors never forced the scalar-list
// backing/wrapper types (a variant may be the program's only `i64[]` mention →
// "i64 list type not collected"), and `emitVariantStruct` threaded the element-kind
// context only for ref/string list fields — an i64[] field's small-literal elements
// built an i32 list into the i64-list slot. Covers the multi-field and single-field
// shapes and small-literal element widening. (The field READ back out of the variant
// is a separate, still-open composition gap — construct-only here, like the fuzzer
// variant that exposed it; an f32[] field is blocked earlier by the checker's
// float-literal-through-a-wrapper reject.)
function go() {
  const _v: {a: i32, f: i64[], z: boolean} | i32 = {a: 11, f: [6000000000], z: true}
  print(0)
  const _s: {f: i64[]} | i32 = {f: [5]}
  print(0)
  // Distinct field names — an object literal picks its variant by field-name SET,
  // so a same-named {a,f,z} shape would collide with the i64[] variant above.
  const _u: {b: i32, g: f64[], y: string} | i32 = {b: 1, g: [2.5], y: "d"}
  print(0)
}
go()
