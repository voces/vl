// @run
// @log 63.5
// @log 2.5
// @log 1
// @log 7.5
// @log STR
// @log hey
// @log 9000000000
// @log W
// @log 4
// @log EMPTY
// @log 0
// @log 5.5
// An `f32[]` member of a value union rides its OWN list atom (value-atom kind 12, the
// `$fa32`/`$fl32` backing — distinct from the f64 list's kind 8): the box tags it via
// `scalarTagOf`, `is f32[]` narrows, and the narrowed read unboxes the f32-list wrapper
// (`atomListWrapHeap`). A float-element literal classifies `f64[]` (a float literal types
// f64), so the coerce re-encodes it at f32 when the union's only float-list atom is
// `f32[]`; the checker's union-arm adoption records the `f32[]` arm on the literal.
// (rep-fuzz REJECT p3c/p3r `f32[] | i64`, p3c/p3r `f32[] | string`, p1r `f32[] | {w: i32}`.)

// GLOBAL binding, string sibling arm (p3c/p3r `f32[] | string`).
const g: f32[] | string = [63.5]
function readGlobal() {
  const t0 = g
  if t0 is f32[] { print(t0[0]) } else { print("OTHER") }
}
readGlobal()

// i64 sibling arm (p3c/p3r `f32[] | i64`) — narrowed read + `.length`.
function readF32s(p: f32[] | i64) {
  const t0 = p
  if t0 is f32[] {
    print(t0[0])
    print(t0.length)
  } else {
    print("OTHER")
  }
}
readF32s([2.5])

// STRUCT-variant sibling arm (p1r `f32[] | {w: i32}`) — the atom band sits above the
// variant ranks, so the f32-list tag discriminates from the struct arm.
function readParam(p: f32[] | {w: i32}) {
  const t0 = p
  if t0 is f32[] { print(t0[0]) } else { print("OTHER") }
}
readParam([7.5])

// The OTHER arms still discriminate against the f32-list tag (no band collision).
function fromStr(p: f32[] | string) {
  const t = p
  if t is f32[] {
    print(t[0])
  } else {
    print("STR")
    print(t)
  }
}
fromStr("hey")

function fromI64(p: f32[] | i64) {
  const t = p
  if t is i64 { print(t) } else { print("OTHER") }
}
fromI64(9000000000)

function fromStruct(p: f32[] | {w: i32}) {
  const t = p
  if t is {w: i32} {
    print("W")
    print(t.w)
  } else {
    print("OTHER")
  }
}
fromStruct({ w: 4 })

// An EMPTY `[]` adopts the union's f32-list atom (the empty-literal route keeps the
// value-atom ladder, not the ref-array arm path).
function fromEmpty(p: f32[] | string) {
  const t = p
  if t is f32[] {
    print("EMPTY")
    print(t.length)
  } else {
    print("OTHER")
  }
}
fromEmpty([])

// A NON-literal `f32[]` value boxes as-is (the wrapper ref rides the box anyref —
// `exprF32Array` claims it BEFORE the f64-list classifier).
function fromVal() {
  const xs: f32[] = [5.5]
  const u: f32[] | string = xs
  const t = u
  if t is f32[] { print(t[0]) } else { print("OTHER") }
}
fromVal()
