// @run
// @log yes
// @log 2
// @log other
// @log 43
// @log 7
// @log yes
// @log yes
// @log yes
// @log 3
// @log 5
// @log 0
// @log 8
// A union whose arm is a LIST OF A PAREN-GROUPED VALUE UNION alongside another arm
// (`(i32 | string)[] | {w: i32}` and scalar/boolean neighbors). Was a LIVE SILENT
// MISCOMPILE (fuzz oracle #906, MISMATCH class): `splitUnionAtoms` split the union
// name INSIDE the paren group (brace/bracket-only depth), so the whole annotation
// mis-split into garbage atoms — the binding silently dropped its union rep (the
// initializer's own type won) and every `is (i32 | string)[]` const-folded FALSE:
// `["other"]` took the ELSE branch, no trap, no validation error. The paren-aware
// split registers the arm; `emitUnionCoerce` routes the scalar-element list literal
// through the arm's union-box-element build (`pendingListKind = 2` + the arm's slot)
// and tags the wrapper with the arm's `refArrSlotTag` — the same rep an annotated
// `let x: (i32|string)[] = [...]` binding builds, boxed.
function go() {
  const x: (i32 | string)[] | {w: i32} = ["other", 42]
  if x is (i32 | string)[] {
    print("yes") // the original mismatch printed the ELSE branch
    print(x.length)
    const e = x[0]
    if e is string { print(e) } else { print("num") }
    const e1 = x[1]
    if e1 is i32 { print(e1 + 1) } else { print("str") }
  } else {
    print("no")
  }
  // The STRUCT arm still boxes + narrows.
  const y: (i32 | string)[] | {w: i32} = {w: 7}
  if y is {w: i32} { print(y.w) } else { print("list") }
}
go()

// Neighboring shapes: a SCALAR other arm (`| i32`) mis-tagged through the value-atom
// ladder (box tag `string[]`, `is` silently FALSE); a flipped arm order; a boolean
// inner union.
function neighbors() {
  const a: (i32 | string)[] | i32 = ["other"]
  if a is (i32 | string)[] { print("yes") } else { print("no") }
  const b: {w: i32} | (i32 | string)[] = ["other"]
  if b is (i32 | string)[] { print("yes") } else { print("no") }
  const c: (boolean | string)[] | {w: i32} = ["other"]
  if c is (boolean | string)[] { print("yes") } else { print("no") }
}
neighbors()

// The PARAM/RETURN coerce boundary + the EMPTY literal (routes to the arm when no
// value-atom list arm could claim it).
function take(p: (i32 | string)[] | {w: i32}): i32 {
  if p is {w: i32} { return p.w }
  return p.length
}
function boundary() {
  print(take(["a", 2, "c"])) // 3
  print(take({w: 5})) // 5
  const e: (i32 | string)[] | {w: i32} = []
  if e is (i32 | string)[] { print(e.length) } else { print("no") }
}
boundary()

// REASSIGNMENT across the arms (was invalid wasm once the union registered).
function reassign() {
  let v: (i32 | string)[] | {w: i32} = {w: 1}
  v = ["g", 8]
  if v is (i32 | string)[] {
    const g = v[1]
    if g is i32 { print(g) } else { print("s") }
  } else { print("no") }
}
reassign()
