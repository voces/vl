// @run
// @log 57
// @log 6
// @log 33
// @log 21
// @log 8
// @log -4
// @log 12
// @log 11
// The ELSE-arm of `v is <value-atom>` over a MIXED union (struct arm + value atom,
// `{f: i32} | i32`) — the #923-observed hole: the emitter's complement narrow
// (`setNarrowFromCondElse`) treated a value-atom test as value-union-only and never
// registered the negative arm, so a GLOBAL receiver's else-arm `v.f` read the box
// RAW (`struct.get` on the union box — invalid wasm) while a function-local
// spelling rejected loudly. A mixed union now falls through to the struct-union
// complement: subtracting the tested atom leaves the struct arm(s), and `v.f`
// reads through the same narrowed-member downcast the positive arm uses — global
// and local agree.

// GLOBAL receiver, struct-valued: the else-arm reads the struct arm.
const v: {f: i32} | i32 = {f: 57}
if v is i32 {
  print(0 - 1)
} else {
  print(v.f) // 57
}

// GLOBAL receiver, value-valued: the then-arm reads the atom.
const w: {f: i32} | i32 = 5
if w is i32 {
  print(w + 1) // 6
} else {
  print(w.f)
}

// DECLARED-alias struct arm.
type S = {g: i32}
const s: S | i32 = {g: 33}
if s is i32 {
  print(0 - 1)
} else {
  print(s.g) // 33
}

// Function-LOCAL spelling (rejected loudly before the fix; narrows identically now).
function pick(): i32 {
  const t: {f: i32} | i32 = {f: 21}
  if t is i32 {
    0 - 1
  } else {
    t.f
  }
}
print(pick()) // 21

// GUARD-if flow narrow over a PARAM: the tail after the early return sees the
// complement (struct arm), and the then-arm reads the narrowed value atom.
function tail(u: {f: i32} | i32): i32 {
  if u is i32 { return 0 - u }
  u.f
}
print(tail({f: 8})) // 8
print(tail(4))      // -4

// THREE-arm chain: the final else subtracts BOTH value atoms.
const m: {f: i32} | i32 | string = {f: 12}
if m is i32 {
  print(0 - 1)
} else if m is string {
  print(0 - 2)
} else {
  print(m.f) // 12
}

// Reverse pin (worked before the fix): the else of `is <struct-arm>` reads the
// remaining VALUE atom.
const r: {f: i32} | i32 = 9
if r is {f: i32} {
  print(0 - 1)
} else {
  print(r + 2) // 11
}
