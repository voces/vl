// @run
// @log I64LIST
// @log 670563
// @log 6000000000
// @log F64LIST
// @log 8
// An INT-element list literal into a union with no `i32[]` member but an `i64[]` (or
// `f64[]`) one adopts the union's list atom: `[670563]` under `i64[] | boolean` builds the
// i64-backed list and TAGS it `i64[]`, so `is i64[]` agrees with the checker. (rep-fuzz
// SILENT WRONG RESULT: the box tagged `i32[]` while the checker typed the member `i64[]`
// — `v is i64[]` was FALSE for small-literal elements; `[6000000000]` worked.)

function readI64s() {
  const v: i64[] | boolean = [670563]
  const t = v
  if t is i64[] {
    print("I64LIST")
    print(t[0])
  } else {
    print("OTHER")
  }
}
readI64s()

function bigStill() {
  const v: i64[] | boolean = [6000000000]
  const t = v
  if t is i64[] { print(t[0]) } else { print("OTHER") }
}
bigStill()

// The f64[] READ side: the narrowed atom's `t[0]` unboxes the f64-list wrapper
// (`exprF64Array`'s kind-8 union arm + `atomListWrapHeap`), so the tag AND the read hold.
function readF64s() {
  const v: f64[] | boolean = [8]
  const t = v
  if t is f64[] {
    print("F64LIST")
    print(t[0])
  } else {
    print("OTHER")
  }
}
readF64s()
