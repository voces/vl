// @run
// @log I64
// @log 5
// @log 6000000000
// @log F64
// @log 7
// A UNION-VARIANT struct built from an object literal widens its SCALAR i64/f64 fields at
// the construction boundary, exactly as a plain struct literal does: `{f: 5}` into
// `{f: i64} | i32` must store an i64 (the variant struct's field rep), not the literal's
// default i32. (rep-fuzz: `p0r {f: i64} | i32` was invalid wasm — `expected i64, found
// i32` at the variant `struct.new`; only an already-i64 literal like 6000000000 worked.)

function readI64(v: { f: i64 } | i32) {
  const t = v
  if t is { f: i64 } {
    print("I64")
    print(t.f)
  } else {
    print("OTHER")
  }
}
readI64({ f: 5 })

function bigStill() {
  const v: { f: i64 } | i32 = { f: 6000000000 }
  const t = v
  if t is { f: i64 } {
    print(t.f)
  } else {
    print("OTHER")
  }
}
bigStill()

function readF64(v: { g: f64 } | i32) {
  const t = v
  if t is { g: f64 } {
    print("F64")
    print(t.g)
  } else {
    print("OTHER")
  }
}
readF64({ g: 7 })
