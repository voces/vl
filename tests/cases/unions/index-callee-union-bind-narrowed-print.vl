// narrowed to a scalar atom and read (`if t0 is boolean { print(t0) }`). The narrowed
// unbox gate required the syntactic union-name render (`unionNameOfIdent`), which the
// Index callee misses — the read pushed the raw union BOX where the i32 was expected:
// INVALID-WASM (fuzz sweep2 multiobs leg, seed 655720167 case_00209 reduction). The
// typed-IR net (`identChainTyBoxedUnion`) now resolves the binding's boxed union from
// its origin's checked type.
// @run
// @log false
// @hint Intentionally-unused parameter `_q0`
function mk(_q0: i32): {f: {[string]: string}} | boolean { return false }
function go() {
  const v: ((i32) => {f: {[string]: string}} | boolean)[] = [mk]
  const t0 = v[0](1)
  if t0 is boolean { print(t0) } else { print("OTHER") }
}
