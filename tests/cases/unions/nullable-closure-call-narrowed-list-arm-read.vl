// Regression: a binding off a narrowed nullable-closure param's call (`const t1 =
// t0(1, 1, 1)` — no syntactic union render) narrowed to a REF-ARRAY arm and indexed
// (`t1 is ({f: boolean} | null)[]` then `t1[0]`). The ref-array unbox gate required
// `unionNameOfIdent`, so the read pushed the raw union BOX where the list wrapper was
// expected — INVALID-WASM (fuzz sweep4 declared leg, seed 462516905 case_00383). The
// `identChainTyBoxedUnion` typed-IR net (the value-atom arm's discipline from #977)
// now covers the ref-array arm too.
// @run
// @log NULL
function useIt(
  p: ((i32, i32, i32) => ({f: boolean} | null)[] | boolean) | null,
) {
  const t0 = p
  if (t0 != null) {
    const t1 = t0(1, 1, 1)
    if (t1 is ({f: boolean} | null)[]) {
      const t2 = t1[0]
      if t2 != null { print(t2.f) } else { print("NULL") }
    } else {
      print("OTHER")
    }
    const u1: ({f: boolean} | null)[] | boolean = false
    if u1 is boolean { print(u1) } else { print("UOTHER") }
  } else {
    print("NULL")
  }
}
function go() { useIt(null) }
go()
