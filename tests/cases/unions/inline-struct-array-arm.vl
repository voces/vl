// @run
// @log 6000000000
// @log 1
// @log 2.5
// @log 42
// A union whose ARM is an ARRAY of an INLINE STRUCT / MAP shape (`{f: i64}[] | f64`) now gets the
// sound `{tag, wrapper-ref}` box rep at construct AND narrowed-read. The inline element shape was
// previously interned ONLY under the anonymous `#anonN` name minted by the object literal, while the
// union arm referred to it by its shape TEXT (`{f: i64}`) — two names, two reflist slots, so
// `unionHasRefArrayArmSlot` missed the arm and the coerce fell through to scalar value-boxing (it
// stored the reflist WRAPPER ref into an i64 value box: INVALID-WASM). `internShapeDeep` now descends
// into the arms of a PAREN-FREE composite union during `collectAnnShapes`, interning the arm's inline
// shape under its shape TEXT BEFORE the literal is seen by `collectAnonShapes` — so both sides key the
// same reflist slot. Found by the rep-composition fuzzer (graduated `INVALID-WASM p0c/p0r {f: i64}[]
// | f64`).

// The struct-element array arm, read back through an `is` narrow.
function readStructArm(v: { f: i64 }[] | f64): i64 {
  if v is { f: i64 }[] {
    return v[0].f
  }
  return 0
}

// The `.length` of the narrowed ref-array arm.
function armLength(v: { f: i64 }[] | f64): i32 {
  if v is { f: i64 }[] {
    return v.length
  }
  return -1
}

// The SCALAR (f64) arm of the same union still reads.
function readScalarArm(v: { f: i64 }[] | f64): f64 {
  if v is f64 {
    return v
  }
  return 0.0
}

function go() {
  const arr: { f: i64 }[] | f64 = [{ f: 6000000000 }]
  print(readStructArm(arr)) // 6000000000
  print(armLength(arr)) // 1
  const sca: { f: i64 }[] | f64 = 2.5
  print(readScalarArm(sca)) // 2.5
  // A multi-element ref-array arm.
  const two: { f: i64 }[] | f64 = [{ f: 40 }, { f: 2 }]
  if two is { f: i64 }[] {
    print(two[0].f + two[1].f) // 42
  }
}

go()
