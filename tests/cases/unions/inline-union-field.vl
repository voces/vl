// @run
// @log 1.5
// @log 7
// @log hi
// @log 8
// @log true
// @log 9
// @log 10
// @log 11
// @log 20
// An INLINE value-union struct field (`{f: f32 | {w: i32}}`) round-trips exactly like the
// NAMED-alias spelling (`type U = f32 | {w: i32}; {f: U}`). The union sits in the field, not at
// the annotation's top level, so the inline shape must register its field union's variant structs
// the same way a named `type T = { f: U }` does — otherwise a scalar-arm read (or an else-branch
// narrow to the struct member) fails ("field access receiver is not a struct"). Covers scalar and
// struct members, a multi-field struct with a union field, and a struct|struct member field.

function readF32(o: { f: f32 | { w: i32 } }) {
  if o.f is f32 { print(o.f) } else { print(o.f.w) }
}
readF32({ f: 1.5 })      // 1.5 — scalar arm
readF32({ f: { w: 7 } }) // 7   — struct arm (else-branch narrow)

function readStr(o: { f: string | { w: i32 } }) {
  if o.f is string { print(o.f) } else { print(o.f.w) }
}
readStr({ f: "hi" })     // hi
readStr({ f: { w: 8 } }) // 8

// A multi-field struct whose middle field is a value union (the decoy siblings keep their reps).
function readMid(o: { a: boolean, f: boolean | { w: i32 }, z: i32 }) {
  if o.f is boolean { print(o.f) } else { print(o.f.w) }
  print(o.z)
}
readMid({ a: true, f: true, z: 9 })       // true / 9
readMid({ a: true, f: { w: 10 }, z: 11 }) // 10  / 11

// A field whose union is TWO struct members (`{v: i32} | {w: i32}`), read via the carrier's
// positive `is` arm (the graduated `p3r {a, f: {…} | {w: i32}, z}` shape's read shape).
function readTwo(o: { f: { v: i32 } | { w: i32 } }) {
  if o.f is { w: i32 } { print(o.f.w) } else { print(0) }
}
readTwo({ f: { w: 20 } }) // 20
