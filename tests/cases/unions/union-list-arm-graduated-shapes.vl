// @run
// @log a
// @log 3
// @log 9
// @log 4
// @log s
// @log nil
// @log list
// @log 1.5
// @log 7
// Pinned regressions for the rep-fuzz baseline shapes graduated by the list-of-union
// arm fix (all were loud REJECTs at the pinned seeds; the const/return positions of the
// same family were the #906 MISMATCH): an f32 inner union, an i64 + STRUCT inner union,
// a boolean + struct inner union alongside `string | null` arms, and a nested inline
// struct whose FIELD union carries a `(boolean | null)[]` niche-list arm.
function f32Inner() {
  const x: (f32 | string)[] | {w: i32} = ["a"]
  if x is (f32 | string)[] {
    const e = x[0]
    if e is string { print(e) } else { print("f") }
  } else { print("no") }
}
f32Inner()

function i64StructInner() {
  const x: (i64 | {w: i32})[] | {w: i32} = [{w: 3}]
  if x is (i64 | {w: i32})[] {
    const e = x[0]
    if e is {w: i32} { print(e.w) } else { print("i") }
  } else { print("no") }
  const y: (i64 | {w: i32})[] | {w: i32} = {w: 9}
  if y is {w: i32} { print(y.w) } else { print("list") }
}
i64StructInner()

function boolStructInner() {
  const x: (boolean | {w: i32})[] | string | null = [true, {w: 4}]
  if x is (boolean | {w: i32})[] {
    const e = x[1]
    if e is {w: i32} { print(e.w) } else { print("b") }
  } else { print("no") }
  const y: (boolean | {w: i32})[] | string | null = "s"
  if y is string { print(y) } else { print("no") }
  const z: (boolean | {w: i32})[] | string | null = null
  if z is null { print("nil") } else { print("no") }
}
boolStructInner()

function nestedFieldNicheList() {
  const s: {a: string, f: {a: string, f: (boolean | null)[] | i32, z: f64}, z: boolean} = {a: "x", f: {a: "y", f: [true, null], z: 1.5}, z: false}
  const inner = s.f
  const v = inner.f
  if v is i32 { print("i32") } else { print("list") }
  print(inner.z)
  const s2: {a: string, f: {a: string, f: (boolean | null)[] | i32, z: f64}, z: boolean} = {a: "x", f: {a: "y", f: 7, z: 2.5}, z: true}
  const v2 = s2.f.f
  if v2 is i32 { print(v2) } else { print("list") }
}
nestedFieldNicheList()
