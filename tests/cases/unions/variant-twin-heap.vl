// @run
// @log 7
// @log 107
// @log -1
// @log 7
// @log 107
// @log -1
// Variant slot dedup (roadmap repOf, slot layer): two union variants that are
// LAYOUT TWINS share one variant-struct heap type (`uVarTwin`/`uVarHeap` —
// canonical variant key + per-field storage guard), covering BOTH:
//   · the SAME declared variant in TWO unions (`Cat` in `Cat | Dog` and in
//     `Cat | Bird`) — each union's push minted its own heap type before, so the
//     duplicate emitted twice and any cross-union flow risked a type mismatch;
//   · STRUCTURAL twins with different names (`Cat`/`Kot`, both `{m: i32}`) —
//     a `Cat` boxed into `Kot | Bird` carried `Cat`'s variant heap where the
//     narrowed `is Kot` read cast to `Kot`'s: a runtime TRAP before (the tags
//     already agreed — `variantSig` keys on field names — so the tag compare
//     PASSED and the cast blew up); with one shared heap type the narrow reads
//     the twin soundly.

type Cat = { m: i32 }
type Kot = { m: i32 }
type Dog = { w: i32 }
type Bird = { z: i32 }
type U = Cat | Dog
type V = Kot | Bird
type W = Cat | Bird

function pickU(u: U): i32 {
  if u is Cat { u.m } else { -1 }
}
function pickV(v: V): i32 {
  if v is Kot { v.m + 100 } else { -1 }
}
function pickW(w: W): i32 {
  if w is Cat { w.m } else { -1 }
}

function go() {
  const c: Cat = { m: 7 }
  print(pickU(c))  // 7 — Cat through U
  print(pickV(c))  // 107 — Cat through V's structural twin arm (was a TRAP)
  const d: Dog = { w: 1 }
  print(pickU(d))  // -1

  const c2: Cat = { m: 7 }
  print(pickW(c2)) // 7 — the SAME Cat variant declared in a second union
  print(pickV(c2)) // 107 — and still a twin of V's Kot
  const b: Bird = { z: 3 }
  print(pickW(b))  // -1
}
go()
