// @run
// @log 7
// @log 1
// @log 5
// @log hi
// @log 5
// @log 42
// A struct carrying a VALUE-UNION field, itself nested as an ARM of an OUTER union — the
// nested struct-field-union rep hole (rep-fuzz `p3r {f: boolean | i64} | i64`,
// `p2r {f: string | f64} | f64`). The arm struct's union field must box on construction
// (`emitVariantStruct` code 16 → `emitUnionCoerce`) and unbox on the narrowed read
// (`emitNarrowedMem` / `emitIs`); the field's value boxes are interned for the arm too
// (`collectVariantFields`). Without these the arm `struct.new`'d a raw scalar where a
// `(ref $box)` was required (invalid wasm), or the narrowed `v.a is i64` folded to a
// constant false. (Each shape uses a DISTINCT field name so the module's variants keep
// disjoint field-sets — `objVariantName` is a global field-set match, and two same-field-set
// variants in ONE module cross-wire, an orthogonal limitation the per-shape fuzzer never hits.)
function go1() {
  const v: { a: boolean | i64 } | i64 = ({ a: 7 })
  if v is { a: boolean | i64 } {
    if v.a is i64 { print(v.a) } else { print("OTHER") } // 7
  } else { print("OTHER") }
}
go1()

function go2() {
  const v: { b: string | f64 } | f64 = ({ b: 3.0 })
  if v is { b: string | f64 } {
    if v.b is f64 { print(1) } else { print("OTHER") } // 1
  } else { print("OTHER") }
}
go2()

// A struct whose field is a union of TWO STRUCT members, one of which shares the outer
// field name `c` (`{c: string} | {w: i32}` under a field `c`): the field-name COLLISION
// must not mis-resolve the inner literal to the outer struct (`emitUnionCoerce` boxes an
// object literal as its matching variant directly). rep-fuzz `p3r {f: {f: string} | {w: i32}}`.
function go3() {
  const a: { c: { c: string } | { w: i32 } } = ({ c: ({ w: 5 }) })
  if a.c is { w: i32 } { print(a.c.w) } else { print("OTHER") } // 5
  const b: { c: { c: string } | { w: i32 } } = ({ c: ({ c: "hi" }) })
  if b.c is { c: string } { print(b.c.c) } else { print("OTHER") } // hi
}
go3()

// A NULLABLE value-union field as an arm (`{d: i32 | null} | string`): the arm interns the
// field's i32 value box (a REJECT that regressed to invalid-wasm without the interning).
function go4() {
  const v: { d: i32 | null } | string = ({ d: 5 })
  if v is { d: i32 | null } {
    if v.d is i32 { print(v.d) } else { print("OTHER") } // 5
  } else { print("OTHER") }
}
go4()

// A multi-field arm with an i64|null value-union middle field (`{p, e: i64 | null, z} | i32`).
function go5() {
  const v: { p: f64, e: i64 | null, z: i64 } | i32 = ({ p: 1.0, e: 42, z: 3 })
  if v is { p: f64, e: i64 | null, z: i64 } {
    if v.e is i64 { print(v.e) } else { print("OTHER") } // 42
  } else { print("OTHER") }
}
go5()
