// @run
// @log 50183
// @log 12
// @log true
// @log 0
// @log cd
// @log 2
// @log zz
// A nested int-array literal `[[50183, 12]]` infers as `i32[][]` (leaf ints default to i32),
// while the union arm is `i64[][]` — a WIDER leaf scalar. The literal's own slot (`i32[]`
// element) matches no arm, so the old carrier path rejected loudly ("leaf-scalar widening
// across a nested array is unsupported"; before that fix it was invalid wasm). Now
// `emitUnionCoerce` routes an ArrayLit carrier through the union's SINGLE nested-array arm
// (`unionNestedArrayArmSlot` → `emitUnionNestedListLit`): the literal builds with the ARM's
// ref-list slot threaded — the same authoritative threading an annotated `i64[][]` binding
// uses — so the i64 inner-list build widens the bare-int leaves at the store
// (`emitExprAsI64`). A `string[][]` arm routes the same way for a literal that never
// self-classifies as a ref array (`[["ab"]]`, string leaf — invisible to `exprRefArray`).
// A union with NO nested-array arm, more than one, or a non-literal carrier keeps the loud
// reject. (rep-fuzz R4: p1c/p1r `i64[][] | boolean | null`, p3c/p3r `string[][] | string`.)
function useIt(p: i64[][] | boolean | null) {
  if p is i64[][] {
    print(p[0][0]) // 50183
    print(p[0][1]) // 12
  }
  if p is boolean { print(p) }
  if p == null { print(0) }
}

const g: string[][] | string = [["ab", "cd"], ["ef"]]

function mk(): string[][] | string {
  return [["zz"]]
}

function go() {
  useIt([[50183, 12]])
  useIt(true)
  useIt(null)
  if g is string[][] {
    print(g[0][1]) // cd
    print(g.length) // 2
  }
  const v = mk()
  if v is string[][] { print(v[0][0]) } // zz
}
go()
