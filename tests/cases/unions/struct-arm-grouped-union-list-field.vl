// @run
// @log false
// @log OTHER
// A union whose STRUCT arm carries a `(...)`-grouped union-element LIST field
// (`{…, f: (boolean | string | null)[], …} | f64`). The paren-carrying union name used to skip
// `internShapeDeep`'s arm interning entirely (its splitter was paren-blind), so the struct arm
// interned only lazily at emit — AFTER type-index assignment — and the field's ref-list element
// (`boolean|string|null`) had no interned slot: `pushFieldStorage` then read `rlWrapIdx` out of
// bounds, CRASHING the compiler ("out of bounds array access") on both the construct and the
// read variant. Regression: the arm interns at collect via the all-grouper-depth split; the
// construct works and the element read narrows through the box.
function go() {
  const v: {a: i32, f: (boolean | string | null)[], z: f64} | f64 = {
    a: 11,
    f: [false],
    z: 2.5,
  }
  const t0 = v
  if (t0 is {a: i32, f: (boolean | string | null)[], z: f64}) {
    const t1 = t0.f[0]
    if t1 != null {
      const t2 = t1
      if t2 is boolean {
        print(t2)
      } else {
        print("OTHER")
      }
    } else {
      print("NULL")
    }
  } else {
    print("OTHER")
  }
}
// The scalar arm of the SAME shape family: the struct arm is never constructed, so only the
// collect-time interning keeps the type section emittable (the original crash reproduced with
// nothing but this binding in the module).
function goScalar() {
  const w: {f: (boolean | string)[]} | f64 = 2.5
  if (w is f64) { print("OTHER") } else { print("STRUCT") }
}
go()
goScalar()
