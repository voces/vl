// @run
// @log 77
// @log 0
// A union with a bare-closure arm as an ARRAY ELEMENT (`((() => i64) | i64)[]`): the element boxes
// as the shared `{tag, value}` union, the closure arm riding the box anyref as its `$cloStructIdx`
// fat-pointer. An extracted element narrowed to the closure arm (`const e = p[0]; if e is () => i64`)
// unboxes and `call_ref`s it (the frame pre-pass reserves the call-ref scratch — the narrowing is
// blind during that pass). A bare LAMBDA element adopts the `() => i64` arm through the array (the
// `seedExpected` array→union recursion). Read + other-arm (an i64 element narrows away the closure).
function useIt(p: ((() => i64) | i64)[]) {
  const e = p[0]
  if e is () => i64 { print(e()) } else { print(0) }
}

function go() {
  useIt([() => 77]) // closure element — calls the arm
  useIt([5000000077]) // i64 element — other-arm branch
}

go()
