// @run
// @log 5
// A MAP-FIELD read through a union's ref-array arm (`t0[i].f["k"] ?? d` after an `is S[]`
// narrow, `S = {a: i64, f: {[string]: i64}, z: boolean}`), with the union produced by a CALL.
// The map-scratch-frame pre-pass (`exprHasMapOp`) is narrowing-blind: it resolved neither
// `exprMap` on the member (the `is` narrow is not active there) nor the union-with-map-arm
// ident (the receiver is a Member, not an Ident), so a function whose ONLY map op is this read
// never reserved the map scratch frame — the read then clobbered the i32 scratch slots with map
// refs: invalid wasm ("expected i32, found ref"). Regression: `unionListElemMapFieldMember`
// spots the shape from the DECLARED union and reserves the frame.
function makeIt(): {a: i64, f: {[string]: i64}, z: boolean}[] | i32 {
  const h0: {[string]: i64} = Map()
  h0["k"] = 5
  return [{a: 6000000000, f: h0, z: true}]
}
function go() {
  const v: {a: i64, f: {[string]: i64}, z: boolean}[] | i32 = makeIt()
  const t0 = v
  if t0 is {a: i64, f: {[string]: i64}, z: boolean}[] {
    const t1 = t0[0].f["k"] ?? 13131313131
    print(t1)
  } else {
    print("OTHER")
  }
}
go()
