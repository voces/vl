// @run
// @log 1
// @log 2
// An else-less `is`-chain whose arms are PARENTHESIZED still proves exhaustive: the
// checker's chain classifiers (`ifChainExhausts`, `ifCondIsDiscriminating`) peel
// `Paren` wrappers, so `if (x is i64) … else if (x is boolean) …` covers the union
// exactly like the bare spelling and the missing-return rule stays quiet.

function pick(x: i64 | boolean): i32 {
  if (x is i64) {
    return 1
  } else if (x is boolean) {
    return 2
  }
}
print(pick(6000000000))
print(pick(true))
