// Regression: a union whose ARM is a NESTED array of union-box elements
// (`({a: i64, f: i32, z: f32} | i32)[][] | i32`). The arm's ELEMENT union is not a
// standalone annotation, so `registerInlineUnion`'s nested-array / paren-element
// recursions (which see only the WHOLE name) never registered it — the inner list's
// `emitUnionBoxArg` then fell through to a RAW struct element in the box-element
// backing: INVALID-WASM (fuzz sweep5 plain leg, seed 685652043 case_00254). The
// 2+-atom walk now registers each ref-array atom's element union.
// @run
// @log 0
// @log S
// @log 3.5
function go() {
  const v: ({a: i64, f: i32, z: f32} | i32)[][] | i32 = [
    [
      {
        a: 6000000000,
        f: 467,
        z: 3.5,
      },
    ],
  ]
  print(0)
  const t0 = v
  if (t0 is ({a: i64, f: i32, z: f32} | i32)[][]) {
    const t1 = t0[0][0]
    if t1 is i32 {
      print(t1)
    } else {
      print("S")
      if (t1 is {a: i64, f: i32, z: f32}) { print(t1.z) }
    }
  } else {
    print("I")
  }
}
go()
