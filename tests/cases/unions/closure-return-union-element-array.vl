// @run
// @log OTHER
// @log 0
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused variable `_v`
// An ARRAY whose ELEMENT type is a value/struct UNION (`(string | {w: i32})[]`) returned
// from a CLOSURE — the inverse of the union-with-an-array-arm trilogy (#863/#865/#867): here
// the union is the reflist's ELEMENT (a `$uBox` heap type), not a union arm. Reaching this
// shape ONLY through a closure return type used to fail two ways — the graduated rep-fuzz
// shapes `p2c/p2r (i32) => (string | {w: i32})[]`:
//   - READ  (`v(1)[0]` then `is string`) → "index receiver is not an array or string"
//   - CONSTRUCT (build, never read)      → "ref valtype with no interned shape"
// Both were the SAME root cause: the closure-typed LOCAL `v` — whose whole type
// `(i32) => (string | {w: i32})[]` ends in `[]` — was mis-classified as a ref-list, its
// `$fnsig` result union-list mis-parsed by `parenUnionArrElemName`, which lacked the
// top-level-arrow guard `nameIsClosureArray` already had. Fixed, the closure reads back the
// boxed element and `is string` discriminates it soundly (a `{w: i32}` element is NOT a
// string — the read casts to the union box and reads the TAG, never the struct's `w` field).

function makeIt(): (i32) => (string | { w: i32 })[] {
  return (_q0) => ([{ w: 77 }])
}

// READ (rep-fuzz `p2r`): build the list inside the closure, call it, index, narrow.
function readBack() {
  const v: (i32) => (string | { w: i32 })[] = makeIt()
  const t0 = v(1)[0]
  if t0 is string { print(t0) } else { print("OTHER") }
}

// CONSTRUCT-only (rep-fuzz `p2c`): build the closure + list but never read it — catches the
// construct-side valtype hole the read path would otherwise mask by rejecting cleanly first.
function constructOnly() {
  const _v: (i32) => (string | { w: i32 })[] = makeIt()
  print(0)
}

readBack()
constructOnly()
