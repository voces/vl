// @run
// @log true
// @log false
// @log OTHER
// @log 7
// A PLAIN-STRUCT element array (`{f: boolean}[]`) whose element SHAPE also matches a
// VALUE-union's struct member (`{f: boolean} | string`). The array physically holds the
// plain struct (its own heap type), but the element READ `z[0].f` mis-classified the
// element as the UNION VARIANT and read through `uVarHeap` — a distinct heap type: it
// read a `(ref plain)` as `(ref variant)` (INVALID-WASM "expected (ref null $t), found
// (ref $t)"). Fixed: exprVariantIndex's Index arm resolves through the variant heap ONLY
// when the element is NOT a registered plain struct. Fuzz F5gJXz multiobs seed 87291197
// case_00135 (`{f: (…{f:boolean}…)[], z: {f:boolean}[]}` at `v.z[0].f`).
function go() {
  const u: {f: boolean} | string = "x"
  const z: {f: boolean}[] = [{ f: true }, { f: false }]
  print(z[0].f)
  print(z[1].f)
  // The value union still reads back correctly (unchanged path).
  if u is {f: boolean} { print(u.f) } else { print("OTHER") }
  // The union's struct arm still boxes/reads through the variant heap when it IS the value.
  const w: {g: i32} | string = { g: 7 }
  if w is {g: i32} { print(w.g) } else { print("OTHER") }
}
go()
