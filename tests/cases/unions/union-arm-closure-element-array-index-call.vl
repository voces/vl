// @run
// @log OTHER
// @log 7
// A struct FIELD that is a union of (array-of-(closure | i64) | i64):
// `{a: f64, f: ((() => i32) | i64)[] | i64, z: i64}`. Narrowing the field to its ref-array
// arm, indexing an element into a plain binding, and calling that binding after narrowing it
// to the closure arm (`const t1 = t0[0]; if t1 is () => i32 { t1() }`) reserves the closure
// `call_ref` scratch slot: narrowing-blindly the element union is recovered from the array
// arm (`unionClosureArrElemUnion`), so the spill lands on a closure-ref local instead of an
// unreserved i32 (which was invalid wasm — `expected i32, found (ref $cloStruct)`). The i64
// element rides the `else` arm; a second useIt over an i64 field payload rides the scalar arm.
function useIt(p: {a: f64, f: ((() => i32) | i64)[] | i64, z: i64}) {
  const t0 = p.f
  if t0 is ((() => i32) | i64)[] {
    const t1 = t0[0]
    if t1 is () => i32 { print(t1()) } else { print("OTHER") }
  } else if t0 is i64 {
    print(t0)
  } else {
    print("NONE")
  }
}

function go() {
  useIt({ a: 2.5, f: [5000000077], z: 6000000000 })
  useIt({ a: 1.5, f: 7, z: 8 })
}

go()
