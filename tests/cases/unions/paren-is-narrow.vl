// @run
// @log IF
// @log 6000000000
// @log CTRL
// @log 6000000000
// @log NEST
// @log 6000000000
// @log AND
// @log 6000000000
// @log ELSE
// @log 6000000000
// @log ELIF
// @log 6000000000
// @log GUARD
// @log 6000000000
// @log NULL
// @log 6000000000
// @log FIELD
// @log 6
// @log STRUCT
// @log 7
// @log WHILE
// @log 1
// A PARENTHESIZED condition narrows exactly like the bare spelling: the emitter's
// `setNarrowFromCond`/`setNarrowFromCondElse` peel `Paren` wrappers the same way the
// checker's narrowing collectors do, so `if (x is i64)` unboxes the branch reads.
// (rep-fuzz SOUNDNESS HOLE: the paren wrapper defeated the emitter's narrow rewrite
// while the checker still narrowed — the branch emitted the BOXED read, invalid wasm.)
// Each parenthesized form sits beside its unparenthesized control.

function ifParen() {
  const x: i64 | boolean = 6000000000
  if (x is i64) {
    print("IF")
    print(x)
  }
}
ifParen()

function ifCtrl() {
  const x: i64 | boolean = 6000000000
  if x is i64 {
    print("CTRL")
    print(x)
  }
}
ifCtrl()

function nestedParens() {
  const x: i64 | boolean = 6000000000
  if ((x is i64)) {
    print("NEST")
    print(x)
  }
}
nestedParens()

function parenConjunct() {
  const x: i64 | boolean = 6000000000
  const y = 1
  if (x is i64) && y == 1 {
    print("AND")
    print(x)
  }
}
parenConjunct()

function elseComplement() {
  const x: i64 | boolean = 6000000000
  if (x is boolean) {
    print("OTHER")
  } else {
    print("ELSE")
    print(x)
  }
}
elseComplement()

function elseIfParen() {
  const x: i64 | boolean = 6000000000
  if (x is boolean) {
    print("OTHER")
  } else if (x is i64) {
    print("ELIF")
    print(x)
  }
}
elseIfParen()

function guardComplement(x: i64 | boolean): i32 {
  if (x is boolean) {
    return 0
  }
  print("GUARD")
  print(x)
  1
}
guardComplement(6000000000)

function nullCmpParen() {
  const x: i64 | null = 6000000000
  if (x != null) {
    print("NULL")
    print(x)
  }
}
nullCmpParen()

function fieldParen() {
  const o: { y: i32 | string } = { y: 5 }
  if (o.y is i32) {
    print("FIELD")
    print(o.y + 1)
  }
}
fieldParen()

type PA = { tag: i32 }
type PB = { name: string }
type PU = PA | PB
function structParen() {
  const v: PU = { tag: 7 }
  if (v is PA) {
    print("STRUCT")
    print(v.tag)
  }
}
structParen()

function whileParen() {
  let x: i64 | boolean = 6000000000
  let n = 0
  while (x is i64) {
    n = n + 1
    x = true
  }
  print("WHILE")
  print(n)
}
whileParen()
