// @run
// @log f
// @log 2
// @log a
// A REBIND under a ref-element-array-arm narrow (`if g is (i32 | string)[] { const t = g … }`):
// inside the narrow the binding reads UNBOXED to the reflist wrapper, so the rebound local is a
// LIST (indexable, `.length`) — the ref-array twin of the scalar-atom narrowing rule in
// `exprUnion`'s Ident arm. Previously the rebind classified as a union BOX while the init
// emitted the unboxed wrapper ref — invalid wasm. The litunion-array (kind-7 atom) rebind
// exercises the same seam over the i32-list backing.

type K = "a" | "b"

function go() {
  const g: (i32 | string)[] | {w: i32} = ["f", 4]
  if g is (i32 | string)[] {
    const t = g
    const e = t[0]
    if e is string { print(e) } else { print("OTHER") } // f
    print(t.length) // 2
  } else {
    print("OTHER")
  }
  const h: K[] | {w: i32} = ["a"]
  if h is K[] {
    const u = h
    print(u[0]) // a — the kind-7 atom-list rebind indexes + widens at print
  } else {
    print("OTHER")
  }
}
go()
