// @emit-error function-value call arity has no interned signature
// A union with a bare-closure arm whose closure `$fnsig` is NEVER interned — the program contains
// NO closure of that arm's type (`((() => i64) | i64)[]` built from ONLY i64 elements), yet a
// narrowed `is () => i64` branch still emits a `call_ref` on the arm. With no closure of that
// signature anywhere, `$fnsig` is unminted (the interner collects sigs from real closures/field
// values, not from a bare union-arm ANNOTATION), so the narrowed call has no functype to `ref.cast`
// to. The emitter rejects LOUDLY rather than emit a call to a non-existent signature — the closure
// dual of the map/array "unsupported neighbour" rejects. (When ANY closure of the arm's type DOES
// flow into the program the sig interns and the shape lowers — see closure-member-array-element.vl.)
function useIt(p: ((() => i64) | i64)[]) {
  const e = p[0]
  if e is () => i64 { print(e()) } else { print(0) }
}

function go() {
  useIt([5000000077])
}

go()
