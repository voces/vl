// @run
// @log bb
// @log aa
// @log aa
// @log bb
// @log bb
// @log cc
// @log bb
// @log cc
// @log bb
// @log cc
// @log aa
// @log aa
// @log cc
// @log 2
// @log 4
// @log bb
// A literal-union ATOM joining a string in a VALUE position — if-expression arms
// (either order, else-if chains), match arms, and un-annotated returns. The join types
// `string` (the atom softens), and the ATOM arm widens to its member string at the seam
// (`emitRefIfArm` / `retStrWiden`): previously the raw i32 atom id flowed into the
// string-ref join — invalid wasm. The join's CHECKED type routes the if-expression
// (arm-order independent), the else-if chain join takes the inner if's own join (not
// the innermost block tail, which dropped the string arm), and an all-atom join stays
// the bare i32 atom (the binding classifies atom, so `print` widens — previously a raw
// id printed). The same class fixed at the `??` seam is `maps/atom-valued-map.vl`.
type K0 = "aa" | "bb"

// if-expression, atom-then order (un-annotated binding).
function j1(c: boolean, k: K0) {
  const x = if c then k else "aa"
  print(x)
}
j1(true, "bb")
j1(false, "bb")

// if-expression, string-then order.
function j2(c: boolean, k: K0) {
  const x = if c then "aa" else k
  print(x)
}
j2(true, "bb")
j2(false, "bb")

// annotated string binding.
function j3(c: boolean, k: K0) {
  const x: string = if c then k else "cc"
  print(x)
}
j3(true, "bb")
j3(false, "bb")

// un-annotated return joining an atom and a string literal.
function j4(c: boolean, k: K0) {
  if c { return k }
  return "cc"
}
print(j4(true, "bb"))
print(j4(false, "bb"))

// else-if chain: atom / string / atom arms.
function j5(n: i32, k: K0) {
  const x = if n == 0 then k else if n == 1 then "cc" else "aa"
  print(x)
}
j5(0, "bb")
j5(1, "bb")
j5(2, "bb")

// match arms desugar to the same chain.
function j6(k: K0): string {
  const r = match k {
    "aa" => k,
    _ => "cc",
  }
  return r
}
print(j6("aa"))
print(j6("bb"))

// argument position: the join value flows straight into a string param.
function useStr(s: string): i32 { s.length }
function j7(c: boolean, k: K0) {
  print(useStr(if c then k else "cccc"))
}
j7(true, "bb")
j7(false, "bb")

// all-atom join stays the atom (binding classifies atom; print widens the id).
function j8(c: boolean, k: K0, k2: K0) {
  const x = if c then k else k2
  print(x)
}
j8(true, "bb", "aa")
