// Regression: a union with a UNION-BOX-ELEMENT array arm (`((() => f64) | {w: i32})[]
// | i64`) — the element read `t0[0]` rebinds, narrows to the closure member, and calls.
// The `callRefSlot` pre-pass missed the IDENT-callee spelling (the typed-IR TyFunc net
// only covered composite callees), so the fat-pointer spill landed on an i32 scratch —
// INVALID-WASM (fuzz sweep4 plain leg, seed 6331245 case_00375). The net is now hoisted
// over both callee shapes.
// @run
// @log OTHER
function useIt(p: ((() => f64) | {w: i32})[] | i64) {
  const t0 = p
  if (t0 is ((() => f64) | {w: i32})[]) {
    const t1 = t0[0]
    if (t1 is () => f64) { print(t1()) } else { print("OTHER") }
  } else {
    print("OTHER")
  }
}
function go() { useIt(5000000077) }
go()
