// @run
// @log 0
// A union with a bare-closure arm whose closure `$fnsig` is never interned from a concrete
// closure — the program contains NO closure of that arm's type (`((() => i64) | i64)[]` built
// from ONLY i64 elements), yet a narrowed `is () => i64` branch still emits a `call_ref` on the
// arm. The concrete-closure interner (which collects sigs from real lambdas / field closures)
// never sees such a signature, so `collectCloSigs` also walks every union's function-type arms
// and interns each arm's annotation key (`unionArmSigKey`) with a rep sentinel; the type-section
// emitter (`emitSynthCloSig`) SYNTHESIZES that `$fnsig` functype purely from the key string. The
// `call_ref` branch is dead at runtime here (the element is an i64, not a closure), but the
// synthesized functype makes the wasm VALID so the else-branch runs and prints 0. (When a real
// closure of the arm's type flows in, the sig interns from it and this pass dedups — see
// closure-member-array-element.vl / closure-member-basic.vl.)
function useIt(p: ((() => i64) | i64)[]) {
  const e = p[0]
  if e is () => i64 { print(e()) } else { print(0) }
}

function go() {
  useIt([5000000077])
}

go()
