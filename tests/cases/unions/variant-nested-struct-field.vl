// @run
// @log 663810583
// @log 6000000000
// @log 9
// @log 42
// @log 205.5
// @log 1.5
// @log dx
// @log 8
// @log true
// @log OTHER
// @log 5.5
// NESTED-STRUCT fields on union VARIANTS — the "only iN/boolean/string/array
// union-variant fields" R1 bucket, nested-struct flavor (rep-fuzz
// `p0c/p0r {a: i32, f: {a: i64, f: i64, z: boolean}, z: f64} | i32`,
// `p1c/p1r {f: {f: f32}} | {w: i32}`, `p1c/p1r {f: {f: K0}} | {w: i32}`,
// `p2c/p2r {a: string, f: {f: {f: i32}}, z: boolean} | boolean`,
// `p1c/p1r {a: boolean, f: {a: f64, f: f32, z: string}, z: i32} | i64`,
// `p0c/p0r {a: f64, f: {f: f32}, z: string} | string | null`). The inline-shape
// variant path (`collectShapeVariantFields`) now accepts an unclassifiable field
// whose (`|null`-stripped) text is a lowerable inline shape as a code-15 nested-struct
// ref (`variantNestedShapeOk`, the pure mirror of `internInlineShape`'s fallback);
// `collectA` interns the target shape post-reset, the render passes its struct index,
// the construct seeds `pendingStructIdx` (the `emitObj` discipline), and
// `structIndexOfExpr`'s Member arm resolves narrowed/variant receivers through the
// variant field tables so chained reads find the layout. TWO same-name-set unions in
// one program (`{f: {f: i64}} | boolean` vs `{f: {f: f32}} | {w: i32}` vs the K0
// spelling) pin the collision guards: the union-context arm pick
// (`unionArmVariantForObj`) at the construct and the canonical-key tightening
// (`nestedStructNamesCompat`) at the `is`/annotation resolvers. The nested WRITE
// pins the store-side scalar widening (`emitScalarFieldStoreVal` — an i64 nested
// field assigned a bare int literal emitted a raw `i32.const`, invalid wasm;
// pre-existing in the flat spelling too). Construct + narrow + deep read + write,
// in local / param / return / 3-arm-nullable positions, decoy arms included.
type K0 = "aa" | "bb"

function pick(p: {f: {f: f32}} | {w: i32}): f32 {
  const t0 = p
  if t0 is {f: {f: f32}} {
    return t0.f.f
  }
  return 1.5
}

function useK(p: {f: {f: K0}} | {w: i32}) {
  const t0 = p
  if t0 is {f: {f: K0}} { print(t0.f.f) } else { print("OTHER") }
}

function deep(sel: boolean): {a: string, f: {f: {f: i32}}, z: boolean} | boolean {
  if sel {
    return {a: "dx", f: {f: {f: 8}}, z: true}
  }
  return false
}

function go() {
  // Local construct + narrow + nested i64 reads (widening at the construct boundary)
  // + the nested WRITE through the narrowed chain.
  const v: {a: i32, f: {a: i64, f: i64, z: boolean}, z: f64} | i32 = {a: 11, f: {a: 6000000000, f: 663810583, z: true}, z: 2.5}
  const t0 = v
  if t0 is {a: i32, f: {a: i64, f: i64, z: boolean}, z: f64} {
    print(t0.f.f) // 663810583
    print(t0.f.a) // 6000000000
    t0.f.f = 9
    print(t0.f.f) // 9 — nested store, i64-widened RHS
  } else {
    print("OTHER")
  }
  // The SECOND union sharing the f/f field-name set with a DIFFERENT nested layout —
  // must not collide onto the other arm's tag/heap.
  const w: {f: {f: i64}} | boolean = {f: {f: 42}}
  if w is {f: {f: i64}} { print(w.f.f) } else { print("OTHER") } // 42
  print(pick({f: {f: 205.5}})) // 205.5 — param position, f32 leaf
  print(pick({w: 77}))         // 1.5 — the decoy arm
  // Double nesting, return position + the scalar decoy.
  const r = deep(true)
  if r is {a: string, f: {f: {f: i32}}, z: boolean} {
    print(r.a)     // dx
    print(r.f.f.f) // 8
  } else {
    print(false)
  }
  const r2 = deep(false)
  if r2 is boolean { print(true) } else { print("no") } // true
  // The litunion-atom leaf spelling (decoy-arm construct only: contextual atom
  // typing through a nested union-arm literal is the checker's own later slice).
  useK({w: 77}) // OTHER
  // 3-arm union with a null member.
  const n: {a: f64, f: {f: f32}, z: string} | string | null = {a: 2.5, f: {f: 5.5}, z: "zz"}
  if n is {a: f64, f: {f: f32}, z: string} {
    print(n.f.f) // 5.5
  } else {
    print("OTHER")
  }
}
go()
