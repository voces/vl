// @run
// @log 77
// @log true
// @log 11
// @log 0
// @log 5
// @log ss
// MEMBER-UNION fields on union VARIANTS / struct arms — the "only iN/boolean/string/
// array union-variant fields" R1 bucket, union-field flavor (rep-fuzz
// `p3c/p3r {f: boolean | {w: i32}} | {w: i32}`,
// `p1c/p1r {a: f32, f: {a: boolean, f: {f: f32}, z: i32} | i64, z: i32}`,
// `p1c/p1r {f: {f: {a: boolean, f: string, z: i64}} | {w: i32}}`). A union ARM's
// field whose text is itself a top-level union now PRE-registers
// (`registerVariantArmFieldUnions`, gated to fields `nameFieldCode` cannot already
// classify, BEFORE the outer union's rows are pushed — an interleaved registration
// would corrupt its variant slice), so the field classifies as the shared box
// (code 16) exactly like its standalone-struct twin. The nested narrow chain
// (`t0.f` then `t1 is …`) rides `memberUnionFieldName`'s new NARROWING-BLIND probe,
// which also lets the frame pre-pass see through `const t1 = t0.f` bindings.
// Global (p3) / param positions, heterogeneous (boolean | struct), mixed
// (struct | i64), and struct-vs-struct field unions, both directions each.
const g: {f: boolean | {w: i32}} | {w: i32} = {f: {w: 77}}
const g2: {f: boolean | {w: i32}} | {w: i32} = {f: true}

function useMix(p: {a: f32, f: {a: boolean, f: {f: f32}, z: i32} | i64, z: i32}): i32 {
  const t1 = p.f
  if t1 is {a: boolean, f: {f: f32}, z: i32} {
    return t1.z
  }
  return 0
}

function go() {
  const t0 = g
  if t0 is {f: boolean | {w: i32}} {
    const t1 = t0.f
    if t1 is boolean {
      print(t1)
    } else {
      if t1 is {w: i32} { print(t1.w) } else { print("no") } // 77
    }
  } else {
    print("OTHER")
  }
  const s0 = g2
  if s0 is {f: boolean | {w: i32}} {
    const s1 = s0.f
    if s1 is boolean { print(s1) } else { print("no") } // true
  } else {
    print("OTHER")
  }
  print(useMix({a: 3.5, f: {a: true, f: {f: 205.5}, z: 11}, z: 9})) // 11 — the struct arm
  print(useMix({a: 3.5, f: 6000000000, z: 9}))                     // 0 — the i64 arm
  // A struct whose field is a union of TWO structs (one carrying a nested struct).
  const u: {f: {f: {a: boolean, f: string, z: i64}} | {w: i32}} = {f: {w: 5}}
  const u1 = u.f
  if u1 is {w: i32} { print(u1.w) } else { print("no") } // 5
  const u2: {f: {f: {a: boolean, f: string, z: i64}} | {w: i32}} = {f: {f: {a: false, f: "ss", z: 7}}}
  const u3 = u2.f
  if u3 is {f: {a: boolean, f: string, z: i64}} { print(u3.f.f) } else { print("no") } // ss
}
go()
