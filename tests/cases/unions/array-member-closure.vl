// @run
// @log 9
// @log i64
// @log 5
// @log 3
// @log 8
// @log 6
// A union whose member is a CLOSURE-element ARRAY alongside another arm
// (`(() => f64)[] | i64`): the closure-array arm boxes as its reflist wrapper ref, and the
// narrowed `p[0]()` calls the boxed closure element directly (the frame pre-pass reserves the
// call-ref scratch for the not-yet-narrowed callee). Also covers a union with TWO distinct
// ref-array arms (struct-array + closure-array — distinct reflist slots tag distinctly) and the
// array-LAST spelling (`i64 | S[]`, whose name ends in `]`).
function callArm(p: (() => f64)[] | i64) {
  if p is (() => f64)[] {
    print(p[0]())
  } else {
    print("i64")
  }
}

function fromClosures() {
  const fs: (() => f64)[] = [() => 9.0]
  callArm(fs)
}

function fromI64() {
  callArm(70000000000)
}

type Box = { v: i32 }

function structArrArm(p: Box[] | boolean) {
  if p is Box[] {
    print(p[0].v)
  } else {
    print("bool")
  }
}

function fromBoxes() {
  const bs: Box[] = [{ v: 5 }]
  structArrArm(bs)
}

// TWO ref-array arms in one union — a struct-array and a closure-array, tagged distinctly.
function twoArms(p: Box[] | (() => i64)[]) {
  if p is Box[] {
    print(p[0].v)
  } else {
    print(p[0]())
  }
}

function fromTwo() {
  const bs: Box[] = [{ v: 3 }]
  twoArms(bs)
  const gs: (() => i64)[] = [() => 8]
  twoArms(gs)
}

// Array-LAST spelling (`i64 | Box[]`, name ends in `]`).
function lastArm(p: i64 | Box[]) {
  if p is Box[] {
    print(p[0].v)
  } else {
    print("i64")
  }
}

function fromLast() {
  const bs: Box[] = [{ v: 6 }]
  lastArm(bs)
}

fromClosures()
fromI64()
fromBoxes()
fromTwo()
fromLast()
