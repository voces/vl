// @run
// @log bfvf
// @log OTHER
// @log true
// @log 3.5
// @log dx
// @log OTHER
// @log false
// @log 56323814985252741
// @log 8389.5
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// A union VARIANT whose struct arm carries a FUNCTION-typed field (`{a, f: (i32) => K0,
// z} | i32`) boxes and reads back through `is`: the field is the closure fat-pointer
// (code 14) — the variant construct passes the lambda through, `unionArmBoxSafe` admits a
// bare TyFunc field so a WIDENING sibling field (a float-literal f32) still adopts the
// arm, and the narrowed member CALL `t0.f(1)` routes to `call_ref` (`exprIsClosure`'s
// variant-member arm, the `memberIsClosure` twin). Covers closure results of an atom /
// boolean / f32 / i64-field-struct / boolean[], and the union at local / global /
// struct-field / array-element positions.

type K0 = "84648" | "bfvf" | "jzf"

// A LOCAL union whose arm's closure returns a literal-union atom (p0) — both arms.
function readAtom(v: { a: i32, f: (i32) => K0, z: f64 } | i32) {
  const t0 = v
  if t0 is { a: i32, f: (i32) => K0, z: f64 } {
    print(t0.f(1))
  } else {
    print("OTHER")
  }
}
readAtom({ a: 11, f: (_q0) => ("bfvf"), z: 2.5 }) // bfvf
readAtom(7)                                      // OTHER

// The union as a struct FIELD, its arm carrying an f32 decoy + closure + string (p3):
// the f32 field's float literal WIDENS to reach the arm (the gate admits the closure).
const g: { f: { a: f32, f: () => boolean, z: string } | i64 } = {
  f: { a: 3.5, f: () => (true), z: "dx" },
}
function readField() {
  const t0 = g.f
  if t0 is { a: f32, f: () => boolean, z: string } {
    print(t0.f())
    print(t0.a)
    print(t0.z)
  } else {
    print("OTHER")
  }
}
const gi: { f: { a: f32, f: () => boolean, z: string } | i64 } = { f: 9 }
function readFieldI() {
  const t0 = gi.f
  if t0 is { a: f32, f: () => boolean, z: string } {
    print(t0.f())
  } else {
    print("OTHER")
  }
}
readField()  // true / 3.5 / dx
readFieldI() // OTHER

// A closure returning a boolean LIST, indexed off the narrowed call.
function readList() {
  const v: { f: (i32) => boolean[] } | f64 = { f: (_q0) => ([false]) }
  const t0 = v
  if t0 is { f: (i32) => boolean[] } {
    print(t0.f(1)[0])
  } else {
    print("OTHER")
  }
}
readList() // false

// A GLOBAL union of two struct arms, the closure returning a struct with an i64 field.
const gs: { a: boolean, f: () => { a: i32, f: i64, z: f64 }, z: i32 } | { w: i32 } = {
  a: true,
  f: () => ({ a: 11, f: 56323814985252741, z: 2.5 }),
  z: 11,
}
function readStructRet() {
  const t0 = gs
  if t0 is { a: boolean, f: () => { a: i32, f: i64, z: f64 }, z: i32 } {
    print(t0.f().f)
  } else {
    print("OTHER")
  }
}
readStructRet() // 56323814985252741

// An ARRAY of the union returned from a call, the closure returning f32 (p2).
function makeIt(): ({ a: i64, f: (i32) => f32, z: f64 } | i32)[] {
  return [{ a: 6000000000, f: (_q0) => (8389.5), z: 2.5 }]
}
function readElem() {
  const v = makeIt()
  const t0 = v[0]
  if t0 is { a: i64, f: (i32) => f32, z: f64 } {
    print(t0.f(1))
  } else {
    print("OTHER")
  }
}
readElem() // 8389.5
