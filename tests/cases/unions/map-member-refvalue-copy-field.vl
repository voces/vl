// @run
// @log 14.5
// @log OTHER
// @log done
// Two positions that once mis-typed a map-member union as a BARE (mono) map — for BOTH ref-value
// and scalar maps (a pre-#865-latent hazard the ref-value lift surfaced):
//
//  1. An INTERMEDIATE COPY `const t0 = p` of a map-member-union PARAM. An un-annotated let infers
//     its type from the initializer; `paramMap` reported the union param as a map (it starts `{[`),
//     so `t0` took a mono-map local instead of the union box — invalid wasm. Guarded now
//     (`paramMap` skips a `nameIsMapMemberUnion` name). The canonical repro: a closure-valued map
//     union, narrowed through the copy, reading + calling the closure value.
//
//  2. A struct FIELD of a map-member-union type (`{f: {[string]: () => boolean} | string}`).
//     `nameFieldCode` (the inline-object-type field classifier) returned the map code for the
//     field, storing the union box in a map-struct slot — invalid wasm. Guarded now, the field
//     rides the union box.
function useCopy(p: {[string]: () => f64} | string) {
  const t0 = p
  if t0 is {[string]: () => f64} {
    const t1 = t0["k"] ?? () => (14.5)
    print(t1())
  } else {
    print("OTHER")
  }
}
function useField(b: {f: {[string]: () => boolean} | string}) {
  const t0 = b.f
  if t0 is {[string]: () => boolean} {
    print("MAP")
  } else {
    print("OTHER")
  }
}
function go() {
  const m: {[string]: () => f64} = Map()
  m["k"] = () => (14.5)
  useCopy(m)
  useField({f: "s"})
  print("done")
}
go()
