// @run
// @log false
// @log LIST
// @log x
// @log N1
// @log I32
// A NICHE-nullable scalar-element list as a VALUE-UNION member — `(boolean | null)[] |
// i32`, `(string | null)[] | i32`. The element's null rides IN the element rep (the i32
// sentinel 2 / a `ref.null $a` string), so the list member IS its leaf backing's value
// atom: `valueAtomKind` folds `(boolean | null)[]` / `(K | null)[]` onto the i32-list
// atom (kind 7) and `(string | null)[]` onto the string-list atom (kind 9) — one tag per
// backing, agreeing with `emitUnionCoerce`'s carrier classification, so `is <arm>`
// tag-compares and the narrowed read unboxes to the shared wrapper
// (`atomListWrapHeap`). A narrowed-arm ELEMENT read classifies as the list via the
// union-narrow arms of `exprArray` / `exprStringArray` (`unionIdentReadKind` 7/9), with
// the `(string | null)[]` arm's element kept `(ref null)` (`exprNulStrArray`).
function mkB(): {f: (boolean | null)[] | i32} {
  return { f: [false, null] }
}

function go() {
  // The struct-FIELD carrier (the fuzzer's p2r shape): narrow, then element-read.
  const v = mkB()
  const t0 = v.f
  if t0 is (boolean | null)[] {
    const t1 = t0[0]
    if t1 != null { print(t1) } else { print("NULL") } // false
  } else {
    print("OTHER")
  }

  // The binding carrier, both narrow polarities.
  const b: (boolean | null)[] | i32 = [null, true]
  if b is i32 { print("I32") } else { print("LIST") } // LIST

  // The string niche arm: narrowed element read stays nullable.
  const s: (string | null)[] | i32 = ["x", null]
  if s is (string | null)[] {
    const t2 = s[0]
    if t2 != null { print(t2) } else { print("NULL") } // x
    if s[1] == null { print("N1") } // N1
  } else {
    print("I32")
  }

  const n: (string | null)[] | i32 = 7
  if n is (string | null)[] { print("LIST") } else { print("I32") } // I32
}
go()
