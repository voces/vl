// @run
// @log 9
// @log 42
// @log 7
// @log hi
// @log OTHER
// A union whose MAP member has a REF VALUE — struct (`{[string]: {w:i32}}`), closure (`{[string]:
// () => f64}`), nested map (`{[string]: {[string]: i32}}`), and union (`{[string]: string | i64}`)
// values — alongside another arm. Each map arm boxes as its VALUE-KIND map-struct ref on the union
// box anyref (tagged by `mapSlotTag`, keyed on the arm's interned mv value slot); the box side
// (`markMapUnionArms`) and the narrowed read (`mapTypeIdxOf`) resolve the SAME slot off the SAME
// atom, so the per-value `$mapStruct` dedups across the box seam (no invalid wasm). #865 shipped
// this for scalar/string values only and rejected ref values as a heap-type-identity hazard; the
// hazard was a mis-classification of the map-member union as a bare map, now fixed. The map arm is
// exercised at RUNTIME (constructed + passed), reading a struct field / calling a closure value /
// indexing a nested map / narrowing a union value.
function useStruct(p: {[string]: {w: i32}} | string) {
  if p is {[string]: {w: i32}} {
    const s = p["k"] ?? {w: 0}
    print(s.w)
  } else {
    print("OTHER")
  }
}
function useClosure(p: {[string]: () => f64} | string) {
  if p is {[string]: () => f64} {
    const f = p["k"] ?? () => (0.0)
    print(f())
  } else {
    print("OTHER")
  }
}
function useNested(p: {[string]: {[string]: i32}} | string) {
  if p is {[string]: {[string]: i32}} {
    const inner = p["k"] ?? Map()
    print(inner["j"] ?? 0)
  } else {
    print("OTHER")
  }
}
function useUnion(p: {[string]: string | i64} | i32) {
  if p is {[string]: string | i64} {
    const v = p["k"] ?? "d"
    if v is string { print(v) } else { print("NUM") }
  } else {
    print("OTHER")
  }
}
function go() {
  const ms: {[string]: {w: i32}} = Map()
  ms["k"] = {w: 9}
  useStruct(ms)
  const mc: {[string]: () => f64} = Map()
  mc["k"] = () => (42.0)
  useClosure(mc)
  const inner: {[string]: i32} = Map()
  inner["j"] = 7
  const mn: {[string]: {[string]: i32}} = Map()
  mn["k"] = inner
  useNested(mn)
  const mu: {[string]: string | i64} = Map()
  mu["k"] = "hi"
  useUnion(mu)
  // The OTHER (string / i32) arm still discriminates correctly.
  useStruct("s")
}
go()
