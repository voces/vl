// @run
// @log 0
// @log 7
// @log 42
// @log 100
// @log -1
// @log -42
// @log 2147483647
// @log -2147483648
// @log 256
// @log -256
// `toString(i32)` renders a signed integer to a VL string (an i32-array of char
// codes), handling 0, positives, and negatives (incl. the i32 extremes).
print(toString(0))
print(toString(7))
print(toString(42))
print(toString(100))
print(toString(-1))
print(toString(-42))
print(toString(2147483647))    // i32 max
print(toString(-2147483648))   // i32 min (no sign-flip overflow)
const n: i32 = 256
print(toString(n))             // i32 variable, not just a literal
print(toString(0 - n))         // computed negative i32

