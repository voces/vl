// @run
// @log 5
// @log -42
// @log 0
// `toString(i32)` resolves and lowers inside a function body and across
// function-call boundaries — not only in straight-line top-level code. (The
// scope lookup used the `in` operator, which fell through to the native
// `Object.prototype.toString` in any nested scope; now own-property only.)
function fmt(n: i32) {
  return toString(n)
}
print(fmt(5))
print(fmt(-42))
print(fmt(0))
