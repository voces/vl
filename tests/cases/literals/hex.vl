// @run
// @log 255
// @log 255
// @log 57005
// @log 3735928559
// Hex integer literals (0x / 0X), case-insensitive digits and prefix, with a
// `_` digit separator. They lower to the same integer literal as the decimal
// value (0xFF == 255, 0xDEAD == 57005, 0xDEAD_BEEF == 3735928559).
print(0xFF)
print(0Xff)
print(0xDEAD)
print(0xDEAD_BEEF)
