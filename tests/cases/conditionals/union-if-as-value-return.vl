// @run
// @log 7
// @log 11
// @log 1
// @log 2
// An if-as-VALUE whose result is a union (`return if c { A } else { B }`, and `else if`
// chains) now lowers as a value-typed `if` with the union-box result type, each arm
// union-coerced (`emitUnionIfValue`). Previously this declared an i32 blocktype over ref
// arms — invalid wasm — for a NAMED function too, so it is a general soundness fix, not a
// map-only one.

type Cat = { meow: i32 }
type Dog = { woof: i32 }
type Animal = Cat | Dog

// A two-arm union if-value.
function pick(toDog: boolean, n: i32): Animal {
  return if toDog { { woof: n } } else { { meow: n } }
}

// An `else if` chain joining three union arms (a passthrough middle arm).
function route(k: i32, a: Animal): Animal {
  return if k == 0 { { meow: 1 } } else if k == 1 { { woof: 2 } } else { a }
}

function go() {
  const d = pick(true, 7)
  if d is Dog { print(d.woof) } else { print(-1) } // 7
  const c = pick(false, 11)
  if c is Cat { print(c.meow) } else { print(-1) } // 11

  const r0 = route(0, { woof: 9 })
  if r0 is Cat { print(r0.meow) } else { print(-1) } // 1
  const r1 = route(1, { woof: 9 })
  if r1 is Dog { print(r1.woof) } else { print(-1) } // 2
}
go()
