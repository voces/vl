// @run
// @log 5
// @log 1
// if as a statement (side effect), and boolean literals.
// The `if true then 1 else 0` has a literal-true condition, so the `else 0`
// branch is statically dead — the lint pass flags it (B17 constant-branch rule).
// @warning This branch is never taken
let a = 0
if 1 < 2 then a = 5
print(a)
const r = if true then 1 else 0
print(r)
