// @run
// @log 5
// @log 1
// @log 0
// A tail `if` WITH a final `else` is a genuine value-producing if-expression
// (every path covered), so it must keep contributing its branch value type to
// the function's inferred return — even though a tail else-LESS `if` is void.
// Regression guard for the void-tail-statement fix: don't over-void the
// with-else case.
// Annotated return: the tail if-else yields the function's i32 result.
function f(b: boolean): i32 {
  if b then 5
  else 6
}
print(f(true))

// Inferred return: a tail if-else still infers a value type (i32 here).
function classify(x: i32) {
  if x > 0 then 1
  else 0
}
print(classify(3))
print(classify(-2))
