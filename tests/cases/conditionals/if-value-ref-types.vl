// @run
// @log pos
// @log neg
// @log 1
// @log 2
// @log 2
// @log 3
// @log 7
// @log mid
// @log a
// @log 6
// An if-EXPRESSION whose VALUE is a REF type — string, struct, i32[], string[], a struct
// ref-list — in BOTH return and binding position, plus an `else if` chain. The join needs
// a multi-byte `(ref $ht)` blocktype (`fbValtype`), not the single-byte numeric rep; the
// checker accepts these but the emitter previously wrote an i32 blocktype over ref arms and
// produced invalid wasm. `emitIfExprRef` lowers a value-typed `if` with the ref blocktype,
// each arm re-seeding its construction context (`pendingStructIdx` / `pendingListSlot`).
// Numeric and union/variant joins keep their existing dedicated paths.

type P = { x: i32 }

// string return.
function sign(n: i32): string { return if n > 0 then "pos" else "neg" }
// struct return.
function pickP(c: boolean): P { return if c then { x: 1 } else { x: 2 } }
// i32[] return.
function pickArr(c: boolean): i32[] { return if c then [1, 2] else [3] }
// `else if` chain (string).
function classify(n: i32): string {
  return if n < 0 then "neg" else if n == 0 then "zero" else "mid"
}
// string[] return.
function pickStrs(c: boolean): string[] {
  return if c then ["a", "b"] else ["x"]
}
// struct ref-list return.
function pickPs(c: boolean): P[] {
  return if c then [{ x: 1 }] else [{ x: 5 }, { x: 6 }]
}

function go() {
  print(sign(5)) // pos
  print(sign(-1)) // neg

  print(pickP(true).x) // 1
  print(pickP(false).x) // 2

  print(pickArr(true).length) // 2
  print(pickArr(false)[0]) // 3

  // binding position: a struct value-`if` written into a `: P` local.
  const c = true
  const p: P = if c then { x: 7 } else { x: 9 }
  print(p.x) // 7

  print(classify(4)) // mid
  print(pickStrs(true)[0]) // a
  print(pickPs(false)[1].x) // 6
}
go()
