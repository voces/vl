// @check
// @error-at 6:3 postfix `++` target must be an identifier
// @error-at 8:4 postfix `--` target must be an identifier
// Postfix `++`/`--` on a member or index target gets the honest diagnostic
// and the operator is consumed (not left to re-parse as a prefix op).
let o = { x: 1 }
o.x++
let a = [1, 2]
a[0]--
