// @error unparenthesized `??` mixed with `||`
// @error unparenthesized `??` mixed with `&&`
// `??` never shares an unparenthesized operand chain with `||`/`&&` (the JS
// rule): `??` and `||` sit on one precedence tier, so the silent left-to-right
// grouping is a coin-flip for the reader — the grammar demands parentheses
// (see the parenthesized control, coalesce-logical-paren-ok.vl).
const a: boolean | null = null
const _x = a ?? true || false
const _y = a ?? false && true
const _z = true && a ?? false
