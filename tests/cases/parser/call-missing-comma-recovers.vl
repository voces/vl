// @check
// @error-at 7:10 expected `)` but found `2`
// @error-at 9:3 postfix `++` target must be an identifier
// A missing comma inside a call resyncs AT the `)` (the closer is not
// consumed by the failed expect), so the two independent errors below are
// both reported — no cascade between them.
function f(a: i32, b: i32) { a + b }
print(f(1 2))
let o = { x: 1 }
o.x++
