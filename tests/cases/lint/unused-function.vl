// @check
// @warning Unused function `dead`
// A non-exported top-level `function` that is never referenced anywhere in the
// file is dead code in a whole-program compile (B17 unused-function rule). `dead`
// is declared but never called, passed as a value, or named in a type, so it is
// flagged. `used` IS called below, so it is not flagged — guarding the rule
// against over-firing on a referenced function.
function dead(n: i32): i32 {
  return n + 1
}
function used(n: i32): i32 {
  return n * 2
}
print(used(3))
