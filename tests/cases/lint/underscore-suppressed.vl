// @check
// A leading-underscore name is the "intentionally unused" convention. It is NOT
// a warning: an unread `_`-prefixed binding emits a `hint`-severity,
// `unnecessary`-tagged diagnostic instead, so editors grey/fade the span with no
// squiggle and without counting it as a warning. Both the unused local
// `_scratch` and the unused parameter `_unused` are asserted as hints below.
// @hint Intentionally-unused variable `_scratch`
// @hint Intentionally-unused parameter `_unused`
function h(n: i32, _unused: i32): i32 {
  let _scratch = n + 1
  return n
}
