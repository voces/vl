// @run
// @log 5
// Code that all executes produces no unreachable-code warning: the `return` is
// the last statement, nothing follows it. (No diagnostics declared => zero
// asserted.) Also exercises that a `return` inside an `if` branch does not make
// the sibling statements after the `if` unreachable.
function pick(n: i32) {
  if n < 0 {
    return 0
  }
  return n
}
print(pick(5))
