// @check
// An EXPORTED top-level function is public API — in VL's multi-file module
// system it may be imported and called by another module — so it is NEVER
// flagged unused-function even with no reference in its own file. This is the key
// difference from a naive single-file dead-code scan. The file declares no
// diagnostics, so the strict harness asserts zero: an exported-but-locally-unused
// `pub` must stay silent.
export function pub(n: i32): i32 {
  return n + 1
}
