// Shared helper for the unused-import lint fixtures: exports a plain function
// (value use), a type (annotation-only use), and a free `self`-function (UFCS
// member-call use). Checked standalone by the corpus walker too, so it must be
// lint-clean itself (exports are exempt from the unused rules).
export function used(n: i32) {
  return n * 2
}

export function never(n: i32) {
  return n + 1
}

export type Point = { x: i32, y: i32 }

export function shout(self: string): string {
  return self + "!"
}
