// @check
// Binding-keyed use/write tracking: an inner binding reusing an outer binding's
// NAME neither marks the outer one used nor leaks its writes onto it.
// @warning Unused variable `n`
// @info `a` is never reassigned; use `const` instead of `let`
let n = 1
export function inc(n: i32) { return n + 1 }
let a = 1
export function bump() {
  let a = 2
  a = 3
  return a
}
print(inc(2) + bump() + a)
