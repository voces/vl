// @check
// @warning This loop body never runs: its condition is always `false`
// A `while false { … }` body never executes (literal-false constant condition).
// The lint pass flags the body (B17 constant-branch rule). `n` is returned and
// `f` is called below (so it is not also flagged unused-function) — the only
// diagnostic is the dead-loop warning.
function f(n: i32) {
  while false {
    print(n)
  }
  return n
}
print(f(1))
