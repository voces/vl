// @run
// @log 6
// A non-exported top-level function that IS called must NOT be flagged
// unused-function (the must-not-warn baseline). `triple` is referenced by the
// top-level `print(triple(2))`, so the rule stays silent; the file declares no
// diagnostics, so the strict harness asserts zero.
function triple(n: i32): i32 { return n * 3 }
print(triple(2))
