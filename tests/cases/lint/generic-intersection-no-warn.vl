// @check
// @warning Unused function `wrap`
// A generic intersection `T & S` involves an unresolved type variable `T`, so it
// can be non-empty for some instantiation (`T = S` makes it just `S`). The
// empty-intersection lint is scoped to CONCRETE operands only, so it must NOT
// flag `type Both<T> = T & S`. The only diagnostic is the unused-function warning
// on `wrap` (it is never called) — crucially NOT an empty-intersection one.
type S = { s: string }
type Both<T> = T & S
function wrap<T>(x: Both<T>): Both<T> x
print(1)
