// @check
// @warning Unused variable `unused`
// A module-level (top-level) `let` that is never read warns (B17 lint pass):
// unused top-level bindings are dead in a whole-program compile. `_`-prefix
// suppresses, and an explicit `export` (future) will exempt consumer-facing
// surface. `used` is read by `f`; `unused` is dead. `f` is called below so it is
// not also flagged unused-function.
const used = 41
let unused = 99
function f() {
  return used + 1
}
print(f())
