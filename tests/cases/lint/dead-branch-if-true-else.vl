// @check
// @warning This branch is never taken: a preceding condition is always `true`
// `if true { … } else { … }` always takes the then-branch, so the `else` is
// statically dead. The lint pass flags the else-branch (B17 constant-branch
// rule). Both branches return i32, and `f` is called below (so it is not also
// flagged unused-function), so the only diagnostic is the dead-else warning.
function f(n: i32): i32 {
  if true {
    return n
  } else {
    return 0
  }
}
print(f(1))
