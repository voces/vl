// @run
// @log 100
// @log 200
// GUARD (must-not-info): the dead-`else` lint must NOT fire when the `else` is
// load-bearing. Here `if v is 0 { … } else { … }` over `0 | 1` subtracts only
// `0`, leaving `1` for the `else` — the chain is NOT exhaustive without it, so
// the `else` is reachable and the exhaustive-dead-else info must stay silent.
function pick(v: 0 | 1): i32 {
  if v is 0 { return 100 } else { return 200 }
}
print(pick(0))  // 100
print(pick(1))  // 200
