// @check
// @warning Unreachable code
// A statement after a `return` in the same block can never execute (the
// must-have unreachable-code rule). The trailing `n + 1` is flagged. It is kept
// i32-typed so the block's fall-through type still matches the `i32` return and
// the ONLY diagnostic is the unreachable-code warning.
function f(n: i32): i32 {
  return n
  n + 1
}
