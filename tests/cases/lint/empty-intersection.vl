// @check
// @warning Intersection `A & B` is empty (`never`) — an object and a string literal, have no common values
// `type C = A & B` folds to `never`: an object and a disjoint string literal
// share no values (B17 empty-intersection lint). A real value can never have
// this type, so the DECLARATION is flagged as a warning even when no value is
// constructed. (When a value IS formed for `C`, the binding-site never-value
// ERROR takes over and suppresses the lint — see tests/cases/types.)
//
// The operand description is accurate — `A` is `{ a: string }` ("an object") and
// `B` is `"foo"` ("a string literal"), NOT "a number literal" (PR #189 review).
// The warning RANGE covers the `A & B` intersection EXPRESSION (0-indexed `9:9`,
// the `type C = A & B` annotation), not the alias name `C`.
type A = { a: string }
type B = "foo"
type C = A & B
print(1)
