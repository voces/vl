// @check
// @info `total` is never reassigned; use `const` instead of `let`
// A `let` binding that is never reassigned should be the immutable `const`
// (VL matches JS/TS: `const` immutable, `let` reassignable). `total` is read
// (returned) but never written, so prefer-`const` fires as an info.
function sum(n: i32) {
  let total = n + 1
  return total
}
print(sum(2))
