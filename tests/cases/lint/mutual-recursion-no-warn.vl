// @run
// @log 1
// @log 0
// A mutually-recursive pair both reachable from a used function must NOT be
// flagged unused-function (guard against a recursion-only false positive). The
// top-level `print(isEven(4))`/`print(isOdd(4))` reach `isEven` ↔ `isOdd`, which
// call each other forward/backward; the rule reuses the file's reference tracking
// (symbol table + AST call set), so every function reachable from a call site is
// spared. No function here is dead, so the harness asserts zero diagnostics.
function isEven(n: i32): i32 {
  if n == 0 { return 1 }
  return isOdd(n - 1)
}
function isOdd(n: i32): i32 {
  if n == 0 { return 0 }
  return isEven(n - 1)
}
print(isEven(4))
print(isOdd(4))
