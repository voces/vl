// @check
// Match-arm bodies are linted like any other block: the shared walker descends
// into each arm, so the binding rules and the structural rules all fire there.
// @warning Unused variable `deadUnusedLocal`
// @info `promotable` is never reassigned; use `const` instead of `let`
// @warning This branch is never taken: its condition is always `false`
// @warning Unreachable code: this can never execute
type Key = "a" | "b"

export function pick(k: Key) {
  match k {
    "a" => {
      let deadUnusedLocal = 42
      let promotable = 1
      if false {
        print("never")
      }
      return promotable
      print("after return")
    }
    _ => {
      return 0
    }
  }
}
