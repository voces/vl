// @check
// A `let` that IS reassigned must NOT trigger prefer-`const`: the binding is
// rebound (`acc = acc + n`, `acc++`), so `let` is the correct keyword and the
// rule stays silent. This file declares no diagnostics, so the strict harness
// asserts zero — proving the reassignment-tracking (occurrence `isWrite`) works.
function count(n: i32): i32 {
  let acc = 0
  acc = acc + n
  acc++
  return acc
}
