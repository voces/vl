// @check
// @warning This branch is never taken: its condition is always `false`
// `if false { … }` has a statically-dead then-branch (literal-false condition).
// The lint pass flags it (B17 constant-branch rule). `n` is returned and `f` is
// called below (so it is not also flagged unused-function) — the only diagnostic
// is the dead-branch warning.
function f(n: i32) {
  if false {
    return 0
  }
  return n
}
print(f(1))
