// @check
// @warning This branch is never taken: its condition is always `false`
// `if false { … }` has a statically-dead then-branch (literal-false condition).
// The lint pass flags it (B17 constant-branch rule). `n` is returned so the only
// diagnostic is the dead-branch warning.
function f(n: i32): i32 {
  if false {
    return 0
  }
  return n
}
