// @check
// @warning Unreachable code
// When BOTH branches of an `if/else` diverge (each returns), control never falls
// through, so a statement after the `if/else` is unreachable. This is the
// "both branches diverge" extension beyond plain unreachable-after-return. The
// trailing `n` is kept i32-typed so the only diagnostic is the warning.
function classify(n: i32) {
  if n < 0 {
    return 0
  } else {
    return 1
  }
  n
}
print(classify(-1))
