// @run
// @log 6
// @warning Unused import `twice`
// An `as`-renamed import binds its LOCAL alias — the unused-import rule names
// the alias (`twice`), anchored at the specifier. The second specifier from the
// same module is used, so only the alias flags.
import { never as twice, used } from "./import-use-helper"

print(used(3))
