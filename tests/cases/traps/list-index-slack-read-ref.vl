// @trap array index out of bounds
// A REF-element list read in the capacity slack traps as an out-of-bounds
// access (the guard fires BEFORE the element unbox, so it can no longer
// surface as a misleading null-cast trap on the zero-initialized slot).
const xs: {v: i32}[] = []
xs.push({v: 1})
print(xs[2].v)
