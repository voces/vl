// @trap array index out of bounds
// A list read in the `len <= i < cap` slack traps. `.push` grows the backing
// capacity past `len` (here len=1, cap=4 after one push onto an empty list), so
// without the `i u< len` guard the read would return the backing's zero-init
// silently. The guard maps any index at or past `len` to an out-of-range
// backing index, so the `array.get` itself traps.
const xs: i32[] = []
xs.push(42)
print(xs[3])
