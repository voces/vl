// @trap array index out of bounds
// @trap :10:6
// A runtime array out-of-bounds READ traps. With debug info (roadmap B-debug)
// the trap is reported as a VL-source-located runtime error rather than a raw
// wasm abort. The `@trap` directive asserts the mapped message contains both the
// reason ("array index out of bounds") and the source location (`:10:6`, the
// `xs[i]` index access on line 10, column 6).
const xs = [10, 20, 30]
const i = 5
print(xs[i])
