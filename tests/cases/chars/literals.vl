// @run
// @log 97
// @log 65
// @log 10
// @log 9
// @log 13
// @log 92
// @log 39
// @log 34
// @log 0
// @log 65
// @log 233
// @log 233
// Char literals (H2): a single-quoted `'x'` evaluates to its i32 code point, so
// it composes with arithmetic, `==`, and string indexing exactly like a bare int
// literal. The SAME escape grammar as strings is supported inside the quotes.
print('a')        // 97
print('A')        // 65
print('\n')       // 10
print('\t')       // 9
print('\r')       // 13
print('\\')       // 92  backslash
print('\'')       // 39  single quote
print('\"')       // 34  double quote (escaped or not)
print('\0')       // 0   nul
print('\x41')     // 65  hex escape -> 'A'
print('é')        // 233 raw non-ASCII char (one code point)
print('\u00e9') // 233 unicode escape -> 'é'
