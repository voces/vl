// @run
// @log 1
// @log true
// @log false
// Char literals compose with string indexing: `s[i]` yields an i32 char code, so
// comparing it against a char literal is the core lexer idiom `if s[i] == 'a'`.
const s = "abc"
if s[0] == 'a' { print(1) }
print(s[1] == 'b')   // true
print(s[2] == 'a')   // false
