// @run
// @log 12
// Nested index-trap composition (ROADMAP B13): a `"[]"` method may itself return
// an object that declares `"[]"`, so `a[i][j]` chains the two traps —
// `a."[]"(i)."[]"(j)`. The outer trap picks a row object; the inner trap reads a
// column from that row's backing array.
function row(base: i32) { { "[]": (j: i32) => base + j } }
function grid() { { "[]": (i: i32) => row(i * 10) } }
const a = grid()
print(a[1][2]) // 12 — outer "[]" -> row(10), inner "[]" -> 10 + 2
