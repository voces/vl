// @run
// @log 15
// @log 12
// Index read trap (ROADMAP B13): a user object that declares a `"[]"` method
// handles `o[k]` itself — `o[k]` dispatches to `o."[]"(k)`, reusing the
// field-method call path (the same shape as a `"+"` operator field). The method
// captures the constructor's parameter, so the lookup is computed, not a stored
// field. A native array keeps its fast `array.get`; only an object that actually
// declares `"[]"` is trapped.
function box(v: i32) { "[]": (k: i32) => v + k }
const b = box(10)
print(b[5]) // 15 — dispatched through "[]"
print(b[2]) // 12
