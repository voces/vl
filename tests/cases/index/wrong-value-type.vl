// @check
// @error index write: expected i32, got string
// CONTRACT (must-error): the `"[]="` method's value parameter checks the
// assigned value — `o[k] = v` is only sound when `v` matches the trap's value
// type. Storing a string into an i32-valued trap is rejected, mirroring the
// direct `o."[]="(0, "bad")` call.
function cell(init: i32) {
  let store = [init]
  {
    "[]": function(k: i32) store[k],
    "[]=": function(k: i32, v: i32) { store[k] = v }
  }
}
let c = cell(7)
c[0] = "bad"
