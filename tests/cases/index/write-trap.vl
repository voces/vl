// @run
// @log 7
// @log 42
// @log 7
// Index write trap (ROADMAP B13): a user object that declares a `"[]="` method
// handles `o[k] = v` itself — the assignment dispatches to `o."[]="(k, v)`,
// reusing the field-method call path. Read and write share a backing array (a
// reference type), so a write through `"[]="` is visible to a later `"[]"` read.
// Mutating one key leaves the others untouched.
function cell(init: i32) {
  const store = [init, init, init]
  {
    "[]": (k: i32) => store[k],
    "[]=": (k: i32, v: i32) => {
      store[k] = v
    },
  }
}
const c = cell(7)
print(c[1]) // 7
c[1] = 42   // dispatched through "[]="
print(c[1]) // 42 — mutation read back
print(c[0]) // 7  — sibling untouched
