// @check
// @error index: expected i32, got string
// CONTRACT (must-error): the `"[]"` method's parameter type checks the index —
// `o[k]` is only sound when `k` matches the trap's key type. Indexing an
// i32-keyed trap with a string literal is a type error (the same rejection a
// direct `o."[]"("wrong")` would get), not a silent coercion.
function box(v: i32) { "[]": (k: i32) => v + k }
let b = box(10)
print(b["wrong"])
