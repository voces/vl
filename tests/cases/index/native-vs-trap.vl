// @run
// @log 20
// @log 99
// @log 97
// @log 11
// Precedence (ROADMAP B13): a native array (i32 index signature → WasmGC array)
// keeps native `array.get`/`array.set` — it is NOT routed through any `"[]"`
// method. A string indexes natively to a char code. Only a non-array user object
// that declares `"[]"` is trapped. This pins the resolution order: native array
// wins, else a `"[]"`/`"[]="` method, else the existing index-signature path.
let xs = [10, 20, 30]
print(xs[1])     // 20 — native array.get
xs[1] = 99       // native array.set
print(xs[1])     // 99
let s = "abc"
print(s[0])      // 97 — native string char code
function box(v: i32) { "[]": function(k: i32) v + k }
let b = box(10)
print(b[1])      // 11 — trapped through "[]"
