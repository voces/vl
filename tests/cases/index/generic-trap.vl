// @run
// @log 99
// @log true
// `_k` is an intentionally-unused parameter (leading `_`) -> a faded hint, not a
// warning. Asserted so the strict harness stays green.
// @hint Intentionally-unused parameter `_k`
// Generic element type through the index trap (ROADMAP B13 + A10): a `"[]"`
// method returning `T` resolves `T` per receiver via the same monomorphization
// that drives self/operator dispatch. `wrap(99)` traps to a `"[]"` returning
// i32; `wrap(true)` to one returning boolean — each lowered against its own
// concrete element type.
function wrap<T>(x: T) { "[]": (_k: i32) => x }
const wi = wrap(99)
print(wi[0]) // 99 (i32)
const wb = wrap(true)
print(wb[0]) // true (boolean)
