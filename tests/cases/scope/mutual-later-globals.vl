// @run
// @log 8
// An UN-annotated callee whose return is inferred THROUGH a forward reference to a
// global declared after it — the case that used to require a return annotation so
// the body could resolve the (not-yet-declared) global. Now it just infers.
function useG() { g + 1 }
function viaA(): i32 { useG() }
const g = 7
print(viaA())
