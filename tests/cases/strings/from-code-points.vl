// @run
// @log hi
// @log 0
// @log abc
// `fromCodePoints(xs: i32[])` builds a string from a CODE-POINT LIST in one bulk
// copy — the amortized alternative to per-char `fromCodePoint(c)` + `+` concat
// (quadratic copy churn; a VL string is a real array, not a rope). Bootstrap-
// critical: the native `vl` tool's source feed pushes code points into an i32[]
// and converts once.
const xs = [104, 105]
print(fromCodePoints(xs))
const empty: i32[] = []
print(fromCodePoints(empty).length)
const ys: i32[] = []
ys.push(97)
ys.push(98)
ys.push(99)
print(fromCodePoints(ys))
