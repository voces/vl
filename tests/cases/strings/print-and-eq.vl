// @run
// @log hello
// @log foobar
// @log 101
// String printing + equality (ROADMAP A7/B7). `__store_string__(off, s)` copies a
// GC string's chars as bytes into linear memory and returns the length;
// `__log_string__(off, len)` renders them as text. `==`/`!=` compare length +
// elements via a generated `__string_eq__` helper (used here through `if`, since
// booleans are distinct from i32).
let n = __store_string__(0, "hello")
__log_string__(0, n)
let k = __store_string__(0, "foo" + "bar")
__log_string__(0, k)
let r = 0
if "abc" == "abc" { r = 1 }
if "abc" == "abd" { r = r + 10 }
if "ab" != "abc" { r = r + 100 }
__store_i32__(0, 0)
__store_i32__(4, r)
__log__(0, 8)
