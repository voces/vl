// @run
// @log hello
// @log foobar
// @log 101
// String printing + equality (ROADMAP A7/B7). `print(s)` renders a string by
// copying its chars to scratch memory and logging them as text. `==`/`!=`
// compare length + elements via a generated `__string_eq__` helper (used here
// through `if`, since booleans are distinct from i32).
print("hello")
print("foo" + "bar")
let r = 0
if "abc" == "abc" { r = 1 }
if "abc" == "abd" { r = r + 10 }
if "ab" != "abc" { r = r + 100 }
print(r)
