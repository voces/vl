// @run
// @log 0
// @log 6
// @log 10
// @log -1
// @log 0
// @log true
// @log false
// `indexOf(sub)` returns the first index of `sub` in the receiver, or -1
// (ROADMAP A7). Empty-substring convention follows JS: `"abc".indexOf("") == 0`.
// `includes(sub)` is `indexOf(sub) != -1`. A naive O(n*m) scan over char codes.
let s = "hello world"
// found at index 0.
print(s.indexOf("hello"))
// found mid-string.
print(s.indexOf("world"))
// found at the end (single char at last index).
print(s.indexOf("d"))
// not found -> -1.
print(s.indexOf("xyz"))
// empty substring -> 0.
print(s.indexOf(""))
// includes: present -> true (print renders the boolean directly).
print(s.includes("lo wo"))
// includes: absent -> false.
print(s.includes("zzz"))
