// @run
// @log 0
// @log 6
// @log 10
// @log -1
// @log 0
// @log 1
// @log 0
// `indexOf(sub)` returns the first index of `sub` in the receiver, or -1
// (ROADMAP A7). Empty-substring convention follows JS: `"abc".indexOf("") == 0`.
// `includes(sub)` is `indexOf(sub) != -1`. A naive O(n*m) scan over char codes.
let s = "hello world"
__store_i32__(0, 0)
// found at index 0.
__store_i32__(4, s.indexOf("hello"))
__log__(0, 8)
// found mid-string.
__store_i32__(4, s.indexOf("world"))
__log__(0, 8)
// found at the end (single char at last index).
__store_i32__(4, s.indexOf("d"))
__log__(0, 8)
// not found -> -1.
__store_i32__(4, s.indexOf("xyz"))
__log__(0, 8)
// empty substring -> 0.
__store_i32__(4, s.indexOf(""))
__log__(0, 8)
// includes: present -> 1 (boolean compared via `if`, distinct from i32).
let a = 0
if s.includes("lo wo") { a = 1 }
__store_i32__(4, a)
__log__(0, 8)
// includes: absent -> 0.
let b = 0
if s.includes("zzz") { b = 1 }
__store_i32__(4, b)
__log__(0, 8)
