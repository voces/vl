// @run
// @log 3
// @log 10
// @log 97
// @log 98
// @log 1
// @log 9
// @log 1
// @log 13
// @log 3
// @log 92
// @log 1
// @log 34
// @log 1
// @log 39
// @log 1
// @log 0
// @log 1
// @log 65
// @log 1
// @log 233
// @log 10
// String escape-sequence decoding. A string literal's stored value holds the
// DECODED characters, so `\n` is a single char (code 10), not a backslash + n.
// The token span still measures the raw 2-char source extent, but `.length`
// and `charCodeAt` see the logical, decoded string.

// "a\nb" is 3 chars: 'a', newline (10), 'b'.
let nl = "a\nb"
print(nl.length)
print(nl.charCodeAt(1))
print(nl.charCodeAt(0))
print(nl.charCodeAt(2))

// "\t" is one char, code 9.
let tab = "\t"
print(tab.length)
print(tab.charCodeAt(0))

// "\r" is one char, code 13.
let cr = "\r"
print(cr.length)
print(cr.charCodeAt(0))

// "a\\b" is 3 chars with a single backslash (92) at index 1.
let bs = "a\\b"
print(bs.length)
print(bs.charCodeAt(1))

// Escaped quote inside a double-quoted string: one char, code 34.
let dq = "\""
print(dq.length)
print(dq.charCodeAt(0))

// Escaped single quote: one char, code 39.
let sq = "\'"
print(sq.length)
print(sq.charCodeAt(0))

// Null escape: one char, code 0.
let nul = "\0"
print(nul.length)
print(nul.charCodeAt(0))

// \xXX hex escape: \x41 == 'A' (65).
let hx = "\x41"
print(hx.length)
print(hx.charCodeAt(0))

// \uXXXX unicode escape: é == 'é' (233).
let u = "\u00e9"
print(u.length)
print(u.charCodeAt(0))

// A decoded newline really is a newline char (code 10), not '\' + 'n'.
let combined = "x\ny"
print(combined.charCodeAt(1))
