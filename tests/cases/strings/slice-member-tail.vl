// @run
// @log 3
// @log 2
// A MEMBER access on a `.slice(...)` result as a function's trailing (implicit-
// return) expression — `s.slice(a, b).length`. The string-op scratch frame this
// slice needs is reserved by a per-function pre-scan; that scan must recognise a
// bare trailing Member statement as an expression to descend into, or the slice
// emits a reference to an unreserved local and the module fails to validate.
function sliceLen(s: string, a: i32, b: i32): i32 {
  s.slice(a, b).length
}
print(sliceLen("hello", 1, 4))
print(sliceLen("worldwide", 0, 2))
