// @run
// @log 5
// @log 104
// Strings are full participants in the object machinery: a `self`-method takes a
// `string` receiver and is callable via UFCS (`"hello".first()`), and an
// annotated `string` parameter type-checks + indexes like any array.
function first(self: string) self[0]
function size(self: string) self.length
print(size("hello"))
print("hello".first())
