// @run
// @log ababab
// @log true
// @log ab!ab
// @log 3
// The same literal evaluated repeatedly (per loop iteration, in comparisons, as a
// const-global init, and as a map key) behaves as a fresh value each time — the
// emitter interns literal occurrences (one shared immutable module global), which
// must be unobservable: strings are immutable and `==` is element-wise.
const sep = "!"
let out = ""
for i in 0 to 2 {
  out = out + "ab"
}
print(out)
print("ab" == "ab")
print("ab" + sep + "ab")
const m: {[string]: i32} = Map()
m["ab"] = 1
for k in 0 to 1 {
  m["ab"] = (m["ab"] ?? 0) + 1
}
print(m["ab"] ?? -1)
