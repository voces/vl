// @run
// @log hello
// @log world
// @log world
// @log 0
// @log 0
// @log 3
// `slice(start, end)` returns a fresh string for the half-open range
// `[start, end)` (ROADMAP A7). JS `String.prototype.slice` semantics: a negative
// index counts from the end (`len + i`); both bounds then clamp to `[0, len]`; if
// `start >= end` after clamping the result is empty. Strings are WasmGC i32-arrays
// of char codes, so `slice` allocates a new array and `array.copy`s the range in.
let s = "hello world"
print(s.slice(0, 5))
// end past the length clamps to len.
print(s.slice(6, 100))
// negative start counts from the end (-5 -> len-5 == 6).
print(s.slice(-5, 100))
// empty range (start == end).
print(s.slice(3, 3).length)
// start > end clamps to empty (no negative length).
print(s.slice(8, 2).length)
// chaining + combining with `+` / `.length`: ("ab" from slice) + "c" -> len 3.
print((s.slice(0, 2) + "c").length)
