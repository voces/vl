// @run
// @log A
// @log B
// @log HI
// @log !
// @log true
// `fromCharCode(code: i32): string` builds a single-character VL string (a
// length-1 i32-array of char codes) from a char code. Bootstrap-critical for
// the self-hosted lexer materializing decoded `\xXX` / `\uXXXX` escapes.
print(fromCharCode(65)) // 'A'
let b: string = fromCharCode(66)
print(b) // 'B'
// Built chars concatenate into a longer string.
let s: string = fromCharCode(72) + fromCharCode(73)
print(s) // "HI"
// Resolves across a function boundary and from a computed i32.
function ch(code: i32): string {
  return fromCharCode(code)
}
print(ch(32 + 1)) // '!'
// A built char compares equal to a string literal of the same character.
print(fromCharCode(65) == "A")
