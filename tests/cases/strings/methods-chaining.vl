// @run
// @log 2
// @log world
// @log 108
// @log 5
// Method chaining + `charCodeAt` (ROADMAP A7). `s.slice(...).indexOf(...)`
// chains because each method's receiver/result is a real `string`.
let s = "hello world"
__store_i32__(0, 0)
// slice("hello world", 6, 11) == "world"; indexOf "r" within it == 2.
__store_i32__(4, s.slice(6, 11).indexOf("r"))
__log__(0, 8)
// the sliced substring round-trips through the print path.
let w = __store_string__(0, s.slice(6, 11))
__log_string__(0, w)
// charCodeAt: 'l' (the 3rd char of "hello") is char code 108.
__store_i32__(4, s.charCodeAt(2))
__log__(0, 8)
// indexOf result feeds a slice: from the space onward is " world" (length 6),
// but slice from index+1 to length is "world" (length 5).
let i = s.indexOf(" ")
__store_i32__(4, s.slice(i + 1, s.length).length)
__log__(0, 8)
