// @run
// @log A
// @log B
// @log HI
// @log !
// @log true
// `fromCodePoint(code: i32): string` builds a single-character VL string (a
// length-1 i32-array of code points) from a Unicode code point. Bootstrap-critical
// for the self-hosted lexer materializing decoded `\xXX` / `\uXXXX` escapes.
print(fromCodePoint(65)) // 'A'
let b: string = fromCodePoint(66)
print(b) // 'B'
// Built chars concatenate into a longer string.
let s: string = fromCodePoint(72) + fromCodePoint(73)
print(s) // "HI"
// Resolves across a function boundary and from a computed i32.
function ch(code: i32): string {
  return fromCodePoint(code)
}
print(ch(32 + 1)) // '!'
// A built char compares equal to a string literal of the same character.
print(fromCodePoint(65) == "A")
