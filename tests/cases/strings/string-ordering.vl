// @run
// @log 1
// @log 0
// @log 1
// @log 1
// @log 1
// @log 0
// @log 1
// @log 1
// Lexicographic string ORDERING (`<`/`>`/`<=`/`>=`). The checker now types a comparison of
// two strings as a bool; the emitter lowers it through ONE primitive `emitStrLessCore`
// (first-operand-less, code-point compare up to the shorter length, the shorter string
// less on a common prefix) and derives the four operators by swap/negate. Previously the
// checker rejected it ("comparison expects numeric operands, got string and string").

function lt(a: string, b: string): boolean { return a < b }

function go() {
  print(if "abc" < "abd" then 1 else 0) // 1
  print(if "abd" < "abc" then 1 else 0) // 0
  print(if "ab" < "abc" then 1 else 0) // 1 (prefix: shorter is less)
  print(if "abc" > "ab" then 1 else 0) // 1
  print(if "abc" <= "abc" then 1 else 0) // 1 (equal)
  print(if "abd" <= "abc" then 1 else 0) // 0
  print(if "z" >= "a" then 1 else 0) // 1
  print(if lt("apple", "banana") then 1 else 0) // 1 (through a function boundary)
}
go()
