// @run
// @log 5
// @log 294
// @log 1
// @log 0
// @log 11
// `for ch in s` iterates a STRING's code units — each an i32, exactly as `s[i]` reads one. A
// string IS the raw i32 array at the wasm level, so the checker types the loop var i32 and the
// emitter reuses the i32-array iteration loop — only the `#l` temp is the string itself (no list
// wrapper), so the length is `array.len` and each element `array.get $aTypeIdx` directly. Was a
// clean rejection ("for-in expects an array or map, got string").

function countChars(s: string): i32 {
  let n = 0
  for ch in s { n = n + 1 }
  return n
}

function go() {
  // element count.
  print(countChars("hello")) // 5

  // sum of code points: 'a'+'b'+'c' = 97 + 98 + 99.
  let t = 0
  for ch in "abc" { t = t + ch }
  print(t) // 294

  // narrow on a code unit — count the 'e' (101) in "hello".
  let e = 0
  for ch in "hello" {
    if ch == 101 { e = e + 1 }
  }
  print(e) // 1

  // an empty string iterates zero times.
  let z = 0
  for ch in "" { z = z + 1 }
  print(z) // 0

  // a longer string through a param.
  print(countChars("hello world")) // 11
}
go()
