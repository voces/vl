// @run
// @log 12
// @log [10, 20, 30]
// A real serializer: conditional separator + value append per iteration, then a
// trailing concat. The accumulator is never read inside the loop.
function ser(xs: i32[]) {
  let s = "["
  let i = 0
  while i < xs.length {
    if i > 0 {
      s = s + ", "
    }
    s = s + toString(xs[i])
    i = i + 1
  }
  return s + "]"
}
const out = ser([10, 20, 30])
print(out.length)   // 12
print(out)          // [10, 20, 30]
