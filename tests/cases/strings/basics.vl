// @run
// @log 5
// @log 104
// @log 5
// @log 99
// @log 3
// Strings (ROADMAP A7 + B7): a `string` is a WasmGC i32-array of char codes,
// recognized by its `{[i32]: i32}` index signature — so `.length` (array.len)
// and `s[i]` (array.get → char code) come from the array machinery. `+`
// concatenates (array.new + array.copy). (Char codes are logged since printing
// a GC string to linear memory isn't wired yet; `==` is not implemented.)
let s = "hello"
__store_i32__(0, 0)
__store_i32__(4, s.length)
__log__(0, 8)
__store_i32__(4, s[0])
__log__(0, 8)
let c = "ab" + "cde"
__store_i32__(4, c.length)
__log__(0, 8)
__store_i32__(4, c[2])
__log__(0, 8)
let g = "Hi" + "!"
__store_i32__(4, g.length)
__log__(0, 8)
