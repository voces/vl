// @run
// @log 0
// @log 1
// @log 2
// @log 1
// @log 0
// @log 2
// @log 1
// @log 3
// An `enum Name { A, B, C }` declaration — the first language feature toward a cleaner compiler (it
// replaces the magic integer "kind" codes). An enum is i32-backed: a member is its 0-based ordinal, a
// `Name.Member` access lowers to that `i32.const`, and a `: Name` annotation is an i32 slot. Works as a
// local (typed / inferred / uninitialized), param, return, global, in `==`, and as a kind-code-style
// dispatch. (Type-distinctness, and enum struct fields / arrays, are follow-ups.)

enum Color { Red, Green, Blue }

enum Kind { I32, Str, Bool }

const START: Color = Color.Red

function classify(k: Kind): i32 {
  if k == Kind.I32 { return 1 }
  if k == Kind.Str { return 2 }
  return 3
}

function go() {
  print(Color.Red) // 0
  print(Color.Green) // 1
  print(Color.Blue) // 2

  const c: Color = Color.Green
  if c == Color.Green {
    print(1) // 1
  } else {
    print(0)
  }

  if START == Color.Red {
    print(0) // 0
  } else {
    print(-1)
  }

  let u: Color
  u = Color.Blue
  print(u) // 2

  print(classify(Kind.I32)) // 1
  print(classify(Kind.Bool)) // 3
}

go()
