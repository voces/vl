// @run
// @log true
// @log 7
// @log hi
// @log 5
// @log NULL
// @log NULL
// A `{[string]: V} | null` is the `nulmap` niche — a `(ref null $mapStruct)` cell that is null or
// the map (the map twin of `nulstruct`/`nulreflist`). A `!= null` narrow lowers to `ref.is_null`;
// the narrowed map ops (`t["k"]`, `t["k"] ?? d`) recover the non-null map ref (`ref.as_non_null`)
// at the receiver — the checker proved every such read guarded. Holistic across the map value
// kinds: boolean / i32 / string / struct all cross the param boundary as the SAME nullable cell.

function useBool(p: {[string]: boolean} | null) {
  const t0 = p
  if t0 != null { print(t0["k"] ?? false) } else { print("NULL") }
}

function useI32(p: {[string]: i32} | null) {
  if p != null { print(p["k"] ?? -1) } else { print("NULL") }
}

function useStr(p: {[string]: string} | null) {
  if p != null { print(p["k"] ?? "d") } else { print("NULL") }
}

function useStruct(p: {[string]: {f: i32}} | null) {
  if p != null { print((p["k"] ?? {f: 0}).f) } else { print("NULL") }
}

function go() {
  const b: {[string]: boolean} = Map()
  b["k"] = true
  useBool(b) // true
  const i: {[string]: i32} = Map()
  i["k"] = 7
  useI32(i) // 7
  const s: {[string]: string} = Map()
  s["k"] = "hi"
  useStr(s) // hi
  const st: {[string]: {f: i32}} = Map()
  st["k"] = {f: 5}
  useStruct(st) // 5
  // a `null` argument crosses as `ref.null $mapStruct` and takes the else branch.
  useBool(null) // NULL
  useI32(null) // NULL
}

go()
