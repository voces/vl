// @run
// @log 42
// @log hey
// @log 2.5
// @log 9
// @log NULL
// @log 7
// @log 42
// Bare `const t = m[k]` reads of LIST- and nested-MAP-valued maps (`V | null` bindings).
// The whole kind-6 family was supposed to hit the bare-read loud reject, but `letIsMap`'s
// init fallback claimed a nested-map read as a NON-null map local (the nullable vals
// element stored into a non-null cell — INVALID-WASM), and list-valued reads rejected
// loudly. `letNulMapReadValKind` now binds each value family to its ESTABLISHED nullable
// local kind (nullist / nulstrlist / nulf64list / nuli64list / nulreflist / nulmap),
// checked BEFORE `letIsMap`, so the narrow + read machinery lowers unchanged (R1
// map-composition slice, 2026-07-22).
type S = {f: i32}
function go() {
  const mi: {[string]: {[string]: i32}} = Map()
  const inner: {[string]: i32} = Map()
  inner["k"] = 42
  mi["o"] = inner
  const t0 = mi["o"]
  if t0 != null { print(t0["k"] ?? 0) } else { print("NULL") }

  const ms: {[string]: {[string]: string}} = Map()
  const sInner: {[string]: string} = Map()
  sInner["k"] = "hey"
  ms["o"] = sInner
  const t1 = ms["o"]
  if t1 != null { print(t1["k"] ?? "d") } else { print("NULL") }

  const mf: {[string]: {[string]: f64}} = Map()
  const fInner: {[string]: f64} = Map()
  fInner["k"] = 2.5
  mf["o"] = fInner
  const t2 = mf["o"]
  if t2 != null { print(t2["k"] ?? 0.0) } else { print("NULL") }

  const m9: {[string]: {[string]: i64}} = Map()
  const nInner: {[string]: i64} = Map()
  nInner["k"] = 9
  m9["o"] = nInner
  const t3 = m9["o"]
  if t3 != null { print(t3["k"] ?? 0) } else { print("NULL") }
  const t4 = m9["missing"]
  if t4 != null { print(t4["k"] ?? 0) } else { print("NULL") }

  const ml: {[string]: i32[]} = Map()
  ml["k"] = [7]
  const t5 = ml["k"]
  if t5 != null { print(t5[0]) } else { print("NULL") }

  const mr: {[string]: S[]} = Map()
  mr["k"] = [{ f: 42 }]
  const t6 = mr["k"]
  if t6 != null { print(t6[0].f) } else { print("NULL") }
}
go()
