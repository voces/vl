// @run
// @log 1
// @log NULL
// @log 3
// A nested map whose inner value is a LIST OF NULLABLE i64 (`{[string]: {[string]: (i64 |
// null)[]}}`): the vals-list element resolves RECURSIVELY at the map op sites, so the
// construct, the deep read, and the small-int/`null` element mix (each int widens to i64
// at the box store; `null` takes the null tag) all round-trip. (Only a nested list-of-MAP
// element stays a loud reject — `mapValNestedListUnsupported`.)
function go() {
  const inner: {[string]: (i64 | null)[]} = Map()
  inner["k"] = [1, null, 3]
  const m: {[string]: {[string]: (i64 | null)[]}} = Map()
  m["k"] = inner
  const t0 = m["k"] ?? inner
  const t1 = t0["k"] ?? []
  const a = t1[0]
  if a != null { print(a) } else { print("NULL") } // 1
  const b = t1[1]
  if b != null { print(b) } else { print("NULL") } // NULL
  const c = t1[2]
  if c != null { print(c) } else { print("NULL") } // 3
}
go()
