// @run
// @log 27234707
// @log 9
// @log true
// @log aa
// @log 3
// @log OTHER
// An ARRAY-OF-MAP arm of a boxed union (`{[string]: V}[] | scalar`) CONSTRUCTED from an
// array literal of map bindings (`[h0]`) — the R1 map-in-list-in-union seam (rep-fuzz
// `p0c/p0r {[string]: i64}[] | f64`, `p2c/p2r {[string]: K0}[] | string`,
// `p2c/p2r {[string]: i32 | boolean}[] | i32`). The literal's map elements are invisible
// to `exprRefArray`, so the ref-array carrier path missed and the construct rejected
// loudly. Now `unionRefArrayArmSlotForMapElem` picks the arm whose element map shares the
// literal element's canonical value rep (mono matches mono, typed slots by `mvCanonRepOf`),
// the literal builds with the arm's reflist slot threaded, and the wrapper is tagged with
// the arm's slot tag. The frame pre-pass reserves the map scratch narrowing-blind for the
// `t[i][k]` read shape (`unionMapArrayElemIndex`). Value reps covered: i64 (typed scalar
// slot), K0 atoms (mono), i32|boolean value union (boxed values); construct + narrow +
// read + write + `.has` + the decoy arm, in local and return positions.
type K0 = "aa" | "bb"

function makeIt(pick: boolean): {[string]: i32 | boolean}[] | i32 {
  if pick {
    const h: {[string]: i32 | boolean} = Map()
    h["k"] = 3
    return [h]
  }
  return 7
}

function go() {
  const h0: {[string]: i64} = Map()
  h0["k"] = 27234707
  const v: {[string]: i64}[] | f64 = [h0]
  if v is {[string]: i64}[] {
    print(v[0]["k"] ?? 13131313131) // 27234707
    v[0]["z"] = 9
    print(v[0]["z"] ?? 0)           // 9 — SET through the narrowed element map
    print(v[0].has("k"))            // true
  } else {
    print(0.0)
  }
  // ATOM-valued (mono) element map.
  const h1: {[string]: K0} = Map()
  h1["k"] = "aa"
  const w: {[string]: K0}[] | string = [h1]
  if w is {[string]: K0}[] { print(w[0]["k"] ?? "bb") } else { print("no") }
  // VALUE-UNION-valued element map, return position + the scalar decoy arm.
  const r = makeIt(true)
  if r is {[string]: i32 | boolean}[] {
    const got = r[0]["k"] ?? false
    if got is i32 { print(got) } else { print(-1) } // 3
  } else {
    print(-2)
  }
  const s = makeIt(false)
  if s is {[string]: i32 | boolean}[] { print(-3) } else { print("OTHER") }
}
go()
