// @run
// @log 7
// @log -1
// @log hi
// @log none
// @log 10
// A BARE map get `const v = m[k]` (no `?? default`) is `V | null`. `emitMapGet` already yields the
// `(ref null …)` value, but the binding only classified a CLOSURE value as nullable (kind 19) — a
// STRUCT or STRING value bound a NON-null local (kind 1 / 3) that mismatched the nullable rep, and
// a UNION or ref-LIST value did the same: invalid wasm in every case (the checker types it
// `V | null` soundly; the emitter could not lower it).
//
// `exprNullableStruct` / `exprNullableString` now classify a bare struct- / string-valued map read
// (kinds 9 / 16), so it binds the nullable niche and narrows with `if v != null` — the map-read
// dual of a nullable struct-ARRAY element. A union- or ref-list-valued bare read has no nullable
// local rep, so it is a CLEAN reject (use `m[k] ?? <default>`, exercised at the bottom) rather than
// invalid wasm.

type S = { v: i32 }

function go() {
  const ms: {[string]: S} = Map()
  ms["a"] = { v: 7 }
  const hit = ms["a"]
  if hit != null {
    print(hit.v) // 7
  } else {
    print(-1)
  }
  const miss = ms["z"]
  if miss != null {
    print(miss.v) // -1
  } else {
    print(-1)
  }

  const mstr: {[string]: string} = Map()
  mstr["a"] = "hi"
  const sh = mstr["a"]
  if sh != null {
    print(sh) // hi
  } else {
    print("none")
  }
  const sm = mstr["z"]
  if sm != null {
    print(sm) // none
  } else {
    print("none")
  }

  // closure value was already nullable-classified (kind 19) — still works.
  const mf: {[string]: (i32) => i32} = Map()
  mf["a"] = (x) => x + 1
  const f = mf["a"]
  if f != null {
    print(f(9)) // 10
  } else {
    print(-1)
  }
}
go()
