// @run
// @log 0
// @log 2
// @log 0
// @log 2
// REGRESSION (B6a, C2.3): size is unified on `.length` (O(1), read-only property
// syntax) across Map and Set — `.size` is retired. This locks the renamed member
// for both collections (a Map's entry count and a Set's membership count both
// read the stored live count).
let m: {[string]: i32} = Map()
print(m.length)          // 0
m["a"] = 1
m["b"] = 2
print(m.length)          // 2

let s: {[string]: boolean} = Set()
print(s.length)          // 0
s.add("x")
s.add("y")
print(s.length)          // 2
