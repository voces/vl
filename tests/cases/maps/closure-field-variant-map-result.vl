// @run
// @log 7.5
// @log 0.5
// @log 84
// A NESTED-STRUCT union variant carrying a MAP-returning CLOSURE field (rep-fuzz
// `p2c/p2r {a: f64, f: {f: () => {[string]: f64}}, z: string} | {w: i32}`). The
// variant's nested-struct field (code 15) holds a closure (code 14) whose result is
// a typed-value map; the narrowed member-CHAIN call (`t0.f.f()`) is invisible to the
// frame pre-pass (the `is`-narrowing is not active there), so `callRefSlot` went
// unreserved and the `call_ref`'s closure spill landed on the mv map frame's local —
// a type-mismatched local, invalid wasm. `calleeIsUnionArmClosureMember` now walks
// the chain NARROWING-BLINDLY (arm tables, code-15 hops, closure leaf) and reserves
// conservatively. The union-CLOSURE-arm spelling with a live closure covers the arm
// construct + narrowed call + result-map read. (The same arm spelling whose program
// carries NO other map mention stays a loud reject until the closure-result map
// forcing lands — the stacked slice.)
function useIt(p: (() => {[string]: f64}) | {w: i32}): f64 {
  const t0 = p
  if t0 is () => {[string]: f64} {
    return t0()["k"] ?? 14.5
  }
  return 0.5
}

function makeIt(): {a: f64, f: {f: () => {[string]: f64}}, z: string} | {w: i32} {
  const h0: {[string]: f64} = Map()
  h0["k"] = 84.0
  return {a: 2.5, f: {f: () => (h0)}, z: "dx"}
}

function go() {
  const h: {[string]: f64} = Map()
  h["k"] = 7.5
  print(useIt(() => (h))) // 7.5 — the closure arm, called + map-read through its result
  print(useIt({w: 77}))   // 0.5 — the decoy variant
  const v = makeIt()
  const t0 = v
  if t0 is {a: f64, f: {f: () => {[string]: f64}}, z: string} {
    print(t0.f.f()["k"] ?? 14.5) // 84 — member-chain call_ref + result-map read
  } else {
    print("OTHER")
  }
}
go()
