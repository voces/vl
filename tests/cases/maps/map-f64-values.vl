// @run
// @log 1.5
// @log 2.5
// @log 9.5
// @log 0
// @log 2
// @log 12
// An f64-VALUED map `{[string]: f64}`. The vals list is the scalar f64 list (`fl64`
// wrapper / `fa64` backing), NOT a ref list — a new mv-value kind (11) whose typed
// valStash is an f64 LOCAL. Get/set/append store/load f64 directly (the default of a
// `?? d` read emits as f64; a miss yields 0.0); `m[k] ?? d` classifies as f64. Previously
// emit failed ("unsupported map value type").

function go() {
  const m: {[string]: f64} = Map()
  m["a"] = 1.5
  m["b"] = 2.5
  print(m["a"] ?? 0.0) // 1.5
  print(m["b"] ?? 0.0) // 2.5

  m["a"] = 9.5 // overwrite
  print(m["a"] ?? 0.0) // 9.5
  print(m["z"] ?? 0.0) // 0 (absent → default)

  print(m.size) // 2

  // iterate keys and sum the f64 values.
  let total = 0.0
  for k in m { total = total + (m[k] ?? 0.0) }
  print(total) // 9.5 + 2.5 = 12
}
go()
