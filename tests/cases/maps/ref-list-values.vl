// @run
// @log 7
// @log 6
// @log 3
// @log 20
// @log 9
// @log y
// @log 3
// @log 2
// @log -1
// A map whose VALUE is a ref LIST of any leaf type at any depth — `{[string]: S[]}`, `S[][]`,
// `i32[][]`, `((i32)=>i32)[]`, `(C|D)[]`, `string[][]`, `(C|D)[][]`. The map store/read now drive
// the SAME recursive ref-list resolver the array dimension uses: `ensureRefElem` interns the
// value's slots (recursive), the store SEEDS the value literal off that slot (so a nested value
// builds correctly), and the read flows through the recursive slots — so nested + closure list
// values fall out, the map analogue of `tests/cases/arrays/nested-ref-arrays.vl`.

type S = { v: i32 }
type Cat = { meow: i32 }
type Dog = { bark: i32 }

function go() {
  // struct-list value.
  const ms: {[string]: S[]} = Map()
  ms["a"] = [{ v: 1 }, { v: 7 }]
  print((ms["a"] ?? [])[1].v) // 7

  // NESTED struct value (S[][]).
  const mss: {[string]: S[][]} = Map()
  mss["a"] = [[{ v: 5 }, { v: 6 }]]
  print((mss["a"] ?? [])[0][1].v) // 6

  // scalar 2D value (i32[][]).
  const mi: {[string]: i32[][]} = Map()
  mi["a"] = [[1, 2], [3]]
  print((mi["a"] ?? [])[1][0]) // 3

  // closure-list value — index then call.
  const mf: {[string]: ((i32) => i32)[]} = Map()
  mf["a"] = [(x) => x + 1, (x) => x * 2]
  print((mf["a"] ?? [])[1](10)) // 20

  // union-list value — narrow the element.
  const mu: {[string]: (Cat | Dog)[]} = Map()
  mu["a"] = [{ bark: 9 }]
  const x = (mu["a"] ?? [])[0]
  if x is Dog {
    print(x.bark) // 9
  } else {
    print(-1)
  }

  // NESTED string value (string[][]).
  const mstr: {[string]: string[][]} = Map()
  mstr["a"] = [["x", "y"]]
  print((mstr["a"] ?? [])[0][1]) // y

  // NESTED union value ((C|D)[][]).
  const muu: {[string]: (Cat | Dog)[][]} = Map()
  muu["a"] = [[{ meow: 3 }]]
  const y = (muu["a"] ?? [])[0][0]
  if y is Cat {
    print(y.meow) // 3
  } else {
    print(-1)
  }

  // OVERWRITE a nested value, then read.
  mss["a"] = [[{ v: 1 }], [{ v: 2 }]]
  print((mss["a"] ?? [])[1][0].v) // 2

  // a MISS falls to the (nested) default.
  print((mss["z"] ?? [[{ v: -1 }]])[0][0].v) // -1
}
go()
