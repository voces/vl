// @run
// @log 5947.5
// @log 36103.5
// @log 04
// A TYPED-value map in a LIST-element position (`{[string]: V}[]`) now lowers: the ref-list
// element resolves the SAME per-value map struct (`mvMapTypeIdx`) a standalone `{[string]: V}`
// binding does, whichever value type it carries — position-independent. Before, the list
// element hard-coded the MONO map struct (`$mStructIdx`), so a store/read of a typed map ref
// mismatched the element heap (invalid wasm). Covers f32-scalar, f64-LIST, and struct value
// types, at param and return positions.
function useF32(p: {[string]: f32}[]) {
  const t0 = p[0]["k"] ?? 15.5
  print(t0)
}

function useF64List(p: {[string]: f64[]}[]) {
  const t0 = p[0]["k"] ?? [14.5]
  print(t0[0])
}

function makeStructMaps(): {[string]: {f: string}}[] {
  const h0: {[string]: {f: string}} = Map()
  h0["k"] = {f: "04"}
  return [h0]
}

function go() {
  const hF32: {[string]: f32} = Map()
  hF32["k"] = 5947.5
  useF32([hF32])

  const hF64L: {[string]: f64[]} = Map()
  hF64L["k"] = [36103.5]
  useF64List([hF64L])

  const v: {[string]: {f: string}}[] = makeStructMaps()
  const t0 = v[0]["k"] ?? {f: "zzz"}
  print(t0.f)
}

go()
