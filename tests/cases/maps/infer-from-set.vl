// @run
// @log 1
// @log 2
// @log 2
// @log true
// @log false
// @log -1
// USAGE-DRIVEN INFERENCE (A-infer-map-set), Map headline: an un-annotated
// `const m = Map()` infers its key/value type from a downstream `m.set(k, v)` —
// the key from `"a"` (`string`), the value from `1` (`i32`) — materialising the
// binding into the real `{[string]: i32}` map representation. So the rest of the
// Map surface (`.get`/`.has`/`.length`/index read) works unchanged. This used to
// fall to the "cannot infer" floor (the `Map()` hole was never pinned).
const m = Map()
m.set("a", 1)
m.set("b", 2)
print(m["a"] ?? -1)        // 1
print(m["b"] ?? -1)        // 2
print(m.length)            // 2
print(m.has("a"))          // true
print(m.has("z"))          // false
print(m.get("missing") ?? -1) // -1 — absent
