// @run
// @log 3
// @log 6
// @log 2
// @log 1
// `m.values()` as a BOUND list over a mono `{[string]: i32}` map — a fresh i32 list of the
// LIVE values (insertion order, tombstone-aware), the value analogue of `m.keys()` via the
// dedicated i32 `mapValsBase` frame. (Other value types iterate fine via `for v in
// m.values()`; the bound list form is i32-only for now — the output backing would vary per
// value kind. A non-i32 bound `.values()` fails with a clear message pointing at the
// for-in form.) Previously the bound form failed to lower ("callee is not a function name").

function go() {
  const m: {[string]: i32} = Map()
  m["a"] = 1
  m["b"] = 2
  m["c"] = 3

  print(m.values().length) // 3

  let s = 0
  const vs = m.values()
  for v in vs { s = s + v }
  print(s) // 1 + 2 + 3

  // delete tombstones an entry; values() skips it.
  m.delete("b")
  print(m.values().length) // 2

  // smallest surviving value via a bound list.
  const vs2 = m.values()
  let lo = vs2[0]
  let i = 1
  while i < vs2.length {
    if vs2[i] < lo { lo = vs2[i] }
    i = i + 1
  }
  print(lo) // 1
}
go()
