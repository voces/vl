// @run
// @log 3
// @log 6
// @log 2
// @log 1
// @log abc
// @log 4
// @log 12000000000
// @log 12
// `m.values()` as a BOUND list, GENERAL over every value kind — a fresh list of the LIVE
// values (insertion order, tombstone-aware). A mono i32 map uses the self-contained
// `mapValsBase` frame; a ref/scalar-valued (mv-slot) map uses a per-slot output backing
// (`mvValsOutBase`) + the mv frame's `valsBk` source + the key-list frame for live/i/j/count.
// `mapValuesResultKind` classifies the result so each `expr*Array` claims it (i32/string/f64/
// i64-list, or a ref list for struct values).

function go() {
  // mono i32 → i32[]
  const m: {[string]: i32} = Map()
  m["a"] = 1
  m["b"] = 2
  m["c"] = 3
  print(m.values().length) // 3
  let s = 0
  for v in m.values() { s = s + v }
  print(s) // 1 + 2 + 3
  m.delete("b")
  print(m.values().length) // 2
  const vs2 = m.values()
  let lo = vs2[0]
  let i = 1
  while i < vs2.length {
    if vs2[i] < lo { lo = vs2[i] }
    i = i + 1
  }
  print(lo) // 1

  // string → string[] (bound, indexed + concatenated)
  const sm: {[string]: string} = Map()
  sm["x"] = "a"
  sm["y"] = "b"
  sm["z"] = "c"
  const sv = sm.values()
  print(sv[0] + sv[1] + sv[2]) // abc

  // f64 → f64[]
  const fm: {[string]: f64} = Map()
  fm["a"] = 1.5
  fm["b"] = 2.5
  let fs = 0.0
  for v in fm.values() { fs = fs + v }
  print(fs + 0.0) // 4

  // i64 → i64[]
  const im: {[string]: i64} = Map()
  im["a"] = 5000000000
  im["b"] = 7000000000
  let it: i64 = 0
  for v in im.values() { it = it + v }
  print(it) // 12000000000

  // struct → ref list (element field access)
  const tm: {[string]: {n: i32}} = Map()
  tm["a"] = { n: 5 }
  tm["b"] = { n: 7 }
  let tt = 0
  for v in tm.values() { tt = tt + v.n }
  print(tt) // 12
}
go()
