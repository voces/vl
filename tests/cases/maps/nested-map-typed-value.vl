// @run
// @log 625.5
// @log 223.5
// A NESTED map whose INNER map carries a TYPED scalar value (`{[string]: {[string]: f64}}`,
// and the same inside a STRUCT field `{f: {[string]: {[string]: f32}}}`) now lowers. The outer
// map's vals ref-list element is the inner map struct: it resolves the inner map's OWN
// per-value struct (`mvMapTypeIdx`), not the mono `$mStructIdx`. A nested-map READ
// (`outer[k] ?? d`) binds the inner map with that same typed slot, so the chained inner read
// (`inner[k] ?? d`) resolves the scalar value. Before, an atom-valued inner map worked (it
// rides the mono struct) but a scalar-valued one emitted invalid wasm. Param and return
// positions.
function useNested(p: {[string]: {[string]: f64}}) {
  const dflt: {[string]: f64} = Map()
  dflt["k"] = 14.5
  const inner = p["k"] ?? dflt
  print(inner["k"] ?? 14.5)
}

function makeFieldNested(): {f: {[string]: {[string]: f32}}} {
  const h0: {[string]: f32} = Map()
  h0["k"] = 223.5
  const h1: {[string]: {[string]: f32}} = Map()
  h1["k"] = h0
  return {f: h1}
}

function go() {
  const inner: {[string]: f64} = Map()
  inner["k"] = 625.5
  const outer: {[string]: {[string]: f64}} = Map()
  outer["k"] = inner
  useNested(outer)

  const v: {f: {[string]: {[string]: f32}}} = makeFieldNested()
  const dflt: {[string]: f32} = Map()
  dflt["k"] = 15.5
  const t0 = v.f["k"] ?? dflt
  print(t0["k"] ?? 15.5)
}

go()
