// @run
// @log 1
// @log 2
// @log -1
// @log 2
// @log 1
// @log 2
// A string‚Üístruct map ‚Äî the compiler's bread-and-butter (a symbol table: name ‚Üí
// symbol record). Struct VALUES are reference entries stored in a nullable-ref
// slot; `m[k]` is `{x} | null`, narrowed with `?.`/`??`. `.values()` yields the
// records in insertion order.
const syms: {[string]: {x: i32}} = Map()
syms["a"] = {x: 1}
syms["b"] = {x: 2}
print(syms["a"]?.x ?? -1)  // 1
print(syms["b"]?.x ?? -1)  // 2
print(syms["z"]?.x ?? -1)  // -1 ‚Äî absent
print(syms.length)           // 2

for rec in syms.values() {
  print(rec.x)             // 1, 2 ‚Äî insertion order
}
