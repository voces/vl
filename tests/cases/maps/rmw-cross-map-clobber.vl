// @run
// @log 6
// @log 5
// @log 1
// @log 1
// @log 6
// @log 5
// @log hit
// @log v
// @log kk
// B-bug-maprmw regression, the CLOBBER family: two SAME-SHAPED maps share one
// scratch frame (the mono frame, or the shape's mv frame), so a map op nested in
// another op's KEY or VALUE expr used to clobber the outer op's parked
// `mapRef`/`keyRef` locals — the outer append then ran against the WRONG map
// (trap or silent corruption), and a key-expr read probed the inner map instead.
// The fix parks the outer receiver + key on the OPERAND STACK (immune to nested
// ops, which only touch locals) and stashes a SET's value before the probe.

// A DIFFERENT same-shaped map read in the RHS, MISSING target key (trapped: the
// append after the RHS eval ran with `mapRef` still pointing at `n`).
const m: {[string]: i32} = Map()
const n: {[string]: i32} = Map()
n["x"] = 5
m["a"] = (n["x"] ?? 0) + 1
print(m["a"] ?? -1) // 6
print(n["x"] ?? -1) // 5 — n untouched
print(m.length)     // 1
print(n.length)     // 1

// Same, PRESENT target key (the overwrite arm always parked its operands on the
// stack — pinned so it stays that way).
m["a"] = (n["x"] ?? 0) + 1
print(m["a"] ?? -1) // 6
print(n["x"] ?? -1) // 5

// A same-shaped map read in the KEY expr of a READ (silently probed `a` instead
// of `b` and printed the default).
const sa: {[string]: string} = Map()
const sb: {[string]: string} = Map()
sa["x"] = "kk"
sb["kk"] = "hit"
print(sb[sa["x"] ?? "d"] ?? "?") // hit

// A same-shaped map read in the KEY expr of a SET (the write was silently lost).
const wa: {[string]: string} = Map()
const wb: {[string]: string} = Map()
wa["x"] = "kk"
wb[wa["x"] ?? "d"] = "v"
print(wb["kk"] ?? "?") // v
print(wa["x"] ?? "?")  // kk — wa untouched
