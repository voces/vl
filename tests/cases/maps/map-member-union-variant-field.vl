// @run
// @log true
// @log 215
// @log ss
// @log 1.5
// @log 2.5
// @log 403874187
// @log bool
// @log 4834127
// @log 14.5
// MAP-MEMBER-UNION fields on union VARIANTS — the "only iN/boolean/string/array
// union-variant fields" R1 bucket, map-union flavor (rep-fuzz
// `p1c/p1r {a: f64, f: {[string]: f32} | string, z: string} | {w: i32}`,
// `p2c/p2r {f: {f: {[string]: i64}} | i32} | boolean`,
// `p2c/p2r {[string]: {a: string, f: {f: i64}, z: f32} | f64}`). The variant's
// map-member-union field pre-registers its union (`registerVariantArmFieldUnions`)
// and codes 16; the DOUBLE narrow (`is` the struct arm, then `is {[string]: f32}` on
// the field) routes the map ops through the arm's value slot — including the WRITE
// and `.has` — with the map scratch reserved narrowing-blind through
// `memberUnionFieldName`'s ident-union probe (a `const t1 = t0.f` binding's map ops
// indexed scratch locals past the frame before it — invalid wasm). The map-VALUE
// union with a nested-struct-carrying arm pins the R1 map-value side of the same
// collection seams. Param / return / map-value positions, every decoy arm exercised.
function useIt(p: {a: f64, f: {[string]: f32} | string, z: string} | {w: i32}): f32 {
  const t0 = p
  if t0 is {a: f64, f: {[string]: f32} | string, z: string} {
    const t1 = t0.f
    if t1 is {[string]: f32} {
      t1["w"] = 9.5
      print(t1.has("k")) // true
      return (t1["k"] ?? 15.5) + (t1["w"] ?? 0.5)
    }
    if t1 is string { print(t1) } // ss
    return 1.5
  }
  return 2.5
}

function makeIt(sel: boolean): {f: {f: {[string]: i64}} | i32} | boolean {
  if sel {
    const h0: {[string]: i64} = Map()
    h0["k"] = 403874187
    return {f: {f: h0}}
  }
  return false
}

function go() {
  const h: {[string]: f32} = Map()
  h["k"] = 205.5
  print(useIt({a: 2.5, f: h, z: "zz"}))    // 215 — map arm: read + write + has
  print(useIt({a: 2.5, f: "ss", z: "zz"})) // ss, then 1.5 — the string arm
  print(useIt({w: 77}))                    // 2.5 — the decoy variant
  const v = makeIt(true)
  const t0 = v
  if t0 is {f: {f: {[string]: i64}} | i32} {
    const t1 = t0.f
    if t1 is {f: {[string]: i64}} {
      print(t1.f["k"] ?? 13131313131) // 403874187 — map field of the union's struct arm
    } else {
      print("no")
    }
  } else {
    print("OTHER")
  }
  if makeIt(false) is boolean { print("bool") } else { print("no") } // bool
  // Map VALUE union whose struct arm carries a nested struct.
  const m: {[string]: {a: string, f: {f: i64}, z: f32} | f64} = Map()
  m["k"] = {a: "dx", f: {f: 4834127}, z: 3.5}
  m["d"] = 14.5
  const e = m["k"] ?? 14.5
  if e is {a: string, f: {f: i64}, z: f32} { print(e.f.f) } else { print("no") } // 4834127
  const e2 = m["d"] ?? 0.5
  if e2 is f64 { print(e2) } else { print("no") } // 14.5
}
go()
