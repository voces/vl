// @run
// @log 5
// @log -1
// @log hi
// @log none
// @log 2.5
// @log 7
// @log 5
// A PARENTHESIZED `??` left-hand side (`(m[k]) ?? d`, `(m.get(k)) ?? d`) lowers identically to the
// bare form — parens must never change `??` semantics. The `??` handler dispatched on the RAW LHS
// node, so a `Paren` wrapper failed the `lhs is Index` / `lhs is Call` checks and fell through to
// "`??` is only supported on a map index get". And the value-type CLASSIFIER (`coalesceMvSlot`) did
// not peel parens either, so even once the emit path was unwrapped a parenthesized STRING/f64/struct
// map-get classified as i32 → `print_i32` on a ref → invalid wasm. Both the emit dispatch and the
// classifier now unwrap the LHS (and the whole expression), so a parenthesized map-get coalesces and
// routes by its real value type. This also unblocks an over-parenthesized nested read
// (`((outer[k] ?? Map())[j]) ?? d`).

type P = { v: i32 }

function go() {
  // i32-valued map — present key and missing-key default.
  const mi: {[string]: i32} = Map()
  mi["a"] = 5
  print((mi["a"]) ?? 0)  // 5
  print((mi["z"]) ?? -1) // -1

  // string-valued map (was invalid wasm parenthesized) — present + missing.
  const ms: {[string]: string} = Map()
  ms["a"] = "hi"
  print((ms["a"]) ?? "none") // hi
  print((ms["z"]) ?? "none") // none

  // f64-valued map.
  const mf: {[string]: f64} = Map()
  mf["a"] = 2.5
  print((mf["a"]) ?? 0.0) // 2.5

  // struct-valued map — the parenthesized coalesce then a field read.
  const mp: {[string]: P} = Map()
  mp["a"] = { v: 7 }
  const p = (mp["a"]) ?? { v: 0 }
  print(p.v) // 7

  // The method form, parenthesized.
  print((mi.get("a")) ?? 0) // 5
}

go()
