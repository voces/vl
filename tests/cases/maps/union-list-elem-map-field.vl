// @run
// @log OTHER
// @log hi
// A UNION-element list whose STRUCT arm carries a MAP field, crossing a PARAM
// boundary (`({a: f64, f: {[string]: string}, z: i64} | string)[]` — rep-fuzz
// `p1c/p1r`). Two seams: the variant's map-field mv slot must intern from the
// variant tables (the union spelling is one TypeRef the map scan never sees), and
// the shared map machinery types must be FORCED even when the variant's map field
// is the program's only map mention (the first call passes only the string arm —
// without the flags the narrowed read rejected "map op but map type not collected").
function useIt(p: ({a: f64, f: {[string]: string}, z: i64} | string)[]) {
  const t0 = p[0]
  if t0 is {a: f64, f: {[string]: string}, z: i64} {
    print(t0.f["k"] ?? "zdmy")
  } else {
    print("OTHER")
  }
}

function go() {
  useIt(["other"])
  const h0: {[string]: string} = Map()
  h0["k"] = "hi"
  useIt([{a: 1.5, f: h0, z: 7}])
}
go()
