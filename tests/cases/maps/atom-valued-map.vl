// @run
// @log aa
// @log bb
// @log bb
// @log bb
// @log bb
// An ATOM-valued map (`{[string]: K}`, `K` a literal union) rides the MONO i32 map: each
// value is the interned atom id, so store / read / overwrite / miss-default are the plain
// i32 machinery with the member literals lowered in atom context (`pendingLitUnion`) —
// NOT the union box (whose ref rep mismatched the i32 vals list: invalid wasm). The map
// KEY stays a string ref even inside an atom-typed binding context. The fused
// `m[k] ?? <member>` read keeps the union type (checker) and IS an atom (emitter), so
// `print` widens it to the member text and an annotated `: K` binding accepts it.
type K0 = "aa" | "bb"

function go() {
  const m: {[string]: K0} = Map()
  m["k"] = "aa"
  print(m["k"] ?? "bb")   // hit → aa
  print(m["zz"] ?? "bb")  // miss → the member-literal default
  m["k"] = "bb"           // overwrite
  print(m["k"] ?? "aa")
  const x: K0 = m["k"] ?? "aa" // annotated atom binding off the fused read
  print(x)
  const y = m["k"] ?? "aa"     // inferred atom binding
  print(y)
}
go()
