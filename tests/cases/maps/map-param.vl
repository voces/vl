// @run
// @log 1
// @log 2
// @log -1
// @log 2
// A string-keyed map can now be PASSED to a function (kind 6, `(ref $mapStruct)`) — previously
// only map LOCALS lowered; a map parameter was rejected ("only i32 … parameters are
// supported"). `vtKindOfType` now classifies a `{[string]: i32}` annotation as the map struct
// ref (via `retMapFlag`), so it crosses the call boundary, and the body's index / `.has` / map
// SET ops resolve the param through the existing `exprMap`/`paramMap` path (shape -1, the mono
// map). A passed map is the SAME object, so a mutation through the param is visible to the
// caller. (Scoped to the mono i32-valued map; a ref/string-valued map param — which must carry
// its per-shape mv slot across the boundary — is still rejected cleanly, a tracked follow-up.)

function lookup(m: {[string]: i32}, k: string) {
  return m[k] ?? -1
}

// Mutating through the param affects the caller's map (same ref).
function put(m: {[string]: i32}, k: string, v: i32) {
  m[k] = v
}

// `.has` on a map param, driven by a string[] param alongside it.
function size(m: {[string]: i32}, keys: string[]) {
  let c = 0
  let i = 0
  while i < keys.length {
    if m.has(keys[i]) { c = c + 1 }
    i = i + 1
  }
  return c
}

const mm: {[string]: i32} = Map()
mm["a"] = 1
put(mm, "b", 2)         // mutate through the param
print(lookup(mm, "a"))  // 1
print(lookup(mm, "b"))  // 2  (the put is visible)
print(lookup(mm, "z"))  // -1 (absent → ?? default)
print(size(mm, ["a", "b", "z"])) // 2  (a, b present; z absent)
