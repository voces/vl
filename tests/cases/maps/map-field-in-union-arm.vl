// @run
// @log 57
// @log 9
// @log true
// @log 6
// @log OTHER
// A MAP-typed field on a UNION'S STRUCT ARM (`{f: {[string]: V}} | i32`) — the R1
// map-in-union-arm seam (rep-fuzz `p0c/p0r {f: {[string]: i32}} | i32`,
// `p2c/p2r {f: {[string]: string}} | i64`). Three seams had to agree:
//   · `shapeFieldElemName` records the code-19 field's VALUE name for a shape-text
//     variant (it answered "" and every op site failed the loud slot find);
//   · `collectA` interns the variant map field's mv slot + forces the map machinery
//     types (the union spelling is ONE TypeRef the map scan never matches);
//   · `mapShapeOfExpr` resolves a NARROWED member receiver (`v.f` after `is`)
//     through the VARIANT field tables (the struct-table miss fell to the mono -1
//     and the typed map ref mismatched its scratch local — invalid wasm), and the
//     frame pre-pass (`unionStructArmMapFieldMember`) reserves the map scratch
//     narrowing-blind.
// Construct + narrow + read + write + `.has`, in local and return positions.

function makeIt(): {f: {[string]: string}} | i64 {
  const h1: {[string]: string} = Map()
  h1["k"] = "6"
  return {f: h1}
}

function go() {
  const h0: {[string]: i32} = Map()
  h0["k"] = 57
  const v: {f: {[string]: i32}} | i32 = {f: h0}
  if v is {f: {[string]: i32}} {
    print(v.f["k"] ?? 0) // 57
    v.f["z"] = 9
    print(v.f["z"] ?? 0) // 9 — SET through the narrowed variant field
    print(v.f.has("k"))  // true
  } else {
    print(-1)
  }
  // A STRING-valued map field on a return-position union arm (a real mv slot).
  const r: {f: {[string]: string}} | i64 = makeIt()
  if r is {f: {[string]: string}} { print(r.f["k"] ?? "zz") } else { print(0) }
  // The i64 arm still narrows.
  const w: {f: {[string]: string}} | i64 = 7
  if w is {f: {[string]: string}} { print(w.f["k"] ?? "zz") } else { print("OTHER") }
}
go()
