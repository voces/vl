// @run
// @log hello
// @log 2
// @log 1.5
// @log 2.5
// @log 6000000000
// A map whose VALUE is a LIST OF MAPS (`{[string]: {[string]: V}[]}` — map -> list ->
// map), for string / f32 / i64 leaves, with overwrite and a param + return boundary
// crossing. The list element's map slot interns recursively (`ensureRefElem`'s
// map-element arm), so the element read classifies as the element map's OWN value rep —
// the shape that once made the compiler trap while classifying, then was gated as a
// loud reject.
function mk(): {[string]: {[string]: string}[]} {
  const s: {[string]: string} = Map()
  s["greet"] = "hello"
  const m: {[string]: {[string]: string}[]} = Map()
  m["a"] = [s]
  return m
}
function use(m: {[string]: {[string]: string}[]}): string {
  const t = m["a"] ?? []
  return t[0]["greet"] ?? "nope"
}
function go() {
  print(use(mk())) // hello — across return + param boundaries

  const a: {[string]: f32} = Map()
  a["x"] = 1.5
  const b: {[string]: f32} = Map()
  b["y"] = 2.5
  const fm: {[string]: {[string]: f32}[]} = Map()
  fm["p"] = [a]
  fm["p"] = [a, b] // overwrite with a longer list
  const t = fm["p"] ?? []
  print(t.length) // 2
  print(t[0]["x"] ?? 0.0) // 1.5
  print(t[1]["y"] ?? 0.0) // 2.5

  const wide: {[string]: i64} = Map()
  wide["v"] = 6000000000
  const im: {[string]: {[string]: i64}[]} = Map()
  im["a"] = [wide]
  const it = im["a"] ?? []
  print(it[0]["v"] ?? 0) // 6000000000 — an i64 leaf under the list-of-maps value
}
go()
