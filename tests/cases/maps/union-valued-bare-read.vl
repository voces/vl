// @run
// @log I64
// @log MISS
// @log hey
// @log STOREDNULL
// @log 7
// @log 42
function go() {
  const m: {[string]: {w: i32} | i64} = Map()
  m["a"] = { w: 5 }
  m["b"] = 9
  const t = m["b"]
  if t != null {
    if t is {w: i32} { print(t.w) } else { print("I64") }
  } else {
    print("NULL")
  }
  const miss = m["zz"]
  if miss == null { print("MISS") } else { print("HIT") }
  const v: {[string]: string | i64} = Map()
  v["k"] = "hey"
  const s = v["k"]
  if s != null {
    if s is string { print(s) } else { print("I64V") }
  } else {
    print("VNULL")
  }
  const n: {[string]: {w: i32} | i64 | null} = Map()
  n["x"] = null
  n["y"] = { w: 7 }
  const nx = n["x"]
  if nx == null { print("STOREDNULL") } else { print("NONNULL") }
  const ny = n["y"]
  if ny != null {
    if ny is {w: i32} { print(ny.w) } else { print("I64N") }
  } else {
    print("NYNULL")
  }
  const w: {[string]: i32 | string} = Map()
  w["q"] = 42
  const wq = w["q"]
  if wq != null {
    if wq is i32 { print(wq) } else { print("STR") }
  } else {
    print("WNULL")
  }
}
go()
