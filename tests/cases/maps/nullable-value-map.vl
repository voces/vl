// @run
// @log 14.5
// @log 14.5
// @log 3.5
// @log 14.5
// @log hi
// @log 1.5
// @log 0.5
// @log 0.5
// @log 2.5
// @log 7
// @log 0
// @log hey
// @log ok
// @log zz
// @log zz
// @log inarm
// @log bd
// @log bd
// @log 2.5
// @log 0.5
// A map whose VALUE is NULLABLE — the nullable ref-VALUE map rep. Shapes:
//   1. a NICHE nullable struct value (`{[string]: {f: f64} | null}`, named `Box | null` too):
//      the vals element is the same `(ref null $S)` slot as the non-null twin; a bare `null`
//      stores `ref.null $S`.
//   2. a NICHE nullable MAP value (`{[string]: {[string]: f64} | null}`) and a NICHE
//      nullable STRING value (`{[string]: string | null}` — also as a struct field in a union
//      arm): the same fold onto the inner rep.
//   3. a BOX union value WITH a null member (`{f: {[string]: f64}} | {w: i32} | null`,
//      `{f: K0[]} | string | null`): `null` boxes as the null-tagged box; `is` discriminates.
// SEMANTICS (USER SEMANTICS RULING 2026-07-23): `m[k] ?? d` coalesces on the read VALUE being
// null — a MISSING key AND a STORED null both take `d` — and a NON-null default types the read
// NON-null (`ref.is_null` / the box null-TAG selects `d`). Only `?? null` leaves it nullable
// (a stored null then passes through, discriminated by `is` / `!= null`).
type Box = { f: string }
function nicheStruct() {
  const m: {[string]: {f: f64} | null} = Map()
  m["k"] = null
  print((m["k"] ?? {f: 14.5}).f)      // STORED null coalesces -> 14.5
  print((m["absent"] ?? {f: 14.5}).f) // missing -> 14.5
  m["k"] = {f: 3.5}
  print((m["k"] ?? {f: 14.5}).f)      // present -> 3.5
  m["k"] = null
  print((m["k"] ?? {f: 14.5}).f)      // stored null -> 14.5
  const nm: {[string]: Box | null} = Map()
  nm["k"] = { f: "hi" }
  print((nm["k"] ?? { f: "d" }).f)    // present -> hi
}
function nicheMap() {
  const inner: {[string]: f64} = Map()
  inner["k"] = 1.5
  const m: {[string]: {[string]: f64} | null} = Map()
  m["a"] = inner
  m["b"] = null
  const d: {[string]: f64} = Map()
  print((m["a"] ?? d)["k"] ?? 0.5) // present inner -> 1.5
  print((m["b"] ?? d)["k"] ?? 0.5) // STORED null coalesces to d -> 0.5
  print((m["absent"] ?? d)["k"] ?? 0.5) // missing -> d -> 0.5
}
type K0 = "aa" | "bb"
function boxUnionWithNull() {
  const h: {[string]: f64} = Map()
  h["k"] = 2.5
  const m: {[string]: {f: {[string]: f64}} | {w: i32} | null} = Map()
  m["a"] = {f: h}
  m["b"] = {w: 7}
  m["c"] = null
  // `?? null` keeps the union nullable — `is` discriminates the non-null arms.
  const t0 = m["a"] ?? null
  if t0 is {f: {[string]: f64}} {
    print(t0.f["k"] ?? 0.5) // -> 2.5
  } else {
    print("OTHER")
  }
  const t1 = m["b"] ?? null
  if t1 is {w: i32} {
    print(t1.w) // -> 7
  } else {
    print("OTHER")
  }
  // `?? {w:0}` (non-null) coalesces a STORED null to the NON-null default union box.
  const t2 = m["c"] ?? {w: 0}
  if t2 is {w: i32} {
    print(t2.w) // stored null -> {w:0} -> 0
  } else {
    print("OTHER")
  }
  const sm: {[string]: {f: K0[]} | string | null} = Map()
  sm["k"] = "hey"
  const sv = sm["k"] ?? "d"
  if sv is string { print(sv) } // present -> hey
}
type K1 = "bd" | "06"
function boxUnionAtomArrayDefault() {
  // A stored null + an ATOM-ARRAY-field struct DEFAULT (`?? {f: ["bd"]}`): the default's variant
  // payload builds the i32 atom list. A stored null now COALESCES to the default and discriminates.
  const m: {[string]: {f: K1[]} | string | null} = Map()
  m["k"] = null
  const t0 = m["k"] ?? {f: ["bd"]}
  if t0 is {f: K1[]} {
    print(t0.f[0]) // stored null -> {f:["bd"]} -> bd
  } else {
    print("OTHER")
  }
  const t1 = m["absent"] ?? {f: ["bd"]}
  if t1 is {f: K1[]} {
    print(t1.f[0]) // missing -> {f:["bd"]} -> bd
  } else {
    print("OTHER")
  }
}
function nicheString() {
  const m: {[string]: string | null} = Map()
  m["x"] = "ok"
  m["y"] = null
  print(m["x"] ?? "zz")      // present -> ok
  print(m["absent"] ?? "zz") // missing -> zz
  print(m["y"] ?? "zz")      // STORED null coalesces -> zz
  const h: {[string]: string | null} = Map()
  h["k"] = "inarm"
  const v: {f: {[string]: string | null}} | i32 = {f: h}
  if v is {f: {[string]: string | null}} {
    print(v.f["k"] ?? "zz") // present -> inarm
  } else {
    print("OTHER")
  }
}
function nicheStructF32Field() {
  // The store literal's f32 field coerces through the DOUBLE nullable (`(S | null)?`).
  const m: {[string]: {a: i32, f: i32, z: f32} | null} = Map()
  m["k"] = {a: 1, f: 2, z: 2.5}
  print((m["k"] ?? {a: 0, f: 0, z: 0.5}).z) // present -> 2.5
  m["k"] = null
  print((m["k"] ?? {a: 0, f: 0, z: 0.5}).z) // STORED null coalesces -> 0.5
}
function go() {
  nicheStruct()
  nicheMap()
  boxUnionWithNull()
  nicheString()
  boxUnionAtomArrayDefault()
  nicheStructF32Field()
}
go()
