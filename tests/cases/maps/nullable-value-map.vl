// @run
// @log NULL
// @log 14.5
// @log 3.5
// @log NULL
// @log hi
// @log 1.5
// @log NULL
// @log 0.5
// @log 2.5
// @log 7
// @log NULL
// @log hey
// @log ok
// @log zz
// @log NULL
// @log inarm
// @log NULL
// @log bd
// @log 2.5
// @log NULL
// A map whose VALUE is NULLABLE — the nullable ref-VALUE map rep. Three shapes:
//   1. a NICHE nullable struct value (`{[string]: {f: f64} | null}`, named `Box | null` too):
//      the vals element is the same `(ref null $S)` slot as the non-null twin (shared mv rep +
//      heap dedup through `nulRefMapValInnerOf`); a bare `null` stores `ref.null $S`.
//   2. a NICHE nullable MAP value (`{[string]: {[string]: f64} | null}`) and a NICHE
//      nullable STRING value (`{[string]: string | null}` — also as a struct field inside a
//      union arm): the same fold onto the inner rep.
//   3. a BOX union value WITH a null member (`{f: {[string]: f64}} | {w: i32} | null`,
//      `{f: K0[]} | string | null`): `null` boxes as the null-tagged box (the vals element
//      itself is never null), `is` discriminates the non-null members.
// SEMANTICS (the corpus oracle's): the fused `m[k] ?? d` read PRESERVES a stored null — the
// default fires only on a MISSING key — so the niche read binds `S | null` / `map | null`
// (kind `nulstruct` / `nulmap`) and narrows with `!= null`.
type Box = { f: string }
function nicheStruct() {
  const m: {[string]: {f: f64} | null} = Map()
  m["k"] = null
  const t0 = m["k"] ?? {f: 14.5}
  if t0 != null {
    print(t0.f)
  } else {
    print("NULL")
  }
  const t1 = m["absent"] ?? {f: 14.5}
  if t1 != null {
    print(t1.f)
  } else {
    print("NULL")
  }
  m["k"] = {f: 3.5}
  const t2 = m["k"] ?? {f: 14.5}
  if t2 != null {
    print(t2.f)
  } else {
    print("NULL")
  }
  m["k"] = null
  const t3 = m["k"] ?? {f: 14.5}
  if t3 != null {
    print(t3.f)
  } else {
    print("NULL")
  }
  const nm: {[string]: Box | null} = Map()
  nm["k"] = { f: "hi" }
  const v = nm["k"] ?? { f: "d" }
  if v != null { print(v.f) }
}
function nicheMap() {
  const inner: {[string]: f64} = Map()
  inner["k"] = 1.5
  const m: {[string]: {[string]: f64} | null} = Map()
  m["a"] = inner
  m["b"] = null
  const d: {[string]: f64} = Map()
  const t0 = m["a"] ?? d
  if t0 != null {
    print(t0["k"] ?? 0.5)
  } else {
    print("NULL")
  }
  const t1 = m["b"] ?? d
  if t1 != null {
    print(t1["k"] ?? 0.5)
  } else {
    print("NULL")
  }
  const t2 = m["absent"] ?? d
  if t2 != null {
    print(t2["k"] ?? 0.5)
  } else {
    print("NULL")
  }
}
type K0 = "aa" | "bb"
function boxUnionWithNull() {
  const h: {[string]: f64} = Map()
  h["k"] = 2.5
  const m: {[string]: {f: {[string]: f64}} | {w: i32} | null} = Map()
  m["a"] = {f: h}
  m["b"] = {w: 7}
  m["c"] = null
  const t0 = m["a"] ?? null
  if t0 is {f: {[string]: f64}} {
    print(t0.f["k"] ?? 0.5)
  } else {
    print("OTHER")
  }
  const t1 = m["b"] ?? null
  if t1 is {w: i32} {
    print(t1.w)
  } else {
    print("OTHER")
  }
  const t2 = m["c"] ?? {w: 0}
  if t2 is {w: i32} {
    print(t2.w)
  } else if t2 == null {
    print("NULL")
  } else {
    print("OTHER")
  }
  const sm: {[string]: {f: K0[]} | string | null} = Map()
  sm["k"] = "hey"
  const sv = sm["k"] ?? "d"
  if sv is string { print(sv) }
}
type K1 = "bd" | "06"
function boxUnionAtomArrayDefault() {
  // A stored null + an ATOM-ARRAY-field struct DEFAULT (`?? {f: ["bd"]}`): the default's
  // variant payload builds the i32 atom list (`variantFieldIsLitUnionArray` — without the
  // atom seed the literal built a string list into the `$lTypeIdx` field: invalid wasm,
  // even though a HIT never runs the default). The miss path builds + discriminates it.
  const m: {[string]: {f: K1[]} | string | null} = Map()
  m["k"] = null
  const t0 = m["k"] ?? {f: ["bd"]}
  if t0 != null {
    if t0 is {f: K1[]} {
      print(t0.f[0])
    } else {
      print("OTHER")
    }
  } else {
    print("NULL")
  }
  const t1 = m["absent"] ?? {f: ["bd"]}
  if t1 != null {
    if t1 is {f: K1[]} {
      print(t1.f[0])
    } else {
      print("OTHER")
    }
  } else {
    print("NULL")
  }
}
function nicheString() {
  const m: {[string]: string | null} = Map()
  m["x"] = "ok"
  m["y"] = null
  const t0 = m["x"] ?? "zz"
  if t0 != null {
    print(t0)
  } else {
    print("NULL")
  }
  const t1 = m["absent"] ?? "zz"
  if t1 != null {
    print(t1)
  } else {
    print("NULL")
  }
  const t2 = m["y"] ?? "zz"
  if t2 != null {
    print(t2)
  } else {
    print("NULL")
  }
  const h: {[string]: string | null} = Map()
  h["k"] = "inarm"
  const v: {f: {[string]: string | null}} | i32 = {f: h}
  if v is {f: {[string]: string | null}} {
    const t3 = v.f["k"] ?? "zz"
    if t3 != null { print(t3) } else { print("NULL") }
  } else {
    print("OTHER")
  }
}
function nicheStructF32Field() {
  // The store literal's f32 field coerces through the DOUBLE nullable (`(S | null)?` — the
  // stored V? over the nullable value): the ObjLit/ArrayLit nullable peel ITERATES.
  const m: {[string]: {a: i32, f: i32, z: f32} | null} = Map()
  m["k"] = {a: 1, f: 2, z: 2.5}
  const t0 = m["k"] ?? {a: 0, f: 0, z: 0.5}
  if t0 != null {
    print(t0.z)
  } else {
    print("NULL")
  }
  m["k"] = null
  const t1 = m["k"] ?? {a: 0, f: 0, z: 0.5}
  if t1 != null {
    print(t1.z)
  } else {
    print("NULL")
  }
}
function go() {
  nicheStruct()
  nicheMap()
  boxUnionWithNull()
  nicheString()
  boxUnionAtomArrayDefault()
  nicheStructF32Field()
}
go()
