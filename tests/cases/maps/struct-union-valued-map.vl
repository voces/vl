// @run
// @log 70
// @log 4
// @log 7
// @log 4
// @log 40
// @log 0
// A STRUCT / heterogeneous union as a MAP VALUE (`{[string]: C | S}`). Value-union maps
// (`{[string]: i32 | string}`) already worked; a struct-union value fell through
// `mvShapeOfValName` to the struct branch and was rejected ("unsupported map value type").
// A union value is the SAME shared `{tag, payload}` box (`uBoxIdx`, element kind 2) as a
// value-union value — only the payload differs (a variant struct vs a scalar value box) — so
// `mvShapeOfValName` now classifies ANY union value name (value / struct / heterogeneous /
// alias, via `unionMemberCount(unionMemberSetOf(...)) > 1`) as kind 2. A stored value boxes
// through `emitUnionBoxArg`, so a concrete VARIANT value (`m[k] = s`) widens like a call arg.

type C = { kind: i32, r: i32 }
type S = { kind: i32, side: i32 }
type Shape = C | S

function area(sh: Shape): i32 {
  if sh is C { return sh.r * 10 } else { return sh.side }
}

function go() {
  const m: {[string]: Shape} = Map()

  // store a struct LITERAL of each variant.
  m["c"] = { kind: 0, r: 7 }
  m["s"] = { kind: 1, side: 4 }

  // read via `?? default` and dispatch through the union.
  const gc = m["c"] ?? { kind: 0, r: 0 }
  print(area(gc)) // C → 70
  const gs = m["s"] ?? { kind: 0, r: 0 }
  print(area(gs)) // S → 4

  // read + narrow each variant directly.
  const gc2 = m["c"] ?? { kind: 0, r: 0 }
  if gc2 is C { print(gc2.r) } else { print(99) } // 7
  const gs2 = m["s"] ?? { kind: 0, r: 0 }
  if gs2 is S { print(gs2.side) } else { print(88) } // 4

  // store a concrete VARIANT VALUE (not a literal) — boxes at the store.
  const v: C = { kind: 0, r: 4 }
  m["c"] = v
  const gc3 = m["c"] ?? { kind: 0, r: 0 }
  print(area(gc3)) // C → 40

  // a MISS falls to the boxed default.
  const miss = m["z"] ?? { kind: 1, side: 0 }
  print(area(miss)) // S{side:0} → 0
}
go()
