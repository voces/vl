// @run
// @log 55
// @log 4
// @log 99
// @log 6
// @log 77
// @log 4
// Eval-order list-store family through MAP receivers, plus the map-SET
// neighbors of the same family (pinned — #918's value-before-probe lowering
// already sequences them correctly).

// A list stored as a MAP VALUE: the store's receiver expr is a map read; the
// RHS pushes onto the SAME wrapper past its cap. The stale-backing lowering
// silently printed 1 pre-fix.
const m: {[string]: i32[]} = Map()
m["k"] = [1, 2]
function f(): i32 {
  const xs = m["k"] ?? []
  xs.push(3)
  xs.push(4)
  55
}
(m["k"] ?? [])[0] = f()
print((m["k"] ?? [])[0])      // 55
print((m["k"] ?? []).length)  // 4

// Map SET whose RHS inserts other keys into the SAME map (growth + rehash
// between the receiver eval and the store) — correct since #918, pinned.
const g: {[string]: i32} = Map()
function fg(): i32 {
  g["a"] = 1
  g["b"] = 2
  g["c"] = 3
  g["d"] = 4
  g["e"] = 5
  99
}
g["k"] = fg()
print(g["k"] ?? -1) // 99
print(g.length)     // 6

// Struct-FIELD map receiver, RHS inserts into the same map — pinned.
type S = { m: {[string]: i32} }
const s: S = { m: Map() }
function fs(): i32 {
  s.m["a"] = 1
  s.m["b"] = 2
  s.m["c"] = 3
  77
}
s.m["k"] = fs()
print(s.m["k"] ?? -1) // 77
print(s.m.length)     // 4
