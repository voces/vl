// @run
// @log stored-true
// @log stored-null
// @log missing
// @log lit-aa
// @log lit-null
// @log lit-missing
// @log param-true
// @log param-missing
// @log global-bb

// BARE map READ (`const b = m[k]`, no `??`) then a `!= null` NARROW of a MONO-NICHE nullable
// value map — `boolean | null` (sentinel `2`) and `K | null` (sentinel `-1`). Before the fix
// the bare read was not classified as the niche, so the `!= null` compare emitted a bare
// `null` and loud-rejected ("bare null needs a struct-typed context"); a missing key also read
// back as the `0` empty value (a false NON-null) instead of null. Distinguishing: on clean
// #1037 this file loud-rejects at the first narrow; passes here. Covers local / param / global
// receiver spellings.

type K = "aa" | "bb"

// boolean | null — MONO i32 niche, null sentinel 2.
function boolFam() {
  const m: {[string]: boolean | null} = Map()
  m["a"] = true
  m["b"] = null
  const b = m["a"] // bare read, stored true
  if b != null {
    if b { print("stored-true") } else { print("stored-false") }
  } else {
    print("was-null")
  }
  const b2 = m["b"] // bare read, stored null
  if b2 != null { print("stored-notnull") } else { print("stored-null") }
  const b3 = m["z"] // bare read, missing key -> null
  if b3 != null { print("present") } else { print("missing") }
}
boolFam()

// litunion K | null — MONO i32 niche, null sentinel -1.
function litFam() {
  const m: {[string]: K | null} = Map()
  m["a"] = "aa"
  m["b"] = null
  const t = m["a"] // bare read, stored member
  if t != null { print("lit-" + t) } else { print("lit-was-null") }
  const t2 = m["b"] // bare read, stored null
  if t2 != null { print("lit-notnull") } else { print("lit-null") }
  const t3 = m["z"] // bare read, missing key -> null
  if t3 != null { print("lit-present") } else { print("lit-missing") }
}
litFam()

// param receiver.
function useParam(m: {[string]: boolean | null}) {
  const b = m["x"]
  if b != null {
    if b { print("param-true") } else { print("param-false") }
  } else {
    print("param-missing")
  }
}
function paramFam() {
  const m: {[string]: boolean | null} = Map()
  m["x"] = true
  useParam(m)
  const m2: {[string]: boolean | null} = Map()
  useParam(m2) // missing
}
paramFam()

// global receiver.
const g: {[string]: K | null} = Map()
function globalFam() {
  g["x"] = "bb"
  const t = g["x"]
  if t != null { print("global-" + t) } else { print("global-none") }
}
globalFam()
