// @run
// @log xdrz
// @log OTHER
// @warning Unused parameter `q0`
// @warning Unused parameter `q1`
// @warning Unused parameter `q3`
// @warning Unused parameter `q4`
// A map VALUE that is a CLOSURE returning a MAP-MEMBER union
// (`{[string]: (i32) => {[string]: K0} | string}` — rep-fuzz `p2r`): the map-value
// closure result is `{[string]: K0} | string`, a union whose map arm's VALUE is a
// litunion (`K0`). The union registers through the checker's RENDERED spelling
// (`{[string]: string}` — a litunion map value widens to `string`), so its interned
// arm is the STRING-map slot while the constructed value folds to the MONO i32 map
// (each litunion atom IS its interned id). `emitUnionCoerce`'s map-carrier arm now
// boxes such a mono litunion-valued map under the MONO tag (`mapSlotTag(-1)`) when
// the union carries a collapsed string-map arm (`unionHasCollapsedStringMapArm`) —
// the SAME tag an `is {[string]: K0}` narrow derives from its own (litunion → mono)
// spelling, so store and narrow resolve one tag. The read chains map get → value
// call → union narrow → (map arm) fused get, both arms.
function makeIt(): {[string]: (i32) => {[string]: K0} | string} {
  const inner: {[string]: K0} = Map()
  inner["k"] = "xdrz"
  const h1: {[string]: (i32) => {[string]: K0} | string} = Map()
  h1["mapArm"] = (q0) => (inner)
  h1["strArm"] = (q1) => ("other")
  return h1
}
type K0 = "60" | "xdrz" | "phtx"
function go() {
  const v = makeIt()
  const dummyInner: {[string]: K0} = Map()
  dummyInner["k"] = "60"
  const cm = v["mapArm"] ?? (q3) => (dummyInner)
  const rm = cm(1)
  if (rm is {[string]: K0}) { print(rm["k"] ?? "60") } else { print("OTHER") }
  const cs = v["strArm"] ?? (q4) => (dummyInner)
  const rs = cs(1)
  if (rs is {[string]: K0}) { print(rs["k"] ?? "60") } else { print("OTHER") }
}
go()
