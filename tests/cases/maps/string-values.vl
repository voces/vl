// @run
// @log hello
// @log world
// @log missing
// @log 2
// @log one
// @log two
// A stringâ†’string map (reference VALUES): the entry value array stores nullable
// string refs (so the hash slots default-init); `m[k]` returns `string | null`
// (defaulted with `??`), and ordered `.values()` yields the strings in insertion
// order.
const m: {[string]: string} = Map()
m["greeting"] = "hello"
m["place"] = "world"
print(m["greeting"] ?? "missing")  // hello
print(m["place"] ?? "missing")     // world
print(m["absent"] ?? "missing")    // missing
print(m.length)                      // 2

const nums: {[string]: string} = Map()
nums["a"] = "one"
nums["b"] = "two"
for v in nums.values() {
  print(v)                         // one, two â€” insertion order
}
