// @run
// @log 0
// @log 5
// REGRESSION (B6a, BUG 2): inserting then deleting 200 DISTINCT keys must keep
// memory bounded. The old `delete` only tombstoned (never reclaimed entries), so
// `count` and the keys/vals/live arrays grew forever. Amortized compaction
// rebuilds from the live entries when dead entries exceed the threshold, so
// `count` stays small and this neither traps nor leaks. After the churn the map
// is empty; a fresh batch of live keys still works (compaction kept it correct).
let alpha = "abcdefghijklmnopqrstuvwxyz"
let m: {[string]: i32} = Map()
let i = 0
while i < 200 {
  // 200 distinct two-letter keys: "aa", "ab", … (alpha[i/26] + alpha[i%26]).
  let key = alpha.slice(i / 26, i / 26 + 1) + alpha.slice(i % 26, i % 26 + 1)
  m[key] = i
  m.delete(key)
  i = i + 1
}
print(m.size)            // 0 — no trap, memory bounded

// Re-use after the churn: live keys still insert/read correctly.
m["one"] = 1
m["two"] = 2
m["three"] = 3
m["four"] = 4
m["five"] = 5
print(m.size)            // 5
