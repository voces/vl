// @run
// @log lvnr
// @log zdmy
// @log lvnr
// @log zdmy
// REGRESSION (was `emit: `??` is only supported on a map index get`): a `??` over a map
// index-get whose RECEIVER is a CLOSURE-CALL result (`v()["k"] ?? d`) — the map is not a
// directly-recognizable local but the value a nullary closure returns. `exprMap` /
// `mapShapeOfExpr` now resolve map-ness + the value-kind shape from the checker's recorded
// type (the map dual of `structIndexOfExpr`'s `nodeTyIsObj` struct fallback), so both the
// bracket form and the `.get(k)` method form lower for a `string`-valued returned map, hit
// (recover the stored value) and miss (the default).
function makeIt(): () => {[string]: string} {
  const h0: {[string]: string} = Map()
  h0["k"] = "lvnr"
  return () => (h0)
}
function go() {
  const v: () => {[string]: string} = makeIt()
  print(v()["k"] ?? "zdmy")     // hit
  print(v()["nope"] ?? "zdmy")  // miss → default
  print(v().get("k") ?? "zdmy") // method form, hit
  print(v().get("x") ?? "zdmy") // method form, miss
}
go()
