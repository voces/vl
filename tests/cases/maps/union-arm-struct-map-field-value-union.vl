// Regression: a variant-BOX union (`{f: {[string]: f32 | string | {q: i64}}} | f64`)
// whose STRUCT arm has a bare-MAP field carrying its own value union. `collectU`'s
// `registerVariantArmFieldUnions` descended single-shape and array fields but NOT a
// bare-map field's value union — so `f32|string|{q:i64}` never registered, its scalar
// arm never marked its value box (`vbF32Used` stayed false), and BOTH the `?? 15.5`
// default's boxing and the narrowed `is f32` read in the (compiled) struct branch minted
// the box at the DEFAULT type index — INVALID-WASM at emit ("expected i64, found f32"),
// which V8/wasmtime reject before the module runs (fuzz post-#1001 sweep branching leg).
// The union appears ONLY as this param's annotation: any standalone typed construction of
// the map would register the value union through the working `registerShapeFieldUnions` /
// bare-map paths and mask the bug — so the read stays a compiled-but-not-executed branch,
// exactly as the fuzz draw took only the f64 arm. The variant-arm-field twin of the #991
// map-atom-value walk.
// @run
// @log F64
function useIt(p: {f: {[string]: f32 | string | {q: i64}}} | f64) {
  const t0 = p
  if t0 is {f: {[string]: f32 | string | {q: i64}}} {
    const t1 = t0.f["k"] ?? 15.5
    if t1 is f32 { print(t1) } else { print("NOTF32") }
    const t2 = t0.f["s"] ?? 15.5
    if t2 is string { print(t2) } else { print("NOTSTR") }
    const t3 = t0.f["q"] ?? 15.5
    if t3 is {q: i64} { print(t3.q) } else { print("NOTQ") }
  } else {
    print("F64")
  }
}
function go() { useIt(9.25) }
go()
