// @run
// @log 15.5
// @log 46
// @log 14.5
// @log 2.5
// @log r
// @log 9.5

// A nullable STRUCT-valued map `{[string]: {f: {a: K0[], f: f32 | null, z: {[string]: f64}}} | null}`
// whose struct nests a litunion array (K0[]), an f32|null niche field, and a map-of-f64 field.
// Read the buried value back via `?? <same-shape dummy>` then descend the three inner fields. The
// compiler must print exactly one line per read — this is the entombed program from a --multiobs
// fuzz draw (seed 292955391) that surfaced a FUZZGEN oracle/generator drift (moLogLines counted a
// nested decoy map's second entry that emitRead never reads); the compiler output was correct.
type K0 = "46" | "dvxdx" | "r"

// STORED-null path: `v["k"]` is null, so `??` coalesces to the dummy and the reads see the dummy.
function storedNull() {
  const v: {[string]: {f: {a: K0[], f: f32 | null, z: {[string]: f64}}} | null} = Map()
  v["k"] = null
  const h1: {[string]: f64} = Map()
  h1["k"] = 14.5
  const t0 = v["k"] ?? {f: {a: ["46"], f: 15.5, z: h1}}
  const t1 = t0.f.f
  if t1 != null {
    print(t1) // f32 non-null -> 15.5
  } else {
    print("NULL")
  }
  print(t0.f.a[0]) // K0[] first element -> 46
  print(t0.f.z["k"] ?? 14.5) // map-of-f64 read -> 14.5
}
storedNull()

// PRESENT-value path: a real struct is stored, so `??` keeps the carrier and the reads see it.
function presentValue() {
  const v: {[string]: {f: {a: K0[], f: f32 | null, z: {[string]: f64}}} | null} = Map()
  const h2: {[string]: f64} = Map()
  h2["k"] = 9.5
  v["k"] = {f: {a: ["r", "46"], f: 2.5, z: h2}}
  const t0 = v["k"] ?? {f: {a: ["dvxdx"], f: null, z: h2}}
  const t1 = t0.f.f
  if t1 != null {
    print(t1) // f32 non-null -> 2.5
  } else {
    print("NULL")
  }
  print(t0.f.a[0]) // K0[] first element -> r
  print(t0.f.z["k"] ?? 14.5) // map-of-f64 read -> 9.5
}
presentValue()
