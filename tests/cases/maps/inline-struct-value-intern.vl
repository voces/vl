// @run
// @log 2585.5
// @log 7
// @log 42
// An INLINE struct shape used as a MAP VALUE now interns from the map annotation, so a
// value struct whose field the store literal cannot self-classify (an f32 field written
// from a variable, a nested-map field written from a bound map) lowers. Before, only a
// map value whose struct shape happened to be collected from its STORE LITERAL worked
// (an i64/f64/string field), while an inline `{f: f32}` / `{f: {[string]: i64}}` value
// failed "unsupported map value type" — the whole map is ONE TypeRef name, so the value's
// inline shape was unreachable to `internInlineShape`. `internShapeDeep` now descends into
// a map value (the #837 position-independent template), the inline dual of the named-alias
// value (`type S = {f: f32}`) which already interned via its own TypeRef.
function readF32(p: {[string]: {f: f32}}) {
  const v: f32 = 15.5
  print((p["k"] ?? {f: v}).f)
}

// A struct value whose FIELD is itself a nested map (`{f: {[string]: i64}}`): the outer
// map value struct interns, and its code-19 map field interns the inner value slot.
function readNestedMapField(p: {[string]: {f: {[string]: i64}}}) {
  const inner: {[string]: i64} = Map()
  inner["a"] = 0
  print((p["k"] ?? {f: inner}).f["a"] ?? 0)
}

function go() {
  const vf: f32 = 2585.5
  const h0: {[string]: {f: f32}} = Map()
  h0["k"] = {f: vf}
  readF32(h0)

  const inner: {[string]: i64} = Map()
  inner["a"] = 7
  const h1: {[string]: {f: {[string]: i64}}} = Map()
  h1["k"] = {f: inner}
  readNestedMapField(h1)

  // A struct value with a nested-map field read in-place (not via a param).
  const h2: {[string]: {f: {[string]: i64}}} = Map()
  const inner2: {[string]: i64} = Map()
  inner2["a"] = 42
  h2["k"] = {f: inner2}
  print((h2["k"] ?? {f: inner2}).f["a"] ?? 0)
}

go()
