// Regression: a MAP ARM of a 2+-member union whose VALUE is itself a union with a
// scalar arm (`{[string]: f64 | {w: i32}} | i64`). `registerInlineUnion`'s atom walk
// registered a ref-ARRAY atom's element union but not a MAP atom's VALUE union — the
// value union's scalar arms never marked their value boxes (`vbF64Used` stayed false),
// so BOTH the `?? 14.5` default's boxing and the narrowed `is f64` read minted the box
// at the DEFAULT type index (the i32 box): INVALID-WASM (fuzz post-#990 sweep plain
// leg, seed 75710791 case_00323). The walk now recurses into map atoms' value names,
// the map-value sibling of the #983 ref-array atom registration.
// @run
// @log I64
// @log 99.25
// @log 42
// @log 14.5
function useIt(p: {[string]: f64 | {w: i32}} | i64) {
  const t0 = p
  if t0 is {[string]: f64 | {w: i32}} {
    const t1 = t0["k"] ?? 14.5
    if ((t1 is f64)) { print(t1) } else { print("NOTF64") }
    const t2 = t0["s"] ?? 14.5
    if (t2 is {w: i32}) { print(t2.w) } else { print("NOTW") }
    const t3 = t0["missing"] ?? 14.5
    if ((t3 is f64)) { print(t3) } else { print("DOTHER") }
  } else {
    print("I64")
  }
}
function go() {
  useIt(5000000077)
  const h: {[string]: f64 | {w: i32}} = Map()
  h["k"] = 99.25
  h["s"] = { w: 42 }
  useIt(h)
}
go()
