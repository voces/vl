// @emit-error unsupported map value type
// A map whose VALUE is a NULLABLE nested map (`{[string]: f64} | null`) — a nullable ref
// composite the value box cannot carry. Loud emit reject, never invalid wasm.
function go() {
  const inner: {[string]: f64} = Map()
  inner["k"] = 1.5
  const m: {[string]: {[string]: f64} | null} = Map()
  m["k"] = inner
  print(0)
}
go()
