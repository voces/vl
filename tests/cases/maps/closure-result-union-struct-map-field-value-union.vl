// Regression: a CLOSURE-result variant-box union (`(i32,i32,i32) => {a: {[string]:
// f32 | {w: i32} | string}, f: boolean, z: f64} | i32`) whose STRUCT arm has a bare-MAP
// field carrying its own value union. The fn-type registration peels to the result
// union and `registerVariantArmFieldUnions` walks the struct arm's fields — but it
// descended single-shape and array fields, NOT a bare-map field's value union, so
// `f32|{w:i32}|string` never registered, its scalar arm never marked its value box
// (`vbF32Used` stayed false), and BOTH the `?? 15.5` default's boxing and the narrowed
// `is f32` read in the (compiled) struct branch minted the box at the DEFAULT type index
// — INVALID-WASM at emit, so V8/wasmtime reject the module before it runs (fuzz post-#1001
// sweep multiobs leg). The closure-result entry twin of the branching-leg pin (which
// exercises the f32/string/{q:i64} reads at runtime via a param-delivered union).
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// @hint Intentionally-unused parameter `_q2`
// @run
// @log OTHER
// @log 88
function go() {
  const v: (i32, i32, i32) => {a: {[string]: f32 | {w: i32} | string}, f: boolean, z: f64} | i32 = (_q0, _q1, _q2) => (77)
  const t0 = v(1, 1, 1)
  if t0 is {a: {[string]: f32 | {w: i32} | string}, f: boolean, z: f64} {
    print(t0.f)
    const t1 = t0.a["k"] ?? 15.5
    if t1 is f32 { print(t1) } else { print("NOTF32") }
    const t2 = t0.a["w"] ?? 15.5
    if t2 is {w: i32} { print(t2.w) } else { print("NOTW") }
    const t3 = t0.a["s"] ?? 15.5
    if t3 is string { print(t3) } else { print("NOTSTR") }
    print(t0.z)
  } else {
    print("OTHER")
  }
  const u2: {a: {[string]: f32 | {w: i32} | string}, f: boolean, z: f64} | i32 = 88
  if u2 is i32 { print(u2) } else { print("UOTHER") }
}
go()
