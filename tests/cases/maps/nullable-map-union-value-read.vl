// @run
// @log NULL
// @log 3.5
// @log 7
// A NULLABLE map whose VALUE is a map-member union
// (`{[string]: {[string]: f64} | i32} | null`). The `| null` niche is owned by the
// nullable-map machinery, but the VALUE union slipped every `registerInlineUnion`
// recursion arm — un-registered, the narrowed `t0[k] ?? d` coalesce boxed the
// default into an UN-MINTED `uBoxIdx` (type index 0, the i32 array) — INVALID-WASM
// (fuzz-nightly seed 796355240 d4). `registerInlineUnion` now recurses on a
// nullable BARE map's value name (the nullable twin of the bare-map value
// recursion), so the box mints and both arms read back.
function onlyNull(g: {[string]: {[string]: f64} | i32} | null) {
  const t0 = g
  if t0 != null {
    const h1: {[string]: f64} = Map()
    h1["k"] = 14.5
    const t1 = t0["k"] ?? h1
    const t2 = t1
    if t2 is {[string]: f64} { print(t2["k"] ?? 14.5) } else { print("OTHER") }
  } else {
    print("NULL")
  }
}
function go() {
  onlyNull(null)
  const m: {[string]: {[string]: f64} | i32} = Map()
  const hv: {[string]: f64} = Map()
  hv["x"] = 3.5
  m["k"] = hv
  m["n"] = 7
  const g: {[string]: {[string]: f64} | i32} | null = m
  const t0 = g
  if t0 != null {
    const h1: {[string]: f64} = Map()
    const t1 = t0["k"] ?? h1
    const t2 = t1
    if t2 is {[string]: f64} { print(t2["x"] ?? 0.5) } else { print("OTHER") }
    const u1 = t0["n"] ?? h1
    const u2 = u1
    if u2 is i32 { print(u2) } else { print("OTHER") }
  } else {
    print("NULL")
  }
}
go()
