// @run
// @log 100
// @log -1
// @log 2.5
// @log 9
// @log inner
// The `nulmap` niche is value-kind agnostic — the `(ref null $mapStruct)` cell is the SAME
// heap type regardless of the map's VALUE kind (only the vals-list element differs). So the
// distinct-rep value kinds cross the nullable-map boundary too: an i64 / f64 SCALAR value
// (scalar valStash), and a NESTED-map value (a ref-list of inner map structs).

function useI64(p: {[string]: i64} | null): i64 {
  if p != null { return p["k"] ?? 0 }
  return -1
}

function useF64(p: {[string]: f64} | null): f64 {
  if p != null { return p["k"] ?? 0.0 }
  return -1.0
}

function useNested(p: {[string]: {[string]: string}} | null) {
  if p != null {
    const inner = p["a"] ?? Map()
    print(inner["b"] ?? "miss")
  } else {
    print("NULL")
  }
}

function go() {
  const a: {[string]: i64} = Map()
  a["k"] = 100
  print(useI64(a)) // 100
  print(useI64(null)) // -1
  const b: {[string]: f64} = Map()
  b["k"] = 2.5
  print(useF64(b)) // 2.5
  // an i64 map holding 9, read through the nullable boundary.
  const c: {[string]: i64} = Map()
  c["k"] = 9
  print(useI64(c)) // 9
  const n: {[string]: {[string]: string}} = Map()
  const inner: {[string]: string} = Map()
  inner["b"] = "inner"
  n["a"] = inner
  useNested(n) // inner
}

go()
