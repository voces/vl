// @run
// @log 99
// @log 42
// @log 7
// @log DEF
// @log hi
// @log aa
// @log bb
// @log true
// @log false
// @log 9
// @log 5
// @log 8
// @log 100
// @log 2.5
// @log 7
// @log STR
// @log 42
// @log NULL
// @log 5

// USER SEMANTICS RULING (2026-07-23): `a ?? d` coalesces whenever `a` evaluates to null —
// including a STORED null in a nullable-VALUED map (`{[string]: V | null}`). `(m[k] ?? d)` is `d`
// when `m[k]` is null for ANY reason (missing key OR stored null), and it types NON-null when `d`
// is non-null. Only `?? null` (a nullable default) leaves the result `V | null`.

// STRUCT value: the ruling's canonical case — `(m[k] ?? {f:99}).f == 99` on a stored null.
function structVal() {
  const m: {[string]: {f: i64} | null} = Map()
  m["k"] = null
  print((m["k"] ?? {f: 99}).f) // stored null -> 99
  m["k"] = {f: 42}
  print((m["k"] ?? {f: 99}).f) // present -> 42
  const e: {[string]: {f: i64} | null} = Map()
  print((e["absent"] ?? {f: 7}).f) // missing -> 7
}
structVal()

// STRING value (ref niche): stored null coalesces to the non-null default.
function stringVal() {
  const m: {[string]: string | null} = Map()
  m["k"] = null
  const t = m["k"] ?? "DEF"
  print(t) // stored null -> DEF
  m["k2"] = "hi"
  const t2 = m["k2"] ?? "DEF"
  print(t2) // present -> hi
}
stringVal()

// LITUNION value (mono i32 niche, -1 sentinel).
type K = "aa" | "bb"
function litunionVal() {
  const m: {[string]: K | null} = Map()
  m["k"] = null
  const t: K = m["k"] ?? "aa"
  print(t) // stored null -> aa
  m["k2"] = "bb"
  const t2: K = m["k2"] ?? "aa"
  print(t2) // present -> bb
}
litunionVal()

// BOOLEAN value (mono i32 niche, 2 sentinel). No stored null here (a bare-null store into a
// boolean|null map is a separate, pre-existing gap); a MISSING key coalesces to the default.
function boolVal() {
  const m: {[string]: boolean | null} = Map()
  const t = m["k"] ?? true
  print(t) // missing -> true
  m["k2"] = false
  const t2 = m["k2"] ?? true
  print(t2) // present -> false
}
boolVal()

// SCALAR-box value (i32 | null / i64 | null / f64 | null): boxed, `??` peels the raw scalar.
function scalarVal() {
  const m: {[string]: i32 | null} = Map()
  m["k"] = null
  print(m["k"] ?? 9)      // stored null -> 9
  m["k"] = 5
  print(m["k"] ?? 9)      // present -> 5
  print(m["absent"] ?? 8) // missing -> 8
  const mi: {[string]: i64 | null} = Map()
  mi["k"] = null
  print(mi["k"] ?? 100)   // stored null -> 100
  const mf: {[string]: f64 | null} = Map()
  mf["k"] = 2.5
  print(mf["k"] ?? 9.9)   // present -> 2.5
}
scalarVal()

// UNION-box value (i64 | string | null): the multi-member value union stays a NON-null box.
function unionVal() {
  const m: {[string]: i64 | string | null} = Map()
  const d: i64 | string = 7
  m["k"] = null
  const t = m["k"] ?? d
  if t is i64 { print(t) } else { print("STR") } // stored null -> 7
  m["k2"] = "hi"
  const t2 = m["k2"] ?? d
  if t2 is i64 { print(t2) } else { print("STR") } // present string -> STR
  m["k3"] = 42
  const t3 = m["k3"] ?? d
  if t3 is i64 { print(t3) } else { print("STR") } // present i64 -> 42
}
unionVal()

// NULL DEFAULT edge: `m[k] ?? null` stays `V | null` — a stored null passes through as null,
// a present value passes through as itself.
function nullDefault() {
  const m: {[string]: {f: i64} | null} = Map()
  m["k"] = null
  const v = m["k"] ?? null
  if v != null { print(v.f) } else { print("NULL") } // stored null, ?? null -> NULL
  m["k2"] = {f: 5}
  const w = m["k2"] ?? null
  if w != null { print(w.f) } else { print("NULL") } // present -> 5
}
nullDefault()
