// @run
// @log 0
// @log 1
// @log 2
// @log 10
// @log 20
// @log -1
// @log true
// @log false
// @log 99
// @log 2
// A string-keyed `Map<K,V>` (B6a): `Map()` constructs an empty map (type pinned
// from the annotation), `m[k] = v` sets, `m[k]` reads `V | null` (missing key is
// normal absence — NOT a trap), `.size` is the live count, `.has` tests
// membership. Overwrite keeps size; a missing read is null (defaulted via `??`).
let m: {[string]: i32} = Map()
print(m.size)            // 0

m["a"] = 10
print(m.size)            // 1
m["b"] = 20
print(m.size)            // 2

print(m["a"] ?? -1)      // 10
print(m["b"] ?? -1)      // 20
print(m["missing"] ?? -1) // -1 — absent → null

// has: present vs absent (boolean → 1/0).
print(m.has("a"))        // 1 (true)
print(m.has("z"))        // 0 (false)

// overwrite an existing key: value changes, size unchanged.
m["a"] = 99
print(m["a"] ?? -1)      // 99
print(m.size)            // 2 — still two keys
