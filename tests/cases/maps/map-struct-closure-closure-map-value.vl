// @run
// @log 167236169
// @log 3.5
// @log 6000000000
// @hint Intentionally-unused parameter
// @hint Intentionally-unused parameter
// A map whose STRUCT value carries a CLOSURE field returning a closure returning a MAP
// (`{[string]: {a: i64, f: (i32) => (() => {[string]: i64}), z: f32}}` — map -> struct ->
// closure -> closure -> map, depth 5). The inner lambda reads `h0` from the frame TWO
// levels up, so the outer lambda re-captures it transitively and the inner env build
// reads it env-to-env; the buried i64-map leaf then survives the full
// read-call-call-read chain.
// (rep-fuzz: p0c/p0r `{[string]: {a: i64, f: (i32) => (() => {[string]: i64}), z: f32}}`.)
function go() {
  const h0: {[string]: i64} = Map()
  h0["k"] = 167236169
  const h2: {[string]: {a: i64, f: (i32) => (() => {[string]: i64}), z: f32}} = Map()
  h2["k"] = { a: 6000000000, f: (_q1: i32) => (() => (h0)), z: 3.5 }
  const h3: {[string]: i64} = Map()
  h3["k"] = 13131313131
  const t0 = h2["k"] ?? { a: 6000000000, f: (_q4: i32) => (() => (h3)), z: 3.5 }
  const t1 = t0.f(1)()["k"] ?? 13131313131
  print(t1) // 167236169 — the buried leaf, read through both closure hops
  print(t0.z) // 3.5 — the f32 sibling
  print(t0.a) // 6000000000 — the i64 sibling
}
go()
