// @run
// @log 6000000000
// @log 1.5
// @log 3.5
// @log 42
// @log hi
// @log aa
// Maps with NON-{i32,string,struct} value types cross the RETURN boundary: the functype
// result is the map's own `$mapStruct` ref (valtype kind "map" + the value type's mv slot)
// — the SAME rep the local binding uses. The boundary gate (`retMapFlag`) reads the ONE
// map value-kind classifier (`mvValKindOfName`) the local interner (`mvShapeOfValName`)
// uses, so every value type that binds locally also returns: i64 / f64 / f32 scalar maps,
// closure-valued, union-valued, and atom (literal-union) valued maps.
type K0 = "aa" | "bb"

function mkI64(): {[string]: i64} {
  const m: {[string]: i64} = Map()
  m["k"] = 6000000000
  return m
}

function mkF64(): {[string]: f64} {
  const m: {[string]: f64} = Map()
  m["k"] = 1.5
  return m
}

function mkF32(): {[string]: f32} {
  const m: {[string]: f32} = Map()
  const x: f32 = 3.5
  m["k"] = x
  return m
}

function mkClo(): {[string]: () => i32} {
  const m: {[string]: () => i32} = Map()
  m["k"] = () => (42)
  return m
}

function mkUnion(): {[string]: i32 | string} {
  const m: {[string]: i32 | string} = Map()
  m["k"] = "hi"
  return m
}

function mkAtom(): {[string]: K0} {
  const m: {[string]: K0} = Map()
  m["k"] = "aa"
  return m
}

function go() {
  // Annotated and UN-annotated caller bindings both classify the returned map.
  const vI64: {[string]: i64} = mkI64()
  print(vI64["k"] ?? 13)
  const vF64 = mkF64()
  print(vF64["k"] ?? 0.25)
  const vF32 = mkF32()
  const dF32: f32 = 2.5
  print(vF32["k"] ?? dF32)
  const vClo = mkClo()
  const f = vClo["k"] ?? (() => (7))
  print(f())
  const vUnion: {[string]: i32 | string} = mkUnion()
  const r = vUnion["k"] ?? 5
  if r is string { print(r) } else { print(r) }
  const vAtom = mkAtom()
  print(vAtom["k"] ?? "bb")
}
go()
