// Regression: the DIRECT-receiver spelling of `litunion-valued-map-read-eq.vl` —
// `h0["k"] == "bbpt"` on the annotated binding itself, with a bare `K0` annotation
// present (the `gLitUnionUsed` flag on via the pre-existing path), isolating defect
// (2): the missing `exprIsLitAtom` map-read claim alone produced the strEq-on-i32
// invalid wasm. Also reads a missing key (`== `→ false path: the not-found arm's
// sentinel is not a member id).
// @run
// @log bbpt
// @log miss
// @log bbpt
type K0 = "bbpt" | "00882"
function go() {
  const kk: K0 = "bbpt"
  const h0: {[string]: K0} = Map()
  h0["k"] = "bbpt"
  if h0["k"] == "bbpt" { print("bbpt") } else { print("WRONG") }
  if h0["nope"] == "00882" { print("WRONG2") } else { print("miss") }
  print(kk)
}
go()
