// @run
// @log 804
// A NULLABLE map whose values are closures returning a NULLABLE literal-union
// (`{[string]: () => K0 | null} | null`). The closure is read out of the map with a
// `??` default, so its binding type is INFERRED (not annotated) — its emit name must
// keep the litunion alias (`K0 | null` → the i32 atom, `>i`) rather than soften to
// `string | null` (`>N`), so the value call's result local matches the i32 the
// `call_ref` yields.
type K0 = "pv" | "804"
function makeIt(): {[string]: () => K0 | null} | null {
  const h0: {[string]: () => K0 | null} = Map()
  h0["k"] = () => ("804")
  return h0
}
function go() {
  const v: {[string]: () => K0 | null} | null = makeIt()
  const t0 = v
  if (t0 != null) {
    const t1 = t0["k"] ?? () => ("pv")
    const t2 = t1()
    if t2 != null { print(t2) } else { print("NULL") }
  } else {
    print("NULL")
  }
}
go()
