// @run
// @log aa
// @log bb
// @log aa
// @log bb
// @log aa
// @log aa
// @hint Intentionally-unused parameter `_x`
// @hint Intentionally-unused parameter `_q`
// A map whose VALUE is a closure returning a LITERAL-UNION atom (`{[string]: (i32) => K0}`).
// The vals element is the closure fat-pointer; `m[k] ?? d` reads it and the call goes through
// `call_ref` with the atom (`>i`) result sig. The load-bearing seam: the `??`-bound callee's
// sig resolves through the checker's RENDERED type name, which softens `K0` to `string` — so
// the per-name string-result claim (`calleeReturnsString`) must be gated on the call node's
// litunion-alias type, else `print(f(1))` hands the raw i32 atom to the string path (invalid
// wasm). The atom widens to its member string at the print seam (`exprIsLitAtom`) instead.
// Covers: local + returned-map positions, the direct-print call, the bound-then-printed call,
// an atom-context arg, a `: K0`-annotated binding, and a missing-key default.
type K0 = "aa" | "bb"
function useK(p: K0): K0 { p }
function mk(): {[string]: (i32) => K0} {
  const h: {[string]: (i32) => K0} = Map()
  h["f"] = (_x) => "aa"
  return h
}
function go() {
  const m: {[string]: (i32) => K0} = Map()
  m["f"] = (_x) => "aa"
  m["g"] = (_x) => "bb"
  // Direct print of the value call — the raw-atom-into-string-path seam.
  const f = m["f"] ?? (_q) => "bb"
  print(f(1))
  // Bound read, then print (the binding classifies as the i32 atom slot).
  const g = m["g"] ?? (_q) => "aa"
  const r = g(2)
  print(r)
  // Atom-context consumers: a `K0` param arg and a `: K0`-annotated binding.
  print(useK(f(3)))
  const k: K0 = g(4)
  print(k)
  // Missing key: the default lambda fires; its adopted `K0` result prints the member.
  const d = m["missing"] ?? (_q) => "aa"
  print(d(5))
  // The RETURNED-map position: the same read through a call-result binding.
  const v = mk()
  const h = v["f"] ?? (_q) => "bb"
  print(h(6))
}
go()
