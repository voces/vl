// @emit-error `??` is only supported on a map index get
// `k ?? "zz"` over a `K | null` NICHE binding with a NON-member default: the checker
// joins the result to `string`, but the niche value's rep is the bare i32 atom (or the
// -1 sentinel) — no lowering exists, a loud EMIT-stage reject. (A MEMBER-literal or
// atom default keeps the union and lowers; see maps/atom-valued-map.vl.)
type K0 = "aa" | "bb"
function go(k: K0 | null) {
  print(k ?? "zz")
}
go("aa")
