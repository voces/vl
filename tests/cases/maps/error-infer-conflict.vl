// @check
// @error set: expected i32, got string
// SOUNDNESS: once the FIRST `m.set("a", 1)` materialises the inferred `Map()` as
// `{[string]: i32}`, a later `m.set("b", "x")` with a CONFLICTING value type is a
// clean type error (`string` not assignable to the pinned `i32`) — NOT a crash,
// the same way a mixed-type array push errors after the element is pinned.
const m = Map()
m.set("a", 1)
m.set("b", "x")
