// @run
// @log 5000000000
// @log 9000000000
// @log 0
// @log 2
// @log 16000000000
// An i64-VALUED map `{[string]: i64}` — the i64 sibling of the f64-valued map, now that
// the i64 list type exists. mv-value kind 10: the vals list is the scalar i64 list
// (`il64`/`ia64`), the typed valStash an i64 LOCAL; get/set/append/default/classification
// all go through the shared `mvScalarValKind` + `emitScalarValue` paths (the f64/i64 maps
// share one scalar-value spine).

function go() {
  const m: {[string]: i64} = Map()
  m["a"] = 5000000000
  m["b"] = 7000000000
  print(m["a"] ?? 0) // 5000000000

  m["a"] = 9000000000 // overwrite
  print(m["a"] ?? 0) // 9000000000
  print(m["z"] ?? 0) // 0 (absent → default)

  print(m.size) // 2

  let total: i64 = 0
  for k in m { total = total + (m[k] ?? 0) }
  print(total) // 9000000000 + 7000000000
}
go()
