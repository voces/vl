// @run
// @log 7
// @log 0
// @log 9
// @log 4
// @log 7
// @log 1
// @log 0
// A STRUCT-valued map (`{[string]: S}`) crossing function BOUNDARIES — param and return. The
// value type's mv slot (the map SHAPE) flows across, so the struct value resolves on both sides
// (index-get via `m[k] ?? d`, `.has`, mutation through the param, annotated + inferred factory).

type P = { x: i32 }
type Pt = { x: i32, y: i32 }

// PARAM: index-get with a struct default, returning a field of the value.
function getX(m: {[string]: P}, k: string) { return (m[k] ?? { x: 0 }).x }
// PARAM mutation (same ref) + `.has`.
function put(m: {[string]: Pt}, k: string, v: Pt) { m[k] = v }
function has(m: {[string]: Pt}, k: string) {
  if m.has(k) { return 1 }
  return 0
}

// RETURN: annotated and inferred struct-valued map factories.
function annotated(): {[string]: P} {
  const m: {[string]: P} = Map()
  m["a"] = { x: 9 }
  return m
}
function inferred() {
  const m: {[string]: P} = Map()
  m["a"] = { x: 4 }
  return m
}

function go() {
  const m: {[string]: P} = Map()
  m["a"] = { x: 7 }
  print(getX(m, "a")) // 7
  print(getX(m, "z")) // 0   (absent → struct default)

  print((annotated()["a"] ?? { x: 0 }).x) // 9
  print((inferred()["a"] ?? { x: 0 }).x) // 4

  const m2: {[string]: Pt} = Map()
  put(m2, "o", { x: 3, y: 4 })
  print((m2["o"] ?? { x: 0, y: 0 }).x + (m2["o"] ?? { x: 0, y: 0 }).y) // 7
  print(has(m2, "o")) // 1
  print(has(m2, "z")) // 0
}
go()
