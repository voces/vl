// @run
// @log aa
// @log bb
// @log NULL
// @log NULL
// A map whose VALUE is a NULLABLE literal union (`{[string]: K | null}`): still the MONO i32
// map — each value is the interned atom id with the `-1` null sentinel (the same niche a
// `K | null` local uses). A member-literal store lowers as its atom id, a bare `null` store
// as `-1` (`emitMapSetValExpr`'s NullLit arm), and the fused `?? d` read admits a member
// literal OR a bare `null` default (`nodeTyMapValIsNulLitUnion` + the nullable-aware
// `nodeTyMapValLitUnionTexts`). SEMANTICS (the corpus oracle's): a stored null is PRESERVED
// through `?? d` — the default fires only on a MISSING key — so `m["y"] ?? "bb"` yields NULL,
// not "bb". The read binds the `K | null` niche (`exprNulLitUnion`'s coalesce arm) and
// narrows with `!= null`.
type K0 = "aa" | "bb"
function go() {
  const m: {[string]: K0 | null} = Map()
  m["x"] = "aa"
  m["y"] = null
  const t0 = m["x"] ?? "bb"
  if t0 != null {
    print(t0)
  } else {
    print("NULL")
  }
  const t1 = m["absent"] ?? "bb"
  if t1 != null {
    print(t1)
  } else {
    print("NULL")
  }
  const t2 = m["y"] ?? "bb"
  if t2 != null {
    print(t2)
  } else {
    print("NULL")
  }
  const t3 = m["y"] ?? null
  if t3 != null {
    print(t3)
  } else {
    print("NULL")
  }
}
go()
