// @run
// @log aa
// @log bb
// @log bb
// @log NULL
// A map whose VALUE is a NULLABLE literal union (`{[string]: K | null}`): still the MONO i32
// map — each value is the interned atom id with the `-1` null sentinel (the same niche a
// `K | null` local uses). A member-literal store lowers as its atom id, a bare `null` store
// as `-1`, and the fused `?? d` read admits a member literal OR a bare `null` default.
// SEMANTICS (USER SEMANTICS RULING 2026-07-23): `??` coalesces on the read VALUE being null —
// a MISSING key AND a STORED null (the `-1` sentinel) both take the default — and a non-null
// default types the result NON-null `K`. `m["y"] ?? "bb"` therefore yields "bb", not NULL. Only
// a nullable default (`?? null`) leaves it `K | null` (a stored null then passes through).
type K0 = "aa" | "bb"
function go() {
  const m: {[string]: K0 | null} = Map()
  m["x"] = "aa"
  m["y"] = null
  const t0: K0 = m["x"] ?? "bb"
  print(t0) // present -> aa
  const t1: K0 = m["absent"] ?? "bb"
  print(t1) // missing -> bb
  const t2: K0 = m["y"] ?? "bb"
  print(t2) // STORED null coalesces -> bb
  const t3 = m["y"] ?? null
  if t3 != null {
    print(t3)
  } else {
    print("NULL") // ?? null keeps `K | null`, stored null passes through -> NULL
  }
}
go()
