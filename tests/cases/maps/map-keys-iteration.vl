// @run
// @log 3
// @log a
// @log b
// @log c
// @log 2
// @log a
// @log c
// @log a
// @log c
// @log 4
// `m.keys()` (a fresh string list of the map's LIVE keys, insertion-ordered) and `for k
// in m` (native map iteration over the same live keys). Both skip tombstoned entries
// after a `.delete`. `m.keys()` builds the list via the dedicated key-list builder frame;
// `for k in m` reuses the existing tombstone-aware `for k in m.keys()` loop (no list
// allocated). Previously `.keys()` failed to lower and `for k in m` was a checker error.

function go() {
  const m: {[string]: i32} = Map()
  m["a"] = 1
  m["b"] = 2
  m["c"] = 3

  // .keys() as a bound string[] — length + indexing + for-in over the result.
  const ks = m.keys()
  print(ks.length) // 3
  for k in ks {
    print(k) // a, b, c
  }

  // delete tombstones an entry; both forms skip it.
  m.delete("b")
  print(m.keys().length) // 2
  for k in m.keys() {
    print(k) // a, c
  }

  // native `for k in m` iterates live keys directly.
  for k in m {
    print(k) // a, c
  }

  // iterate keys to sum the surviving values.
  let sum = 0
  for k in m { sum = sum + (m[k] ?? 0) }
  print(sum) // 1 + 3 = 4
}
go()
