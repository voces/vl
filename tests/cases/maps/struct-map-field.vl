// @run
// @log 8
// @log 42
// @log hi
// A MAP-typed field inside an INLINE struct annotation (`{ m: {[string]: V} }`) — and the
// `{ m: Map() }` literal that fills it. Was rejected at emit ("object literal but no struct
// type declared"): `nameFieldCode` (the name-level field-code mirror) had no map case, so an
// inline shape with a map field never interned. Now code 19 (the map field) is recognized;
// `collectAnnShapes` records the value name and `collectA` interns the field's mv slot (the
// inner map of an inline `{m:{[string]:V}}` is not a standalone TypeRef the scan sees). Named
// types already worked — this closes the inline-annotation path.

function tally(s: { counts: {[string]: i32} }): i32 {
  return s.counts["x"] ?? 0
}

function go() {
  // i32-valued map field (mono) + a sibling scalar field.
  const a: { m: {[string]: i32}, n: i32 } = { m: Map(), n: 5 }
  a.m["a"] = 3
  print((a.m["a"] ?? 0) + a.n) // 8

  // map field flowing through a struct PARAM.
  const c: { counts: {[string]: i32} } = { counts: Map() }
  c.counts["x"] = 42
  print(tally(c)) // 42

  // a STRING-valued map field (a real mv slot, not the mono map).
  const s: { m: {[string]: string} } = { m: Map() }
  s.m["k"] = "hi"
  print(s.m["k"] ?? "none") // hi
}
go()
