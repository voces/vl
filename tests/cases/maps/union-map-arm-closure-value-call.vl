// A union with a MAP arm whose VALUE union carries a CLOSURE arm
// (`{[string]: (() => i64) | string} | {w: i32}`). Calling the closure read out of
// the narrowed map (`const t1 = t0["k"] ?? d; t1()`) needs `callRefSlot` reserved by
// the frame pre-pass — but the pre-pass is narrowing-blind: `exprMap(t0)` is false
// there, so `mapReadMvSlot` missed the read, `t1` never classified as the value
// union, and `calleeIsUnionClosureIdent` missed its closure arm. The `call_ref`
// closure spill then landed on the UNRESERVED `callRefSlot` index — shared with the
// mv map frame's `mapRef` local, a `(ref $mapStruct)`-typed local receiving a
// `(ref $cloStruct)` (invalid wasm; fuzz-nightly run 29808029476, seed 78530533 d5).
// `mapReadMvSlot` now resolves a union-ident receiver through its MAP arm's value
// name (`unionMapArmName`), narrowing-blindly.
function useIt(p: {[string]: (() => i64) | string} | {w: i32}) {
  const t0 = p
  if t0 is {[string]: (() => i64) | string} {
    const t1 = t0["k"] ?? () => (13131313131)
    const t2 = t1
    if (t2 is () => i64) { print(t2()) } else { print("OTHER") }
  } else {
    print("OTHER")
  }
}

function go() {
  const h: {[string]: (() => i64) | string} = Map()
  h["k"] = () => (5)
  useIt(h)
  useIt({ w: 77 })
}
go()
