// @run
// @log OTHER
// @log 686
// A map whose VALUE is a STRUCT with a litunion-mix union FIELD (`{[string]: {f: K0 |
// f64}}`), produced by a FACTORY that returns a closure over the built map (`() => (h0)`).
// The self-inferred factory-return lambda and the binding annotation must agree on the
// map-value STRUCT rep: the field `K0 | f64` softens its litunion alias `K0` to `string`
// (R3's boxed-atom rule) THROUGH the struct-field nesting — `{f: string | f64}` — so both
// producers intern ONE mv/map struct (and one `$fnsig`). Before `rlCanonLitUnionAtoms`
// descended the softening into inline shapes, the two spellings minted TWIN map structs
// (and twin closure functypes), so the returned-map read (`v()["k"]`) cast-TRAPPED. The
// struct-field sibling of the #1030 `(K0 | i32)[]` ref-list canon. rep-fuzz post-#1030.
type K0 = "686" | "lfvvb" | "txvpr"
function makeIt(): () => {[string]: {f: K0 | f64}} {
  const h0: {[string]: {f: K0 | f64}} = Map()
  h0["k"] = { f: 1.5 }
  h0["k1"] = { f: "686" }
  return () => (h0)
}
function go() {
  const v: () => {[string]: {f: K0 | f64}} = makeIt()
  const t0 = v()["k"] ?? { f: 1.5 }
  const x = t0.f
  if x is K0 { print(x) } else { print("OTHER") }
  const t1 = v()["k1"] ?? { f: 1.5 }
  const y = t1.f
  if y is K0 { print(y) } else { print("OTHER") }
}
go()
