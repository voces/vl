// @run
// @log 3
// @log 2
// @log 5
// @log 4
// Map-value slot dedup (roadmap repOf, slot layer): two map types whose VALUE
// types are LAYOUT TWINS share one map-struct heap type (`mvTwin` —
// `repMapValSlotsTwin`: canonical value key + per-kind layout guard), so a
// twin-spelled map flows where the other spelling is annotated. Each shape below
// was INVALID WASM before (each mv slot minted its own byte-identical — yet
// distinct, inside the one rec group — 7-field map struct):
//   · a `{[string]: B}` passed to a `{[string]: A}` param (declared twins),
//   · a `{[string]: A}` passed to the inline `{[string]: {v: i32}}` spelling,
//   · a NESTED `{[string]: {[string]: B}}` into `{[string]: {[string]: A}}`
//     (the vals ref-list's map-element sig keys on the canonical mv rep, so the
//     inner twin propagates through the list layer),
//   · a LIST of twin maps (`{[string]: B}[]` into `{[string]: A}[]`).

type A = { v: i32 }
type B = { v: i32 }

function total(m: {[string]: A}): i32 {
  const x = m["one"]
  let t = 0
  if x != null { t = t + x.v }
  const y = m["two"] ?? { v: 0 }
  t + y.v
}

function shapeTotal(m: {[string]: {v: i32}}): i32 {
  const y = m["two"] ?? { v: 0 }
  y.v
}

function deep(m: {[string]: {[string]: A}}): i32 {
  const inner = m["x"] ?? Map()
  const a = inner["y"] ?? { v: 0 }
  a.v
}

function firstV(xs: {[string]: A}[]): i32 {
  const m = xs[0]
  const a = m["k"] ?? { v: 0 }
  a.v
}

function go() {
  const mb: {[string]: B} = Map()
  mb["one"] = { v: 1 }
  mb["two"] = { v: 2 }
  print(total(mb))      // 3 — declared twin param
  print(shapeTotal(mb)) // 2 — inline-shape spelling

  const mi: {[string]: B} = Map()
  mi["y"] = { v: 5 }
  const mo: {[string]: {[string]: B}} = Map()
  mo["x"] = mi
  print(deep(mo))       // 5 — nested map twin

  const mk: {[string]: B} = Map()
  mk["k"] = { v: 4 }
  const xs: {[string]: B}[] = [mk]
  print(firstV(xs))     // 4 — list of twin maps
}
go()
