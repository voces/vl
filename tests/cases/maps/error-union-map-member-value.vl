// @emit-error unsupported map value type
// A map whose VALUE is a union with a MAP member (`{[string]: {[string]: i32} | f64}`). A map
// arm boxes fine in BINDING position, but the map-value store/read seams coerce through
// `emitUnionBoxArg`, which has no map-member arm — the raw value went into the `(ref null $uBox)`
// vals element unboxed: invalid wasm on every store. Loud emit reject, never invalid wasm.
function go() {
  const h0: {[string]: i32} = Map()
  h0["k"] = 10749
  const h1: {[string]: {[string]: i32} | f64} = Map()
  h1["k"] = h0
  print(0)
}
go()
