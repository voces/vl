// @run
// @log 13131313131
// @log NULL
// @log x
// @log N1
// @log NULL
// @log 42
// A NICHE/BOX-nullable scalar-element list as a MAP VALUE, direct and nested —
// `{[string]: (i64 | null)[]}`, `{[string]: (string | null)[]}`, `{[string]: {[string]:
// (i64 | null)[]}}`. Three seams hold it together: the map STORE's generic ref-list seed
// (kind 5) clears `isI64Lit`, so an i64-magnitude literal (`[13131313131]`) builds the
// kind-2 union-box element list, not a scalar i64 list into the box slot; the string-inner
// array classifiers admit `(string | null)[]` wherever `string[]` goes (the `$mkListIdx`
// wrapper is shared), so the vals ref-list element heap resolves; and a nested map's
// list-of-NULLABLE inner value resolves recursively at the op sites (only a list-of-MAP
// element stays a loud reject).
function useIt(p: {[string]: {[string]: (i64 | null)[]}}) {
  const h3: {[string]: (i64 | null)[]} = Map()
  h3["k"] = [13131313131]
  const t0 = p["k"] ?? h3
  const t1 = t0["k"] ?? [13131313131]
  const t2 = t1[0]
  if t2 != null { print(t2) } else { print("NULL") }
}

function go() {
  // Direct i64-elem value: an i64-magnitude store literal + a `?? <literal>` default.
  const h0: {[string]: (i64 | null)[]} = Map()
  h0["k"] = [13131313131]
  const t1 = h0["k"] ?? [13131313131]
  const t2 = t1[0]
  if t2 != null { print(t2) } else { print("NULL") } // 13131313131
  h0["n"] = [null]
  const t3 = h0["n"] ?? []
  const t4 = t3[0]
  if t4 != null { print(t4) } else { print("NULL") } // NULL

  // Direct string-elem value: element read stays nullable.
  const hs: {[string]: (string | null)[]} = Map()
  hs["k"] = ["x", null]
  const s1 = hs["k"] ?? []
  const s2 = s1[0]
  if s2 != null { print(s2) } else { print("NULL") } // x
  if s1[1] == null { print("N1") } // N1

  // Nested: a map of maps of nullable-i64 lists, read through a map PARAM.
  const g0: {[string]: (i64 | null)[]} = Map()
  g0["k"] = [null]
  const g1: {[string]: {[string]: (i64 | null)[]}} = Map()
  g1["k"] = g0
  useIt(g1) // NULL

  // Nested with a non-null element read.
  g0["k"] = [42]
  useIt(g1) // 42
}
go()
