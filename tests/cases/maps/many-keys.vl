// @run
// @log 12
// @log 0
// @log 11
// @log 10
// @log 66
// Many distinct string keys force the hash index to grow (rehash 8 → 16 → 32 as
// the load factor crosses 1/2) and exercise collision probing. Every key remains
// retrievable after the rehashes, and ordered `.values()` sums the inserted
// values (0..11 = 66).
let m: {[string]: i32} = Map()
let names = ["alpha", "beta", "gamma", "delta", "epsilon", "zeta", "eta", "theta", "iota", "kappa", "lambda", "mu"]
let i = 0
while i < names.length {
  m[names[i]] = i
  i = i + 1
}
print(m.size)              // 12
print(m["alpha"] ?? -1)    // 0
print(m["mu"] ?? -1)       // 11
print(m["lambda"] ?? -1)   // 10

let sum = 0
for v in m.values() {
  sum = sum + v
}
print(sum)                 // 66 — 0 + 1 + … + 11
