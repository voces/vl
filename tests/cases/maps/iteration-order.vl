// @run
// @log c
// @log a
// @log b
// @log 30
// @log 10
// @log 20
// @log d
// @log e
// @log f
// @log g
// Deterministic INSERTION-ORDER iteration (the hard multiplayer/replay
// requirement): `m.keys()` / `m.values()` materialize ordered snapshot lists in
// the order keys were first inserted — NOT hash order, NOT sorted. Overwriting a
// key keeps its original position; a large map (forcing index rehash + entry
// growth) still iterates in insertion order. (Iteration is via `m.keys()` since
// the parser's `for…in` only admits i32-keyed sequences.)
const m: {[string]: i32} = Map()
m["c"] = 1
m["a"] = 2
m["b"] = 3
m["c"] = 30 // overwrite — position unchanged (stays first)
m["a"] = 10
m["b"] = 20

for k in m.keys() {
  print(k)        // c, a, b — insertion order, overwrite kept c first
}
for v in m.values() {
  print(v)        // 30, 10, 20 — values in the same order
}

// Insert past the initial capacity (8) to force a rehash; order still holds.
const big: {[string]: i32} = Map()
big["d"] = 1
big["e"] = 2
big["f"] = 3
big["g"] = 4
for k in big.keys() {
  print(k)        // d, e, f, g — insertion order across the rehash
}
