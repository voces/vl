// @run
// @log 7
// @log OTHER
// @log hey
// @log 3
// @log 5
// @log ss
// @log 4
// A map whose VALUE is a union with a MAP member (`{[string]: {[string]: i32} | boolean}`).
// The kind-2 (union-box) map value store/read seams route through `emitUnionBoxArg` →
// `emitUnionCoerce`, whose map-carrier arm tags the map-struct ref with the arm's
// `mapSlotTag`; `mvShapeOfValName` interns each map arm's mv value slot
// (`markMapUnionArms`) so the box tag and the narrowed read resolve the same slot.
// Covers: the map arm and the other arm through store + `?? default` read + `is`
// discrimination, a map|struct union value, TWO distinct map arms in one union value
// (distinct mv slots tag distinctly), and the param/return boundary.
function mapArm() {
  const inner: {[string]: i32} = Map()
  inner["k"] = 7
  const m: {[string]: {[string]: i32} | boolean} = Map()
  m["a"] = inner
  m["b"] = true
  const t0 = m["a"] ?? false
  if t0 is {[string]: i32} {
    print(t0["k"] ?? 0)
  } else {
    print("OTHER")
  }
  const t1 = m["b"] ?? false
  if t1 is {[string]: i32} {
    print(t1["k"] ?? 0)
  } else {
    print("OTHER")
  }
}
function mapStructArms() {
  const inner: {[string]: string} = Map()
  inner["k"] = "hey"
  const m: {[string]: {[string]: string} | {w: i32}} = Map()
  m["a"] = inner
  m["b"] = {w: 3}
  const t0 = m["a"] ?? {w: 0}
  if t0 is {[string]: string} {
    print(t0["k"] ?? "zz")
  } else {
    print("OTHER")
  }
  const t1 = m["b"] ?? {w: 0}
  if t1 is {w: i32} {
    print(t1.w)
  } else {
    print("OTHER")
  }
}
function twoMapArms() {
  const mi: {[string]: i32} = Map()
  mi["k"] = 5
  const ms: {[string]: string} = Map()
  ms["k"] = "ss"
  const m: {[string]: {[string]: i32} | {[string]: string}} = Map()
  m["a"] = mi
  m["b"] = ms
  const t0 = m["a"] ?? ms
  if t0 is {[string]: i32} {
    print(t0["k"] ?? 0)
  } else {
    print("OTHER")
  }
  const t1 = m["b"] ?? mi
  if t1 is {[string]: string} {
    print(t1["k"] ?? "zz")
  } else {
    print("OTHER")
  }
}
function mk(): {[string]: {[string]: i32} | i64} {
  const inner: {[string]: i32} = Map()
  inner["k"] = 4
  const m: {[string]: {[string]: i32} | i64} = Map()
  m["a"] = inner
  return m
}
function useIt(p: {[string]: {[string]: i32} | i64}) {
  const t0 = p["a"] ?? 500
  if t0 is {[string]: i32} {
    print(t0["k"] ?? 0)
  } else {
    print("OTHER")
  }
}
function go() {
  mapArm()
  mapStructArms()
  twoMapArms()
  useIt(mk())
}
go()
