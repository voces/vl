// @emit-error unsupported map value type
// A map whose VALUE is a NULLABLE struct (`{f: string} | null`). The value box has no null
// arm, so the store/read seams mis-type the `(ref null)` vals element against the box — a
// LOUD emit reject (never invalid wasm) until a nullable ref-VALUE map rep lands.
type Box = { f: string }
function go() {
  const m: {[string]: Box | null} = Map()
  m["k"] = { f: "hi" }
  const v = m["k"] ?? { f: "d" }
  if v != null { print(v.f) }
}
go()
