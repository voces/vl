// @run
// @log 2
// @log 3
// @log 5
// @log 1
// @log 2
// @log 10
// @log 2.5
// @log 5000000000
// @log 2
// `for r in m.values()` over a LIST-valued map (`{[string]: i32[]}` / `f64[]` / `i64[]` / `S[]` …):
// the loop var binds the inner VALUE LIST, exactly as `for row in g` over a nested array `i32[][]`
// does. `forInElemKind` returns the value-list's loop-var rep (`mvListValKind` → 2/7/12/20/21, or 5
// for a struct/ref list) for a kind-6 (list) map value; the rest reuses the nested-array for-in
// machinery (the `#l` temp is the vals ref-list wrapper). Previously a loud "ref valtype with no
// interned shape" (the list value fell into the struct-value path). Scalar/struct map values for-in
// already worked.

function go() {
  // i32[] values — `.length` and indexed read across multiple entries.
  const m: {[string]: i32[]} = Map()
  m["a"] = [1, 2]
  m["b"] = [3, 4, 5]
  for r in m.values() {
    print(r.length) // 2, 3
  }
  let total = 0
  for r in m.values() {
    total = total + r.length
  }
  print(total) // 5

  // NESTED for-in: iterate the values, then each inner list.
  const g: {[string]: i32[]} = Map()
  g["x"] = [1, 2]
  g["y"] = [10]
  for r in g.values() {
    for v in r {
      print(v) // 1, 2, 10
    }
  }

  // f64[] and i64[] value lists.
  const fm: {[string]: f64[]} = Map()
  fm["a"] = [1.5, 2.5]
  for r in fm.values() {
    print(r[1]) // 2.5
  }
  const nm: {[string]: i64[]} = Map()
  nm["a"] = [5000000000]
  for r in nm.values() {
    print(r[0]) // 5000000000
  }

  // a struct-list value (`S[]`).
  const sm: {[string]: S[]} = Map()
  sm["a"] = [{n: 7}, {n: 8}]
  for r in sm.values() {
    print(r.length) // 2
  }
}

type S = { n: i32 }

go()
