// @run
// @log bx
// @log fv
// @log bn
// @log dnjb
// An ATOM-valued map (`{[string]: K}`, `K` a literal union) as a STRUCT FIELD — the R1
// map-in-field seam over the MONO map (rep-fuzz `p1c/p1r {a: boolean, f: {[string]: K0},
// z: i32}`, `p1c/p1r {f: {f: {[string]: K0}}}`, `p2c/p2r {f: {a: …, f: {[string]: K0},
// …}}`). The field records the ALIAS name ("K0") in `sFieldElemName`; `mvSlotOfValNameFind`
// now classifies mono-ness through `mvValKindOfName` (the interner's own classifier) instead
// of the two-name i32/boolean test, so the atom map rides the shared mono `$mStructIdx`
// exactly like the binding it mirrors — construct, param crossing, nested fields, return
// position, read + overwrite.
type K0 = "bx" | "fv" | "bn" | "dnjb"

function useIt(p: {a: boolean, f: {[string]: K0}, z: i32}) {
  print(p.f["k"] ?? "dnjb") // bx — atom map field through a PARAM
  p.f["k"] = "fv"
  print(p.f["k"] ?? "dnjb") // fv — overwrite through the param
}

function makeIt(): {f: {a: boolean, f: {[string]: K0}, z: i32}} {
  const h0: {[string]: K0} = Map()
  h0["k"] = "dnjb"
  return {f: {a: true, f: h0, z: 11}}
}

function go() {
  const h0: {[string]: K0} = Map()
  h0["k"] = "bx"
  useIt({a: true, f: h0, z: 11})
  // NESTED struct field (`{f: {f: {[string]: K0}}}`).
  const h1: {[string]: K0} = Map()
  h1["k"] = "bn"
  const o: {f: {f: {[string]: K0}}} = {f: {f: h1}}
  print(o.f.f["k"] ?? "bx") // bn
  // RETURN-position struct with an atom-map field.
  const r = makeIt()
  print(r.f.f["k"] ?? "bx") // dnjb
}
go()
