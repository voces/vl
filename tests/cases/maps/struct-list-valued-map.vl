// @run
// @log 2
// @log 7
// @log 15
// @log 0
// A STRUCT-LIST-valued map `{[string]: S[]}` — values are struct lists. The outer vals are a
// ref list whose element is the INNER struct-list WRAPPER (a ref list itself): nested ref
// lists. A new mv ref-list element kind 9 (confined to `mvShapeOfValName` so the broadly-used
// `refArrElemKind` is untouched) resolves to `rlWrapIdx` of the inner struct slot, interned
// first so its index is lower for the heap-resolution pass. `mvListValKind` → 5 (a ref list);
// `exprRefArray` / `refListElemNameOfExpr` recognize a `m[k]` / `m[k] ?? d` read as a struct
// ref list (so `.length` / `[i].field` / `for` resolve), and an empty `[]` default is hinted
// to a ref list of the inner struct. Was rejected ("unsupported map value type").

type P = { n: i32 }

function go() {
  const m: {[string]: P[]} = Map()
  m["a"] = [{ n: 7 }, { n: 8 }]
  print((m["a"] ?? []).length) // 2

  const xs = m["a"] ?? []
  print(xs[0].n) // 7
  let s = 0
  for p in xs { s = s + p.n }
  print(s) // 7 + 8

  // a MISS yields the empty-ref-list default.
  print((m["z"] ?? []).length) // 0
}
go()
