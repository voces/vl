// @check
// @error cannot infer a type for `m`
// ROBUSTNESS FLOOR: a `Map()` with no annotation has an unknown key/value type.
// Even WITH a subsequent use (`m.set("a", 1)`) it used to slip past the
// type-check gate and die in codegen as the opaque `Unhandled AST -> WASM
// "Unknown" type`. It must report a clean, source-located "cannot infer …
// annotate" diagnostic before codegen. (See `error-uninferred-annotated.vl` for
// the annotated form that compiles fine.)
const m = Map()
m.set("a", 1)
