// @run
// @log 2
// @log d
// A map whose VALUE is the `string | null` NICHE (`{[string]: string | null}`). SEMANTICS (USER
// SEMANTICS RULING 2026-07-23): `m[k] ?? d` with a NON-null default `d` coalesces on the read
// VALUE being null — a MISSING key AND a STORED null both take `d` — and types the result a
// NON-null `string`. So `print(m[k] ?? "d")` is a plain string print, no narrow (this was a loud
// emit reject under the old "stored null passes through" semantics). Only `?? null` stays
// `string | null` (see the narrowed spellings in nullable-value-map.vl).
function go() {
  const h0: {[string]: string | null} = Map()
  h0["k"] = "2"
  print(h0["k"] ?? "d")       // present -> 2
  print(h0["absent"] ?? "d")  // missing -> d
}
go()
