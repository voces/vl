// @run
// @log 686
// The array-of-struct sibling of `litunion-struct-field-value-closure-factory`: a map
// whose VALUE is a LIST of structs with a litunion-mix union field (`{[string]: {f: K0 |
// f64}[]}`), from a factory returning a closure over the built map. The map-value ref-list
// element `{f: K0 | f64}` softens `K0` → `string` THROUGH the array wrapper AND the struct-
// field nesting (`{f: string | f64}[]`) — the `[]` arm of `rlCanonLitUnionAtoms` descends
// into the struct arm — so both producers key ONE mv/map/ref-list slot instead of twinning.
type K0 = "686" | "lfvvb" | "txvpr"
function makeIt(): () => {[string]: {f: K0 | f64}[]} {
  const h0: {[string]: {f: K0 | f64}[]} = Map()
  h0["k"] = [{ f: 1.5 }, { f: "686" }]
  return () => (h0)
}
function go() {
  const v: () => {[string]: {f: K0 | f64}[]} = makeIt()
  const t0 = v()["k"] ?? [{ f: 1.5 }]
  const t1 = t0[1].f
  if t1 is K0 { print(t1) } else { print("OTHER") }
}
go()
