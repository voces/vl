// Regression: a NULLABLE closure returning a BARE map whose VALUE is a heterogeneous
// union (`(() => {[string]: i32 | string | {q: i64}}) | null`). `registerInlineUnion`'s
// nul-closure arm gates on value-union / map-MEMBER-union / variant-box results — a
// bare-map result matched none, so the map's VALUE union was never registered and its
// box/variant types never minted: the narrowed `t0()[k] ?? d` read referenced the
// DEFAULT type index ("expected struct type at index 0, found (array (mut i32))") —
// INVALID-WASM (fuzz post-#996 sweep branching leg, seed 499060527 case_00095). The
// arm now recurses into a bare-map result's value name — the nul-closure sibling of
// the bare-map value recursion and the #991 map-atom walk.
// @run
// @log NULL
// @log 5
// @log 9000000001
function useIt(p: (() => {[string]: i32 | string | {q: i64}}) | null) {
  const t0 = p
  if ((t0 != null)) {
    const t1 = t0()["k"] ?? 12121
    if (t1 is i32) { print(t1) } else { print("OTHER") }
    const t2 = t0()["s"] ?? 12121
    if (t2 is {q: i64}) { print(t2.q) } else { print("NOTQ") }
  } else {
    print("NULL")
  }
}
function go() {
  useIt(null)
  const h: {[string]: i32 | string | {q: i64}} = Map()
  h["k"] = 5
  h["s"] = { q: 9000000001 }
  useIt(() => (h))
}
go()
