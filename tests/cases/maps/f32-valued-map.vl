// @run
// @log 1.5
// @log 4
// @log 9
// An f32-VALUED map `{[string]: f32}` — the f32 sibling of the f64-valued map (mv-value kind
// 13: the scalar f32 list `fl32`/`fa32`, a typed f32 valStash, no `ref.as_non_null`). The
// checker accepts a float-literal value (`dstAdmitsF32` covers the nullable `f32?` map slot),
// and a `?? <float lit>` default keeps the result f32 (else `joinTys` would widen to f64 and a
// downstream `f32` slot would reject the demote). Was rejected ("cannot assign f64 to f32?").

function go() {
  const m: {[string]: f32} = Map()
  m["a"] = 1.5
  m["b"] = 2.5
  print(m["a"] ?? 0.0) // 1.5

  // sum the values (a `.values()` for-in over f32 scalars).
  let s: f32 = 0.0
  for v in m.values() { s = s + v }
  print(s) // 4

  // overwrite + a fresh read.
  m["a"] = 6.5
  const t: f32 = (m["a"] ?? 0.0) + (m["b"] ?? 0.0)
  print(t) // 6.5 + 2.5 = 9
}
go()
