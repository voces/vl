// @run
// @log 0
// REGRESSION (B6a, BUG 1): deleting then re-adding the SAME key in a loop must
// not grow the hash index unboundedly. The old `delete` unconditionally doubled
// the index on every call, so this trapped with "requested new array is too
// large" after ~25 iterations. With amortized compaction the index tracks the
// live count (here always 0 or 1), so 100 add+delete cycles stay bounded and
// `size` ends at 0.
let m: {[string]: i32} = Map()
let i = 0
while i < 100 {
  m["x"] = i
  m.delete("x")
  i = i + 1
}
print(m.length)            // 0 — no trap
