// @emit-error unsupported map value type
// A map whose VALUE is a 3-way union INCLUDING null and a ref composite (`{f: K0[]} | string
// | null`). The union box has no null arm; loud emit reject, never invalid wasm.
type K0 = "aa" | "bb"
function go() {
  const m: {[string]: {f: K0[]} | string | null} = Map()
  m["k"] = "hey"
  const v = m["k"] ?? "d"
  if v is string { print(v) }
}
go()
