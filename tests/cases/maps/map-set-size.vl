// @run
// @log 3
// @log 2
// @log 2
// `.size` on a Map / Set — the JS-API name for the live-entry count, identical to the
// existing `.length` (struct field 5 `size`, maintained by set/delete; NOT `count`, which
// includes tombstones). Previously the checker rejected it ("no field 'size' on map").

function go() {
  const m: {[string]: i32} = Map()
  m["x"] = 1
  m["y"] = 2
  m["z"] = 3
  print(m.size) // 3

  m.delete("z")
  print(m.size) // 2

  const s: {[string]: boolean} = Set()
  s.add("a")
  s.add("b")
  s.add("a") // duplicate — size stays 2
  print(s.size) // 2
}
go()
