// @run
// @log hello
// @log ?
// @log world
// @log yes
// @log no
// @log v
// @log p
// @log v
// @log on
// A string-VALUED map (`{[string]: string}`) crossing function BOUNDARIES — as a PARAMETER and
// as a RETURN. Previously only the MONO i32-valued map could cross (the boundary carried no
// value type); now the per-value-type mv slot (the map SHAPE) flows through `paramStructIdxOf` /
// the functype result / `mapShapeOfExpr`, so a `string`-valued map param/return resolves its
// value type on both sides. (A `boolean`-valued map rides the same shape -1 as i32.)

// PARAM: index-get with a `?? default`, mutation through the param, and `.has`.
function lookup(m: {[string]: string}, k: string) { return m[k] ?? "?" }
function put(m: {[string]: string}, k: string, v: string) {
  m[k] = v // mutates the caller's map (same ref)
}
function has(m: {[string]: string}, k: string) {
  if m.has(k) { return "yes" }
  return "no"
}

function go() {
  const m: {[string]: string} = Map()
  m["a"] = "hello"
  print(lookup(m, "a")) // hello
  print(lookup(m, "z")) // ?     (absent → default)
  put(m, "b", "world")
  print(lookup(m, "b")) // world (the mutation is visible)
  print(has(m, "a")) // yes
  print(has(m, "z")) // no
}
go()

// RETURN: annotated and inferred string-valued map factories, plus a param pass-through.
function annotated(): {[string]: string} {
  const m: {[string]: string} = Map()
  m["k"] = "v"
  return m
}
function inferred() {
  const m: {[string]: string} = Map()
  m["k"] = "p"
  return m
}
function passthru(m: {[string]: string}) { return m }

function go2() {
  print(annotated()["k"] ?? "?") // v
  print(inferred()["k"] ?? "?") // p
  print(passthru(annotated())["k"] ?? "?") // v   (a map flows in and back out)
  const b: {[string]: boolean} = Map()
  b["on"] = true
  if passthru2(b, "on") {
    print("on") // on
  } else {
    print("off")
  }
}
function passthru2(m: {[string]: boolean}, k: string) { return m[k] ?? false }
go2()
