// @emit-error print of a nullable string
// A map whose VALUE is the `string | null` NICHE (`{[string]: string | null}`) now has a real
// rep (the nullable ref-VALUE map: the vals slot carries a stored null, `??` preserves it) —
// but a DIRECT `print(m[k] ?? d)` of the fused read may genuinely see null, and print has no
// nullable-string rendering: narrowing is the supported spelling (`const t = m[k] ?? d;
// if t != null { print(t) }` — see nullable-value-map.vl). Loud emit reject, never invalid wasm.
function go() {
  const h0: {[string]: string | null} = Map()
  h0["k"] = "2"
  print(h0["k"] ?? "d")
}
go()
