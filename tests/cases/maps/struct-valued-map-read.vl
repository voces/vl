// @run
// @log 7
// @log 42
// @log 7
// @log b
// A STRUCT-valued map (`{[string]: S}`) read via `m[k] ?? default` classifies as the value
// struct — so an un-annotated `const p = m[k] ?? d` binds a struct local and `(m[k] ?? d).x`
// resolves the field. (The value lowering already worked under an explicit `: S` annotation;
// this closes the classification gap for the inferred / direct forms.)

type P = { x: i32 }
type Pt = { x: i32, y: i32 }
type Rec = { id: i32, tag: string }

function go() {
  const m: {[string]: P} = Map()
  m["a"] = { x: 7 }
  m["b"] = { x: 42 }
  const p = m["a"] ?? { x: 0 } // inferred struct local
  print(p.x) // 7
  print((m["b"] ?? { x: 0 }).x) // 42  (direct field access on the coalesce)

  const m2: {[string]: Pt} = Map()
  m2["o"] = { x: 3, y: 4 }
  const q = m2["o"] ?? { x: 0, y: 0 }
  print(q.x + q.y) // 7

  // A string field of the value struct.
  const m3: {[string]: Rec} = Map()
  m3["r"] = { id: 1, tag: "b" }
  print((m3["r"] ?? { id: 0, tag: "?" }).tag) // b
}
go()
