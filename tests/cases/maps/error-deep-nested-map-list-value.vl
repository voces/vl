// @emit-error unsupported map value type
// A nested map whose inner-value chain bottoms out in a LIST OF MAPS read two map levels deep
// (`{[string]: {[string]: {[string]: f32}[]}}`). The vals intern is recursive but the op sites
// resolve the element one level shallow → a runtime out-of-bounds cast. Loud emit reject
// instead. (A DIRECT list-of-maps map value — one level shallower — works.)
function makeIt(): {[string]: {[string]: {[string]: f32}[]}} {
  const leaf: {[string]: f32} = Map()
  leaf["k"] = 2.5
  const mid: {[string]: {[string]: f32}[]} = Map()
  mid["k"] = [leaf]
  const top: {[string]: {[string]: {[string]: f32}[]}} = Map()
  top["k"] = mid
  return top
}
function go() { const v = makeIt(); print(0) }
go()
