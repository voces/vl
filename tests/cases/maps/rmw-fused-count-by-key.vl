// @run
// @log 3
// @log 2
// @log 1
// @log 3
// B-chore-maprmw-fuse regression: the compiler's own `repSlotKeyN` build site
// re-fused to `n[k] = (n[k] ?? 0) + 1` once the published seed carried #918's
// map-SET lowering. This mirrors that exact shape — a fused missing-key RMW
// accumulating counts inside a loop, fresh map, keys repeating.
const keys: string[] = ["x", "y", "x", "z", "x", "y"]
const n: {[string]: i32} = Map()
let i = 0
while i < keys.length {
  n[keys[i]] = (n[keys[i]] ?? 0) + 1
  i = i + 1
}
print(n["x"] ?? -1) // 3
print(n["y"] ?? -1) // 2
print(n["z"] ?? -1) // 1
print(n.length)     // 3
