// @run
// @log 16
// @log 30
// @log 2
// @log 14
// @log -1
// @log 100
// @log 107
// @log false
// @log true
// @log a
// @log c
// @log e
// @log g
// @log i
// @log k
// @log m
// @log o
// @log za
// @log zb
// @log zc
// @log zd
// @log ze
// @log zf
// @log zg
// @log zh
// REGRESSION (B6a, BUGs 1+2): add/delete/re-add interleaved past the point that
// triggers amortized compaction, then assert correctness — `get`, `size`, and
// INSERTION-ORDER `keys()` all hold after the rebuild. Compaction rebuilds the
// index from the live entries, so a key that previously collided/probed past a
// now-deleted slot is still found (probe chains stay intact).
let alpha = "abcdefghijklmnopqrstuvwxyz"
let m: {[string]: i32} = Map()

// Insert 16 single-letter keys a..p (indices 0..15).
let i = 0
while i < 16 {
  m[alpha.slice(i, i + 1)] = i
  i = i + 1
}
// Delete every odd-indexed key (b,d,f,h,j,l,n,p) — enough dead entries to force
// at least one amortized compaction. Survivors: a,c,e,g,i,k,m,o (8 keys).
i = 1
while i < 16 {
  m.delete(alpha.slice(i, i + 1))
  i = i + 2
}

// Re-add 8 fresh distinct keys ("za".."zh") after the deletes.
i = 0
while i < 8 {
  m["z" + alpha.slice(i, i + 1)] = 100 + i
  i = i + 1
}
// Overwrite a survivor: value updates, position (first) is kept.
m["a"] = 30

print(m.length)            // 16 — 8 survivors + 8 re-added
print(m["a"] ?? -1)      // 30 — overwrite kept
print(m["c"] ?? -1)      // 2  — survivor keeps its original value
print(m["o"] ?? -1)      // 14 — survivor
print(m["b"] ?? -1)      // -1 — deleted, now absent
print(m["za"] ?? -1)     // 100 — re-added
print(m["zh"] ?? -1)     // 107 — re-added
print(m.has("d"))        // false — deleted
print(m.has("za"))       // true — re-added

// keys() in insertion order: surviving originals first (a,c,e,g,i,k,m,o), then
// the re-added z* keys in add order (za..zh). The overwrite of `a` kept it first.
for k in m.keys() { print(k) }
