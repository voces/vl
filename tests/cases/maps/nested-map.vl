// @run
// @log 5
// @log 7
// @log 2
// @log 12
// @log 100
// A NESTED map `{[string]: {[string]: i32}}` — a map whose values are inner maps. The
// outer vals are stored as a ref list whose element kind is 3 (a map element → the inner
// map struct), reusing the existing map-array element machinery; the mv-value kind 6
// rides the SAME ref-value spine as a struct-valued map (valStash a nullable map-struct
// ref, get/set/append through `array.get`/`array.set` + `ref.as_non_null`), only the
// element heap differs. Previously emit rejected it ("unsupported map value type").

function go() {
  const m: {[string]: {[string]: i32}} = Map()
  const a: {[string]: i32} = Map()
  a["x"] = 5
  a["y"] = 7
  m["a"] = a

  const b: {[string]: i32} = Map()
  b["z"] = 100
  m["b"] = b

  // chained read: outer `?? a` recovers the inner map, then inner `?? 0` the value.
  print((m["a"] ?? a)["x"] ?? 0) // 5
  print((m["a"] ?? a)["y"] ?? 0) // 7
  print(m.size) // 2

  // iterate an inner map (bound through the outer read) and sum its values.
  let total = 0
  const inner = m["a"] ?? a
  for k in inner { total = total + (inner[k] ?? 0) }
  print(total) // 5 + 7

  print((m["b"] ?? a)["z"] ?? 0) // 100
}
go()
