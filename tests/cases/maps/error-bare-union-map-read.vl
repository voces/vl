// @emit-error a bare `m[k]` read of a union-valued map
// A bare `m[k]` over a UNION-valued map is `V | null` with no nullable local rep (the
// vals element is the shared box; a nullable-box binding has no local kind yet) — a loud
// EMIT-stage reject pointing at the `m[k] ?? <default>` spelling. The LIST- and
// nested-MAP-valued bare reads GRADUATED to full support (`letNulMapReadValKind` binds
// their established nullable kinds — see maps/nested-map-and-list-value-reads.vl).
const m: {[string]: i32 | string} = Map()
function go() {
  const v = m["x"]
  print(1)
}
go()
