// @run
// @log 947.5
// @log 15.5
// @log 1
// @log 0
// A nested map whose inner-value chain bottoms out in a LIST OF MAPS, read two map
// levels deep (`{[string]: {[string]: {[string]: f32}[]}}` — map -> map -> list -> map).
// The value chain resolves recursively at every op site: the mv-slot interner completes
// ALL recursive interning (`ensureRefElem`, whose map-element arm re-enters
// `mvShapeOfValName`) BEFORE pushing the slot's parallel arrays, so the deep element
// read lands on a fully-resolved slot — a reentrant intern mid-push skewed the parallel
// tables and the compiler itself trapped out-of-bounds. Crosses a function-return
// boundary (the seam that forced the annotation-first intern order).
// (rep-fuzz: p2c/p2r `{[string]: {[string]: {[string]: f32}[]}}`.)
function makeIt(): {[string]: {[string]: {[string]: f32}[]}} {
  const leaf: {[string]: f32} = Map()
  leaf["k"] = 947.5
  const mid: {[string]: {[string]: f32}[]} = Map()
  mid["k"] = [leaf]
  const top: {[string]: {[string]: {[string]: f32}[]}} = Map()
  top["k"] = mid
  return top
}
function go() {
  const v = makeIt()
  const miss: {[string]: {[string]: f32}[]} = Map()
  const t0 = v["k"] ?? miss
  const fallback: {[string]: f32} = Map()
  fallback["k"] = 15.5
  const t1 = t0["k"] ?? [fallback]
  print(t1[0]["k"] ?? 15.5) // 947.5 — the buried leaf survives the deep read
  const u1 = t0["absent"] ?? [fallback]
  print(u1[0]["k"] ?? 0.0) // 15.5 — the miss arm yields the default list
  print(t1.length) // 1
  print(miss.size) // 0
}
go()
