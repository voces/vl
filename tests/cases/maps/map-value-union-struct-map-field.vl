// @run
// @log true
// @log 1.5
// @log 246
// @log zdmy
// A MAP whose VALUE is a union carrying a STRUCT arm that itself has a MAP field
// (`{[string]: {f: {[string]: boolean}} | f64}` — rep-fuzz `p0c/p0r`), and a
// STRUCT-VALUED map whose value struct carries a CLOSURE field, inside a union arm
// (`{f: {[string]: {f: (i32) => string}}} | i32` — rep-fuzz `p0c/p0r`). Both used to
// fail the loud slot find at the shape-text variant seam ("map value type has no
// interned slot"); the value-name recording + variant mv-slot intern + the narrowed
// member-receiver shape resolution let the whole composition lower. The read chains:
// map get → union `is` narrow → inner map get, and map get → struct field closure call.
type Boxed = {f: {[string]: boolean}} | f64

function go() {
  const inner: {[string]: boolean} = Map()
  inner["k"] = true
  const outer: {[string]: Boxed} = Map()
  outer["k"] = {f: inner}
  outer["d"] = 1.5
  const hit = outer["k"] ?? 0.25
  if hit is {f: {[string]: boolean}} { print(hit.f["k"] ?? false) } else { print(false) }
  const miss = outer["d"] ?? 0.25
  if miss is f64 { print(miss) } else { print(0.0) }

  // Struct-valued map (value struct carries a CLOSURE field) inside a union arm.
  const h1: {[string]: {f: (i32) => string}} = Map()
  h1["k"] = {f: (q0) => ("246")}
  const v: {f: {[string]: {f: (i32) => string}}} | i32 = {f: h1}
  if v is {f: {[string]: {f: (i32) => string}}} {
    const t1 = v.f["k"] ?? {f: (q2) => ("zdmy")}
    print(t1.f(1)) // 246 — the stored closure
    const t2 = v.f["miss"] ?? {f: (q3) => ("zdmy")}
    print(t2.f(1)) // zdmy — the default's closure
  } else {
    print(-1)
  }
}
go()
