// @run
// @log 3
// @log 9
// @log 7
// @log 11
// @log 3
// @log 8
// A map whose VALUE is a ref LIST crossing a CALL BOUNDARY — RETURNED from a function and passed
// as a PARAM. The map crosses as a `(ref $mapStruct)` (kind 6); `retMapFlag` only accepted scalar
// / string / struct value types, so a list-valued map return was not recognized as a map at the
// caller ("`??` is only supported on a map index get"). It now accepts any LIST or nested-MAP
// value — the value's interned `mvShapeOfValName` slot carries its `$mapStruct` across, and the
// recursive ref-list machinery makes the value store/read fall out, so a list-valued map returns
// / passes exactly as it binds locally.

type S = { v: i32 }
type Cat = { meow: i32 }
type Dog = { bark: i32 }

function mkI(): {[string]: i32[]} {
  const m: {[string]: i32[]} = Map()
  m["a"] = [1, 2, 3]
  return m
}

function mkS(): {[string]: S[]} {
  const m: {[string]: S[]} = Map()
  m["a"] = [{ v: 9 }]
  return m
}

function mkNested(): {[string]: S[][]} {
  const m: {[string]: S[][]} = Map()
  m["a"] = [[{ v: 7 }]]
  return m
}

function mkClo(): {[string]: ((i32) => i32)[]} {
  const m: {[string]: ((i32) => i32)[]} = Map()
  m["a"] = [(x) => x + 1]
  return m
}

function mkUni(): {[string]: (Cat | Dog)[]} {
  const m: {[string]: (Cat | Dog)[]} = Map()
  m["a"] = [{ meow: 3 }]
  return m
}

// a list-valued map as a PARAM (the boundary's other side).
function firstV(m: {[string]: S[]}): i32 { return (m["a"] ?? [])[0].v }

function go() {
  print((mkI()["a"] ?? [])[2]) // 3
  print((mkS()["a"] ?? [])[0].v) // 9
  print((mkNested()["a"] ?? [])[0][0].v) // 7
  print((mkClo()["a"] ?? [])[0](10)) // 11

  const x = (mkUni()["a"] ?? [])[0]
  if x is Cat {
    print(x.meow) // 3
  } else {
    print(-1)
  }

  const ms: {[string]: S[]} = Map()
  ms["a"] = [{ v: 8 }]
  print(firstV(ms)) // 8
}
go()
