// @run
// @log bb
// @log NULL
// A MAP VALUE struct carrying a nullable-litunion field (`{[string]: {a: string,
// f: K0 | null, z: f32}}`), reached through a map-MEMBER-union struct field
// (`{f: {[string]: …} | boolean}`): the value struct's `f` reps as the code-30 i32
// niche (atom id / `-1` sentinel), the map store's literal seeds the atom + null
// context, and the fused `m[k] ?? default` read yields the struct whose niche field
// narrows with `!= null` (a missing key's default carries `f: null`). rep-fuzz
// p2c/p2r `{f: {[string]: {a: string, f: K0 | null, z: f32}} | boolean}` (were
// REJECT: "binding's inline-shape type has an unsupported field").
type K0 = "aa" | "bb" | "cc"

function makeIt(): {f: {[string]: {a: string, f: K0 | null, z: f32}} | boolean} {
  const m: { [string]: { a: string, f: K0 | null, z: f32 } } = Map()
  m["k"] = { a: "x", f: "bb", z: 1.5 }
  return { f: m }
}

function go() {
  const v = makeIt()
  const t0 = v.f
  if t0 is { [string]: { a: string, f: K0 | null, z: f32 } } {
    const t1 = t0["k"] ?? { a: "d", f: null, z: 2.5 }
    const t2 = t1.f
    if t2 != null {
      print(t2) // bb
    } else {
      print("NULL")
    }
    const t3 = t0["missing"] ?? { a: "d", f: null, z: 2.5 }
    const t4 = t3.f
    if t4 != null {
      print(t4)
    } else {
      print("NULL") // NULL (the default's null field)
    }
  } else {
    print("OTHER")
  }
}
go()
