// @emit-error unsupported map value type
// A nested map whose inner value is a LIST OF NULLABLE i64 (`{[string]: {[string]: (i64 |
// null)[]}}`) — the deep nullable-element read mis-resolves the element heap. Loud emit
// reject, never invalid wasm. (The DIRECT `{[string]: (i64 | null)[]}` map value works.)
function go() {
  const inner: {[string]: (i64 | null)[]} = Map()
  inner["k"] = [1, null, 3]
  const m: {[string]: {[string]: (i64 | null)[]}} = Map()
  m["k"] = inner
  print(0)
}
go()
