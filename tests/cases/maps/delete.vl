// @run
// @log 3
// @log true
// @log 2
// @log -1
// @log false
// @log false
// @log a
// @log c
// @log 10
// @log 30
// @log true
// @log 0
// `m.delete(k)`: removes a key (returns whether it was present), decrements
// `.length`, and a subsequent `m[k]` is null. Crucially, DELETING THEN ITERATING
// preserves the insertion order of the REMAINING keys (tombstone keeps positions;
// the deleted entry is skipped) — and re-inserting a deleted key appends it at the
// end (a new position).
let m: {[string]: i32} = Map()
m["a"] = 10
m["b"] = 20
m["c"] = 30
print(m.length)             // 3

print(m.delete("b"))      // true — was present
print(m.length)             // 2
print(m["b"] ?? -1)       // -1 — gone
print(m.has("b"))         // false
print(m.delete("b"))      // false — already gone

// delete-then-iterate: a, c remain in insertion order (b skipped).
for k in m.keys() {
  print(k)                // a, c
}
for v in m.values() {
  print(v)                // 10, 30
}

// Deleting every key empties the map.
let one: {[string]: i32} = Map()
one["x"] = 1
print(one.delete("x"))    // true
print(one.length)           // 0
