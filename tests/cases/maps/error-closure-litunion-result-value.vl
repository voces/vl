// @emit-error unsupported map value type
// A map whose VALUE is a closure returning a LITERAL-UNION atom (`(i32) => K0`). The map read
// recovers the call result as `string` (K0's atom text) not the i32 atom id, so the print
// walks an i32 as a string ref — invalid wasm. Rejected loudly instead. (A closure → string /
// i64 / boolean value is fine, and the SAME closure works standalone / in an array.)
type K0 = "aa" | "bb"
function go() {
  const m: {[string]: (i32) => K0} = Map()
  m["f"] = (x) => "aa"
  const f = m["f"] ?? (q) => "bb"
  print(f(1))
}
go()
