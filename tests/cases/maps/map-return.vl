// @run
// @log 1
// @log 2
// @log 3
// @log 100
// @log 7
// @log 2
// A function can now RETURN a string-keyed mono map (`{[string]: i32}`) — a factory pattern.
// Pairs with map PARAMS: the map rep (kind 6, `(ref $mapStruct)`) crosses the call boundary in
// both directions. The CALLER classifies the returned map (`fnRetMap`) so `const r = mk()` is a
// map local and `mk()[k]` / `r["c"] = …` / `r.has(k)` route to the map lowering. The return is
// recognized whether ANNOTATED (`: {[string]: i32}`) or INFERRED — for an inferred return of a
// map LOCAL, the classifier reads the local's annotation (`retIsMapLocalAnnot`), since its kind
// isn't collected yet during the global return pass. (Mono i32 value, like map params; a
// ref/string-valued map return is still rejected cleanly, a tracked follow-up.)

// INFERRED return (no `: {…}` annotation): the returned map local is classified by annotation.
function mk() {
  const m: {[string]: i32} = Map()
  m["a"] = 1
  m["b"] = 2
  return m
}
const r = mk()
print(r["a"] ?? 0) // 1
print(r["b"] ?? 0) // 2
r["c"] = 3         // SET through the bound map-return
print(r["c"] ?? 0) // 3
if r.has("a") { print(100) } // 100

// ANNOTATED return.
function annotated(): {[string]: i32} {
  const m: {[string]: i32} = Map()
  m["k"] = 7
  return m
}
print(annotated()["k"] ?? 0) // 7

// Returning a map PARAM (the receiver flows straight through).
function passthru(m: {[string]: i32}) {
  return m
}
print(passthru(r)["b"] ?? 0) // 2
