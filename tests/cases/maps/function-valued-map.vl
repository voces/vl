// @run
// @log 10
// @log 6
// @log 50
// @log -1
// @log 14
// @log 15
// A FUNCTION-valued map (`{[string]: (i32) => i32}`). The checker accepted it (the assignment
// RHS lambda infers its param from the map value type), but the emitter had no closure
// map-value kind ("unsupported map value type"). `mvShapeOfValName` now classifies a function
// type value (`annArrowAt >= 0`) as mv-kind 14 — a ref list whose element is the closure
// fat-pointer (kind 5, heap `cloStructIdx`), the SAME rep an `((i32) => i32)[]` array uses. A
// bare `m[k]` reads back a NULLABLE closure (`exprNulClosure` / `letInfersNulClosure` → the
// kind-19 niche), narrowed `if f != null`; `m[k] ?? d` yields the non-null closure. The call
// resolves the sig from the value annotation (`call_ref`).

function id(x: i32): i32 { return x }
function adder(n: i32): (i32) => i32 { return (x) => x + n }

function go() {
  const m: {[string]: (i32) => i32} = Map()
  m["double"] = (x) => x * 2
  m["inc"] = (x) => x + 1

  const d = m["double"]
  if d != null { print(d(5)) } // 10
  const i = m["inc"]
  if i != null { print(i(5)) } // 6

  // overwrite a key, then read.
  m["double"] = (x) => x * 10
  const d2 = m["double"]
  if d2 != null { print(d2(5)) } // 50

  // a MISS reads back null.
  const miss = m["nope"]
  if miss != null { print(miss(1)) } else { print(-1) } // -1

  // `?? default` (a named function) yields the non-null closure.
  const f = m["inc"] ?? id
  print(f(13)) // 14

  // a CAPTURING closure value (`adder(5)` closes over `n`).
  m["add5"] = adder(5)
  const a = m["add5"]
  if a != null { print(a(10)) } // 15
}
go()
