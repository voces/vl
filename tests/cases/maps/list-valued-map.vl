// @run
// @log 3
// @log 2
// @log 6
// @log 9
// @log 3
// @log c
// @log 4
// @log 12000000000
// A LIST-valued map `{[string]: i32[]}` — values are i32 lists. The outer vals are a ref
// list whose element kind is 4 (the i32-list wrapper, as in `i32[][]`), reusing the same
// ref-value spine as a nested map (mv-value kind 6); only the element heap differs
// (`lTypeIdx`). The map-vs-list ambiguity of kind 6 is split by the ref-list element kind
// (`mvValIsMap` 3 / `mvValIsList` 4), so `m[k]` / `m[k] ?? d` classify as an i32 list and
// route through the list machinery. Previously rejected at emit ("unsupported map value
// type").

function go() {
  const m: {[string]: i32[]} = Map()
  m["a"] = [1, 2, 3]
  m["b"] = [10, 20]
  print((m["a"] ?? []).length) // 3
  print((m["b"] ?? []).length) // 2

  // iterate a fetched inner list and sum it.
  let s = 0
  const av = m["a"] ?? []
  for v in av { s = s + v }
  print(s) // 1 + 2 + 3

  // overwrite, then iterate the new list directly off the read.
  m["a"] = [4, 5]
  let s2 = 0
  for v in (m["a"] ?? []) { s2 = s2 + v }
  print(s2) // 4 + 5

  // GENERAL over the element type — string[] / f64[] / i64[] values ride the same ref-value
  // spine, the ref-list element kind picking the inner list's wrapper (6/7/8 → mkListIdx /
  // fl64TypeIdx / il64TypeIdx). An empty `[]` default is hinted to the value's wrapper.
  const sm: {[string]: string[]} = Map()
  sm["k"] = ["a", "b", "c"]
  print((sm["k"] ?? []).length) // 3
  let sr = ""
  for v in (sm["k"] ?? []) { sr = v }
  print(sr) // c

  const fm: {[string]: f64[]} = Map()
  fm["k"] = [1.5, 2.5]
  let fsum = 0.0
  for v in (fm["k"] ?? []) { fsum = fsum + v }
  print(fsum + 0.0) // 4

  const im: {[string]: i64[]} = Map()
  im["k"] = [5000000000, 7000000000]
  let isum: i64 = 0
  for v in (im["k"] ?? []) { isum = isum + v }
  print(isum) // 12000000000
}
go()
