// @run
// @log true
// @log HAS
// @log 5
// A map whose VALUE is a NULLABLE-ATOM niche (`boolean | null` — 0/1 with the spare `2` = null)
// reps as the MONO i32 map (no box): the value IS a plain i32 with a sentinel, NOT a ref-value
// map. Regression for the invalid-wasm hole where `mvValKindOfName` counted the value's union
// members (`boolean` + `null`) and BOXED the values into a union box, storing a raw i32 niche
// into a `(ref $box)` cell. (`K0 | null` — a nullable LITUNION value — is the atom twin; its atom
// values are StrLit-syntax so it stays a LOUD reject, not invalid wasm, at the map store guard.)
function go() {
  const h: {[string]: boolean | null} = Map()
  h["k"] = true
  const t = h["k"] ?? false
  if t != null { print(t) } else { print("NULL") }

  // A read that MISSES the key falls to the `??` default.
  const u = h["absent"] ?? false
  if u == null { print("NULL") } else { print("HAS") }

  // The niche value carried alongside a plain i32 map op keeps working.
  const g: {[string]: i32} = Map()
  g["n"] = 5
  print(g["n"] ?? 0)
}
go()
