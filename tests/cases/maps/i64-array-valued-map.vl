// @run
// @log 3
// @log 6
// @log 30
// An i64-ARRAY-valued map (`{[string]: i64[]}`). Storing a bare-integer array literal emitted
// invalid wasm: the value-store built `[1,2,3]` as the default i32-list (`(ref $lTypeIdx)`),
// which mismatched the i64-list element slot (`(ref null $il64TypeIdx)`). The store paths
// (append + overwrite) now seed the inner list kind from `mvListValKind` (20 → `pendingListKind
// = 6`), exactly as the `?? default` READ already did — so the literal builds the i64-list
// wrapper. (i32/f64/string array maps already worked: i32 is the default, and f64/string
// elements self-identify by literal; only bare integers defaulted to i32.)

function go() {
  const m: {[string]: i64[]} = Map()
  m["a"] = [1, 2, 3]
  const xs = m["a"] ?? []
  print(xs.length) // 3

  // sum the i64 elements via a for-in over the inner list.
  let t: i64 = 0
  for x in xs { t = t + x }
  print(t) // 6

  // overwrite the key (the overwrite store path seeds the inner kind too).
  m["a"] = [10, 20]
  const ys = m["a"] ?? []
  let u: i64 = 0
  for y in ys { u = u + y }
  print(u) // 30
}
go()
