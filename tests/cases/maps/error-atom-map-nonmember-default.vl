// @error `??` over an atom-valued map needs a member-literal (or atom) default
// An atom-valued map's fused `m[k] ?? d` result is the bare i32 atom id, so the default
// must itself be an atom: a MEMBER literal or an atom-typed expression. A general string
// (or a NON-member literal, which would mint a fresh id under a `string`-typed result)
// has the wrong rep — rejected loudly instead of emitting invalid wasm.
type K0 = "aa" | "bb"

function go() {
  const m: {[string]: K0} = Map()
  m["k"] = "aa"
  const s = "xx"
  print(m["k"] ?? s)
}
go()
