// Regression: `==` over a BARE litunion-valued map read (`m["k"] == "bbpt"` where m is
// `{[string]: K0}`). Two stacked defects: (1) a program whose ONLY litunion mention is
// a MAP VALUE left `gLitUnionUsed` at 0 (`anyLitUnionUsed` had no map-value arm), so
// every atom classifier short-circuited; (2) `exprIsLitAtom` had no arm for a map READ
// (the atom map rides the MONO mv slot — no per-slot value name), so the compare fell
// to the STRING-equality path, calling strEq with the raw i32 atom id: INVALID-WASM
// (the r4 residual of the nullable-nested-map family, scratchpad p245b). Now
// `anyLitUnionUsed` counts map-value litunions (nested, nullable-peeled) and
// `exprIsLitAtom`'s Index arm claims a read the checker typed as the (nullable) pure
// litunion — the typed-IR net.
// @run
// @log NULL
// @log bbpt
// @log ok
type K0 = "bbpt" | "00882"
function go() {
  const v: ({[string]: {[string]: K0}} | null)[] = [null]
  const t0 = v[0]
  if t0 != null { print("NN") } else { print("NULL") }
  const h0: {[string]: K0} = Map()
  h0["k"] = "bbpt"
  const h1: {[string]: {[string]: K0}} = Map()
  h1["k"] = h0
  const w: ({[string]: {[string]: K0}} | null)[] = [h1]
  const t1 = w[0]
  if t1 != null {
    const h2: {[string]: K0} = Map()
    h2["kk"] = "00882"
    const m = t1["k"] ?? h2
    if m["k"] == "bbpt" { print("bbpt") } else { print("WRONG") }
    if m["k"] != "00882" { print("ok") } else { print("WRONG2") }
  } else {
    print("NULL2")
  }
}
go()
