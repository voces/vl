// @run
// @log fbbnd
// @log d
// A LITERAL-UNION (atom) FIELD of a map-value struct, read via `map[k] ?? <inline literal>`,
// now widens to its MEMBER STRING instead of rendering the raw atom id. The map-value struct's
// litunion field is an i32 ATOM (interned in #847), and the read `t0.f` must widen the atom at
// `print`. But `??` typed its result via `joinTys(nonNull, default)`, which WIDENED the litunion
// struct field (`{f: K}`) to `string` when the inline default's field types bare `string` —
// divorcing the checked type from the atom rep, so `print` had no litunion members to widen and
// emitted the raw id. The `??` result is now the non-null LHS type whenever the default is
// assignable to it (with the field-wise object-literal coercion #851 added), which preserves the
// litunion field. The variable-default spelling (`?? d`, `d: {f: K}`) was already correct — this
// closes the inline-literal default (the form the fuzzer's `?? <same-shape dummy>` read emits).
type K0 = "28" | "fbbnd" | "r"
type K1 = "2" | "d" | "jx"

// A litunion field read through a MAP PARAM with an inline-literal default (mixed sibling reps:
// f32 `a`, i32 `z`). Stored member `"fbbnd"`, default member `"28"`.
function readViaParam(p: {[string]: {a: f32, f: K0, z: i32}}) {
  const t0 = p["k"] ?? {a: 3.5, f: "28", z: 11}
  print(t0.f)
}

// A map nested inside a STRUCT FIELD, i64 sibling, default is an inline literal. Stored `"d"`.
function readNested(p: {f: {[string]: {a: boolean, f: K1, z: i64}}}) {
  const t0 = p.f["k"] ?? {a: true, f: "2", z: 6000000000}
  print(t0.f)
}

function go() {
  const h0: {[string]: {a: f32, f: K0, z: i32}} = Map()
  h0["k"] = {a: 3.5, f: "fbbnd", z: 11}
  readViaParam(h0)

  const h1: {[string]: {a: boolean, f: K1, z: i64}} = Map()
  h1["k"] = {a: true, f: "d", z: 6000000000}
  readNested({f: h1})
}

go()
