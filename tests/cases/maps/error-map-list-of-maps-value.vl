// @emit-error unsupported map value type
// A map whose VALUE is a LIST OF MAPS (`{[string]: {[string]: string}[]}` — map -> list -> map):
// the map op sites resolve a list element one level too shallow when the element is itself a MAP
// or a NULLABLE (the same limitation the nested-map value arm gates on), and un-gated this value
// shape made the COMPILER ITSELF trap out-of-bounds while classifying. Loud emit reject — never a
// compiler crash — until the op sites migrate to the recursive resolver. (A list-of-STRUCT /
// list-of-scalar value, and a DIRECT list-of-maps binding, all still lower.)
function go() {
  const m: {[string]: {[string]: string}[]} = Map()
  print(1)
}
go()
