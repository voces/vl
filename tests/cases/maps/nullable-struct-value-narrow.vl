// @run
// @log 42
// @log 7
// @log hi
// @log 5
// @log MISS
// A map whose VALUE type is ALREADY nullable (`{[string]: {f: i64} | null}`): binding a
// read (`const v = m["k"]`) then narrowing it non-null (`if v != null { v.f }`) must type
// `v` as the plain non-null struct inside the branch. The read returns `mkNullableTy(mVal)`;
// when `mVal` is itself nullable this DOUBLE-nullables the type, so the `!= null` narrow —
// which peels ONE nullable layer via `nonNullTy` — left an inner `{f:i64}?` that a member
// access `.f` rejected as non-object. Fixed: `nonNullTy` COLLAPSES nested nullables
// (`Nullable(Nullable(X))` ≡ non-null `X`, sound), so the narrow reaches the value. Bind-
// then-narrow is the spelling (a bare `m["k"]` computed index is not a narrowable place).

function useOne(m: {[string]: {f: i64} | null}) {
  const v = m["k"]
  if v != null { print(v.f) } else { print("MISS") }
}

function useRich(m: {[string]: {a: i64, b: string} | null}) {
  const v = m["k"]
  if v != null {
    print(v.a)
    print(v.b)
  }
}

function go() {
  const m: {[string]: {f: i64} | null} = Map()
  m["k"] = { f: 42 }
  useOne(m) // 42
  const r: {[string]: {a: i64, b: string} | null} = Map()
  r["k"] = { a: 7, b: "hi" }
  useRich(r) // 7, hi
}
go()

// A GLOBAL nullable-struct-valued map narrows the same way, and an ABSENT key takes the
// else branch (the read is null).
const g: {[string]: {f: i64} | null} = Map()
function go2() {
  g["k"] = { f: 5 }
  const v = g["k"]
  if v != null {
    print(v.f) // 5
  } else {
    print("MISS")
  }
  const w = g["absent"]
  if w != null {
    print(w.f) // MISS
  } else {
    print("MISS")
  }
}
go2()
