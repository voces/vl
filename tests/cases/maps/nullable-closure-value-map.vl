// @run
// @hint Intentionally-unused parameter `_n`
// @log va
// @log d1
// @log d2
// @log vb
// @log 9000000000
// @log zdv
// @log 572369430583034501
// @log lxdz
// A map whose VALUE is a NULLABLE CLOSURE (`{[string]: (() => T) | null}`) ā€” the closure
// niche of the nullable-value map rep. The closure fat-pointer rides the SAME
// `(ref null $cloStruct)` vals element a non-null closure value uses (mv kind 14, resolved
// through `nulRefMapValInnerOf`'s closure arm); a bare `null` stores `ref.null`.
// SEMANTICS (USER SEMANTICS RULING 2026-07-23): the fused `m[k] ?? d` read coalesces on the
// value being null ā€” a MISSING key AND a STORED null both take `d` ā€” and a non-null default
// (a default closure) types the read a NON-null closure (no `!= null` narrow). Only `?? null`
// leaves it the kind-19 `nulclosure` niche, narrowed with `!= null`.
function nicheClosure() {
  const m: {[string]: (() => string) | null} = Map()
  m["a"] = () => ("va")
  m["b"] = null
  const t0 = m["a"] ?? () => ("d0")
  print(t0()) // present -> va
  // a STORED null now coalesces to the default closure
  const t1 = m["b"] ?? () => ("d1")
  print(t1()) // stored null -> d1
  // a missing key fires the default
  const t2 = m["c"] ?? () => ("d2")
  print(t2()) // missing -> d2
  // `?? null` stays nullable; an overwrite replaces the stored null with a closure
  m["b"] = () => ("vb")
  const t3 = m["b"] ?? null
  if t3 != null { print(t3()) } else { print("NULL-b2") } // present -> vb
  // a PARAM-carrying closure value with an i64 result, read via `?? null`
  const p: {[string]: ((i32) => i64) | null} = Map()
  p["x"] = (_n: i32) => (9000000000)
  const t5 = p["x"] ?? null
  if t5 != null { print(t5(1)) } else { print("NULL-x") } // present -> 9000000000
}

// The RETURN position, with the MAP itself also nullable (`{ā€¦} | null` ā€” the outer niche
// narrows first, then the value niche).
function makeNulMap(): {[string]: (() => string) | null} | null {
  const h0: {[string]: (() => string) | null} = Map()
  h0["k"] = () => ("zdv")
  return h0
}
function outerNullable() {
  const v: {[string]: (() => string) | null} | null = makeNulMap()
  if v != null {
    const t1 = v["k"] ?? () => ("zdmy")
    print(t1()) // present -> zdv
  } else {
    print("NULL")
  }
}

// A NESTED map bottoming in a nullable closure (`{[string]: {[string]: (() => i64) | null}}`):
// the inner map's value slot is the same closure niche, reached through the composition read.
function makeNested(): {[string]: {[string]: (() => i64) | null}} {
  const h0: {[string]: (() => i64) | null} = Map()
  h0["k"] = () => (572369430583034501)
  const h1: {[string]: {[string]: (() => i64) | null}} = Map()
  h1["k"] = h0
  return h1
}
function nested() {
  const v: {[string]: {[string]: (() => i64) | null}} = makeNested()
  const h2: {[string]: (() => i64) | null} = Map()
  h2["k"] = () => (13131313131)
  const t0 = v["k"] ?? h2
  const t1 = t0["k"] ?? () => (13131313131)
  print(t1()) // present -> 572369430583034501
}

// A NULLABLE-ATOM map value read through a closure-VALUE call receiver
// (`v()["k"] ?? <member>` over `() => {[string]: K0 | null}`): the mono niche (`-1`
// sentinel) rides the shared map ā€” `mapShapeOfExpr`'s call fallback gates on the
// checker-recorded NULLABLE litunion (the rendered value name would collapse to
// `string | null` and resolve a slot-less string-valued map).
type K0 = "80028" | "lxdz" | "tf"
function atomCallRecv() {
  const h0: {[string]: K0 | null} = Map()
  h0["k"] = "lxdz"
  const v: () => {[string]: K0 | null} = () => (h0)
  const t0: K0 = v()["k"] ?? "80028"
  print(t0) // present -> lxdz
}

function go() {
  nicheClosure()
  outerNullable()
  nested()
  atomCallRecv()
}
go()
