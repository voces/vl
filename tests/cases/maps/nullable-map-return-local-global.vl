// @run
// @log 42
// @log N
// @log LNULL
// @log G0
// @log filled
// @log 55
// A `{[string]: V} | null` (kind `nulmap`) round-trips through the RETURN, LOCAL, and GLOBAL
// positions too — each is the same `(ref null $mapStruct)` cell. A `return null` / `= null` /
// non-const global cell lowers as `ref.null $mapStruct`; a map value subtypes the nullable slot.
// An un-annotated `const r = mk(...)` infers the niche from the annotated return and narrows.

let g: {[string]: i32} | null = null

function mk(b: boolean): {[string]: i32} | null {
  if b {
    const m: {[string]: i32} = Map()
    m["x"] = 42
    return m
  }
  return null
}

function fill() {
  const m: {[string]: i32} = Map()
  m["x"] = 55
  g = m
  print("filled")
}

function go() {
  const r = mk(true)
  if r != null { print(r["x"] ?? -1) } else { print("N") } // 42
  const r2 = mk(false)
  if r2 != null { print(r2["x"] ?? -1) } else { print("N") } // N
  const local: {[string]: i32} | null = null
  if local != null { print(local["x"] ?? -1) } else { print("LNULL") } // LNULL
  if g != null { print(g["x"] ?? -1) } else { print("G0") } // G0
  fill()
  if g != null { print(g["x"] ?? -1) } else { print("G0") } // 55
}

go()
