// @run
// @log 5
// @log hi
// @log 7
// @log fallback
// A VALUE-UNION-valued map `{[string]: i32 | string}` — each value is the shared union BOX
// ref (`uBoxIdx`), stored in a ref list whose element kind is 2 (the union box), the SAME
// ref-value spine as a struct-valued map. The store boxes the value (`emitUnionCoerce`); a
// `m[k] ?? d` read yields the box (default coerced too); `exprUnion` classifies it and
// `unionNameOfExpr` resolves the value union's name so an UN-annotated `const v = m[k] ?? d`
// narrows/unboxes with `is`. Was rejected ("unsupported map value type").

function go() {
  const m: {[string]: i32 | string} = Map()
  m["a"] = 5
  m["b"] = "hi"

  // inferred-union bind + narrow (both atoms).
  const va = m["a"] ?? 0
  if va is i32 {
    print(va) // 5
  }
  const vb = m["b"] ?? 0
  if vb is string {
    print(vb) // hi
  }

  // overwrite an existing key, then read.
  m["a"] = 7
  const va2 = m["a"] ?? 0
  if va2 is i32 {
    print(va2) // 7
  }

  // a MISS falls to the (boxed) default.
  const vc = m["c"] ?? "fallback"
  if vc is string {
    print(vc) // fallback
  }
}
go()
