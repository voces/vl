// @run
// @log 1
// @log 1.5
// @log ab
// @log 1
// B-bug-maprmw regression, non-i32 value shapes: the fused missing-key RMW trapped
// (OOB array access) for every mv-slot value kind too — the append arm's stale-probe
// bug is shape-agnostic. Pins an i64, an f64, and a string value, plus a STRUCT-FIELD
// map receiver (`s.m[k] = (s.m[k] ?? 0) + 1`), which rides the same set lowering.

// i64-valued (scalar mv slot).
let a: {[string]: i64} = Map()
a["k"] = (a["k"] ?? 0) + 1
print(a["k"] ?? -1) // 1

// f64-valued (scalar mv slot), non-zero default.
let f: {[string]: f64} = Map()
f["k"] = (f["k"] ?? 0.5) + 1.0
print(f["k"] ?? -1.0) // 1.5

// string-valued (ref mv slot) — the RHS read routes through the slot's valStash,
// the same local the SET now stashes its value in; the stash write lands after
// all user code, so they cannot collide.
let s: {[string]: string} = Map()
s["k"] = (s["k"] ?? "a") + "b"
print(s["k"] ?? "?") // ab

// Struct-FIELD map receiver.
type Box = { m: {[string]: i32} }
const box: Box = { m: Map() }
box.m["k"] = (box.m["k"] ?? 0) + 1
print(box.m["k"] ?? -1) // 1
