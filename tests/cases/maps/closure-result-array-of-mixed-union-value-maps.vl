// Regression: a closure RETURNING an ARRAY of maps whose value is a MIXED
// litunion-alias + scalar + struct union (`{[string]: K0 | i64 | {q: i64}}[]`).
// The map's own local binding (`h0`/`h1`) keys the mv table CANONICALLY — a mixed
// litunion-alias value `K0 | i64 | {q: i64}` interns as `string | i64 | {q: i64}`
// (`mvCanonValName`), a box-backed 7-field map struct. But the closure-result array
// ELEMENT name preserves the `K0` alias (the `tyToEmitName` render, #945), and the
// kind-3 map-element heap resolver (`mAssignTypeIndices` second pass) looked the value
// name up RAW — a miss — leaving the element heap at the shared MONO map (i32-backed
// vals) while the captured maps are the box-backed struct: `array.new_fixed` of a
// `(ref $boxMap)` into a `(ref null $monoMap)`-element array = INVALID-WASM, which
// V8/wasmtime reject before the module runs (fuzz-sweep.0ZaYSm branching p2c). Fix:
// canonicalize the value name before the mv lookup, mirroring `mvShapeOfValName` /
// `mvSlotOfValNameFind`. The `| boolean` outer arm of the original draw is elided (its
// narrowing is a SEPARATE, pre-existing loud-reject gap) so the values round-trip and
// pin the fix at runtime.
// @run
// @log 5000000077
// @log 428
type K0 = "428" | "pnh" | "bhvtr"
function makeIt(): (i32, i32, i32) => {[string]: K0 | i64 | {q: i64}}[] {
  const h0: {[string]: K0 | i64 | {q: i64}} = Map()
  h0["k"] = 5000000077
  const h1: {[string]: K0 | i64 | {q: i64}} = Map()
  h1["k"] = "428"
  // @hint Intentionally-unused parameter `_q2`
  // @hint Intentionally-unused parameter `_q3`
  // @hint Intentionally-unused parameter `_q4`
  return (_q2, _q3, _q4) => ([h0, h1])
}
function go() {
  const v = makeIt()
  const t0 = v(1, 1, 1)
  const m0 = t0[0]
  const r0 = m0["k"] ?? "428"
  if r0 is i64 { print(r0) } else { print("NOI64") }
  const m1 = t0[1]
  const r1 = m1["k"] ?? "999"
  if r1 is K0 { print(r1) } else { print("NOK0") }
}
go()
