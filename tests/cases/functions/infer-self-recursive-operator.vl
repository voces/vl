// @run
// @log 55
// @log 15
// @log aaa
// @log 7
// @log 3
// A DIRECT self-recursive call feeding an OPERATOR is resolved to the function's
// provisional inferred type (its base-case returns so far), not a `TY_ERR` hole. Without
// that, `assignable(TY_ERR, string)` is vacuously true, so `+` would take its string
// form and pollute the inferred return to `i32 | string` (`operator '+' is not defined
// for i32 | string and i32 | string`). The base case decides the form: `fib`/`sum`/`ack`
// stay i32, `rep` stays string (the `""` base pins concat). Mutual recursion (`ping`/
// `pong`) is unaffected — it is still settled by the binding-group fixpoint. None are
// annotated.
function fib(n: i32) {
  if n < 2 { return n }
  return fib(n - 1) + fib(n - 2)
}
function sum(n: i32) {
  if n == 0 { return 0 }
  return n + sum(n - 1)
}
function rep(n: i32) {
  if n == 0 { return "" }
  return "a" + rep(n - 1)
}
function ack(m: i32, n: i32) {
  if m == 0 { return n + 1 }
  if n == 0 { return ack(m - 1, 1) }
  return ack(m - 1, ack(m, n - 1))
}
function ping(n: i32) {
  if n == 0 { return 0 }
  return 1 + pong(n - 1)
}
function pong(n: i32) {
  if n == 0 { return 0 }
  return ping(n - 1)
}
print(fib(10))
print(sum(5))
print(rep(3))
print(ack(2, 2))
print(ping(6))
