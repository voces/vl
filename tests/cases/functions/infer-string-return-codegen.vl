// @run
// @log 3
// A20: an un-annotated function returning a `let`-bound (built) string emits
// correctly when its result is field-accessed. The emitter classifies the return
// from the checker's INFERRED type (string), not the return-expression syntax — which
// misses a plain-variable return and previously crashed codegen ("field access
// receiver is not a struct"). A generic `self`-style function is NOT elaborated (its
// definition-time return is a per-call-site placeholder). No annotation is added.
function build(n: i32) {
  let s = ""
  let i = 0
  while i < n {
    s = s + "x"
    i = i + 1
  }
  s
}
print(build(3).length)
