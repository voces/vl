// @run
// @log 15
// @log 110
// @log 17
// Escaping closures (ROADMAP B4): a capturing function used as a *value* —
// returned from its defining scope, then called later. A function value is a
// fat pointer (a WasmGC struct of {table index, environment}); the environment
// rides along, so two closures of the same type keep distinct captures.
function makeAdder(n: i32) {
  function add(x: i32) x + n
  add
}
let f = makeAdder(5)
let g = makeAdder(100)
__store_i32__(0, 0)
__store_i32__(4, f(10))
__log__(0, 8)
__store_i32__(4, g(10))
__log__(0, 8)
// A closure can also escape inside an object field.
function makeO(k: i32) {
  function add(x: i32) x + k
  { go: add }
}
let o = makeO(7)
let h = o.go
__store_i32__(4, h(10))
__log__(0, 8)
