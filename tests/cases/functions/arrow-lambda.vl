// @run
// @log 42
// @log 42
// @log 7
// @log 15
// @log 37
// @log 6
// @log 21
// Arrow lambdas `(params) => body` are the sole anonymous-function syntax. They
// parse to a nameless FuncDecl that is lifted to a top-level function, with a
// closure value built at each use site (capturing the enclosing frame when the
// body references it). The body is a bare expression or a `{ … }` block.
const dbl = (n: i32) => n * 2
print(dbl(21))

const k = () => 42 // zero params
print(k())

const add = (a: i32, b: i32) => a + b
print(add(3, 4))

// Capture: the returned lambda closes over `x` from the enclosing frame.
function adder(x: i32): (i32) => i32 { return (y: i32) => x + y }
print(adder(5)(10))

// Block body with an explicit `return`.
const sq1 = (n: i32) => {
  const t = n * n
  return t + 1
}
print(sq1(6))

// Immediately-invoked: a parenthesized lambda is callable in place.
print(((n: i32) => n + 1)(5))

// Higher-order: an arrow lambda passed where a function type is expected.
function apply(fn: (i32) => i32, x: i32) fn(x)
print(apply((n: i32) => n * 3, 7))
