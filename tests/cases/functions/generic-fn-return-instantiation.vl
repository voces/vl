// @run
// @log 7
// @log 4
// @log ba
// @log 11
// A generic (un-annotated-param) function's RETURN type is instantiation-dependent — `a + b` over
// two holes yields the OPERAND type (i32+i32→i32, f64→f64, string→string), resolved per call site,
// NOT a collapsed `string`. (A hole is permissively assignable to string, so the string-concat fast
// path used to swallow `a + b` and type its result `string` for every instantiation — which both
// rejected a valid `const x: i32 = add(3, 4)` and let an invalid `const x: string = add(3, 4)`
// reach codegen. See soundness/xfail-generic-return-type-mismatch.vl.) Because the return now flows
// through the call-site binding, a generic function value also becomes assignable to a CONCRETE
// function type, so an annotated binding `const c: (f64,f64)=>f64 = add` materializes and calls the
// f64 instance.
function add(a, b) a + b

function go() {
  // the return concretizes to the call's argument type, checked against the binding annotation.
  const xi: i32 = add(3, 4)
  print(xi) // 7

  const xf: f64 = add(2.5, 1.5)
  print(xf) // 4.0 → 4

  const xs: string = add("b", "a")
  print(xs) // ba

  // an ANNOTATED function-typed binding accepts the generic value and runs at the annotation's type.
  const c: (f64, f64) => f64 = add
  print(c(7.5, 3.5)) // 11.0 → 11
}

go()
