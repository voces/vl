// @run
// @log -1
// @log 0
// @log 1
// @log 3
// @log 13
// @log anon
// @log vita
// The `return` keyword supports early returns: from branches, from inside a
// loop, and as a bare fall-through. The function's return type is inferred from
// the returned values (no annotation needed). Calling such a function directly
// in argument position (`print(classify(...))`) must evaluate it in value
// position, not drop it.
function classify(n: i32) {
  if n < 0 { return 0 - 1 }
  if n == 0 { return 0 }
  return 1
}
print(classify(0 - 5))
print(classify(0))
print(classify(42))

// Early return out of a loop; falls through to `return n` for a prime.
function firstFactor(n: i32) {
  for i in 2 to n {
    if n % i == 0 { return i }
  }
  return n
}
print(firstFactor(15))
print(firstFactor(13))

// Inferred string return through early returns.
function greet(name: string) {
  if name == "" { return "anon" }
  return name
}
print(greet(""))
print(greet("vita"))
