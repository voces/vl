// @run
// @log 14
// @log 20
// @log 8
// An un-annotated lambda on the RHS of an ASSIGNMENT infers its param types from the target,
// the same contextual typing a let-init / call-arg / return already gets. The checker only
// seeded the expected type at those positions, so `fs[i] = (n) => …` / `f = (n) => …` reported
// "cannot infer a type for parameter `n`". `checkNode`'s assignment arm now calls
// `seedExpected(rhs, lt)` before checking the RHS, and `seedExpected` peels a nullable expected
// type (a map / array element slot is `V | null`) to seed the inner function shape.

function apply(f: (i32) => i32, x: i32): i32 { return f(x) }

function go() {
  // indexed-assign an un-annotated lambda into a function array (the target's element type
  // `(i32) => i32` pins the param).
  const fs: ((i32) => i32)[] = [(x) => x + 1]
  fs[0] = (n) => n * 2
  print(fs[0](7)) // 14

  // reassign a closure-typed local with an un-annotated lambda.
  let f: (i32) => i32 = (x) => x + 1
  f = (n) => n * 2
  print(f(10)) // 20

  // the existing call-arg seeding still pins a directly-passed un-annotated lambda.
  print(apply((n) => n + 1, 7)) // 8
}
go()
