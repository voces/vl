// @run
// @log 5
// @log 1.5
// @log 5
// @log 15
// @log 5
// A BARE-EXPRESSION function body returning a narrower numeric literal now coerces to the
// declared return type. The implicit-return tail (`function f(): i64 5`, `(): f32 => 1.5`)
// shares `emitReturnValue` with the explicit `return e`, which promotes a narrower literal
// (`5` → i64, `1.5` → f32) to the declared float/i64 result. Before, the implicit path
// deliberately skipped the widening (to avoid mis-widening an already-typed tail like a
// closure `call_ref`) and emitted the literal at its DEFAULT type, trapping wasm validation
// (`expected i64, found i32`). The skip is obsolete — `emitExprAs{I64,F32,F64}` is a no-op
// pass-through on a value already of the right type (the float/i64 classifiers recognize a
// closure call_ref, a variable, etc.), so widening unconditionally is safe.

// Named bare-expression bodies — a single literal, and integer arithmetic that defaults to
// i32 then widens to the i64 return.
function five64(): i64 5
print(five64()) // 5

function onePointFive(): f32 1.5
print(onePointFive()) // 1.5

function sum64(): i64 2 + 3
print(sum64()) // 5

// Arrow-lambda bare bodies — the i64 closure-value return (supported) with the same
// literal-widening, as a single literal and as arithmetic.
const fifteen = (): i64 => 10 + 5
print(fifteen()) // 15

const lit64 = (): i64 => 5
print(lit64()) // 5
