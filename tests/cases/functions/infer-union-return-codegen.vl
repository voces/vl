// @run
// @log 5
// @log 2
// An UN-annotated function whose returns JOIN to a value union (`i32 | string`) now
// lowers end-to-end: the inferred union name drives `registerValueUnionName` (box
// interning), `fRetUni` (the result valtype), `emitUnionCoerce` at the return sites,
// and the caller's narrowing/unboxing — exactly the annotated path, no annotation. The
// `is string` narrow unboxes the value-union box: pick(true) → 5 (i32 arm),
// pick(false) → "hi" (string arm, length 2).
function pick(b: boolean) {
  if b { return 5 }
  return "hi"
}
const a = pick(true)
if a is string { print(a.length) } else { print(a) }
const b = pick(false)
if b is string { print(b.length) } else { print(b) }
