// @run
// @log 7
// @log 4
// @log xy
// @log 12
// @log 4
// @log 19
// A lambda bound to an UN-annotated `const`/`let` behaves EXACTLY like the equivalent named generic
// function — WITHOUT being hoisted into one. Its un-annotated params are inference holes; the
// emitter value-flow-monomorphizes one instance per call shape, and because the call rides through
// the binding's closure `call_ref`, a CAPTURING lambda's env travels with it. So the binding works
// at i32 / f64 / string, captures enclosing locals, and escapes through every typed boundary (a HOF
// parameter, an array element) — the whole generic-function-value machinery, reached by value flow
// rather than by an AST rewrite.
function go() {
  // monomorphized per call site at i32 / f64 / string.
  const add = (a, b) => a + b
  print(add(3, 4)) // 7
  print(add(2.5, 1.5)) // 4
  print(add("x", "y")) // xy

  // CAPTURING: the lambda reads an enclosing local, monomorphized per call (the env rides the
  // closure call) — a thing a top-level hoist fundamentally can't do.
  const n = 10.0
  const addN = (x) => x + n
  print(addN(2.0)) // 10.0 + 2.0 → 12
  print(addN(-6.0)) // 10.0 + -6.0 → 4

  // ESCAPES into a concrete function-typed array, dispatched by index.
  const mul = (a, b) => a * b
  const fs: ((i32, i32) => i32)[] = [add, mul]
  print(fs[0](3, 4) + fs[1](3, 4)) // 7 + 12 = 19
}

go()
