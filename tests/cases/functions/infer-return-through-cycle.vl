// @run
// @log 42
// The return type is determinable (it bottoms out in `addN`) even though inference
// must pass THROUGH a recursive cycle (tail -> blk -> fexpr -> head -> tail) reached
// from the body. Single-pass demand inference committed `void` here; the
// binding-group fixpoint resolves the whole group to i32. No return annotations.
function addN(x: i32) { x }
function mk(b: i32) { addN(b) }
function tail(stop: i32) {
  if stop == 0 { mk(42) } else { blk(stop - 1) }
}
function head(stop: i32) { tail(stop) }
function fexpr(stop: i32) { head(stop) }
function blk(stop: i32) { fexpr(stop) }
print(head(2))
