// @run
// @log hi
// @log hey
// @log yo!
// @log hello
// @log hello!
// @hint Intentionally-unused parameter `_n` (leading `_` marks it unused)
// A STRING-returning function used as a VALUE — bound, passed as an `(i32) => string`
// callback, or held in a struct field — now lowers when called, and its RESULT types as a
// string (print routing, concat, a string binding cell), where before it failed
// `function-value call arity has no interned signature`. A string return is the raw i32
// array `(ref $aTypeIdx)` — a NEW value-call result kind `>S`, the string analogue of the
// void (`>v`) and struct (`>sN;`) slices: `cloSigKeyExt` / `annRetKind("string")` mint it,
// the `$fnsig` functype emits `(ref $aTypeIdx)` as its result, `calleeReturnsString` (and
// `fRetStr` for a field-closure call) classify the result so `exprString` routes it.
function greet(_n: i32) { return "hi" }
const f = greet
print(f(1)) // hi (bound string closure)

function apply(g: (i32) => string, x: i32) { return g(x) }
function hey(_n: i32) { return "hey" }
print(apply(hey, 1)) // hey (an (i32) => string callback)

function yo(_n: i32) { return "yo" }
const g = yo
const s = g(1)
print(s + "!") // yo! (result bound to a string cell, then concatenated)

type Greeter = { say: (i32) => string }
function hello(_n: i32) { return "hello" }
const o: Greeter = { say: hello }
print(o.say(2)) // hello (string closure in a struct field)
const t = o.say(2)
print(t + "!") // hello! (field-closure string result bound to a cell, then concatenated)
