// @run
// @log 30
// @log 5
// @log 7
// @log a
// @log 5
// @log 5
// Closure VALUES with non-i32 parameters: a lifted lambda used as a function value can
// now take a function-typed, string, list, or struct-list parameter — its env-leading
// `$fnsig` encodes the param valtype (`cloParamTok`), where before only i32/f64/struct
// params were representable and anything else fell back to the all-i32 arity signature
// and trapped wasm validation. The args are pushed at their real valtypes (unchanged);
// only the interned signature key needed widening.

// Function-typed param — a higher-order lambda calling its closure argument.
const call3 = (g: (i32) => i32) => g(3)
print(call3((n: i32) => n * 10)) // 30

// string param.
const slen = (s: string) => s.length
print(slen("hello")) // 5

// i32[] param.
const head = (xs: i32[]) => xs[0]
print(head([7, 8])) // 7

// string[] param.
const first = (xs: string[]) => xs[0]
print(first(["a", "b"])) // a

// struct[] (ref-list) param.
type P = { x: i32 }
const firstX = (ps: P[]) => ps[0].x
print(firstX([{ x: 5 }])) // 5

// Higher-order through an annotated function-type param whose callback takes a string.
function apply(g: (string) => i32, s: string) g(s)
print(apply((x: string) => x.length, "hello")) // 5
