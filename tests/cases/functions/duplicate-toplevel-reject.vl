// @check
// @error redeclared foo
// A second top-level `function` of the same name is a redeclaration error,
// like a duplicate `let`/`const`. Before this was enforced the later hoist
// silently overwrote the earlier one and the last body won at run time.
function foo() { return 1 }
function foo() { return 2 }
print(foo())
