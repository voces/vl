// @run
// @log 0
// @log 1
// An un-annotated struct-union return (`A | B`) sharing a field COMMON to every variant
// (`tag`) now infers + lowers (this WAS the "cannot infer a union return type — annotate"
// floor; see inferred-struct-union-return.vl for the narrowing form). A common field
// reads directly off the union box with NO `is`-narrowing — the variant-agnostic read.
type A = { tag: i32, a: i32 }
type B = { tag: i32, b: i32 }
function pick(c: boolean) {
  if c { return { tag: 0, a: 1 } }
  return { tag: 1, b: 2 }
}
const r = pick(true)
print(r.tag) // 0
const r2 = pick(false)
print(r2.tag) // 1
