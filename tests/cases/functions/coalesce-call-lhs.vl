// @run
// @log 5
// @log -1
// @log 5000000000
// @log -2
// @log 1.5
// @log -3.5
// @log 5
// @log 10
// @log 200
// @log 42
// `f(x) ?? d` — a null-coalesce whose LEFT operand is a CALL returning a value union
// with `null` — now lowers, where before it failed `emitProgram: `??` is only
// supported on a map index get`. Unlike the ident/field `x ?? d` forms (which RE-READ
// their place in the non-null arm), a call cannot be re-evaluated (effects + cost), so
// its value-union box is STASHED once in a 1-slot `(ref $uBoxIdx)` scratch frame
// (`fnHasCoalesceCall` reserves it; functions without one keep a byte-identical
// layout), then the tag test + unbox read that single evaluation. Covers the scalar
// value-union-box atoms `i32 | null`, `i64 | null`, `f64 | null` — in print, argument,
// binding, and NESTED-default positions (one slot is sound: each `??` sets-tests-uses
// within its own evaluation, and the null arm never re-reads the box). The classifiers
// (`exprIsI64`/`exprIsF64`/`exprIsF32`) now type a value-union `??` by its unboxed atom
// (`coalesceAtomKind`), so `print`/numeric-context routing is correct — fixing the same
// gap for the ident form too (`print(<i64|null ident> ?? d)` previously trapped). A
// `string | null` / `boolean | null` (niche) or a multi-member result (still a box)
// remains deferred, with `const r = f(); r ?? d` as the workaround.
function pi(c: boolean) {
  if c { return 5 }
  return null
}
function pl(c: boolean) {
  if c { return 5000000000 }
  return null
}
function pf(c: boolean) {
  if c { return 1.5 }
  return null
}
function dbl(n: i32) {
  n + n
}
print(pi(true) ?? -1)  // i32 | null → present
print(pi(false) ?? -1) // → default
print(pl(true) ?? -2)  // i64 | null
print(pl(false) ?? -2)
print(pf(true) ?? -3.5) // f64 | null
print(pf(false) ?? -3.5)
print(pi(false) ?? (pi(true) ?? -9)) // nested call-LHS `??` in the default → 5
print(dbl(pi(true) ?? 100))          // argument position → dbl(5) = 10
print(dbl(pi(false) ?? 100))         // → dbl(100) = 200
const x = pi(true) ?? -1 // binding position
print(x + 37)            // 5 + 37 = 42
