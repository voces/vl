// @check
// @error 'pick' infers the union return type i32 | {x: i32} — type-valid, but an inferred return of this shape is not yet supported by codegen
// CONTRACT (must-error, UNSUPPORTED-LOWERING channel): an un-annotated function whose
// returns join to a union the emitter can't lower — here a SCALAR mixed with an
// anonymous struct shape (`valueUnionRetName` and `structUnionRetName` both render "")
// — floors with an emitter-capability admission, not a type-soundness verdict: the
// inference is correct (the message names the inferred type), and the diagnostic
// carries the stable `unsupported-lowering` code so tooling can tell codegen maturity
// apart from a type error. A pure value union (`i32 | string`) and a pure NAMED struct
// union (`Cat | Dog`, see inferred-struct-union-return.vl) both lower and do NOT floor.
function pick(c: boolean) {
  if c { return 1 }
  return { x: 2 }
}
function go(c: boolean) {
  const v = pick(c)
  if v is i32 { print(v) }
}
go(true)
