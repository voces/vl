// @run
// @log hi
// @log none
// @log 1
// @log 0
// @log 9
// @log 4
// @log 7
// @log none
// @log set
// Struct FIELDS now carry the SAME full type capability as variables: the niche nullables
// `string | null` (code 20, a `(ref null $aTypeIdx)` slot) and `boolean | null` (code 21,
// the i32 sentinel), plus the variant-box unions — a HETEROGENEOUS union (`A | i32`) and a
// STRUCT union (`A | B`), which ride the same kind-16 `uBoxIdx` box as a value union.
// Before, all of these failed `emitProgram: only i32 / boolean / string / array struct
// fields are supported`. An inline-union FIELD annotation is registered in `collectU` (a
// new `TypeDecl` scan) so it interns its variant heap types; the field read / write / `??`
// / `!= null` paths reuse the generic niche + box lowerings (the `??` niche paths were
// hoisted to apply to a member field, not just an ident). Nested variant field access
// through a field path (`s.v.a`) narrows via the member path key.
type T = { name: string | null, on: boolean | null }
function niche() {
  const a: T = { name: "hi", on: true }
  print(a.name ?? "none") // hi
  const b: T = { name: null, on: false }
  print(b.name ?? "none") // none
  print(a.on ?? false) // 1
  print(b.on ?? false) // 0
}
niche()
type A = { a: i32 }
type B = { b: i32 }
type U = { v: A | i32 }
type S = { v: A | B }
function unions() {
  const h: U = { v: 9 }
  if h.v is i32 {
    print(h.v) // 9 (heterogeneous field)
  } else {
    print(h.v.a)
  }
  const h2: U = { v: { a: 4 } }
  if h2.v is i32 {
    print(h2.v) // 4
  } else {
    print(h2.v.a)
  }
  const s: S = { v: { a: 7 } }
  if s.v is A {
    print(s.v.a) // 7 (struct-union field, nested access)
  } else {
    print(-1)
  }
}
unions()
// Field WRITE on a niche field: `a.name = null`, then a string.
function wr() {
  const a: T = { name: "x", on: null }
  a.name = null
  print(a.name ?? "none") // none (wrote null)
  a.name = "set"
  print(a.name ?? "none") // set
}
wr()
