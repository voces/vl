// @run
// @log 1
// @log 2.5
// @log 5000000000
// @log 7
// @log 1
// @log 2
// @log 1.5
// @log 2.5
// @log 10.5
// @log 20.5
// A value-position if-EXPRESSION whose branch-join is a NON-i32 scalar rep (f64 / f32 /
// i64) lowers with that rep's single-byte blocktype (0x7c / 0x7d / 0x7e), not the i32
// default — and both arms are emitted COERCED to the join, so a mixed `then 1 else 2.5`
// widens its i32 then-arm to f64. Previously these produced a type-invalid module (an
// i32 blocktype over f64/i64 arm values). Covers print/return value positions, an `else
// if` chain (one shared blocktype down the chain), and a function-local binding whose
// slot valtype is inferred from the if-expr init (`letIsF64`, like `letIsI64`). An
// un-annotated *global* binding from a non-literal init stays out of scope (annotate
// `: f64`), exactly as for an i64/call-returning global today.
const c = true
const d = false
print(if c then 1 else 2.5)        // i32 then-arm widens into the f64 join
print(if d then 1 else 2.5)
const big: i64 = 5000000000
print(if c then big else 7)        // i64 join; the i32 `7` arm extends to i64
print(if d then big else 7)
print(if c then 1.0 else if d then 2.0 else 3.0)  // else-if chain, one f64 blocktype
print(if d then 1.0 else if c then 2.0 else 3.0)
function lf(b: boolean) {
  const r = if b then 1.5 else 2.5 // local slot valtype inferred f64 from the init
  print(r)
}
lf(true)
lf(false)
function rf(b: boolean): f64 {
  if b then 10.5 else 20.5         // f64 return-tail if-expr
}
print(rf(true))
print(rf(false))
