// @run
// @log true
// @log 7
// @log y
// @log z
// @log 5
// A function-type ANNOTATION may now have a UNION / NULLABLE return — `(i32) => A | B`,
// `(i32) => S | null`, `(i32) => string | null` — so such a function passes as a callback
// PARAM or a struct FIELD (not only the bound form), and the call result narrows / `??`-
// coalesces. Before, the checker rejected the annotation outright (`called value is not a
// function`). Two pieces: (1) the checker parses a top-level `=>` as binding LOOSER than
// `|`, so `(i32) => i32 | string` is a function RETURNING a union, not `((i32) => i32) |
// string` (the `isTopLevelFuncTypeName` guard on the union/intersection split); (2) the
// emitter's `annRetKind` maps such a return to its closure-sig suffix (`>u` / `>nN;` /
// `>N`), matching `cloRetKeySuffix` for the underlying function, so the value call
// resolves and the result classifies (`unionNameOfExpr` resolves the callback / field
// callee's union NAME for narrowing). (A genuine union of a function — `((i32) => i32) |
// null`, arrow nested in parens — still parses as a union; calling it is a later slice.)

// UNION return, as a callback PARAM — the result narrows + is used.
function applyU(g: (i32) => i32 | string, x: i32) { return g(x) }
function classify(n: i32): i32 | string {
  if n > 0 { return n }
  return "neg"
}
print(applyU(classify, 1) is i32) // true

// UNION return, as a struct FIELD — narrow + use.
type Classifier = { run: (i32) => i32 | string }
const c: Classifier = { run: classify }
const r = c.run(7)
if r is i32 {
  print(r) // 7
}

// string | null return, as a callback PARAM.
function applyN(g: (i32) => string | null, x: i32) { return g(x) }
function maybeName(n: i32): string | null {
  if n > 0 { return "y" }
  return null
}
print(applyN(maybeName, 1) ?? "z") // y
print(applyN(maybeName, 0) ?? "z") // z

// S | null return, as a struct FIELD — narrow + deref.
type P = { x: i32 }
type Maker = { make: (i32) => P | null }
function maybePoint(n: i32): P | null {
  if n > 0 { return { x: n } }
  return null
}
const m: Maker = { make: maybePoint }
const p = m.make(5)
if p != null {
  print(p.x) // 5
}
