// @run
// @log 1
// @log 10
// @log 2
// @log 7
// A NAMED function with an un-annotated body whose tail is a STRUCT-valued `if`-expression
// (`function pick(c) if c > 1 then mk(1) else mk(2)`). The return-type inference recorded only
// scalar / string / list names from the checker (a struct name is excluded there), and the
// expression fallback classifies a bare tail value only for anonymous lambdas — so a named
// function's inferred struct return through an `if`-join went unclassified, and the caller's
// `pick(…).field` failed ("field access receiver is not a struct"). `computeRetInference` now
// classifies a tail value-`if` directly (`exprStruct`/`structIndexOfExpr` see through it), so the
// result types as the join's struct. A bare tail value (`function first() mk(7)`) already worked.

type P = { x: i32, y: i32 }

function mk(n: i32): P { return { x: n, y: n * 10 } }

// tail STRUCT if-value, un-annotated return.
function pick(c: i32) if c > 1 then mk(1) else mk(2)

// an else-if chain whose arms are all the same struct.
function tier(c: i32) if c > 9 then mk(1) else if c > 3 then mk(2) else mk(3)

// a bare struct tail value (the non-`if` case, for contrast).
function first() mk(7)

function go() {
  const p = pick(5)
  print(p.x) // 1
  print(p.y) // 10 (field layout resolved → second field reads correctly: mk(1).y = 1*10)

  print(tier(5).x) // 2 (middle arm)

  print(first().x) // 7
}
go()
