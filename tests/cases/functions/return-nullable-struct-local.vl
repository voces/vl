// @error 'mk' infers the nullable return type
// Returning a NULLABLE-struct local from an un-annotated function stays the
// checker's explicit-annotation policy (an inferred nullable return is
// rejected with an annotate-the-return hint) — the diagnostic, not a
// miscompile.
type Ctx = { a: i32 }

function mk(f: i32) {
  const c: Ctx | null = if f > 0 then { a: 9 } else null
  return c
}

const r = mk(1)
if r != null { print(r.a) }
