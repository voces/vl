// @error cannot infer a nullable return type for 'mk'
// Returning a NULLABLE-struct local from an un-annotated function stays the
// checker's explicit-annotation policy (a nullable return type is never
// inferred) — the diagnostic, not a miscompile.
type Ctx = { a: i32 }

function mk(f: i32) {
  const c: Ctx | null = if f > 0 then { a: 9 } else null
  return c
}

const r = mk(1)
if r != null { print(r.a) }
