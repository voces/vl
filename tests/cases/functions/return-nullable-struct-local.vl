// @error infers the nullable return type
// Returning a NULLABLE-struct local from an un-annotated function is
// type-valid but not yet lowered by codegen — the checker asks for an explicit
// return annotation (the diagnostic, not a miscompile).
type Ctx = { a: i32 }

function mk(f: i32) {
  const c: Ctx | null = if f > 0 then { a: 9 } else null
  return c
}

const r = mk(1)
if r != null { print(r.a) }
