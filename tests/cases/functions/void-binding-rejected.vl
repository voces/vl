// @error cannot bind the void result of 'x' — a void function returns no value
// Binding the result of a VOID function has no value to bind, so it is a clean,
// source-located type error — NOT a codegen crash. The assignment path (`x = f()`) and
// expression/argument positions (`f() + 1`, `g(f())`) already rejected void; the BINDING
// path (`const x = f()`) did not — an un-annotated binding had no assignability check and
// `assignableExpr(void, T)` is lenient, so a void binding slipped past `vl check` and died
// in codegen with an opaque wasm error. The checker now rejects it where the initializer
// types `void` (compared structurally — `void`, like `null`, may intern at more than one
// arena index), EXCEPT an if-EXPRESSION init (a statement-if is context-free `void` but
// the if-binding inference resolves it to `T | null`).
function f() { print(1) }
const x = f()
print(x)
