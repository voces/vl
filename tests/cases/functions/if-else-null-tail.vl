// @run
// @log 5
// @log -1
// @log 2
// @log -1
// @log 1
// @log -1
// An `if`/`else` EXPRESSION in TAIL position (the implicit return) with a `null` branch.
// Before, a trailing `null` wasn't a tail value (`stmtIsTailValue` omitted `NullLit`), so
// the if fell to the void-statement path and failed `unsupported statement in body`. Now
// the implicit-return tail routes through the SAME `emitReturnValue` as `return e`, so a
// `null` arm boxes / sentinels / `ref.null`s per the function's return type. Covers all
// three nullable reps: i32|null (box), string|null (ref), boolean|null (niche, via an
// else-if chain).
function fi(b: boolean): i32 | null {
  if b { 5 } else { null }
}
function fs(b: boolean): string | null {
  if b { "hi" } else { null }
}
function fb(n: i32): boolean | null {
  if n == 0 { true } else if n == 1 { false } else { null }
}
const a = fi(true)
if a != null { print(a) } else { print(-1) }
const a2 = fi(false)
if a2 != null { print(a2) } else { print(-1) }
const s = fs(true)
if s != null { print(s.length) } else { print(-1) }
const s2 = fs(false)
if s2 != null { print(s2.length) } else { print(-1) }
const c = fb(0)
if c != null { if c { print(1) } else { print(0) } } else { print(-1) }
const c2 = fb(2)
if c2 != null { if c2 { print(1) } else { print(0) } } else { print(-1) }
