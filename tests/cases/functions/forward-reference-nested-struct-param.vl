// @run
// @log 110
// A FORWARD reference passing a NESTED / multi-field struct value through to a
// later-declared callee. Exercises that the hoisted-signature param patch
// carries the full resolved shape (a struct whose field is itself a struct),
// not just a flat single-field struct, so a deep `o.inner.v` read lowers
// correctly across the forward boundary.
type Inner = { v: i32 }
type Outer = { inner: Inner, n: i32 }
function f(o: Outer): i32 {
  return g({ inner: { v: o.inner.v * 2 }, n: o.n })
}
function g(o: Outer): i32 {
  return o.inner.v + o.n
}
print(f({ inner: { v: 5 }, n: 100 }))
