// @run
// @log 1
// @log 2
// @log 7
// @log 2.5
// @log hi
// @log true
// @log -1
// @log 7
// @log 9
// A union mixing STRUCT-ref variants with SCALAR value-atoms — `A | B | i32 | f64 |
// boolean | string | null` — is now representable as a variable, where before it failed
// `emitProgram: only i32 locals are supported`. There are two union machineries that
// share the SAME `uBoxIdx` `{tag, value}` box: a value union (`i32 | string`) boxes
// scalar atoms, a struct union (`A | B`) boxes variant structs — both tag-discriminated.
// The gap was the CLASSIFIER/registration rejecting a union that mixed the two: a struct
// ref variant with a bare scalar fell between `isValueUnionName` (all scalar) and the
// all-struct path. `isVariantBoxUnion` now admits the mix (≥1 struct + value-atoms),
// registers the struct members as variants AND marks the scalars' value boxes, and
// `emitUnionCoerce` boxes a scalar arm (an object arm auto-boxes as a variant struct).
// `is`-narrowing then dispatches each member by tag — exactly as the homogeneous unions
// already did. (A numeric atom reached by a DOUBLE-complement `else` is a pre-existing
// narrowing limitation shared with value unions, so each numeric arm uses an explicit
// `is`.)
type A = { a: i32 }
type B = { b: i32 }
function show(x: A | B | i32 | f64 | boolean | string | null) {
  if x is A { print(x.a) }
  else if x is B { print(x.b) }
  else if x is i32 { print(x) }
  else if x is f64 { print(x) }
  else if x is string { print(x) }
  else if x is boolean { print(x) }
  else { print(-1) }
}
show({ a: 1 }) // 1
show({ b: 2 }) // 2
show(7) // 7
show(2.5) // 2.5
show("hi") // hi
show(true) // true
show(null) // -1 (null arm)
// A mixed union as a RETURN + an inferred binding.
function pick(c: boolean): A | i32 {
  if c { return { a: 7 } }
  return 9
}
function useRet(c: boolean) {
  const r = pick(c)
  if r is A { print(r.a) } else { print(r) }
}
useRet(true) // 7
useRet(false) // 9
