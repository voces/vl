// @run
// @log 6
// @log -1
// @log 10
// @log -1
// @log 8
// A NULLABLE function value as a STRUCT FIELD — `{ op: ((i32) => i32) | null }` — holds a
// function OR `null`, narrows with `if recv.op != null`, and calls the recovered function.
// The field-form completion of A-nullable-function-value (which covered local bindings) and
// A-nullable-function-param (params): a struct field carries the SAME nullable closure
// fat-pointer as a kind-19 local, encoded as a NEW FIELD CODE 22 — `(ref null $cloStruct)`
// storage (`pushFieldStorage`), a `null` field value lowering as `ref.null $cloStruct` (a
// `pendingNulClosure` seed in `emitObj`, and `emitOmittedFieldNull` for an omitted field),
// the field read narrowing with `ref.is_null` and the call recovering non-null
// (`ref.as_non_null`) before `call_ref` — both driven by `exprNulClosure`'s Member case,
// with `structFieldIsClosure` routing `recv.op(x)` to the `call_ref` path.
type Handler = { op: ((i32) => i32) | null }
function inc(n: i32) { return n + 1 }
function dbl(n: i32) { return n * 2 }

// Narrowed + called, or the null branch taken.
function apply(h: Handler, x: i32) {
  if h.op != null { return h.op(x) }
  return -1
}

print(apply({ op: inc }, 5)) // 6   (a named function field value)
print(apply({ op: null }, 5)) // -1  (a null field → the fallback)
print(apply({ op: dbl }, 5)) // 10  (a distinct function field)

// An OMITTED nullable field defaults to `null` (the completion coercion), so the guard
// fails and the fallback is taken.
type Tagged = { tag: i32, op: ((i32) => i32) | null }
function applyTagged(t: Tagged, x: i32) {
  if t.op != null { return t.op(x) }
  return -1
}
print(applyTagged({ tag: 1 }, 5)) // -1  (op omitted → null)

// A field read passed THROUGH to a nullable-closure local, then narrowed + called.
function via() {
  const t: Tagged = { tag: 2, op: inc }
  const g: ((i32) => i32) | null = t.op
  if g != null {
    print(g(7)) // 8
  }
}
via()
