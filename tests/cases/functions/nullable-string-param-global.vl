// @run
// @log 1
// @log 0
// @log 5
// @log -1
// `string | null` as a PARAMETER and a module GLOBAL (with reassignment). A `null`
// argument / a `g = null` assignment emits `ref.null $aTypeIdx`; a string stays the
// array ref; `!= null` is the sentinel-free `ref.is_null`. param: has("x") → 1,
// has(null) → 0; global: g="hello" → length 5, then g=null → -1.
function has(x: string | null) {
  if x != null { print(1) } else { print(0) }
}
has("x")
has(null)
let g: string | null = "hello"
if g != null { print(g.length) } else { print(-1) }
g = null
if g != null { print(g.length) } else { print(-1) }
