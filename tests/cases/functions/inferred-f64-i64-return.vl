// @run
// @log 7
// @log 4
// @log 5000000001
// @log 8
// An UN-ANNOTATED function with an inferred f64 (or i64) return now lowers when CALLED,
// where before it crashed codegen with a wasm type mismatch IN the callee (`expected i32,
// found f64`). The inferred-return functype emission picked the result valtype from the
// `fRet*` tables for string / array / union / nullable / struct / `string|null` — but
// NEVER `fRetF64` / `fRetI64`, so an inferred f64/i64 return declared an i32 result while
// the body returned f64/i64. The flags WERE set (the checker exports the inferred scalar
// name, `buildFnMap`'s A20 pass sets `fRetF64`/`fRetI64` exactly as for `string`/`i64`) —
// only the functype-result switch was missing the two scalar cases. The annotated `: f64`
// / `: i64` path always worked (via `vtKindOfType`), which is why every existing f64/i64
// corpus case — all explicitly annotated — masked this.
function dbl(n: f64) { return n * 2.0 }
print(dbl(3.5)) // 7
// Through a wrapper (the call result is the inferred-f64 callee's).
function w() { return dbl(2.0) }
print(w()) // 4
// Inferred i64 return.
function big(n: i64) { return n + 1 }
const r: i64 = big(5000000000)
print(r) // 5000000001
// The f64 result flows into an annotated f64 binding (used + re-doubled).
const v: f64 = dbl(2.0)
print(dbl(v)) // 8 (2.0 -> 4.0 -> 8.0)
