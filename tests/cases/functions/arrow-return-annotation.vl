// @run
// @log 6
// @log 7
// @log hi
// @log 3
// @log 20
// Arrow lambdas may carry an OPTIONAL return-type annotation `(params): Ret => body`,
// completing the `function`-form parity (which always allowed `: Ret`). The lookahead
// commits to a lambda when a `:` (or `=>`) follows the matching `)` — unambiguous since
// `vl` has no `?:` ternary, so no `(group):` arises in expression position. The annotation
// parses into the same `fnRet` the named form uses, so checker/emitter are unchanged; the
// formatter preserves it verbatim (it would otherwise silently drop a load-bearing type).

// Explicit i32 return.
const inc = (n: i32): i32 => n + 1
print(inc(5)) // 6

// Explicit i64 return — the annotation pins the wider result up front.
const seven = (): i64 => {
  const x: i64 = 7
  return x
}
print(seven()) // 7

// Explicit string and list returns.
const greet = (): string => "hi"
print(greet()) // hi

const triple = (): i32[] => [1, 2, 3]
print(triple()[2]) // 3

// A return annotation on a higher-order argument.
function apply(f: (i32) => i32, x: i32) f(x)
print(apply((n: i32): i32 => n * 2, 10)) // 20
