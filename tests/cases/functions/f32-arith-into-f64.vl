// @run
// @log 3.5
// @log 5
// @log 11.5
// An f32 ARITHMETIC expression flowing into an f64 slot (an f64 return, an f64 binding) now widens
// correctly instead of emitting invalid wasm. `x + 1.0` with `x: f32` EMITS as f32 — a float literal
// re-encodes to the f32 operand — but `exprIsF64` also claims it via that literal, so the f64
// coercion (`emitExprAsF64`) took its fast path and pushed an f32 into the f64 slot ("expected f64,
// found f32"). `emitExprAsF64` now checks the f32 case FIRST and promotes (`f64.promote_f32`); a
// pure-f64 expression is not `exprIsF32`, so it stays on the byte-identical fast path.
function inc(x: f32): f64 { return x + 1.0 }

function go() {
  const a: f32 = 2.5
  print(inc(a)) // 2.5 + 1.0 → 3.5

  // an f64 binding initialized from an f32 arithmetic expression.
  const r: f64 = a * 2.0
  print(r) // 2.5 * 2.0 → 5

  // a longer f32 arithmetic chain widened to the f64 binding.
  const s: f64 = a + a + a + 4.0
  print(s) // 2.5 * 3 + 4.0 → 11.5
}

go()
