// @log 1
// @log 0
// Mutually-recursive functions with a base case now infer their return types with
// NO annotations (binding-group fixpoint inference): even/odd resolve to i32.
function isEven(n: i32) { if n == 0 { 1 } else { isOdd(n - 1) } }
function isOdd(n: i32) { if n == 0 { 0 } else { isEven(n - 1) } }
print(isEven(4))
print(isEven(3))
