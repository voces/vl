// @run
// @log 5
// @log 10
// @log 7
// @log 8
// A function whose body calls a BUILTIN (`print`, `toString`, `Map`, …) can now be used
// as a VALUE — bound to a binding, passed as a callback — where before it failed
// `emitProgram: captured variable not found in enclosing frame`. The closure
// free-variable scan (`capScan` → `capRecord`) excluded bound vars, module globals, and
// USER functions, but NOT builtins — so a builtin call target (`print`) was mistaken for
// a captured variable and the closure-env build failed. Builtins are call targets the
// emitter lowers directly (never values), so they are now excluded too. (Not void- or
// return-type-specific: an i32 function calling `print` hit this exact bug.)
function logDouble(n: i32) {
  print(n) // a BUILTIN call in the closure body
  return n * 2
}
const f = logDouble
print(f(5)) // prints 5 (from the body), then 10 (the result)
function each(g: (i32) => i32, x: i32) { return g(x) }
function logInc(n: i32) {
  print(n)
  return n + 1
}
print(each(logInc, 7)) // prints 7 (body), then 8 (result)
