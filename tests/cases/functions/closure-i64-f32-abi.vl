// @run
// @log 5000000001
// @log 30
// @log 5000000001
// @log 4
// @log 9
// @log 4
// The closure-call ABI now carries i64 and f32 PARAMS and RESULTS — a function VALUE may take/return
// them, not just i32/f64/string. The value call (`emitCallRef`) coerces each argument to its
// parameter's scalar valtype read from the interned `$fnsig` key (so an i32 literal widens into an
// i64 / f32 / f64 parameter — without that the `call_ref` pushed an i32 and trapped). Covers a
// closure-typed binding, a higher-order parameter, an array element, and a value-flow-monomorphized
// un-annotated lambda — at i64 and f32.
function go() {
  // i64 closure binding: the i32 literal `1` widens to i64 at the call.
  const addI: (i64, i64) => i64 = (a, b) => a + b
  print(addI(5000000000, 1)) // 5000000001

  // i64 through a higher-order parameter.
  function useI(g: (i64, i64) => i64) g(20, 10)
  print(useI(addI)) // 30

  // i64 closure as an array element, called by index.
  const fs: ((i64, i64) => i64)[] = [addI]
  print(fs[0](5000000000, 1)) // 5000000001

  // f32 closure binding (param + result).
  function dblF(x: f32): f32 { return x + x }
  const d: (f32) => f32 = dblF
  const a: f32 = 2.0
  print(d(a)) // 4

  // f32 through a higher-order parameter.
  function useF(g: (f32) => f32) {
    const t: f32 = 4.5
    return g(t)
  }
  print(useF(dblF)) // 9

  // a VALUE-FLOW-monomorphized un-annotated lambda, escaping into an f32 higher-order parameter.
  const add = (p, q) => p + q
  function useF2(g: (f32, f32) => f32) {
    const x: f32 = 2.5
    const y: f32 = 1.5
    return g(x, y)
  }
  print(useF2(add)) // 4
}

go()
