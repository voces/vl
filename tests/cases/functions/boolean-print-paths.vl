// @run
// @log true
// @log false
// @log true
// @log true
// @log false
// @log true
// @log false
// Boolean-ness survives every read path (rep-fuzz F4 — SILENT 0/1 instead of
// true/false). Boolean shares the i32 rep everywhere, so the syntactic print-routing
// classifiers lost the tag through: a struct FIELD read (field code 0 = i32/boolean —
// depth 1!), a nested field, a multi-field sibling, a map `??` result, a closure-VALUE
// call result, a closure-in-a-list call result, and a `boolean[]` PARAM element (a
// local `boolean[]` element already printed true). `exprIsBool` now consults the
// checker's recorded node type first (the same typed-IR fast path `exprIsF64` has).
function useIt(p: boolean[]) {
  print(p[0]) // param element
}
function go() {
  const s = {f: true}
  print(s.f) // struct field
  const n: {f: {f: boolean}} = {f: {f: false}}
  print(n.f.f) // nested field
  const m3 = {a: true, f: true, z: 4}
  print(m3.f) // multi-field sibling
  const h: {[string]: boolean} = Map()
  h["k"] = true
  const t0 = h["k"] ?? false
  print(t0) // map ?? result
  const f: (i32) => boolean = (x) => (x > 0)
  print(f(-1)) // closure-value call result
  const fs: ((i32) => boolean)[] = [f]
  print(fs[0](1)) // closure-element call result
  useIt([false])
}
go()
