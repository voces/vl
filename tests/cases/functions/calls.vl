// Direct function calls: one-liner body, explicit return, and a function calling
// another. (Indirect / first-class calls are not implemented yet — see functions.vl.)
function add(a: i32, b: i32) a + b
function sub(a: i32, b: i32) {
  return a - b
}
function dbl(x: i32) x * 2
function incDouble(x: i32) dbl(x) + 1
__store_i32__(0, 0)
__store_i32__(4, add(5, 7))
__log__(0, 8)
__store_i32__(4, sub(10, 3))
__log__(0, 8)
__store_i32__(4, incDouble(4))
__log__(0, 8)
