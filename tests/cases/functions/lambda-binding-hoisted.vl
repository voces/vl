// @run
// @log 7
// @log 4
// @log xy
// @log 4
// @log 19
// A TOP-LEVEL `const f = <un-annotated lambda>` binding is HOISTED to a named function before
// checking, so the lambda behaves EXACTLY like the equivalent `function f(…) …`: its un-annotated
// params are inference holes that monomorphize per call and per typed boundary — the whole
// generic-function-value machinery — instead of being rejected as an uninferable closure value. (A
// top-level lambda captures nothing, so the rewrite is sound; the binding is `const`, un-annotated,
// and has a hole param, so nothing that already worked changes — an annotated lambda or an annotated
// binding stays a contextually-typed closure.)
const add = (a, b) => a + b
const mul = (a, b) => a * b

// monomorphized per call site at i32 / f64 / string, exactly like a named function.
print(add(3, 4)) // 7
print(add(2.5, 1.5)) // 4
print(add("x", "y")) // xy

// ESCAPES through every typed boundary the named-function machinery handles: a HOF parameter, …
function useF(g: (f64, f64) => f64) g(2.5, 1.5)
print(useF(add)) // 4

// … and a concrete function-typed array element.
const fs: ((i32, i32) => i32)[] = [add, mul]
print(fs[0](3, 4) + fs[1](3, 4)) // 7 + 12 = 19
