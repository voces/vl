// @run
// @log 1
// @log 2
// @log 4
// @log 7
// @log 100
// @log B
// @log 42
// @log 7
// An un-annotated NAMED function whose returns join to a VARIANT-BOX union (a struct arm
// beside a scalar/list â€” `i32 | {x: i32}`, `Cat | i32`, `i32[] | boolean`) now infers +
// lowers, where before the checker floored `'pick' infers the union return type â€¦ not yet
// supported by codegen`. The ANNOTATED form (`: i32 | {x: i32}`) already interned the `>u`
// box + `is`-narrowed; only the inferred spelling was missing its A20 recording. The fix:
// the A20 loop records `variantBoxUnionRetName` under the function's name (the same emit
// render the annotated pin and the anonymous-lambda `#<nodeIx>` recording already use), so
// `collectU`'s inferred-return loop registers the box + variant struct and the emitter's
// `isUName` return classification boxes each arm â€” byte-identically to the annotation. The
// floor accepts EXACTLY that predicate; a shape `variantBoxUnionRetName` still declines
// (an anonymous struct arm mixed with a map the emitter can't box un-annotated) stays a
// clean loud floor.

// (a) inline-struct arm beside a scalar â€” the exact spelling that used to floor.
function pick(c: boolean) {
  if c { return 1 }
  return { x: 2 }
}
function showPick(c: boolean) {
  const v = pick(c)
  if v is i32 { print(v) } else { print(v.x) }
}
showPick(true) // 1
showPick(false) // 2

// (b) a NOMINAL struct arm beside a scalar (`Cat | i32`): `variantBoxUnionRetName` resolves
// the struct member to its declared name so the registered variant matches the annotated
// `Cat | i32` spelling and `is Cat` narrows.
type Cat = { legs: i32 }
function mkCat(c: boolean) {
  if c { return { legs: 4 } }
  return 7
}
function showCat(c: boolean) {
  const r = mkCat(c)
  if r is Cat { print(r.legs) } else { print(r) }
}
showCat(true) // 4
showCat(false) // 7

// (c) a scalar-leaf LIST arm beside a scalar (`i32[] | boolean`).
function mkList(c: boolean) {
  if c { return [100, 200] }
  return false
}
function showList(c: boolean) {
  const r = mkList(c)
  if r is i32[] { print(r[0]) } else { print("B") }
}
showList(true) // 100
showList(false) // B

// (d) the NULLABLE variant-box form (`{w: i32} | i32 | null` â€” canon wraps the null into a
// TyNullable): a fall-through path yields `null`, which rides the box tag.
function mkNul(c: boolean) {
  if c { return { w: 42 } }
  if !c { return 7 }
}
function showNul(c: boolean) {
  const r = mkNul(c)
  if r is {w: i32} { print(r.w) }
  else if r == null { print("null") }
  else { print(r) }
}
showNul(true) // 42
showNul(false) // 7 (the i32 arm on the `!c` path)
