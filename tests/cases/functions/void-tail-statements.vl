// @run
// @log 1
// @log 2
// @log 3
// @log 4
// @warning Unused variable `z`
// A function with no explicit return type infers it from the body's tail
// statement (VL's implicit last-expression return). A tail statement that
// produces no value — an empty body, an else-less `if` (executed for effect),
// or a declaration — must infer a VOID return, not a spurious concrete type.
// Getting this wrong gave the function a concrete wasm result type with a
// body that leaves nothing on the stack, crashing binaryen's codegen.
// Empty body `{}` is a void block, not an empty object literal.
function foo() {}
foo()
print(1)

// Tail else-less `if` calling another void function (the original repro).
function bar() {
  if true {
    foo()
  }
}
bar()
print(2)

// Tail else-less `if` whose then-branch produces a value: the value is
// discarded (statement position), the function stays void.
function baz() {
  if true {
    1 + 1
  }
}
baz()
print(3)

// Tail declaration: binds a name but yields no value → void function.
function decl() {
  let z = 1
}
decl()
print(4)
