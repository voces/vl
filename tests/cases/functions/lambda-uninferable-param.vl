// @error cannot infer a type for parameter `n`
// An anonymous function-literal param with NO contextual type (it is not a
// callback argument, has no annotation, and is bound straight to a `const`) is
// genuinely uninferable. The compiler reports a clear, actionable error asking
// for an annotation — rather than letting the `Unknown` reach codegen as the
// cryptic "Unhandled AST -> WASM Unknown type" crash.
const f = function(n) n * 2
print(f(3))
