// @error cannot infer a type for parameter `n`
// A NESTED arrow-lambda param with no contextual type — bound to a `const` INSIDE a function, where
// the lambda could capture the enclosing frame — is still genuinely uninferable: it is reported as a
// clear error rather than reaching codegen as an `Unknown`. (A TOP-LEVEL `const f = (n) => …`
// binding, which captures nothing, is instead HOISTED to a named function and its hole params
// monomorphize per use — see lambda-binding-hoisted.vl. Hoisting the nested form needs capture
// analysis, a follow-up; until then the un-annotated nested binding stays a clean rejection.)
function go() {
  const f = (n) => n * 2
  print(f(3))
}
go()
