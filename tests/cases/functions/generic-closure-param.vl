// @run
// @log 10
// @log abc
// @log 7
// @log 40
// A GENERIC function with a closure PARAMETER whose type rides the type params
// (`f: (A, T) => A`) is now monomorphized per call shape: the binding is derived
// from the closure ARGUMENT's function type (`(i32, i32) => i32` /
// `(string, string) => string`), and the param's annotation is substituted through
// it so the instance body's `f(…)` call resolves the right `$fnsig`. Before, the
// function-type annotation was left un-substituted (`monoSubstAnn` /
// `monoAnnHasTyParam` / `monoBindFromAnn` only handled bare `T` / `T[]` / `Head<…>`
// / object shapes), so the value call found no interned signature.

function fold<T, A>(self: T[], f: (A, T) => A, init: A): A {
  let acc = init
  let i = 0
  while i < self.length {
    acc = f(acc, self[i])
    i = i + 1
  }
  return acc
}

// i32 accumulator over i32[].
print(fold([1, 2, 3, 4], (a: i32, b: i32) => a + b, 0)) // 10

// string accumulator over string[] — the SAME generic definition.
print(fold(["a", "b", "c"], (acc: string, s: string) => acc + s, "")) // abc

// A single-type-param closure: `f` applied twice. `f(f(x))`.
function twice<T>(x: T, f: (T) => T): T {
  return f(f(x))
}
print(twice(5, (n: i32) => n + 1))  // 7  (f(f(5)) = f(6) = 7)
print(twice(10, (n: i32) => n * 2)) // 40 (f(f(10)) = f(20) = 40)
