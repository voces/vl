// @run
// @log 4
// @log 3
// REGRESSION PIN: a struct-typed VALUE passed into a mutually-recursive
// (forward-referencing) function group. This used to miscompile ("Unhandled
// AST -> WASM Never"), which forced the self-host parser/checker state (`P`/`T`)
// into module globals instead of parameters (see `compiler/ast.vl`'s gap note).
type St = { cur: i32, depth: i32 }
function fa(s: St, n: i32): i32 {
  if n <= 0 { return s.cur }
  fb(s, n - 1)
}
function fb(s: St, n: i32): i32 {
  if n <= 0 { return s.depth }
  fa(s, n - 1)
}
const s: St = { cur: 3, depth: 4 }
print(fa(s, 5))
print(fa(s, 4))
