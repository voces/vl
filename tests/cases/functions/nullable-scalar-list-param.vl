// @run
// @log 1945
// @log NULL
// @log 2.5
// @log NULL
// @log hey
// @log NULL
// @log 1.5
// @log NULL
// A DISTINCT-backing nullable scalar-list PARAM (`i64[] | null`, `f64[] | null`,
// `string[] | null`, `f32[] | null`): the param gate admits the four nul-scalar-list
// kinds; a list-literal argument builds the leaf wrapper (the call-arg `listKind` seed —
// a bare `[1945]` would otherwise build the i32 list), and a `null` argument lowers as
// `ref.null $wrapper`. The body narrows with `!= null` and indexes the leaf list.
// rep-fuzz p1c/p1r `i64[] | null`.
function useI64(p: i64[] | null) {
  const t = p
  if t != null { print(t[0]) } else { print("NULL") }
}
function useF64(p: f64[] | null) {
  const t = p
  if t != null { print(t[0]) } else { print("NULL") }
}
function useStr(p: string[] | null) {
  const t = p
  if t != null { print(t[0]) } else { print("NULL") }
}
function useF32(p: f32[] | null) {
  const t = p
  if t != null { print(t[0]) } else { print("NULL") }
}
function go() {
  useI64([1945])
  useI64(null)
  useF64([2.5])
  useF64(null)
  useStr(["hey"])
  useStr(null)
  useF32([1.5])
  useF32(null)
}
go()
