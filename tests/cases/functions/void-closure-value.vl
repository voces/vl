// @run
// @log 1
// @log 2
// @log 7
// @log 9
// @log 1
// @log 2
// @log 3
// A VOID-returning function used as a VALUE — bound, passed as a callback, or held in a
// struct field — now lowers when called, where before it failed `function-value call
// arity has no interned signature` (the void `>v` sig wasn't interned for a non-field
// value) or a wasm stack mismatch. Three pieces: (1) the value-eligible sig pass now
// interns a void function's `>v` sig (not just for object-field closures); (2)
// `calleeCloSigKey` resolves it — `annRetKind("void")` → `>v` for a `() => void` param,
// `cloSigKeyExt` for a void binding — and a void closure call STATEMENT skips the result
// `drop` (`calleeReturnsVoid`); (3) `stmtIsTailValue` treats a void closure-call tail as a
// STATEMENT not a value, so `run(g: () => void) { g() }` infers void (the value-call
// analogue of the named-`fRetVoid` tail rule).
function hi() { print(1) }
const f = hi
f() // 1 (void binding, called as a statement)

function run(g: () => void) { g() }
function hi2() { print(2) }
run(hi2) // 2 (void closure as a () => void param callback — `run` itself infers void)

function each(g: (i32) => void, x: i32) { g(x) }
function show(n: i32) { print(n) }
each(show, 7) // 7 (void closure with an arg)

type Handler = { on: () => void }
function hi3() { print(9) }
const h: Handler = { on: hi3 }
h.on() // 9 (void closure in a struct field)

function each3(g: (i32) => void) {
  g(1)
  g(2)
  g(3)
}
each3(show) // 1, 2, 3 (the callback invoked repeatedly for effect)
