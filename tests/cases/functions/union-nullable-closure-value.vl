// @run
// @log true
// @log 7
// @log y
// @log z
// A function whose return is a UNION (`A | B`) or NULLABLE (`S | null`, `string | null`),
// used as a VALUE (bound), now lowers when called, and its RESULT types as that union /
// nullable so it narrows (`r is i32`, `p != null`) and `??`-coalesces. Before, each failed
// `function-value call arity has no interned signature`. These are new closure-call RESULT
// kinds — `>u` a union box, `>nN;` a nullable struct, `>N` `string | null` — minted by
// `cloRetKeySuffix` / decoded by `calleeRetKind`, the union/nullable analogues of the
// scalar (`>d`/`>I`) and struct (`>sN;`) result slices. (Passing such a function as an
// annotated `(…) => A | B` PARAM or struct FIELD needs checker support for complex return
// types in a function-type annotation — a separate slice; the bound form works today.)
function classify(n: i32): i32 | string {
  if n > 0 { return n }
  return "neg"
}
const f = classify
const r = f(1)
print(r is i32) // 1 (the union result narrows)

type P = { x: i32 }
function maybePoint(n: i32): P | null {
  if n > 0 { return { x: n } }
  return null
}
const g = maybePoint
const p = g(7)
if p != null {
  print(p.x) // 7 (the nullable-struct result narrows + derefs)
}

function maybeName(n: i32): string | null {
  if n > 0 { return "y" }
  return null
}
const h = maybeName
print(h(1) ?? "z") // y  (non-null path)
print(h(0) ?? "z") // z  (null path -> coalesce default)
