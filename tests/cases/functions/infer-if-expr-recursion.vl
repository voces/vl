// @run
// @log 55
// @log 55
// @log aaa
// @log 6
// SELF-RECURSION through an if-EXPRESSION (a bare-value branch, not an explicit
// `return`): the base-case branch value seeds the inferred return BEFORE the recursive
// sibling branch is checked, so the recursive call resolves to the base type instead of
// an unresolved hole. Covers both the `then … else …` expression form and the braced
// bare-value tail-if form (#487 only covered the explicit-`return` statement form). The
// base case decides the form — `rep` stays string. A void procedure whose tail is a
// no-else `if` ending in a recursive call still infers `void` (no spurious value seeded).
function fib1(n: i32) if n < 2 then n else fib1(n - 1) + fib1(n - 2)
function fib2(n: i32) {
  if n < 2 { n } else { fib2(n - 1) + fib2(n - 2) }
}
function rep(n: i32) if n < 1 then "" else "a" + rep(n - 1)
let total = 0
function sumTo(n: i32) {
  if n > 0 {
    total = total + n
    sumTo(n - 1)
  }
}
print(fib1(10))
print(fib2(10))
print(rep(3))
sumTo(3)
print(total)
