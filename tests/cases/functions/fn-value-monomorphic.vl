// @run
// @log 7
// @log 6
// @log 11
// A function VALUE must be MONOMORPHIC — its wasm closure has one signature. A generic function
// (un-annotated params) taken as a value would emit its params at the i32 default, callable only at
// i32 (`g(2.5,…)` / `g("x",…)` would `ref.cast` to the wrong functype: invalid wasm). So a generic
// function aliased as a value is now a CLEAN emit error ("cannot take a generic function … as a
// value; annotate them, or call it directly by name") instead of silently miscompiling. The forms
// that remain sound — a CONCRETELY-typed function as a value, and a `.map` callback (cloned /
// contextually pinned per receiver element) — keep working. (Value-flow monomorphization, which
// makes a generic function value WORK at its used type, is the follow-up.)

// A concretely-typed (non-generic) function IS a valid value.
function addI(a: i32, b: i32): i32 { return b + a }

function scale(self) { return self.map((x) => x * 2) }

function go() {
  // alias a concretely-typed function, then call it.
  const g = addI
  print(g(3, 4)) // 7

  // an un-annotated `.map` callback stays sound (cloned per element type).
  print(scale([1, 2, 3])[2]) // 6

  // the same generic `scale` definition at f64 — its callback clones to `x: f64`.
  print(scale([2.5, 3.5])[1] + 4.0) // 3.5*2 + 4.0 = 11
}

go()
