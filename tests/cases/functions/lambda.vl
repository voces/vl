// @run
// @log 3
// @log 15
// Anonymous function values (ROADMAP B15): a `function` literal in value position
// lowers to the same fat-pointer closure as a named reference (`closureValue`).
// Works as a let-bound value called directly, and captures an enclosing variable.
let add = function(a: i32, b: i32) a + b
__store_i32__(0, 0)
__store_i32__(4, add(1, 2))
__log__(0, 8)
function make(n: i32) {
  let f = function(x: i32) x + n
  f(10)
}
__store_i32__(4, make(5))
__log__(0, 8)
