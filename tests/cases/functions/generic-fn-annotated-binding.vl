// @run
// @log 7
// @log 4
// @log xy
// @log 30
// @log 11
// ANNOTATION-DRIVEN MONOMORPHIZATION: a generic (un-annotated-param) function bound to a CONCRETE
// function-typed binding (`const c: (f64,f64)=>f64 = add`) is materialized at the ANNOTATION's
// param types and the binding carries THAT instance — independent of any call. So unlike a bare
// `const g = add` alias (which only works when a direct call drives the per-call instance), an
// annotated binding can ESCAPE: be passed to a higher-order function, returned, or stored, and is
// `call_ref`'d at the type its annotation pinned. The annotation also governs the binding's own
// calls (the checker pins them to it). `monoInstanceFor` builds the instance (annotating an i32
// param too, so the closure passes the value floor); the checker first validates that instantiating
// the generic at those params satisfies its `+` capability and yields the annotation's return type.
function add(a, b) a + b

function useF(g: (f64, f64) => f64) g(2.5, 1.5)
function useI(g: (i32, i32) => i32) g(10, 20)

function go() {
  // direct call through an annotated binding.
  const ci: (i32, i32) => i32 = add
  print(ci(3, 4)) // 7

  const cf: (f64, f64) => f64 = add
  print(cf(2.5, 1.5)) // 4.0 → 4

  const cs: (string, string) => string = add
  print(cs("x", "y")) // xy

  // ESCAPE: the annotated binding flows into a HOF and is called there — the bare alias can't.
  const ce: (i32, i32) => i32 = add
  print(useI(ce)) // 30

  const cfe: (f64, f64) => f64 = add
  print(useF(cfe) + 7.0) // useF calls cfe(2.5, 1.5) = 4.0; 4.0 + 7.0 → 11
}

go()
