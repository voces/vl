// @run
// @log 5000000001
// @log 5000000002
// @log 5000000001
// @log 5000000003
// An i64-returning function used as a VALUE — bound, passed as an `(i32) => i64` callback,
// or held in a struct field — now lowers when called, and its RESULT types as i64 (print
// routing, i64 arithmetic, an i64 binding cell), where before it failed `function-value
// call arity has no interned signature`. i64 is the `0x7e` scalar — a new value-call
// result kind `>I`, the i64 analogue of the f64 (`>d`) / string (`>S`) slices:
// `cloSigKeyExt` (inferred `fRetI64` / annotated `vtKindOfType == 10`) and
// `annRetKind("i64")` mint it, the `$fnsig` functype emits `0x7e` as its 1 result, and
// `calleeReturnsI64` (an Ident binding/param callee) + `fRetI64` (a field-closure Member
// callee) classify the result so `exprIsI64` routes it.
function big(n: i32) { return 5000000000 + n }
const f = big
print(f(1)) // 5000000001 (bound i64 closure)

function apply(g: (i32) => i64, x: i32) { return g(x) }
print(apply(big, 2)) // 5000000002 (an (i32) => i64 callback)

const r = f(0)
print(r + 1) // 5000000001 (result bound to an i64 cell, then i64 arithmetic)

type T = { f: (i32) => i64 }
const o: T = { f: big }
print(o.f(3)) // 5000000003 (i64 closure in a struct field)
