// @run
// @log 5
// @log 7
// @log 8
// An UN-ANNOTATED function returning a struct-typed LOCAL must infer a struct
// return (the functype result is the struct ref, not the i32 default): the
// annotated local, the un-annotated local (typed by its literal), and — when two
// declared structs share a field-name set — the ANNOTATION's struct, not the
// first field-shape match.
type A = { v: i32 }
type B = { v: i32 }

function mkAnnotated() {
  const c: A = { v: 5 }
  return c
}
function mkInferred() {
  const c = { v: 7 }
  return c
}
function mkCollide() {
  const c: B = { v: 8 }
  return c
}
function takeB(b: B) { b.v }

print(mkAnnotated().v)
print(mkInferred().v)
print(takeB(mkCollide()))
