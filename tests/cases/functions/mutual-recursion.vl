// @run
// @log true
// @log false
// @log true
// Mutual recursion between two top-level functions: `isEven` calls `isOdd` and
// `isOdd` calls `isEven`. A recursive-descent parser is intrinsically mutually
// recursive (`parseExpr` ↔ `parsePrimary`), so this is the single biggest
// structural tax when bootstrapping a real compiler in VL. The forward-reference
// pre-pass hoists BOTH signatures into module scope before either body is
// checked, so each can resolve the other. Both carry an explicit return type
// (`boolean`) — see the annotation rule: a forward/mutual call resolves against
// the hoisted signature, whose return must be declared since the callee's body
// has not been inferred yet.
function isEven(n: i32): boolean {
  if n == 0 { return true }
  return isOdd(n - 1)
}
function isOdd(n: i32): boolean {
  if n == 0 { return false }
  return isEven(n - 1)
}
print(isEven(10))
print(isEven(7))
print(isOdd(3))
