// @run
// @log 0
// Mutual recursion where each function takes a STRUCT VALUE parameter (`c: Cur`).
// This is the parser-bootstrap shape: a recursive-descent parser threads its
// cursor/state struct through mutually-recursive `parseX` ↔ `parseY` calls.
//
// REGRESSION (the #67 forward-ref pre-pass × struct lowering): the pre-pass
// (`preRegisterTopLevelFunctions`) hoists each top-level function's *signature*
// before any `type` declaration is registered, so the struct param annotation
// `c: Cur` could not resolve `Cur` and was hoisted as `Never`. A FORWARD/mutual
// caller captured that hoisted signature (a non-generic signature is shared by
// reference at the call site), so codegen lowered a `Never` param and crashed
// with `Unhandled AST -> WASM "Never" type`. The fix patches the hoisted
// signature's parameters in place once the real pass resolves them, so every
// forward caller observes the concrete struct type. (Struct *array* params were
// unaffected; only the bare struct alias resolved to `Never`.)
type Cur = { pos: i32 }
function ping(c: Cur): i32 {
  if c.pos <= 0 { return 0 }
  return pong({ pos: c.pos - 1 })
}
function pong(c: Cur): i32 {
  return ping({ pos: c.pos - 1 })
}
print(ping({ pos: 4 }))
