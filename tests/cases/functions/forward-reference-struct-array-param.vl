// @run
// @log 6
// Companion guard: a struct-typed *ARRAY* parameter (`ns: Node[]`) through a
// FORWARD reference. This shape always worked (an array annotation lowers to a
// structural `Object` that did not hinge on the hoist ordering the way a bare
// struct alias did), and must keep working after the bare-struct fix.
type Node = { val: i32 }
function sum(ns: Node[]): i32 {
  return helper(ns)
}
function helper(ns: Node[]): i32 {
  let total = 0
  for n in ns {
    total = total + n.val
  }
  return total
}
print(sum([{ val: 1 }, { val: 2 }, { val: 3 }]))
