// @run
// @log 5
// @log 9
// The working controls around the returned-struct-local inference: an ANNOTATED
// return of a struct local, and a bare tail struct LITERAL (which classifies
// from the expression itself, no local involved).
type Ctx = { a: i32 }

function mkAnnotatedRet(): Ctx {
  const c: Ctx = { a: 5 }
  return c
}
function mkTailLiteral() {
  { a: 9 }
}

print(mkAnnotatedRet().a)
print(mkTailLiteral().a)
