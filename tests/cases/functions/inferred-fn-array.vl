// @run
// @log 19
// @log 10
// @log 7
// An UN-annotated array literal of FUNCTION VALUES (`const fs = [addI, mulI]`) is inferred as a
// closure-element array (ref-list kind 5) and is callable by index (`fs[i](x, y)`) — previously only
// an explicitly-annotated `((i32,i32)=>i32)[]` binding classified as a closure array, so the inferred
// form failed ("callee is not a function name", then an un-interned element signature). The element
// closure type is read from the checker's recorded array type (`nodeArrayElemName` now renders a
// function element), which drives the kind-5 classification, the element `$fnsig` interning, and the
// `fs[i](…)` call-ref. (A literal of GENERIC functions — `[add, mul]` with un-annotated params — is
// still a value-floor error: its element type is an unpinned hole. That is the follow-up.)
function addI(a: i32, b: i32): i32 { return a + b }
function mulI(a: i32, b: i32): i32 { return a * b }
function addF(a: f64, b: f64): f64 { return a + b }
function mulF(a: f64, b: f64): f64 { return a * b }

function go() {
  // i32 closure table, dispatched by index.
  const fs = [addI, mulI]
  print(fs[0](3, 4) + fs[1](3, 4)) // 7 + 12 = 19

  // f64 closure table — the element signature is (f64, f64) => f64, no annotation needed.
  const gs = [addF, mulF]
  print(gs[0](2.5, 1.5) + gs[1](2.0, 3.0)) // 4 + 6 = 10

  // a single-element inferred closure array.
  const hs = [addI]
  print(hs[0](3, 4)) // 7
}

go()
