// @run
// @log 7
// @log true
// @log NULL
// A `<ref-array> | null` (nullable REF-ARRAY) crossing a function RETURN boundary now gets the
// sound `(ref null $wrapper)` niche (kind 18, "nulreflist") — the same rep the LOCAL ladder already
// gives it — instead of the classifier falling through to "i32" and emitting an `(ref …)` value into
// an i32 result slot (INVALID-WASM). `vtKindOfType` gained a `retNulRefArrFlag` arm and the return
// valtype / return-null seeding thread the inner ref-list element wrapper. A `return [x]` builds the
// ref list (which subtypes the nullable result); a `return null` is `ref.null $wrapper`. Found by the
// rep-composition fuzzer (graduated `INVALID-WASM p2c/p2r (() => f64)[] | null`, `{f: boolean}[] | null`).

// A closure-element ref-array return (`(() => f64)[] | null`).
function makeClosures(): (() => f64)[] | null {
  return [() => 7.0]
}

// A struct-element ref-array return (`{f: boolean}[] | null`).
function makeStructs(): {f: boolean}[] | null {
  return [{f: true}]
}

// The null arm of the same return type.
function makeNull(): {f: boolean}[] | null {
  return null
}

function go() {
  const c: (() => f64)[] | null = makeClosures()
  if c != null {
    print(c[0]()) // 7
  } else {
    print(-1)
  }

  const s: {f: boolean}[] | null = makeStructs()
  if s != null {
    print(s[0].f) // true
  } else {
    print("NULL")
  }

  const n: {f: boolean}[] | null = makeNull()
  if n != null {
    print(n[0].f)
  } else {
    print("NULL") // NULL
  }
}

go()
