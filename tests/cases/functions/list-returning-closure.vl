// @run
// @log 3
// @log 5
// @log 9
// @log 6
// @log 2
// @log yo
// @log 3
// @log 3.5
// @hint Intentionally-unused parameter `_n` (leading `_` marks it unused)
// @hint Intentionally-unused parameter `_n` (leading `_` marks it unused)
// A LIST-RETURNING function VALUE — `(i32) => i32[]` / `(i32) => string[]` / `(i32) => f64[]`
// — passes as a callback param or a bound value, is CALLED, and its returned list flows
// through the list machinery (`.length`, indexing, `for-in`). The reps were explicitly
// DEFERRED in #513 (adding them then crashed `string[]`); this revives them, narrowed to a
// VALUE call.
//
// Two pieces. (1) NAME disambiguation: a function type whose RETURN is a list ends in `[]`
// (`(i32) => i32[]`), so the array-name scan would mis-read the whole annotation as an array
// — guarded by `annArrowAt` (a TOP-LEVEL arrow ⇒ a function type, force only the RETURN's
// backing types; `((i32) => i32)[]`, a nested arrow, stays an array OF functions, a later
// slice). (2) RESULT suffix: `annRetKind` / `cloRetKeySuffix` mint `>a` (i32[]) / `>A`
// (string[]) / `>D` (f64[]) so the closure `$fnsig` result is the list-wrapper ref, and
// `exprArray` / `exprStringArray` / `exprF64Array` recognize a closure-value call result
// (via `calleeRetKind`) so a `const xs = g(x)` binding types as that list.
function mkInts(n: i32): i32[] { return [n, n + 1, n + 2] }
function mkStrs(_n: i32): string[] { return ["hi", "yo"] }
function mkF64s(_n: i32): f64[] { return [1.5, 2.5, 3.5] }

// An i32[]-returning callback PARAM — called, length + index + for-in over the result.
function sumLen(g: (i32) => i32[], x: i32) {
  const xs = g(x)
  return xs.length
}
print(sumLen(mkInts, 5)) // 3

// A BOUND list-returning value — called, indexed.
const gi: (i32) => i32[] = mkInts
const xs = gi(5)
print(xs[0])             // 5
print(gi(4)[0] + gi(3)[2]) // 4 + 5 = 9
let total = 0
for v in gi(1) { total = total + v } // 1 + 2 + 3
print(total)             // 6

// A string[]-returning value — length + index (the rep #513 cut).
const gs: (i32) => string[] = mkStrs
const ss = gs(0)
print(ss.length)         // 2
print(ss[1])             // yo

// An f64[]-returning value — length + index.
const gf: (i32) => f64[] = mkF64s
const fs = gf(0)
print(fs.length)         // 3
print(gf(0)[2])          // 3.5
