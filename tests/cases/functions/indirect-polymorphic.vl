// @run
// @log 3
// @skip per-shape monomorphization (ROADMAP B3→A10): one wasm instance per
//   resolved name, so the same inferred-generic function can't yet be used at
//   two different type shapes. The first call pins `apply`'s shared inference
//   cells to i32; the f64 call then mismatches and fails binaryen validation.
//   Flip @skip → @run once `apply` emits `apply$i32` / `apply$f64` instances.
function addi(a: i32, b: i32) a + b
function addf(a: f64, b: f64) a + b
function apply(fn, a, b) fn(a, b)
__store_i32__(0, 0)
__store_i32__(4, apply(addi, 1, 2))
__log__(0, 8)
// Second call at a different type shape (f64) is what currently fails.
__store_f64__(8, apply(addf, 1.5, 2.5))
