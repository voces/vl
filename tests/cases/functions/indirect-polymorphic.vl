// @run
// @log 3
// Per-shape monomorphization (ROADMAP B3→A10): the same inferred-generic
// function used at two different type shapes. Each call site instantiates a
// fresh copy of `apply`'s signature, so the inference holes unify against that
// call's arguments independently; codegen then emits one wasm instance per
// distinct parameter shape (`apply` for the i32 call, `apply$1` for the f64).
function addi(a: i32, b: i32) a + b
function addf(a: f64, b: f64) a + b
function apply(fn, a, b) fn(a, b)
__store_i32__(0, 0)
__store_i32__(4, apply(addi, 1, 2))
__log__(0, 8)
// Second call at a different type shape (f64) — a distinct monomorphization.
__store_f64__(8, apply(addf, 1.5, 2.5))
