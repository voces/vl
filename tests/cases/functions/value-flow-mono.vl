// @run
// @log 7
// @log 4
// @log ba
// @log 9
// @log 12
// VALUE-FLOW MONOMORPHIZATION: a generic (un-annotated-param) NAMED function aliased to a
// `const`/`let` and called DIRECTLY through that binding (`const g = add; g(3, 4)`) now works at
// its used type — exactly as a by-name call would. `monomorphize` resolves `g` to `add`'s slot
// (`identClosureFe`) and instantiates per call site: the first/i32 shape rides `add`'s own slot
// (un-annotated params, byte-identical), each other type clones a fresh annotated instance, and
// the closure value the binding stores is `call_ref`'d only at the type its slot was pinned to.
// A binding whose name only ever appears as a direct-call callee is exempt from the value floor
// (its uses are all monomorphized); any value-USE of it (passed, returned, stored) still escapes
// to the floor — see soundness/xfail-generic-fn-value-escapes.vl.
function add(a, b) a + b

function go() {
  // alias a generic function, call it at i32 through the binding.
  const g = add
  print(g(3, 4)) // 7

  // a SECOND alias, called at f64 — its own instance is pinned to f64.
  const h = add
  print(h(2.5, 1.5)) // 4.0 → 4

  // string `+` is concatenation; the alias monomorphizes to (string, string).
  const s = add
  print(s("b", "a")) // ba

  // MULTIPLE call types through ONE alias: the first call (i32) rides add's slot, the second
  // (f64) clones a fresh instance and rewrites that call site to it.
  const k = add
  print(k(4, 5)) // 9
  print(k(7.5, 4.5)) // 12.0 → 12
}

go()
