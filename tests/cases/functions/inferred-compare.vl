// @run
// @log 9
// @log 3
// A generic over a comparison (ROADMAP A13): `a > b` on inference holes yields a
// boolean and defers the operands to the call site. `max` returns whichever
// operand; works through a braced body (block result type taken from the tail).
function max(a, b) { if a > b then a else b }
function min(a, b) { if a < b then a else b }
print(max(3, 9))
print(min(3, 9))
