// @run
// @log hi
// @log lo
// @log greet
// @log 1
// @log 2
// An if-EXPRESSION in value position whose branch join is a REF type — STRING or STRUCT — bound
// to an UN-annotated `const`. The numeric joins (i32/i64/f64) already classified through
// `ifExprArmIsKind`, but the string/struct expression classifiers (`exprString` / `exprStruct` /
// `structIndexOfExpr`) had no `IfStmt` case, so the binding defaulted to an i32 local while the
// `if` yielded a `(ref …)` — a wasm type mismatch (check-clean, run-broken). They now recurse
// into the THEN arm (the checker proved the arms agree), so the local takes the join's ref rep.

type P = { x: i32 }

function mk(n: i32): P { return { x: n } }

function go() {
  const c = 5

  // STRING join, un-annotated binding.
  const s1 = if c > 1 then "hi" else "lo"
  print(s1) // hi
  const s2 = if c < 1 then "hi" else "lo"
  print(s2) // lo

  // a string VARIABLE arm + the `then`/`else` expression form.
  const greeting = "greet"
  const s3 = if c > 1 then greeting else "other"
  print(s3) // greet

  // STRUCT join, un-annotated binding — the field read resolves the join's struct layout.
  const p1 = if c > 1 then mk(1) else mk(2)
  print(p1.x) // 1
  const p2 = if c < 1 then mk(1) else mk(2)
  print(p2.x) // 2
}
go()
