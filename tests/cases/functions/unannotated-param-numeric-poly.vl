// @run
// @log 3.5
// @log 4
// @log 6.25
// @log 9
// @log 10000000000
// @log 3
// An UN-annotated param is a capability-bounded generic, not an i32 pin: `(n) => n + 1` works for
// ANY numeric type the call supplies. The monomorphization pass already instantiates an
// un-annotated-param function per concrete call (`monoIsGenericDecl` treats an un-annotated param
// as generic) and pins the param to the argument's type — but the instance's INFERRED SCALAR
// return defaulted to i32: the checker only saw the original with `n` a type variable, so it never
// recorded an f64/f32/i64 return name, and `criClassify` (the expression-based return classifier)
// detected string / list / struct returns but not scalar f64/f32/i64. The instance then declared
// an i32 result over an f64 body — "expected i32, found f64". `criClassify` now also detects a
// scalar f64/f32/i64 return from the expression (excluding a value-union `?? d` coalesce, whose
// atom reads numeric but whose rep is the union box). So a numeric-polymorphic function resolves
// its real type per call instead of silently becoming i32.

function inc(n) { return n + 1 }

function sq(n) { return n * n }

function dbl(n) { return n + n }

function go() {
  // ONE definition of `inc`, called at f64 and i32 — two monomorphized instances.
  print(inc(2.5)) // 3.5
  print(inc(3)) // 4

  // `sq` at f64 then i32.
  print(sq(2.5)) // 6.25
  print(sq(3)) // 9

  // i64 and f32 fall out of the same path.
  print(dbl(5000000000)) // 10000000000
  const x: f32 = 1.5
  print(dbl(x)) // 3
}

go()
