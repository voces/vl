// @run
// @log 3
// @log 4
// @log 2
// An UN-ANNOTATED function returning a REF-LIST-typed LOCAL must infer a
// ref-list return: an annotated struct-list local (as a tail value), and an
// un-annotated list-of-list local (via `return`).
type Ctx = { a: i32 }

function mkStructs() {
  const xs: Ctx[] = [{ a: 3 }]
  xs
}
function mkGrid() {
  const g = [[1, 2], [3, 4]]
  return g
}

print(mkStructs()[0].a)
print(mkGrid()[1][1])
print(mkGrid().length)
