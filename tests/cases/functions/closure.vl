// @run
// @log 15
// @skip closures not yet implemented (ROADMAP B4). `add` captures `n` from the
//   enclosing `makeAdder` frame. Until closures land, the codegen guard rejects
//   this with "Closures are not yet implemented: ... captures \"n\" ..." rather
//   than silently miscompiling (it used to emit `x + x` = 20). Flip @skip → @run
//   once captured variables are carried in a WasmGC environment.
function makeAdder(n: i32) {
  function add(x: i32) x + n
  add(10)
}
__store_i32__(0, 0)
__store_i32__(4, makeAdder(5))
__log__(0, 8)
