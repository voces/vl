// @run
// @log 15
// @log 110
// @log 13
// Closures (ROADMAP B4): a nested function captures variables from the
// enclosing frame. Captures are carried in a WasmGC struct environment threaded
// as a hidden leading argument; inside the callee, each capture is a struct.get
// on it. Non-escaping (called within the defining scope); escaping closures
// (the closure used as a value) are still guarded as unimplemented. Captures may
// themselves be objects (struct refs), not just numbers.
function makeAdder(n: i32) {
  function add(x: i32) x + n
  add(10)
}
function combine(a: i32, b: i32) {
  function g(x: i32) x + a + b
  g(100)
}
function sumPoint() {
  let p = { x: 5, y: 8 }
  function inner() p.x + p.y
  inner()
}
print(makeAdder(5))
print(combine(3, 7))
print(sumPoint())
