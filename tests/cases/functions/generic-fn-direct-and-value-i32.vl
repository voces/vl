// @run
// @log 7
// @log 11
// @log 30
// A generic function both DIRECT-CALLED at i32 and taken as a VALUE at i32 in the same program.
// `monoInstantiate` (the direct call) leaves an i32 param UN-annotated for byte-identity, so its
// instance trips the value floor; the value boundary (`monoInstanceFor`) needs a fully-annotated
// twin. The two instances are now distinct registry entries (an `A`-discriminated key when a pin is
// i32), so a generic function used BOTH ways at i32 — previously a spurious "cannot take a generic
// function as a value" floor error — works.
function add(a, b) a + b

function use(g: (i32, i32) => i32) g(10, 20)

function go() {
  print(add(3, 4)) // direct call → un-annotated i32 instance → 7

  const fs: ((i32, i32) => i32)[] = [add]
  print(fs[0](5, 6)) // value (array element) at i32 → annotated i32 instance → 11

  print(use(add)) // value (HOF argument) at i32 → 30
}

go()
