// @check
// @error parameter is used as a number, so it needs a numeric argument
// An un-annotated param is a capability-bounded generic: `f(n) { return n + 1 }` constrains `n` to
// a NUMERIC type (it is used with `+` and a numeric literal). Calling it with a STRING is a
// capability VIOLATION — a clean type error. Before, the param's hole stayed permissively typed
// (`isNumeric(TyVar)` is true), so the call passed the checker and the monomorphized `string + 1`
// instance reached the emitter as invalid wasm. The numeric use now records a demand on the hole
// (`noteNumericDemand`, the arithmetic/comparison analogue of the array-index demand), and the
// call-arg check enforces it. Valid numeric calls (i32 / i64 / f32 / f64, each monomorphized) are
// in `unannotated-param-numeric-poly.vl`; an unconstrained hole (`id(x) { return x }`) stays fully
// polymorphic and accepts a string.

function f(n) { return n + 1 }

function go() {
  print(f("hello"))
}

go()
