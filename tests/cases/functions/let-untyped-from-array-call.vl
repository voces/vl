// @run
// @log z
// @log 1
// @log w
// @log 2
// An UNTYPED `let` whose initializer is a CALL returning `string[]` must classify
// the local as a string list (a `(ref $stringListType)`), not fall through to the
// default i32 local kind. The typed form `let saved: string[] = snap()` already
// worked; the self-host emitter previously inferred string-array-ness from array
// literals / idents / `string[]` field reads but NOT from a Call return type, so an
// untyped binding emitted invalid wasm (`expected i32, found (ref …)`). Indexing,
// `.length`, `.push`, and reassignment (to another `string[]`-returning call) on the
// binding all confirm it is a real string list — and keep it a genuine `let`.
function snap(): string[] {
  const s: string[] = []
  s.push("z")
  s
}

function snap2(): string[] {
  const s: string[] = []
  s.push("w")
  s.push("w")
  s
}

let saved = snap()
print(saved[0])
print(saved.length)
saved = snap2()
print(saved[0])
print(saved.length)
