// @run
// @log 7
// @log 9
// @log 1
// @log 2
// @log 3
// An un-annotated function whose returns join to a STRUCT union (`Cat | Dog`) now infers
// + lowers, where before the checker floored `cannot infer a union return type for 'pick'
// — annotate the return type`. The ANNOTATED form already lowered (the variant-boxed rep)
// + `is`-narrowed; only the inference was missing. The checker is purely STRUCTURAL — it
// infers `{meow: i32} | {woof: i32}` — but the emitter's union machinery is keyed by the
// NOMINAL struct-table name (`registerInlineUnion` / `structIndexByName` resolve names,
// not `{…}` shapes). So the checker reverse-maps each inferred object member to the named
// type whose shape it equals (`structUnionRetName`, bidirectional assignability) and
// exports `Cat|Dog`; the emitter registers + classifies it exactly like an annotation.
// The floor uses the SAME predicate, so it accepts EXACTLY what lowers: a member that
// matches no named type (an anonymous / partial shape) or a struct mixed with a scalar
// still floors (annotate to disambiguate).
type Cat = { meow: i32 }
type Dog = { woof: i32 }
function pick(c: boolean) {
  if c { return { meow: 7 } }
  return { woof: 9 }
}
function show(c: boolean) {
  const x = pick(c) // inferred `Cat | Dog` binding
  if x is Cat { print(x.meow) } else { print(x.woof) }
}
show(true) // 7
show(false) // 9
// Three variants + an `else if` narrowing chain.
type A = { a: i32 }
type B = { b: i32 }
type C = { c: i32 }
function tri(n: i32) {
  if n == 0 { return { a: 1 } }
  if n == 1 { return { b: 2 } }
  return { c: 3 }
}
function showTri(n: i32) {
  const x = tri(n)
  if x is A { print(x.a) }
  else if x is B { print(x.b) }
  else { print(x.c) }
}
showTri(0) // 1
showTri(1) // 2
showTri(2) // 3
