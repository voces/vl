// @run
// @log 7
// @log -1
// @log 5
// @log anon
// @log -1
// @log -1
// @log 0
// A struct literal may OMIT a NULLABLE field — it is materialized as `null` at
// construction (the "completion coercion"). `let cat: Cat = { meow: 7 }` with `foo: i32 |
// null` no longer errors `cannot assign {meow: i32}`; `foo` defaults to `null`. The check
// is scoped to the object-LITERAL assignability path (`assignableExpr`, a known target
// type) — NOT general structural subtyping, so it never widens a value through a
// container/variance. A NON-nullable omitted field is still required. Works in binding,
// return, and argument position; the emitter fills the omitted field via
// `emitOmittedFieldNull` (per-rep null). SOUNDNESS: a value built as the NARROWER shape is
// physically that shape — `cat is WiderType` is false (it lacks the slot), so no value
// masquerades with fields it does not have.
type Cat = { meow: i32, foo: i32 | null }
const cat: Cat = { meow: 7 } // omit foo -> null
print(cat.meow) // 7
print(cat.foo ?? -1) // -1 (foo is null)
type Box = { id: i32, name: string | null }
const b: Box = { id: 5 } // omit string|null name -> null
print(b.id) // 5
print(b.name ?? "anon") // anon
// Return + argument position.
function mk(): Cat {
  return { meow: 1 } // omit foo
}
print(mk().foo ?? -1) // -1
function use(c: Cat) { print(c.foo ?? -1) }
use({ meow: 2 }) // -1
// SOUNDNESS: a value constructed as the narrower shape is NOT the wider shape — it has no
// `foo` slot, so `is` must report false (it cannot soundly grow fields).
type SimpleCat = { meow: i32 }
type ComplexCat = { meow: i32, foo: i32 | null }
const sc: SimpleCat = { meow: 7 }
print(if sc is ComplexCat then 1 else 0) // 0
