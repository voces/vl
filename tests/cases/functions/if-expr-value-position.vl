// @run
// @log 10
// @log 20
// @log 7
// @log 1
// @log x
// An `if … then … else …` (or braced `if { v } else { w }`) used as a VALUE has the
// type of the JOIN of its branch tail values — not `void`. So it lowers correctly in
// assignment, argument, and tail positions, where it previously type-checked as `void`
// and then crashed codegen (a wasm type mismatch). Same-type branches join to that type;
// disagreeing branches join to a value union that narrows with `is`. (An else-less `if`
// used as a value has no value on the fall-through, so it stays `void` and is rejected
// at the assignment — a clean error, not a runtime trap.)
function chooseI32(c: boolean): i32 {
  const x = if c then 10 else 20
  x
}
function maxOf(a: i32, b: i32): i32 {
  // if-expression directly as a call argument
  id(if a > b then a else b)
}
function id(n: i32): i32 { n }
function pick(c: boolean) if c then 1 else "x"
print(chooseI32(true))
print(chooseI32(false))
print(maxOf(3, 7))
const p = pick(true)
if p is i32 { print(p) } else { print(0) }
const q = pick(false)
if q is string { print(q) } else { print(99) }
