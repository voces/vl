// @run
// @log 6
// @log -1
// @log 10
// @log 8
// A NULLABLE function value as a PARAMETER — `(c: ((i32) => i32) | null)` — accepts a
// function OR `null`, narrows with `if c != null`, and calls the recovered function. The
// param-form completion of A-nullable-function-value (which covered local bindings): the
// param slot is the same kind-19 `(ref null $cloStruct)` (`vtKindOfType` now maps a
// `fn | null` annotation to kind 19 BEFORE the bare-function kind 14), a `null` ARGUMENT
// lowers as `ref.null $cloStruct` (a `cParamNulClosure` seed at the call boundary), and the
// narrowed call recovers non-null before `call_ref` (`paramNulClosure` feeds `exprIsClosure`
// / `exprNulClosure`).
function apply(c: ((i32) => i32) | null, x: i32) {
  if c != null { return c(x) }
  return -1
}
function inc(n: i32) { return n + 1 }
function dbl(n: i32) { return n * 2 }

print(apply(inc, 5)) // 6   (a named function argument)
print(apply(null, 5)) // -1  (a null argument → the fallback)

// A nullable-function LOCAL passed through to a nullable-function param.
function via() {
  const g: ((i32) => i32) | null = dbl
  print(apply(g, 5)) // 10
}
via()

// The argument chosen at runtime (function or null), both reaching the param.
function pick(useInc: boolean) {
  if useInc {
    print(apply(inc, 7)) // 8
  } else {
    print(apply(null, 7))
  }
}
pick(true)
