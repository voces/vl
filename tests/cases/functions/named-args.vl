// @run
// @log 201
// @log 201
// @log 201
// @log 201
// @log 10203
// @log 10203
// @log 11
// Named call arguments are bound to parameters by NAME, then positionally —
// so source order is irrelevant for named args. (Regression: codegen used to
// emit arguments in source order, mis-mapping out-of-order named calls.)
function f(a: i32, b: i32) a * 100 + b
print(f(a: 2, b: 1)) // source order matches declaration
print(f(b: 1, a: 2)) // out of order — the key regression
print(f(2, 1))       // all positional
print(f(2, b: 1))    // positional + named mix (a := 2 positionally, b := 1)

// Three params exercise non-adjacent reordering.
function g(a: i32, b: i32, c: i32) a * 10000 + b * 100 + c
print(g(c: 3, a: 1, b: 2)) // fully reordered
print(g(1, c: 3, b: 2))    // a := 1 positionally, b/c by name out of order

// A `self`/UFCS receiver is an unnamed positional arg (slot 0); the remaining
// named args still reorder around it.
function scale(self: i32, by: i32, plus: i32) self * by + plus
print(5.scale(plus: 1, by: 2)) // 5 * 2 + 1
