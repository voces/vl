// @run
// @log 5
// @log -1
// The nullable-scalar sibling of infer-union-return-codegen.vl: returns of `5` and
// `null` JOIN to `i32 | null`, which lowers un-annotated through the same value-union
// box (`null` is an atom of the box). The caller narrows with `!= null`:
// maybe(true) → 5, maybe(false) → null → -1. No annotation.
function maybe(b: boolean) {
  if b { return 5 }
  return null
}
const a = maybe(true)
if a != null { print(a) } else { print(-1) }
const b = maybe(false)
if b != null { print(b) } else { print(-1) }
