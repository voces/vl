// @run
// @log hi
// @log none
// @log A
// @log none
// @log world
// @log none
// An un-annotated `const x = if c then <string> else null` infers `string | null` — a
// NICHE rep (`ref.null $aTypeIdx`), not the value-union box. `valueUnionRetName` renders
// "" for niches, so #494's `inferLetNameOf` export skips it and the emitter's STATIC
// arm derivation (#492) can't classify it either. The checker now ALSO exports each
// inferred `string | null` if-binding by node index (`isInferLetNulStr`), and the
// emitter's `letIsNulString` consults it so the slot classifies as the kind-16 nullable
// string and reuses the ANNOTATED `string | null` if-binding lowering (#491, rep 1) with
// no annotation. Arms the checker can type all work: a literal, an else-less tail, a
// param, a `: string`-returning call.
function fl(c: boolean) {
  const x = if c then "hi" else null // STRING LITERAL arm
  print(x ?? "none")
}
fl(true)
fl(false)
function fp(c: boolean, s: string) {
  const x = if c then s else null // PARAM arm
  print(x ?? "none")
}
fp(true, "A")
fp(false, "A")
function gs(n: i32) {
  if n > 0 { return "world" }
  return "neg"
}
function fc(c: boolean, n: i32) {
  const x = if c then gs(n) else null // CALL arm (un-annotated string return)
  print(x ?? "none")
}
fc(true, 5)
fc(false, 5)
