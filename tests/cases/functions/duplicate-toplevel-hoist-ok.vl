// @run
// @log 3
// @log true
// The must-not-error twin of duplicate-toplevel-reject: DISTINCT top-level
// functions still hoist (call-before-decl, mutual recursion) — only a second
// top-level `function` of the SAME name is a redeclaration.
print(add(1, 2))
function add(a: i32, b: i32) { return a + b }
function isEven(n: i32) { return if n == 0 { true } else { isOdd(n - 1) } }
function isOdd(n: i32) { return if n == 0 { false } else { isEven(n - 1) } }
print(isEven(10))
