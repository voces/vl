// @run
// @log 6
// @log -1
// @log 10
// @log -1
// @log 8
// A NULLABLE function value as a MODULE GLOBAL — `let handler: ((i32) => i32) | null` —
// holds a function OR `null`, narrows with `if handler != null` / `== null`, and calls the
// recovered function. The global-form completion of the nullable-function arc (after the
// local-binding, parameter, and struct-field forms): a module global carries the SAME
// nullable closure fat-pointer as a kind-19 local, encoded as a global cell **kind 19** —
// `globalCellKind` maps a `fn | null` annotation to it (before the bare-function kind 14),
// the non-const cell is declared `(ref null $cloStruct)` (`fbValtypeNullable`) and
// zero-initialized `ref.null $cloStruct` (`fbRefNullForKind`), a bare `null` init / RHS
// lowers as `ref.null $cloStruct` (a `pendingNulClosure` seed in the start fn and
// `emitAssign`), the read stays raw nullable (NOT auto-recovered, like a kind-9/15 global)
// so `!= null` is `ref.is_null` and the narrowed call recovers non-null (`ref.as_non_null`)
// before `call_ref` — both driven by `exprNulClosure`'s global case, with `exprIsClosure`
// routing `handler(x)` to the `call_ref` path.
function inc(n: i32) { return n + 1 }
function dbl(n: i32) { return n * 2 }

// A const global initialized with a function, narrowed + called.
const handler: ((i32) => i32) | null = inc
// A const global initialized with `null` — the guard fails.
const missing: ((i32) => i32) | null = null
// A second function global (distinct closure value).
const doubler: ((i32) => i32) | null = dbl

function callHandler(x: i32) {
  if handler != null { return handler(x) }
  return -1
}
function callMissing(x: i32) {
  if missing != null { return missing(x) }
  return -1
}

function callDoubler(x: i32) {
  if doubler != null { return doubler(x) }
  return -1
}

print(callHandler(5)) // 6   (the function global)
print(callMissing(5)) // -1  (the null global → fallback)
print(callDoubler(5)) // 10  (a distinct function global)

// A MUTABLE global reassigned at runtime — null → function → null — each state narrowed.
let slot: ((i32) => i32) | null = null
function callSlot(x: i32) {
  if slot != null { return slot(x) }
  return -1
}
print(callSlot(7)) // -1  (starts null)
slot = inc
print(callSlot(7)) // 8   (reassigned to a function)
