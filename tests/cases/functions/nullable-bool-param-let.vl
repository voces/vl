// @run
// @log 1
// @log 0
// @log 1
// @log 0
// `boolean | null` as a PARAMETER and a LET binding (the niche sentinel rides the i32):
// a `null` argument / a `x = null` assignment emits the sentinel 2, a boolean stays
// 0/1, and `!= null` is the sentinel compare. param: f(true) → 1, f(null) → 0;
// let: x=true → 1, then x=null → 0.
function f(x: boolean | null) {
  if x != null { print(1) } else { print(0) }
}
f(true)
f(null)
let x: boolean | null = true
if x != null { print(1) } else { print(0) }
x = null
if x != null { print(1) } else { print(0) }
