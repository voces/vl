// @run
// @log 7
// @log neg
// @log 8
// A UNION value produced by a CLOSURE call, bound to a local, then NARROWED and USED
// (`const r = f(x); if r is i32 { … r … }`), now lowers — before it crashed codegen
// `expected i32, found (ref $type)` (the narrowed read kept the raw union box instead of
// unboxing to the scalar). The narrowing/unboxing is driven by the binding's union NAME
// (its atom set), resolved by `unionNameOfExpr` — which handled a NAMED-function call but
// fell through to "" for a function-VALUE callee, so a closure-sourced union local had no
// atoms to narrow against. It now resolves the name from the underlying lifted function
// (mirroring the named path), so a union from a closure call narrows exactly like one from
// a named call. (The bound form `print(r is i32)` already worked; narrow-and-USE did not.)
function classify(n: i32): i32 | string {
  if n > 0 { return n }
  return "neg"
}
const f = classify

const a = f(7)
if a is i32 {
  print(a) // 7 (i32 arm unboxes + prints)
}

const b = f(0)
if b is string {
  print(b) // neg (string arm unboxes + prints)
}

// The unboxed scalar participates in arithmetic.
const c = f(7)
if c is i32 {
  print(c + 1) // 8
}
