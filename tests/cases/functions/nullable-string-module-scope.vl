// @run
// @log hi
// @log present
// @log none
// @log bye
// A `string | null` (kind 16, a `(ref null $array)` niche) read AS A VALUE at MODULE
// scope now recovers the non-null string ref, where before a top-level `x ?? d` / `x !=
// null` left a `(ref null $array)` where a `(ref $array)` was expected (a wasm validation
// error). The non-null recovery (`ref.as_non_null`) was gated on the global being
// NON-const, on the assumption that a const ref cell is already non-null — but a `string
// | null` cell is ALWAYS nullable (a const can be initialized to `null`), so the recovery
// now applies to a kind-16 cell regardless of const-ness. Function-scope reads already
// worked (the local path recovers); this closes the module-scope gap. `i32 | null` /
// `boolean | null` were unaffected (their cells are i32, no ref recovery).
const a: string | null = "hi"
print(a ?? "none") // hi (?? value read)
const b: string | null = "x"
if b != null {
  print("present") // present (!= null narrow)
} else {
  print("absent")
}
const c: string | null = null
print(c ?? "none") // none (null falls through)
let d: string | null = "start"
d = "bye"
print(d ?? "none") // bye (reassigned non-const cell)
