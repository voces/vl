// @run
// @log 1
// @log 0
// @log 2
// @log 7
// @log 5
// @log -1
// `??` (null-coalescing) over the nullable VALUE types, for an Ident/field place:
// boolean|null (i32 sentinel → select on 2), string|null (nullable ref → value-typed
// `if` on ref.is_null, recovering the non-null string in the present arm), and i32|null
// (the value-union box). Each tested present + null. (The non-Ident `f() ?? d` form
// needs a scratch local — tracked follow-up; `const r = f(); r ?? d` is the workaround.)
function fb(b: boolean): boolean | null {
  if b { return true }
  return null
}
function fs(b: boolean): string | null {
  if b { return "hi" }
  return null
}
function fi(b: boolean): i32 | null {
  if b { return 5 }
  return null
}
const a = fb(true)
if (a ?? false) { print(1) } else { print(0) }
const a2 = fb(false)
if (a2 ?? false) { print(1) } else { print(0) }
const s = fs(true)
print((s ?? "x").length)
const s2 = fs(false)
print((s2 ?? "default").length)
const i = fi(true)
print(i ?? -1)
const i2 = fi(false)
print(i2 ?? -1)
