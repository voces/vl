// @run
// @log 5
// @log -1
// The annotated counterpart to infer-nullable-return-needs-annotation.vl: with an
// explicit `: i32 | null` the emitter seeds the return, so a multi-return function
// mixing `5` and `null` lowers and the caller narrows it with `!= null`. This is the
// path the robustness floor directs an un-annotated nullable return toward.
function maybe(b: boolean): i32 | null {
  if b { return 5 }
  return null
}
const a = maybe(true)
if a != null { print(a) } else { print(-1) }
const b = maybe(false)
if b != null { print(b) } else { print(-1) }
