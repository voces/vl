// @run
// @log 5
// @log 3
// @log -1
// `string | null` is the nullable-REF value type: `(ref null $aTypeIdx)` over the raw
// string array ‚Äî `null` is `ref.null`, `!= null` is `ref.is_null` (distinct from the
// `boolean | null` i32 sentinel). A function returning it lowers, the caller narrows
// with `!= null`, and the narrowed string is read as a value (`.length`, `+` concat,
// returned as `string`) via `ref.as_non_null` recovery. greet("hi") ‚Üí "hi!"? no ‚Äî
// f("hello").length 5; concat g("hi") ‚Üí "hi!" length 3; f(null) ‚Üí -1.
function f(b: boolean): string | null {
  if b { return "hello" }
  return null
}
function g(x: string | null): string {
  if x != null { return x + "!" }
  return "none"
}
const r = f(true)
if r != null { print(r.length) } else { print(-1) }
print(g("hi").length)
const s = f(false)
if s != null { print(s.length) } else { print(-1) }
