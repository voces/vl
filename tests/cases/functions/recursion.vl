// @run
// @log 120
// @log 55
// @log 55
// Recursive functions: the function name is forward-registered in the enclosing
// scope *before* its body is walked, so `f` resolves inside `f`. Works with an
// annotated return; codegen's instance cache (set before the body compiles)
// terminates the recursive instantiation.
function fact(n: i32): i32 {
  if n <= 1 { 1 } else { n * fact(n - 1) }
}
print(fact(5))
function sum(n: i32): i32 {
  if n <= 0 { 0 } else { n + sum(n - 1) }
}
print(sum(10))
function fib(n: i32): i32 {
  if n < 2 then n
  else fib(n - 1) + fib(n - 2)
}
print(fib(10))
