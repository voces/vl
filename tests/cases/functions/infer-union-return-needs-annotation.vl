// @error cannot infer a union return type for 'pick' — annotate the return type
// The union sibling of infer-nullable-return-needs-annotation.vl: returns of
// disagreeing concrete types (`5` and `"hi"`) JOIN to `i32 | string`. Before the join
// fix the checker took the first return (`i32`) and WRONGLY accepted the program, then
// crashed codegen when the string flowed through an i32 result. Now the union is
// inferred correctly and the robustness floor asks for an annotation (the annotated
// `: i32 | string` form lowers). Removing this requirement is the documented follow-up.
function pick(b: boolean) {
  if b { return 5 }
  return "hi"
}
const r = pick(false)
if r is string { print(r) } else { print(r) }
