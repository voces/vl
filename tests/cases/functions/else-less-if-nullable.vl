// @run
// @log 5
// @log 99
// @log hi
// @log none
// @log true
// @log false
// An else-less `if` in RETURN-TAIL position is a fall-through (when the condition is
// false there is no value) — that path is `null`, exactly like a function that falls off
// its end (#484). So `function f(c) { if c then v }` returns `T | null`: the then-arm
// returns its value and the false fall-through is lowered as the rep's null by the
// function-end padding (`emitNullForRet`). Covers the value-union box (`i32 | null`), the
// string niche (`ref.null`), and the boolean niche (sentinel `2`). An annotated NON-
// nullable `: i32` else-less tail stays a totality error (missing-return-reject.vl), and
// `: i32 | null` is allowed — same rule as a bare fall-through.
function fi(c: boolean) {
  if c then 5
}
function fs(c: boolean) {
  if c then "hi"
}
function fb(c: boolean) {
  if c then true
}
const i1 = fi(true)
const i2 = fi(false)
const s1 = fs(true)
const s2 = fs(false)
const b1 = fb(true)
const b2 = fb(false)
print(i1 ?? 99)
print(i2 ?? 99)
print(s1 ?? "none")
print(s2 ?? "none")
print(b1 ?? false)
print(b2 ?? false)
