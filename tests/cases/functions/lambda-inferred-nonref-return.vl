// @run
// @log 42
// @log 2.5
// @log hi
// @log 2
// @log b
// An anonymous lambda's UN-annotated return reached THROUGH A VARIABLE now classifies
// correctly. The checker records a function's inferred scalar/string/list return for the
// emitter (the expression-based fallback misses a return that is a plain `let`-bound
// variable), but it keyed that table by function NAME — and a lambda is anonymous at check
// time, lifted to a `__lambda_N` name the checker never saw. So a non-i32 return through a
// variable mis-classified as i32 and emitted invalid wasm. The checker now ALSO records an
// anonymous lambda's inferred return by NODE INDEX (`inferRetNameByNode`), which the emitter
// consults when the name lookup misses — the lambda analogue of the named-function path.
// (A named function with the same body always worked; these are the lambda counterparts.)

const i64v = () => {
  const x: i64 = 42
  return x
}
print(i64v()) // 42

const f64v = () => {
  const x: f64 = 2.5
  return x
}
print(f64v()) // 2.5

const strv = () => {
  const s = "hi"
  return s
}
print(strv()) // hi

const listv = () => {
  const xs = [1, 2]
  return xs
}
print(listv()[1]) // 2

const strlistv = () => {
  const xs = ["a", "b"]
  return xs
}
print(strlistv()[1]) // b
