// @run
// @log true
// @log false
// A function-VALUE call used DIRECTLY as the operand of an `is` test (`f(x) is i32`),
// rather than bound to a `const` first, now lowers — before it crashed codegen `unknown
// local 0: local index out of bounds`. The closure `call_ref` reads a 1-slot scratch
// local (`callRefSlot`), reserved only when `blockHasCallRef` finds a function-value call
// in the body — but that scan recursed into `BinExpr` / `Member` / `Index` / arg lists,
// NOT into an `IsExpr` operand, so an inline `f(x) is T` left the slot un-reserved and the
// `call_ref` read a non-existent local 0. The scan now recurses into the `is` operand.
// (A union-returning closure exercises it directly; the same slot backs EVERY closure call
// — an i32 one in an `is` would hit it too.)
function classify(n: i32): i32 | string {
  if n > 0 {
    return n
  }
  return "neg"
}
const f = classify
print(f(7) is i32) // true  — the closure-call result tested inline, never bound
print(f(0) is i32) // false
