// @run
// @log 7
// @log -1
// @log 9
// @log -1
// @log 5
// @log 6
// @log -1
// @log 5000000000
// @log 0
// An un-annotated `const x = if c then <non-literal> else null` now infers + lowers as
// a value union, where before the emitter failed `emitProgram: bare null needs a
// struct-typed context` — the checker typed it `i32 | null` cleanly, but the emitter's
// STATIC arm derivation (#492) could only classify LITERAL / annotated-call arms, so a
// bare param / inferred-local / call arm slipped through. The checker now EXPORTS each
// un-annotated binding's inferred value-union name by node index (`inferLetNameOf`, the
// binding analogue of the inferred-RETURN export), and the emitter reads it instead of
// re-deriving — so any arm the checker can type works (a param `v`, an inferred local
// `const v = 9`, a call `g(d)`, an `i64` widening), and the numeric-widening join (`if c
// then 1 else 2.5` → f64, not a union) is correct for free. A pure `string | null`
// (a niche, not the value box) inferred binding stays a follow-up.
function gi(c: boolean) {
  if c { return 5 }
  return 6
}
function fp(c: boolean, v: i32) {
  const x = if c then v else null // PARAM arm — not classifiable statically
  print(x ?? -1)
}
fp(true, 7)
fp(false, 7)
function fl(c: boolean) {
  const v = 9
  const x = if c then v else null // INFERRED-LOCAL arm
  print(x ?? -1)
}
fl(true)
fl(false)
function fc(c: boolean, d: boolean) {
  const x = if c then gi(d) else null // CALL arm (un-annotated i32 return)
  print(x ?? -1)
}
fc(true, true)
fc(true, false)
fc(false, true)
function fl64(c: boolean, n: i64) {
  const x = if c then n else null // i64 param arm → i64 | null
  if x is i64 { print(x) } else { print(0) }
}
fl64(true, 5000000000)
fl64(false, 5000000000)
