// @run
// @log 6.5
// @log 8.5
// @log 3
// @log 5000000001
// An un-annotated MODULE-SCOPE binding whose initializer is f64 (or i64) ARITHMETIC, or
// an f64-returning CALL, now lowers, where before it crashed codegen with a wasm type
// mismatch (`expected i32, found f64`). A single float literal (`const a = 1.5`) already
// classified, but a COMPOSITE init did not: the local `letIsF64` inference was gated to
// INSIDE a function (`fnIx >= 0`) — top-level `const`s run in the start function — and the
// module-cell classifier (`globalKind`) had no scalar-f64/i64 case in its expression
// family. Both now classify it (`globalKind` → kind 11/10; `letIsF64`/`letIsI64` infer at
// module scope too). The cross-global ref (`const b = a + 1.0`) recurses through
// `globalIsF64` and terminates for an acyclic program, like the existing
// `exprString`/`exprStruct` module-cell classifiers. (Inside a function this always
// worked; an explicit `: f64` annotation also always worked.)
const r = 2.0 + 4.5
print(r) // 6.5
function dbl(n: f64) { return n * 2.0 }
const c = dbl(2.0) + 4.5
print(c) // 8.5
const a = 2.0
const b = a + 1.0
print(b) // 3 (cross-global f64 reference)
const big = 5000000000 + 1
print(big) // 5000000001 (module-scope i64 arithmetic)
