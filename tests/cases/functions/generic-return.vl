// @run
// @log 10
// @log 6
// A generic (un-annotated-param) function whose body is a single `return expr`:
// the body ends in `return` (so its block is `unreachable`), and the inferred
// return type resolves from the recorded return value, not the body.
function double(n) { return n * 2 }
const r = double(5)
print(r)
function inc(n) { return n + 1 }
print(inc(5))
