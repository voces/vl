// @run
// @log true
// @log false
// @log true
// @log false
// @log false
// @log true
// @log false
// @log false
// @log 99
// @log 99
// @log false
// @log true
// @log false
// An un-annotated `const x = if c then <boolean> else null` infers `boolean | null` —
// the OTHER niche (the i32 sentinel rep: 0/1 with the spare value 2 = null), the
// companion of `string | null`. Before this, `boolean | null` was not a supported LOCAL
// rep AT ALL — even an ANNOTATED `let x: boolean | null` failed `only i32 locals are
// supported` — because the slot classifier had no kind for it. It is now kind 17 (a
// plain i32 cell, like a `boolean`, but `checkLocalI32` no longer rejects the niche
// annotation/init). The checker EXPORTS each inferred `boolean | null` if-binding by
// node index (`isInferLetNulBool`, the companion of `isInferLetNulStr`), the emitter's
// `letNulBool` consults it so the slot classifies as kind 17, and the if-binding lowers
// via `emitNullableIfBinding` rep 2 (a bare `null` arm is the sentinel 2). Every
// null-check idiom works — `??`, `!= null`, `== null` — at parity with an annotated
// `boolean | null`. (`is boolean` narrowing of the niche is a SEPARATE pre-existing gap
// shared with the annotated form, so it is not exercised here.)
function fl(c: boolean) {
  const x = if c then true else null // BOOLEAN LITERAL arm
  print(x ?? false)
}
fl(true) // true
fl(false) // false
function fp(c: boolean, b: boolean) {
  const x = if c then b else null // PARAM arm
  print(x ?? false)
}
fp(true, true) // true
fp(true, false) // false
fp(false, true) // 0 (null → ?? false)
function gb(n: i32) {
  if n > 0 { return true }
  return false
}
function fc(c: boolean, n: i32) {
  const x = if c then gb(n) else null // CALL arm (un-annotated boolean return)
  print(x ?? false)
}
fc(true, 5) // true
fc(false, 5) // 0 (null → ?? false)
function fnull(c: boolean) {
  const x = if c then false else null
  // == null sentinel test; the narrowed `print(x)` prints the BOOLEAN ("false"), where
  // `print(x ?? false)` above prints the i32 ("0") — a pre-existing print-routing detail
  // of the niche `??`, identical for an annotated `boolean | null`.
  if x == null { print(99) } else { print(x) }
}
fnull(true) // false
fnull(false) // 99
function fne(c: boolean, b: boolean) {
  const x = if c then b else null
  if x != null { print(x) } else { print(99) }
}
fne(false, true) // 99 (null)
fne(true, false) // false
// ANNOTATED `boolean | null` LOCAL (a non-if init + a `= null` reassignment) — before
// kind 17 even this failed `only i32 locals are supported`; the niche is now a real
// local rep, so a later `x = null` write stays valid (the sentinel 2).
function fann(c: boolean) {
  let x: boolean | null = true
  if c { x = null }
  print(x ?? false)
}
fann(false) // true
fann(true) // 0 (null → ?? false)
