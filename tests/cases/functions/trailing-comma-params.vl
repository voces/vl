// @run
// @log 9
// @log 9
// Trailing comma in a function parameter list (`function f(a, b,) { … }`). The
// trailing `,` before `)` is allowed and ignored, so the declared signature and
// its calls behave exactly as without it.
function add(a: i32, b: i32,) a + b
function sub(
  a: i32,
  b: i32,
) {
  return a - b
}
print(add(4, 5))
print(sub(14, 5))
