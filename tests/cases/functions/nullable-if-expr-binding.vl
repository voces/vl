// @run
// @log 9
// @log -1
// @log 10
// @log 20
// @log -1
// @log hi
// @log none
// @log 1.5
// @log 0
// @log 5000000000
// @log 0
// @log 5
// @log 99
// A nullable / value-union if-EXPRESSION in BINDING-INIT position now lowers, where
// before it failed `emitProgram: bare null needs a struct-typed context` (or emitted a
// type-invalid module). `const x: i32 | null = if c then v else null` is a value-
// position `if` whose result is a nullable rep — a reference (the value-union box / the
// `string | null` ref), so a single-byte blocktype cannot carry it. Instead of an
// interned-functype typed blocktype (which the emitter avoids everywhere) or a scratch
// stash, each arm writes the binding's OWN local inside a VOID `if`: the binding local
// IS the destination. Covers the value-union box (kind 4 — `i32 | null`, `i64 | null`,
// `f64 | null`, and a multi-member `i32 | string | null`) and the `string | null` ref
// (kind 16), incl. `else if` chains and a bare `null` arm. The non-null box is pre-
// seeded with its null before the `if` (it is non-defaultable, and a void-`if` merge
// does not satisfy the validator's local-init check). The binding position counterpart
// of the return-tail nullable `if` (#484/#489). Inferred (un-annotated) bindings,
// `boolean | null` locals (a separate pre-existing gap), and non-binding value
// positions remain follow-ups.
function fi(c: boolean) {
  const v = 9
  const x: i32 | null = if c then v else null
  print(x ?? -1)
}
fi(true)
fi(false)
function chain(n: i32) {
  const x: i32 | null = if n == 0 then 10 else if n == 1 then 20 else null
  print(x ?? -1)
}
chain(0)
chain(1)
chain(2)
function fs(c: boolean) {
  const x: string | null = if c then "hi" else null
  print(x ?? "none")
}
fs(true)
fs(false)
function fd(c: boolean) {
  const x: f64 | null = if c then 1.5 else null
  if x is f64 { print(x) } else { print(0.0) }
}
fd(true)
fd(false)
function fl(c: boolean) {
  const big: i64 = 5000000000
  const x: i64 | null = if c then big else null
  if x is i64 { print(x) } else { print(0) }
}
fl(true)
fl(false)
function fm(c: boolean) {
  const x: i32 | string | null = if c then 5 else "hi"
  if x is i32 { print(x) } else { print(99) }
}
fm(true)
fm(false)
