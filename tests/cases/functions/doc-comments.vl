// @run
// @log 12
// `///` doc-comments are markdown documentation attached to a declaration; they
// are pure trivia to codegen (just like plain `//` comments), so a program that
// sprinkles them everywhere compiles and runs exactly as if they were absent.

/// Adds two numbers.
/// Returns their sum.
function add(a: i32, b: i32) a + b

/// A scratch value.
let result = add(5, 7)

//// not a doc-comment, still ignored
__store_i32__(0, 0)
__store_i32__(4, result) // trailing `//` comment, also ignored
__log__(0, 8)
