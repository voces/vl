// @run
// @log 33
// Plain FORWARD reference passing a struct VALUE: `a` calls `b`, declared later,
// with a struct argument bound to `b`'s `p: Pt` parameter. Before the fix the
// pre-pass hoisted `b`'s `p: Pt` as a `Never` param (the `type Pt` alias wasn't
// resolvable during the signature scout), and the forward call captured that
// hoisted signature, crashing codegen. The hoisted-signature param patch makes
// the forward call see the concrete `Pt` struct.
type Pt = { x: i32, y: i32 }
function a(p: Pt): i32 {
  return b({ x: p.x + 1, y: p.y + 2 })
}
function b(p: Pt): i32 {
  return p.x + p.y
}
print(a({ x: 10, y: 20 }))
