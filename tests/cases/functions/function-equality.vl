// @run
// @log 1
// @log 1
// @log 1
// Function values compare by reference (same function + same captured env): two
// variables pointing to the same function are equal; different functions are not.
// Consistent with how function-valued object fields compare.
function inc(n: i32) n + 1
function dec(n: i32) n - 1
let f = inc
let g = inc
let r = 0
if f == g { r = 1 }
__store_i32__(0, 0)
__store_i32__(4, r)
__log__(0, 8)
let h = dec
let s = 0
if f != h { s = 1 }
__store_i32__(4, s)
__log__(0, 8)
let aliased = f
let t = 0
if f == aliased { t = 1 }
__store_i32__(4, t)
__log__(0, 8)
