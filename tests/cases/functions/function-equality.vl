// @run
// @log true
// @log true
// @log true
// Function values compare by reference (same function + same captured env): two
// variables pointing to the same function are equal; different functions are not.
// Consistent with how function-valued object fields compare. `print` renders the
// booleans directly.
function inc(n: i32) n + 1
function dec(n: i32) n - 1
let f = inc
let g = inc
print(f == g)
let h = dec
print(f != h)
let aliased = f
print(f == aliased)
