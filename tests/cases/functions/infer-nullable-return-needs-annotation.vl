// @error cannot infer a nullable return type for 'maybe' — annotate the return type
// Return-type inference JOINS every return, so a function returning `5` on one path
// and `null` on another infers `i32 | null` (not first-wins `i32`, which silently
// dropped the null branch and let the caller's `!= null` narrow mis-type or crash
// codegen). The emitter cannot yet lower an UN-annotated nullable return (the A20
// return classifier carries scalar/string/array, not the nullable seed), so this is
// the robustness floor: a clear "annotate it" — the annotated form `: i32 | null`
// DOES lower. Lowering inferred union/nullable returns end-to-end is the follow-up.
function maybe(b: boolean) {
  if b { return 5 }
  return null
}
const r = maybe(true)
if r != null { print(r) } else { print(-1) }
