// @run
// @log 5
// @log 1
// FORWARD CALL into an un-annotated callee (A17). `add` uses `helper`, which is
// defined LATER with no return annotation. When `add`'s body type-checks `a +
// helper(b)`, `helper`'s return is still an unresolved `Infer` hole; it is
// inferred on demand (out of source order) to `i32`, so `a + helper(b)` checks
// against `i32` instead of erroring `expected i32, got any`. A plain
// forward-then-call chain (`first` calls later `second`) resolves the same way.
function add(a: i32, b: i32) { return a + helper(b) }
function helper(n: i32) { return n }
print(add(2, 3))

function first() { return second() }
function second() { return 1 }
print(first())
