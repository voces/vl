// @run
// @log true
// @log true
// @log false
// MUTUAL RECURSION, both members un-annotated (A17). `isEven` and `isOdd` call
// each other; neither declares a return type. Demand-driven inference resolves
// the group as a unit: each has a concrete base-case path (`return true` /
// `return false`) that fills its return hole, while the cross-call to the other
// member — being mid-inference — reads the live hole (the cycle is detected) and
// is satisfied once the base case lands. Both infer `bool`.
function isEven(n: i32) {
  if n == 0 { return true }
  return isOdd(n - 1)
}
function isOdd(n: i32) {
  if n == 0 { return false }
  return isEven(n - 1)
}
print(isEven(10))
print(isOdd(7))
print(isEven(3))
