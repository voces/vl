// @run
// @log 2
// @log 5
// The annotated counterpart to infer-union-return-needs-annotation.vl: with an
// explicit `: i32 | string` the union return lowers and the caller narrows it with
// `is string`. pick(false) → "hi" (length 2); pick(true) → 5. This is the path the
// robustness floor directs an un-annotated union return toward.
function pick(b: boolean): i32 | string {
  if b { return 5 }
  return "hi"
}
const r = pick(false)
if r is string { print(r.length) } else { print(r) }
const r2 = pick(true)
if r2 is string { print(r2.length) } else { print(r2) }
