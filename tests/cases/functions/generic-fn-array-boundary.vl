// @run
// @log 7
// @log 4
// @log 19
// @log 4
// A generic (un-annotated-param) function used as an ELEMENT of a CONCRETE function-typed array
// (`((i32,i32)=>i32)[]`) is monomorphized at the array's element type — the last typed boundary the
// `monoCoerceFnValue` coercion fans out to (it now recurses into an array literal, coercing each
// element against the element function type). So a heterogeneous table of generic functions can be
// built at a pinned signature and called by index. The checker (`genericFnAssignable`, reached
// through `assignable`'s nested `TyArray` recursion) first proves each element instantiates validly
// at the element type; a mismatch is rejected (see xfail-generic-fn-array-element-mismatch.vl).
function add(a, b) a + b
function mul(a, b) a * b

function go() {
  // a single-element i32 closure array.
  const fi: ((i32, i32) => i32)[] = [add]
  print(fi[0](3, 4)) // 7

  // f64 element — `add` clones to (f64, f64) => f64.
  const ff: ((f64, f64) => f64)[] = [add]
  print(ff[0](2.5, 1.5)) // 4

  // a multi-element table, each pinned to (i32, i32) => i32, dispatched by index.
  const fs: ((i32, i32) => i32)[] = [add, mul]
  print(fs[0](3, 4) + fs[1](3, 4)) // 7 + 12 = 19

  // an array element flows back out into a concrete function-typed binding (escape) and is called.
  const g: (f64, f64) => f64 = ff[0]
  print(g(2.5, 1.5)) // 4
}

go()
