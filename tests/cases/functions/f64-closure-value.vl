// @run
// @log 7
// @log 7
// @log 8
// @log 7
// `mix` exercises a mixed (i32, f64) signature; its `a` is deliberately unused:
// @warning Unused parameter `a`
// An f64-signature function VALUE — bound, passed as a callback, or held in a struct
// field — now lowers when CALLED, where before the `call_ref` used the all-i32 arity
// signature (`function-value call arity has no interned signature`, or a wasm type
// mismatch routing the f64 result as i32). The call site now derives the callee's REAL
// signature — from a function-typed PARAM / LOCAL / GLOBAL annotation (`(f64) => f64` →
// the `"d>d"` `$fnsig` via `calleeCloSigKey` → `annSigKey`), or, for an INFERRED binding
// (`const f = dbl`), from the underlying function's own `fnSigKeyOf` — and the f64 result
// classifies through `calleeReturnsF64` so print / numeric-context routing is correct
// (incl. a field-closure call `t.op(x)`). f64 sigs were already interned by the
// value-eligible pass; this threads the right one through the call + result.
function dbl(n: f64) { return n * 2.0 }
const f = dbl
print(f(3.5)) // 7 (inferred binding)
function apply(g: (f64) => f64, x: f64) { return g(x) }
print(apply(dbl, 3.5)) // 7 (function-typed PARAM callback)
function combine(g: (i32, f64) => f64, a: i32, b: f64) { return g(a, b) }
function mix(a: i32, b: f64) { return b * 2.0 }
print(combine(mix, 1, 4.0)) // 8 (mixed (i32, f64) => f64)
type Scaler = { op: (f64) => f64 }
const s: Scaler = { op: dbl }
print(s.op(3.5)) // 7 (function-typed FIELD)
