// @run
// @log 7
// @log ab
// @log 4
// @log hi!
// @log 1
// @log 1
// A generic function that wraps an OPERATOR — `add(a, b) { return a + b }` — is polymorphic over
// every type the operator is defined for, monomorphized per call. One unified rule drives it: when
// a binary op has a HOLE operand, a deferred `(lt, op, rt)` constraint is recorded, and the call
// site re-validates it under the substituted argument types (`binOpDefinedFor`). So `add` works at
// (i32,i32), (string,string) [concat], (f64,f64); a one-param `s + "!"` works at string; and `<`
// works for numbers and strings — while `add(1,"x")` (i32+string) and `s+"!"` over a number are
// clean type errors (see `soundness/xfail-arith-hole-operand.vl` and
// `functions/numeric-capability-violation.vl`). This SUBSUMED the per-kind numeric demand: numeric,
// string, and relational all fall out of validating the operation under substitution.

function add(a, b) { return a + b }

function exclaim(s) { return s + "!" }

function less(a, b) { return a < b }

function go() {
  print(add(3, 4)) // 7 — numeric
  print(add("a", "b")) // ab — string concat
  print(add(2.5, 1.5)) // 4 — f64
  print(exclaim("hi")) // hi! — string param + literal

  // `<` is defined for both numbers and strings — same generic function, two instances.
  if less(1, 2) {
    print(1) // 1
  } else {
    print(0)
  }
  if less("a", "b") {
    print(1) // 1
  } else {
    print(0)
  }
}

go()
