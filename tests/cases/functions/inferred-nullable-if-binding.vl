// @run
// @log 5
// @log -1
// @log 5
// @log -1
// @log 10
// @log 20
// @log -1
// @log 5000000000
// @log 0
// @log 1.5
// @log 0
// @log 5
// @log 99
// @log 1
// @log 2.5
// An UN-annotated `const x = if c then 5 else null` (and the else-less `if c then 5`,
// where the false path is the implicit `null`) now infers + lowers as a value union,
// where before it failed `emitProgram: bare null needs a struct-typed context`. The
// annotated form already lowered (#491); this drops the annotation. A static pre-pass
// (`nliInferIfLet`, beside the `let x = null` hole `nliInferLet`) derives the value-
// union NAME from the if-expression's literal / annotated-call arms, registers it
// (`registerValueUnionName` — interns the box even as the program's only union), and
// records it in the same `nli` tables, so the slot classifies (kind 4 box via
// `letIsUnion`) and the binding emits (`emitNullableIfBinding` via `letUNm`) exactly
// like an annotated nullable/value-union binding — NO annotation. Covers `i32 | null`,
// `i64 | null`, `f64 | null`, an `else if` chain, a non-null `i32 | string`, and the
// else-less form. MIXED-numeric arms (`if c then 1 else 2.5`) are NOT a union — they
// WIDEN to one numeric (f64, #490) and stay on the numeric value-position-if path.
// Arms the static pre-pass cannot classify (a bare ident `if c then v else null`), a
// pure `string | null` (a niche, not the value box), and `boolean | null` locals (a
// separate gap) remain follow-ups.
function fi(c: boolean) {
  const x = if c then 5 else null
  print(x ?? -1)
}
fi(true)
fi(false)
function fe(c: boolean) {
  const x = if c then 5 // else-less: the false path is the implicit null
  print(x ?? -1)
}
fe(true)
fe(false)
function chain(n: i32) {
  const x = if n == 0 then 10 else if n == 1 then 20 else null
  print(x ?? -1)
}
chain(0)
chain(1)
chain(2)
function fl(c: boolean) {
  const x = if c then 5000000000 else null
  if x is i64 { print(x) } else { print(0) }
}
fl(true)
fl(false)
function fd(c: boolean) {
  const x = if c then 1.5 else null
  if x is f64 { print(x) } else { print(0.0) }
}
fd(true)
fd(false)
function fm(c: boolean) {
  const x = if c then 5 else "hi"
  if x is i32 { print(x) } else { print(99) }
}
fm(true)
fm(false)
function widen(c: boolean) {
  const x = if c then 1 else 2.5 // mixed numeric → f64, NOT a union
  print(x)
}
widen(true)
widen(false)
