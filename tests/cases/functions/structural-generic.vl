// @run
// @log 4
// @log 6
// @log 3
// @log 4
// Fully-inferred structural generics (ROADMAP A13): an operator on an inference
// hole (`self.x + b.x`) no longer errors — the operands are concretized per call
// site (monomorphization), and codegen reads the concrete type from the instance
// scope (`codegenType`). `add` works on `{x, y}`; `addx` instantiates at both i32
// and f64 from its two call sites.
function add(self, b) { x: self.x + b.x, y: self.y + b.y }
let r = add({x: 1, y: 2}, {x: 3, y: 4})
print(r.x)
print(r.y)
function addx(self, b) { x: self.x + b.x }
let p = addx({x: 1}, {x: 2})
print(p.x)
let q = addx({x: 1.5}, {x: 2.5})
print(q.x)
