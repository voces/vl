// @run
// @log hi
// @log none
// @log 1
// @log 0
// @log g
// @log none
// @log hi
// @log 0
// @log 1
// @log hi!
// @log 2
// @log x!
// @log 1
// `f() ?? d` over a CALL returning a NICHE nullable — `string | null` (kind 16) or
// `boolean | null` (the i32 sentinel) — now lowers. A-coalesce-call (#493) handled the
// VALUE-UNION-BOX call-LHS `??` and explicitly deferred the niches: a call cannot be
// re-read the way an ident/field place can, and the niches need their own rep, so they
// hit `emitProgram: \`??\` is only supported on a map index get`. The call-`??` stash
// frame now carries THREE slots (the box, a `(ref null $aTypeIdx)` string slot, an i32
// bool slot); a niche call stashes its single evaluation, then `ref.is_null` (string) /
// the sentinel-2 compare (bool) selects the default or the recovered value. Nested
// chains (`f() ?? g() ?? d`, left-associative) work too — `emitExpr` re-associates them,
// and the print-routing classifiers (`exprNullableString` / `exprNulBool`) now see
// through a `??` LHS so the result type stays consistent with the emitted rep.
function fs(c: boolean): string | null {
  if c { return "hi" }
  return null
}
print(fs(true) ?? "none") // hi
print(fs(false) ?? "none") // none
function fb(c: boolean): boolean | null {
  if c { return true }
  return null
}
print(fb(true) ?? false) // 1
print(fb(false) ?? false) // 0
// nested string chain (left-assoc → re-associated)
function gs(c: boolean): string | null {
  if c { return "g" }
  return null
}
print(fs(false) ?? gs(true) ?? "none") // g
print(fs(false) ?? gs(false) ?? "none") // none (both null)
print(fs(true) ?? gs(false) ?? "none") // hi (fs(true) non-null wins)
// nested boolean chain
function gb(c: boolean): boolean | null {
  if c { return false }
  return null
}
print(fb(false) ?? gb(true) ?? true) // 0 (gb(true)=false)
print(fb(false) ?? gb(false) ?? true) // 1 (both null → true)
// recovered string is non-null: usable in concat / `.length`
function use(c: boolean) {
  const r = fs(c) ?? "x"
  print(r + "!")
  print(r.length)
}
use(true) // hi!, 2
use(false) // x!, 1
