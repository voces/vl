// @run
// @log 56509
// @log 42
// @log NULL
// @log 7
// @log NULL
// @log 9
// A NULLABLE ref array (`<ref-array> | null`, kind 18 — a `(ref null $wrapper)` niche) narrowed
// with `if p != null` and READ in the body — at PARAM, LOCAL-of-param, and CALL-RETURN positions.
// #877 wired the rep at the signature boundary (param slot / return valtype / call-arg) but left the
// body-side classifiers (`exprNullableRefArray` / `exprRefArray` / the inner-slot resolvers) with only
// a declared-LOCAL arm, so a nulreflist PARAM or a `const t = mk()` binding fell through to the
// bare-null reject. The param / local-of-param / call-return arms make the `!= null` narrow + the
// narrowed indexing (`p[0][0]`) resolve the same inner ref-list slot the local already gets.
function readParam(p: i32[][] | null) {
  const t0 = p
  if t0 != null { print(t0[0][0]) } else { print("NULL") }
}
function readStruct(p: {f: i32}[] | null) {
  if p != null { print(p[0].f) } else { print("NULL") }
}
function mk(b: boolean): i32[][] | null {
  if b { return [[7]] } else { return null }
}
function go() {
  readParam([[56509]]) // 56509
  readStruct([{f: 42}]) // 42
  readStruct(null)      // NULL
  const t = mk(true)
  if t != null { print(t[0][0]) } else { print("NULL") } // 7
  const u = mk(false)
  if u != null { print(u[0][0]) } else { print("NULL") } // NULL
  const v: i32[][] | null = [[9]]
  if v != null { print(v[0][0]) } else { print("NULL") } // 9
}
go()
