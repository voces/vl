// @run
// @log 0
// @log -1
// `boolean | null` is the NICHE value type: the i32 cell holds 0 (false), 1 (true), or
// the sentinel 2 (null). A function returning it now lowers — `return null` emits the
// sentinel, a boolean return emits 0/1, the result valtype is i32. The caller narrows
// with `!= null` and reads the boolean: f(true) → false → 0; f(false) → null → -1.
function f(b: boolean): boolean | null {
  if b { return false }
  return null
}
const r = f(true)
if r != null { if r { print(1) } else { print(0) } } else { print(-1) }
const s = f(false)
if s != null { if s { print(1) } else { print(0) } } else { print(-1) }
