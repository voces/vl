// @run
// @log 6
// @log -1
// @log 4
// @log 6
// @log 10
// A NULLABLE function value — `let c: ((i32) => i32) | null` — holds a function OR `null`,
// narrows with `if c != null` / `c == null`, and CALLS the recovered function. Before, the
// `null` and the value call both failed (`bare null needs a struct-typed context`). It is
// the closure analogue of the nullable struct (kind 9): a `(ref null $cloStruct)` cell
// (kind 19), `null` → `ref.null $cloStruct`, `== null` → `ref.is_null`, and the narrowed
// call recovers non-null (`ref.as_non_null`) before `call_ref`.
//
// Crucial DISTINCTION (the reason this needed a checker fix): `((i32) => i32) | null` is a
// nullable FUNCTION, whereas `(i32) => i32 | null` is a function RETURNING `i32 | null`.
// The two now keep DISTINCT canonical type names — `canonEmitName` preserves the grouping
// parens around a function union-member and no longer splits a top-level function type on
// `|` (the #516 rule, now applied to canonicalization too).
function inc(n: i32) { return n + 1 }
function dbl(n: i32) { return n * 2 }

// Conditionally assigned, then narrowed + called (or the null branch taken).
function run(useIt: boolean) {
  let c: ((i32) => i32) | null = null
  if useIt { c = inc }
  if c != null {
    print(c(5)) // 6 when useIt, else…
  } else {
    print(-1) // …-1
  }
}
run(true) // 6
run(false) // -1

// Two distinct nullable closures, each narrowed + called.
function two() {
  const a: ((i32) => i32) | null = dbl
  const b: ((i32) => i32) | null = inc
  if a != null {
    print(a(2)) // 4
  }
  if b != null {
    print(b(5)) // 6
  }
}
two()

// Initialized with a function directly, called after the non-null check.
function once() {
  const f: ((i32) => i32) | null = dbl
  if f != null {
    print(f(5)) // 10
  }
}
once()
