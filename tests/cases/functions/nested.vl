// @run
// @log 6
// @log 25
// Nested (non-capturing) function declarations: a function declared inside
// another body is registered and instantiated like a top-level one. `inner`
// does not capture any of `outer`'s scope yet (that's closures).
function outer() {
  function inner(x: i32) x + 1
  inner(5)
}
function square(n: i32) {
  function timesSelf(x: i32) x * x
  timesSelf(n)
}
print(outer())
print(square(5))
