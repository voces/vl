// @run
// @log z
// @log 1
// @log w
// @log 2
// A20 (string-array widening): an un-annotated function returning a `let`-bound
// `string[]` emits the correct result valtype (kind 7, the module-global string-list
// wrapper) so the caller can index it and read `.length`. The emitter classifies the
// return from the checker's inferred TYPE (`string[]`), not the return-expression
// syntax — a plain-variable return would otherwise fall back to an i32 result valtype
// and trap ("index receiver is not an array or string"). No annotation is added.
function snap() {
  const s: string[] = []
  s.push("z")
  s
}

function snap2() {
  const s: string[] = []
  s.push("w")
  s.push("w")
  s
}

let saved = snap()
print(saved[0])
print(saved.length)
saved = snap2()
print(saved[0])
print(saved.length)
