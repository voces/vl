// @error cannot infer a union return type for 'pick' — annotate the return type
// The robustness floor still guards the union shapes the emitter can't yet box
// un-annotated: a union of STRUCT refs (each return a distinct object) needs the
// variant-boxed ref rep, not the value box, so the inferred return is floored with a
// clear "annotate it". (Value unions and nullable scalars — `i32 | string`,
// `i32 | null` — DO lower inferred; see infer-union/nullable-return-codegen.vl.)
// Lowering struct-ref unions un-annotated is the remaining follow-up.
type A = { tag: i32, a: i32 }
type B = { tag: i32, b: i32 }
function pick(c: boolean) {
  if c { return {tag: 0, a: 1} }
  return {tag: 1, b: 2}
}
const r = pick(true)
print(r.tag)
