// @run
// @log 9
// A20 (array widening): an un-annotated function returning a `let`-bound i32[] emits
// correctly when its result is indexed. The emitter classifies the return from the
// checker's inferred TYPE (i32[]), not the return-expression syntax (which misses a
// plain-variable return). No annotation is added.
function squares(n: i32) {
  const xs: i32[] = []
  let i = 0
  while i < n {
    xs.push(i * i)
    i = i + 1
  }
  xs
}
print(squares(4)[3])
