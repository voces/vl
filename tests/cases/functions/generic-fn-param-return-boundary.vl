// @run
// @log 7
// @log 4
// @log ab
// @log 30
// @log 4
// @log ab
// A generic (un-annotated-param) function flows into a CONCRETE function-typed PARAMETER or RETURN,
// monomorphized at that boundary's declared type — the same `monoInstanceFor` materialization #624
// wired to annotated bindings, now shared (via `monoCoerceFnValue`) by every typed boundary a
// generic function value reaches. So `add` can be passed to a higher-order function whose callback
// parameter is `(i32,i32)=>i32` / `(f64,f64)=>f64` / `(string,string)=>string`, or RETURNED from a
// function declaring a concrete function return type. The checker (`genericFnAssignable`) first
// proves the instantiation is valid at that type (capability + return); a mismatch is rejected.
function add(a, b) a + b

// PARAMETER boundary: the callback param's declared type pins the instance.
function applyI(f: (i32, i32) => i32, x: i32, y: i32) f(x, y)
function applyF(f: (f64, f64) => f64) f(2.5, 1.5)
function applyS(f: (string, string) => string) f("a", "b")

// RETURN boundary: the function's declared return type pins the instance.
function mkF(): (f64, f64) => f64 { return add }
function mkS(): (string, string) => string { return add }

function go() {
  print(applyI(add, 3, 4)) // 7
  print(applyF(add)) // 2.5 + 1.5 = 4
  print(applyS(add)) // ab

  // a generic passed to a HOF whose param is `(i32,i32)=>i32`, called inside.
  print(applyI(add, 10, 20)) // 30

  // RETURN: bind the returned closure (concrete fn type) then call it.
  const gf: (f64, f64) => f64 = mkF()
  print(gf(2.5, 1.5)) // 4

  const gs: (string, string) => string = mkS()
  print(gs("a", "b")) // ab
}

go()
