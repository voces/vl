// @run
// @log 6
// @log 10
// @log 6
// @log 10
// @log 15
// @log 7
// @log 2
// An ARRAY OF FUNCTIONS — `((i32) => i32)[]` — a ref list whose ELEMENTS are function
// values: built from a literal of named functions, indexed, and CALLED via `call_ref`.
// The closure-element list is a NEW ref-list element kind (5): the backing is `(array (mut
// (ref null $cloStruct)))`, each element a closure fat-pointer.
//
// NAME disambiguation (the crux, mirroring the list-return and nullable-function rules):
// `((i32) => i32)[]` (a NESTED arrow under a top-level `[]`) is an array OF functions,
// whereas `(i32) => i32[]` (a TOP-LEVEL arrow) is a function RETURNING a list. `canonEmitName`
// now keeps the element's grouping parens for a function-type element AND no longer treats a
// top-level function type's trailing `[]` as an array suffix, so the two stay DISTINCT
// canonical names. `vtKindOfType` then classifies `((i32) => i32)[]` as the ref list (kind 5)
// BEFORE the bare-closure kind 14 (whose `=>` test would otherwise claim the whole array).
function inc(n: i32) { return n + 1 }
function dbl(n: i32) { return n * 2 }
function trip(n: i32) { return n * 3 }

// A LOCAL array of functions — indexed + called (constant and variable index).
function main() {
  const fns: ((i32) => i32)[] = [inc, dbl]
  print(fns[0](5)) // 6
  print(fns[1](5)) // 10
  // A variable index in a loop.
  let i = 0
  while i < fns.length {
    print(fns[i](5)) // 6, 10
    i = i + 1
  }
}
main()

// An array of functions as a PARAM — indexed + called.
function runAll(fns: ((i32) => i32)[], x: i32) {
  let i = 0
  while i < fns.length {
    print(fns[i](x))
    i = i + 1
  }
}
function passThrough() {
  const three: ((i32) => i32)[] = [trip]
  runAll(three, 5) // 15
}
passThrough()

// An indexed function bound to a local, then called.
function viaLocal() {
  const fns: ((i32) => i32)[] = [inc, dbl]
  const f = fns[0]
  print(f(6))         // 7
  print(fns.length)   // 2
}
viaLocal()
