// @run
// @log 42
// @warning Unused parameter `x`
// Regression guard (Track B / codegen): a function with an UNUSED parameter,
// called INLINE as a call argument (`print(ignore(42))`), must pass its argument
// through normally — it must NOT mis-box the argument into a closure-env struct.
// The TS host (`compiler/toWasm.ts`) emits `(call $ignore (ref.null structref)
// (i32.const 42))`: a null env plus the plain i32 argument, so the module
// validates and `WebAssembly.instantiate` accepts it. Binding the same call to a
// `let` first, or a function whose parameter IS used, must behave identically.
function ignore(x: i32) 42
print(ignore(42))
