// @run
// @log 6
// @log 7
// @log 5
// @log 20
// @log 12
// Function-type ANNOTATIONS now parse and check: `(i32) => i32`, `(i32, i32) => i32`,
// `() => i32` — a parenthesized param-type list, `=>`, and a return type. The parser
// produces the synthetic name `"(params)=>ret"` (a top-level `=>` marks it), the checker
// resolves it to a `TyFunc` (`nameToTy`), and the emitter classifies the annotated
// param / field / global / module-binding as the closure fat-pointer (kind 14), with the
// call lowering to `call_ref` over its interned signature — the same rep an INFERRED
// function value already used. Before, the type grammar had no arrow form at all, so a
// function-typed annotation failed to parse. (Scope: all-i32-param, value-returning
// signatures — `() => void` and f64/struct signatures need the internal sig key threaded
// and stay a follow-up; a function INSIDE a union, and `is`-by-signature, are separate.)
function apply(f: (i32) => i32, x: i32) { return f(x) }
function inc(n: i32) { return n + 1 }
print(apply(inc, 5)) // 6 (function-typed PARAM)
type Combiner = { op: (i32, i32) => i32 }
function add(a: i32, b: i32) { return a + b }
const c: Combiner = { op: add }
print(c.op(3, 4)) // 7 (function-typed FIELD, multi-arg)
function five() { return 5 }
const g: () => i32 = five
print(g()) // 5 (function-typed GLOBAL, no params)
const dbl: (i32) => i32 = function(n: i32) {
  return n * 2
}
print(dbl(10)) // 20 (module-scope binding, lambda init)
// A function-typed param threaded through and called.
function twice(f: (i32) => i32, x: i32) { return f(f(x)) }
print(twice(inc, 10)) // 12
