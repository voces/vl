// @run
// @log 5
// @log 9
// A function body of `{ name }` — a brace wrapping a bare identifier — is a BLOCK
// whose tail expression is the value (an implicit return of the binding), NOT a
// one-field shorthand object literal. Object literals are identified by a `key:`
// pair; a genuine shorthand object in body position needs parens (`({ x })`).
const base: i32 = 9
function echo(n: i32): i32 { n }
function getBase(): i32 { base }
print(echo(5))
print(getBase())
