// @run
// @log 5
// @log 7
// @log 7
// @log 42
// A STRUCT-returning function used as a VALUE — bound, or passed as an `(i32) => S`
// callback — now lowers when called, and its RESULT types as that struct (so `f(5).x` /
// `const p = f(5); p.x` resolve the field), where before it failed `function-value call
// arity has no interned signature`. The value-eligible sig pass now interns a struct
// function's `>sN;` sig for non-field values too (it already did for object-field
// closures); `calleeReturnsStructIdx` parses the struct index back out of the resolved
// `>sN;` key, mirroring `fnRetStructIndex` for a named function, and feeds both
// `structIndexOfExpr` and `exprStruct` so the closure-call result classifies as a struct
// (binding cell + field read). Builds on the same `cloSigKeyExt` interning the void slice
// added.
type Point = { x: i32, y: i32 }

function mk(n: i32) { return { x: n, y: n } }

const f = mk
const p = f(5)
print(p.x) // 5 (bound struct closure; result typed as Point)

function build(g: (i32) => Point, n: i32) { return g(n) }
const q = build(mk, 7)
print(q.x) // 7 (an (i32) => Point callback; `build` itself returns the struct)
print(build(mk, 7).y) // 7 (member read directly off the closure-call result)

// The bound closure invoked inline, field read off the temporary.
print(f(42).y) // 42
