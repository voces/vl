// @run
// @log 5
// @log 7
// @log 7
// @log 9
// The intrinsic floor (std-design D1 / collections-design §LS.2):
// `__array_new__(n, fill)` → `array.new` — allocate a list of a length known
// only at RUNTIME (the capability the array literal cannot express), every
// slot set to `fill`, `len == cap == n`. The element type is inferred from the
// fill argument; the result is an ordinary `T[]` (length, index read/write).
const n = 3
const xs = __array_new__(n + 2, 7)
print(xs.length)
print(xs[0])
print(xs[4])
xs[2] = 9
print(xs[2])
