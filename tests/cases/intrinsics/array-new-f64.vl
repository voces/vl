// @run
// @log 2
// @log 0.5
// @log 0
// @log 0.5
// Per-element-type monomorphization: an f64 fill allocates an f64-element
// list (the element wasm type flows through `array.new`), and `__array_copy__`
// moves f64 elements between f64 backings.
const fs: f64[] = __array_new__(2, 0.5)
print(fs.length)
print(fs[1])
const fd: f64[] = __array_new__(4, 0.0)
__array_copy__(fd, 2, fs, 0, 2)
print(fd[0])
print(fd[3])
