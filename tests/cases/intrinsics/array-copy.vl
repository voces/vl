// @run
// @log 0
// @log 20
// @log 30
// @log 40
// @log 0
// @log 1
// `__array_copy__(dst, dstAt, src, srcAt, count)` → `array.copy` — bulk-move
// `count` elements from `src[srcAt..]` into `dst[dstAt..]` in ONE engine-level
// operation (the memcpy the grow/concat/slice paths need). Here: a middle run
// of `src` lands at offset 1 of a zeroed destination; the slots outside the
// copied range are untouched.
const src: i32[] = [10, 20, 30, 40, 50]
const dst: i32[] = __array_new_default__(6)
__array_copy__(dst, 1, src, 1, 3)
print(dst[0])
print(dst[1])
print(dst[2])
print(dst[3])
print(dst[4])
// A zero-length copy is a no-op (never a trap).
__array_copy__(dst, 0, src, 0, 0)
print(1)
