// @run
// @log 10
// @log 10
// @log 20
// @log 30
// @log 20
// @log 30
// @log 40
// @log 40
// Overlapping ranges within ONE backing: `array.copy` has memmove semantics
// (the engine copies as if through a temporary), so a forward shift
// (dst > src) and a backward shift (dst < src) both preserve the run.
const xs: i32[] = [10, 20, 30, 40]
// Forward overlap: shift [0..3) right by one → 10 10 20 30.
__array_copy__(xs, 1, xs, 0, 3)
print(xs[0])
print(xs[1])
print(xs[2])
print(xs[3])
const ys: i32[] = [10, 20, 30, 40]
// Backward overlap: shift [1..4) left by one → 20 30 40 40.
__array_copy__(ys, 0, ys, 1, 3)
print(ys[0])
print(ys[1])
print(ys[2])
print(ys[3])
