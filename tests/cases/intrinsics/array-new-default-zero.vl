// @run
// @log 4
// @log 0
// @log 0
// @log 6
// @log 0
// `__array_new_default__(n)` → `array.new_default` — allocate `n`
// default-initialized (ZEROED) slots. The element type comes from context (the
// binding annotation / the enclosing return type), like an empty `[]`.
const xs: i32[] = __array_new_default__(4)
print(xs.length)
print(xs[0])
print(xs[3])
function mk(len: i32): i32[] {
  return __array_new_default__(len)
}
const zs = mk(6)
print(zs.length)
print(zs[5])
