// @run
// @log hi
// @log hi
// @log 5
// Reference-element fills: the fill value lands in every slot (a non-null ref
// stores into the nullable-widened backing slot directly). String and struct
// elements monomorphize through the same interner as their literals. NOTE:
// the native emitter's ref-element coverage is long tail — this case is
// host-corpus only until that lands (it fails LOUDLY there, never wrong bytes).
const ss = __array_new__(2, "hi")
print(ss[0])
print(ss[1])
type P = { x: i32 }
const ps = __array_new__(2, { x: 5 })
print(ps[1].x)
