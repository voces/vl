// @run
// @log 42
// @log 30
// @log 3.5
// @log 9000000000
// @log 2.25
// @log true
// @log false
// @log hello
// @log foobar
// The `print(x)` builtin logs a value of any printable type. Codegen dispatches
// on the argument's type to a type-specific host sink: numerics/boolean go
// through a direct value import; a string is copied to scratch and rendered via
// `__log_string__`. Booleans render as `true`/`false`.
print(42)
let x = 10
let y = 20
print(x + y)
print(3.5)
let big: i64 = 9000000000
print(big)
let f: f32 = 2.25
print(f)
print(true)
print(false)
let s = "hello"
print(s)
print("foo" + "bar")
