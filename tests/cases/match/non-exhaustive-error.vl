// @check
// @error non-exhaustive match
// A `match` over a literal union must cover every member (or have a `_`) — the exhaustiveness
// guarantee that makes `match` safer than an if-chain (review C3's silent fallthrough).
type K = "a" | "b" | "c"
function go() {
  const k: K = "a"
  match k {
    "a" => { print(1) }
    "b" => { print(2) }
  }
}
go()
