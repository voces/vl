// @check
// A `match` subexpression is TRANSPARENT to return-tail tracking: the checker
// saves/restores the tail flag around a match (as `checkIfStmtNode` does), so a
// sibling expression in the same tail statement types identically whether or
// not a match precedes it. The else-less value-`if` argument types `1 | null`
// in BOTH functions here; a stale flag instead re-typed the sibling AFTER the
// match as void, so `pick` alone failed with "argument 2: expected i32?, got
// void" while the match-free `pickCtl` checked clean. (Check tier only: the
// emitter does not lower a union-valued else-less `if` yet.)
function take(a: i32, v: i32 | null) {
  if v != null { a + v } else { a }
}
function pickCtl(c: boolean) {
  take(0, if c { 1 })
}
function pick(c: boolean, k: "a" | "b") {
  take(match k { "a" => 0, "b" => 10 }, if c { 1 })
}
print(pickCtl(true) + pick(true, "b"))
