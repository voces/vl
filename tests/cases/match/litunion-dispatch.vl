// @run
// @log 1
// @log 2
// @log 2
// @log b
// @log other
// @log v
// `match` over a literal union — exhaustive dispatch, no fallthrough (review C2/C3). Exercises a
// VALUE-returning match with an OR-pattern (`"b" | "c" => 2`), a void statement-position match, and
// a `_` wildcard arm.

type K = "a" | "b" | "c"

function rank(k: K): i32 {
  match k {
    "a" => 1
    "b" | "c" => 2
  }
}

function name(k: K) {
  match k {
    "a" => { print("a") }
    "b" => { print("b") }
    "c" => { print("c") }
  }
}

type Big = "a" | "b" | "c" | "d"

function tag(k: Big): string {
  match k {
    "a" => "v"
    _ => "other"
  }
}

function go() {
  print(rank("a")) // 1
  print(rank("b")) // 2
  print(rank("c")) // 2
  name("b") // b
  print(tag("d")) // other (wildcard)
  print(tag("a")) // v
}

go()
