// @run
// @log 7
// @log neg
// @log num
// @log 9
// A VALUE-union-returning closure (`(i32) => i32 | string`) passed to a higher-order function. #648
// brought struct unions and #649 aliases into a HOF; a value union still failed — and earlier, pinning
// it pre-monomorphization emitted INVALID WASM, because the HOF body's narrowed result was NOT unboxed:
// `if r is i32 { return r }` over `r = g(x)` (g a closure PARAM) returned the raw `(ref $uBox)` against
// an i32 functype result. The struct case reads a field off the narrowed variant (no scalar unbox), so
// it needed no union NAME; the value case must unbox, which needs `r`'s union. `unionNameOfExpr` now
// resolves a closure-PARAM callee's union return from the param annotation (`paramUnionRetName`), so the
// value-union narrow unboxes — and with that, the lambda's union return is pinned pre-mono uniformly
// (struct / alias / value), so its clone interns `i>u` and the call's `ref.cast` resolves.

function unwrapI(g: (i32) => i32 | string, x: i32): i32 {
  const r = g(x)
  if r is i32 { return r }
  return -1
}

function unwrapS(g: (i32) => i32 | string, x: i32): string {
  const r = g(x)
  if r is string { return r }
  return "num"
}

// The HOF returns the value union unchanged; the caller narrows it.
function passthrough(g: (i32) => i32 | string, x: i32): i32 | string { return g(x) }

function go() {
  const g: (i32) => i32 | string = (n) => if n > 0 { n } else { "neg" }

  print(unwrapI(g, 7))   // 7  (i32 arm, unboxed in the HOF)
  print(unwrapS(g, -1))  // neg (string arm, unboxed in the HOF)
  print(unwrapS(g, 3))   // num (i32 arm → the string fallback)

  const r = passthrough(g, 9)
  if r is i32 { print(r) } // 9
}

go()
