// @run
// @log 2.5
// @log 6000000000
// @log OTHER
// A struct ARM of a variant-box union carrying a CLOSURE-ARRAY-UNION field
// (`z: (() => i64)[] | i32`). The single-shape closure-field sig pass never ran on a
// UNION ARM, and even when reached it only handled bare closure / closure-array fields —
// not a `(closure[]) | scalar` UNION field — so the narrowed `t0.z is (()=>i64)[]`
// element call `t0.z[0]()` had NO interned `() => i64` sig and fell to the i32-arity
// fallback: "no interned signature" reject, or "expected i64 found i32" when a sibling
// arity-0 closure supplied the wrong fallback sig. Fixed by running
// internShapeFieldCloSigs on single-shape union arms + descending its union fields'
// closure-array arms. Fuzz F5gJXz declared seed 530559367 case_00309.
function useIt(p: {a: f64, z: (() => i64)[] | i32} | {w: i32} | {q: i64}) {
  const t0 = p
  if (t0 is {a: f64, z: (() => i64)[] | i32}) {
    print(t0.a)
    const t320 = t0.z
    if t320 is (() => i64)[] { print(t320[0]()) } else { print("OTHER") }
  } else {
    print("OTHER")
  }
}
function go() {
  useIt({ a: 2.5, z: [() => (6000000000), () => (7000000000)] })
  useIt({ w: 77 })
}
go()
