// @run
// @log 6
// @log 8
// @log 2
// @log 5
// A GENERIC higher-order function whose element / result type-param is a STRUCT, driven by an
// un-annotated lambda — `mapArr<T,R>(xs, f)` returning `R = P` (a struct), and `filter<T>(xs, p)` over a
// `P[]` whose predicate reads a field. This was the last open corner of the closure-value-callback
// matrix (generic + struct).
//
// ROOT (and the GENERIC fix): the checker renders a lambda's struct return STRUCTURALLY (`(i32) =>
// {x:i32}`), so the monomorphizer bound the result type-param `R = {x:i32}` and `R[]` became
// `{x:i32}[]` — which the emitter's NOMINAL-keyed machinery (`nameIsRefArray`, `rlSlotByName`,
// `structIndexByName`) rejected ("only i32[] / struct/union element arrays"). Rather than teach each of
// those sites to accept a structural shape, `monoArgFnTypeName` NOMINALIZES the lambda's function type
// ONCE at the mono boundary (`resolveShapeToNominal` per param/return), so `R = P` and every downstream
// site keys on the declared name — one bridge, not N special cases.

type P = { x: i32 }

function mapArr<T, R>(xs: T[], f: (T) => R): R[] { return xs.map(f) }
function pick<T>(xs: T[], p: (T) => boolean): T[] { return xs.filter(p) }

function go() {
  // Generic .map whose result element is a struct, from an un-annotated lambda.
  const ps = mapArr([1, 2, 3], (n) => { x: n + 5 }) // [{6},{7},{8}]
  print(ps[0].x) // 6
  print(ps[2].x) // 8

  // Generic .filter over a struct array, predicate reads a field.
  const qs: P[] = [{ x: 1 }, { x: 5 }, { x: 9 }]
  const r = pick(qs, (q) => q.x > 3) // [{5},{9}]
  print(r.length)                    // 2
  print(r[0].x)                      // 5
}

go()
