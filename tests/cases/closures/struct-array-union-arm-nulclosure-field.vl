// A scalar union `{a: f64, f: (() => f64 | null)[], z: string}[] | i64` whose ARRAY arm's
// element struct has a field that is an ARRAY of closures returning `f64 | null`. The value
// is built as the array arm, then narrowed and the closure called (`t0[0].f[0]()`).
// `seedExpected`'s ArrayLitтЖТunion descent only matched a CLOSURE-element array arm
// (`unionClosureArrayArmForLit`), never a STRUCT-element array arm, so the innermost lambda
// `() => (661.5)` got no expected-return seed and self-inferred a raw `() => f64`. The
// consumer correctly casts the closure to the `() => f64|null` (boxed-result) functype and
// `call_ref`s it тАФ a runtime CAST-FAILURE TRAP against the raw-f64 producer. Fixed by
// generalizing the resolver (`unionArrayArmForLit`) to also descend a seed-safe struct-element
// array arm, so the nested closure-array-field lambda adopts `f64|null` and boxes its result.
// The `| i64` union wrapper is load-bearing (the direct `{тАж}[]` binding always lowered).
// Fuzz plain (gating) leg, seed 483550502 case_00285.
const g: {a: f64, f: (() => f64 | null)[], z: string}[] | i64 = [
  {
    a: 2.5,
    f: [() => (661.5)],
    z: "dx",
  },
]
const h: {a: f64, f: (() => f64 | null)[], z: string}[] | i64 = [
  {
    a: 3.5,
    f: [() => (null)],
    z: "ey",
  },
]
function go() {
  const t0 = g
  if (t0 is {a: f64, f: (() => f64 | null)[], z: string}[]) {
    const t1 = t0[0].f[0]()
    if t1 != null { print(t1) } else { print("NULL") }
  } else {
    print("OTHER")
  }
  const s0 = h
  if (s0 is {a: f64, f: (() => f64 | null)[], z: string}[]) {
    const s1 = s0[0].f[0]()
    if s1 != null { print(s1) } else { print("NULL") }
  } else {
