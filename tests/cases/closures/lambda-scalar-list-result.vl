// @run
// @log 6000000000
// @log 42
// @log 2
// @log 1.5
// @log 2
// @log 10
// @log 20
// @log 30
// @log 6000000000
// @log 1.5
// A lambda / closure VALUE whose RESULT is an i64-list or f32-list (`() => i64[]` /
// `() => f32[]`) lowers correctly — the closure functype result byte-matches the
// wide-list wrapper (`il64TypeIdx` / `fl32TypeIdx`), and the value call recovers it.
// The inferred-return kind carries the i64/f32-list codes (20 / 21), and the `$fnsig`
// ABI token round-trips (`L` / `F`). f64-list closures already lowered; the i64/f32
// siblings were invalid wasm (`expected (ref $type), found (ref $type)` in the body /
// `expected (ref $type), found i32` at the call). An i64-list / f32-list PARAM closure
// (`(i64[]) => i64`) lowers with them (the same ABI token feeds the param side).

function main() {
  // i64-list result — inline expr-bodied lambda over a captured list.
  const src: i64[] = [6000000000, 42]
  const v: () => i64[] = () => (src)
  const xs = v()
  print(xs[0])
  print(xs[1])
  print(xs.length)

  // f32-list result — the checker's per-node f32[] typing is unreliable, so the
  // lambda's inferred return name carries the classification.
  const fsrc: f32[] = [1.5, 2.5]
  const fv: () => f32[] = () => (fsrc)
  const fxs = fv()
  print(fxs[0])
  print(fxs.length)

  // for-in directly over an i64-list closure result.
  const ns: i64[] = [10, 20, 30]
  const nv: () => i64[] = () => (ns)
  for n in nv() {
    print(n)
  }

  // i64-list / f32-list PARAM closures — value-called with the list argument.
  const gi: (i64[]) => i64 = (a) => (a[0])
  print(gi(src))
  const gf: (f32[]) => f32 = (a) => (a[0])
  print(gf(fsrc))
}

main()
