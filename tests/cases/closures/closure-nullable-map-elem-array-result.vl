// Fuzz sweep YKq9Jw declared leg, seed 43421976 case_00257.
type T0 = {
  a: () => ({[string]: boolean} | null)[],
  f: {[string]: string | null},
  z: i64,
}

function useTwin(p: T0) {
  // `?? "zdmy"` (non-null default) coalesces the string-value map read to a NON-null string.
  const t0 = p.f["k"] ?? "zdmy"
  print(t0)
  const m0 = p.f["k1"] ?? "zdmy"
  print(m0)
  // p.a()[0] is a NULLABLE array ELEMENT (`({[string]:boolean} | null)[]`) — that null is not a
  // `??` coalesce, so it still narrows with `!= null`; its inner `["k"] ?? true` coalesces.
  const t220 = p.a()[0]
  if t220 != null { print(t220["k"] ?? true) } else { print("NULL") }
  print(p.z)
}

// Direct closure param spelling of the nullable-map-element result.
function useDirect(p: () => ({[string]: boolean} | null)[]) {
  const t = p()[0]
  if t != null { print(t["k"] ?? true) } else { print("NULL") }
}

function go() {
  const h0: {[string]: string | null} = Map()
  h0["k"] = "20220"
  h0["k1"] = "zdmy"
  const h1: {[string]: boolean} = Map()
  h1["k"] = false
  const w: {a: () => ({[string]: boolean} | null)[], f: {[string]: string | null}, z: i64} = {
    a: () => ([h1]),
    f: h0,
    z: 2,
