// @run
// @log 7
// @log NULL
// @log hey
// @log 9
// @log NULL0
// @log 5
// @log 2.5
// @log NULL
// A closure whose RESULT is an array of NULLABLE structs carrying a BOXED union field
// (`() => ({f: i64 | string | {q: i64}} | null)[]` — the variant-box-field composition).
// The bare lambda self-classified a plain `{f:…}[]` reflist keyed on a DIFFERENT
// `$fnsig` slot than the annotation-side value call's `(…|null)[]` slot — a
// cast-failure TRAP (non-null elements) / "bare null needs a struct-typed context"
// reject (`[null]` hole). Fixed by widening `nulStructElemListRetName`'s element gate:
// a non-`structElemFieldsPlain` element admits when `structFieldBoxRetName` proves
// every field lowerable (the nullable-element sibling of
// `structFieldBoxElemListRetName`), so the existing adoption/recorder/pin arms route
// the lambda through the annotated `(…|null)[]` kind-1 struct-niche rep the
// named-function value spelling already lowers. The nullable-FIELD element
// (`{f: f64 | null}`, a niche slot) rides the same widened gate. Fuzz post-#1051
// sweep declared leg.
function useIt(p: () => ({f: i64 | string | {q: i64}} | null)[]) {
  let i = 0
  while i < 4 {
    const t0 = p()[i]
    if t0 != null {
      const v = t0.f
      if v is i64 { print(v) }
      if v is string { print(v) }
      if v is {q: i64} { print(v.q) }
    } else {
      print("NULL")
    }
    i = i + 1
  }
}

function go() {
  // All three union arms + a null element through the direct closure param.
  useIt(() => ([{ f: 7 }, null, { f: "hey" }, { f: { q: 9 } }]))
  // Struct-FIELD position with a null-first body literal.
  const w: {a: () => ({f: i64 | string | {q: i64}} | null)[], z: i64} = {
    a: () => ([null, { f: 5 }]),
    z: 3,
  }
  const t = w.a()[0]
  if t == null { print("NULL0") }
  const u = w.a()[1]
  if u != null {
    const f = u.f
    if f is i64 { print(f) }
  }
  // Nullable-FIELD element sibling (`({f: f64 | null} | null)[]`) — the niche field slot.
  const g: () => ({f: f64 | null} | null)[] = () => ([{ f: 2.5 }, null])
  const e0 = g()[0]
  if e0 != null {
    const v0 = e0.f
    if v0 != null { print(v0) } else { print("FNULL") }
  }
  const e1 = g()[1]
  if e1 == null { print("NULL") }
}

go()
