// @run
// @log 5
// @log 7
// @log 12
// A closure VALUE returning a declared union ALIAS (`type Sh = C | S`), passed to a higher-order
// function and called via the param. #648 made an INLINE struct-union closure flow into a HOF; an
// ALIAS return still failed with "function-value call arity has no interned signature". The lambda
// interned its `$fnsig` as `i>u` (`cloRetKeySuffix` → `vtKindOfType` recognizes the alias as the union
// box), but the CALL site's `annRetKind` — resolving the param annotation `(i32) => Sh` — only split an
// INLINE `|` union, so a bare alias name keyed "" and the call's `ref.cast` found no matching sig.
// `annRetKind` now resolves a union alias to its member set (`unionMemberSetOf`) before the split, so
// `(i32) => Sh` keys `>u` and byte-matches the lambda — the two `$fnsig` producers agree.

type C = { c: i32 }
type S = { s: i32 }
type Sh = C | S

function callIt(g: (i32) => Sh, x: i32): i32 {
  const r = g(x)
  if r is C { return r.c }
  return -1
}

function applyA(g: (i32) => Sh, x: i32): Sh { return g(x) }

function go() {
  const g: (i32) => Sh = (n) => if n > 0 { { c: n } } else { { s: 7 } }

  // Called and narrowed inside the HOF.
  print(callIt(g, 5)) // 5

  // HOF returns the alias union; the caller narrows it.
  const r = applyA(g, -1)
  if r is S { print(r.s) } // 7

  // A second distinct callback.
  const h: (i32) => Sh = (n) => if n > 0 { { c: n * 4 } } else { { s: 0 } }
  print(callIt(h, 3)) // 12
}

go()
