// Regression: a global NULLABLE-closure value whose result union carries a struct arm
// with a NULLABLE field (`((i32, i32, i32) => {f: i64 | null} | string | f64) | null`).
// `vbUnionMemberName`'s field loop declined the TyNullable field, so the expected-return
// adoption never fired and the lambda's recorded return stayed the raw null-hole render
// (`{f: null}`) — the whole-span pin arm then interned an ARM-typed `$fnsig` (the
// `{f: i64|null}` struct row) while the narrowed value call cast to the `>u` box sig:
// a cast-failure TRAP (fuzz sweep6 multiobs leg, seed 153999330 case_00187; the union
// was registered by the sibling `u1` binding, which bypassed the loud CASE-A floor).
// Nullable fields now render canonically (`i64|null`), the map-field / nested-struct
// admissions' sibling.
// @run
// @log S
// @log other
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// @hint Intentionally-unused parameter `_q2`
const g: ((i32, i32, i32) => {f: i64 | null} | string | f64) | null = (_q0, _q1, _q2) => ({ f: null })
function go() {
  const t0 = g
  if t0 != null {
    const t1 = t0(1, 1, 1)
    if t1 is {f: i64 | null} { print("S") } else { print("O") }
  } else {
    print("NULL")
  }
  const u1: {f: i64 | null} | string | f64 = "other"
  if (u1 is string) { print(u1) } else { print("UOTHER") }
}
go()
