// @log NIL
// @log 40747256525
// @hint Intentionally-unused parameter `_q0`

// A NULLABLE-STRUCT closure RESULT via a lambda (`() => {a, f, z} | null = () => ({…})`): the
// return-adoption ladder's TyObj arm adopts the nullable, so the lambda's functype result is the
// `(ref null $S)` niche — `>n<idx>;`, byte-matching the value call's `annRetKind`. An INLINE
// shape (no TypeDecl) records through `nullableRetName`'s `tyToEmitName` render, resolving by
// field-set to the same struct index the annotation side keys. The named-function VALUE spelling
// already lowered; only the lambda adoption + inline-shape name were missing. (rep-fuzz:
// `p1r () => {a: boolean, f: {f: f64}, z: i32} | null` was a `no interned signature` reject;
// `p0r ((i32) => {f: i64} | null)[]` — the array-element carrier — graduated with it.)

// The PARAM position with the INLINE shape (the fuzzer's `p1r` spelling).
function useIt(p: () => {a: boolean, f: {f: f64}, z: i32} | null) {
  const t0 = p()
  if t0 != null { print(t0.f.f) } else { print("NIL") }
}

// A DECLARED alias, binding position, value arm + null arm.
type S = {a: boolean, f: {f: f64}, z: i32}

function go() {
  useIt(() => ({ a: true, f: { f: 82147.5 }, z: 11 }))
  const v: () => S | null = () => ({ a: true, f: { f: 82147.5 }, z: 11 })
  const tv = v()
  if tv != null { print(tv.f.f) } else { print("NIL") }
  const n: () => S | null = () => (null)
  const tn = n()
  if tn != null { print(tn.f.f) } else { print("NIL") }
  // The ARRAY-element carrier: a lambda element adopts the nullable-struct result and the
  // indexed value call reads it back (an i64 field proves the wide-field rep rides along).
  const xs: ((i32) => {f: i64} | null)[] = [(_q0) => ({ f: 40747256525 })]
  const tx = xs[0](1)
  if tx != null { print(tx.f) } else { print("NIL") }
}

go()
