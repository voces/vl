// @run
// @log 11
// @log 20
// @log 11
// A LAMBDA pushed onto a closure array infers its param from the array's element function type
// (`fs.push((n) => n + 1)` over `((i32) => i32)[]`) — `.push` now seeds the callback param the
// same way `.map`/`.filter` do, so the un-annotated lambda no longer errors "cannot infer a
// type for parameter `n`".

function go() {
  const fs: ((i32) => i32)[] = []
  fs.push((n) => n + 1)
  fs.push((n) => n * 2)
  print(fs[0](10)) // 11
  print(fs[1](10)) // 20

  // f64 element signature infers the param as f64 too.
  const gs: ((f64) => f64)[] = []
  gs.push((x) => x + 1.0)
  print(gs[0](10.0)) // 11
}
go()
