// @run
// @log 11
// @log 20
// @log 2
// @log 12
// @log 30
// An ARRAY OF FUNCTIONS (`((i32) => i32)[]`) as a function LOCAL: a closure-element ref list
// (kind 5, element heap = the shared closure fat-pointer struct). The array builds from
// function NAMES or lambda literals, supports `.length` / index / `.push`, and an INDEXED
// element is a callable closure value — `fs[i](x)` resolves the element signature from the
// array's element type and `call_ref`s through it.

function add1(n: i32) { return n + 1 }
function mul2(n: i32) { return n * 2 }

function go() {
  const fs: ((i32) => i32)[] = [add1, mul2]
  print(fs[0](10)) // 11  (add1)
  print(fs[1](10)) // 20  (mul2)
  print(fs.length) // 2

  // Index-call inside an accumulation loop (each element applied in turn).
  let acc = 5
  let i = 0
  while i < fs.length {
    acc = fs[i](acc) // 5→6→12
    i = i + 1
  }
  print(acc) // 12

  // `.push` a function value, then call the appended element.
  fs.push(mul2)
  print(fs[2](15)) // 30
}
go()
