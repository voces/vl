// @run
// @log 11
// @log 20
// @log 7
// @log 8
// A closure array at MODULE scope (a top-level `const`). The global cell is the kind-5 ref-list
// wrapper (NOT the bare closure fat-pointer — `tyIsFuncType` is top-level-arrow only, so the
// nested arrow of `((i32) => i32)[]` reads as a ref list). A const-init runs in the synthetic
// start function (threading the closure list kind so the literal builds the closure backing),
// and an empty-init global filled by `.push` works too.

function add1(n: i32) { return n + 1 }
function mul2(n: i32) { return n * 2 }

// CONST-INIT global.
const fs: ((i32) => i32)[] = [add1, mul2]

// EMPTY-INIT global, filled at runtime.
const gs: ((i32) => i32)[] = []
function seed() {
  gs.push(add1)
  gs.push(add1)
}

function go() {
  print(fs[0](10)) // 11
  print(fs[1](10)) // 20
  seed()
  print(gs[0](6)) // 7
  print(gs[1](add1(6))) // 8  (add1(add1(6)))
}
go()
