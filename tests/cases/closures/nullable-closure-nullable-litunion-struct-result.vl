type K0 = "fvjzx" | "80"
const g: (() => {f: K0} | null) | null = () => ({ f: "80" })

function go() {
  const t0 = g
  if (t0 != null) {
    const t1 = t0()
    if (t1 != null) { print(t1.f) } else { print("NULL") }
  } else {
    print("NULL")
  }
  // The LOCAL nullable-closure spelling.
  const h: (() => {f: K0} | null) | null = () => ({ f: "80" })
  if (h != null) {
    const t2 = h()
    if (t2 != null) { print(t2.f) } else { print("NULL") }
  }
  // The DIRECT (non-nullable-closure) spelling — was a loud reject before the pin agreed.
  const d: () => {f: K0} | null = () => ({ f: "80" })
  const t3 = d()
  if (t3 != null) { print(t3.f) } else { print("NULL") }
  // The numeric-widen twin through the wrapper (`{f: i64}` adopted from `{f: 5}`).
  const w: (() => {f: i64} | null) | null = () => ({ f: 5 })
  if (w != null) {
    const t4 = w()
    if (t4 != null) { print(t4.f) } else { print("NULL") }
