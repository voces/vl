// @emit-error value-union closure RESULT is not yet representable
// A struct FIELD that is an ARRAY of closures each returning a scalar+composite value
// union whose composite arm is a VALUE-UNION-element array (`(i64 | boolean)[] | i32`).
// The narrowed indexed call `p.f[0]()` casts to the array-element annotation's union BOX
// (`>u`), but the concrete element lambda self-inferred a NON-box arm (`>A`, the bare
// list) — a param-fed closure array has no producer to verify, so the twin-cast check
// never fired and the narrow `t0 is (i64 | boolean)[]` TRAPPED at runtime (`ref.cast`
// failure). The scalar+composite closure-RESULT union is the deferred hole in EVERY
// spelling (the DIRECT binding rejects it as "not yet representable" too), so the
// indexed-closure-array-element callee now rejects cleanly. Fuzz sweep 3aJP7v plain,
// seed 84127013 (p1r) — the #1034 family one closure-array level deeper.
function useIt(p: {a: f64, f: (() => (i64 | boolean)[] | i32)[], z: i32}) {
  const t0 = p.f[0]()
  if (t0 is (i64 | boolean)[]) {
    const t1 = t0[0]
    if (t1 is i64) { print(t1) } else { print("OTHER") }
  } else {
    print("OTHER")
  }
}
function go() { useIt({ a: 2.5, f: [() => ([2307])], z: 11 }) }
go()
