// @run
// @log 5.5
// @log 7.25
// @log 3.5
// @log 4.5
// @log 11
// @log 1.5
// @log 2.5
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// The f32 dual of `lambda-return-widens-{i64,f64}.vl`: a FLOAT-LITERAL-bodied lambda whose
// contextual return is f32 (`(i32) => f32 = (x) => 5.5`) infers f64 (a float literal's
// default), but the literal re-encodes EXACTLY at f32 — the same grant a direct
// `const v: f32 = 5.5` binding makes. The checker ADOPTS the expected f32 (the scalar and the
// FIELD-level `objRetWidenAdopt` arms), so the lambda's functype result is f32 and
// `emitReturnValue`/the struct construction encode the literal at f32. The named-function-VALUE
// spelling (`= mk`) already lowered — only the inline lambda's return adoption was missing.
// (rep-fuzz: `p0c/p0r/p2c/p2r (i32) => f32`, `p0c/p0r (i32) => {a: f32, f: f64, z: i32}` were
// checker rejects — "cannot assign (i32) -> f64 to ... (i32) -> f32".)

// A scalar f32 result — binding position, then called.
const v: (i32) => f32 = (_q0) => (5.5)
print(v(0))

// An f32 result at an ARGUMENT position (a `p: (i32) => f32` param).
function useIt(p: (i32) => f32) {
  print(p(0))
}
useIt((_q0) => (7.25))

// A COMPOSITE struct result with an f32 field beside an f64 and an i32 field: each field
// re-encodes at its own rep (the f32-field adoption arm records f32 on the value node so the
// literal-shape interner codes the f32 slot).
const s: (i32) => {a: f32, f: f64, z: i32} = (_q0) => ({a: 3.5, f: 4.5, z: 11})
print(s(0).a)
print(s(0).f)
print(s(0).z)

// An f32 result nested in a struct FIELD (`{f: (i32) => f32}`) and in an ARRAY element
// (`((i32) => f32)[]`) — the `seedExpected` recursion reaches the lambda at any depth.
const o: { f: (i32) => f32 } = { f: (_q0) => (1.5) }
print(o.f(0))

const xs: ((i32) => f32)[] = [(_q0) => (2.5)]
print(xs[0](0))
