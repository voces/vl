// @run
// @log 1
// @log 7
// @log 9
// @log neg
// A union-returning closure value is pinned to its union return UNIFORMLY across boundary positions,
// because the emitter now CONSUMES the contextual return type the checker recorded for each lambda
// (`inferRetNameByNode`) instead of re-deriving it per boundary. The prior arc handled the bound (#644)
// and HOF (#648–#650) positions with position-specific code; a lambda as a struct FIELD value or in a
// FACTORY return tail was not pinned, so its inferred return collapsed to one arm and the value call
// failed ("ref valtype with no interned shape"). Reading the checker's record pins all positions at
// once. Covers a STRUCT union and a VALUE union, as a struct field and a factory return.

type C = { c: i32 }
type S = { s: i32 }
type Box = { f: (i32) => C | S }
type VBox = { f: (i32) => i32 | string }

// A FACTORY: a function whose return type is a closure-union, returning a lambda.
function mkStruct(): (i32) => C | S {
  return (n) => if n > 0 { { c: n } } else { { s: 9 } }
}
function mkValue(): (i32) => i32 | string {
  return (n) => if n > 0 { n } else { "neg" }
}

function go() {
  // Struct-union closure as a struct FIELD value, called and narrowed.
  const b: Box = { f: (n) => if n > 0 { { c: n } } else { { s: 0 } } }
  const r = b.f(1)
  if r is C { print(r.c) } // 1

  // Value-union closure as a struct FIELD value.
  const vb: VBox = { f: (n) => if n > 0 { n } else { "x" } }
  const vr = vb.f(7)
  if vr is i32 { print(vr) } // 7

  // Struct-union FACTORY return.
  const g = mkStruct()
  const sr = g(-1)
  if sr is S { print(sr.s) } // 9

  // Value-union FACTORY return.
  const h = mkValue()
  const hr = h(-1)
  if hr is string { print(hr) } // neg
}

go()
