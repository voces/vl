// Graduation: the SAME nullable-field-arm union result WITHOUT any sibling binding
// registering the union (`nul-closure-nullable-field-arm-union-result.vl` has one).
// Before the `vbUnionMemberName` nullable-field admission this drew the loud CASE-A
// floor ("ref valtype with no interned shape"); the adoption + pin now registers and
// lowers the box end-to-end. Reads BOTH result flavors: the struct arm's nullable
// field (null and non-null).
// @run
// @log NULL
// @log 91
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// @hint Intentionally-unused parameter `_q2`
// @hint Intentionally-unused parameter `_q4`
// @hint Intentionally-unused parameter `_q5`
// @hint Intentionally-unused parameter `_q6`
const g: ((i32, i32, i32) => {f: i64 | null} | string | f64) | null = (_q0, _q1, _q2) => ({ f: null })
const h: ((i32, i32, i32) => {f: i64 | null} | string | f64) | null = (_q4, _q5, _q6) => ({ f: 91 })
function go() {
  const t0 = g
  if t0 != null {
    const t1 = t0(1, 1, 1)
    if t1 is {f: i64 | null} {
      const t2 = t1.f
      if t2 != null { print(t2) } else { print("NULL") }
    } else {
      print("O")
    }
  } else {
    print("GNULL")
  }
  const m0 = h
  if m0 != null {
    const m1 = m0(1, 1, 1)
    if m1 is {f: i64 | null} {
      const m2 = m1.f
      if m2 != null { print(m2) } else { print("MNULL") }
    } else {
      print("MO")
    }
  } else {
    print("HNULL")
  }
}
go()
