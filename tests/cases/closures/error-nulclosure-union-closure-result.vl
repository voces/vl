// @emit-error value-union closure RESULT is not yet representable
// An OUTER closure returning a NULLABLE CLOSURE whose INNER closure returns a VALUE
// UNION (`() => (() => i32 | boolean) | null`). The inner value-union box
// (`i32 | boolean`) is never constructed (g returns null), so no value union is
// declared and `uBoxIdx` is never minted; the inner call `t0()`'s `$fnsig` still
// keys a `>u` union-box result and `fbValtype("union")` emitted `(ref 0)` (the
// string/array type) — invalid wasm at the `t1 is i32` `struct.get` tag read. The
// box read through this nullable-closure-RESULT nesting is the deferred #875 family
// (the plain-binding nullable-closure-union already rejects), so `emitCallRef`
// REJECTs cleanly (`cloCallUnionResultUnrepresentable` CASE A: a `>u` result with no
// interned box). (rep-fuzz p3r `() => (() => i32 | boolean) | null`, was INVALID-WASM.)
const g: () => (() => i32 | boolean) | null = () => (null)

function go() {
  const t0 = g()
  if t0 != null {
    const t1 = t0()
    if t1 is i32 {
      print(t1)
    } else {
      print(0)
    }
  } else {
    print(-1)
  }
}

go()
