// @run
// @log 11
// @log 10
// @log 6
// @log 14
// A function-typed binding whose OWN parameter is a closure (`g: ((i32) => i32) => i32`) — a
// higher-order callback. Its `$fnsig` is resolved at the call from the binding annotation through
// `annSigKey` → `annParamKind`, which classified a NAME to a sig-key token but — unlike the
// kind-based `cloParamTok` and the recursive `annRetKind` — had no CLOSURE or REF-LIST case. A
// closure parameter therefore minted an empty token: the value's signature stayed un-interned and
// the call fell back to the all-i32 arity sig, emitting INVALID WASM. `annParamKind` now matches a
// function-type param (`annArrowAt`) → `c` and a ref-list param (`nameIsRefArray`) → `r<slot>;`,
// the recursive duals the other two sig-key producers already had — so the three agree.

function run1(g: ((i32) => i32) => i32): i32 { return g((n) => n + 1) }

function run2(g: ((i32) => i32, (i32) => i32) => i32): i32 {
  return g((a) => a + 1, (b) => b * 2)
}

function run3(g: ((i32) => i32, i32) => i32): i32 { return g((a) => a + 1, 5) }

const helper: ((i32) => i32) => i32 = (f) => f(7)

function go() {
  print(run1((f) => f(10))) // 11
  print(run2((p, q) => p(3) + q(3))) // (3+1) + (3*2) = 10
  print(run3((f, x) => f(x))) // 6
  print(helper((n) => n * 2)) // 14
}

go()
