// Regression: a closure RETURNING a struct that mixes a CLOSURE field whose result is
// `{f: i64}` with a NESTED-STRUCT field `{f: string[]}` — both fieldset `{f}` at
// different nesting levels. The result struct carries a plain closure field (code 14),
// so `funcTypeShapeLowerable` declines it and `internFuncTypeShapes` interned NEITHER
// the outer shape NOR its nested `{f: string[]}` field. Only the closure sibling's
// `{f: i64}` result row existed, so the `collectAnonShapes` literal path fieldset-
// collided the `{f: string[]}` field onto the `{f: i64}` twin — the outer struct's `f`
// field typed `(ref null {f: i64})`, and the nested `struct.new` stored a string[] list
// where an i64 was expected: INVALID-WASM on both the read and construction spellings
// (fuzz branching leg 2KEodO, seed 359696188 case_00071/00072, p0r + p0c). Fix:
// `internFuncTypeShapes` now interns the nested inline-shape and closure fields of a
// NON-lowerable result struct (`internNonLowerableFieldShapes`), so both `{f: i64}` and
// `{f: string[]}` rows exist before the literal is seen and `structIndexOfObjCtx`'s
// matches>=2 ambiguity resolver disambiguates via the checker's recorded node type.
// @run
// @log pf
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// @hint Intentionally-unused parameter `_q2`
function go() {
  const v: (i32, i32, i32) => {a: () => {f: i64}, f: {f: string[]}, z: boolean} = (_q0, _q1, _q2) => ({ a: () => ({ f: 3965894781 }), f: { f: ["pf", "zdmy", "zdmy"] }, z: false })
  print(v(1, 1, 1).f.f[0])
}
go()
