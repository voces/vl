// @run
// @log 73.5
// @log 5.5
// @log OTHER
// @log 8.5
// A struct closure field `f: () => {f: f64}` whose plain-struct RESULT `{f: f64}` is an
// exact fieldset+type TWIN of the struct ARM of an UNRELATED sibling union field
// `z: {f: f64} | f64`. Registering `{f: f64}` as that union's variant made
// `cbRetVariantIdx`'s anonymous-shape match collapse the closure's inferred return to the
// VARIANT — the lambda declared a `>V;` variant-result `$fnsig` while the field
// annotation's value-call keyed `>s;` (plain struct), so the `ref.cast` at `t0.f()` TRAPPED
// at runtime. The checker classified the return as a plain struct (`fRetKind == "struct"`),
// which is now authoritative for anonymous shapes: the closure result stays `>s;` and the
// call site agrees.
function go() {
  const t0: {f: () => {f: f64}, z: {f: f64} | f64} = {
    f: () => ({ f: 73.5 }),
    z: 9.25,
  }
  // Value-call the closure field and read its plain-struct result — the seat of the trap.
  print(t0.f().f) // 73.5

  // The union struct-arm read still works (the variant registration is intact).
  const s0: {f: () => {f: f64}, z: {f: f64} | f64} = {
    f: () => ({ f: 1.5 }),
    z: { f: 5.5 },
  }
  const zs = s0.z
  if zs is {f: f64} {
    print(zs.f) // 5.5
  } else {
    print("OTHER")
  }

  // The union scalar-arm read (the `f64` member) narrows the other way.
  const zf = t0.z
  if zf is {f: f64} {
    print(zf.f)
  } else {
    print("OTHER") // OTHER (t0.z is the f64 arm)
  }

  // The closure result composes through a second call on the struct-arm-bearing struct.
  print(s0.f().f + 7.0) // 8.5
}
go()
