// @run
// @log 72
// @log 9.25
// @log 5.5
// A variant-box union `{…} | f64` whose STRUCT arm has a CLOSURE field returning
// a double-`{f}`-nested struct `{f: {f: f64}}`. The inner return spelling is an
// anonymous inline shape (no TypeDecl → `nameFieldCode` cannot classify it), so
// before the fix the lambda's inferred return name leniently matched the union's
// struct-ARM variant `{f: () => {f: {f: f64}}}` (fieldset `{f}`, a CLOSURE field
// code 14) — `cbRetVariantIdx` mis-collapsed the return to that variant and the
// `$fnsig` result token keyed the arm struct instead of the `{f: {f: f64}}`
// return struct: INVALID-WASM at the lambda (`ref $type` twin mismatch). A
// whole-span `{…}` shape has no top-level arrow, so it can never denote a
// closure field — `shapeFieldTypeCompat` now rejects it.
const g: {f: () => {f: {f: f64}}} | f64 = { f: () => ({ f: { f: 72.0 } }) }

function go() {
  const t0 = g
  if t0 is {f: () => {f: {f: f64}}} {
    print(t0.f().f.f)
  } else {
    print("OTHER")
  }
  // The f64 arm of the same variant-box union narrows and reads back.
  const u1: {f: () => {f: {f: f64}}} | f64 = 9.25
  if u1 is f64 { print(u1) } else { print("UOTHER") }
  // A TRIPLE-`{f}` nest — the same twin one level deeper.
  const w: {f: () => {f: {f: {f: f64}}}} | f64 = {
    f: () => ({ f: { f: { f: 5.5 } } }),
  }
  if w is {f: () => {f: {f: {f: f64}}}} {
    print(w.f().f.f.f)
  } else {
    print("OTHER")
  }
}
go()
