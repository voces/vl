// @run
// @log 0
// @log 2
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused variable `_v`
// @hint Intentionally-unused variable `_w`
// A composite MAP-MEMBER union (`{[string]: f32} | {w: i32}`) used as a CLOSURE's declared RETURN
// type. The map-union box rep (#865/#868) works in direct positions, but an UN-annotated lambda whose
// contextual return is the map-union inferred its body's bare struct arm (`{w: i32}`), so its functype
// result was an un-interned struct ref — `emitProgram: ref valtype with no interned shape`. The checker
// now ADOPTS the map-union at the lambda's return boundary (like the value-union arm), records its
// emitter name (`mapUnionRetName`), and `synthRetAnnots` PINS `fnRet` to it, so the lambda emits the
// boxed-union result — the SAME sound rep the annotated `: {[string]:f32}|{w:i32}` return lowers.
// Covers the factory-returned closure (the original repro) and a directly-bound un-annotated lambda.
// (The bindings are never CALLED — the value-CALL of a composite-union closure result is a separate
// value-call-ABI gap; this pins the interning + lowering of the RETURN, which the fix graduates.)
function makeIt(): (i32) => {[string]: f32} | {w: i32} {
  return (_q0) => ({w: 77})
}

function go() {
  // Factory form: the map-union closure return interns + lowers through `makeIt`'s annotation.
  const _v: (i32) => {[string]: f32} | {w: i32} = makeIt()
  print(0)

  // Direct-binding form: the un-annotated lambda body `{w: 5}` (the struct arm) is adopted +
  // pinned to the map-union, so its functype result is the interned box, not a bare struct ref.
  const _w: (i32) => {[string]: f32} | {w: i32} = (_q0) => ({w: 5})
  print(2)
}

go()
