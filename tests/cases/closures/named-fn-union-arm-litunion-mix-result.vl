// @log OTHER
// The NAMED-FN producer twin of error-union-arm-litunion-mix-result.vl: a union
// whose closure arm's result is a mixed litunion+composite union
// (`((i32) => K0 | {w: i32}) | boolean`), fed a named function. The named fn's
// return annotation registers the union and its own `$fnsig` loop entry interns
// the `>u` key, so the narrowed call casts to the functype the producer was
// declared with — the union-arm synth guard must NOT regress this spelling.
type K0 = "2208" | "xhp" | "h"
function mk(_q0: i32): K0 | {w: i32} { return "2208" }
function useIt(v: ((i32) => K0 | {w: i32}) | boolean) {
  const t0 = v
  if t0 is (i32) => K0 | {w: i32} {
    const t1 = t0(1)
    if t1 is K0 { print(t1) } else { print("OTHER") }
  } else {
    print("OTHER")
  }
}
function go() {
  useIt(mk)
  useIt(true)
}
go()
// @hint Intentionally-unused parameter `_q0`
