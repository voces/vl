// @run
// @log 11
// @log 8
// @log 11
// @log 7
// @log 20
// CONTEXTUAL (bidirectional) param inference for un-annotated lambdas. A `(x) => …` literal in
// a position with a KNOWN expected function type infers its params from that type — previously
// only a `.map`/`.filter` receiver and a direct call argument did this; now EVERY contextual
// position does, through one mechanism (`seedExpected`): an annotated `let`, an annotated
// return, and a struct field. `seedExpected` also descends composites (an array / object of
// lambdas) against the expected element / field types, so a lambda nested in the shape is
// reached. (Recorded per lambda NODE, not a single-shot global, so many lambdas in one
// composite each get their own expectation.)

// Annotated `let`: `x` infers as i32 from `(i32) => i32`.
const f: (i32) => i32 = (x) => x + 1
print(f(10)) // 11

// Annotated RETURN type: the returned lambda's `x` infers from the declared return.
function mk(n: i32): (i32) => i32 {
  return (x) => x + n
}
print(mk(5)(3)) // 8

// Struct FIELD whose type is a function: the field-value lambda's param infers.
type Box = { f: (i32) => i32 }
const b: Box = { f: (x) => x + 1 }
print(b.f(10)) // 11

// A TWO-parameter field lambda — both params infer from the field's function type.
type R = { add: (i32, i32) => i32 }
const r: R = { add: (a, b) => a + b }
print(r.add(3, 4)) // 7

// A direct HOF call argument still infers (the original case, now the same mechanism).
function apply(g: (i32) => i32, x: i32) {
  return g(x)
}
print(apply((n) => n * 2, 10)) // 20
