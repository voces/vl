// @run
// @log 5
// @log 7
// @log 9
// @log 42
// @log 2.5
// @log hey
// @log bb
// @log 6000000000
// @log 8
// @hint Intentionally-unused parameter `_x`
// @hint Intentionally-unused parameter `_x`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// A closure/function-VALUE call whose RESULT is a composite VARIANT-BOX union
// (`(i32) => i32 | {w: i32}`, `() => {f: i32} | f64`, `(i32) => {f: string} | {w: i32}`,
// `() => {a, f, z} | boolean` — the R2 closure-result `$fnsig` seam). The lambda whose
// body infers ONE arm of the expected union ADOPTS the whole union
// (`variantBoxUnionRetName`), so the boxing lands at the return seam and the lambda's
// functype result IS the box — its `$fnsig` keys `>u`, byte-matching the value call's
// key, and the narrowed read unboxes the arm. Positions: local (p0), param (p1),
// returned-closure (p2), global (p3); expr- and block-bodied lambdas; positive-`is`,
// else-branch struct read, and else-branch scalar read.
type K0 = "aa" | "bb"

// p0: expr-bodied lambda, scalar arm taken.
function scalarArm() {
  const v: (i32) => i32 | {w: i32} = (_x) => (5)
  const t0 = v(1)
  if t0 is i32 { print(t0) } else { print(0) }
}
scalarArm()

// p0: block-bodied lambda constructing BOTH arms; struct arm taken at runtime.
function blockBody() {
  const v: (i32) => i32 | {w: i32} = (x) => {
    if x > 0 { return 5 }
    return { w: 7 }
  }
  const t0 = v(0)
  if t0 is i32 { print(t0) } else { print(t0.w) }
}
blockBody()

// p0: else-branch struct-member read off the box.
function elseRead() {
  const v: (i32) => i32 | {w: i32} = (_x) => ({ w: 9 })
  const t0 = v(1)
  if t0 is i32 { print(t0) } else { print(t0.w) }
}
elseRead()

// p0: struct-arm result with a scalar sibling (`{f: i32} | f64`), both arms.
function structScalar() {
  const v: () => {f: i32} | f64 = () => ({ f: 42 })
  const t0 = v()
  if t0 is {f: i32} { print(t0.f) } else { print(0) }
  const w: () => {f: i32} | f64 = () => (2.5)
  const t1 = w()
  if t1 is {f: i32} { print(t1.f) } else { print(t1) }
}
structScalar()

// p2: closure returned from a named function, struct|struct union result.
function makeIt(): (i32) => {f: string} | {w: i32} {
  return (_q0) => ({ f: "hey" })
}
function structStruct() {
  const v: (i32) => {f: string} | {w: i32} = makeIt()
  const t0 = v(1)
  if t0 is {f: string} { print(t0.f) } else { print(0) }
}
structStruct()

// p2: multi-field struct arm with a litunion field and an i64 field.
function makeK(): (i32) => {a: boolean, f: K0, z: i64} | string {
  return (_q0) => ({ a: true, f: "bb", z: 6000000000 })
}
function multiFieldK() {
  const v: (i32) => {a: boolean, f: K0, z: i64} | string = makeK()
  const t0 = v(1)
  if t0 is {a: boolean, f: K0, z: i64} { print(t0.f) } else { print("OTHER") }
}
multiFieldK()

// p1: the closure arrives as a PARAM; mixed-rep struct arm (i64 field read).
function useIt(v: () => {a: i32, f: i64, z: f32} | boolean) {
  const t0 = v()
  if t0 is {a: i32, f: i64, z: f32} { print(t0.f) } else { print("OTHER") }
}
useIt(() => ({ a: 1, f: 6000000000, z: 1.5 }))

// p3: the closure is a module GLOBAL.
const gv: () => {a: i32, f: i32, z: f64} | boolean = () => ({ a: 1, f: 8, z: 2.5 })
function globalPos() {
  const t0 = gv()
  if t0 is {a: i32, f: i32, z: f64} { print(t0.f) } else { print("OTHER") }
}
globalPos()
