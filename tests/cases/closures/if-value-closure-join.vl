// @run
// @log 11
// @log 9
// @log 20
// @log 11
// An if-EXPRESSION in value position whose branch join is a CLOSURE — `if c then (x) => x + 1
// else (x) => x - 1`, or named-function arms (`if c then inc else dec`). The if-value join
// classifiers (string / struct, added earlier) had no closure case, so the binding wasn't typed
// a closure ("call to unknown function" / "only i32 locals are supported"). `ifExprRefKind` now
// returns kind 14 for a closure join (`(ref $cloStruct)` blocktype, each arm via
// `emitClosureValue`), and `exprIsClosure` sees through the `if` so the binding/return classify
// kind 14. A bare named-function arm flips `fnValUsed` (in `collectFnValUse`) so its `$fnsig`
// interns, exactly as a directly-bound `const f = inc` does.

function inc(x: i32): i32 { return x + 1 }
function dbl(x: i32): i32 { return x * 2 }
function dec(x: i32): i32 { return x - 1 }

// a closure-returning function whose body is a closure if-join.
function choose(c: i32): (i32) => i32 {
  return if c > 0 then (x: i32) => x + 1 else (x: i32) => x - 1
}

function go() {
  // LAMBDA arms, un-annotated binding.
  const f = if 5 > 0 then (x: i32) => x + 1 else (x: i32) => x - 1
  print(f(10)) // 11

  // the else arm (a capturing-free lambda), through a returning function.
  print(choose(0)(10)) // 9

  // NAMED-function arms + an `else if` chain.
  const g = if 5 > 9 then inc else if 5 > 3 then dbl else dec
  print(g(10)) // 20 (middle arm: dbl)

  // a MIX — a named function and a lambda arm.
  const h = if 5 > 0 then inc else (x: i32) => x - 1
  print(h(10)) // 11
}
go()
