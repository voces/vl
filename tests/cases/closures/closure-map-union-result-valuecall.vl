// @hint Intentionally-unused parameter `_q0`
// The VALUE-CALL side of the map-member-union closure result (`(i32) => {[string]: f32} | {w:
// i32}`). The construct/return side (#872) interns + lowers the boxed result; calling the closure
// (`v(1)`) then reading the boxed result was the missing half — the call keyed the map result token
// (`>m`) because `annRetKind` classified the map-FIRST union name as a bare map (`nameIsMap` matches
// `{[…]}` prefixes), while the closure interned the union box (`>u`), so the value call found "no
// interned signature". `annRetKind` now excludes a map-member union (`nameIsMapMemberUnion`) so it
// keys the box (`>u`), byte-matching the closure's `$fnsig`, and the boxed result recovers + narrows.
function makeIt(): (i32) => {[string]: f32} | {w: i32} {
  return (_q0) => ({ w: 77 })
}

function go() {
  const v: (i32) => {[string]: f32} | {w: i32} = makeIt()
  const t0 = v(1)
  if t0 is {[string]: f32} {
    const t1 = t0["k"] ?? 15.5
    print(t1)
  } else {
    print("OTHER")
  }
}

go()
