// @emit-error lambda field value resolved to a non-closure field slot
// A closure-result struct whose FIELD is itself a closure, fed a NESTED lambda
// literal (`(i32) => {f: () => {f: i64}}` fed `{f: () => ({f: 9})}`): three
// same-field-name-set `{f}` shapes collide (outer closure-field, mid i64-field,
// and the inner literal's own), and the outer literal resolves a non-closure
// twin — the closure ref cannot store there. `emitObj` rejects a lambda value
// flowing into a non-closure/non-box field slot loudly (fuzz-nightly seed
// 4797042 d5); the plain-binding and named-fn spellings of the same shape lower
// fully and stay pinned by their own tests.
function go() {
  const v: (i32) => {f: () => {f: i64}} = (_q0) => ({ f: () => ({ f: 9 }) })
  print(0)
}
go()
// @hint Intentionally-unused parameter `_q0`
