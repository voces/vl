// Regression: a depth-3 closure-array chain reached through a closure VALUE call.
// `p: () => (() => (() => i32)[])[]` — calling `p()` yields an array of closures, each
// returning an array of `() => i32` closures. The checker rendered the inferred
// closure-VALUE element `() => (() => i32)[]` via `tyToEmitName` as `()=>()=>i32[]` — the
// trailing `[]` bound into the closure's RESULT (a closure returning `i32[]`) instead of
// parenthesizing the array's closure element (`(()=>i32)[]`). That mangled name interned a
// ref-list slot DISTINCT from the annotation's, so `p()`'s `$fnsig` key `>r0;` missed
// `cloSigKeys` and fell back to the all-i32 arity signature — a `call_ref` whose functype
// returned i32 into a `(ref $list)` local (INVALID-WASM: "expected (ref $type), found i32"
// at the first unwrap). The named-function spelling always worked (its return interns via
// the annotation). Fix: `tyToEmitName`'s TyArray arm wraps a TyFunc element in grouping
// parens, the array sibling of the existing TyFunc-result / union-member preservation.
// @run
// @log 2
// @log 696185
function useIt(p: () => (() => (() => i32)[])[]) {
  const t1 = p()
  const t2 = t1[0]
  const t3 = t2()
  print(t3.length)
  const t4 = t3[0]
  print(t4())
}
function go() { useIt(() => ([() => ([() => (696185), () => (12121)])])) }
go()
