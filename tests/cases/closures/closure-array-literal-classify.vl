// @run
// @log 10
// @log 11
// @log 20
// A CLOSURE-element array LITERAL (`[(x) => x + 1]`) is a REF list (element kind 5), not an i32
// list. `arrLitIsRef` classified only object- and nested-array-element literals as ref lists, so a
// closure-element literal fell through to the i32-list default: `exprArray` claimed it, the
// inferred-return scan minted a `>a` (i32-list) closure signature, and a closure VALUE returning
// one (`const mk: () => ((i32) => i32)[] = () => […]`) MISCOMPILED to invalid wasm. Treating a
// `FuncDecl`-element literal as a ref list routes it through the kind-5 machinery like a struct
// literal — so the supported positions below classify and lower correctly (and the unsupported
// closure-value return is now a clean reject, not invalid wasm).

function go() {
  // literal bound to an annotated closure-array local, then indexed + called.
  const fs: ((i32) => i32)[] = [(x) => x + 1, (x) => x * 2]
  print(fs[0](9)) // 10

  // literal as a direct call ARGUMENT (the param's kind-5 element drives it).
  print(applyFirst([(x) => x + 1])) // 11

  // literal stored as a map VALUE (the ref-list value path), read back and called.
  const m: {[string]: ((i32) => i32)[]} = Map()
  m["a"] = [(x) => x * 2]
  print((m["a"] ?? [])[0](10)) // 20
}

function applyFirst(fs: ((i32) => i32)[]): i32 { return fs[0](10) }

go()
