// @run
// @log 2.5
// @log 6000000000
// @log 1.5
// @log NIL
// @log 683.5
// @log 7.5
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`

// A NULLABLE wide-SCALAR closure RESULT (`f32 | null`, `i64 | null`, `f64 | null`) through the
// value-call ABI, at every position. The rep is the value-union `{tag, value}` BOX
// (`repOfNullable`'s scalar arm â€” a numeric scalar has no spare value to niche into), token `>u`.
// Both `$fnsig` producers key it: the lambda side via `cloRetKeySuffix` â†’ `vtKindOfType` â†’
// "union", and the annotation side via `annRetKind`'s nullable-scalar arm â€” `i64`/`f64`/`f32`
// alongside the original `i32`. (rep-fuzz: `p1r () => f32 | null`, `p2r (i32) => i64 | null` were
// `function-value call arity has no interned signature` rejects â€” the annotation producer keyed
// "" for the wide scalars while the lambda interned `>u`.)
//
// `boolean | null` stays OFF this path by design: its result valtype is the plain i32 sentinel
// (niche), which the all-i32 arity fallback already agrees with.

// The PARAM position (`p1r`): the value call inside the callee keys the param annotation.
function useF32(p: () => f32 | null) {
  const t = p()
  if t != null { print(t) } else { print("NIL") }
}

// The RETURN position (`p2r`): the lambda flows out through an annotated return.
function makeI64(): (i32) => i64 | null { return (_q0) => (6000000000) }

// A genuinely-null arm through a named-function VALUE â€” the box's null atom reads back.
function mkF64(k: i32): f64 | null {
  if k > 0 { return 1.5 }
  return null
}

// A CHAINED value call (`v(1)()`): the box result of the inner closure binds through the
// checker-typed net (`nodeTyIsNulScalarBox`) â€” no intermediate binding needed.
function makeNested(): (i32) => (() => f32 | null) {
  return (_q0) => (() => (683.5))
}

// A union-VARIANT struct field carrying a nullable-scalar-result closure
// (`{f: () => f32 | null} | string`) â€” the `is`-narrowed field call resolves the same `>u` sig.
const g: {f: () => f32 | null} | string = { f: () => (7.5) }

function go() {
  useF32(() => (2.5))
  const v = makeI64()
  const ti = v(1)
  if ti != null { print(ti) } else { print("NIL") }
  const w: (i32) => f64 | null = mkF64
  const td = w(1)
  if td != null { print(td) } else { print("NIL") }
  const tn = w(0)
  if tn != null { print(tn) } else { print("NIL") }
  const tc = makeNested()(1)()
  if tc != null { print(tc) } else { print("NIL") }
  const gv = g
  if gv is {f: () => f32 | null} {
    const tf = gv.f()
    if tf != null { print(tf) } else { print("NIL") }
  } else {
    print("OTHER")
  }
}

go()
