// @run
// @log 1
// @log 9
// @log 5
// @log neg
// A union-returning closure stored in an ARRAY, called by index and narrowed (`arr[i](x)` over an
// `((i32) => C | S)[]`). The narrow-site union resolution re-derived a call result's union per CALLEE
// KIND (named / binding / param / field), but an INDEXED closure-array callee fell through — so the
// struct case rejected ("is receiver is not a union value") and the value case emitted invalid wasm
// (the box read as i32). Both `exprUnion` and `unionNameOfExpr` now FALL BACK to the checker's per-node
// type for a CALL whose callee they don't resolve (`nodeTyIsUnion` / `nodeUnionName`) — the consumer
// dual of the producer's `inferRetNameByNode`. The fallback is scoped to a call (not an if-expr, which
// has its own union rep) and `nodeUnionName` renders only a small VALUE union (a struct union narrows
// via the variant alone), so the costly type render never touches the hot path.

type C = { c: i32 }
type S = { s: i32 }

function go() {
  // Struct union — narrow each arm via the variant.
  const g: (i32) => C | S = (n) => if n > 0 { { c: n } } else { { s: 9 } }
  const arr = [g]
  const a = arr[0](1)
  if a is C { print(a.c) } // 1
  const b = arr[0](-1)
  if b is S { print(b.s) } // 9

  // Value union — the narrowed read must UNBOX.
  const h: (i32) => i32 | string = (n) => if n > 0 { n } else { "neg" }
  const vs = [h]
  const r = vs[0](5)
  if r is i32 { print(r) } // 5
  const r2 = vs[0](-1)
  if r2 is string { print(r2) } // neg
}

go()
