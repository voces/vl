// @run
// @log 5
// @log 42
// @log 901
// @log 24929
// @log 6692589
// @log 6000000000
// A SMALL int literal at an i64-returning LAMBDA's return seam widens to i64 — at every
// contextual position (binding, block body, param, nullable-of-closure, closure field).
// The lambda's body infers i32, but the contextual function type demands i64: the checker
// ADOPTS the expected return (`recordCbExpectedRet`), so the widening lands INSIDE the
// body at the return seam and the emitted functype result matches every call site.
// (rep-fuzz: `p1r () => i64`, `p3r () => i64`, `p0r (() => i64) | null`, `p1r {f: () => i64}`
// were invalid wasm — `expected i64, found i32` at the call.)

const v: () => i64 = () => (5)
print(v())

const b: () => i64 = () => {
  const x = 42
  return x
}
print(b())

function useIt(p: () => i64) {
  print(p())
}
useIt(() => (901))

function nul() {
  const n: (() => i64) | null = () => (24929)
  const t = n
  if t != null {
    print(t())
  } else {
    print("NULL")
  }
}
nul()

function useField(p: { f: () => i64 }) {
  print(p.f())
}
useField({ f: () => (6692589) })

// A literal already out of the i32 range keeps working (the body infers i64 natively).
const big: () => i64 = () => (6000000000)
print(big())
