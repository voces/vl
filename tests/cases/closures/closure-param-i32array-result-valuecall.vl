// @run
// @log true
// @log false
// @log 7
// @log true
// @log false
// @log true
// The inner closures ignore their params (they probe the ABI, not the arg):
// @warning Unused parameter
// A closure whose RESULT is an i32-BACKED LIST — `boolean[]`, `(boolean | null)[]` or a
// litunion `K[]` — value-called through a closure PARAMETER, an ARRAY element, a struct
// FIELD, and the higher-order chain `p()(1)`. The concrete-lambda collector keys such a
// result `>a` (via `cloRetValKind` → `vtKindOfType` → "list") for ALL of them — they share
// the one i32-list backing (`nameIsI32Array`) — but the call site derived its key through
// `annRetKind`, which recognized only the LITERAL name `"i32[]"` and returned "" for
// `boolean[]` / a nullable-bool / litunion array. So the value call keyed "" and rejected
// loudly ("function-value call arity has no interned signature") even though a concrete
// lambda of the exact shape was interned. `annRetKind` now keys the whole i32-list family
// via `nameIsI32Array` (the dual of `annParamKind`, which already did), so the two sig
// producers agree and the value call resolves the interned signature.

// Higher-order closure PARAMETER whose result is a closure returning boolean[] (`p()(1)`):
function useHof(p: () => ((i32) => boolean[])) { print(p()(1)[0]) }
// Direct closure PARAMETER returning boolean[]:
function useDirect(p: (i32) => boolean[]) { print(p(1)[0]) }

function go() {
  useHof(() => ((q0) => ([true])))          // true
  useDirect((q0) => ([false]))              // false
  // ARRAY of closures returning i32[] — element value-called:
  const fs: ((i32) => i32[])[] = [(q0) => ([7])]
  print(fs[0](1)[0])                        // 7
  // Struct FIELD closure returning boolean[] — read back and value-called:
  const o: {f: (i32) => boolean[]} = {f: (q0) => ([true])}
  print(o.f(1)[0])                          // true
  // The exact graduated rep-fuzz shapes: a NULLARY `() => boolean[]` value, and an ARRAY
  // of them — value-called (`g()`, `gs[0]()`):
  const g: () => boolean[] = () => ([false])
  print(g()[0])                             // false
  const gs: (() => boolean[])[] = [() => ([true])]
  print(gs[0]()[0])                         // true
}
go()
