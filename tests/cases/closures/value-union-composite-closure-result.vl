// @log 0
// @log 2.5
// @hint Intentionally-unused parameter `_q0`
// A struct field that is a closure returning a VALUE UNION with a composite member
// (`(i32) => f32 | {w: i32}`): the value call `v.f(1)` types as the whole union and the
// `is f32` narrow reads each arm soundly — the struct arm (`{w: 77}`) takes the else
// branch, the f32 arm round-trips through `__print_f32__`. Was an INVALID-WASM hole (the
// narrowed f32 arm mis-read the plain struct rep as a `{tag, value}` box); the value-call
// composite-union result rep now boxes and reads back correctly.
function go() {
  const vs: {a: i32, f: (i32) => f32 | {w: i32}, z: f32} = {
    a: 11,
    f: (_q0) => ({w: 77}),
    z: 3.5,
  }
  const s0 = vs.f(1)
  if s0 is f32 { print(s0) } else { print(0) }
  const vf: {a: i32, f: (i32) => f32 | {w: i32}, z: f32} = {
    a: 11,
    f: (_q0) => (2.5),
    z: 3.5,
  }
  const f0 = vf.f(1)
  if f0 is f32 { print(f0) } else { print(0) }
}
go()
