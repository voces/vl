// @run
// @log NULL
// @log 5000000077
// A 3-arm variant box `{f: nullable-closure} | i64 | f64` whose struct arm holds a
// NULLABLE-CLOSURE field `((i32,i32,i32) => i32 | null) | null`. The closure's RESULT is
// itself a value union `i32 | null` (the nullable-i32 general box). A variant-box struct
// ARM is registered via `registerVariantArmFieldUnions`, which skipped closure fields (its
// arms all gated on `annArrowAt < 0`) — so the inner `i32 | null` result union never
// registered, the boxed-i32 heap `(struct (field i32))` was never minted (`vbI32Used`
// stayed false), and the narrowed call-result read `print(t2)` unboxed the box value by
// casting it to the WRONG heap (the outer `{f}` struct) — INVALID-WASM. The walk now
// descends closure fields' result unions like `registerShapeFieldUnions` does for a plain
// annotation. Fuzz sweep wo7cNe multiobs, seed 254586317 (p3r).
const g: {f: ((i32, i32, i32) => i32 | null) | null} | i64 | f64 = { f: null }
function go() {
  const t0 = g
  if t0 is {f: ((i32, i32, i32) => i32 | null) | null} {
    const t1 = t0.f
    if t1 != null {
      const t2 = t1(1, 1, 1)
      if t2 != null { print(t2) } else { print("NULL") }
    } else {
      print("NULL")
    }
  } else {
    print("OTHER")
  }
  const u1: {f: ((i32, i32, i32) => i32 | null) | null} | i64 | f64 = 5000000077
  if u1 is i64 { print(u1) } else { print("UOTHER") }
}
go()
