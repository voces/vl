// @emit-error ref valtype with no interned shape
// A closure result shape whose list field's element is a UNION
// (`{f: (A | string)[]}`): NOT admitted by `structElemArrayLowerable` — the
// union-box element rep carries the R3 composition seams — so the shape stays
// un-interned and the closure is a loud reject, never invalid wasm. (The
// struct-element admission is exactly `S[]` / `{…}[]` leaves; this pins the
// boundary.)
type A = {w: i32}
const v: () => {f: (A | string)[]} = () => ({f: ["x"]})
const t = v()
print(1)
