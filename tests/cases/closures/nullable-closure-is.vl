// @run
// @log 10
// @log -1
// @log 12
// `f is (A) => B` over a NULLABLE-closure operand (`f: ((i32) => i32) | null`) — a NON-NULL
// test, the closure-typed `is` form of `f != null`. Was rejected at emit ("`is` test but no
// union type declared"): `setNarrowFromCond`/`emitIs` only knew union/variant/niche `is`
// forms. `emitIs` now lowers it to `ref.is_null` + `eqz`; calling `f(x)` in the then-branch
// already ref-casts the nullable value to non-null, so no narrowing key is needed. (The
// `if f == null { … } else { f(x) }` form already worked — this is the `is` equivalent.)

function apply(f: ((i32) => i32) | null, x: i32): i32 {
  if f is ((i32) => i32) { return f(x) }
  return -1
}

function go() {
  const g: (i32) => i32 = (n) => n * 2
  print(apply(g, 5)) // 10
  print(apply(null, 5)) // -1

  // composes with a non-null arg through another binding.
  const h: (i32) => i32 = (n) => n + 2
  print(apply(h, 10)) // 12
}
go()
