// @run
// @log 2
// @log true
// @log false
// @log 99
// The TOP-LEVEL closure-array-as-union-arm (`((i32, i32, i32) => boolean)[] | i32`) with the
// array arm CONSTRUCTED and exercised at runtime: `.length`, indexed element calls
// `t0[0](5, 2, 3)`, and the scalar arm. Companion to the no-lambda spelling — verifies the
// interned element sig lowers the same whether the closure of the arm's type exists or not.
function useIt(p: ((i32, i32, i32) => boolean)[] | i32) {
  const t0 = p
  if t0 is ((i32, i32, i32) => boolean)[] {
    print(t0.length)
    print(t0[0](5, 2, 3))
    print(t0[1](9, 1, 3))
  } else {
    print(t0)
  }
}
function useScalar(p: ((i32, i32, i32) => boolean)[] | i32) {
  const t0 = p
  if t0 is i32 { print(t0) } else { print("OTHER") }
}
function go() {
  useIt([(a, b, c) => (a > b && c > 0), (a, b, c) => (b > a && c > 0)])
  useScalar(99)
}
go()
