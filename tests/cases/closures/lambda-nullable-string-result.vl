// @run
// @log hey
// @log hey
// @log NIL
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`

// A `string | null` closure RESULT via a lambda: the body infers a bare `string` member of the
// expected nullable (`(i32) => string | null = (x) => "hey"`). The lambda-return adoption's
// nullable-string arm adopts `string | null`, so the lambda's functype result is the string-ref
// `ref.null` NICHE — the position-independent rep the value call recovers — and `synthRetAnnots`
// pins it (via the `nullableRetName` recording). The named-function VALUE (`= mk`) already lowered;
// only the inline lambda's adoption was missing. (rep-fuzz: `p0r (i32) => string | null` was a
// `function-value call arity has no interned signature` reject.)
//
// RESTRICTED to the string niche: a nullable SCALAR (`i32 | null`) and a VALUE-UNION result
// (`string | i32`, `i64 | boolean`) lower STANDALONE but do NOT yet compose through a
// nullable-closure param / map value (the named-function VALUE cleanly REJECTS those), so adopting
// them would EXPOSE invalid wasm in composition — they stay loud rejects until the sibling
// value-union / nullable composition reps (C2/C3) land.

function go() {
  // The binding form the fuzzer exercises (`p0r`): a lambda into a `(i32) => string | null` slot,
  // value-called and null-checked.
  const v: (i32) => string | null = (_q0) => ("hey")
  const r = v(0)
  if r != null { print(r) } else { print("NIL") }

  // At an ARGUMENT position (a `p: (i32) => string | null` param), the lambda is seeded by
  // `seedExpected` and adopts the same nullable.
  useIt((_q0) => ("hey"))

  // A NAMED function VALUE whose body genuinely returns `null` on a path — the null arm niches to
  // `ref.null` and reads back as `null` (the rep the lambda now shares).
  const w: (i32) => string | null = mk
  const rw = w(0)
  if rw != null { print(rw) } else { print("NIL") }
}

function useIt(p: (i32) => string | null) {
  const t = p(0)
  if t != null { print(t) } else { print("NIL") }
}

function mk(k: i32): string | null {
  if k > 0 { return "yes" }
  return null
}

go()
