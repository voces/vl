// @run
// @log 1
// @log 9
// @log 6
// A struct/variant-union-returning closure VALUE passed to a HIGHER-ORDER FUNCTION, then called via
// the param and narrowed (`callIt(g, x)` where `g: (i32) => C | S`). #644 made a BOUND union closure
// callable (`const g = …; g(1)`); flowing one into a HOF additionally MONOMORPHIZES it — its lifted
// slot is REPLACED by an instance cloned with `nret = fnRet`. The union-return annotation
// (`synthRetAnnots`) must therefore be pinned BEFORE monomorphization, or the clone keeps `fnRet < 0`
// and emits a single-arm struct `$fnsig` result the call-site `ref.cast` to `i>u` rejects ("ref
// valtype with no interned shape"). The pre-mono pass is restricted to STRUCT/variant unions; a value
// union (`i32 | string`) stays on the post-mono pass and, if it escapes to a HOF, is a clean reject
// (its clone passes mono un-pinned) — never invalid wasm.

type C = { c: i32 }
type S = { s: i32 }

// The HOF calls the callback internally and narrows the union result to an i32.
function callIt(g: (i32) => C | S, x: i32): i32 {
  const r = g(x)
  if r is C { return r.c }
  return -1
}

// The HOF RETURNS the union result (passthrough) — the caller narrows it.
function applyA(g: (i32) => C | S, x: i32): C | S { return g(x) }

function go() {
  const g: (i32) => C | S = (n) => if n > 0 { { c: n } } else { { s: 9 } }

  // Passed to a HOF that narrows internally.
  print(callIt(g, 1)) // 1

  // Passed to a HOF that returns the union; narrow the HOF result.
  const r = applyA(g, -1)
  if r is S { print(r.s) } // 9

  // A second distinct callback through the same HOF.
  const h: (i32) => C | S = (n) => if n > 0 { { c: n * 2 } } else { { s: 0 } }
  print(callIt(h, 3)) // 6
}

go()
