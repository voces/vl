// @run
// @log NIL
// @log 7
// @log 42
// @log STRUCT
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`

// A NULLABLE VARIANT-BOX closure result (`{a, f, z} | i32 | null` вАФ a composite union PLUS the
// null member): the `>u` box already carries a null member atom, so `variantBoxUnionRetName`
// peels the `TyNullable` wrapper and appends `|null`, the adopted lambda's `$fnsig` keys `>u`
// (matching `annRetKind`'s вЙ•2-non-null arm), and `nodeUnionName`'s TyNullable arm renders the
// same spelling for the call-inferred binding's unbox/narrow. All three arms are live below,
// lambda AND named-function spellings. (rep-fuzz: `p0r`/`p0c (i32) => {a: string, f: i32,
// z: boolean} | i32 | null` were `bare null needs a struct-typed context` rejects.)

function mk(_q0: i32): {a: string, f: i32, z: boolean} | i32 | null {
  return { a: "n", f: 9, z: true }
}

function readIt(v: (i32) => {a: string, f: i32, z: boolean} | i32 | null) {
  const t0 = v(1)
  if t0 != null {
    const t1 = t0
    if t1 is i32 {
      print(t1)
    } else {
      if t1 is {a: string, f: i32, z: boolean} {
        print(t1.f)
      } else {
        print("OTHER")
      }
    }
  } else {
    print("NIL")
  }
}

function go() {
  readIt((_q0) => (null))
  readIt((_q0) => ({ a: "x", f: 7, z: true }))
  readIt((_q0) => (42))
  const w: (i32) => {a: string, f: i32, z: boolean} | i32 | null = mk
  const t = w(1)
  if t != null {
    const u = t
    if u is i32 { print(u) } else { print("STRUCT") }
  } else {
    print("NIL")
  }
}

go()
