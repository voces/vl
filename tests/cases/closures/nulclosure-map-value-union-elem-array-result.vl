// @run
// @log OTHER
// @log 9.25
// @log hi
// @log NULL
// A NULLABLE closure whose RESULT is an array of map-member VALUE unions
// (`(() => ({[string]: string} | f64)[]) | null`). Two independent defects:
//  (1) REGISTRATION — `registerInlineUnion`'s nul-closure block handled value-union /
//      map-member-union / variant-box / bare-map results, but NOT a ref-ARRAY result
//      whose element is a value union, so the element union was never interned. Un-
//      registered, the narrowed `p()[0]` element box defaulted to type index 0 ("expected
//      struct type at index 0, found (array (mut i32))") — INVALID-WASM. Demonstrated by
//      the `useNull(null)` call below (no lambda adopts, so the annotation is the ONLY
//      spelling — the adoption fix alone does not cover it).
//  (2) ADOPTION — the bare lambda `() => ([9.25])` self-classified an `f64[]` reflist
//      keyed on a DIFFERENT `$fnsig` slot than the annotation-side value call's union-box
//      `(…)[]` slot: a cast-failure TRAP. Fixed by the elemMapUnionListRetName adoption +
//      recorder quadruple (`synthRetAnnots` pins via `parenUnionArrElemName`; the map-union
//      sibling of the element-value-union / element-variant-box arms). The named-fn value
//      spelling already lowered this rep.
// Fuzz sweep YKq9Jw multiobs, seed 58637234 case_00137.
function useIt(p: (() => ({[string]: string} | f64)[]) | null) {
  if p != null {
    const t1 = p()[0]
    if t1 is {[string]: string} {
      print(t1["k"] ?? "z")
    } else {
      print("OTHER")
    }
  } else {
    print("NULL")
  }
}

function useNull(p: (() => ({[string]: string} | f64)[]) | null) {
  if p != null {
    const t1 = p()[0]
    if t1 is {[string]: string} {
      print(t1["k"] ?? "z")
    } else {
      print("OTHER")
    }
  } else {
    print("NULL")
  }
}

function go() {
  // f64-arm element: the `is {[string]: string}` narrow is false.
  useIt(() => ([9.25]))
  // The direct binding / f64 union-member spelling of the same rep.
  const u3: {[string]: string} | f64 = 9.25
  if u3 is f64 { print(u3) } else { print("UOTHER") }
  // map-arm element: the narrow is true and the map read returns "hi".
  const h: {[string]: string} = Map()
  h["k"] = "hi"
  useIt(() => ([h]))
  // null-only spelling — no lambda adopts, so registration must intern the element union.
  useNull(null)
}

go()
