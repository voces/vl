// Regression: a CLOSURE whose body binds a multi-field plain-struct CALL to an UN-ANNOTATED
// local, then RETURNS it into the closure's variant-box union result `{…} | scalar`. The
// intermediate `const s = mk3()` inside the lambda body was mis-classified by `letIsVariant`
// as a kind-8 variant local (its init shape-matched the arm) while mk3 returns the plain
// struct twin — `local.set` of the plain ref into the variant cell was invalid wasm. Now the
// un-annotated binding is a plain STRUCT and the RETURN reboxes field-by-field (#1005/#1010).
// Mixed field types (i64 / boolean / f64) exercise the per-field re-read. The single-expr
// `(mk3())` closure-return twin is closures/multi-field-call-struct-arm-union.vl.
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// @hint Intentionally-unused parameter `_q2`
// @run
// @log 7
// @log 3.5
function mk3(): {a: i64, f: boolean, z: f64} {
  return { a: 7, f: true, z: 3.5 }
}
function go() {
  const v: (i32, i32, i32) => {a: i64, f: boolean, z: f64} | i32 = (_q0, _q1, _q2) => {
    const s = mk3()
    return s
  }
  const t0 = v(1, 1, 1)
  if t0 is {a: i64, f: boolean, z: f64} {
    print(t0.a)
    print(t0.z)
  } else {
    print("OTHER")
  }
}
go()
