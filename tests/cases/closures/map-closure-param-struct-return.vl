// @log 10
// @log 20
// @log 200
// @log 7
// @run
// `.map` with a CLOSURE-VALUE callback that RETURNS A STRUCT (`xs.map(f)` where `f: (i32) => P`) — the
// struct follow-up to the scalar closure-value callback support. The inline `.map` already builds a NEW
// ref list of the callback's return struct; it only resolved that result struct (and its ref-list slot)
// from a LIFTED callback function. A closure VALUE has no lifted fe, so the result struct index now comes
// from the closure's own `>s<idx>;` sig-return token (`sigKeyRetStructIdx`), and its `P[]` ref-list slot
// (`mfResKindFromSigRet` maps the struct return to a ref-list result). Covers a closure PARAM and a
// closure BINDING callback. (A GENERIC HOF whose result type-param is a struct — `mapArr<T,R>` with
// `R` a struct — is a separate, deeper mono interaction, not yet covered.)

type P = { x: i32 }

// A HOF forwarding a struct-returning callback to `.map`.
function mapToP(xs: i32[], f: (i32) => P): P[] { return xs.map(f) }

function go() {
  const ps = mapToP([1, 2], (n) => { x: n * 10 }) // [{10},{20}]
  print(ps[0].x) // 10
  print(ps[1].x) // 20

  // The callback held in a BINDING (not a param).
  const g: (i32) => P = (n) => { x: n * 100 }
  const qs = mapToP([1, 2], g) // [{100},{200}]
  print(qs[1].x) // 200

  // The result list participates in further reads.
  const rs = mapToP([3], (n) => { x: n + 4 })
  print(rs[0].x) // 7
}

go()
