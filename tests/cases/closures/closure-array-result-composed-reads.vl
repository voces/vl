// Closure-returns-ARRAY results read through COMPOSED positions of the value-call ABI:
//  · a value-union CLOSURE arm's chained read (`t0(1)[0].f` after `is (i32) => S[]`) —
//    `exprRefArray`/`refListElemNameOfExpr` resolve the ref-list slot via the general
//    `cloCallSigKey` fallback (the same key the call emit resolves);
//  · a struct-FIELD closure's chained read (`v.f(1)[0].f` — a Member callee);
//  · a NARROWED union struct variant's closure-field CALL (`t0.f(1)[0]` —
//    `memberIsClosure` reads the variant field code);
//  · a union whose closure arm buries an inline shape (`((i32) => {…}[]) | f64`) interns
//    it from the annotation (`internShapeDeep`'s value-union closure-atom descent +
//    `forceCloResultListTypes`'s ref-array arm), so the DEAD arm still validates when
//    only the scalar carrier is constructed.
// A UNION-element array result (`(i32 | {w: i32})[]`) stays a loud reject (the
// array-of-union-element family) — the fallbacks decline it by checked element type.
// @run
// @log djp
// @log td
// @log false
// @log OTHER
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
type K0 = "46480" | "djp" | "td"
function makeIt(): ((i32) => {a: f64, f: K0, z: string}[]) | f64 {
  return (_q0) => ([{a: 2.5, f: "djp", z: "dx"}])
}
function makeField(): {f: (i32) => {a: f32, f: K0, z: i64}[]} {
  return {f: (_q0) => ([{a: 3.5, f: "td", z: 6000000000}])}
}
function deadArm(): ((i32) => {a: f64, f: K0, z: string}[]) | f64 {
  return 1.5
}
function go() {
  const v = makeIt()
  const t0 = v
  if t0 is (i32) => {a: f64, f: K0, z: string}[] {
    print(t0(1)[0].f)
  } else {
    print("OTHER")
  }
  const s = makeField()
  print(s.f(1)[0].f)
  const u: {f: (i32) => boolean[]} | f64 = {f: (_q0) => ([false])}
  const t1 = u
  if t1 is {f: (i32) => boolean[]} {
    print(t1.f(1)[0])
  } else {
    print("OTHER")
  }
  const d = deadArm()
  const t2 = d
  if t2 is (i32) => {a: f64, f: K0, z: string}[] {
    print(t2(1)[0].f)
  } else {
    print("OTHER")
  }
}
go()
