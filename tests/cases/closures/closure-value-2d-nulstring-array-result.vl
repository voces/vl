// Regression: a closure VALUE returning a 2-D nullable-string array (`() => (string|null)[][]`,
// `(i32) => (string|null)[][]`). The outer array's ELEMENT is the inner STRING-list wrapper —
// `(string|null)[]` shares the EXACT `$mkListIdx` string-list wrapper `string[]` uses (a string
// element is already a `(ref null $aTypeIdx)` ref; the `| null` niche rides INSIDE the elements).
// The ANNOTATION rendered that element by its source spelling (`(string|null)[]`) while the
// self-inferred lambda softened it to `string[]`, so the two sides interned TWIN ref-list slots
// for one wrapper heap type. The value call's `$fnsig` result token `>r0;` (annotation slot)
// diverged from the lambda's inferred slot, and the `call_ref` `ref.cast` to the annotation's
// wrapper TRAPPED on the lambda's — a cast failure. The named-function spelling always worked.
// Fix: `rlCanonElemName` folds a string-backed leaf list (`nameIsStringArray`: `string[]` /
// `(string|null)[]`) to `string[]` at the single ref-list intern/lookup point, so both sides key
// ONE slot — the string-leaf sibling of #1033's i32-leaf fold. A top-level-nullable list
// (`string[] | null`) carries its `| null` OUTSIDE and keeps its distinct niche slot; the inner
// element READ discipline stays driven by the checked expression type, not this slot. (An
// ALL-`null` inner literal — `() => [[null]]` — still keys a distinct producer element slot and
// stays the pre-existing `cloCallReflistElemTwin` deferred loud reject, exactly as #1033's
// i32-leaf pin scoped to mixed-content inners.)
// @run
// @log 2
// @log 2
// @log NULL
// @log a
// @log b
// @log 2
// @log s
// @log NULL
// @log t
// @hint Intentionally-unused parameter `_q0`
function show(t: string | null) {
  if t != null { print(t) } else { print("NULL") }
}
function useNulStr(p: (i32) => (string | null)[][]) {
  const t1 = p(1)
  print(t1.length) // 2
  const t2 = t1[0]
  print(t2.length) // 2
  show(t2[0])      // NULL (the niche-null element)
  show(t2[1])      // a
  show(t1[1][0])   // b (chained read of the second row)
}
function usePlainStr(s: () => string[][]) {
  const r = s()
  print(r.length) // 2
  show(r[0][0])   // s
}
function go() {
  useNulStr((_q0) => ([[null, "a"], ["b"]]))
  usePlainStr(() => ([["s"], ["u"]]))
  // Direct binding spelling of the closure value (mixed-content inner).
  const q: () => (string | null)[][] = () => [[null, "x"], ["t"]]
  const w = q()
  show(w[0][0]) // NULL
  show(w[1][0]) // t
}
go()
