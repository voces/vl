// @run
// @log 42
// @log 42
// A closure-ELEMENT array whose element returns a NULLABLE-LITUNION (`(() => K0 | null)[]`, K0 a
// literal union). The checker now ADOPTS a `K | null` litunion at a bare lambda's return boundary
// (`() => ("42")` widens `string` → `K0 | null`), records the alias (`nulLitUnionRetName`), and
// `synthRetAnnots` pins `fnRet` so the lambda's `$fnsig` result keys the i32 atom (`>i`, with `-1` =
// null) — the SAME rep the annotated `: () => K | null` return lowers. The INDEXED value call
// `p[0]()` binds the `K | null` niche (`exprNulLitUnion`'s indexed-closure-array arm reads the
// element's result name off the ref-list slot). Covers the anonymous-lambda element (the fuzzer
// repro) and a NAMED-function element (the latent hole ZERO-C found: `[mk]` passed `vl check` but
// the emitter miscompiled the litunion-atom result — the same rep now closes it).
type K0 = "lf" | "42"

function useIt(p: (() => K0 | null)[]) {
  const t0 = p[0]()
  if t0 != null { print(t0) } else { print("NULL") }
}

function mk(): K0 | null { return "42" }

function go() {
  // Anonymous-lambda element: the bare `() => ("42")` adopts `K0 | null` at its return boundary.
  useIt([() => ("42")])
  // Named-function element: the latent-hole case — a `[mk]` array of the same closure type.
  useIt([mk])
}

go()
