// @run
// @log 11
// @log 20
// @log 110
// LAMBDA elements in a closure array (`[(n) => n + 1, (n) => n * 2]`): the inline function
// literals are lifted and stored as closure values, indistinguishable from named-function
// elements at the call site.

function go() {
  const fs: ((i32) => i32)[] = [(n) => n + 1, (n) => n * 2]
  print(fs[0](10)) // 11
  print(fs[1](10)) // 20

  // A lambda that closes over a captured local still works as an element.
  const k = 100
  const gs: ((i32) => i32)[] = [(n) => n + k]
  print(gs[0](10)) // 110
}
go()
