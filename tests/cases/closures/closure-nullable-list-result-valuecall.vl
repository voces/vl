// A closure RESULT that is a NULLABLE i32-backed list (`boolean[] | null`,
// `i32[] | null` — the `nullist` niche, `(ref null $lTypeIdx)`), read back through the
// value-call ABI: the `>o` result token. The named-function VALUE, the contextual
// lambda (adopted at its boundary — `tyIsNulI32BackedListInner` + the
// `nullableRetName` i32-backed-list arm), the closure PARAM position, and the bare
// `null` carrier all round-trip; the un-annotated `const t0 = v()` binding classifies
// `nullist` off the resolved sig (`exprNullableList`'s closure-value arm). The
// distinct-backing nullable lists (`i64[] | null`, …) and the litunion `K0[] | null`
// lambda stay loud rejects (outside the value-call ABI).
// @run
// @log true
// @log NULL
// @log true
// @log 42
function mk(): boolean[] | null {
  return [true]
}
function useIt(p: () => boolean[] | null) {
  const t0 = p()
  if t0 != null {
    print(t0[0])
  } else {
    print("NULL")
  }
}
function go() {
  useIt(() => ([true]))
  useIt(() => (null))
  const v: () => boolean[] | null = mk
  const t0 = v()
  if t0 != null {
    print(t0[0])
  }
  const w: () => i32[] | null = () => ([41])
  const t1 = w()
  if t1 != null {
    print(t1[0] + 1)
  }
}
go()
