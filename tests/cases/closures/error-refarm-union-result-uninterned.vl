// @emit-error value-union closure RESULT is not yet representable
// A closure result that is a REF-ARM value union (`{…}[] | i32`): the annotation side
// renders the `>u` box result while the lambda self-infers its bare scalar arm and
// never interns that key — the call then fell back to the all-i32 arity sig and stored
// the raw i32 into the box-typed local (INVALID-WASM at any arity; fuzz frontier seed
// 615401451 d6 --branching p0r). The soundness floor now requires an un-interned `>u`
// key to reject loudly: `cloCallUnionResultUnrepresentable` checks `cloSigPosOfKey`,
// not just the key text. Representable box-result closures (a producer interned the
// key) are unaffected. Deferred to the repOf descriptor rewrite (ROADMAP "Next").
function go() {
  const v: (i32) => {a: f32, f: i64, z: boolean}[] | i32 = (q0) => (77)
  const t0 = v(1)
  if t0 is {a: f32, f: i64, z: boolean}[] {
    print(t0[0].f)
  } else {
    print("OTHER")
  }
}
go()
