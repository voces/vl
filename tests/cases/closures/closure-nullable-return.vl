// @run
// @log 5
// @log 99
// @log hi
// @log none
// @log 5
// @log -1
// @log 7
// A NULLABLE-ref-returning closure VALUE (`(i32) => P | null`, `(i32) => string | null`) now lowers and
// its call narrows. Previously even the BOUND-direct form failed ("function-value call arity has no
// interned signature"): the anonymous lambda's inferred return COLLAPSED to the bare non-null kind
// (`>s<idx>;` / `>S`), so its `$fnsig` result token disagreed with the call's nullable key (`>n<idx>;` /
// `>N`) and the cast target was un-interned.
//
// Fix (the nullable dual of the union pin, #652): the checker records the lambda's CONTEXTUAL nullable
// return under its node sentinel (`nullableRetName` reverse-maps a struct inner to its nominal name like
// `structUnionRetName`), and `synthRetAnnots` pins it — so the lambda's result keys the nullable token
// uniformly, position-independently. Covers a nullable STRUCT and nullable STRING, BOUND and through a
// HOF (param + return). (A nullable closure stored in an ARRAY / returned from a FACTORY still drops the
// `| null` at the call-site element/binding type recording — a separate follow-up.)

type P = { x: i32 }

// A HOF taking a nullable-returning closure: narrows the result inside.
function useP(g: (i32) => P | null, n: i32): i32 {
  const r = g(n)
  if r != null { return r.x }
  return -1
}

// A HOF that RETURNS the nullable closure result unchanged; the caller narrows.
function passP(g: (i32) => P | null, n: i32): P | null { return g(n) }

function go() {
  // BOUND nullable-struct closure — both arms, narrowed two ways.
  const g: (i32) => P | null = (n) => if n > 0 { { x: n } } else { null }
  const r = g(5)
  if r != null {
    print(r.x) // 5
  }
  const r2 = g(-1)
  if r2 == null {
    print(99) // 99
  }

  // BOUND nullable-string closure — `?? default` over each arm.
  const h: (i32) => string | null = (n) => if n > 0 { "hi" } else { null }
  print(h(1) ?? "none")  // hi
  print(h(-1) ?? "none") // none

  // Through a HOF — param narrow, and the passthrough return.
  print(useP(g, 5))  // 5
  print(useP(g, -1)) // -1
  const pr = passP(g, 7)
  if pr != null {
    print(pr.x) // 7
  }
}

go()
