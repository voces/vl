// @emit-error value-union closure RESULT is not yet representable
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// @hint Intentionally-unused parameter `_q2`
// A NULLABLE closure whose result is a heterogeneous value union carrying a NESTED (2-D)
// LITUNION-array arm beside a scalar (`K0[][] | boolean`). The litunion 2-D array folds to a
// distinct wrapper slot the value-union box does not yet compose through, so the DIRECT
// binding already rejects as "not yet representable". A PARAM/arg-fed spelling interns the
// box on the nullable-closure annotation side (slipping the `cloSigPosOfKey < 0` arm), and
// the concrete producer lambda (`(q0,q1,q2) => (false)`) self-infers its bare `boolean`
// functype — so the value call's closure `ref.cast` to the `>u`-result functype TRAPPED at
// runtime. `cloCallUnionResultUnrepresentable`'s `pk == ""` path now flags the litunion
// 2-D-array arm (the map-array / closure-array sibling), keeping it a clean loud REJECT.
// A 1-D litunion array (`K0[]`) and a SCALAR-leaf nested array (`i32[][]`, `string[][]`)
// rep fine and are unaffected. Fuzz sweep P8mid2 branching, seed 75568152.
type K0 = "80848" | "hl" | "t"
function useIt(p: ((i32, i32, i32) => K0[][] | boolean) | null) {
  const t0 = p
  if t0 != null {
    const t1 = t0(1, 1, 1)
    if (t1 is K0[][]) { print(t1[0][0]) } else { print("OTHER") }
  } else {
    print("NULL")
  }
}
function go() { useIt((_q0, _q1, _q2) => (false)) }
go()
