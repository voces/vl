// @run
// @log NULL
// @log 7
// @log 12121
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q2`
// @hint Intentionally-unused parameter `_q2`
// @hint Intentionally-unused parameter `_q2`
// The value-call RESULT ABI for a `??`-DEFAULTED map-value closure returning a NULLABLE SCALAR
// (`{[string]: (i32) => i32 | null}`). Three pieces:
//   1. CHECKER — a `??` seeds its DEFAULT operand with the LHS type, so the un-annotated default
//      lambda `(q2) => …`'s param infers from the map value's `(i32) => i32 | null` (fixes the
//      `cannot infer a type for parameter q2` reject).
//   2. RESULT TOKEN — `annRetKind(i32 | null)` keys the value-union {tag,value} BOX (`>u`), matching
//      `cloRetKeySuffix`'s construct-side token (`vtKindOfType` → "union"), so the value call
//      resolves the interned `i>u` sig instead of "no interned signature".
//   3. SIG + RECOVERY — the `??`-coalesced binding `t0` has NO single lifted fe (a runtime pick),
//      so `identFnTypeAnnName` recovers its function type from the checker's join type of the `??`
//      expression; `nodeUnionName` classifies the call result's `TyNullable(i32)` as the value-union
//      box, so `const t1 = t0(1)` binds the box and narrows / unboxes exactly as the annotated form.
// Covers the null arm (the stored closure returns `null` → NULL), a non-null value (`7`), and the
// map-MISS default (`12121`, the seeded default lambda), all recovered soundly (byte-exact fixpoint).
function makeNull(): {[string]: (i32) => i32 | null} {
  const h1: {[string]: (i32) => i32 | null} = Map()
  h1["k"] = (_q0) => (null)
  return h1
}

function makeVal(): {[string]: (i32) => i32 | null} {
  const h2: {[string]: (i32) => i32 | null} = Map()
  h2["k"] = (_q0) => (7)
  return h2
}

function go() {
  // Null arm: the stored closure returns `null` → the else branch prints NULL.
  const a: {[string]: (i32) => i32 | null} = makeNull()
  const t0 = a["k"] ?? (_q2) => (12121)
  const r0 = t0(1)
  if r0 != null { print(r0) } else { print("NULL") }

  // Non-null value: the stored closure returns 7.
  const b: {[string]: (i32) => i32 | null} = makeVal()
  const t1 = b["k"] ?? (_q2) => (12121)
  const r1 = t1(1)
  if r1 != null { print(r1) } else { print("NULL") }

  // Map MISS → the seeded default lambda is used (returns 12121).
  const t2 = b["missing"] ?? (_q2) => (12121)
  const r2 = t2(1)
  if r2 != null { print(r2) } else { print("NULL") }
}

go()
