// Regression: a closure VALUE returning a list whose element is a union mixing a
// VARIANT-BOX-union-element ARRAY arm with a scalar arm — `() => ((string|i64|{q:i64})[] | f64)[]`.
// Like the value-union sibling (`closure-value-refarm-value-union-elem-list-result.vl`), the
// element union boxes each arm as `{tag, payload}`, but the array arm's element union
// `string|i64|{q:i64}` carries a STRUCT member — a VARIANT-BOX union (`variantBoxUnionRetName`),
// not a pure value union (`isValueUnionName` declines it because of the `{q:i64}` arm). The
// named-function-VALUE spelling (`= mk`) and the direct binding always lowered this box soundly,
// but an anonymous lambda `() => ([9.25])` self-classified its body as a plain `f64[]` reflist
// keyed on a DIFFERENT `$fnsig` slot than the annotation-side value call's box-list slot — the
// `call_ref` `ref.cast` to the box sig TRAPPED (cast failure). Fix: `elemRefArmValueUnionListRetName`
// admits a VARIANT-BOX-union element array (its array-arm element passing `variantBoxUnionRetName`,
// not only `isValueUnionName`), and the lambda-return cascade adopts + records it so
// `synthRetAnnots` pins `fnRet` via `parenUnionArrElemName`. The variant-box sibling of
// `elemValueUnionListRetName`'s union-element-array arm (fuzz sweep cV4tlq branching, seed 396585459).
// @run
// @log OTHER
// @log OTHER
// @log ARR
// @log hi
// @log 7
// @log 99
function useScalarArm() {
  // The draw spelling: a `[9.25]` body whose element takes the scalar f64 arm.
  const v: () => ((string | i64 | {q: i64})[] | f64)[] = () => ([9.25])
  const t0 = v()[0]
  if t0 is (string | i64 | {q: i64})[] { print("ARR") } else { print("OTHER") }
  const u1: (string | i64 | {q: i64})[] | f64 = 9.25
  if u1 is (string | i64 | {q: i64})[] { print("UARR") } else { print("OTHER") }
}
function useArrayArm() {
  // A body exercising the variant-box-element ARRAY arm: `[["hi", 7, {q: 99}]]`'s first outer
  // element is the `(string|i64|{q:i64})[]` arm — narrow to it and round-trip each inner member.
  const v: () => ((string | i64 | {q: i64})[] | f64)[] = () => ([["hi", 7, { q: 99 }]])
  const t0 = v()[0]
  if t0 is (string | i64 | {q: i64})[] {
    print("ARR")
    const e0 = t0[0]
    if e0 is string { print(e0) } else { print("NOTSTR") }
    const e1 = t0[1]
    if e1 is i64 { print(e1) } else { print("NOTI64") }
    const e2 = t0[2]
    if e2 is {q: i64} { print(e2.q) } else { print("NOTOBJ") }
  } else {
    print("OTHER")
  }
}
function go() {
  useScalarArm()
  useArrayArm()
}
go()
