// Regression: a closure VALUE whose result is a NULLABLE niche-element array made
// nullable — `(i32, i32, i32) => (boolean | null)[] | null` (`() => (boolean|null)[] | null`
// too). The inner `(boolean | null)[]` is an i32-BACKED niche list (the element's null rides
// IN the i32, sentinel 2), so the outer `| null` is the ordinary nullable-list `(ref null
// $lTypeIdx)` niche — the SAME rep `boolean[] | null` (non-niche element) already lowered.
// The lambda body (`[true]`) self-inferred the NON-null list result, so its emitted functype
// keyed `(result (ref $list))` while the value call's `ref.cast` keyed the annotation's
// nullable `(result (ref null $list))` — two DISTINCT iso-recursive functypes → a `call_ref`
// cast-failure TRAP. `boolean[] | null` (a plain `TyPrim` boolean element) was pinned to the
// nullable result; `(boolean | null)[] | null` was NOT — the pin's `tyIsNulI32BackedListInner`
// gate admitted only a `TyPrim` i32/boolean element, missing the `TyNullable(boolean)` niche
// element that `nodeTyIsNulI32List` (the definition-site classifier) already covered. Fix:
// `tyIsNulI32BackedListInner` admits a `TyNullable(boolean)` element, so `nullableRetName`
// renders `(boolean|null)[]|null` and `synthRetAnnots` pins the lambda's `fnRet` to the
// nullable list — both `$fnsig` producers now key `(ref null $list)`. The distinct-backing
// nullable lists (`i64[]|null`, string elements, …) stay outside the value-call ABI.
// @run
// @log true
// @log NULL
// @log false
// @log bound
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// @hint Intentionally-unused parameter `_q2`
function useThree(v: (i32, i32, i32) => (boolean | null)[] | null) {
  const t0 = v(1, 1, 1)
  if t0 != null {
    const a = t0[0]
    if a != null { print(a) } else { print("NULL") }
    const b = t0[1]
    if b != null { print(b) } else { print("NULL") }
    const c = t0[2]
    if c != null { print(c) } else { print("NULL") }
  } else {
    print("NULL")
  }
}
function useZero(v: () => (boolean | null)[] | null) {
  const t0 = v()
  if t0 != null { print("bound") }
}
useThree((_q0, _q1, _q2) => ([true, null, false]))
useZero(() => ([true]))
