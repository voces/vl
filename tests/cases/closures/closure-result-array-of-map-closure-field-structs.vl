// @run
// @log 270
// @log 14.5
// @log zjh
// @log 1
// A CLOSURE VALUE returning a LIST of structs whose element MIXES a map field and a
// closure field (`() => {a: string, f: {[string]: f64}, z: () => f64}[]`). The annotated
// named-fn spelling lowers such a struct element, but an UN-pinned closure returning the
// list self-classified each element and mis-coded the SIBLING map field to the i32 default
// (a struct ref stored into an i32 field slot — INVALID-WASM). `structElemFieldsPlain` now
// admits a CLOSURE field (the map field was #1044, the closure the missing sibling), so
// `structElemListRetName` pins the closure value and the element interns with the map field
// resolved. Neither field alone breaks — the map field takes the default only when a closure
// field also blocks the plain-struct pin. Fuzz sweep D8n9AN declared, seed 472261954 p0c/p0r.
function go() {
  const h0: {[string]: f64} = Map()
  h0["k"] = 270.0
  h0["k1"] = 14.5
  const v: () => {a: string, f: {[string]: f64}, z: () => f64}[] = () => ([{ a: "zjh", f: h0, z: () => (1.0) }])
  print(v()[0].f["k"] ?? 0.0)
  print(v()[0].f["k1"] ?? 0.0)
  print(v()[0].a)
  print(v()[0].z())
}
go()
