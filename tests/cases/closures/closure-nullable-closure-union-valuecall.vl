// @run
// @log NULL
// @log 82
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// The value-call RESULT ABI for a closure whose result is a NULLABLE-CLOSURE union (`(i32) =>
// ((i32) => K0) | null`, kind 19). The result rides a new `$fnsig` RESULT token `C` (the shared
// closure fat-pointer made nullable, `(ref null $cloStruct)`, slot-free) with its encode/decode
// twin (`repSigTokOfKind`/`repKindOfSigTok`), excluded as a PARAM (`cloParamTok`). The checker
// adopts the nullable-closure at the lambda's return boundary and records its name
// (`nullableRetName`'s `TyFunc`-inner arm, litunion result preserved); `synthRetAnnots` pins
// `fnRet`, so `return null` niches as `ref.null $cloStruct`. The INNER closure (`(i32) => K0`) is
// never constructed in the null arm, so `collectCloSigs` interns its `$fnsig` from the pinned type
// (a litunion result keys `>i`, matching a constructed inner) — else the narrowed `t0(1)` call
// mis-cast. Covers the null arm (prints NULL) and a constructed inner (prints its litunion member).
type K0 = "82" | "rttn" | "tx"

function go() {
  // Null arm: the outer closure returns `null`, narrowed away → the else branch.
  const v: (i32) => ((i32) => K0) | null = (_q0) => (null)
  const t0 = v(1)
  if ((t0 != null)) { print(t0(1)) } else { print("NULL") }

  // Constructed-inner arm: the outer returns a real inner closure; the narrowed `t1(1)` calls it.
  const w: (i32) => ((i32) => K0) | null = (_q0) => ((_q1) => ("82"))
  const t1 = w(1)
  if ((t1 != null)) { print(t1(1)) } else { print("NULL") }
}

go()
