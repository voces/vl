// @run
// @log b
// @log c
// @log a
// @log b
// @log c
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_x`
type K = "a" | "b" | "c"

// A litunion RESULT via a lambda: the body is a bare string literal that is a MEMBER of the
// expected aliased litunion (`(i32) => K = (x) => "b"`). The lambda's body infers the softened
// `string`; the checker ADOPTS the litunion (the return-adoption's litunion arm), so the lambda's
// functype result is the litunion — an i32 ATOM (per the alias-i32 rep, #843). `synthRetAnnots`
// pins the adopted alias so the `$fnsig` result keys `>i` (matching the value call) and
// `emitReturnValue` encodes the member as its atom id. At the value CALL, `print(v(0))` widens the
// atom back to its member string — the value-call dual of the named-call widening #843 added.
const v: (i32) => K = (_q0) => ("b")
print(v(0))

// A NAMED-function VALUE call (`= mk`) already emitted the atom, but `print(v(0))` printed the raw
// atom id (0/1/2) — the value-call result was outside `exprIsLitAtom`'s widening. Now widened.
function mk(_x: i32): K { return "c" }
const w: (i32) => K = mk
print(w(0))

// A litunion-result closure nested in a STRUCT FIELD, value-called through the field
// (`s.f(0)`) — the Member-callee call the callee-Ident arm cannot reach, resolved by the call's
// checked result type.
const s: { f: (i32) => K } = { f: (_q0) => ("a") }
print(s.f(0))

// Deeper: a closure field inside a nested struct (`{a, f: {f: (i32) => K}, z}`), value-called
// via `o.f.f(0)` — the shape the fuzzer's `{a: i64, f: {f: (i32) => K0}, z: boolean}` exercises.
const o: { a: i64, f: { f: (i32) => K }, z: boolean } = {
  a: 6000000000,
  f: { f: (_q0) => ("b") },
  z: true,
}
print(o.f.f(0))

// A litunion result in an ARRAY element (`((i32) => K)[]`), value-called via `xs[0](0)`.
const xs: ((i32) => K)[] = [(_q0) => ("c")]
print(xs[0](0))
