// @run
// @log OTHER
// @log OTHER
// @log 2.5
// @hint Intentionally-unused parameter `_p`
// A value union whose CLOSURE arm returns a nullable NUMERIC scalar
// (`(() => f64 | null) | string`). `internFuncTypeShapes` now splits a TOP-LEVEL
// arrow BEFORE the `| null` peel — `()=>f64|null` binds the null to its RESULT
// (`nulCloFlag`'s rule), so the `f64 | null` result surfaces and registers its value
// box; and a value-union RESULT leaf registers exactly as `internShapeDeep`'s arm
// does. Producer-less (only the string arm constructed), the narrowed call's unbox
// previously cast the box payload to a bogus default type index — INVALID-WASM at
// the `print` read (fuzz-nightly run 29808029476, seed 100113225 d4, p1r).
function useIt(p: (() => f64 | null) | string) {
  const t0 = p
  if (t0 is () => f64 | null) {
    const t1 = t0()
    if (t1 != null) { print(t1) } else { print("NULL") }
  } else {
    print("OTHER")
  }
}

// The producer-less spelling (only the string arm ever flows).
function noProducer(_p: (() => f64 | null) | string) { print("OTHER") }

function go() {
  noProducer("other")
  useIt("other")
  // The PRODUCER spelling still narrows and reads the f64 through the box.
  useIt(() => (2.5))
}
go()
