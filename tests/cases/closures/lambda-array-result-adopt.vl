// A closure RESULT that is a plain ARRAY value, read back through the value-call ABI.
// Three seams pinned together:
//  ¬∑ contextual lambda ADOPTION of a distinct-backing scalar-leaf list result (`f32[]`
//    from float literals, `i64[]` from small ints ‚Äî `scalarLeafListRetName`) and of a
//    struct-element list result whose fields coerce field-wise (`{f: f32}[]`,
//    `{a: f32, f: K0, z: i64}[]` ‚Äî `structElemListRetName`); `synthRetAnnots` pins the
//    scalar-leaf `fnRet` so the body literal builds the leaf's wrapper.
//  ¬∑ a list reached ONLY as a closure result inside a composite annotation forces its
//    wrapper/backing types (`forceCloResultListTypes` ‚Äî the value-call index read needs
//    them even when the program never constructs such a list).
//  ¬∑ a CURRIED value call's f32[] result classifies by its checked type
//    (`callResTyIsF32Array`), so `m["a"]`-style curried reads index correctly.
// The named-function spelling lowered all of these already; the lambda spellings adopt.
// @run
// @log 1.5
// @log 1.5
// @log 5
// @log 3.5
// @log pt
// @log 11
// @log 2.5
// @log 0
// @log pt
// @hint Intentionally-unused parameter `_p`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q3`
// @hint Intentionally-unused parameter `_q0`
type K0 = "80" | "pt" | "j"
function useIt(_p: {f: (i32) => {a: f32, f: K0, z: i64}[]}) {}
function makeIt(): (i32) => f32[] {
  return (_q0) => ([1.5])
}
function go() {
  const v: (i32) => f32[] = makeIt()
  print(v(1)[0])
  const w: (i32) => {f: f32}[] = (_q0) => ([{f: 1.5}])
  print(w(1)[0].f)
  const x: (i32) => i64[] = (_q0) => ([5])
  print(x(1)[0])
  const y: (i32) => {a: f32, f: K0, z: i64}[] = (_q0) => ([{a: 3.5, f: "pt", z: 11}])
  print(y(1)[0].a)
  print(y(1)[0].f)
  print(y(1)[0].z)
  // A map VALUE carrying a curried closure whose inner result is f32[] ‚Äî the curried
  // value-call read (`t0()(1)[0]`) classifies its element kind from the checked type.
  const m: {[string]: () => ((i32) => f32[])} = Map()
  m["a"] = () => ((_q0) => ([2.5]))
  const t0 = m["a"] ?? () => ((_q3) => ([9.5]))
  print(t0()(1)[0])
  // A struct FIELD carrying the adopted closure (construct-only; the chained
  // `s.f(1)[0].f` read is a separate composition seam).
  const s: {f: (i32) => {a: f32, f: K0, z: i64}[]} = {
    f: (_q0) => ([{a: 3.5, f: "pt", z: 11}]),
  }
  useIt(s)
  print(0)
  // A LITUNION-ALIAS-element list result (`(i32) => K0[]`): the member-literal body
  // adopts the alias array; `synthRetAnnots` pins it so the body builds the i32 ATOM list.
  const k: (i32) => K0[] = (_q0) => (["pt"])
  print(k(1)[0])
}
go()
