// @run
// @log 3
// @log 3
// @log 2
// @log 4
// @log 3
// @log 1
// @log 5
// A UNION-returning `.map`: the callback yields a value union, so the result is a ref list of
// union BOXES (the source element type, or a transformed one). Three callback shapes:
//   - a passthrough lambda (`(a) => a`),
//   - a NAMED multi-variant callback (returns either variant via explicit `return`s),
//   - an INLINE lambda whose body is a value-`if` constructing a variant in one arm.
// The inline lambda's union return is inferred (`criWalkBlock` classifies an if-arm's
// implicit-return tail value — lambda-gated so named-function inference stays byte-identical),
// the `$fnsig` result is the union box, and the value-`if` join lowers via `emitUnionIfValue`
// (a value-typed `if` with the `(ref $uBox)` blocktype, each arm union-coerced).

type Cat = { meow: i32 }
type Dog = { woof: i32 }
type Animal = Cat | Dog

// A named callback that genuinely returns EITHER variant (explicit `return`s).
function swap(a: Animal): Animal {
  if a is Cat { return { woof: a.meow * 2 } }
  if a is Dog { return { meow: a.woof * 2 } }
  return a
}

// A named if-as-VALUE union return (`return if … else …`) — its own pre-existing gap.
function tag(a: Animal): Animal {
  return if a is Cat { { woof: a.meow } } else { a }
}

function go() {
  const xs: Animal[] = [{ meow: 1 }, { woof: 2 }, { meow: 3 }]

  // passthrough lambda
  const same = xs.map((a) => a)
  print(same.length) // 3

  // named multi-variant callback
  const sw = xs.map(swap)
  print(sw.length) // 3
  const s0 = sw[0]
  if s0 is Dog { print(s0.woof) } else { print(-1) } // 2  (cat 1 -> dog 2)
  const s1 = sw[1]
  if s1 is Cat { print(s1.meow) } else { print(-1) } // 4  (dog 2 -> cat 4)

  // inline lambda, value-if constructing a variant in one arm
  const flipped = xs.map((a) => if a is Cat { { woof: a.meow } } else { a })
  print(flipped.length) // 3
  const f0 = flipped[0]
  if f0 is Dog { print(f0.woof) } else { print(-1) } // 1

  // named if-as-value union return, used directly
  const t = tag({ meow: 5 })
  if t is Dog { print(t.woof) } else { print(-1) } // 5
}
go()
