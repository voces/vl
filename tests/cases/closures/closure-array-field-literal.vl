// @run
// @log 0
// @log 265
// @log 7
// @log 42
// A field-position lambda returning a struct whose FIELD is a closure-ARRAY
// literal (`{f: (i32) => {f: (() => i32)[]}}` fed `{f: [() => (265), …]}`) — the
// full-support graduation of the old loud reject. `funcTypeShapeLowerable` now
// admits a code-5 closure-element array field (`nameIsClosureArray` — a plain
// ref-list slot over the shared `$cloStruct` fat-pointer, the rep the plain
// binding annotation form already lowers), so the closure-RESULT shape interns,
// the literal resolves to it (the same-name-set outer `{f}` closure-field shape
// disambiguates via the checker's node type), and the elements call through.
function makeIt(): {f: (i32) => {f: (() => i32)[]}} {
  return { f: (_q0) => ({ f: [() => (265), () => (7)] }) }
}
function go() {
  const v: {f: (i32) => {f: (() => i32)[]}} = makeIt()
  print(0)
  const s = v.f(1)
  print(s.f[0]())
  print(s.f[1]())
  const g: () => {f: (() => i32)[]} = () => ({ f: [() => (42)] })
  print(g().f[0]())
}
go()
// @hint Intentionally-unused parameter `_q0`
