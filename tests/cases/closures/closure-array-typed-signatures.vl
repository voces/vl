// @run
// @log 11
// @log 20
// @log 10.5
// @log abc
// @log 5000000000
// Closure arrays over NON-i32 signatures. The all-i32 arity fallback an indexed call used to
// ride doesn't exist for these, so the call resolves its signature from the array's ELEMENT
// TYPE; the RESULT routes by that element's return atom (f64 / string / i64 / list), not the
// default i32.

// f64 parameter AND f64 result.
function inc(x: f64) { return x + 1.0 }
function dbl(x: f64) { return x * 2.0 }
function half(x: f64) { return x / 2.0 }

// `(i32) => string` — a string RESULT routes to the string printer / concat.
function tag(n: i32) {
  if n < 0 { return "z" }
  return "a"
}

// `(i32) => i64` — a wide-integer result (both branches are i64 literals).
function big(n: i32) {
  if n < 0 { return 6000000000 }
  return 5000000000
}

function go() {
  const fs: ((f64) => f64)[] = [inc, dbl, half]
  print(fs[0](10.0)) // 11    (f64 11.0)
  print(fs[1](10.0)) // 20    (f64 20.0)
  print(fs[2](21.0)) // 10.5  (genuinely f64)

  const ss: ((i32) => string)[] = [tag]
  print(ss[0](0) + "bc") // abc  (string result, concatenated)

  const bs: ((i32) => i64)[] = [big]
  print(bs[0](1)) // 5000000000  (i64 result)
}
go()
