// @run
// @log 3
// @log 5
// @log 12
// @log 42
// @log 7
// A lambda whose inferred return is an inline STRUCT and whose object-literal fields
// are BARE PARAM reads (`(x) => ({f: x})`). The lambda has no return annotation, so
// its return shape is inferred from the literal; a bare param field value codes -1 in
// `anonFieldCode`, so the literal must NAME-SET match a PRE-interned shape. But the
// inline shape lives inside a FUNCTION-TYPE annotation (`(i32) => {f: i32}`) — one
// TypeRef name — so `internShapeDeep` never reached it and the closure functype result
// had no interned shape ("ref valtype with no interned shape"). `internShapeDeep` now
// recurses into a functype's params and result, interning each plainly-lowerable inline
// shape. A struct-with-map / value-union field stays un-interned (a clean reject, not
// invalid wasm — those reps are R1/R3). Each case uses a DISTINCT field-name set:
// literals resolve shapes by field-name set (the documented same-name-set limitation).
const single: (i32) => {f: i32} = (x) => ({f: x})
const block: (i32) => {h: i32} = (x) => {
  return {h: x + 2}
}
const multi: (i32, i32) => {a: i32, b: i32} = (a, b) => ({a: a, b: b})
const nested: (i32) => {p: {q: i32}} = (x) => ({p: {q: x}})

function go() {
  print(single(3).f) // 3
  print(block(3).h) // 5
  const m = multi(5, 7)
  print(m.a + m.b) // 12
  print(nested(42).p.q) // 42
  // A captured variable as a field value (also unclassifiable) resolves the same shape.
  const k = 7
  const cap: () => {c: i32} = () => ({c: k})
  print(cap().c) // 7
}
go()
