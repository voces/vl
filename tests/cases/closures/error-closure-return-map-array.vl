// @emit-error map array elements are not supported
// A closure whose (inferred) return is an ARRAY-OF-MAP `{[string]: f32}[]` — the map-array closure
// value-call result rep. The inferred-return classifier collapses `[h0]` (a map-element array) to the
// i32 list, so the closure body builds `array.new_fixed $i32arr` and stores the map STRUCT ref as an
// i32 element ("expected i32, found (ref $type)", invalid wasm). The captured map is invisible to the
// locals-based `exprMap`, so the guard also consults the checker's recorded node type (`nodeTyIsMap`).
// A map array can only build through the ref-list path with a threaded map-element kind; with none in
// this closure-result position there is no sound rep — must be a CLEAN reject. (rep-fuzz p0c
// `(i32) => {[string]: f32}[]`; the read variant already rejects.)
function go() {
  const h0: {[string]: f32} = Map()
  h0["k"] = 3.5
  const v: (i32) => {[string]: f32}[] = (q1) => ([h0])
  print(0)
}
go()
