// @run
// @log OTHER
// @log 99
// @log OTHER
// @log 9.25
// The TOP-LEVEL closure-array-as-union-arm spelling (`((i32, i32, i32) => boolean)[] | i32`),
// NO-LAMBDA: the program constructs NO closure of the arm's type (the value is only ever the
// scalar arm), so nothing else flips the closure machinery on. The union's closure-ARRAY arm
// must still flip `fnValUsed` (collectFnValUse's union-arm closure-array extension) AND intern
// the `(i32, i32, i32) => boolean` element sig (collectCloSigs' unMemberSet closure-array-arm
// pass — the union-arm sibling of the top-level closure-array annotation pass), else the
// narrowed `t0[0](1, 1, 1)` element call rejected loudly ("function-value call arity has no
// interned signature"). Fuzz post-#1025 declared/branching leg `((i32,i32,i32)=>boolean)[] | i32`.
function useIt(p: ((i32, i32, i32) => boolean)[] | i32) {
  const t0 = p
  if t0 is ((i32, i32, i32) => boolean)[] {
    print(t0[0](1, 1, 1))
  } else {
    print("OTHER")
  }
  if t0 is i32 { print(t0) } else { print("UOTHER") }
}
function useF64(p: ((i32, i32, i32) => boolean)[] | f64) {
  const t0 = p
  if t0 is ((i32, i32, i32) => boolean)[] {
    print(t0[0](1, 1, 1))
  } else {
    print("OTHER")
  }
  if t0 is f64 { print(t0) } else { print("UOTHER") }
}
function go() {
  useIt(99)
  useF64(9.25)
}
go()
