// An ARRAY OF CLOSURES whose RESULT is a COMPOSITE — the array-of-closure-with-
// composite-result graduations. The indexed call `xs[i](a)` must key the element's
// `$fnsig` with the composite result token and the read must recover it:
//   - a value-union-element list result (`(i64 | string)[]` — `>r` over a kind-2 slot):
//     the general call-result ref-list fallback claims the union-box element slot, so
//     `v[0](1)[0]` indexes directly AND a rebound list binding classifies;
//   - a variant-box-element list result (`({a,f,z} | i64)[]`): the lambda ADOPTS the
//     expected element union (`elemVariantBoxListRetName`), so its `$fnsig` byte-matches
//     the annotation side's `>r<slot>;`;
//   - a nullable-closure result (`((i32) => string) | null` — `>C`): the indexed call's
//     result binds the kind-19 niche (`exprNulClosure`'s sig-key fallback), narrows
//     `!= null`, and the inner call lowers;
//   - a closure-arm value union result (`(() => string) | i64` — `>u`): the lambda
//     adopts the union (`cloArmValueUnionRetName`), the closure arm boxes as the kind-11
//     ref atom, and the un-annotated call-result binding's narrowed read unboxes
//     (`nodeUnionName` renders the same spelling);
//   - a struct-FIELD closure with a variant-box-element list result at the GLOBAL
//     position (`{f: (i32) => (i32 | {w: i32})[]}`).

// Value-union-element list result: direct indexed-call index, both element arms.
function valueUnionElemList() {
  const v: ((i32) => (i64 | string)[])[] = [
    (_q0) => ([5000000077]),
    (_q0) => (["other"]),
  ]
  const t0 = v[0](1)[0]
  if t0 is i64 { print(t0) } else { print("OTHER") }
  const xs = v[1](1)
  const t1 = xs[0]
  if t1 is string { print(t1) } else { print("OTHER") }
}
valueUnionElemList()

// Variant-box-element list result through a named factory returning the closure.
function makeVb(): (i32) => ({a: boolean, f: boolean, z: i32} | i64)[] {
  return (_q0) => ([{ a: true, f: false, z: 9 }])
}
function variantBoxElemList() {
  const v: (i32) => ({a: boolean, f: boolean, z: i32} | i64)[] = makeVb()
  const t0 = v(1)[0]
  if (t0 is {a: boolean, f: boolean, z: i32}) {
    print(t0.f)
  } else {
    print("OTHER")
  }
}
variantBoxElemList()

// Nullable-closure result off an indexed element call.
function nulClosureResult() {
  const v: ((i32) => ((i32) => string) | null)[] = [
    (_q1) => ((_q0) => ("8202")),
  ]
  const t0 = v[0](1)
  if (t0 != null) { print(t0(1)) } else { print("NULL") }
}
nulClosureResult()

// Closure-arm value-union result under the nullable array-of-closure carrier
// (param position), both arms.
function useIt(p: ((i32) => (() => string) | i64)[] | null) {
  const t0 = p
  if t0 != null {
    const t1 = t0[0](1)
    if t1 is () => string { print(t1()) } else { print("OTHER") }
    const t2 = t0[1](1)
    if t2 is i64 { print(t2) } else { print("OTHER") }
  } else {
    print("NULL")
  }
}
useIt([(_q0) => (() => ("rdtlf")), (_q0) => (6001002003)])

// Struct-FIELD closure with a variant-box-element list result, GLOBAL position.
const g: {f: (i32) => (i32 | {w: i32})[]} = { f: (_q0) => ([{ w: 77 }]) }
function fieldCloList() {
  const t0 = g.f(1)[0]
  if t0 is i32 { print(t0) } else { print(t0.w) }
}
fieldCloList()
