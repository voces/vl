// @run
// @log 9
// @log 4
// Regression (unified arena registration walk): a struct union `A | B` buried TWO
// struct-field levels deep inside a CLOSURE PARAMETER type
// (`({f: {g: A | B}}) => i32`) — the deepest of the closure-param blind-spot family.
// The NAME walk descends a function-type annotation only into its RESULT and never
// reaches a union under a closure param at any depth, so `A | B` went unregistered and
// the chained field read `p.f.g` emit-failed ("unknown struct field in field access").
// The arena walk descends every composite variant uniformly (TyFunc → param → TyObj →
// TyObj field → TyUnion), so the union registers regardless of nesting depth — the
// missed-descent bug class made structurally impossible. Two lambdas (full dispatch +
// decoy arm) pin the box tag discrimination. Off-corpus pin.
type A = { a: i32 }
type B = { b: i32 }
function apply(cb: ({f: {g: A | B}}) => i32): i32 {
  return cb({ f: { g: { a: 9 } } })
}
function go() {
  print(
    apply(
      (p) => {
        const x = p.f.g
        if x is A { return x.a }
        if x is B { return x.b }
        return -1
      },
    ),
  )
  print(
    apply(
      (p) => {
        const x = p.f.g
        if x is B { return x.b }
        return 4
      },
    ),
  )
}
go()
