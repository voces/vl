// @run
// @log NIL
// @log NIL
// @log NIL
// @hint Intentionally-unused variable `_t3`

// A nullable-CLOSURE binding whose value is ONLY EVER `null` — no lambda exists anywhere —
// with the narrowed call in the (dead but must-validate) then-branch. The callee sig resolves
// from the binding ANNOTATION: `identFnTypeAnnName` returns a nulclosure annotation's name
// (local + global arms) and `cloNameSigKey` peels the `| null` + grouping parens, so the copy
// chain (`const t0 = v`) classifies the call result. The nullable RESULT (`string | null`)
// inside makes the inner niche read compose too. (rep-fuzz: `p0r (() => string | null) | null`
// was a `bare null needs a struct-typed context` reject; the unused-result spelling was
// INVALID-WASM — the nulstr call result stored into an i32-classified slot.)

function mkNone(): (() => string | null) | null { return null }

function go() {
  // Bare-null init, narrowed call, inner null-narrow (the fuzzer's `p0r` spelling).
  const v: (() => string | null) | null = null
  const t0 = v
  if t0 != null {
    const t1 = t0()
    if t1 != null { print(t1) } else { print("SOME") }
  } else {
    print("NIL")
  }

  // The UNUSED-result binding (was invalid wasm: the ref result into an i32 slot).
  const w: (() => string | null) | null = null
  const t2 = w
  if t2 != null {
    const _t3 = t2()
    print("SOME")
  } else {
    print("NIL")
  }

  // The call-returned spelling: no bare `null` literal in this function at all.
  const u: (() => string | null) | null = mkNone()
  const t4 = u
  if t4 != null {
    const t5 = t4()
    if t5 != null { print(t5) } else { print("SOME") }
  } else {
    print("NIL")
  }
}

go()
