// Regression: a global closure value in a `(closure | f64)` union whose result is a
// union of a NESTED-STRUCT-field struct arm and boolean
// (`{a: string, f: {f: string}, z: {[string]: i64}} | boolean`).
// `vbUnionMemberName`'s field loop declined the nested-struct field, so the lambda
// stayed un-pinned (self `boolean` `$fnsig`) while the narrowed value call cast to the
// `>u` box sig — a runtime TRAP (fuzz sweep5 declared leg, seed 448399393
// case_00335). Nested-struct fields now render canonically (the map-field admission's
// sibling from #977).
// @run
// @log OTHER
// @log false
// @log 9
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// @hint Intentionally-unused parameter `_q2`
const g: ((i32, i32, i32) => {a: string, f: {f: string}, z: {[string]: i64}} | boolean) | f64 = (_q0, _q1, _q2) => (false)
function go() {
  const t0 = g
  if (
    t0 is (i32, i32, i32) => {a: string, f: {f: string}, z: {[string]: i64}} | boolean
  ) {
    const t1 = t0(1, 1, 1)
    if t1 is {a: string, f: {f: string}, z: {[string]: i64}} {
      print(t1.f.f)
    } else {
      print("OTHER")
    }
    const u6: {a: string, f: {f: string}, z: {[string]: i64}} | boolean = false
    if u6 is boolean { print(u6) } else { print("UOTHER") }
    print(9)
  } else {
    print("F")
  }
}
go()
