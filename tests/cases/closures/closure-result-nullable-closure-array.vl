// @run
// @log 7
// @log NULL
// @log aa
// @log 0
// The lambdas ignore their params:
// @warning Unused parameter `q0`
// @warning Unused parameter `q1`
// A closure whose RESULT is an array of NULLABLE closures (`() => ((() => i64) | null)[]`,
// `((i32) => (((i32) => K0) | null)[]) | f64`) — the closure-result rep composed with the
// kind-5 niche element (`nullClosureArrElem`, `rlElemNullable`). Three seams close here:
//   1. the LITERAL-side element key: a `[() => 7, null]` typed only through a lambda's
//      contextual result renders its `(<fn>)|null` table key via `nodeArrayElemName`'s
//      TyNullable arm (through `nullableRetName`, so a litunion result keeps its ALIAS —
//      `K0`, the i32-atom token), byte-matching the annotation-side `refArrElemName` key;
//   2. an all-`null` body literal (`() => ([null])` — the fuzzer's isNull draw, which
//      self-infers `null[]`): the checker ADOPTS the expected niche list at the lambda
//      boundary (`nulClosureElemListRetName`) and `synthRetAnnots` pins `fnRet`, so the
//      pinned TypeRef collects the ref-list slot + element `$fnsig` and `emitReturnValue`
//      threads the kind-5 `[null]` seed (`ref.null $cloStruct`);
//   3. the value call keys `>r<slot>;` on BOTH producers (`cloRetKeySuffix` from the
//      literal-side element name, `annRetKind` from the annotation), so the chained
//      `g()[0]` read narrows and the element call resolves its real `$fnsig`.
// Covers the global (p3) and union-armed local (p0) positions the rep fuzzer exercises.
// (rep-fuzz: `p3c`/`p3r () => ((() => i64) | null)[]` and `p0c`/`p0r
// ((i32) => (((i32) => K0) | null)[]) | f64` were `ref valtype with no interned shape` /
// `bare null needs a struct-typed context` / `no interned signature` rejects.)
type K0 = "aa" | "bb"

const g: () => ((() => i64) | null)[] = () => [() => 7, null]
const gNull: () => ((() => i64) | null)[] = () => ([null])

function go() {
  const f = g()[0]
  if f != null { print(f()) }
  const h = gNull()[0]
  if h == null { print("NULL") }
  const v: ((i32) => (((i32) => K0) | null)[]) | f64 = (q0) => [(q1) => "aa", null]
  if v is (i32) => (((i32) => K0) | null)[] {
    const arr = v(1)
    const k = arr[0]
    if k != null { print(k(2)) }
    const nil = arr[1]
    if nil == null { print(0) }
  }
}
go()
