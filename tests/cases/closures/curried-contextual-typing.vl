// @run
// @log 7
// @log 7
// @log 7
// A CURRIED lambda with UN-annotated params — `(a) => (b) => a + b` — typed from an expected
// FUNCTION type whose result is itself a function type. `seedExpected` (the one contextual-typing
// mechanism) recorded a lambda's expected PARAMS but never recursed into its BODY, so the inner
// lambda's params had no expected type ("cannot infer a type for parameter `b`"). It now seeds the
// body tail against the expected RESULT type — the dual of its array/object-literal recursion — so
// a lambda nested under arrows (curried) is reached by the SAME recursive walk that already
// reached lambdas under arrays / object fields. Works across every contextual position: an
// annotated binding, a call argument, and a closure-returning function's return.
//
// (The deep EMITTER chain — a 3rd application, or the direct `mk()(3)(4)` call of a call result —
// is a separate closure-ABI gap; binding the intermediate closure, as below, lowers cleanly.)

// curried via an annotated binding.
function fromBinding(): i32 {
  const f: (i32) => ((i32) => i32) = (a) => (b) => a + b
  return f(3)(4)
}

// curried passed as a call ARGUMENT (expected type from the param annotation).
function applyCurried(f: (i32) => ((i32) => i32)): i32 { return f(3)(4) }

// a closure-returning function whose body is itself a curried lambda.
function adder(): (i32) => ((i32) => i32) { return (a) => (b) => a + b }

function go() {
  print(fromBinding()) // 7
  print(applyCurried((a) => (b) => a + b)) // 7

  // bind the returned closure, then apply it.
  const g = adder()
  print(g(3)(4)) // 7
}
go()
