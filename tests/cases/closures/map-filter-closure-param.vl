// @run
// @log 2
// @log 6
// @log 3
// @log 2
// @log 4
// @log 8
// `.map` / `.filter` with a CLOSURE-VALUE callback — a function-typed PARAM or binding (`xs.map(f)`
// where `f: (i32) => i32`), as opposed to a literal lambda or named function. This is the callback-
// forwarding HOF pattern (`function applyMap(xs, f) { return xs.map(f) }`), and the body of a GENERIC
// HOF (`mapArr<T,R>(xs, f: (T) => R) { return xs.map(f) }`) once instantiated.
//
// The inline `.map`/`.filter` loop already `call_ref`s its callback closure per element — it just
// required a lifted function to derive the result element kind + the interned `$fnsig`. A closure value
// has no lifted fe, so both now come from the closure's own SIG (`mfCallbackCloKey` →
// `sigKeyRetKind` / `cloSigPosOfKey`). Scalar callback returns (i32 / f64 / i64 / string).

// A non-generic HOF forwarding a callback to `.map`.
function applyMap(xs: i32[], f: (i32) => i32): i32[] { return xs.map(f) }
// …and to `.filter`.
function applyFilter(xs: i32[], p: (i32) => boolean): i32[] {
  return xs.filter(p)
}
// A GENERIC HOF — its body's `xs.map(f)` is a closure-param call once monomorphized.
function mapArr<T, R>(xs: T[], f: (T) => R): R[] { return xs.map(f) }

function go() {
  const a = applyMap([1, 2, 3], (x) => x * 2) // [2,4,6]
  print(a[0]) // 2
  print(a[2]) // 6

  const b = applyFilter([1, 2, 3, 4], (x) => x > 2) // [3,4]
  print(b[0])                                       // 3
  print(b.length)                                   // 2

  // A binding (not a param) holding the closure, forwarded to .map.
  const dbl: (i32) => i32 = (n) => n + n
  const c = applyMap([1, 2], dbl) // [2,4]
  print(c[1]) // 4

  // A generic HOF with an annotated lambda arg.
  const d = mapArr([1, 2, 3, 4], (x: i32) => x * 2) // [2,4,6,8]
  print(d[3]) // 8
}

go()
