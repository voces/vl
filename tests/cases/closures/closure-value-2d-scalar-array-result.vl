// Regression: a closure VALUE returning a 2-D i32-backed leaf array (`(i32) => boolean[][]`,
// `(i32) => (boolean|null)[][]`). The outer array's ELEMENT is the inner i32-list wrapper
// (element kind 4 — `boolean[]`, `(boolean|null)[]` all share the ONE i32-list wrapper
// `i32[]` uses). The ANNOTATION rendered that element by its source spelling (`boolean[]` /
// `(boolean|null)[]`) while the self-inferred lambda softened it to `i32[]`, so the two sides
// interned TWIN ref-list slots for one wrapper heap type. The value call's `$fnsig` result
// token `>r0;` (annotation slot) diverged from the lambda's `>r1;` (inferred slot), and the
// `call_ref` `ref.cast` to the annotation's wrapper TRAPPED on the lambda's — a cast failure.
// The named-function spelling always worked. Fix: `rlCanonElemName` folds an i32-backed leaf
// list (`nameIsI32Array`) to `i32[]` at the single ref-list intern/lookup point, so both sides
// key ONE slot — the i32-leaf sibling of the litunion-atom slot canonicalization.
// @run
// @log 2
// @log 2
// @log true
// @log false
// @log false
// @log 2
// @log 99
// @log 0
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_a`
function useBool(p: (i32) => boolean[][]) {
  const t1 = p(1)
  print(t1.length)
  const t2 = t1[0]
  print(t2.length)
  print(t2[0])
  print(t2[1])
  print(t1[1][0])
}
function useNulBool(s: (i32) => (boolean | null)[][]) {
  const r = s(1)
  print(r.length)
  const inner = r[0]
  const e = inner[1]
  if e == null { print(99) } else { print(1) }
  print(r[1][0])
}
function go() {
  useBool((_q0) => ([[true, false], [false]]))
  useNulBool((_a) => ([[true, null], [false]]))
}
go()
