// Regression: a `ref.cast` whose target heap type index is >= 64 must encode the
// immediate as SIGNED LEB128 (s33), not unsigned. `ref.cast`'s operand is a HEAPTYPE:
// a non-negative value is a concrete type index, a negative one an abstract heaptype
// (`func`/`struct`/…). Under an unsigned write, a concrete index whose low 7 bits set
// bit 6 (`>= 64`) is misread on decode as a NEGATIVE abstract heaptype — `ref.cast
// (ref 64)` emitted `0x40`, which SLEB-decodes to `-64` → "invalid heap type", a
// hard WebAssembly translation error at exactly the 49th distinct capturing closure
// (env struct types climb one per closure; index 63 = `0x3F` still reads positive,
// index 64 = `0x40` flips negative). This map whose value is a 2-D array of maps-returning
// closures mints 64 distinct env struct types (each `() => (h0)` captures `h0`), so its
// per-lambda `local.get 0; ref.cast (ref <envType>)` crosses the boundary. Fix: `fbRefCast`
// writes the heap type with `wSLEB` — byte-identical to `wULEB` for every index < 64
// (the compiler's own max is 59, so its self-compilation is byte-neutral), and pads a
// `>= 64` index with a `0x00` continuation so it decodes as the intended positive index.
// @run
// @log 381.5
function go() {
  const h0: {[string]: f32} = Map()
  h0["k"] = 381.5
  const m: {[string]: (() => {[string]: f32})[][]} = Map()
  m["k"] = [
    [
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
    ],
    [
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
    ],
    [
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
    ],
    [
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
    ],
    [
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
    ],
    [
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
    ],
    [
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
    ],
    [
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
      () => (h0),
    ],
  ]
  const t0 = m["k"] ?? [[() => (h0)]]
  const t1 = t0[0][0]()["k"] ?? 15.5
  print(t1)
}
go()
