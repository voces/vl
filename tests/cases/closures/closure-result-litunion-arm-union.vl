// @run
// @log bb
// @log 6000000001
// @log aa
// @log cc
// @log OTHER
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// A closure/function-VALUE call whose RESULT is a value union carrying a literal-union
// ALIAS arm (`(i32) => K0 | i64`, `(i32) => {f: K0} | i64` — the R2 closure-result
// seam over `nameIsLitUnionArmValueUnion`). The alias arm rides the value box as its
// member-STRING atom (tag `string`), so the union registers value-box style
// (`registerValueUnionName` admits the alias arm), the adopted lambda's `$fnsig` keys
// `>u`, and both the positive `is K0` narrow and the else-branch i64 complement read
// unbox. Positions: local lambda (p0) and returned closure (p2).
type K0 = "aa" | "bb" | "cc"

// p0: lambda adopts `K0 | i64`; alias arm taken, then the i64 arm's complement read.
function localPos() {
  const v: (i32) => K0 | i64 = (_q0) => ("bb")
  const t0 = v(1)
  if t0 is K0 { print(t0) } else { print("OTHER") }
  const w: (i32) => K0 | i64 = (_q0) => (6000000001)
  const t1 = w(1)
  if t1 is K0 { print(t1) } else { print(t1) }
}
localPos()

// p2: the union-result closure is returned from a named function.
function makeIt(): (i32) => K0 | i64 { return (_q0) => ("aa") }
function retPos() {
  const v: (i32) => K0 | i64 = makeIt()
  const t0 = v(1)
  if t0 is K0 { print(t0) } else { print("OTHER") }
}
retPos()

// p2: a STRUCT arm whose field is the litunion (`{f: K0} | i64`), both arms.
function makeF(): (i32) => {f: K0} | i64 { return (_q0) => ({ f: "cc" }) }
function makeI(): (i32) => {f: K0} | i64 { return (_q0) => (6000000002) }
function structField() {
  const v: (i32) => {f: K0} | i64 = makeF()
  const t0 = v(1)
  if t0 is {f: K0} { print(t0.f) } else { print("OTHER") }
  const w: (i32) => {f: K0} | i64 = makeI()
  const t1 = w(1)
  if t1 is {f: K0} { print(t1.f) } else { print("OTHER") }
}
structField()
