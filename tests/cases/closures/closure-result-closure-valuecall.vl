// @run
// @log 6143.5
// @log 777
// @log true
// A closure whose RESULT is itself a closure, called DIRECTLY on the call result
// (`g()(1)`) — the "no interned signature" family this graduates. Calling the outer
// closure yields an inner closure whose `$fnsig` the concrete-lambda collector never
// mints: it interns from real lifted lambdas, and a lambda RETURNING a closure has no
// lifted lambda of the RESULT type (and its self-inferred result kind — an f64 literal —
// would disagree with the annotated f32 anyway). So the inner call `...(1)` had no
// interned signature and rejected loudly. `collectCloSigs` now walks each closure-
// returning lambda's CHECKER type (`nodeTyName`, the same source the call site keys off)
// and synthesizes every result closure's `$fnsig` from its key (`unionArmSigKey` +
// `emitSynthCloSig`, rep -1) — the closure dual of the nullable-closure-result pass,
// generalized to the whole result spine and to arbitrary nesting depth. A top-level
// `const`/global lambda also now has its own body descended (a resumed lift worklist), so
// the inner literal is lifted rather than reaching emit as `function literal not lifted`.
const g1: () => ((i32) => f32) = () => ((q0) => (6143.5))
const g2: (i32) => (() => i64) = (a) => (() => (777))
const g3: () => (() => (i32) => boolean) = () => (() => ((z) => (true)))

function go() {
  print(g1()(1))    // 6143.5 — result f32
  print(g2(1)())    // 777    — result i64, via a returned nullary closure
  print(g3()()(1))  // true   — triple-nested chain g3()()(1)
}
go()
