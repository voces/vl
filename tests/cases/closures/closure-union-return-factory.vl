// @run
// @log 1
// @log 9
// @log 5
// @log neg
// A FACTORY returning a union-handler closure: `function mk(): (i32) => C | S { return (n) => … }`.
// The previous union-closure work pinned a lambda BOUND to a closure-union type (`const g: (i32) =>
// C | S = …`); a lambda in the RETURN tail of a closure-union-returning function was NOT pinned, so its
// inferred return collapsed to one arm and the value call failed ("ref valtype with no interned shape").
// `synthRetAnnots` now also pins a return-tail lambda from the enclosing function's return annotation
// (`synthPinUnionRet`, shared with the binding case). The result binding `const g = mk()` recovers its
// closure type from `mk`'s return (`identFnTypeAnnName`), so `unionNameOfExpr` classifies `g(x)`'s union
// — and a VALUE-union result unboxes on narrow (`unionRetOfFnType` / the value-union binding case).
// Covers a STRUCT union, a declared ALIAS, and a VALUE union.

type C = { c: i32 }
type S = { s: i32 }
type Sh = C | S

function mkStruct(): (i32) => C | S {
  return (n) => if n > 0 { { c: n } } else { { s: 9 } }
}

function mkAlias(): (i32) => Sh {
  return (n) => if n > 0 { { c: n } } else { { s: 0 } }
}

function mkValue(): (i32) => i32 | string {
  return (n) => if n > 0 { n } else { "neg" }
}

function go() {
  // Struct union — both arms narrowed.
  const g = mkStruct()
  const a = g(1)
  if a is C { print(a.c) } // 1
  const b = g(-1)
  if b is S { print(b.s) } // 9

  // Declared alias.
  const h = mkAlias()
  const c2 = h(5)
  if c2 is C { print(c2.c) } // 5

  // Value union — the string arm unboxes.
  const v = mkValue()
  const r = v(-1)
  if r is string { print(r) } // neg
}

go()
