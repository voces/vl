// @run
// @log b
// @log hi
// The inner closures ignore their param `q0`:
// @warning Unused parameter
// A closure-returning-closure whose INNERMOST result is a COMPOSITE (a litunion `K0`, a
// struct `{f: string}`) — reached directly on the call result (`g()(1)`). These lower via
// the CONCRETE lifted inner lambda's own `$fnsig` (interned with a real representative);
// the result-chain synthesis (`internCloResultChain`) deliberately does NOT synth a sig
// for a composite RESULT — that is bounded to nested-closure / plain-scalar results, so a
// synthesized `>i` / `>u` never displaces the concrete rep and mis-lowers the boxed/atom
// value. Guards that boundary: the litunion atom and the struct ref both round-trip when
// the concrete lambda supplies the rep, and stay a clean REJECT (never INVALID-WASM / TRAP)
// when no concrete lambda of the shape exists.
type K0 = "a" | "b" | "c"

const gLit: () => ((i32) => K0) = () => ((q0) => ("b"))
const gStruct: () => ((i32) => {f: string}) = () => ((q0) => ({f: "hi"}))

function go() {
  print(gLit()(1))       // b  — litunion result
  print(gStruct()(1).f)  // hi — struct result
}
go()
