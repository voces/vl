// @run
// @log bjtvb
// A closure result struct whose MAP field's value union is a nullable
// litunion mix (`() => {f: {[string]: K0 | i64 | null}}`, fuzz-nightly seed
// 658239060 d5). `canonEmitName` expands a litunion-ALIAS union member through
// `unionAliasMembers` like a regular alias, softening its literals — so one
// producer spelled the map value `string|i64|null` while the annotation kept
// `K0|i64|null`: TWIN mv slots with divergent vals reps, the narrowed map read
// resolving the wrong twin's struct (INVALID-WASM). The mv-table now
// canonicalizes at its intern + lookup chokepoints (`mvCanonValName` — litunion
// atoms widen to `string` ONLY in a genuine mix; a pure `K0 | null` niche keeps
// its -1-sentinel mono rep).
type K0 = "64" | "bjtvb" | "tt"
function useIt(p: () => {f: {[string]: K0 | i64 | null}}) {
  const t0 = p().f["k"] ?? "64"
  const t1 = t0
  if t1 != null {
    const t2 = t1
    if (t2 is K0) { print(t2) } else { print("OTHER") }
  } else {
    print("NULL")
  }
}
function go() {
  const h1: {[string]: K0 | i64 | null} = Map()
  h1["k"] = "bjtvb"
  useIt(() => ({ f: h1 }))
}
go()
