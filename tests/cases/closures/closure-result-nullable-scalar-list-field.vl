// A struct with a CLOSURE FIELD whose result struct carries a NULLABLE i32-backed
// SCALAR-LIST field (`f: i32[] | null`, code 18) beside sibling fields, AND a sibling
// `z: {a: f64, f: f32, z: i64}` that shares the same {a,f,z} field-name set. The
// closure-result shape now interns (`funcTypeShapeLowerable` admits the code-18
// i32-backed nullable list), so the lambda literal building it name-set-matches THIS
// row instead of fieldset-colliding onto the f64/f32/i64 sibling twin — which emitted
// `a: 3.5` as f64 into an f32 slot (INVALID WASM: "expected f32, found f64" at the
// lambda; fuzz-sweep.PYbpDt branching p2c+p2r, seed 611511973). Reads both the non-null
// and null nullable-list field to prove the field rep round-trips.
// @run
// @log 12121
function makeIt(): {a: () => {a: f32, f: i32[] | null, z: i32}, f: string, z: {a: f64, f: f32, z: i64}} {
  return {
    a: () => ({ a: 3.5, f: [4, 12121], z: 11 }),
    f: "pppj",
    z: { a: 2.5, f: 747.5, z: 6000000000 },
  }
}
function go() {
  const v: {a: () => {a: f32, f: i32[] | null, z: i32}, f: string, z: {a: f64, f: f32, z: i64}} = makeIt()
  const r = v.a()
  const lst = r.f
  if lst != null { print(lst[1]) } else { print(-1) }
}
go()
