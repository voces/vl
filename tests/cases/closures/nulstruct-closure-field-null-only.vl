// @run
// @log NIL
// @log 7
// @log 2.5

// A nullable STRUCT with a CLOSURE field (`{f: () => i32} | null`) whose program constructs NO
// lambda on the null draw — the field's `$fnsig` interns from the SHAPE annotation
// (`internShapeFieldCloSigs`, the field dual of the nulclosure-annotation sig pass) and
// `collectFnValUse` flips the closure machinery on (`shapeHasCloField`), so the narrowed member
// call `t0.f()` in the dead-but-must-validate branch resolves. The live spellings — a real
// closure field value, and a NULLABLE-RESULT field closure (`() => f32 | null`) — share the
// same interned sig. (rep-fuzz: `p2r {f: () => i32} | null` was a `function-value call arity
// has no interned signature` reject.)

function mkNone(): {f: () => i32} | null { return null }

function go() {
  // The null-only draw (the fuzzer's `p2r` spelling): no lambda exists anywhere on this path.
  const v: {f: () => i32} | null = mkNone()
  const t0 = v
  if t0 != null { print(t0.f()) } else { print("NIL") }

  // The live field value.
  const w: {f: () => i32} | null = { f: () => (7) }
  const t1 = w
  if t1 != null { print(t1.f()) } else { print("NIL") }

  // A NULLABLE-RESULT field closure: the field's inner sig keys the `>u` box result. A
  // DISTINCT field name (`g`) — two same-field-name-set shapes with different closure reps
  // in one program stay the documented name-set-keyed interning limitation.
  const u: {g: () => f32 | null} | null = { g: () => (2.5) }
  const t2 = u
  if t2 != null {
    const t3 = t2.g()
    if t3 != null { print(t3) } else { print("SOME") }
  } else {
    print("NIL")
  }
}

go()
