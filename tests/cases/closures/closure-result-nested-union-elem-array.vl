// @run
// @log OTHER
// @log 77
// A closure whose result is a NESTED (2-D) array of a value union `({f: (i32,i32,i32) =>
// boolean} | i32)[][]`. A NAMED function with the explicit 2-D annotation lowers this today
// (its `fnRet` threads `pendingListKind`/`pendingListSlot` into the body's nested array
// literal), but an INFERRED lambda had `fnRet < 0` — no thread — so the outer array literal
// `[[77], [{f:…}]]` self-classified `i32[][]` from its first inner list's leaf (`[77]`),
// storing a union-list element into the i32-list backing (INVALID-WASM at __lambda_0). The
// checker now adopts + records the nested union-element array (`nestedElemUnionListRetName`)
// and `synthRetAnnots` pins the lambda's `fnRet` (`nameIsNestedUnionElemArray`), routing it
// through the same sound path the annotated named-fn form uses. Fuzz sweep wo7cNe declared,
// seed 174529790 (p2c+p2r).
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// @hint Intentionally-unused parameter `_q2`
function makeIt(): () => ({f: (i32, i32, i32) => boolean} | i32)[][] {
  return () => ([[77], [{ f: (_q0, _q1, _q2) => (true) }], [{ f: (_q0, _q1, _q2) => (true) }]])
}
function go() {
  const v: () => ({f: (i32, i32, i32) => boolean} | i32)[][] = makeIt()
  const t0 = v()[0][0]
  if (t0 is {f: (i32, i32, i32) => boolean}) {
    print(t0.f(1, 1, 1))
  } else {
    print("OTHER")
  }
  const u0: {f: (i32, i32, i32) => boolean} | i32 = 77
  if u0 is i32 { print(u0) } else { print("UOTHER") }
}
go()
