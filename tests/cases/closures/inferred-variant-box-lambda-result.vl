// @run
// @log 4
// @log 7
// @log 42
// @log OTHER
// An anonymous LAMBDA with an inferred VARIANT-BOX union result (`Cat | i32`, `{w: i32} |
// i32` — a struct arm beside a scalar) lowers identically to the annotated spelling. The
// checker records `variantBoxUnionRetName` under the lambda's `#<nodeIx>` sentinel,
// `collectU` registers the box + variant, and `synthRetAnnots`'s `isUName` arm pins the
// lambda's `fnRet` to the same name the annotated `: Cat | i32` closure type would carry —
// so the value call's `$fnsig` result keys `>u` and the narrow resolves. The NOMINAL arm
// (`Cat`) resolves to its declared name (`vbUnionMemberName`'s `nominalNameOfObj`), so an
// `is Cat` narrow finds the variant exactly as the annotated form does.
type Cat = { legs: i32 }
function go(c: boolean) {
  const mk = (b: boolean) => {
    if b { return { legs: 4 } }
    return 7
  }
  const r = mk(c)
  if r is Cat { print(r.legs) } else { print(r) }
}
go(true) // 4
go(false) // 7

// An INLINE-shape arm (`{w: i32} | i32`) narrows by shape.
function go2(c: boolean) {
  const mk = (b: boolean) => {
    if b { return { w: 42 } }
    return 99
  }
  const r = mk(c)
  if r is {w: i32} { print(r.w) } else { print("OTHER") }
}
go2(true) // 42
go2(false) // OTHER
