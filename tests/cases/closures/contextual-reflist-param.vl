// @run
// @log 7
// @log 7
// @log 5
// A lambda with an UN-annotated REF-LIST parameter, typed contextually from the expected function
// type (`run` expects `(S[]) => i32`, so `xs` in `(xs) => …` is `S[]`). The checker types `xs`,
// but the emitter's `nodeTyName` rendered only scalars / structs / closures — a `TyArray` fell
// through to "", so `synthParamAnnots` left the param un-pinned and it DEFAULTED to i32: `xs[0]`
// read as an i32 index, "field access receiver is not a struct".
//
// `nodeTyName` now renders a `TyArray` (recursively, via `tyToEmitName`), and `synthParamAnnots`
// resolves the shape to its nominal form through one recursive `resolveShapeToNominal` (struct /
// variant / ref-array at any depth) rather than a per-shape special case — so the contextual
// ref-list param resolves to its real type instead of silently becoming i32.

type S = { v: i32 }

function runList(g: (S[]) => i32): i32 { return g([{ v: 7 }]) }

function runSum(g: (S[]) => i32): i32 { return g([{ v: 3 }, { v: 4 }]) }

function runStruct(g: (S) => i32): i32 { return g({ v: 5 }) }

function go() {
  // index + field through the contextually-typed list param.
  print(runList((xs) => xs[0].v)) // 7

  // for-in over the contextually-typed list param.
  print(
    runSum(
      (xs) => {
        let t = 0
        for s in xs { t = t + s.v }
        return t
      },
    ),
  ) // 3 + 4 = 7

  // a bare struct param still resolves (regression).
  print(runStruct((s) => s.v)) // 5
}

go()
