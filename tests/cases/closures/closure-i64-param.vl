// @run
// @log 12000000000
// @log 9000000001
// @log 10000000000
// @log 4999999999
// An i64 PARAMETER in a function VALUE's signature. The closure `$fnsig` param token (kind
// 10 → `I`) interns the signature, so a value call (`f(x)`), a let-bound closure, and an
// i64-signature closure array all resolve the right functype instead of the absent all-i32
// arity fallback. The un-annotated lambda param infers i64 from the contextual position.

function apply(f: (i64) => i64, x: i64) { return f(x) }

function go() {
  // value call through a higher-order parameter; `n` inferred i64 from `(i64) => i64`.
  print(apply((n) => n * 2, 6000000000)) // 12000000000

  // a let-bound closure value with an i64 signature.
  const inc: (i64) => i64 = (n) => n + 1
  print(inc(9000000000)) // 9000000001

  // an i64-signature closure ARRAY (indexed call resolves the element signature).
  const fs: ((i64) => i64)[] = [(n) => n * 2, (n) => n - 1]
  print(fs[0](5000000000)) // 10000000000
  print(fs[1](5000000000)) // 4999999999
}
go()
