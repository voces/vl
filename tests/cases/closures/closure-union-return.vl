// @run
// @log 5
// @log 9
// @log 8
// @log neg
// @log 7
// @log 2
// A function VALUE (a lambda bound to an annotated closure type) whose RESULT is a UNION:
// `const g: (i32) => Cat | Dog = (n) => if … { aCat } else { aDog }`. The value call `g(x)` returns
// the union box, and the result narrows (`if r is Cat`). An anonymous lambda's un-annotated return
// is inferred from its body, which for a union join collapses to ONE arm — so its emitted functype
// result and interned `$fnsig` key (`i>s0;` / `i>S`) disagreed with the call site's annotation-derived
// `i>u`, leaving the value call un-interned. `synthRetAnnots` now propagates the binding's closure-type
// UNION return onto the lambda's `fnRet` (before the shape-interning passes), so it emits the boxed-union
// result like a named `: Cat | Dog` function, interns `i>u`, and `registerInlineUnion` registers an
// inline union written directly in the closure annotation so the `is`-narrow resolves. Covers a declared
// union ALIAS and an INLINE union, a STRUCT union and a VALUE union, and a 3-way union — both arms.

type Cat = { meow: i32 }
type Dog = { bark: i32 }
type Animal = Cat | Dog

function go() {
  // Declared union ALIAS, struct union — both arms narrow.
  const g: (i32) => Animal = (n) => if n > 0 { { meow: n } } else { { bark: 9 } }
  const a = g(5)
  if a is Cat { print(a.meow) } // 5
  const b = g(-1)
  if b is Dog { print(b.bark) } // 9

  // INLINE value union written directly in the closure annotation — both arms.
  const h: (i32) => i32 | string = (n) => if n > 0 { n * 2 } else { "neg" }
  const r = h(4)
  if r is i32 { print(r) } // 8
  const r2 = h(-1)
  if r2 is string { print(r2) } // neg

  // 3-way union.
  const k: (i32) => i32 | string | boolean = (n) => if n > 0 { n } else { "x" }
  const c = k(7)
  if c is i32 { print(c) } // 7

  // INLINE struct union written directly in the closure annotation.
  const m: (i32) => Cat | Dog = (n) => if n > 0 { { meow: n } } else { { bark: 0 } }
  const d = m(2)
  if d is Cat { print(d.meow) } // 2
}

go()
