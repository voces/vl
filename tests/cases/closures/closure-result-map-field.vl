// @run
// @log 445.5
// @log 14.5
// @log 3878
// @log 6000000000
// @log 3.5
// @log 0
// A closure/lambda RESULT that is a struct CARRYING a typed-value MAP field
// (`(i32) => {f: {[string]: f64}}`, `() => {a: i64, f: {[string]: f64}, z: f32}`):
// `funcTypeShapeLowerable` admits a code-19 map field whose VALUE kind the mv
// interner represents (`mvValKindOfName != -3`), so the functype's result shape
// interns and the value call's `$fnsig` keys the struct slot. The `collectA`
// struct-field pass interns the field's mv slot AND forces the shared map
// machinery (`mUsed`/`lUsed`/`aUsed`) — the annotation may be the module's only
// map mention. The read chains: value call → field access → fused map get
// (`v(1).f["k"] ?? d`), hit and miss arms both.
// The lambda captures the map from the enclosing frame (`exprMap`'s captured-map
// arm classifies it, `mapShapeOfExpr` resolves its mv slot from the PARENT
// binding), and an f32-valued map field is construct-only exercised.
function makeIt(): () => {a: i64, f: {[string]: f64}, z: f32} {
  const h1: {[string]: f64} = Map()
  h1["k"] = 3878.0
  return () => ({ a: 6000000000, f: h1, z: 3.5 })
}
function go() {
  const h0: {[string]: f64} = Map()
  h0["k"] = 445.5
  const v: (i32) => {f: {[string]: f64}} = (q1) => ({ f: h0 })
  print(v(1).f["k"] ?? 14.5)
  print(v(2).f["zz"] ?? 14.5)
  const v2: () => {a: i64, f: {[string]: f64}, z: f32} = makeIt()
  print(v2().f["k"] ?? 14.5)
  print(v2().a)
  print(v2().z)
  // An f32-VALUED map field (construct-only): the shape interns; no read.
  const m: {[string]: f32} = Map()
  const v3: () => {m: {[string]: f32}} = () => ({ m: m })
  print(0)
}
go()
