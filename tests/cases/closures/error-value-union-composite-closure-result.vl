// @emit-error value-union closure RESULT is not yet representable
// @hint Intentionally-unused parameter `_q0`
// A struct FIELD that is a closure returning a VALUE UNION with a COMPOSITE member
// (`(i32) => f32 | {w: i32}`). The lambda body `({w: 77})` self-infers its single
// concrete arm (a bare `{w: i32}` rep) while the checker types the value call
// `v.f(1)` as the whole union `f32 | {w: i32}`, so the narrow that reads it
// (`t0 is f32`) mis-read the plain struct rep as the `{tag, value}` box — a
// dead-but-invalid narrowed arm printing a `(ref)` via `__print_f32__` (invalid
// wasm). The value-union-with-composite closure-RESULT box READ is deferred by
// design (typecheck C2/C3), so `emitCallRef` REJECTs cleanly
// (`cloCallUnionResultUnrepresentable`) instead of leaking invalid wasm — matching
// the plain-binding loud reject. (rep-fuzz p0r
// `{a: i32, f: (i32) => f32 | {w: i32}, z: f32}`, was INVALID-WASM.)
function go() {
  const v: {a: i32, f: (i32) => f32 | {w: i32}, z: f32} = {
    a: 11,
    f: (_q0) => ({w: 77}),
    z: 3.5,
  }
  const t0 = v.f(1)
  if t0 is f32 {
    print(t0)
  } else {
    print(0)
  }
}

go()
