// @run
// @log 9
// @log 10
// @log 9
// @log 9
// @log 12
// The non-capturing probe `k` deliberately ignores its outer arg `a`:
// @warning Unused parameter `a`
// A CURRIED lambda — an anonymous arrow whose body is ITSELF an arrow (`(a) => (b) => a + b`),
// the last of the closure nesting-probe gaps. Two compounding bugs blocked it. (1) CHECK: an
// anonymous lambda is keyed `""` on the inference stack, so a nested lambda collided with its
// parent and short-circuited to void. Keyed by node index now. (2) EMIT: a function whose tail
// is a bare lambda is a closure RESULT (`>c`), a kind outside the value-call ABI — needed in all
// three `$fnsig` producers (AST `cloRetKeySuffix`, key parser `sigKeyRetKind`, annotation
// `annRetKind`), a non-void function-result classification (`fnReturnsClosure` over the tail OR
// an annotated function-type return), a bare-lambda tail-VALUE case (`stmtIsTailValue`), and a
// `canonEmitName` fix so a nested function-type annotation (`(i32) => ((i32) => i32)`) is not
// corrupted by the blind wrapping-paren strip.

function apply(f: (i32) => i32, x: i32): i32 { return f(x) }

// A function-typed PARAM whose result is itself a closure (`(i32) => ((i32) => i32)`): the
// intermediate `g = f(x)` binds a closure, then `g(y)` calls it.
function apply2(f: (i32) => ((i32) => i32), x: i32, y: i32): i32 {
  const g = f(x)
  return g(y)
}

// A NAMED function returning a curried closure value.
function makeAdder(a: i32): (i32) => i32 { return (b) => a + b }

function go() {
  // the canonical curried lambda, bound and called in two steps.
  const add = (a: i32) => (b: i32) => a + b
  const add4 = add(4)
  print(add4(5)) // 9

  // a NON-capturing inner — the outer arg is ignored.
  const k = (a: i32) => (b: i32) => b * 2
  const k9 = k(99)
  print(k9(5)) // 10

  // a BLOCK-body outer arrow (`(a) => { return (b) => … }`).
  const addB = (a: i32) => {
    return (b: i32) => a + b
  }
  const addB4 = addB(4)
  print(addB4(5)) // 9

  // passed THROUGH a higher-order function taking a closure-returning closure.
  print(apply2(add, 4, 5)) // 9

  // a named curried function, applied in two steps via `apply`.
  const inc7 = makeAdder(7)
  print(apply(inc7, 5)) // 12
}
go()
