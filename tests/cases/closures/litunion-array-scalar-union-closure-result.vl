// @run
// @log OTHER
// @log 84
// @log OTHER
// @log bf
// @log 3.5
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`

// An anonymous lambda whose expected closure RESULT is a `litunion-array | scalar` value union
// (`K0[] | i64`) must ADOPT the union so its `$fnsig` result keys the value box (`>u`) that the
// value call casts to. `valueUnionRetName` DECLINED this union (its `tyToStr` render flattens the
// litunion-array atom `"84"|"trl"|"bf"[]`, fracturing the atom split) even though `K0[]` IS a
// value atom (kind 7, the i32-list backing) — so the lambda self-inferred a bare `i64` / `K0[]`
// arm and the narrowed field-closure call `ref.cast`-ed the funcref to the box `$fnsig` it never
// interned. Distinguishing: on clean #1037 the variant-box-arm spelling TRAPs (cast failure) and
// the direct-binding spelling loud-rejects ("value-union closure RESULT is not yet representable");
// full support here. The named-function spelling (`mk(): K0[] | i64`) already lowered this box.

type K0 = "84" | "trl" | "bf"

// The variant-box-arm-field spelling — the original fuzz TRAP `{f: (i32) => K0[] | i64} | f64`.
function variantBoxArm() {
  const v: {f: (i32) => K0[] | i64} | f64 = { f: (_q0) => (5000000077) }
  const t0 = v
  if t0 is {f: (i32) => K0[] | i64} {
    const t1 = t0.f(1)
    if t1 is K0[] {
      print(t1[0]) // scalar arm -> OTHER
    } else {
      print("OTHER")
    }
  } else {
    print("F64")
  }
}
variantBoxArm()

// Direct closure-binding spelling, ARRAY arm.
function directArrayArm() {
  const c: (i32) => K0[] | i64 = (_q0) => {
    const a: K0[] = ["84", "trl"]
    return a
  }
  const t1 = c(1)
  if t1 is K0[] {
    print(t1[0]) // array arm -> 84
  } else {
    print("OTHER")
  }
}
directArrayArm()

// Direct closure-binding spelling, SCALAR arm.
function directScalarArm() {
  const c: (i32) => K0[] | i64 = (_q0) => (42)
  const t1 = c(1)
  if t1 is K0[] {
    print(t1[0]) // scalar arm -> OTHER
  } else {
    print("OTHER")
  }
}
directScalarArm()

// Variant-box-arm-field spelling, ARRAY arm.
function variantBoxArrayArm() {
  const v: {f: (i32) => K0[] | i64} | f64 = {
    f: (_q0) => {
      const a: K0[] = ["bf"]
      return a
    },
  }
  const t0 = v
  if t0 is {f: (i32) => K0[] | i64} {
    const t1 = t0.f(1)
    if t1 is K0[] {
      print(t1[0]) // array arm -> bf
    } else {
      print("OTHER")
    }
  } else {
    print("F64")
  }
}
variantBoxArrayArm()

// The outer union's f64 arm still narrows.
function outerF64Arm() {
  const v: {f: (i32) => K0[] | i64} | f64 = 3.5
  const t0 = v
  if t0 is {f: (i32) => K0[] | i64} {
    print("STRUCT") // -> 3.5
  } else {
    print(t0)
  }
}
outerF64Arm()
