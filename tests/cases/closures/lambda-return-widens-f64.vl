// @run
// @log 5
// @log 7
// @log 2.5
// The f64 dual of `lambda-return-widens-i64.vl`: a small int literal at an f64-returning
// lambda's return seam widens to f64 (the contextual return adoption), AND the program
// interns the `__print_f64__` import from the `() => f64` ANNOTATION alone — the print
// scan matched only an exact `f64` annotation name, so a program whose only f64 mention
// was a closure type routed `print(v())` to the i32 print import (invalid wasm).

const v: () => f64 = () => (5)
print(v())

function useIt(p: () => f64) {
  print(p())
}
useIt(() => (7))

// A float-literal body keeps working (the body infers f64 natively).
const w: () => f64 = () => (2.5)
print(w())
