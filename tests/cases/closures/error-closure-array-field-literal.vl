// @emit-error closure-array struct-field literal is not supported
// A field-position lambda returning a struct whose FIELD is a closure-ARRAY
// literal (`{f: (i32) => {f: (() => i32)[]}}` fed `{f: [() => (265)]}`): the
// literal-side shape intern mis-codes the field as a BARE closure (code 14), so
// the built list WRAPPER stored into the `(ref $cloStruct)` slot — INVALID-WASM
// (fuzz-nightly seed 614405057 d6). `emitObj` now rejects a code-14 field
// receiving an ArrayLit loudly, matching the binding-position spelling's
// existing "ref valtype with no interned shape" reject. The NAMED-fn spelling
// (annotation-interned shape, field code 5) still lowers.
function makeIt(): {f: (i32) => {f: (() => i32)[]}} {
  return { f: (_q0) => ({ f: [() => (265)] }) }
}
function go() {
  const v: {f: (i32) => {f: (() => i32)[]}} = makeIt()
  print(0)
}
go()
// @hint Intentionally-unused parameter `_q0`
