function makeIt(): ((i32) => (() => f32 | null) | {w: i32}) | boolean {
  return (_q0) => (() => (null))
}
function makeW(): (i32) => (() => f32 | null) | {w: i32} {
  return (_q0) => ({ w: 7 })
}
