// @run
// @log 2
// @log 2
// @log 2
// @log 2
// @log 9
// A UNION-element callback: `.map`/`.filter` over a union array, and a higher-order function
// taking a `(Animal) => i32` callback. The un-annotated lambda param (`a`) is typed as the
// value union by contextual inference, so its `is`-narrowing works AND the closure `$fnsig`
// param token (kind 4 → `u`, the shared union box) interns the signature. All unions share
// one box and program-global variant tags, so the union param crosses the value-call ABI.

type Cat = { meow: i32 }
type Dog = { woof: i32 }
type Animal = Cat | Dog

// A higher-order function over a union-typed callback (annotated function type).
function count(f: (Animal) => i32, xs: Animal[]) {
  let n = 0
  let i = 0
  while i < xs.length {
    n = n + f(xs[i])
    i = i + 1
  }
  return n
}

function go() {
  const xs: Animal[] = [{ meow: 1 }, { woof: 2 }, { meow: 3 }, { woof: 9 }]

  // `.filter` over a union array preserves the element type (a union array result).
  const cats = xs.filter((a) => a is Cat)
  print(cats.length) // 2
  const dogs = xs.filter((a) => a is Dog)
  print(dogs.length) // 2

  // a higher-order callback narrowing the union to count cats (two cats in xs).
  print(count((a) => if a is Cat { 1 } else { 0 }, xs)) // 2
  print(count((a) => if a is Cat { 1 } else { 0 }, [{ meow: 1 }, { woof: 2 }, { meow: 3 }])) // 2

  // `.map` a union array to i32, narrowing per variant.
  const ns = xs.map((a) => if a is Cat { a.meow } else if a is Dog { a.woof } else { 0 })
  print(ns[3]) // 9
}
go()
