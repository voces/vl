// @run
// @log 7
// @log 5
// @log 99
// @log 60
// @log 0
// @log 9
// @log hi
// @log was-null
// A NULLABLE-ref-returning closure VALUE composes through an ARRAY element and a FACTORY return — the
// follow-up to #655 (which brought nullable closures to the BOUND + HOF positions). Two layers had to
// meet, both via the checker's type, mirroring the struct arc (#654):
//   - PRODUCER (the sig key): the closure-array element / factory binding type carries the full
//     `(i32)=>{x:i32}|null`, but `annSigKey` → `annRetKind` dropped the `|null` — `structIndexOfTypeName`
//     greedily matched the LEADING `{x:i32}` shape of `{x:i32}|null` as a bare struct (keying `>s` not
//     `>n`). Fixed by requiring a single shape to span the WHOLE name (its first `{`'s match is the last
//     char), so a composite falls through to the nullable case.
//   - CONSUMER (the result classification): `exprNullableStruct` / `exprNullableString` /
//     `structIndexOfExpr` missed an indexed-array closure callee, so the kind-9 / kind-16 binding
//     mis-classified and its `!= null` narrow lost the struct/string context. Each now falls back to the
//     checker's per-node type (`nodeTyIsNullableStruct` / `nodeTyIsNullableString` /
//     `nodeNulStructInnerName`) for a CALL — the nullable dual of #654's struct fallbacks.

type P = { x: i32 }

// A FACTORY whose return type is a nullable-struct-returning closure.
function mkP(): (i32) => P | null {
  return (n) => if n > 0 { { x: n } } else { null }
}

function go() {
  // Nullable-STRUCT closure in an ARRAY — direct field off the indexed call, and bound then narrowed.
  const g: (i32) => P | null = (n) => if n > 0 { { x: n } } else { null }
  const arr = [g]
  const a = arr[0](7)
  if a != null {
    print(a.x) // 7
  }
  const r = arr[0](5)
  if r != null {
    print(r.x) // 5
  }
  const r2 = arr[0](-1)
  if r2 == null {
    print(99) // 99
  }

  // A multi-element nullable-closure array.
  const h: (i32) => P | null = (n) => if n > 5 { { x: n * 10 } } else { null }
  const qs = [g, h]
  const q = qs[1](6)
  if q != null {
    print(q.x) // 60
  }
  const q2 = qs[1](2)
  if q2 == null {
    print(0) // 0
  }

  // A FACTORY-returned nullable-struct closure.
  const mk = mkP()
  const m = mk(9)
  if m != null {
    print(m.x) // 9
  }

  // Nullable-STRING closure in an array (the kind-16 niche dual).
  const s: (i32) => string | null = (n) => if n > 0 { "hi" } else { null }
  const ss = [s]
  const sr = ss[0](1)
  if sr != null {
    print(sr) // hi
  }
  const sr2 = ss[0](-1)
  if sr2 == null {
    print("was-null") // was-null
  }
}

go()
