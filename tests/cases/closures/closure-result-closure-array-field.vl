// @run
// @log 9.5
// @log 3.25
// The inner closures ignore their param `q`:
// @warning Unused parameter
// A closure-returning-closure reached through an ARRAY element and a struct FIELD, then
// called directly on the result — the holistic reach of the result-chain `$fnsig`
// synthesis (`collectCloSigs` walks every closure-returning lambda's checker type, so a
// lambda stored in an array / object literal is covered by the same lift + synth pass).
// Both the array-indexed `gs[0]()(1)` and the field `b.g()(1)` mint the inner `(i32) => f32`
// signature from the annotation key, matching the value call's `nodeTyName`-derived key.
type Box = { g: () => ((i32) => f32) }

const gs: (() => ((i32) => f32))[] = [() => ((q) => (9.5))]

function go() {
  print(gs[0]()(1))                                       // 9.5  — array element
  const b: Box = { g: () => ((q) => (3.25)) }
  print(b.g()(1))                                         // 3.25 — struct field
}
go()
