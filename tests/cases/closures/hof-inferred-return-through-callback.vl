// @run
// @log y
// @log z
// @log 7
// @log 1
// @log 5
// @log 0
// @log 5000000000
// @log 0.5
// @log pos
// `half`/`tag` return constants regardless of `n` (the result-kind is the probe):
// @warning Unused parameter `n`
// @warning Unused parameter `n`
// A higher-order function with an UN-ANNOTATED return whose value flows THROUGH the callback
// (`function applyN<T>(g: (T) => R, x: T) { return g(x) }`) takes the callback's return type `R` as
// its own. Previously the monomorphizer's "un-annotated return through a closure-pinned param"
// inference only resolved an f64 callback result (`>d`); every other result was missed — a UNION
// (`i32 | string`) callback result emitted INVALID WASM at the `is`-narrow, and a NULLABLE
// (`string | null`) result was a clean `??` reject. Now the instance pins its return to the
// callback's actual return type (extracted from the annotated function-type param `(i32)=>R`), so
// union / nullable / string / i64 results all lower and the caller's `is` / `??` classifies them.

// NULLABLE string result + `??`.
function maybeName(n: i32): string | null {
  if n > 0 { return "y" }
  return null
}
function applyN<T>(g: (T) => string | null, x: T) { return g(x) }

// UNION result + `is`-narrow (was invalid wasm).
function classify(n: i32): i32 | string {
  if n > 0 { return n }
  return "neg"
}
function applyU<T>(g: (T) => i32 | string, x: T) { return g(x) }

// STRUCT-UNION result + `is`-narrow.
type Cat = { meow: i32 }
type Dog = { bark: i32 }
function pick(n: i32): Cat | Dog {
  if n > 0 { return { meow: n } }
  return { bark: 0 - n }
}
function applyS<T>(g: (T) => Cat | Dog, x: T) { return g(x) }

// i32|null and i64|null results + `??`.
function maybeNum(n: i32): i32 | null {
  if n > 0 { return n }
  return null
}
function applyNum<T>(g: (T) => i32 | null, x: T) { return g(x) }
function bigOrNull(n: i32): i64 | null {
  if n > 0 { return 5000000000 }
  return null
}
function applyBig<T>(g: (T) => i64 | null, x: T) { return g(x) }

// f64 and plain-string results — the pre-existing f64 branch + a newly-enabled string result.
function half(n: i32): f64 { return 0.5 }
function applyF<T>(g: (T) => f64, x: T) { return g(x) }
function tag(n: i32): string { return "pos" }
function applyStr<T>(g: (T) => string, x: T) { return g(x) }

function go() {
  print(applyN(maybeName, 1) ?? "z") // y
  print(applyN(maybeName, 0) ?? "z") // z

  const r = applyU(classify, 7)
  if r is i32 { print(r) } // 7

  const s = applyS(pick, 1)
  if s is Cat { print(s.meow) } // 1

  print(applyNum(maybeNum, 5) ?? 0) // 5
  print(applyNum(maybeNum, 0) ?? 0) // 0
  print(applyBig(bigOrNull, 1) ?? 0) // 5000000000

  print(applyF(half, 3)) // 0.5
  print(applyStr(tag, 1)) // pos
}

go()
