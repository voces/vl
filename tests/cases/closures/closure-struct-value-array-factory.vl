// @run
// @log 7
// @log 5
// @log 3
// @log 6
// @log 40
// @log 4
// @log 9
// @log 8
// A STRUCT-returning closure VALUE composes through an ARRAY element and a FACTORY return — the call
// resolves its `$fnsig` and the struct result classifies for a field read. Both halves were missing:
//   - PRODUCER: the call-site sig key was re-derived by a per-position syntactic producer that fell
//     through for an indexed closure-array element (`arr[i](x)`) and a factory-inferred binding. It now
//     falls back to the callee's CHECKER type (`cloCallSigKey` → `nodeTyName` → `annSigKey`), and
//     `annSigKey` resolves a struct the checker rendered as an inline shape (`{x: i32}`) by field-set
//     (`structIndexOfTypeName`), so the key byte-matches the lambda's interned `i>sN;`.
//   - CONSUMER: `exprStruct` / `structIndexOfExpr` fell back to the checker's per-node type
//     (`nodeTyIsObj` / `nodeTyName`) for a struct-returning call whose callee they miss, so the binding
//     classifies kind-1 and the field read finds the layout.
// One mechanism (the checker's type), uniform across positions — not a per-position spot fix.

type P = { x: i32 }
type Q = { x: i32, y: i32 }

// A FACTORY: a function whose return type is a struct-returning closure.
function mkP(): (i32) => P {
  return (n) => { x: n }
}

function go() {
  // Struct closure in an ARRAY — direct field read off the indexed call.
  const g: (i32) => P = (n) => { x: n }
  const arr = [g]
  print(arr[0](7).x) // 7

  // …and bound first, then read (the binding must classify as a struct local).
  const p = arr[0](5)
  print(p.x) // 5

  // A multi-element array of multi-field struct closures.
  const a: (i32) => Q = (n) => { x: n, y: n * 2 }
  const b: (i32) => Q = (n) => { x: n * 10, y: n }
  const qs = [a, b]
  const qa = qs[0](3)
  const qb = qs[1](4)
  print(qa.x) // 3
  print(qa.y) // 6
  print(qb.x) // 40
  print(qb.y) // 4

  // A FACTORY-returned struct closure — direct field, and bound then read.
  const mk = mkP()
  print(mk(9).x) // 9
  const r = mk(8)
  print(r.x) // 8
}

go()
