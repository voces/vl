// @run
// @log 3
// @log 6
// @log 42
// A closure array crossing function BOUNDARIES — as a PARAMETER and as a RETURN value. The
// kind-5 ref-list wrapper passes by reference both directions, and an indexed element stays a
// callable closure on the far side.

function add1(n: i32) { return n + 1 }
function mul2(n: i32) { return n * 2 }

// PARAM: apply every function in the array to a threaded accumulator.
function applyAll(fs: ((i32) => i32)[], x: i32) {
  let acc = x
  let i = 0
  while i < fs.length {
    acc = fs[i](acc)
    i = i + 1
  }
  return acc
}
print(applyAll([add1, add1, add1], 0)) // 3   (0→1→2→3)
print(applyAll([add1, mul2], 2))       // 6   (2→3→6)

// RETURN: a factory yields a closure array; the caller indexes + calls it directly.
function makeFns(): ((i32) => i32)[] { return [add1, mul2] }
print(makeFns()[1](21)) // 42  (mul2(21))
