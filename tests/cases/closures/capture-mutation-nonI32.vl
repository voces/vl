// @run
// @log 7
// @log abc
// @log 5000000001
// @log 1.5
// @log 4
// Closure-captured MUTATION of a NON-i32 local — `let c = 0.0; const f = () => { c = c + 1.5 }`.
// `captureBoxRewrite` lowers a captured-mutated local to a shared length-1 list (`let c = [0.0]`,
// every use → `c[0]`); previously i32-only. Now any SCALAR-literal init boxes: the annotation is
// converted to its array form (`let c: f64` → `let c: f64[]`, so an `f32`/`i64` local builds the
// right list), the list type is collected (the second `collectA`), and the CLOSURE classifies the
// captured env field's list kind (`capturedKindOf` is now consulted by `exprF64Array`/`exprI64Array`/
// `exprF32Array`/`exprStringArray`). Also fixes `exprIsI64`'s Index case (it only saw an i64 MAP
// read, not an `i64[]` index) so the synthetic boxed `c[0]` reads as i64, not a widened i32.

function go() {
  // f64 accumulator (un-annotated — the `[0.0]` literal infers `f64[]`).
  let sum = 0.0
  const add = (x: f64) => {
    sum = sum + x
  }
  add(1.5)
  add(2.5)
  add(3.0)
  print(sum) // 7

  // string builder.
  let s = ""
  const app = (x: string) => {
    s = s + x
  }
  app("a")
  app("b")
  app("c")
  print(s) // abc

  // i64 (annotated — converted to `i64[]`; the `exprIsI64` Index fix makes the read i64).
  let n: i64 = 5000000000
  const bump = () => {
    n = n + 1
  }
  bump()
  print(n) // 5000000001

  // f32 (annotated — `f32[]` so the `[0.0]` literal builds f32, not the f64 default).
  let g: f32 = 0.0
  const incF = () => {
    g = g + 1.5
  }
  incF()
  print(g) // 1.5

  // two captured f64 vars mutated in one closure.
  let a = 0.0
  let b = 0.0
  const both = () => {
    a = a + 1.5
    b = b + 2.5
  }
  both()
  print(a + b) // 4
}

go()
