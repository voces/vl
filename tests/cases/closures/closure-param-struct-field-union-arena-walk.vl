// @run
// @log 7
// Regression (unified arena registration walk): a struct union `A | B` buried one
// STRUCT-FIELD level deep inside a CLOSURE PARAMETER type (`({f: A | B}) => i32`). The
// NAME walk descends a function-type annotation only into its RESULT, so neither the
// param struct `{f: A | B}` nor its field union `A | B` was registered → the closure
// param classified as an unsupported shape ("only i32, i64, f64, f32, boolean, struct,
// union, array, or string parameters are supported"). The arena walk descends
// structurally (TyFunc → param → TyObj field → TyUnion) and registers the field union,
// so the param lowers as a struct carrying a kind-16 union box and the narrowed read
// resolves. Off-corpus pin (closure-param nesting the name walk never reached).
type A = { a: i32 }
type B = { b: i32 }
function apply(cb: ({f: A | B}) => i32): i32 { return cb({ f: { a: 7 } }) }
function go() {
  const r = apply(
    (p) => {
      const x = p.f
      if x is A { return x.a }
      if x is B { return x.b }
      return -1
    },
  )
  print(r)
}
go()
