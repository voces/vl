// @run
// @log 1.5
// @log NULL
// @log 7
// @log hey
// @log 42
// @log 2.5
// @log NULL
// A closure whose RESULT is an array of NULLABLE scalar/string LISTS
// (`() => (f64[] | null)[]`), as a direct param and through a struct FIELD. The bare
// lambda `() => ([[1.5]])` self-classified a plain `f64[][]` reflist keyed on a
// DIFFERENT `$fnsig` slot than the annotation-side value call's `(…|null)[]` slot —
// divergent reflist tokens: a cast-failure TRAP; an all-`[null]` body missed the
// element seed entirely ("bare null needs a struct-typed context"). Fixed by the
// nulListElemListRetName adoption + recorder quadruple (`synthRetAnnots` pins via
// `parenUnionArrElemName`; the scalar-list sibling of nulStructElemListRetName /
// nulMapElemListRetName). The named-fn value spelling and the direct
// `(f64[]|null)[]` binding already lowered this nullable-inner-wrapper niche rep
// (`nullArrayArrElem`, kinds 4/6/7/8/10). Fuzz post-#1051 sweep GATING leg.
function useF(p: () => (f64[] | null)[]) {
  const t0 = p()[0]
  if t0 != null { print(t0[0]) } else { print("NULL") }
}

function useI(p: () => (i64[] | null)[]) {
  const t0 = p()[0]
  if t0 != null { print(t0[0]) } else { print("NULL") }
}

function useS(p: () => (string[] | null)[]) {
  const t0 = p()[0]
  if t0 != null { print(t0[0]) } else { print("NULL") }
}

function use32(p: () => (i32[] | null)[]) {
  const t0 = p()[1]
  if t0 != null { print(t0[0]) } else { print("NULL") }
}

function go() {
  // Distinct-backing f64 leaf: the fuzz draw's shape, non-null and all-null bodies.
  useF(() => ([[1.5]]))
  useF(() => ([null]))
  // i64 / string / i32 leaves share the pin (kinds 8 / 6 / 4 inners).
  useI(() => ([[7]]))
  useS(() => ([["hey"], null]))
  use32(() => ([null, [42]]))
  // Struct-FIELD position of the closure: the adopted lambda's `$fnsig` must match the
  // field annotation's slot too.
  const w: {a: () => (f64[] | null)[], z: i64} = {
    a: () => ([[2.5], null]),
    z: 3,
  }
  const t = w.a()[0]
  if t != null { print(t[0]) } else { print("NULL") }
  const u = w.a()[1]
  if u != null { print(u[0]) } else { print("NULL") }
}

go()
