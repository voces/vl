// @emit-error cannot yet be boxed into a variant-box union
// A MULTI-FIELD struct value from a CALL (a non-re-readable source with more than one
// field) returned into a variant-box union `{…} | scalar`: the value is built as the plain
// struct — a layout TWIN of but a DISTINCT type from the union arm's variant struct — so it
// must be REBUILT field-by-field (`emitStructExprAsVariantBox`), which re-emits the source
// once per field. A call cannot be re-emitted (its effects would fire again), and no scratch
// local is reserved to stash it, so this floors LOUDLY rather than boxing the raw plain ref
// (a runtime cast TRAP). The single-field call and the ident/re-readable multi-field paths
// ARE supported — see closures/closure-result-struct-arm-rebox.vl. Binding the call result to
// a local does not currently help (the union-annotated local mis-types from a struct init —
// a separate binding-classifier gap).
function mk3(): {a: i64, f: boolean, z: f64} {
  return { a: 7, f: true, z: 3.5 }
}
function go() {
  const v: (i32, i32, i32) => {a: i64, f: boolean, z: f64} | i32 = (_q0, _q1, _q2) => (mk3())
  const t0 = v(1, 1, 1)
  if t0 is {a: i64, f: boolean, z: f64} { print(t0.a) } else { print("OTHER") }
}
go()
