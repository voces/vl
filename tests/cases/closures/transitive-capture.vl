// @run
// @log hey!
// @log 11
// @log 3
// @log 21
// @log 16
// TRANSITIVE captures: a nested lambda reading a binding from a frame two-or-more
// levels up. `capScan` records a nested function's frees as captures of the ENCLOSING
// function too, and the env build reads a capture that is not a local of the enclosing
// frame from the enclosing frame's OWN env (`emitCaptureRead` -> `emitCapturedRead`) —
// so the value flows env-to-env down any nesting depth, for i32 / string / list /
// struct / f64 captures alike, with typing resolved at the OWNING frame's binding.
function mk(base: i32): () => (() => i32) { return () => (() => base + 1) }
function go() {
  const s = "hey"
  const xs = [1, 2, 3]
  const p = { x: 9 }
  const d = 2.5
  const f = () => (() => (() => s + "!"))
  print(f()()()) // hey! — a string capture through THREE frames
  const g = (n: i32) => (() => xs[n] + p.x)
  print(g(1)()) // 11 — list + struct captures, mixed with the outer lambda's param
  const h = () => (() => d + 0.5)
  print(h()()) // 3 — an f64 capture
  print(mk(20)()()) // 21 — a PARAM captured through two frames
  const z = 5
  const two = () => {
    const inner1 = () => z + 1
    const inner2 = () => z * 2
    return inner1() + inner2()
  }
  print(two()) // 16 — two sibling closures sharing one transitive capture
}
go()
