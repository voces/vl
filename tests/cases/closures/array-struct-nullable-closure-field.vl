// @run
// @log hptf
// An array of structs whose field `f` is a NULLABLE closure `(() => string) | null`. Reading the
// field, narrowing `f != null`, then CALLING it must dispatch `print` on the string result via the
// string path — not `__print_i32__`. The classifier `exprString` resolves a Member/Index-inferred
// closure local's call result the SAME way the `call_ref` lowering does (`cloCallSigKey` +
// `sigKeyRetKind`), so the two agree; pre-fix `exprString` said i32 and `print` emitted
// `__print_i32__` on a `(ref $string)` → invalid wasm. (rep-fuzz p0r
// `{a: string, f: (() => string) | null, z: boolean}[]`.)
function go() {
  const v: {a: string, f: (() => string) | null, z: boolean}[] = [
    {a: "dx", f: () => ("hptf"), z: true},
  ]
  const t0 = v[0].f
  if t0 != null {
    print(t0())
  } else {
    print("NULL")
  }
}
go()
