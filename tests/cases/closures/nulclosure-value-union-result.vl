// @run
// @log NIL
// @log 42
// @log OTHER

// An OUTER closure returning a NULLABLE CLOSURE whose INNER closure returns a VALUE UNION
// (`() => (() => i32 | boolean) | null`). The inner union (`i32 | boolean`) appears ONLY inside
// the nullable-closure result type, so it registers through `registerInlineUnion`'s
// nulclosure arm (peel the `| null` + grouping parens, recurse on the bare closure — its RETURN
// registers through the function-type arm), minting `uBoxIdx` so the null-narrowed inner call's
// `>u` box result reads back. Every arm is live below: the null draw, and both union members
// through the box. (rep-fuzz: `p3r () => (() => i32 | boolean) | null` was a `value-union
// closure RESULT is not yet representable` reject — the CASE-A floor, `>u` with no interned box.)

const g: () => (() => i32 | boolean) | null = () => (null)
const h: () => (() => i32 | boolean) | null = () => (() => (42))
const b: () => (() => i32 | boolean) | null = () => (() => (true))

function readIt(v: () => (() => i32 | boolean) | null) {
  const t0 = v()
  if t0 != null {
    const t1 = t0()
    if t1 is i32 { print(t1) } else { print("OTHER") }
  } else {
    print("NIL")
  }
}

function go() {
  readIt(g)
  readIt(h)
  readIt(b)
}

go()
