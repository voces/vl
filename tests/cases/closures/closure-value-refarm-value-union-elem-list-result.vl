// Regression: a closure VALUE returning a list whose element is a union mixing a
// VALUE-union-element ARRAY arm with a scalar arm — `() => ((i32|boolean)[] | i32)[]`.
// The element union boxes each arm as `{tag, payload}` (the array arm `(i32|boolean)[]` — a
// union-element list, itself the kind-2 box list — rides the box's anyref `value` as a REF
// atom; the scalar arm boxes its value). The named-function-VALUE spelling (`= mk`) and the
// direct binding always lowered this box soundly, but an anonymous lambda `() => ([77])`
// self-classified its body as a plain `i32[]` reflist keyed on a DIFFERENT `$fnsig` slot than
// the annotation-side value call's box-list slot — the `call_ref` `ref.cast` to the box sig
// TRAPPED (cast failure). Fix: `elemRefArmValueUnionListRetName` classifies this element-list
// shape (a `TyArray` whose element is a union with a value-union-element-array arm + scalar
// siblings — what `variantBoxUnionRetName` / `refArmUnionRetName` decline), and the lambda-
// return cascade adopts + records it so `synthRetAnnots` pins `fnRet` via `parenUnionArrElemName`.
// The union-element-array sibling of `elemValueUnionListRetName`.
// @run
// @log OTHER
// @log 77
// @log 1
// @log E1SCALAR
function useScalarArm() {
  // The draw spelling: a `[77]` body whose element takes the scalar i32 arm.
  const v: () => ((i32 | boolean)[] | i32)[] = () => ([77])
  const t0 = v()[0]
  if t0 is (i32 | boolean)[] { print("ARR") } else { print("OTHER") }
  const u1: (i32 | boolean)[] | i32 = 77
  if u1 is i32 { print(u1) } else { print("UOTHER") }
}
function useBothArms() {
  // A mixed body exercising BOTH element arms: `[1,2]` boxes the array arm, `3` the scalar.
  const v: () => ((i32 | boolean)[] | i32)[] = () => ([[1, 2], 3])
  const arr = v()
  const e0 = arr[0]
  if e0 is (i32 | boolean)[] {
    const x = e0[0]
    if x is i32 { print(x) } else { print("BX") }
  } else {
    print("E0SCALAR")
  }
  const e1 = arr[1]
  if e1 is (i32 | boolean)[] { print("E1ARR") } else { print("E1SCALAR") }
}
function go() {
  useScalarArm()
  useBothArms()
}
go()
