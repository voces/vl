// Regression: a closure value returning a NULLABLE variant-box union whose struct arm
// carries a LIST field and a CLOSURE field (`() => {a: i64[], f: {f: string},
// z: () => f64} | i32 | null`). `vbUnionMemberName`'s field loop declined both, so
// the `() => (77)` lambda never adopted the expected union — it returned the RAW i32
// where the value call expected the box: INVALID-WASM (fuzz post-#993 sweep branching
// leg, seed 3496995 case_00249). TyArray/TyFunc fields now render canonically, the
// list/closure siblings of the map/nested-struct/nullable admissions.
// @run
// @log OTHER
function go() {
  const v: () => {a: i64[], f: {f: string}, z: () => f64} | i32 | null = () => (77)
  const t0 = v()
  if (t0 != null) {
    const t1 = t0
    if t1 is {a: i64[], f: {f: string}, z: () => f64} {
      print(t1.f.f)
    } else {
      print("OTHER")
    }
  } else {
    print("NULL")
  }
}
go()
