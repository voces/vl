// Regression: a closure / function-value whose result RETURNS the STRUCT arm of a
// variant-box union `{…} | scalar` — as an IDENT binding or a single-field CALL result,
// NOT an object literal. The struct value is BUILT as the plain struct (its own interned
// heap type, a LAYOUT TWIN of but a DISTINCT type from the union arm's variant struct —
// the `sHeapIdx`/`uVarHeap` tables never cross-dedup), so boxing the raw ref emitted
// invalid wasm (an IDENT source: the box local wanted the variant struct) or a RUNTIME
// cast TRAP (a CALL source that boxed the plain ref, then the narrow's `ref.cast
// (ref $variant)` failed). `emitStructExprAsVariantBox` now re-boxes a struct-typed union
// arm by rebuilding the variant struct field-by-field from the source (source & variant
// share the layout, so each field read is store-compatible), then tag + box. Found while
// pinning #1002 (the pin there returns the SCALAR arm, so the struct arm never boxed at
// runtime). Object-literal returns (`=> ({w: 1})`) already worked via `emitUnionBoxAs`.
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// @hint Intentionally-unused parameter `_q2`
// @hint Intentionally-unused parameter `_q3`
// @hint Intentionally-unused parameter `_q4`
// @hint Intentionally-unused parameter `_q5`
// @hint Intentionally-unused parameter `_q6`
// @hint Intentionally-unused parameter `_q7`
// @hint Intentionally-unused parameter `_q8`
// @run
// @log 42
// @log 7
// @log true
// @log 3.5
// @log 99
function mk1(): {w: i32} { return { w: 42 } }
function go() {
  // (a) single-field CALL result returned from a closure — was a RUNTIME cast trap.
  const v1: (i32, i32, i32) => {w: i32} | i32 = (_q0, _q1, _q2) => (mk1())
  const a = v1(1, 1, 1)
  if a is {w: i32} { print(a.w) } else { print("OTHER1") }
  // (b) multi-field struct bound to a local then returned — was invalid wasm (ident).
  const v2: (i32, i32, i32) => {a: i64, f: boolean, z: f64} | i32 = (_q3, _q4, _q5) => {
    const s = { a: 7, f: true, z: 3.5 }
    return s
  }
  const b = v2(1, 1, 1)
  if b is {a: i64, f: boolean, z: f64} {
    print(b.a)
    print(b.f)
    print(b.z)
  } else {
    print("OTHER2")
  }
  // (c) the SCALAR arm still rides the box correctly (the original pin's live path).
  const v3: (i32, i32, i32) => {w: i32} | i32 = (_q6, _q7, _q8) => (99)
  const c = v3(1, 1, 1)
  if c is {w: i32} { print(c.w) } else { print(c) }
}
go()
