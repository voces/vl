// @run
// @log 2.5
// @log true
// @log nil
// @log 3.5
// @hint Intentionally-unused parameter

// A PLAIN closure array element whose RESULT is a value union with null
// (`((i32) => f64 | boolean | null)[]`): the indexed call's result is the union BOX —
// `exprUnion`'s indexed-closure-call arm (`cloArrCallRetKind == "union"`) classifies the
// binding as the box ref (the checker net records the null-carrying union
// nullable-shaped, so the sig-derived kind is authoritative), and each arm narrows via
// `is` / `== null` exactly as the annotated-binding form does. The rebind spelling
// (`const v = xs[0]; v(4)`) resolves the same element `$fnsig` through
// `identFnTypeAnnName`'s kind-5 Index arm. (rep-fuzz: `p0r
// ((i32) => f64 | boolean | null)[]` was an emit reject.)

function go() {
  const xs: ((i32) => f64 | boolean | null)[] = [
    (_q) => 2.5,
    (_q) => true,
    (_q) => null,
  ]
  const r = xs[0](1)
  if r is f64 { print(r) }
  const s = xs[1](2)
  if s is boolean { print(s) }
  const t = xs[2](3)
  if t == null { print("nil") }
  const v = xs[0]
  const w = v(4)
  if w is f64 { print(w + 1.0) }
}
go()
