// @log 2.25
// A closure RESULT struct whose FIELD is a MAP-member union
// (`(i32) => {f: {[string]: f64} | i64}`): `registerInlineUnion`'s
// functype-return descent registers the field union in `collectU`
// (`registerShapeFieldUnions`), so `funcTypeShapeLowerable` admits the code-16
// box field (`isUName`) and the result shape interns — the value-call result's
// field access resolves the struct and the field's `is` narrow reads either arm.
// The i64 arm widens the small literal into the box; the map arm boxes the
// captured map and the narrowed read chains into the fused get.
function makeIt(): (i32) => {f: {[string]: f64} | i64} {
  return (q0) => ({ f: 5000000077 })
}
function makeMapArm(): (i32) => {f: {[string]: f64} | i64} {
  const h: {[string]: f64} = Map()
  h["k"] = 2.25
  return (q0) => ({ f: h })
}
function readIt(v: (i32) => {f: {[string]: f64} | i64}) {
  const t0 = v(1).f
  if t0 is {[string]: f64} { print(t0["k"] ?? 14.5) } else { print("OTHER") }
}
function go() {
  readIt(makeIt())
  readIt(makeMapArm())
}
