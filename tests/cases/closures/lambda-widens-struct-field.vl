// @run
// @log 5
// @log 5
// @log 5
// @log 1
// @log 5
// @log true
// @log 5
// @log 5
// @log 6000000000
// A SMALL int literal into a WIDE struct field through a LAMBDA context
// (`const v: () => {f: i64} = () => ({f: 5})`): the lambda's return shape is interned from
// its LITERAL (`anonFieldCode` — no annotation to read), which coded the small literal's
// field i32 while the contextual annotation demanded i64 — invalid wasm in the body. Fix:
// the checker's FIELD-LEVEL contextual return adoption (`objRetWidenAdopt`, the object dual
// of the scalar `() => i64 = () => (5)` rule) adopts the expected shape when every widening
// field is a re-encodable int literal, recording the wide type on the literal node — the
// interner and the value emit both honor it. Covers expr- and block-bodied lambdas, f64
// fields, multi-field shapes, the call-arg position, and a closure array mixing an adopted
// small literal with a magnitude literal. (Each shape uses a DISTINCT field-name set —
// two same-name-set shapes with different scalar reps is a separate, pre-existing
// interning limitation, a loud reject.)
function take(cb: () => {f: i64}): i64 {
  const r = cb()
  return r.f
}

const v: () => {f: i64} = () => ({f: 5})
print(v().f)

const vb: () => {f: i64} = () => {
  return {f: 5}
}
print(vb().f)

const vd: () => {g: f64} = () => ({g: 5})
print(vd().g)

const vm: () => {a: i32, f: i64, z: boolean} = () => ({a: 1, f: 5, z: true})
const rm = vm()
print(rm.a)
print(rm.f)
print(rm.z)

print(take(() => ({f: 5})))

const fs: (() => {f: i64})[] = [() => ({f: 5}), () => ({f: 6000000000})]
print(fs[0]().f)
print(fs[1]().f)
