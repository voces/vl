// @run
// @log NULL
// @log 2.25
// @log NULL
// @log 9
// The inner closures ignore their params (they probe the ABI, not the arg):
// @warning Unused parameter
// A NULLABLE closure whose RESULT is itself a closure or struct — the rep-fuzz p2r/p3r
// family this graduates:
//   (a) `(() => ((i32) => f32)) | null` — a nulclosure returning a closure, chained
//       value-called `t0()(1)` after the `!= null` narrow.
//   (b) `((i32) => (() => {a: i64, f: i32, z: f64})) | null` — a nulclosure returning a
//       closure whose OWN result is a struct, chained `t0(1)().f`.
// The `| null`-only intern above mints only the OUTER `$fnsig` (its result collapsed to the
// shared `>c` fat-pointer), so the CHAINED value call on the narrowed result found no
// interned sig for the INNER closure — "function-value call arity has no interned signature"
// (and, for (b), the deep struct shape was never interned: "field access but no struct type
// declared"). `collectCloSigs` now walks the nulclosure annotation's RESULT spine
// (`internNulCloResultSpine`, struct results admitted) and `internShapeDeep` /
// `internFuncTypeShapes` peel ONLY a truly-wrapping paren pair — so a functype whose leading
// `(` is its own param list no longer garbles the name and its buried result shapes intern.
// Each binding carries the `| null` annotation (non-redundant: a bare `null` / lambda init
// infers only `null` / the non-null closure) so the narrow drives the chained value call.
// Exercised in both the null draw (the fuzzer's isNull carriers, printing NULL) and a live
// non-null draw (the real chained result).
function go() {
  const a0: (() => ((i32) => f32)) | null = null
  if a0 != null {
    print(a0()(1)) // NULL
  } else {
    print("NULL")
  }

  const a1: (() => ((i32) => f32)) | null = () => ((x) => (2.25))
  if a1 != null {
    print(a1()(1)) // 2.25
  } else {
    print("NULL")
  }

  const b0: ((i32) => (() => {a: i64, f: i32, z: f64})) | null = null
  if b0 != null {
    print(b0(1)().f) // NULL
  } else {
    print("NULL")
  }

  const b1: ((i32) => (() => {a: i64, f: i32, z: f64})) | null = (x) => (() => ({ a: 4, f: 9, z: 1.5 }))
  if b1 != null {
    print(b1(1)().f) // 9
  } else {
    print("NULL")
  }
}

go()
