// Regression (was the #1005 @emit-error floor, now FULL support): a MULTI-FIELD struct
// value from a CALL — a NON-re-readable source (a call cannot be re-evaluated once per
// field) — coerced into a variant-box union `{…} | scalar`. The value is built as the plain
// struct (a layout TWIN of but a DISTINCT type from the union arm's variant struct), so it
// must be REBUILT field-by-field (`emitStructExprAsVariantBox`). The call result is now
// stashed ONCE in a reserved `(ref null struct)` scratch slot (`variantReboxSlot`) and each
// field re-reads it via `ref.cast (ref $plainStruct)`; #1005 could only floor this loudly.
// Covers the closure-RESULT position (a) and the call-ARGUMENT position (b); the single-
// field / re-readable-ident / scalar-arm twins are in
// closures/closure-result-struct-arm-rebox.vl.
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// @hint Intentionally-unused parameter `_q2`
// @run
// @log 7
// @log 3.5
// @log 7
// @log 3.5
// @log 99
function mk3(): {a: i64, f: boolean, z: f64} {
  return { a: 7, f: true, z: 3.5 }
}
function take(x: {a: i64, f: boolean, z: f64} | i32) {
  if x is {a: i64, f: boolean, z: f64} {
    print(x.a)
    print(x.z)
  } else {
    print("TAKEOTHER")
  }
}
function go() {
  // (a) a closure whose result returns the MULTI-FIELD CALL directly.
  const v: (i32, i32, i32) => {a: i64, f: boolean, z: f64} | i32 = (_q0, _q1, _q2) => (mk3())
  const t0 = v(1, 1, 1)
  if t0 is {a: i64, f: boolean, z: f64} {
    print(t0.a)
    print(t0.z)
  } else {
    print("OTHER")
  }
  // (b) a MULTI-FIELD CALL directly into a union call ARGUMENT.
  take(mk3())
  // (c) the scalar arm still rides the box correctly.
  print(99)
}
go()
