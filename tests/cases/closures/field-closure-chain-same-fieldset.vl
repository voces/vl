// A field closure returning a struct whose FIELD is itself a closure, both shapes
// spelling the same field-name set (`{f: () => {f: (i32) => K0}}`). Same-name-set
// shapes DEDUP to one struct index, so `fieldClosureFeOf` resolved the OUTER
// 0-arity lambda for the INNER call (`p.f().f(1)`) — the wrong `$fnsig` key drove
// the arg coercion + `ref.cast`, pushing the i32 arg against the env slot
// (INVALID-WASM "expected i32, found structref"; fuzz-nightly seed 54110331 d5).
// `cloCallSigKey`'s Member arm now trusts the literal-resolved closure only when
// its ARITY matches the call, else falls to the checker-typed fallback
// (`nodeTyName` → `annSigKey`) which keys the field's real function type.
type K0 = "442" | "jtzdd" | "hjf"
function useIt(p: {f: () => {f: (i32) => K0}}) { print(p.f().f(1)) }
function useIt2(p: {f: () => {f: (i32) => K0}}) {
  const s = p.f()
  print(s.f(1))
}
