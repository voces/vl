// @hint Intentionally-unused parameter `_p`
function useIt(_p: () => {a: string, f: {f: {[string]: {f: i64}}}, z: f32}) {
  print(0)
}
function makeIt(): () => {a: string, f: {f: {[string]: {f: i64}}}, z: f32} {
  return () => {
    const h: {[string]: {f: i64}} = Map()
    h["k"] = { f: 9 }
    return { a: "s", f: { f: h }, z: 1.5 }
  }
}
function go() {
  const h0: {[string]: {f: i64}} = Map()
  h0["k"] = { f: 74727 }
