// @run
// @log 6000000000
// @log 6000000000
// @log 6000000000
// @log 7
// @log 6000000000
// @log 1.5
// A lambda returning a struct with an i64 (or i64[]/f64[]) field. The lambda's return
// shape is inferred from its LITERAL (`anonFieldCode` — no annotation to read), and the
// i64-magnitude leaf coded the field i32: the body `struct.new`ed an i64 operand into an
// i32 field (invalid wasm in the expr-bodied form; the block-bodied form broke at the
// CALL side, reading the field as i32). A NAMED function's annotated return shape already
// coded 23 via `fieldTypeCode` — the value-based and annotation-based field-code
// enumerations had drifted on the scalar leaves. (Each case uses a distinct field name:
// literals resolve shapes by field-name set.)
const vExpr: () => {f: i64} = () => ({f: 6000000000})
const vBlock: () => {g: i64} = () => {
  return {g: 6000000000}
}
const vMulti: () => {a: boolean, h: i64, z: i32} = () => ({a: true, h: 6000000000, z: 7})
const vList: () => {q: i64[]} = () => ({q: [6000000000]})
const vF64List: () => {w: f64[]} = () => ({w: [1.5]})

function go() {
  print(vExpr().f)
  print(vBlock().g)
  const m = vMulti()
  print(m.h)
  print(m.z)
  print(vList().q[0])
  print(vF64List().w[0])
}
go()
