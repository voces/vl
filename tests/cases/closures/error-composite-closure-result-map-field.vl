// @emit-error ref valtype with no interned shape
// A closure returning a struct whose field is a typed-value MAP (`{[string]: f32}`,
// R1) must stay a CLEAN reject, never invalid wasm. `internShapeDeep`'s functype-shape
// recursion interns a functype's result/param inline shapes so a plain composite result
// (`(i32) => {f: i32}`) lowers — but ONLY a plainly-lowerable shape (scalar / string /
// scalar-list / nested-struct fields). A map / value-union / nullable-list field
// (`funcTypeShapeLowerable` false) leaves the shape un-interned, so the closure result
// has no interned shape and fails loudly here rather than emitting a broken f32-map
// value type into the module. (The map-value-in-composition rep is R1.)
function go() {
  const v: () => {m: {[string]: f32}} = () => ({m: Map()})
  print(0)
}
go()
