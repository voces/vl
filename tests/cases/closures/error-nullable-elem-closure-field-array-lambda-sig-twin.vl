// @emit-error list element has no rep
// A LAMBDA whose result is a ref-list of a NULLABLE struct with a CLOSURE-ONLY field
// (`() => ({f: () => string} | null)[]`): the nullable-struct-element list is a deferred
// rep composition. Since `structElemFieldsPlain` admits a CLOSURE field, the element pins
// through `nulStructElemListRetName`, and the nullable list-element lowering rejects cleanly
// with "a nullable-{…} list element has no rep; use a non-null element type" (was
// `cloCallReflistElemTwin`'s call-site floor before the closure-field admission — both are
// clean loud REJECTs, never a trap). The DIRECT array binding
// (`const v: ({f: () => string} | null)[] = […]`) lowers fully, and a nullable element
// struct with a MAP field beside the closure (`{a, f: {[string]: f64}, z: () => f64} | null`)
// now lowers fully too. rep-fuzz post-#1029, seed 361 case_00011 (multiobs leg p0r).
function go() {
  const v: () => ({f: () => string} | null)[] = () => ([{ f: () => ("frb") }])
  const t0 = v()[0]
  if (t0 != null) { print(t0.f()) } else { print("NULL") }
}
go()
