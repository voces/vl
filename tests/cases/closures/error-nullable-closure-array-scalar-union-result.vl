// @emit-error value-union closure RESULT is not yet representable
// A closure whose result is a NULLABLE value union with a CLOSURE-ARRAY arm:
// `(() => string | null)[] | i32 | null`. The non-null spelling (`(…)[] | i32`) already
// rejects as "not yet representable" (its `>u` box is never interned), but the outer `| null`
// wraps the union in TyNullable and interns the box on the annotation side, slipping the
// un-interned check — so the value call `v()` then TRAPPED at the callee `ref.cast` (the
// producer lambda `() => (77)` self-inferred an i32-result functype, not the union box). A
// param-fed closure has no producer to verify, and the closure-array composite arm is the
// deferred value-union-result hole, so the nullable spelling now rejects cleanly in every
// spelling (the nullable-union analysis routes through the same scalar+composite test as the
// direct spelling). Fuzz sweep wo7cNe declared backlog (pre-existing).
function makeIt(): () => (() => string | null)[] | i32 | null {
  return () => (77)
}
function go() {
  const v: () => (() => string | null)[] | i32 | null = makeIt()
  const t0 = v()
  if t0 is i32 { print(t0) } else { print("OTHER") }
}
go()
