// @run
// @log 822
// @log OTHER
// A FIELD-position contextual lambda whose result is a litunion+struct union
// (`{f: (i32) => K0 | {w: i32}}`) — the full-support graduation of the old loud
// reject. Three seams compose: the union registers from the shape annotation's
// closure-field RETURN (`registerShapeFieldUnions` no longer skips closure
// fields), the checker's `variantBoxUnionRetName` regroups the flattened
// litunion members back into the alias so `synthRetAnnots` pins the lambda, and
// `unionHasValueAtom` counts the litunion-ALIAS atom so the return coerce boxes
// the member string as the K0 atom instead of passing it RAW into the box
// result. Both arms verified: the litunion member narrows via `is K0` and the
// struct arm falls through.
type K0 = "zltp" | "822"
function go() {
  const v: {f: (i32) => K0 | {w: i32}} = { f: (_q0) => ("822") }
  const t0 = v.f(1)
  if t0 is K0 { print(t0) } else { print("OTHER") }
  const w: {f: (i32) => K0 | {w: i32}} = { f: (_q1) => ({ w: 77 }) }
  const u0 = w.f(1)
  if u0 is K0 { print(u0) } else { print("OTHER") }
}
go()
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
