// @run
// @log 7
// The VALUE-CALL side of a closure whose RESULT is an ARRAY of a VALUE UNION
// (`() => (i64 | boolean)[]`). The lambda body's array literal (`[7]`) self-infers the plain
// element list (`i64[]`), so the value call recovered a plain scalar list and the element read
// mismatched the union-box element rep (INVALID-WASM: i64 vs i32). The checker now ADOPTS the
// value-union-box list at the lambda return boundary (`elemValueUnionListRetName`) and
// `synthRetAnnots` pins the lambda's `fnRet` to it (`parenUnionArrElemName`), so `emitReturnValue`
// boxes each element through the element-kind-2 rep — the value-union sibling of the element-
// nullable list path, and identical to the annotated `(i64 | boolean)[]` / named-value form.
function go() {
  const v: () => (i64 | boolean)[] = () => ([7])
  const t0 = v()
  const e = t0[0]
  if e is i64 { print(e) } else { print("OTHER") }
}
go()
