// @run
// @log 32741.5
// @log 2
// @log 45.5
// A closure returning an array of structs with a MAP field and a MAP-ARRAY field
// (`() => {a: {[string]: f64 | null}, b: i64, z: {[string]: f32}[]}[]`) — the tFpE3l draw's
// sibling fields at a single nesting level. Un-admitted, the map / map-array field declined
// `structElemFieldsPlain`, so the whole struct-element list was never pinned and the
// un-pinned lambda mis-keyed the element heap type. `structElemFieldsPlain` now admits a
// (nameable) map field and a map-element list field — the reps the annotated named-fn
// spelling already lowers.
function h0(): {[string]: f64 | null} {
  const m: {[string]: f64 | null} = Map()
  m["k"] = 32741.5
  m
}
function h1(): {[string]: f32} {
  const m: {[string]: f32} = Map()
  m["k"] = 45.5
  m
}
const v: () => {a: {[string]: f64 | null}, b: i64, z: {[string]: f32}[]}[] = () => ([{ a: h0(), b: 1, z: [h1()] }, { a: h0(), b: 2, z: [h1()] }])
function go() {
  print(v()[0].a["k"] ?? 0.0)
  print(v()[1].b)
  print(v()[0].z[0]["k"] ?? 0.0)
}
go()
