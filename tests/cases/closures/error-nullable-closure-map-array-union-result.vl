// @emit-error value-union closure RESULT is not yet representable
// A NULLABLE closure whose result is a scalar+composite value union with a MAP-ARRAY arm
// (`{[string]: f32}[] | f64`). The DIRECT binding of such a union already rejects as "not
// yet representable" (its `>u` box is never interned), but the `| null` wrapper interns the
// box on the annotation side, slipping the un-interned check — so the narrowed call
// `t0(1,1,1)` then TRAPPED at the `is {[string]:f32}[]` cast (the closure VALUE carried the
// bare f64 arm, not the box). A param-fed closure has no producer to verify, and the
// map-array composite arm is the deferred value-union-result hole (struct/closure/scalar-
// list/struct-list arms all rep fine), so it now rejects cleanly in every spelling.
// Fuzz sweep wo7cNe branching, seed 565560412 (p1r).
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// @hint Intentionally-unused parameter `_q2`
function useIt(p: ((i32, i32, i32) => {[string]: f32}[] | f64) | null) {
  const t0 = p
  if (t0 != null) {
    const t1 = t0(1, 1, 1)
    if (t1 is {[string]: f32}[]) {
      print(t1[0]["k"] ?? 15.5)
    } else {
      print("OTHER")
    }
  } else {
    print("NULL")
  }
}
function go() { useIt((_q0, _q1, _q2) => (9.25)) }
go()
