// @run
// @log 40
// @log 20
// @log 16
// `for f in fs` over a CLOSURE array (`((i32) => i32)[]`) — and over a function-valued map's
// `.values()`. The for-in element-kind dispatch handled struct / union / nested-list / scalar
// ref-list elements but not a CLOSURE element (ref-list kind 5), nor a closure map VALUE, so both
// fell to "unsupported for-in iterable". The loop var now binds a kind-14 closure (recovered
// non-null like a struct element, the `#l` temp the ref-list wrapper), callable via `call_ref`.

function go() {
  // a closure array — call each element.
  const fs: ((i32) => i32)[] = [(x) => x + 1, (x) => x * 2, (x) => x - 1]
  let t = 0
  for f in fs { t = t + f(10) }
  print(t) // 11 + 20 + 9 = 40

  // CAPTURING closures in an array (each closes over `a`).
  const a = 100
  const gs: ((i32) => i32)[] = [(x) => x + a, (x) => x - a]
  let u = 0
  for g in gs { u = u + g(10) }
  print(u) // 110 + (-90) = 20

  // a function-VALUED map's `.values()`.
  const m: {[string]: (i32) => i32} = Map()
  m["a"] = (x) => x + 1
  m["b"] = (x) => x * 2
  let v = 0
  for h in m.values() { v = v + h(5) }
  print(v) // 6 + 10 = 16
}
go()
