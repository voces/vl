// @run
// @log 2
// @log 6
// @log 21
// @log 3
// @log 2
// @log 25
// An UN-annotated lambda argument to a GENERIC higher-order function — `mapArr([1,2,3], (x) => x * 2)`
// where `mapArr<T,R>(xs: T[], f: (T) => R)` — now infers the lambda's param from the bound type param.
//
// The checker's call-site contextual inference seeded the lambda arg with the param's type RAW
// (`(T) => R`), so `x` stayed a `TyVar` — the monomorphizer then had no concrete type to pin (`x` is
// un-annotated, and `nodeTyName` renders "" for a type var). Now the seed SUBSTITUTES the type-param
// bindings accumulated from earlier args (`T = i32` from `xs`) first, so `x` infers `i32`; the emitter's
// `monoArgFnTypeName` reads the resulting concrete `(i32) => i32` from the checker to pin the instance.
// (Builds on the closure-value `.map`/`.filter` callback support — the monomorphized body is `xs.map(f)`
// over a closure param.)

function mapArr<T, R>(xs: T[], f: (T) => R): R[] { return xs.map(f) }
function filterArr<T>(xs: T[], p: (T) => boolean): T[] { return xs.filter(p) }
function applyTwice<T>(x: T, f: (T) => T): T { return f(f(x)) }

function go() {
  const a = mapArr([1, 2, 3], (x) => x * 2) // [2,4,6]
  print(a[0]) // 2
  print(a[2]) // 6

  const b = mapArr([10, 20], (x) => x + 1) // [11,21]
  print(b[1]) // 21

  const c = filterArr([1, 2, 3, 4], (x) => x > 2) // [3,4]
  print(c[0])                                     // 3
  print(c.length)                                 // 2

  print(applyTwice(5, (n) => n + 10)) // 25
}

go()
