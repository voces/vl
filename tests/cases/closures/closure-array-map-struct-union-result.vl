// Regression: an annotated closure-array whose element RESULT is a union with a
// MAP-FIELD struct arm (`((i32, i32, i32) => {f: {[string]: string}} | boolean)[]`).
// The lambda `fnRet` pin declined the map-field struct member (`vbUnionMemberName`
// rendered only prim/litunion-alias fields), so RETURN-position lambdas emitted raw
// arm-typed `$fnsig`s while the value call cast to the `>u` box sig — a cast-failure
// TRAP (fuzz sweep2 multiobs leg, seed 655720167 case_00209). The member render now
// admits map fields via the canonical `tyToEmitName` spelling.
// @run
// @log OTHER
// @log false
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// @hint Intentionally-unused parameter `_q2`
function makeIt(): ((i32, i32, i32) => {f: {[string]: string}} | boolean)[] {
  const h3: {[string]: string} = Map()
  h3["k"] = "zdmy"
  return [
    (_q0, _q1, _q2) => (false),
    (_q0, _q1, _q2) => ({ f: h3 }),
    (_q0, _q1, _q2) => ({ f: h3 }),
    (_q0, _q1, _q2) => ({ f: h3 }),
  ]
}
function go() {
  const v: ((i32, i32, i32) => {f: {[string]: string}} | boolean)[] = makeIt()
  const t0 = v[0](1, 1, 1)
  if t0 is {f: {[string]: string}} {
    const t1 = t0.f["k"] ?? "zdmy"
    print(t1)
  } else {
    print("OTHER")
  }
  const u0: {f: {[string]: string}} | boolean = false
  if u0 is boolean { print(u0) } else { print("UOTHER") }
}
go()
