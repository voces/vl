// @run
// @log OTHER
// @log 7
// @log ZSTR
// @log 42
// @log OTHER
// A closure returning an ARRAY whose element is a variant-box union
// `{z: string | i32} | i64` — the struct arm carries a VALUE-UNION field
// (`z: string | i32`). `vbUnionMemberName`'s TyObj field loop had no TyUnion arm
// (prim / litunion / map / nested-struct / nullable / list / closure fields were all
// admitted, a value-union field fell to the decline `else`), so `variantBoxUnionRetName`
// declined the element and the closure never adopted the union-array result: its body
// `() => ([5000000077])` self-inferred `i64[]` and returned a raw i64-list wrapper while
// the value call cast the funcref to the ref-list `$fnsig` — a cast-failure TRAP.
// Fixed by admitting a value-union field via `tyToEmitName` (the sibling of the map /
// nested-struct / nullable / list / closure field admissions; the inner `|` is
// brace-scoped exactly like the `{f: i64|null}` nullable arm). The annotated named-fn
// spelling of such a union already lowered fully. Fuzz sweep hPjUJh branching leg,
// seed 117044659 case_00365.
function go() {
  // The i64 arm value: `is Struct` must be FALSE (was a cast-failure trap).
  const v: () => ({z: string | i32} | i64)[] = () => ([5000000077])
  const t0 = v()[0]
  if t0 is {z: string | i32} { print("STRUCT") } else { print("OTHER") }

  // The struct arm value with the value-union field read + field narrow (i32 then string).
  const vi: () => ({z: string | i32} | i64)[] = () => ([{ z: 7 }])
  const ti = vi()[0]
  if ti is {z: string | i32} {
    const zz = ti.z
    if zz is i32 { print(zz) } else { print("ZSTR") }
  } else {
    print("OTHER")
  }

  const vs: () => ({z: string | i32} | i64)[] = () => ([{ z: "hi" }])
  const ts = vs()[0]
  if ts is {z: string | i32} {
    const zz = ts.z
    if zz is i32 { print(zz) } else { print("ZSTR") }
  } else {
    print("OTHER")
  }

  // The drawn inner 3-arm value-union field `z: string | {w: i32} | {q: i64}`, struct value.
  const vw: () => ({z: string | {w: i32} | {q: i64}} | i64)[] = () => ([{ z: { w: 42 } }])
  const tw = vw()[0]
  if tw is {z: string | {w: i32} | {q: i64}} {
    const zw = tw.z
    if zw is {w: i32} { print(zw.w) } else { print("NOTW") }
  } else {
    print("OTHER")
  }

  // The drawn inner 3-arm shape with the i64 arm value: `is Struct` FALSE.
  const vq: () => ({z: string | {w: i32} | {q: i64}} | i64 | {q: i64})[] = () => ([5000000077])
  const tq = vq()[0]
  if tq is {z: string | {w: i32} | {q: i64}} {
    print("STRUCT")
  } else {
    print("OTHER")
  }
}
go()
