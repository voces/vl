// @run
// @log NULL
// @log 42
// @log OTHER
// A NULLABLE-closure param whose result is a MIXED litunion+composite+scalar
// union (`(() => K0 | {w: i32} | f64 | null) | null`) fed by contextual
// lambdas — the full-support graduation of the old loud reject. The union
// registers through the nulclosure annotation's variant-box recursion, the
// checker's flattened-lit regroup records it, `synthRetAnnots` pins each lambda,
// and every arm round-trips: null param, litunion-arm producer (narrowed via
// `is K0`), and the f64 arm falling to OTHER.
type K0 = "pd" | "42"
function useIt(p: (() => K0 | {w: i32} | f64 | null) | null) {
  const t0 = p
  if t0 != null {
    const t1 = t0()
    if t1 != null {
      const t2 = t1
      if t2 is K0 { print(t2) } else { print("OTHER") }
    } else {
      print("INNERNULL")
    }
  } else {
    print("NULL")
  }
}
function go() {
  useIt(null)
  useIt(() => ("42"))
  useIt(() => (2.5))
}
go()
