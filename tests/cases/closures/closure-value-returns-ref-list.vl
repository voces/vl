// @run
// @log 9
// @log 14
// @log 2
// @log 5
// @log 8
// A closure VALUE whose result is a REF LIST (`() => S[]`) — the closure-call `$fnsig` ABI now
// mints a `>r<slot>;` RESULT token (the dual of the `r<idx>;` struct-list PARAM token), so calling
// the value yields the ref-list wrapper. Previously kind-5 results were left un-minted: a closure
// value returning one rejected at the soundness floor (`cloRetValSlot`/`cloRetKeySuffix` had no
// ref-list case), and the underlying inferred-return classifier even MISCOMPILED a closure-array
// literal (fixed in the prior PR). Now the AST and annotation sig producers both key the result by
// the element ref-list slot (`cloRetKeySuffix` / `annSigKey`, byte-matching), the functype emits
// `fbValtype(5, slot)`, and a closure-value call result resolves as a ref list (`exprRefArray` /
// `refListElemNameOfExpr` read the slot off the callee's sig) — so it indexes both bound and
// directly.

type S = { v: i32 }

function go() {
  const mk: () => S[] = () => [{ v: 5 }, { v: 9 }]

  // DIRECT call result — index + field, and `.length`.
  print(mk()[1].v) // 9

  // BIND the result, then index, for-in, and length.
  const xs: S[] = mk()
  let t = 0
  for s in xs { t = t + s.v }
  print(t) // 5 + 9 = 14
  print(xs.length) // 2
  print(xs[0].v) // 5

  // a closure value built over a captured value, returning the list.
  const base = 3
  const mk2: () => S[] = () => [{ v: base + 5 }]
  print(mk2()[0].v) // 8
}

go()
