// @run
// @log OTHER
// @log mv
// A UNION carrying a CLOSURE whose result is a struct-with-map
// (`(() => {f: {[string]: string}}) | string`): the closure arm's functype
// interner (`internShapeArms` → `internFuncTypeShapes`) reaches the result
// shape, whose code-19 map field is admitted — so the narrowed arm's value-call
// result read chains into the map (`t0().f["k"] ?? d`). Both arms: the string
// carrier narrows to OTHER; the closure carrier calls through and reads the map.
function mk(): {f: {[string]: string}} {
  const h: {[string]: string} = Map()
  h["k"] = "mv"
  return { f: h }
}
function useIt(p: (() => {f: {[string]: string}}) | string) {
  const t0 = p
  if t0 is () => {f: {[string]: string}} {
    print(t0().f["k"] ?? "zdmy")
  } else {
    print("OTHER")
  }
}
function go() {
  useIt("other")
  const c: () => {f: {[string]: string}} = mk
  useIt(c)
}
go()
