// @run
// @log b
// @log 8
// @log dltj
// @log ok
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// A lambda whose body is a struct literal ADOPTS an expected struct return whose
// field is a LITERAL-UNION (`(i32) => {p: K0}` with `p: "b"`): the body infers the
// softened `string` field, but the literal is a MEMBER of the litunion and re-encodes
// as its i32 atom at the return seam — the field dual of the scalar litunion-return
// arm (`(i32) => K = (x) => "b"`). `objRetWidenAdopt` records the litunion field type
// so the emitter interns the atom slot, and `synthRetAnnots` pins the whole struct as
// the functype result — the SAME rep the named-function-value spelling (`= mk`) lowers.
// (Field names are kept DISTINCT per struct so the returns do not collide in the
// emitter's shape / value-call-signature interner — a pre-existing limitation.)
type K0 = "b" | "z"

function onlyLitField() {
  const v: (i32) => {p: K0} = (_q0) => ({p: "b"})
  print(v(1).p)
}

// The litunion field alongside a WIDENING f32 field and a plain i32 field.
type K1 = "xz" | "8"

function litFieldWithF32() {
  const v: (i32) => {aa: f32, bb: K1, cc: i32} = (_q0) => ({aa: 3.5, bb: "8", cc: 11})
  const s = v(1)
  print(s.bb)
}

// A litunion field inside a struct whose other fields are f64 / i64.
type K2 = "260" | "dltj" | "r"

function litFieldWide() {
  const v: (i32) => {dd: f64, ee: K2, ff: i64} = (_q0) => ({dd: 3.5, ee: "dltj", ff: 6000000000})
  print(v(1).ee)
}

// A litunion field alongside a boolean field + string field (no numeric widening).
type K3 = "yes" | "no"

function litFieldMixed() {
  const v: (i32) => {gg: boolean, hh: K3, ii: string} = (_q0) => ({gg: true, hh: "yes", ii: "ok"})
  print(v(1).ii)
}

onlyLitField()
litFieldWithF32()
litFieldWide()
litFieldMixed()
