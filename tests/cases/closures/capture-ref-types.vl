// @run
// @log 5
// @log 42
// @log -1
// @log 9
// @log 7
// A closure CAPTURING a STRING, a NULLABLE struct, or a struct-UNION variable, then using its
// captured type inside the body. The env field already carried the real ref valtype, but the
// expression classifiers consulted only param / local / global bindings — not a captured one —
// so `s.length` read as a struct field, `p != null` as struct equality, and `a is Cat` as a
// non-union. `exprString` / `exprNullableStruct` / `exprUnion` now consult `capturedKindOf`, and
// `unionNameOfIdent` resolves a captured union's member set from the parent binding
// (`capturedUnionName`). Captured struct / array values already worked. (A captured VALUE union
// `i32 | string` narrowed-atom read stays a clean reject — the unbox off the env isn't wired.)

type P = { x: i32 }
type Cat = { meow: i32 }
type Dog = { bark: i32 }
type Animal = Cat | Dog

function go() {
  // capture a STRING — `.length` and `+` work.
  const s = "hello"
  const slen = () => s.length
  print(slen()) // 5

  // capture a NULLABLE struct — narrow with `!= null`, read the field.
  const p: P | null = { x: 42 }
  const pf = () => if p != null { p.x } else { -1 }
  print(pf()) // 42
  const q: P | null = null
  const qf = () => if q != null { q.x } else { -1 }
  print(qf()) // -1

  // capture a struct-UNION (inline) — narrow with `is`.
  const a: Cat | Dog = { meow: 9 }
  const af = () => if a is Cat { a.meow } else { 0 }
  print(af()) // 9

  // capture a union ALIAS, narrowed in the else-if arm.
  const b: Animal = { bark: 7 }
  const bf = () => if b is Cat { b.meow } else if b is Dog { b.bark } else { 0 }
  print(bf()) // 7
}
go()
