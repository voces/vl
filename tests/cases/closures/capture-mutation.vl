// @run
// @log 2
// @log 10
// @log 1
// @log 1
// @log 2
// @log 3
// A closure that MUTATES a captured local. Closures capture by VALUE (the env copies each
// captured local), so `c = c + 1` inside a closure had no slot and failed at emit ("assignment
// target is not a parameter, local, or global"). A pre-monomorphization AST rewrite boxes a
// captured-mutated local as a shared LENGTH-1 ARRAY: `let c = 0` → `let c = [0]`, and every use
// of `c` → `c[0]`, so the closure's `c[0] = c[0] + 1` writes into the shared array, visible in
// the maker (arrays are already capturable + index-assignable through a closure). Conservative:
// only a direct, unshadowed `let` with an i32 integer init is boxed.

function go() {
  // the canonical counter.
  let c = 0
  const inc = () => {
    c = c + 1
  }
  inc()
  inc()
  print(c) // 2

  // an accumulator over a parameter.
  let total = 0
  const add = (n: i32) => {
    total = total + n
  }
  add(3)
  add(7)
  print(total) // 10

  // two closures sharing one captured cell.
  let shared = 0
  const up = () => {
    shared = shared + 1
  }
  const downTwice = () => {
    shared = shared - 1
    shared = shared - 1
  }
  up()
  up()
  up()
  downTwice()
  print(shared) // 3 - 2 = 1
}
go()

// a closure FACTORY: the captured cell outlives the maker (heap-allocated), so successive
// calls of the returned closure keep incrementing the same counter.
function counter(): () => i32 {
  let n = 0
  return () => {
    n = n + 1
    return n
  }
}

function go2() {
  const next = counter()
  print(next()) // 1
  print(next()) // 2
  print(next()) // 3
}
go2()
