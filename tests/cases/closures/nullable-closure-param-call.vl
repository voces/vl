// @run
// @log hi
// @log NULL
// @hint Intentionally-unused parameter `_q0`
// A NULLABLE-closure param `((i32) => string) | null` (kind 19): narrow with `!= null`, then call
// the recovered closure. The read binds an intermediate `const t0 = p` (the nullable-read pattern),
// so the callee sig — and thus the CALL RESULT type used for print routing — is recovered by
// chasing the copy to its source param (`identCopySource` → `paramCloSigKey` → `cloNameSigKey`
// peels `| null` + the grouping parens to `(i32) => string`, key `>S`). Pre-fix the string result
// printed via `__print_i32__` — invalid wasm.
function useIt(p: ((i32) => string) | null) {
  const t0 = p
  if t0 != null { print(t0(1)) } else { print("NULL") }
}

function go() {
  useIt((_q0) => ("hi"))
  useIt(null)
}

go()
