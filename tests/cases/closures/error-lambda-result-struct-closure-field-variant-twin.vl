// @emit-error a lambda field value resolved to a non-closure field slot
// A LAMBDA whose result is a struct `{f: () => …}` whose closure field returns a
// variant-box union (`{f: string} | string`): the outer `{f: <closure>}` shares its
// fieldset `{f}` with the union's STRUCT arm `{f: string}` and — un-interned as its own
// struct (the deferred same-fieldset twin-matcher composition) — routes through the
// union-box path, which would store the closure ref into a string field (INVALID-WASM
// before this floor: `struct.new` of `{f: string}` fed a closure ref). The named-fn
// spelling (`function mk(): {f: () => …}`) lowers fully. rep-fuzz post-#1029, seed 4118
// case_00372 (declared leg p0c). Since the anonymous-shape variant-collapse gate, the
// inner closure's `{f: string}` result no longer mis-collapses to the union arm, so the
// floor is the generic non-closure-field-slot reject (still loud) rather than the
// variant-field-slot one.
function go() {
  const v: () => {f: () => {f: string} | string} = () => ({ f: () => ({ f: "082" }) })
  print(0)
}
go()
