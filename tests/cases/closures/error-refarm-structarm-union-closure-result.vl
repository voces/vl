// @emit-error value-union closure RESULT is not yet representable
// @hint Intentionally-unused parameter `_q0`
// A closure whose result is a COMPOSITE-ONLY variant-box union — a ref-LIST arm beside a
// STRUCT arm (`(f32 | string)[] | {w: i32}`): the union reps as the `{tag, value}` box
// (`>u`), but the lambda body returns only the list arm (`(_q0) => (["other"])`), so it
// self-infers the bare string-list `>A` sig. The value carries `>A` while the narrowed call
// casts to `>u` — an iso-recursive twin cast TRAP. `cloCallUnionResultUnrepresentable` now
// rejects composite-ONLY unions too (not just the scalar+composite mix) when the concrete
// PRODUCER's sig is a non-union arm: the deferred #938/#875 ref-arm+struct-arm value-union
// closure-result composition (repOf-rewrite scope) stays a clean loud REJECT, never a trap.
// A `Cat | Dog` variant union (both arms rep as the variant tag) and a producer that ADOPTS
// the box are unaffected. rep-fuzz post-#1029 (plain gating leg, seed 12638454 case_00127).
function go() {
  const v: (i32) => (f32 | string)[] | {w: i32} = (_q0) => (["other"])
  const t0 = v(1)
  if (t0 is (f32 | string)[]) {
    const t1 = t0[0]
    if (t1 is f32) { print(t1) } else { print("OTHER") }
  } else {
    print("OTHER")
  }
}
go()
