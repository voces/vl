// @run
// @log 1.5
// @log 2.5
// @log 6000000000
// @log 4.5
// @log hey
// @hint Intentionally-unused parameter `_x`
// A closure RESULT / PARAM shape with a STRUCT-element list field
// (`() => {f: {f: f64}[]}`, `({p: {g: f64}[]}) => f64`): `funcTypeShapeLowerable`
// admits a code-5 field whose element is itself a lowerable struct
// (`structElemArrayLowerable` — a declared plain struct name or an inline shape
// that recursively lowers), and `internFuncTypeShapes` pre-interns the inline
// element shape (`internShapeFieldElems`) so the shape's code-5 field records its
// element name and the `collectA` field pass interns the ref-list slot. The
// closure result then has an interned shape and the chained read lowers.
// Un-admitted element sorts (union / nullable-struct / 2-D struct arrays)
// stay loud rejects ("ref valtype with no interned shape").
// Field names are DISTINCT per shape — an anonymous object literal matches its
// interned shape by field-name SET.
const v: () => {f: {f: f64}[]} = () => ({ f: [{ f: 1.5 }] })
const t = v()
print(t.f[0].f)
// A NAMED struct element.
type S = {g: f64}
const nv: () => {h: S[]} = () => ({ h: [{ g: 2.5 }] })
print(nv().h[0].g)
// A block-bodied lambda; a wide-i64 leaf through the struct-list field.
const bv: (i32) => {k: {w: i64}[]} = (_x) => {
  return { k: [{ w: 6000000000 }] }
}
print(bv(0).k[0].w)
// A closure PARAM whose shape carries the struct-list field.
const pv: ({p: {q: f64}[]}) => f64 = (r) => (r.p[0].q)
print(pv({ p: [{ q: 4.5 }] }))
// A mixed-field result shape (decoy scalar siblings around the list field).
const mv: () => {a: i32, f: {s: string}[], z: f64} = () => ({ a: 1, f: [{ s: "hey" }], z: 2.5 })
print(mv().f[0].s)
