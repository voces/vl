// @run
// @log 200
// @log 2
// @log 62321678167
// @log 1.5
// @log q
// @log 4
// @log true
// @log 7
// A closure whose RESULT is a nested scalar-leaf array (`() => i64[][]`, `(i32) =>
// f64[][]` / `string[][]` / `i32[][]`) and a closure result STRUCT with a 2-D field
// (`(i32) => {f: boolean[][]}`). Three seams compose:
//   1. the checker ADOPTS the contextual nested-list return (`nestedLeafListRetName`)
//      and `synthRetAnnots` pins the lambda's `fnRet`, so the body literal builds under
//      the return-position threading (i64 leaves widen at the store) and both `$fnsig`
//      producers key the SAME reflist slot;
//   2. a SELF-classified nested literal keys its element by its LEAF (`arrLitElemKind`
//      6/7/8 for string/f64/i64 inners — an i64-magnitude leaf `[[62321678167]]`
//      previously keyed `i32[]` while its inner built the i64 wrapper: wrapper-heap
//      mismatch, INVALID WASM at fuzz seed 314159, `p3c/p3r () => i64[][]`);
//   3. `funcTypeShapeLowerable` accepts a code-5 field whose type is a nested
//      scalar-leaf array (`{f: boolean[][]}` — `nameIsNestedScalarLeafArray`), so the
//      result shape interns (was "ref valtype with no interned shape").
// (rep-fuzz R4: p2c/p2r `(i32) => {f: boolean[][]}` + the `() => i64[][]` landmine.)

const g: () => i64[][] = () => ([[62321678167]])

function makeIt(): (i32) => { f: boolean[][] } {
  return (x: i32) => ({ f: [[true, false]] })
}

function go() {
  // Local closure, small i64 leaves: the pin threads the i64 inner build.
  const f: () => i64[][] = () => [[100], [200]]
  const v = f()
  print(v[1][0]) // 200
  print(v.length) // 2

  // Global closure, i64-magnitude leaf (the seed-314159 invalid-wasm spelling).
  print(g()[0][0]) // 62321678167

  // f64 / string / i32 leaves.
  const ff: () => f64[][] = () => [[1.5]]
  print(ff()[0][0]) // 1.5
  const fs: () => string[][] = () => [["q"]]
  print(fs()[0][0]) // q
  const fi: (i32) => i32[][] = (n: i32) => [[n]]
  print(fi(4)[0][0]) // 4

  // Closure-result struct with a 2-D field, read at both depths.
  const mk = makeIt()
  const r = mk(1)
  print(r.f[0][0]) // true
  r.f.push([false])
  print(r.f.length + 5) // 7
}
go()
