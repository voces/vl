// @run
// @log 0
// @log 3.5
// A contextual lambda returning nested structs that SHARE a field-name set —
// outer `{a: f32, f: …}` vs nested `{a: f64, f: {f: f64 | null}}` — with a
// nullable leaf field. `structFieldBoxRetName`'s blanket TyNullable-field decline
// left the lambda UN-pinned, and the un-pinned return resolution collapsed onto
// the wrong same-name-set struct: the outer `a: f32` literal emitted as f64 into
// the f32 slot — INVALID-WASM (fuzz seed 103465585 d6, p2c
// `(i32) => {a: f32, f: {a: f64, f: {f: {f: f64 | null}}, z: string}, z: i32}`).
// The nullable field now records as box-bearing (prim/literal/object inners), so
// `synthRetAnnots` pins the lambda through the proven annotated-form path.
function go() {
  const v: (i32) => {a: f32, f: {a: f64, f: {f: f64 | null}}} = (_q0) => ({ a: 3.5, f: { a: 2.5, f: { f: 410.0 } } })
  print(0)
  const r = v(1)
  print(r.a)
}
go()
// @hint Intentionally-unused parameter `_q0`
