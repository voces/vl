function makeIt(): {a: (i32, i32, i32) => {a: i32[], f: (i32, i32, i32) => string, z: K1}, f: {a: {f: i64}, f: (i32, i32, i32) => K0, z: f32} | null} {
  return {
    a: (_q6, _q7, _q8) => ({ a: [2], f: (_q3, _q4, _q5) => ("46"), z: "br" }),
    f: { a: { f: 3 }, f: (_q0, _q1, _q2) => ("246"), z: 485.5 },
