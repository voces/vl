// @run
// @log false
// @log 99
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q0`
// The VALUE-CALL side of a closure whose RESULT is a STRUCT with a UNION/NULLABLE FIELD
// (`(i32) => {f: boolean | {w: i32}}`, `(i32) => {f: i64 | string}`). The lambda body's ObjLit
// (`{f: false}` / `{f: 99}`) self-infers the PLAIN field shape (`{f: boolean}` / `{f: i32}`), so
// the value call recovered the plain struct — a MISMATCH (`t0(1).f is boolean` read the wrong tag,
// printing OTHER instead of `false`) or INVALID-WASM (an i64 field read where an i32 was stored).
// The checker now ADOPTS the annotated union-field struct at the lambda return boundary
// (`objRetWidenAdopt`'s boxing-widen arm) and `synthRetAnnots` pins the lambda's `fnRet` to the
// canonical union-field struct (`structFieldBoxRetName` → `nameIsStructWithUnionField`), so its
// `$fnsig` result is the boxed-field struct and `emitReturnValue` boxes the body ObjLit — exactly
// as the annotated named-function form already lowers.

// A struct-MIXED union field (`boolean | {w: i32}`), narrowed through an OUTER closure|boolean union
// (the reported MISMATCH — printed OTHER before the fix).
function makeIt(): ((i32) => {f: boolean | {w: i32}}) | boolean {
  return (_q0) => ({ f: false })
}
function goMismatch() {
  const v: ((i32) => {f: boolean | {w: i32}}) | boolean = makeIt()
  const t0 = v
  if t0 is (i32) => {f: boolean | {w: i32}} {
    const t1 = t0(1).f
    if t1 is boolean { print(t1) } else { print("OTHER") }
  } else {
    print("OTHER")
  }
}

// A VALUE-union field (`i64 | string`) — the representative INVALID-WASM shape.
function goStructUnionField() {
  const v: (i32) => {f: i64 | string} = (_q0) => ({ f: 99 })
  const t0 = v(1)
  if t0.f is i64 { print(t0.f) } else { print("OTHER") }
}

goMismatch()
goStructUnionField()
