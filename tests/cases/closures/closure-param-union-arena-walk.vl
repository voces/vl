// @run
// @log 5
// Regression (unified arena registration walk): a struct union `A | B` that appears
// ONLY in a CLOSURE PARAMETER type (`(A | B) => i32`) — never in a direct
// param/return/let/field annotation. The union-collection NAME walk
// (`collectInlineUnionsIn` → `registerInlineUnion`) descends a function-type
// annotation ONLY into its RESULT (`(i32) => C | S` registers the result union), never
// into its PARAMS, so `A | B` was never registered → the lambda's `x is A` narrow saw
// no union box and `x.a` emit-failed ("field access receiver is not a struct"). The
// arena walk (`collectTyReachRegister`) descends the resolved param type structurally
// (TyFunc → param → TyUnion) and registers it, so the union box, the `is` dispatch, and
// the field reads all lower. Off-corpus pin — this closure-param nesting position does
// not occur in the rest of the corpus, so the name walk alone left it uncovered.
type A = { a: i32 }
type B = { b: i32 }
function apply(cb: (A | B) => i32): i32 { return cb({ a: 5 }) }
function go() {
  const r = apply(
    (x) => {
      if x is A { return x.a }
      if x is B { return x.b }
      return -1
    },
  )
  print(r)
}
go()
