// Regression: a NULLABLE-closure field buried inside a NESTED struct field
// (`a: {f: (() => {a: i64, f: i64, z: i64}) | null, ...}`). `internShapeFieldCloSigs`
// split only the OUTER shape's depth-0 fields, so the inner closure field's `$fnsig`
// (`() => {a,f,z}`) never interned. With no producer for that closure (`f: null`)
// but SOME lambda present elsewhere (`g` below, flipping `fnValUsed`), the narrowed
// `v.a.f()` `ref.cast`ed to a sig that never existed and fell to the i32-arity
// fallback — an i32 result stored where the ref/i64 result was expected: INVALID-WASM
// (fuzz 6NuCoq multiobs leg, seed 17245159 case_00127). Fix: `internShapeFieldCloSigs`
// recurses into single-shape (nullable-peeled) struct fields. Un-annotated bare-lambda
// spelling of the outer shape's `z` closure interns via its own producer.
// @run
// @log 7
// @log NULL
function makeIt(): {a: {a: f64, f: (() => {a: i64, f: i64, z: i64}) | null, z: string}} {
  return { a: { a: 2.5, f: null, z: "dx" } }
}
function go() {
  const g = () => (7)
  print(g())
  const v: {a: {a: f64, f: (() => {a: i64, f: i64, z: i64}) | null, z: string}} = makeIt()
  const t220 = v.a.f
  if (t220 != null) { print(t220().f) } else { print("NULL") }
}
go()
