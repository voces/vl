// @run
// @log x
// @log 5
// GRADUATED (was @emit-error "ref valtype with no interned shape"): a closure result
// struct whose LIST FIELD's element is a VALUE-UNION / VARIANT-BOX union
// (`() => {f: (A | string)[]}`). The element rides the union `{tag, payload}` box — the
// rep the annotated named-fn spelling already lowers — so `structElemFieldsPlain` now
// admits a box-element-union list field and `structPlainRetName` pins the lambda. The
// STILL-un-supported boundary (a named-struct arm built from an ANONYMOUS obj literal in a
// MIXED closure body, or a DEEP-nested composite) stays a loud reject — see
// closure-result-value-union-field-nested-composite-floor.vl.
type A = {w: i32}
const v: () => {f: (A | string)[]} = () => ({ f: ["x"] })
function mk(): {f: (A | string)[]} { return { f: [{ w: 5 }] } }
function go() {
  const e0 = v().f[0]
  if (e0 is string) { print(e0) } else { print("NS") }
  // The struct arm read is exercised on the named-fn VALUE spelling (already lowered).
  const w: () => {f: (A | string)[]} = mk
  const e1 = w().f[0]
  if (e1 is A) { print(e1.w) } else { print("NA") }
}
go()
