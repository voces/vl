// The null-valued and boolean-backed variants of the code-18 nullable-scalar-list
// closure-result field (sibling of closure-result-nullable-scalar-list-field). A bare
// closure `() => {f: <list> | null}` returning `null` for the list, plus a
// `boolean[] | null` backing (the other i32-backed nullable scalar list `nameFieldCode`
// codes 18) — both interned via `funcTypeShapeLowerable`. Before the code-18 admission
// the sig never interned ("function-value call arity has no interned signature").
// @run
// @log NULL/true
function mkNull(): () => {f: i32[] | null} { return () => ({ f: null }) }
function mkBool(): () => {g: boolean[] | null} {
  return () => ({ g: [true, false] })
}
function go() {
  const vn: () => {f: i32[] | null} = mkNull()
  const rn = vn()
  let out = ""
  if rn.f != null { out = out + "SOME" } else { out = out + "NULL" }
  out = out + "/"
  const vb: () => {g: boolean[] | null} = mkBool()
  const rb = vb()
  const gb = rb.g
  if gb != null {
    if gb[0] { out = out + "true" } else { out = out + "false" }
  } else {
    out = out + "NONE"
  }
  print(out)
}
go()
