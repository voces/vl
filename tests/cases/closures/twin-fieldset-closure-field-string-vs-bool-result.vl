// @run
// @log 66
// @log 4709.5
// @log false
// A declared struct whose fields `f` and `z` are BOTH `{f: closure}` structs (same fieldset
// `{f}`, closure field) differing ONLY in the closure RESULT type: `f`'s returns `string`,
// `z`'s returns `boolean`. The two `{f: closure}` structs are LAYOUT-identical (both a single
// closure fat-pointer field), so they collapse to one wasm heap type — correct at the layout
// level, but `fieldClosureFeOf` then resolved `p.z.f`'s closure by fieldset-match and aliased
// onto `f`'s STRING lambda. `p.z.f(1,1,1)` call-cast correctly to the boolean functype (i32
// result), but `exprString` claimed the result was a string, so `print` routed it through the
// string path and stored the raw i32 into a string-array local — INVALID-WASM ("expected
// (ref $type), found i32"). `exprString`'s member-closure arm now trusts the CHECKER's
// recorded result type (boolean, kind 0) over the fieldset-matched fe. Fuzz sweep wo7cNe
// declared, seed 172658796 (p0r).
// @hint Intentionally-unused parameter `_q0`
// @hint Intentionally-unused parameter `_q1`
// @hint Intentionally-unused parameter `_q2`
// @hint Intentionally-unused parameter `_q3`
// @hint Intentionally-unused parameter `_q4`
// @hint Intentionally-unused parameter `_q5`
type T0 = {
  a: {a: boolean, f: f32, z: i64} | f64,
  f: {f: (i32, i32, i32) => string},
  z: {f: (i32, i32, i32) => boolean},
}
function useTwin(p: T0) {
  print(p.f.f(1, 1, 1))
  const t200 = p.a
  if t200 is {a: boolean, f: f32, z: i64} {
    print(t200.f)
  } else {
    print("OTHER")
  }
  print(p.z.f(1, 1, 1))
}
function go() {
  const w: T0 = {
    a: { a: true, f: 4709.5, z: 6000000000 },
    f: { f: (_q0, _q1, _q2) => ("66") },
    z: { f: (_q3, _q4, _q5) => (false) },
  }
  useTwin(w)
}
go()
