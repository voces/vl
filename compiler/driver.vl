}
// The whole module pipeline behind `compileSrc` (emit = 1) / `checkSrc` (0).
function modCompile(emit: i32): i32 {
  // 1. Order + validate (DFS from the entry, table index 0).
  modState = []
  modOrder = []
  modDiags = []
  let s = 0
  while s < modKeys.length {
    modState.push(0)
    s = s + 1
  }
  modVisit(0)
  if modDiags.length > 0 {
    let d = 0
    while d < modDiags.length {
      P.diags.push({ msg: modDiags[d], at: -1 })
      d = d + 1
    }
    return 1
  }
  // 2. Parse each module dependency-first into the SHARED arena. Tokens append
  // to `P.toks` (anchors stay per-module-correct via the global `pos`); each
  // `parseProgram` starts at its own module's first token.
  const roots: i32[] = []
  modLoadStart = []
  modLoadMod = []
  let o = 0
  while o < modOrder.length {
    const m = modOrder[o]
    P.pos = P.toks.length
    // Record where this module's tokens begin so an occurrence's token maps back
    // to its module (`modOfTok`) for cross-file find-references.
    modLoadStart.push(P.toks.length)
    modLoadMod.push(m)
    vcLoadToks(modSrcs[m])
    roots.push(parseProgram())
    if P.diags.length > 0 { return 1 }
    o = o + 1
  }
  // 2b. Duplicate-binding check: a top-level declaration whose name collides
  // with an import local would be silently ORPHANED by the merge rename (the
  // import mapping wins, so every reference rewrites to the IMPORT's target) —
  // diagnose the collision instead of misbinding.
  let dc = 0
  while dc < modOrder.length {
    modCheckDupBindings(modOrder[dc], roots[dc])
    dc = dc + 1
  }
  if P.diags.length > 0 { return 1 }
  // 3 + 4. Per-module rename map + scope-aware arena rewrite. First register
  // every top-level `self`-function under its mangled name (across ALL modules)
  // so a UFCS member-call can resolve its (possibly mangled) callee through the
  // merge; the rewrite records the plain→mangled aliases it discovers.
  ufcsAliasReset()
  modCollectSelfFns(roots)
  let o2 = 0
  while o2 < modOrder.length {
    modBuildRename(modOrder[o2], roots[o2])
    modShadow = []
    modTyShadow = []
    modRwStmt(roots[o2])
    o2 = o2 + 1
  }
  // 4b. Resolve each RE-EXPORT's public name to its merged (mangled) target — the
  // exporting module renamed its `name` to `name$mDD`, so a re-export `export { name }
  // from "dep"` aliases the bare `name` onto that target in the emitter's export
  // section. The re-export rode in as an import (same module + local binding), so the
  // target is its `impName$m<depIndex>`.
  reExpName = []
  reExpTarget = []
  let re = 0
  while re < reExpMod.length {
    const rm = reExpMod[re]
    const rloc = reExpLocal[re]
    let ii2 = 0
    let done = false
    while ii2 < impMod.length && !done {
      if impMod[ii2] == rm && impLocal[ii2] == rloc && impName[ii2] != "" {
        const dd = modIndexOfKey(impKey[ii2])
        if dd >= 0 {
          reExpName.push(reExpPublic[re])
          reExpTarget.push(impName[ii2] + "$m" + i32ToStr(dd))
