    const tySaved = modTyShadow.length
    // The function's generic type parameters are live across its annotations
    // and body — segments naming them must not rewrite (see `modTyShadow`).
    let ti = 0
    while ti < n.fnTyParams.length {
      modTyShadow.push(n.fnTyParams[ti])
      ti = ti + 1
    }
    let pi = 0
    while pi < n.fnParams.length {
      const p = P.nodes[n.fnParams[pi]]
      if p is Param {
        modShadow.push(p.parName)
        modRwType(p.parType)
      }
      pi = pi + 1
    }
    modRwType(n.fnRet)
    modRwStmt(n.fnBody)
