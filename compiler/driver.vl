// The source-in / bytes-out DRIVER — the interface `scripts/vl-host` embeds
// against. A real `import`/`export` MODULE that imports the pipeline (lexer →
// ast → parser → typecheck → wasmEmit → lint → format) and exposes the host ABI
// (`srcReset`/`compileSrc`/`checkSrc`/`lintSrc`/`formatSrc` + the LSP query
// families). `compiler/entry.vl` re-exports this ABI under bare names so the
// module-resolved build (`vl build compiler/entry.vl`) keeps a stable surface.
//
// Source accumulates as an i32 CODE-POINT LIST (amortized push — string concat
// per char is quadratic copy churn, pathological where GC array.copy is a
// per-element host libcall), converted ONCE by the fromCodePoints builtin.
import {
  ArrayLit,
  BinExpr,
  Block,
  BreakStmt,
  Call,
  ContinueStmt,
  Diag,
  FieldDef,
  FieldInit,
  ForIn,
  ForRange,
  FuncDecl,
  Ident,
  IfStmt,
  Index,
  IsExpr,
  LetDecl,
  MatchExpr,
  Member,
  ObjLit,
  OptMember,
  Param,
  Paren,
  Program,
  RetStmt,
  Tok,
  TypeDecl,
  TypeRef,
  Unary,
  UnionDecl,
  WhileStmt,
} from "./ast"
import { diag } from "./lexer"
import { tErr } from "./typecheck"
import { emitProgram } from "./wasmEmit"
import {
  W,
  emitErr,
  fnIndices,
  fnNames,
  globalNames,
  globalStmts,
  localNames,
  reExpName,
  reExpTarget,
} from "./emit_state"
import { capHas } from "./emit_base"
import { tokenize } from "./lexer"
import {
  P,
  declNameTok,
  declNameTokOf,
  i32ToStr,
  mkProgram,
  nodeToks,
  ufcsAliasAdd,
  ufcsAliasReset,
} from "./ast"
import { parseProgram } from "./parser"
import { T, checkProgram, demangleMsg, initChecker } from "./typecheck"
import {
  redunCount,
  redunEColAt,
  redunELineAt,
  redunNameAt,
  redunSColAt,
  redunSLineAt,
  redunTokAt,
  redunTypeAt,
  symDefAt,
  symInlayColAt,
  symInlayCount,
  symInlayKindAt,
  symInlayLineAt,
  symInlayOccAt,
  symInlayScan,
  symInlayTypeCharAt,
  symInlayTypeLen,
  symMemTypeStrAt,
  symMemberCol,
  symMemberCount,
  symMemberIsMethod,
  symMemberLen,
  symMemberLine,
  symMemberScanAt,
  symMemberScanCount,
  symMemberScanIsFn,
  symMemberScanNameCharAt,
  symMemberScanNameLen,
  symMemberScanTypeCharAt,
  symMemberScanTypeLen,
  symOccBinding,
  symOccCount,
  symOccEndCol,
  symOccEndLine,
  symOccIsDeclAt,
  symOccKindAt,
  symOccStartCol,
  symOccStartLine,
  symOccTokAt,
  symRefAt,
  symRefsCountAt,
  symScopeAt,
  symScopeKindAt,
  symScopeNameCharAt,
  symScopeNameLen,
  symScopeTypeCharAt,
  symScopeTypeLen,
  symSetEnabled,
  symTypeAliasAt,
  symTypeStrAt,
} from "./check_query"
import { emitProgram } from "./wasmEmit"
import {
  W,
  emitErr,
  fnIndices,
  fnNames,
  globalNames,
  globalStmts,
  localNames,
  reExpName,
  reExpTarget,
} from "./emit_state"
import { capHas } from "./emit_base"
import {
  lint,
  lintCodeAt,
  lintColAt,
  lintCount,
  lintLineAt,
  lintMsgAt,
  lintSevAt,
} from "./lint"
import {
  fmtAddComment,
  fmtResetComments,
  fmtSetSource,
  formatProgram,
} from "./format"
export let vcCodes: i32[] = []
export function srcReset(): i32 {
  vcCodes = []
  0
}
export function srcPush(c: i32): i32 {
  vcCodes.push(c)
  0
}
export function vcSource(): string { fromCodePoints(vcCodes) }
// Source positions of the LEX diagnostics folded into `P.diags` (parallel to the
// first `vcLexLines.length` entries of `P.diags`): a lex diag carries a real
// `line`/`col` but `Diag.at` is a TOKEN index, so the positions ride here and
// `diagLine`/`diagCol` consult this table first. Reset per compile.
let vcLexLines: i32[] = []
let vcLexCols: i32[] = []

// ── H3 module-table state (globals precede their first textual use; the module
// SUBSYSTEM itself — exports, scan, pipeline, rewrite — lives at the bottom of
// this file) ──────────────────────────────────────────────────────────────────
let modKeys: string[] = [] // resolved module keys, [0] = the entry
let modSrcs: string[] = [] // module sources ("" when missing)
let modFound: i32[] = []   // 1 = read ok, 0 = host could not read the key
let modKeyAcc: i32[] = []  // accumulators for the NEXT commit
let modSrcAcc: i32[] = []
// Flat per-import-entry tables (filled by the token scan at each commit):
let impMod: i32[] = []      // importing module's table index
let impSpec: string[] = []  // the raw specifier text (diagnostics)
let impKey: string[] = []   // resolved key ("" = unsupported specifier)
let impName: string[] = []  // the exported (source) name ("" = bare import)
let impLocal: string[] = [] // the local binding name (after `as`)
// Flat per-module export-name sets (token scan: `export`-modified declarations).
let expMod: i32[] = []
let expName: string[] = []
// RE-EXPORTS (`export { a, b as c } from "spec"`): the PUBLIC name each re-export
// surfaces (`a`/`c`) and the importing module — parallel arrays. The re-export is
// ALSO recorded as an import (so the symbol is pulled + the dependency edge exists);
// these tables additionally drive the emitter to alias the (merged, mangled) target
// function under its bare PUBLIC name in the wasm export section, giving a stable ABI.
let reExpMod: i32[] = []       // the re-exporting module's table index
let reExpPublic: string[] = [] // the public bare name (the `as` alias, else the source name)
let reExpLocal: string[] = []  // the local binding the import created (resolves to the target)
// Filled by `modCompile` once renames are known: the public name → the merged
// (mangled) target function name, consumed by `emitProgram`'s export section.
// `reExpName`/`reExpTarget` are DEFINED in wasmEmit (the consumer) and imported
// here, so the driver→emitter→driver read does not form an import cycle.
// The export NAME token's source position (1-based line, 0-based col), parallel to
// `expName` — the cross-file go-to-definition target (the exporting module's decl).
let expDeclLine: i32[] = []
let expDeclCol: i32[] = []
// The `export` KEYWORD token's source position, parallel to `expName` — the target
// for the "redundant export keyword" hint (an export imported by no other module).
let expKwLine: i32[] = []
let expKwCol: i32[] = []
// Resolved keys imported by committed modules that are neither committed nor
// marked missing — what the host fetch loop reads next. Recomputed per commit.
let modPending: string[] = []
// DFS state: 0 unvisited, 1 loading (a back-edge is a cycle), 2 done; `modOrder`
// collects table indices dependency-first; `modDiags` the resolution errors.
let modState: i32[] = []
let modOrder: i32[] = []
let modDiags: string[] = []
// Per-module token-load ranges, recorded as each module's tokens append to the
// shared `P.toks` during `modCompile`: `modLoadStart[o]` is the first token index
// of the o-th loaded module, `modLoadMod[o]` its TABLE index. `modOfTok` maps an
// occurrence's token back to its owning module — cross-file find-references.
let modLoadStart: i32[] = []
let modLoadMod: i32[] = []
// Per-module rename map (`name` → `name$mN`) and the lexical shadow stack.
let modRenameFrom: string[] = []
let modRenameTo: string[] = []
let modShadow: string[] = []
// Registry of every top-level free `self`-function across all modules, keyed by
// its MANGLED name (`shout$m1`) with its parameter arity. A UFCS call
// `"x".shout()` is a `Call` whose callee is a `Member` (`memProp == shout`); the
// native pipeline lowers UFCS at check/emit time (not at parse time like the
// host). The merge cannot rewrite `memProp` (a same-named struct field must keep
// precedence, decided by the receiver TYPE the walker lacks), so it records a
// plain→mangled `ufcsAlias` for every site whose `prop` resolves through this
// registry to a self-function of matching arity (the host parser's UFCS rule,
// applied at the merge boundary); the checker/emitter follow the alias AFTER the
// field check.
let modSelfFnName: string[] = []
let modSelfFnArity: i32[] = []
// Generic type-parameter names live inside the rewrite of their declaration
// (`T` while inside `id<T>`'s annotations/body or `Box<T>`'s definition): a
// segment matching one must NOT rewrite through the rename map — it names the
// parameter, not a top-level binding.
let modTyShadow: string[] = []

function vcLoadToks(src: string): i32 {
  const r = tokenize(src)
  let i = 0
  while i < r.tokens.length {
    const t = r.tokens[i]
    // `pos` is the GLOBAL P.toks index (single-source: identical to the per-call
    // index; module mode APPENDS each module's tokens, so anchors stay correct).
    P.toks.push(
      {
        kind: t.kind,
        text: t.text,
        pos: P.toks.length,
        start: t.start,
        line: t.line,
        col: t.col,
      },
    )
    i = i + 1
  }
  // Fold the lexer's diagnostics into the parse-stage store so a LEX error (e.g.
  // an empty `''` or multi-char `'ab'` char literal) is rejected at the parse
  // stage. Mirrors the host's `checkOnly`, which seeds its diagnostics list from
  // `tokenize(...).diagnostics` BEFORE appending parse errors. The token index is
  // not tracked on a lex diag, so it is anchored at 0; the diag's REAL source
  // position is kept in the parallel `vcLexLines`/`vcLexCols`.
  let d = 0
  while d < r.diags.length {
    P.diags.push({ msg: r.diags[d].msg, at: 0 })
    vcLexLines.push(r.diags[d].line)
    vcLexCols.push(r.diags[d].col)
    d = d + 1
  }
  P.toks.length
}
// 0 = ok; 1 = lex/parse error; 2 = type error; 3 = emit error.
export function compileSrc(): i32 {
  symSetEnabled(0)
  P.toks = []
  P.nodes = []
  P.diags = []
  vcDiagMemoReset()
  P.pos = 0
  nodeToks = []
  declNameTok = []
  vcLexLines = []
  vcLexCols = []
  W.bytes = []
  fnNames = []
  fnIndices = []
  localNames = []
  globalStmts = []
  globalNames = []
  initChecker()
  // Module mode (H3): a non-empty module table runs the multi-file pipeline
  // (order/validate → parse-merge → rename/rewrite → check/emit). With an EMPTY
  // table (every existing consumer) the single-source path below is untouched.
  if modKeys.length > 0 { return modCompile(1) }
  vcLoadToks(vcSource())
  const root = parseProgram()
  if P.diags.length > 0 { return 1 }
  checkProgram(root)
  if T.diags.length > 0 { return 2 }
  const rc = emitProgram(root)
  if rc < 0 { return 3 }
  0
}
export function rbyteLen(): i32 { W.bytes.length }
export function rbyteAt(i: i32): i32 { W.bytes[i] }
// `vl check`: parse + typecheck ONLY, no emit. 0 = ok; 1 = lex/parse; 2 = type.
// Emit is `vl build`'s job — skipping it makes `check` faster on large inputs
// (~60% of a full compile of the whole compiler is emit) AND avoids rejecting a
// type-VALID program the emitter can't yet lower (an emit-coverage gap is not a
// check failure). Shares the diagnostic stores (`diagLen`/`diagAt`) with compileSrc.
export function checkSrc(): i32 {
  symSetEnabled(0)
  P.toks = []
  P.nodes = []
  P.diags = []
  vcDiagMemoReset()
  P.pos = 0
  nodeToks = []
  declNameTok = []
  vcLexLines = []
  vcLexCols = []
  fnNames = []
  fnIndices = []
  localNames = []
  globalStmts = []
  globalNames = []
  initChecker()
  // Module mode (H3) — see compileSrc; `check` runs the same pipeline minus emit.
  if modKeys.length > 0 { return modCompile(0) }
  vcLoadToks(vcSource())
  const root = parseProgram()
  if P.diags.length > 0 { return 1 }
  checkProgram(root)
  if T.diags.length > 0 { return 2 }
  0
}

// ── Lint tier (LSP-on-wasm Stage 3) ───────────────────────────────────────────
// Run the AST-derivable lint pass (compiler/lint.vl) over the current source and
// expose its diagnostics, so the corpus oracle (cases_wasm_test) can adjudicate
// `@warning`/`@info`/`@hint` cases on the self-hosted compiler too. Lint runs on
// the PARSE alone (no typecheck — matching the standalone lint harness). Returns
// the lint diagnostic count, or -1 on a lex/parse error (lint needs a valid AST).
// The host reads each diagnostic via `lintCount()` + `lintSevLen`/`lintSevByte`,
// `lintMsgLen`/`lintMsgByte` (per code point, like the diag stream), and the
// positions via lint.vl's own `lintLineAt`/`lintColAt` (1-based line, 0-based col).
export function lintSrc(): i32 {
  symSetEnabled(0)
  P.toks = []
  P.nodes = []
  P.diags = []
  vcDiagMemoReset()
  P.pos = 0
  nodeToks = []
  declNameTok = []
  vcLexLines = []
  vcLexCols = []
  vcLoadToks(vcSource())
  const root = parseProgram()
  if P.diags.length > 0 { return -1 }
  lint(root)
  lintCount()
}

export function lintSevLen(i: i32): i32 { lintSevAt(i).length }
export function lintSevByte(i: i32, j: i32): i32 { lintSevAt(i)[j] }
export function lintMsgLen(i: i32): i32 { lintMsgAt(i).length }
export function lintMsgByte(i: i32, j: i32): i32 { lintMsgAt(i)[j] }
// The stable rule `code` (e.g. "unused-variable", "prefer-const") drives the LSP
// quick-fixes, and the 1-based line / 0-based col place the squiggle.
export function lintCodeLen(i: i32): i32 { lintCodeAt(i).length }
export function lintCodeByte(i: i32, j: i32): i32 { lintCodeAt(i)[j] }
export function lintLine(i: i32): i32 { lintLineAt(i) }
export function lintCol(i: i32): i32 { lintColAt(i) }

// ── Format tier (kill-TS step 1) ──────────────────────────────────────────────
// Run the AST-driven formatter (compiler/format.vl) over the current source and
// expose its canonical-form output as a string, so the native `vl fmt` and the
// deno harness can reformat VL. Lexes (capturing the retained `//`/`///` comments
// the formatter places), parses, and formats. Returns the formatted string length,
// or -1 on a lex/parse error (the formatter needs a valid AST). The host then
// reads the bytes via `fmtByteAt(j)` (one UTF-32 code point per call, like the
// other string accessors), 0 ≤ j < the returned length.
export let vcFmtOut = ""
export function formatSrc(): i32 {
  symSetEnabled(0)
  P.toks = []
  P.nodes = []
  P.diags = []
  vcDiagMemoReset()
  P.pos = 0
  nodeToks = []
  declNameTok = []
  vcLexLines = []
  vcLexCols = []
  const src = vcSource()
  // Lex once, feeding tokens into the parser AND the formatter's comment table
  // (the formatter slices spans from `src` and places comments around them).
  fmtSetSource(src)
  fmtResetComments()
  const r = tokenize(src)
  let i = 0
  while i < r.tokens.length {
    const t = r.tokens[i]
    P.toks.push(
      {
        kind: t.kind,
        text: t.text,
        pos: P.toks.length,
        start: t.start,
        line: t.line,
        col: t.col,
      },
    )
    i = i + 1
  }
  let d = 0
  while d < r.diags.length {
    P.diags.push({ msg: r.diags[d].msg, at: 0 })
    d = d + 1
  }
  let c = 0
  while c < r.comments.length {
    const cm = r.comments[c]
    let tr = 0
    if cm.trailing { tr = 1 }
    fmtAddComment(cm.text, cm.start, cm.line, tr)
    c = c + 1
  }
  if P.diags.length > 0 { return -1 }
  const root = parseProgram()
  if P.diags.length > 0 { return -1 }
  vcFmtOut = formatProgram(root)
  vcFmtOut.length
}
export function fmtLen(): i32 { vcFmtOut.length }
export function fmtByteAt(j: i32): i32 { vcFmtOut[j] }

// ── LSP symbol query (Stage 2): a SYMBOL-AWARE check ──────────────────────────
// Identical to `checkSrc` but with the symbol table turned ON, so the checker
// records the occurrence + binding-type tables the query exports below read.
// Used ONLY by the LSP's go-to-def / find-refs / hover path; every other consumer
// calls `checkSrc`/`compileSrc`, which force the table OFF (zero cost, and emit
// stays byte-identical — the tables never feed the emitter). The codes match
// `checkSrc` (0 ok, 1 lex/parse, 2 type); the symbol tables are populated for a
// 0 OR 2 result (a type error still yields partial occurrences), and stay valid
// until the next check. Module mode rides the same `modCompile` path.
export function checkSrcSym(): i32 {
  symSetEnabled(1)
  P.toks = []
  P.nodes = []
  P.diags = []
  vcDiagMemoReset()
  P.pos = 0
  nodeToks = []
  declNameTok = []
  vcLexLines = []
  vcLexCols = []
  fnNames = []
  fnIndices = []
  localNames = []
  globalStmts = []
  globalNames = []
  initChecker()
  if modKeys.length > 0 {
    const mrc = modCompile(0)
    return mrc
  }
  vcLoadToks(vcSource())
  const root = parseProgram()
  if P.diags.length > 0 { return 1 }
  checkProgram(root)
  if T.diags.length > 0 { return 2 }
  0
}

// The occurrence table (parallel to the host's `SymbolOccurrence[]`). After a
// `checkSrcSym`, the host reads `symCount()` occurrences; for each, its source
// span via `symSpanStartLine/Col` + `symSpanEndLine/Col` (1-based line, 0-based
// col — the diagnostic convention), `symIsDecl(i)` (1 = the binding's declaration,
// 0 = a use), and `symBindingId(i)` (the declaring node index — the stable
// binding identity two occurrences share iff they refer to the same binding).
export function symCount(): i32 { symOccCount() }
export function symSpanStartLine(i: i32): i32 { symOccStartLine(i) }
export function symSpanStartCol(i: i32): i32 { symOccStartCol(i) }
export function symSpanEndLine(i: i32): i32 { symOccEndLine(i) }
export function symSpanEndCol(i: i32): i32 { symOccEndCol(i) }
export function symIsDecl(i: i32): i32 { symOccIsDeclAt(i) }
export function symBindingId(i: i32): i32 { symOccBinding(i) }

// Cross-file find-references: the MODULE (table index) occurrence `i` belongs to.
// A module's tokens occupy a contiguous range of the merged `P.toks` (recorded as
// `modLoadStart`/`modLoadMod` during `modCompile`); map the occurrence's anchor
// token into that range. Single-file mode (no module load) → 0. Lets the host
// attribute each occurrence to its source file and collect refs across the graph.
export function modOfTok(tok: i32): i32 {
  let best = 0
  let o = 0
  while o < modLoadStart.length {
    if modLoadStart[o] <= tok { best = modLoadMod[o] }
    o = o + 1
  }
  best
}
export function symOccModuleAt(i: i32): i32 {
  const tok = symOccTokAt(i)
  if tok < 0 { return 0 }
  modOfTok(tok)
}

// Semantic tokens (Stage 2): after a `checkSrcSym`, the recorded occurrences ARE
// the classified identifiers, so `tokCount` is just `symCount` and a token's span
// reads via the same `symSpan*` accessors. The ONE addition is each token's
// CLASSIFICATION — `tokBindKindAt(i)` (0=local 1=param 2=function, -1 otherwise),
// the binding kind a lexer can't see. This slice classifies identifiers only;
// the host keeps its lexical pass for keywords/operators/literals/comments and
// its member walk for properties/methods (neither is recorded here). Declaration
// vs use comes from `symIsDecl(i)`; the span from `symSpan*`.
export function tokCount(): i32 { symOccCount() }
export function tokBindKindAt(i: i32): i32 { symOccKindAt(i) }
export function tokSpanStartLine(i: i32): i32 { symOccStartLine(i) }
export function tokSpanStartCol(i: i32): i32 { symOccStartCol(i) }
export function tokSpanEndCol(i: i32): i32 { symOccEndCol(i) }

// Go-to-definition: the occurrence index of the DECLARATION for the binding whose
// occurrence covers (line, col), or -1 when the cursor is off any tracked name.
// Read its span via the `symSpan*` accessors.
export function defAt(line: i32, col: i32): i32 { symDefAt(line, col) }

// Find-references: the count of occurrences (declaration + uses) of the binding
// at (line, col), and the k-th such occurrence INDEX (its span via `symSpan*`).
export function refsCountAt(line: i32, col: i32): i32 {
  symRefsCountAt(line, col)
}
export function refAt(line: i32, col: i32, k: i32): i32 {
  symRefAt(line, col, k)
}

// Hover-types: the rendered type string of the binding at (line, col), exposed
// per-codepoint via a result buffer the host fills then reads (mirrors the
// `rbyte*` idiom). `typeStrAt` computes the string and returns its length;
// `typeStrCharAt(j)` reads code point `j` of that last-computed string. A cursor
// off any tracked binding yields a zero-length string.
let symTyBuf: string = ""
export function typeStrAt(line: i32, col: i32): i32 {
  symTyBuf = symTypeStrAt(line, col)
  symTyBuf.length
}
export function typeStrLen(): i32 { symTyBuf.length }
export function typeStrCharAt(j: i32): i32 { symTyBuf[j] }

// Type-alias hover: the rendered type of the user `type` NAME (struct/union alias)
// under (line, col) — its decl name or a use in an annotation — exposed
// per-codepoint like `typeStrAt`. "" when the cursor is off a known user type.
let typeAliasBuf: string = ""
export function typeAliasAt(line: i32, col: i32): i32 {
  typeAliasBuf = symTypeAliasAt(line, col)
  typeAliasBuf.length
}
export function typeAliasCharAt(j: i32): i32 { typeAliasBuf[j] }

// Inlay hints (LSP): after a `checkSrcSym`, the inferred type at each UNANNOTATED
// declaration — `inlayScan` records the set, the per-index accessors read each
// hint's KIND (0 = value binding → its type; 1 = function → its RETURN type),
// the NAME-end position (1-based line, 0-based col — the host walks to the `)`
// for a function and applies its own annotation/range filters), and the rendered
// type label (per-codepoint). The native `deriveInlayHints`.
export function inlayScan(): i32 { symInlayScan() }
export function inlayCount(): i32 { symInlayCount() }
export function inlayKindAt(i: i32): i32 { symInlayKindAt(i) }
export function inlayLineAt(i: i32): i32 { symInlayLineAt(i) }
export function inlayColAt(i: i32): i32 { symInlayColAt(i) }
export function inlayTypeLen(i: i32): i32 { symInlayTypeLen(i) }
export function inlayTypeCharAt(i: i32, j: i32): i32 {
  symInlayTypeCharAt(i, j)
}
// The MODULE (table index) hint `i` belongs to — its occurrence's module (0 =
// the entry). A whole-program compile records a hint for every module's
// unannotated decls, each with module-local line/col; the host keeps only the
// entry's (module 0) so a dependency's hints don't render against the importer
// (`./mathx`'s function-return hints bleeding onto the `import` line). Mirrors
// `symOccModuleAt` for the semantic-token slice.
export function inlayModuleAt(i: i32): i32 { symOccModuleAt(symInlayOccAt(i)) }

// The module a redundant-type finding belongs to (its name token's owner). Lets
// the cli keep only the ENTRY module's (== 0) findings in a multi-module compile,
// where every module's AST is merged. Single-file mode has no module table, so
// `modOfTok` returns 0 throughout (nothing filtered). Mirrors `inlayModuleAt`.
export function redunModuleAt(i: i32): i32 { modOfTok(redunTokAt(i)) }

// Member hover: the rendered type string of the member access whose PROPERTY NAME
// is at (line, col) — `o.x` / `o?.y` — exposed per-codepoint like `typeStrAt`. A
// cursor off any recorded member access yields a zero-length string.
let memTyBuf: string = ""
export function memberTypeStrAt(line: i32, col: i32): i32 {
  memTyBuf = symMemTypeStrAt(line, col)
  memTyBuf.length
}
export function memberTypeStrLen(): i32 { memTyBuf.length }
export function memberTypeStrCharAt(j: i32): i32 { memTyBuf[j] }

// Member semantic tokens: after a `checkSrcSym`, every member-access property
// name the checker resolved — `memberCount()` then per-index span + class. A
// member is a `method` (`memberIsMethodAt(i) == 1`) when its resolved type is a
// function, else a `property`. The native counterpart of the host's AST member
// walk; lets the wasm semantic-tokens path classify `o.x`/`xs.get` itself.
export function memberCount(): i32 { symMemberCount() }
export function memberLineAt(i: i32): i32 { symMemberLine(i) }
export function memberColAt(i: i32): i32 { symMemberCol(i) }
export function memberLenAt(i: i32): i32 { symMemberLen(i) }
export function memberIsMethodAt(i: i32): i32 { symMemberIsMethod(i) }

// Scope-at-position (completion): after a `checkSrcSym`, the user bindings
// (var/param/function) visible at (line, col) — 1-based line, 0-based col.
// `scopeAt` computes the set and returns its count; the per-index accessors read
// each binding's NAME (per-codepoint), KIND (0=variable 1=parameter 2=function),
// and rendered TYPE (per-codepoint, zero length when none). Builtins/imports/types
// are not included — the host folds those in. The native `bindingsInScopeAt`.
export function scopeAt(line: i32, col: i32): i32 { symScopeAt(line, col) }
export function scopeNameLen(i: i32): i32 { symScopeNameLen(i) }
export function scopeNameCharAt(i: i32, j: i32): i32 {
  symScopeNameCharAt(i, j)
}
export function scopeKindAt(i: i32): i32 { symScopeKindAt(i) }
export function scopeTypeLen(i: i32): i32 { symScopeTypeLen(i) }
export function scopeTypeCharAt(i: i32, j: i32): i32 {
  symScopeTypeCharAt(i, j)
}

// Member completion (LSP): after a `checkSrcSym`, the members of the receiver type
// whose binding is under (line, col) — `memberScanAt` resolves + records the set,
// the per-index accessors read each member's NAME (per-codepoint), detail TYPE
// string (per-codepoint), and method flag (`memberScanIsFn` = 1 for a
// function-typed member). The host strips the trailing `.` so the receiver parses
// as a bare expression at its original position. The native `receiverObjectType` +
// `memberCompletions`.
export function memberScanAt(line: i32, col: i32): i32 {
  symMemberScanAt(line, col)
}
export function memberScanCount(): i32 { symMemberScanCount() }
export function memberScanNameLen(i: i32): i32 { symMemberScanNameLen(i) }
export function memberScanNameCharAt(i: i32, j: i32): i32 {
  symMemberScanNameCharAt(i, j)
}
export function memberScanTypeLen(i: i32): i32 { symMemberScanTypeLen(i) }
export function memberScanTypeCharAt(i: i32, j: i32): i32 {
  symMemberScanTypeCharAt(i, j)
}
export function memberScanIsFn(i: i32): i32 { symMemberScanIsFn(i) }

// Builtin completions (LSP): the compiler's builtin surface the host folds into
// identifier completion — the numeric/string TYPE names and the builtin FUNCTIONS
// (`print`/`Map`/`Set`/`toString`/`fromCodePoint[s]`). The checker defines these
// as special-cased call/type arms (no enumerable builtin scope), so the
// completion list is maintained HERE, in the native LSP surface, next to the
// compiler that owns them — the single source of truth the host used to get from
// the TS `defaultScope`. Static (no source / `checkSrcSym` needed): `builtinScan`
// fills the table, the per-index accessors read each entry's NAME, KIND (0=type,
// 1=function), and detail TYPE string.
let blName: string[] = []
let blKind: i32[] = []
let blType: string[] = []
function blPush(n: string, k: i32, t: string) {
  blName.push(n)
  blKind.push(k)
  blType.push(t)
}
export function builtinScan(): i32 {
  blName = []
  blKind = []
  blType = []
  blPush("i32", 0, "i32")
  blPush("i64", 0, "i64")
  blPush("f32", 0, "f32")
  blPush("f64", 0, "f64")
  blPush("boolean", 0, "boolean")
  blPush("string", 0, "string")
  blPush("print", 1, "(any) -> null")
  blPush("toString", 1, "(i32 | boolean) -> string")
  blPush("fromCodePoint", 1, "(i32) -> string")
  blPush("fromCodePoints", 1, "(i32[]) -> string")
  blPush("Map", 1, "() -> Map")
  blPush("Set", 1, "() -> Set")
  blName.length
}
export function builtinCount(): i32 { blName.length }
export function builtinNameLen(i: i32): i32 { blName[i].length }
export function builtinNameCharAt(i: i32, j: i32): i32 { blName[i][j] }
export function builtinKindAt(i: i32): i32 { blKind[i] }
export function builtinTypeLen(i: i32): i32 { blType[i].length }
export function builtinTypeCharAt(i: i32, j: i32): i32 { blType[i][j] }

// ── LSP lexical semantic tokens: keywords / operators / literals / comments ────
// The lexical highlighting layer the host's TS `tokenize` pass used to own. Unlike
// the identifier/member slices above it needs no typecheck — `lexScan()` just
// tokenizes the staged source (srcReset/srcPush first) and records, per COLOURED
// token, a small lexical CLASS plus its 1-based line / 0-based col / length. The
// retained `//` and `///` comments fold in as class COMMENT. Tokens that get no
// semantic colour — identifiers (owned by the symbol slice), strings (left to the
// TextMate grammar so its finer escape scopes survive), and structural punctuation
// — are dropped (class < 0). The host maps the class onto its token-type legend.
//
//   class: 0 = keyword  1 = operator  2 = number  3 = boolean  4 = comment
let lexCls: i32[] = []
let lexLine: i32[] = []
let lexCol: i32[] = []
let lexLen: i32[] = []

// The lexical class for a lexer token kind, or -1 for kinds that get no token.
// Operators span arithmetic / logical / comparison / bitwise / compound-assign /
// nullish. Keyed off the lexer's ACTUAL kind tags (`SLASH`/`PERCENT`/`BANG`/`EQ`…)
// rather than the host's older guesses, so every operator the lexer emits colours.
function lexClassOf(kind: string): i32 {
  if kind == "NUMBER" { return 2 }
  if kind == "TRUE" || kind == "FALSE" || kind == "NULL" { return 3 }
  if (
    kind == "FUNCTION" ||
    kind == "IF" ||
    kind == "ELSE" ||
    kind == "WHILE" ||
    kind == "FOR" ||
    kind == "CONST" ||
    kind == "LET" ||
    kind == "RETURN" ||
    kind == "IS" ||
    kind == "AWAIT" ||
    kind == "BREAK" ||
    kind == "CONTINUE" ||
    kind == "TYPE" ||
    kind == "IMPORT" ||
    kind == "EXPORT"
  ) {
    return 0
  }
  if (
    kind == "PLUS" ||
    kind == "MINUS" ||
    kind == "STAR" ||
    kind == "SLASH" ||
    kind == "PERCENT" ||
    kind == "CARET" ||
    kind == "EQUAL" ||
    kind == "PLUSEQ" ||
    kind == "MINUSEQ" ||
    kind == "STAREQ" ||
    kind == "SLASHEQ" ||
    kind == "PLUSPLUS" ||
    kind == "MINUSMINUS" ||
    kind == "AND" ||
    kind == "OR" ||
    kind == "BANG" ||
    kind == "EQ" ||
    kind == "NE" ||
    kind == "GT" ||
    kind == "GE" ||
    kind == "LT" ||
    kind == "LE" ||
    kind == "PIPE" ||
    kind == "AMPERSAND" ||
    kind == "TILDE" ||
    kind == "SHL" ||
    kind == "SHR" ||
    kind == "USHR" ||
    kind == "QUESTION_DOT" ||
    kind == "QUESTION_QUESTION"
  ) {
    return 1
  }
  -1
}

export function lexScan(): i32 {
  lexCls = []
  lexLine = []
  lexCol = []
  lexLen = []
  const r = tokenize(vcSource())
  let i = 0
  while i < r.tokens.length {
    const t = r.tokens[i]
    let c = lexClassOf(t.kind)
    if c >= 0 {
      lexCls.push(c)
      lexLine.push(t.line)
      lexCol.push(t.col)
      lexLen.push(t.text.length)
    }
    i = i + 1
  }
  // Retained comments → class COMMENT. The lexeme text includes the leading `//`
  // or `///`, so its length spans the whole comment to end of line.
  let k = 0
  while k < r.comments.length {
    const cm = r.comments[k]
    lexCls.push(4)
    lexLine.push(cm.line)
    lexCol.push(cm.col)
    lexLen.push(cm.text.length)
    k = k + 1
  }
  lexCls.length
}
export function lexCount(): i32 { lexCls.length }
export function lexClassAt(i: i32): i32 { lexCls[i] }
export function lexLineAt(i: i32): i32 { lexLine[i] }
export function lexColAt(i: i32): i32 { lexCol[i] }
export function lexLenAt(i: i32): i32 { lexLen[i] }

// All failure diagnostics, newline-joined: parse diags, then typecheck diags,
// then the emit failure message (whichever stage failed populated its store).
function vcDiags(): string {
  let out = ""
  let i = 0
  while i < P.diags.length {
    let d = P.diags[i]
    out = out + demangleMsg(d.msg) + "\n"
    i = i + 1
  }
  let j = 0
  while j < T.diags.length {
    const d2 = T.diags[j]
    out = out + demangleMsg(d2.tmsg) + "\n"
    j = j + 1
  }
  if emitErr.length > 0 { out = out + demangleMsg(emitErr) + "\n" }
  out
}
// The host reads the joined text ONE CODE POINT PER CALL (`diagAt(i)`), so
// re-rendering — re-demangling and re-joining every message — on each read
// makes error reporting quadratic in the diagnostic text. Memoize the rendered
// string (the `symTyBuf` idiom); the pipeline entry points invalidate it
// (`vcDiagMemoReset`) before repopulating the diagnostic stores.
let vcDiagsBuf = ""
let vcDiagsBufValid = 0
function vcDiagsMemo(): string {
  if vcDiagsBufValid == 0 {
    vcDiagsBuf = vcDiags()
    vcDiagsBufValid = 1
  }
  vcDiagsBuf
}
// Per-message memo for the structured stream (`diagMsgAt(i, j)` is likewise
// read once per character): the last (index, rendered message) pair.
let vcDiagMsgBufI = -1
let vcDiagMsgBuf = ""
function vcDiagMemoReset(): i32 {
  vcDiagsBufValid = 0
  vcDiagMsgBufI = -1
  0
}
export function diagLen(): i32 { vcDiagsMemo().length }
export function diagAt(i: i32): i32 { vcDiagsMemo()[i] }

// ── Structured per-diagnostic exports (positions) ─────────────────────────────
// PARALLEL to `diagLen`/`diagAt` (which stay byte-compatible: corpus `@error`
// directives and host-parity tests substring-match that newline-joined TEXT).
// The host reads `diagCount()` diagnostics; for each, the message text via the
// per-byte `diagMsgLen(i)`/`diagMsgAt(i, j)` idiom and its source position via
// `diagLine(i)` (1-based; 0 = "no position, render the message bare") and
// `diagCol(i)` (0-based — the lexer's and `@error-at`'s convention). Order
// matches `vcDiags`: parse diags (lex diags first), then type diags, then the
// emit failure message (positionless).
export function vcDiagMsg(i: i32): string {
  // Demangle the module-merge `$mN` rename artifact so the user sees SOURCE names.
  if i < P.diags.length { return demangleMsg(P.diags[i].msg) }
  let j = i - P.diags.length
  if j < T.diags.length { return demangleMsg(T.diags[j].tmsg) }
  demangleMsg(emitErr)
}
export function diagCount(): i32 {
  let n = P.diags.length + T.diags.length
  if emitErr.length > 0 { n = n + 1 }
  n
}
function vcDiagMsgMemo(i: i32): string {
  if vcDiagMsgBufI != i {
    vcDiagMsgBuf = vcDiagMsg(i)
    vcDiagMsgBufI = i
  }
  vcDiagMsgBuf
}
export function diagMsgLen(i: i32): i32 { vcDiagMsgMemo(i).length }
export function diagMsgAt(i: i32, j: i32): i32 { vcDiagMsgMemo(i)[j] }
export function diagLine(i: i32): i32 {
  if i < P.diags.length {
    // A lex diag (always at the front of `P.diags`) carries its own position.
    if i < vcLexLines.length { return vcLexLines[i] }
    // A parse diag is anchored at a token index; out of range ⇒ no position.
    let at = P.diags[i].at
    if at >= 0 && at < P.toks.length { return P.toks[at].line }
    return 0
  }
  let j = i - P.diags.length
  if j < T.diags.length { return T.diags[j].tline }
  0
}
export function diagCol(i: i32): i32 {
  if i < P.diags.length {
    if i < vcLexCols.length { return vcLexCols[i] }
    let at = P.diags[i].at
    if at >= 0 && at < P.toks.length { return P.toks[at].col }
    return 0
  }
  let j = i - P.diags.length
  if j < T.diags.length { return T.diags[j].tcol }
  0
}
// The diagnostic's END column: the anchor token's start + its lexeme length
// (lexemes never span lines, so the end LINE is `diagLine`). A parse diag is
// anchored at a TOKEN index; a type diag at an AST NODE index, resolved through
// the `nodeToks` side table — the same resolution `tErr` applies. A lex diag or
// a positionless/out-of-range anchor degrades to `diagCol` — a zero-width range
// at the start, which an LSP host may widen client-side.
export function diagEndCol(i: i32): i32 {
  let at = -1
  if i < P.diags.length {
    if i >= vcLexLines.length {
      // a lex diag carries no token anchor
      at = P.diags[i].at
    }
  } else {
    let j = i - P.diags.length
    if j < T.diags.length {
      const nd = T.diags[j].tat
      if nd >= 0 && nd < nodeToks.length { at = nodeToks[nd] }
    }
  }
  if at >= 0 && at < P.toks.length {
    return P.toks[at].col + P.toks[at].text.length
  }
  diagCol(i)
}

// ── H3: native module resolution ──────────────────────────────────────────────
// The module-table half of docs/native-modules-design.md (state declared at the
// top of this file — globals precede their first textual use). The host (Rust
// driver) runs a FETCH LOOP: it commits the entry, asks `modPendingCount` which
// resolved keys are still needed, reads + commits them, and repeats until the
// graph is closed; `compileSrc`/`checkSrc` then run the module pipeline
// (order/validate → parse-merge → rename/rewrite → check/emit). With an EMPTY
// table they behave exactly as before — the back-compat branch every existing
// consumer (the selfhost harnesses, the fixpoint assemblies) rides.
export function modReset(): i32 {
  modKeys = []
  modSrcs = []
  modFound = []
  modKeyAcc = []
  modSrcAcc = []
  impMod = []
  impSpec = []
  impKey = []
  impName = []
  impLocal = []
  expMod = []
  expName = []
  expDeclLine = []
  expDeclCol = []
  expKwLine = []
  expKwCol = []
  reExpMod = []
  reExpPublic = []
  reExpLocal = []
  reExpName = []
  reExpTarget = []
  modPending = []
  // Clear the token-load ranges too: a subsequent SINGLE-FILE check (no imports →
  // no `modCompile`) must not inherit a prior graph's ranges, or `symOccModuleAt`
  // would mis-attribute its occurrences.
  modLoadStart = []
  modLoadMod = []
  0
}
export function modKeyPush(c: i32): i32 {
  modKeyAcc.push(c)
  0
}
export function modSrcPush(c: i32): i32 {
  modSrcAcc.push(c)
  0
}
// Register the accumulated (key, source) pair. `found = 0` marks "the host could
// not read this key" so the unresolvable diagnostic fires instead of an infinite
// re-request. A found module is token-scanned immediately (imports + exports).
export function modCommit(found: i32): i32 {
  const key = fromCodePoints(modKeyAcc)
  const src = fromCodePoints(modSrcAcc)
  modKeyAcc = []
  modSrcAcc = []
  modKeys.push(key)
  modSrcs.push(src)
  modFound.push(found)
  if found != 0 { modScan(modKeys.length - 1, src) }
  modRecomputePending()
  0
}
export function modPendingCount(): i32 { modPending.length }
export function modPendingLen(i: i32): i32 { modPending[i].length }
export function modPendingAt(i: i32, j: i32): i32 { modPending[i][j] }

// Cross-file symbols (kill-TS #3-C): the import/export SURFACE the module scan
// already built (`imp*`/`exp*`), exposed as accessors. After committing the graph
// (the `mod*` fetch protocol), the host reads each import specifier — its local
// alias, the exported (source) name, and the resolved sibling KEY ("" =
// unresolved) — and each module's exports with the decl-name source position. The
// orchestration (disk crawl, dedup) stays host-side; this is the per-graph
// extraction. Strings are exposed per-codepoint (the `rbyte*` idiom).
export function impCount(): i32 { impMod.length }
export function impModAt(i: i32): i32 { impMod[i] }
export function impLocalLen(i: i32): i32 { impLocal[i].length }
export function impLocalCharAt(i: i32, j: i32): i32 { impLocal[i][j] }
export function impNameLen(i: i32): i32 { impName[i].length }
export function impNameCharAt(i: i32, j: i32): i32 { impName[i][j] }
export function impKeyLen(i: i32): i32 { impKey[i].length }
export function impKeyCharAt(i: i32, j: i32): i32 { impKey[i][j] }

export function expCount(): i32 { expMod.length }
export function expModAt(i: i32): i32 { expMod[i] }
export function expNameLen(i: i32): i32 { expName[i].length }
export function expNameCharAt(i: i32, j: i32): i32 { expName[i][j] }
export function expDeclLineAt(i: i32): i32 { expDeclLine[i] }
export function expDeclColAt(i: i32): i32 { expDeclCol[i] }
export function expKwLineAt(i: i32): i32 { expKwLine[i] }
export function expKwColAt(i: i32): i32 { expKwCol[i] }

// The committed modules' KEYS, by table index — lets the host map an import's
// resolved key to the module that owns a matching export (`impKey` ↔ `expMod`).
export function modKeyCount(): i32 { modKeys.length }
export function modKeyAtLen(m: i32): i32 { modKeys[m].length }
export function modKeyAtCharAt(m: i32, j: i32): i32 { modKeys[m][j] }

// The table index of the module that OWNS diagnostic `i` (its anchor token's module
// via `modOfTok`), or 0 (the entry) when the anchor is positionless / out of range.
// Mirrors `diagLine`/`diagEndCol`'s anchor resolution: a parse diag is anchored at a
// TOKEN index (`Diag.at`), a type diag at an AST NODE resolved through `nodeToks`.
// MUST be read BEFORE `lintSrc` re-parses the entry (which resets `P.toks`/`nodeToks`,
// so the anchor would no longer map) — same capture window as the error-tier stream.
export function diagModule(i: i32): i32 {
  let at = -1
  if i < P.diags.length {
    at = P.diags[i].at
  } else {
    let j = i - P.diags.length
    if j < T.diags.length {
      const nd = T.diags[j].tat
      if nd >= 0 && nd < nodeToks.length { at = nodeToks[nd] }
    }
  }
  if at >= 0 && at < P.toks.length { return modOfTok(at) }
  0
}

// ── specifier resolution (ports of the host's pure string math) ───────────────
function modIsRelative(spec: string): boolean {
  if spec.length >= 2 {
    if spec[0] == '.' && spec[1] == '/' { return true }
  }
  if spec.length >= 3 {
    if spec[0] == '.' && spec[1] == '.' && spec[2] == '/' { return true }
  }
  false
}
// A `std:` specifier: `std:` + a [a-z0-9_]+(/[a-z0-9_]+)* module name. The
// specifier IS the module key (returned verbatim by `modResolveSpecifier`);
// the HOST maps it to bytes ($VL_STD / the exe-relative std/ dir).
function modIsStdSpec(spec: string): boolean {
  if !modKeyIsStd(spec) { return false }
  let segLen = 0
  let i = 4
  while i < spec.length {
    let c = spec[i]
    if c == '/' {
      if segLen == 0 { return false }
      segLen = 0
    } else if (c >= 'a' && c <= 'z') || (c >= '0' && c <= '9') || c == '_' {
      segLen = segLen + 1
    } else {
      return false
    }
    i = i + 1
  }
  segLen > 0
}
// A module key in the `std:` scheme (a verbatim std specifier).
function modKeyIsStd(key: string): boolean {
  if key.length < 4 { return false }
  key[0] == 's' && key[1] == 't' && key[2] == 'd' && key[3] == ':'
}
// The directory portion of a `/`-separated key (no trailing slash), "" if none.
function modDirOf(key: string): string {
  let slash = -1
  let i = 0
  while i < key.length {
    if key[i] == '/' { slash = i }
    i = i + 1
  }
  if slash < 0 { return "" }
  // An explicit `return` — a bare member-call TAIL expression routes through the
  // statement dispatch, an emit gap in the native pipeline.
  return key.slice(0, slash)
}
// Normalize a `/`-separated path, collapsing `.` and `..` segments. A leading
// `/` (absolute key) is preserved; leading `..` that escape the root are kept
// (the key stays distinct and the reader simply won't find it).
function modNormalize(path: string): string {
  let absolute = false
  if path.length > 0 {
    if path[0] == '/' { absolute = true }
  }
  let segs: string[] = []
  let cur: i32[] = []
  let i = 0
  while i <= path.length {
    const atEnd = i == path.length
    let c = 0
    if !atEnd { c = path[i] }
    if atEnd || c == '/' {
      const seg = fromCodePoints(cur)
      cur = []
      if seg == "" || seg == "." {
        // skip
      } else if seg == ".." {
        if segs.length > 0 && segs[segs.length - 1] != ".." {
          // Drop the last segment (rebuild — a bare `.pop()` STATEMENT is an
          // emit gap in the native pipeline; this stays on the lowered path).
          const trimmed: string[] = []
          let ti = 0
          while ti < segs.length - 1 {
            trimmed.push(segs[ti])
            ti = ti + 1
          }
          segs = trimmed
        } else {
          segs.push("..")
        }
      } else {
        segs.push(seg)
      }
    } else {
      cur.push(c)
    }
    i = i + 1
  }
  let out = ""
  let s = 0
  while s < segs.length {
    if s > 0 { out = out + "/" }
    out = out + segs[s]
    s = s + 1
  }
  if absolute { return "/" + out }
  out
}
// Resolve `spec` written in the module at `fromKey` to a key, or "" for a kind
// the resolver rejects (bare, malformed `std:`, or relative-inside-std — std
// modules import only via `std:` specifiers, since `dirOf` of a std key is ""
// and `./x` would resolve CWD-relative). A well-formed `std:` specifier IS its
// key (verbatim). For relative specs `.vl` is APPENDED (specifiers omit it).
function modResolveSpecifier(spec: string, fromKey: string): string {
  if modIsStdSpec(spec) { return spec }
  if !modIsRelative(spec) { return "" }
  if modKeyIsStd(fromKey) { return "" }
  const base = modDirOf(fromKey)
  let joined = spec
  if base != "" { joined = base + "/" + spec }
  modNormalize(joined) + ".vl"
}

// ── token-level import/export scan (per committed module) ─────────────────────
// Tokenizes the committed source with the REAL `tokenize` and walks top-level
// tokens (brace-depth tracked): each `import { a as b, … } from "spec"` records
// one import entry per specifier (resolved against THIS module's key); each
// top-level `export`-modified `function`/`let`/`const`/`type` records an export
// name. Imports still PARSE as no-ops later — this scan is the only reader.
function modScan(m: i32, src: string): i32 {
  const r = tokenize(src)
  const toks = r.tokens
  let depth = 0
  let i = 0
  while i < toks.length {
    let k = toks[i].kind
    if k == "LBRACE" {
      depth = depth + 1
      i = i + 1
    } else if k == "RBRACE" {
      depth = depth - 1
      i = i + 1
    } else if k == "IMPORT" && depth == 0 {
      // One `import { a as b, … } from "spec"`, scanned INLINE (the lexer's
      // token type is renamed per assembly — `Tok` → `LexTok` — so a named
      // annotation can't portably type a token param). Records one entry per
      // specifier (the `as` local rename honored); a specifier-less import
      // records one entry with empty names (a pure graph edge). The cursor
      // ends just past the trailing path STRING.
      i = i + 1
      const names: string[] = []
      const locals: string[] = []
      if i < toks.length {
        if toks[i].kind == "LBRACE" {
          i = i + 1
          let going = true
          while going && i < toks.length {
            const ck = toks[i].kind
            if ck == "RBRACE" {
              i = i + 1
              going = false
            } else {
              if ck == "IDENT" {
                let nm = toks[i].text
                let loc = nm
                if i + 2 < toks.length {
                  if (
                    toks[i + 1].kind == "IDENT" &&
                    toks[i + 1].text == "as" &&
                    toks[i + 2].kind == "IDENT"
                  ) {
                    loc = toks[i + 2].text
                    i = i + 2
                  }
                }
                names.push(nm)
                locals.push(loc)
              }
              i = i + 1
            }
          }
        }
      }
      // Forward to the path STRING (the `from` keyword rides as an IDENT). The
      // STRING token's `text` keeps its surrounding quotes — strip them.
      let spec = ""
      let scanning = true
      while scanning && i < toks.length {
        const sk = toks[i].kind
        if sk == "STRING" {
          spec = toks[i].text
          if spec.length >= 2 {
            if spec[0] == '"' && spec[spec.length - 1] == '"' {
              spec = spec.slice(1, spec.length - 1)
            }
          }
          i = i + 1
          scanning = false
        } else if sk == "EOF" {
          scanning = false
        } else {
          i = i + 1
        }
      }
      const key = modResolveSpecifier(spec, modKeys[m])
      let n = 0
      while n < names.length {
        impMod.push(m)
        impSpec.push(spec)
        impKey.push(key)
        impName.push(names[n])
        impLocal.push(locals[n])
        n = n + 1
      }
      if names.length == 0 {
        impMod.push(m)
        impSpec.push(spec)
        impKey.push(key)
        impName.push("")
        impLocal.push("")
      }
    } else if k == "EXPORT" && depth == 0 {
      if i + 1 < toks.length && toks[i + 1].kind == "LBRACE" {
        // A RE-EXPORT `export { a, b as c } from "spec"`: scanned like an import's
        // name list, but each entry is ALSO recorded as a public re-export. The local
        // binding (`as` alias, else the name) is what the import created; the public
        // name is the same alias. Cursor advances past the trailing path STRING.
        i = i + 2 // past EXPORT and LBRACE
        const rnames: string[] = []
        const rlocals: string[] = []
        let rgoing = true
        while rgoing && i < toks.length {
          const ck = toks[i].kind
          if ck == "RBRACE" {
            i = i + 1
            rgoing = false
          } else {
            if ck == "IDENT" {
              let nm = toks[i].text
              let loc = nm
              if i + 2 < toks.length {
                if (
                  toks[i + 1].kind == "IDENT" &&
                  toks[i + 1].text == "as" &&
                  toks[i + 2].kind == "IDENT"
                ) {
                  loc = toks[i + 2].text
                  i = i + 2
                }
              }
              rnames.push(nm)
              rlocals.push(loc)
            }
            i = i + 1
          }
        }
        let rspec = ""
        let rscan = true
        while rscan && i < toks.length {
          const sk = toks[i].kind
          if sk == "STRING" {
            rspec = toks[i].text
            if rspec.length >= 2 {
              if rspec[0] == '"' && rspec[rspec.length - 1] == '"' {
                rspec = rspec.slice(1, rspec.length - 1)
              }
            }
            i = i + 1
            rscan = false
          } else if sk == "EOF" {
            rscan = false
          } else {
            i = i + 1
          }
        }
        const rkey = modResolveSpecifier(rspec, modKeys[m])
        let rn = 0
        while rn < rnames.length {
          // Pull the symbol (an import edge) so the merge binds it and the host fetches `spec`.
          impMod.push(m)
          impSpec.push(rspec)
          impKey.push(rkey)
          impName.push(rnames[rn])
          impLocal.push(rlocals[rn])
          // Record the PUBLIC re-export (its merged target is resolved in `modCompile`).
          reExpMod.push(m)
          reExpPublic.push(rlocals[rn])
          reExpLocal.push(rlocals[rn])
          rn = rn + 1
        }
      } else if i + 2 < toks.length {
        const dk = toks[i + 1].kind
        if dk == "FUNCTION" || dk == "LET" || dk == "CONST" || dk == "TYPE" {
          expMod.push(m)
          expName.push(toks[i + 2].text)
          expDeclLine.push(toks[i + 2].line)
          expDeclCol.push(toks[i + 2].col)
          // The `export` keyword's own span — the target for the "redundant export
          // keyword" hint (an export used locally but imported nowhere).
          expKwLine.push(toks[i].line)
          expKwCol.push(toks[i].col)
        }
        i = i + 1
      } else {
        i = i + 1
      }
    } else {
      i = i + 1
    }
  }
  0
}
function modIndexOfKey(key: string): i32 {
  let i = 0
  while i < modKeys.length {
    if modKeys[i] == key { return i }
    i = i + 1
  }
  -1
}
function modRecomputePending(): i32 {
  modPending = []
  let i = 0
  while i < impKey.length {
    let k = impKey[i]
    if k != "" && modIndexOfKey(k) < 0 {
      if !capHas(modPending, k) { modPending.push(k) }
    }
    i = i + 1
  }
  0
}

// ── module pipeline (order/validate → parse-merge → rename/rewrite) ───────────
// DFS state lives at the top of this file: 0 unvisited, 1 loading (on the stack
// — a back-edge is a cycle), 2 done. `modOrder` collects table indices in
// dependency-first (post) order.
function modDiag(msg: string): i32 {
  if !capHas(modDiags, msg) { modDiags.push(msg) }
  0
}
function modExportsHas(m: i32, name: string): boolean {
  let i = 0
  while i < expMod.length {
    if expMod[i] == m && expName[i] == name { return true }
    i = i + 1
  }
  false
}
// Visit module `m`: resolve + validate its imports (unsupported specifier,
// unresolvable key, cycle back-edge, name-not-exported), recursing into deps
// first. Message texts match the host's `modules.ts` (the corpus `@error`s
// substring them).
function modVisit(m: i32): i32 {
  modState[m] = 1
  let i = 0
  while i < impMod.length {
    if impMod[i] == m {
      let spec = impSpec[i]
      const key = impKey[i]
      if key == "" {
        // Texts mirror the host's `loadProgram` — keep them aligned.
        if modKeyIsStd(modKeys[m]) && modIsRelative(spec) {
          modDiag(
            "Unsupported import specifier \"" +
              spec +
              "\" — std modules import only via `std:` specifiers (relative imports inside std are not allowed)",
          )
        } else {
          modDiag(
            "Unsupported import specifier \"" +
              spec +
              "\" — supported: relative paths (`./`, `../`) and `std:` modules; bare specifiers are not yet implemented",
          )
        }
      } else {
        let d = modIndexOfKey(key)
        if d < 0 {
          modDiag(
            "Cannot resolve import \"" + spec + "\" (no module `" + key + "`)",
          )
        } else if modFound[d] == 0 {
          modDiag(
            "Cannot resolve import \"" + spec + "\" (no module `" + key + "`)",
          )
        } else if modState[d] == 1 {
          modDiag(
            "Import cycle detected through \"" +
              spec +
              "\" (module `" +
              key +
              "`)",
          )
        } else {
          if modState[d] == 0 { modVisit(d) }
          if impName[i] != "" {
            if !modExportsHas(d, impName[i]) {
              modDiag(
                "\"" + impName[i] + "\" is not exported by \"" + spec + "\"",
              )
            }
          }
        }
      }
    }
    i = i + 1
  }
  modState[m] = 2
