}
// The mangled name of a UFCS `self`-function reachable as `.prop(args)` —
// `prop` mapped through the live module's rename map, matched against the
// registry with arity = explicit args + 1 (the receiver fills `self`). Empty
// when `prop` names no such function (an ordinary field/method stays unrenamed).
function modSelfFnTarget(prop: string, argc: i32): string {
  const cand = modRenamed(prop)
  let i = 0
  while i < modSelfFnName.length {
    if modSelfFnName[i] == cand && modSelfFnArity[i] == argc + 1 { return cand }
    i = i + 1
  }
  ""
}
// A VALUE reference: shadowed locals win, then the rename map, else unchanged.
function modRenamed(name: string): string {
  if capHas(modShadow, name) { return name }
  let j = 0
  while j < modRenameFrom.length {
    if modRenameFrom[j] == name { return modRenameTo[j] }
    j = j + 1
  }
  name
}
// A TYPE-position name: annotations are SYNTHETIC strings ("A|B", "Point[]",
// "Box<i32>"), so rewrite identifier SEGMENTS through the rename map (types are
// never shadowed by locals — VL has no local type declarations). Quoted
// string-literal segments (`"a"|"b"`) are copied verbatim.
function modTypeRenamed(tn: string): string {
  let out: i32[] = []
  let run: i32[] = []
  let i = 0
  while i <= tn.length {
    const atEnd = i == tn.length
    let c = 0
    if !atEnd { c = tn[i] }
    let isIdent = false
    if !atEnd {
      if c >= 'a' && c <= 'z' { isIdent = true }
      if c >= 'A' && c <= 'Z' { isIdent = true }
      if c >= '0' && c <= '9' { isIdent = true }
      if c == '_' { isIdent = true }
    }
    if isIdent {
      run.push(c)
    } else {
      if run.length > 0 {
        const seg = fromCodePoints(run)
        run = []
        let rep = seg
        // A live generic type-parameter name is the PARAMETER here, never the
        // top-level binding it may textually collide with.
        if !capHas(modTyShadow, seg) {
          let j = 0
          while j < modRenameFrom.length {
            if modRenameFrom[j] == seg { rep = modRenameTo[j] }
            j = j + 1
          }
        }
        let k = 0
        while k < rep.length {
          out.push(rep[k])
          k = k + 1
        }
      }
      if !atEnd {
        if c == '"' {
          // copy a quoted literal segment verbatim (no escapes in type names)
