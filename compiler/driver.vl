    modTyShadow = modTrimTo(modTyShadow, tySaved)
  }
  0
}
function modRwBlock(ix: i32): i32 {
  let n = P.nodes[ix]
  if n is Block {
    // Block-local `let`/`function` names shadow a same-named top-level binding
    // for the WHOLE block (VL `let` is block-scoped, visible across the block).
    const saved = modShadow.length
    let pre = 0
    while pre < n.blkStmts.length {
      const st = P.nodes[n.blkStmts[pre]]
      if st is LetDecl { modShadow.push(st.letName) }
      if st is FuncDecl {
        if st.fnName != "" { modShadow.push(st.fnName) }
      }
      pre = pre + 1
    }
    let i = 0
    while i < n.blkStmts.length {
      modRwStmt(n.blkStmts[i])
      i = i + 1
    }
    modShadowTrim(saved)
  }
  0
}
function modRwStmt(ix: i32): i32 {
  if ix < 0 { return 0 }
  let n = P.nodes[ix]
  if n is Program {
    let i = 0
    while i < n.progStmts.length {
      modRwStmt(n.progStmts[i])
      i = i + 1
    }
    return 0
  }
  if n is Block { return modRwBlock(ix) }
  if n is LetDecl {
    // The initializer evaluates in the ENCLOSING scope; rewrite it before the
    // name. At the top level the declaration name is RENAMED; in a nested block
    // it is pre-collected into the shadow set, so `modRenamed` is a no-op.
    if n.letInit >= 0 { modRwExpr(n.letInit) }
    modRwType(n.letType)
    n.letName = modRenamed(n.letName)
    return 0
  }
  if n is FuncDecl { return modRwFunc(ix) }
  if n is RetStmt {
    if n.retArg >= 0 { modRwExpr(n.retArg) }
    return 0
  }
  if n is IfStmt {
    modRwExpr(n.ifCond)
    modRwStmt(n.ifThen)
    if n.ifElse >= 0 { modRwStmt(n.ifElse) }
    return 0
  }
  if n is WhileStmt {
    modRwExpr(n.whileCond)
    modRwStmt(n.whileBody)
    return 0
  }
  if n is ForRange {
    modRwExpr(n.frFrom)
    modRwExpr(n.frTo)
    if n.frStep >= 0 { modRwExpr(n.frStep) }
    const frSaved = modShadow.length
    modShadow.push(n.frVar)
    modRwStmt(n.frBody)
    modShadowTrim(frSaved)
    return 0
  }
  if n is ForIn {
    modRwExpr(n.fiIter)
    const fiSaved = modShadow.length
    modShadow.push(n.fiVar)
    modRwStmt(n.fiBody)
    modShadowTrim(fiSaved)
    return 0
  }
  if n is BreakStmt { return 0 }
  if n is ContinueStmt { return 0 }
  if n is TypeDecl {
    // A generic alias's parameters (folded into the declared name) are live
    // across the name and the field annotations.
    const tdTySaved = modTyShadow.length
    const tdPs = modGenParams(n.tdName)
    let tdPi = 0
    while tdPi < tdPs.length {
      modTyShadow.push(tdPs[tdPi])
      tdPi = tdPi + 1
    }
    n.tdName = modTypeRenamed(n.tdName)
    let i = 0
    while i < n.tdFields.length {
      const f = P.nodes[n.tdFields[i]]
      if f is FieldDef { modRwType(f.fdType) }
      i = i + 1
    }
    modTyShadow = modTrimTo(modTyShadow, tdTySaved)
    return 0
  }
  if n is UnionDecl {
    const udTySaved = modTyShadow.length
    const udPs = modGenParams(n.udName)
    let udPi = 0
    while udPi < udPs.length {
      modTyShadow.push(udPs[udPi])
      udPi = udPi + 1
    }
    n.udName = modTypeRenamed(n.udName)
    const vs: string[] = []
    let i = 0
    while i < n.udVariants.length {
      vs.push(modTypeRenamed(n.udVariants[i]))
      i = i + 1
    }
    n.udVariants = vs
    modTyShadow = modTrimTo(modTyShadow, udTySaved)
    return 0
  }
  modRwExpr(ix)
}
function modRwExpr(ix: i32): i32 {
  if ix < 0 { return 0 }
  let n = P.nodes[ix]
  if n is Ident {
    n.identName = modRenamed(n.identName)
    return 0
  }
  if n is Call {
    // A UFCS member-call `recv.prop(args)` whose `prop` names a free
    // `self`-function (matching arity) that the merge MANGLED — same-module
    // (`inc` → `inc$m0`) or imported (`shout` → `shout$m1`). The property string
    // on the `Member` is NOT rewritten (a callable field/struct method of the
    // same name must keep field precedence, which the checker/emitter decide from
    // the receiver TYPE — info the rename walker lacks). Instead, record the
    // plain→mangled alias so the checker's/emitter's UFCS resolution (which runs
    // AFTER the field check, with the plain `prop`) can find the mangled function.
    const cf = P.nodes[n.callFn]
    if cf is Member {
      const target = modSelfFnTarget(cf.memProp, n.callArgs.length)
      if target != "" { ufcsAliasAdd(cf.memProp, target) }
    }
    modRwExpr(n.callFn)
    let i = 0
    while i < n.callArgs.length {
      modRwExpr(n.callArgs[i])
      i = i + 1
    }
    return 0
  }
  if n is Member {
    // The property is a field label, never a top-level binding — receiver only.
    modRwExpr(n.memObj)
    return 0
  }
  if n is OptMember {
    modRwExpr(n.omObj)
    return 0
  }
  if n is Index {
    modRwExpr(n.idxArr)
    modRwExpr(n.idxIndex)
    return 0
  }
  if n is BinExpr {
    modRwExpr(n.binLeft)
    modRwExpr(n.binRight)
    return 0
  }
  if n is Unary {
    modRwExpr(n.unArg)
    return 0
  }
  if n is Paren {
    modRwExpr(n.parInner)
    return 0
  }
  if n is ObjLit {
    let i = 0
    while i < n.objFields.length {
      const f = P.nodes[n.objFields[i]]
      if f is FieldInit { modRwExpr(f.fiValue) }
      i = i + 1
    }
    return 0
  }
  if n is ArrayLit {
    let i = 0
    while i < n.arrElems.length {
      modRwExpr(n.arrElems[i])
      i = i + 1
    }
    return 0
  }
  if n is IsExpr {
    modRwExpr(n.isObj)
    n.isVariant = modTypeRenamed(n.isVariant)
    return 0
  }
  // A `match` (value- or statement-position; `modRwStmt` falls through to here). The merge
  // rename must descend into the scrutinee and EVERY arm body — else an imported / merged
  // name used in an arm (`match k { "a" => sink(1) }`) keeps its bare spelling and resolves
  // to nothing after the export's rename. Patterns are string literals / the `_` wildcard
  // (no renamable identifier), so they are left alone. A body may be a block (its own scope)
  // or a bare expression — `modRwStmt` dispatches both.
  if n is MatchExpr {
    modRwExpr(n.matchScrut)
    let i = 0
    while i < n.matchBodies.length {
      modRwStmt(n.matchBodies[i])
      i = i + 1
    }
    return 0
  }
  if n is FuncDecl { return modRwFunc(ix) }
  0
}
