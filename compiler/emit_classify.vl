// The `$fnsig` PARAM-spine token for the parameter at `paramIx` — one token per distinct
// param VALTYPE, so two functions share a `$fnsig` exactly when their param valtypes
// byte-match. Mirrors `fbValtype`'s coverage (the functype emitter writes
// `fbValtype(vtKindOfParam, paramStructIdxOf)` for each param) and the annotation-string
// scheme in `annParamKind`. Single-char tokens for the FIXED-valtype kinds (every i32 /
// string / closure / list param has an identical valtype); the struct-table index is
// appended (delimited by `;`) for the per-shape kinds (struct, nullable struct, ref list).
// "" for a kind still outside the value-call ABI (union box / variant / map param) — that
// keeps the signature un-interned (a clean "no interned signature" rejection at the call /
// value site, never a mis-lowered all-i32 fallback).
function cloParamTok(paramIx: i32) {
  const k = vtKindOfParam(paramIx)
  // The slot-CARRYING kinds append their interned table slot (struct index /
  // variant index / ref-list slot), so two sigs share a `$fnsig` exactly when
  // the param SHAPES match, not just the kind.
  if k == "struct" || k == "variant" || k == "reflist" {
    return repSigSlotTokOfKind(k, paramStructIdxOf(paramIx))
  }
  // Param-position ABI gate: the nullable-REF kinds (struct|null, string|null —
  // and via the empty table entries i32[]|null, closure|null) still mis-lower as
  // a closure-call param — left "" so the value's signature stays un-interned
  // and the soundness floor (`emitClosureValue`) rejects it with a clear message
  // rather than emitting invalid wasm. (`nulstr`/`nulstruct` DO carry result
  // tokens, so the exclusion must be explicit here.)
  if k == "nulstr" || k == "nulstruct" { return "" }
  // A NULLABLE-closure param (`((i32) => i32) | null`, kind 19) stays OUTSIDE the value-call
  // ABI (only nullable-closure RESULTS are wired — the closure result carries the niche).
  // `repSigTokOfKind("nulclosure")` now yields a RESULT token (`C`), so exclude it explicitly
  // here (like map/nulstr/nulstruct) — else a nulclosure param would key a slot-less `C` and
  // mis-lower. The soundness floor rejects a nulclosure-param value with a clear message.
  if k == "nulclosure" { return "" }
  // A MAP param stays OUTSIDE the value-call ABI (only map RESULTS are wired — the closure
  // result carries the map shape). `repSigTokOfKind("map")` now yields a result token, so
  // exclude it explicitly here (like `nulstr`/`nulstruct`) — else a map param would key a
  // slot-less `m` and mis-lower. The soundness floor rejects a map-param value with a clear
  // message.
  if k == "map" { return "" }
  // A NULLABLE-list param (`i32[] | null`, kind 15) stays OUTSIDE the value-call ABI
  // (only nullable-list RESULTS are wired — the closure result carries the niche).
  // `repSigTokOfKind("nullist")` now yields a RESULT token (`o`), so exclude it
  // explicitly here (like map/nulstr/nulstruct/nulclosure) — else a nullable-list param
  // would key a slot-less `o` and mis-lower. The soundness floor rejects it loudly.
  if k == "nullist" { return "" }
  // Every slot-free kind reads the shared canonical token table (emit_rep) —
  // "" for the kinds outside the value-call ABI (scalar lists, niches).
  repSigTokOfKind(k)
}

// The interning KEY for lifted function `fe`'s env-leading `$fnsig`, or "" when the
// signature is not function-value-eligible (a void / closure-returning function, or a
// param/return kind outside the `cloParamTok` / value-result ABI). The key encodes the
// param kinds (`cloParamTok`) and the return kind, so two functions share one `$fnsig`
// exactly when their env-leading functypes are byte-identical. `fnSigKeyOf` is the
// value-eligible (i32/f64-result) variant; `cloSigKeyExt` extends the RESULT spine.
export function fnSigKeyOf(fe: i32) {
  if fe < 0 || fe >= fnStmts.length { return "" }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    let key = ""
    const params = fn.fnParams
    let pi = 0
    while pi < params.length {
      const tok = cloParamTok(params[pi])
      if tok == "" { return "" }
      key = key + tok
      pi = pi + 1
    }
    const r = cloRetKindOf(fe)
    if r == "i32" { return key + ">" + repSigTokOfKind("i32") }
    if r == "f64" { return key + ">" + repSigTokOfKind("f64") }
    return ""
  }
  ""
}

// The VALUE-ABI return kind of lifted function `fe` for `$fnsig` purposes: `"i32"`
// (i32/boolean), `"f64"`, or `null` (void / closure-returning / any other kind).
// Annotated returns read the annotation; un-annotated ones ride the stored return
// kind, plus a registry-INDEPENDENT f64 tail check (`tailIsF64NoLocal` — the
// general `exprIsF64` consults the per-function locals registry, whose contents
// depend on WHICH function is currently being emitted, so the key must not use it).
export function cloRetKindOf(fe: i32): VKind | null {
  if fe < 0 || fe >= fnStmts.length { return null }
  if fe >= fRetVoid.length { return null }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    if fRetVoid[fe] == 1 { return null }
    if fnReturnsClosure(fe) { return null }
    if fn.fnRet >= 0 {
      const k = vtKindOfType(fn.fnRet)
      if k == "i32" { return "i32" }
      if k == "f64" { return "f64" }
      return null
    }
    // Un-annotated: any inferred ref/i64/f32 kind is out of the value ABI; an f64
    // tail is `"f64"`; everything else (i32 / boolean) rides the i32 result. The
    // `"nulstr"` niche deliberately falls through with `"i32"` — the historical flag
    // ladder here never consulted `fRetNulStr`, so it kept riding the i32 result.
    const irk = fRetKind[fe]
    if irk == "f64" { return "f64" }
    if irk != "i32" && irk != "nulstr" { return null }
    if tailIsF64NoLocal(fnRetExprOf(fnStmts[fe]), fnStmts[fe]) { return "f64" }
    return "i32"
  }
  null
}

// Whether the lifted callback at `fe` returns a STRING — its annotation (`: string`) or the
// inferred `"str"` kind. `cloRetKindOf` folds string into `null` (it is outside the i32/f64
// value ABI), so `.map`/`.filter` consult this separately to pick the string-list result kind.
export function cloRetIsString(fe: i32) {
  if fe < 0 || fe >= fnStmts.length { return false }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    if fn.fnRet >= 0 { return nameIsString(tyNameOf(fn.fnRet)) }
    if fe < fRetKind.length { return fRetKind[fe] == "str" }
  }
  false
}

// Registry-independent f64-ness of a lifted callback's tail expression: float
// literals, f64 PARAMS, f64 arithmetic over those, and f64-returning named calls.
// Deliberately avoids `declaredF64`/`declaredSlotOf` (the locals registry belongs to
// whichever function is currently being emitted), so the answer is STABLE whether
// asked during sig collection or during section emission.
function tailIsF64NoLocal(ix: i32, fnArenaIx: i32) {
  if ix < 0 { return false }
  const e = P.nodes[ix]
  if e is NumLit { return numTextIsFloat(e.numText) }
  if e is Paren { return tailIsF64NoLocal(e.parInner, fnArenaIx) }
  if e is Ident { return paramIsF64(fnArenaIx, e.identName) }
  if e is BinExpr {
    const op = e.binOp
    if op == "+" || op == "-" || op == "*" || op == "/" {
      if tailIsF64NoLocal(e.binLeft, fnArenaIx) { return true }
      return tailIsF64NoLocal(e.binRight, fnArenaIx)
    }
    return false
  }
  if e is Unary {
    if e.unOp == "-" { return tailIsF64NoLocal(e.unArg, fnArenaIx) }
    return false
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const t = fnIndexOf(callee.identName)
      if t >= 0 {
        if t < fRetKind.length { return fRetKind[t] == "f64" }
      }
    }
    return false
  }
  false
}

// The lifted-function position (`fnStmts` index) of an object-literal FIELD
// VALUE that is a function: an inline lambda (`FuncDecl` node — lifted in place,
// so its arena index appears in `fnStmts`) or a bare Ident naming a function.
// -1 for any other field value.
export function fieldValueFeOf(valIx: i32) {
  if valIx < 0 { return -1 }
  const v = P.nodes[valIx]
  if v is FuncDecl { return fnStmtsPosOf(valIx) }
  if v is Ident { return fnIndexOf(v.identName) }
  -1
}

// The historical override-chain PRIORITY of a stored return kind — the position its
// per-family flag held in the deleted `retKindChainOf` ladder (LAST-MATCH won, so a
// higher position overrode a lower one; a struct-UNION return set both the union and
// struct flags, and the later struct arm won). `criSetRetKind` lands a write only when
// it outranks the current kind, so the eager per-fact writes resolve to EXACTLY the
// kind the old post-fixpoint chain snapshot computed. The wide scalars share the top
// tier: they were the chain's final override, and are mutually exclusive with each
// other by the `"i32"`-guarded write sites.
function retKindPri(k: VKind) {
  if k == "str" { return 1 }
  if k == "list" { return 2 }
  if k == "union" { return 3 }
  if k == "struct" { return 4 }
  if k == "nulstruct" { return 5 }
  if k == "reflist" { return 6 }
  if k == "strlist" { return 7 }
  if k == "f64list" { return 8 }
  if k == "i64list" { return 9 }
  if k == "f32list" { return 10 }
  if k == "map" { return 11 }
  if k == "nulstr" { return 12 }
  if k == "i64" { return 13 }
  if k == "f64" { return 13 }
  if k == "f32" { return 13 }
  0
}

// True if `k` is one of the LIST return kinds (the old `fRetListKind != 0`) — the
// shared not-yet-a-list guard of `criClassify`'s list arms.
function retKindIsList(k: VKind) {
  k == "list" ||
    k == "reflist" ||
    k == "strlist" ||
    k == "f64list" ||
    k == "i64list" ||
    k == "f32list"
}

// Store an inferred return-kind FACT for function `i`: the write lands only when it
// outranks the current kind in the historical override-chain priority (`retKindPri`),
// marking the `computeRetInference` fixed point dirty. True exactly when the write
// landed — the struct/nulstruct arms gate their `fRetStructIdx` payload on it.
function criSetRetKind(i: i32, k: VKind) {
  if retKindPri(k) > retKindPri(fRetKind[i]) {
    fRetKind[i] = k
    criChanged = true
    return true
  }
  false
}

// The stored return kind of an ANNOTATED return-type node `tyIx` — the annotation
// flag producers applied in the historical `retKindChainOf` order (LAST-MATCH wins),
// so `buildFnMap`'s seed byte-matches what the old per-flag tables resolved to. An
// i64/f32 LIST annotation never flagged here (those codes were only ever inferred —
// an annotated `i64[]` return rides the typed-IR path), so the producer set is
// deliberately unchanged. A union-VARIANT annotation (`: Cat`) stays `"i32"` with its
// variant index in `fRetStructIdx`, exactly as the flag tables left it.
export function retAnnKindChain(tyIx: i32): VKind {
  let k: VKind = "i32"
  if retStrFlag(tyIx) == 1 { k = "str" }
  const lk = retListKindFlag(tyIx)
  if lk == 2 { k = "list" }
  if retUnionFlag(tyIx) == 1 { k = "union" }
  if retTRFlag(tyIx) == 1 { k = "struct" }
  if retNulRefFlag(tyIx) == 1 { k = "nulstruct" }
  if lk == 5 { k = "reflist" }
  if lk == 7 { k = "strlist" }
  if lk == 12 { k = "f64list" }
  if retMapFlag(tyIx) == 1 { k = "map" }
  if retNulStringFlag(tyIx) == 1 { k = "nulstr" }
  if retI64Flag(tyIx) == 1 { k = "i64" }
  if retF64Flag(tyIx) == 1 { k = "f64" }
  if retF32Flag(tyIx) == 1 { k = "f32" }
  k
}

// The RESULT valtype KIND of a function's return — the stored `fRetKind` slot
// (seeded by `buildFnMap`, refined by `computeRetInference`'s eager writes).
export function inferredRetKindCore(ti: i32): VKind { fRetKind[ti] }

// The RESULT valtype KIND of lifted function `fe`'s `$fnsig` functype — the same kind the
// function's OWN functype emits, read from an annotation (`vtKindOfType`) or the inferred
// stored return kind, so the closure functype byte-matches the callee. -1 for void (0 results)
// and for the kinds still outside the value-call ABI (a ref-list / closure return — `5` /
// `14` are minted by their own paths, not here). The slot (struct index for kinds 1 / 9)
// comes from `cloRetValSlot`.
export function cloRetValKind(fe: i32): VKind | null {
  if fe < 0 || fe >= fnStmts.length { return null }
  if fe >= fRetVoid.length { return null }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    if fRetVoid[fe] == 1 { return null }
    if fn.fnRet >= 0 {
      if tyIsFuncType(fn.fnRet) { return "closure" }
      return vtKindOfType(fn.fnRet)
    }
    if fnReturnsClosure(fe) { return "closure" }
    // A callback that COLLAPSES to one concrete variant (`(a) => if a is Cat { a } else {
    // catShape }`) — the checker types it as that variant, so the `$fnsig` result is the
    // variant struct (kind 8), NOT the union box. Checked BEFORE the `"union"` kind, which
    // the emitter's syntactic inference also stores for the narrowed receiver arm.
    if cbRetVariantIdx(fe) >= 0 { return "variant" }
    // The shared inferred-return-kind mapping (the SAME one the named-function functype result
    // uses) — so a scalar/list/ref kind added there is reflected here too. The closure-specific
    // cases (closure / variant-collapse above; the `tailIsF64NoLocal` backup below) are layered
    // around it.
    const core = inferredRetKindCore(fe)
    if core != "i32" { return core }
    // An f64 tail with no intervening local (a `.map`/`.filter` callback `n => n * 2.0`)
    // — its f64-ness is detected structurally, not via `fRetF64` (mirrors the old
    // `cloRetKindOf`; without this the callback's functype declared i32 over an f64 body).
    if tailIsF64NoLocal(fnRetExprOf(fnStmts[fe]), fnStmts[fe]) { return "f64" }
    return "i32"
  }
  null
}

// The struct-table slot for `fe`'s result valtype — a real index only for a struct (kind
// 1) or nullable-struct (kind 9) return, `-1` otherwise.
export function cloRetValSlot(fe: i32) {
  if fe < 0 || fe >= fnStmts.length { return -1 }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    if fn.fnRet >= 0 {
      const k = vtKindOfType(fn.fnRet)
      if k == "struct" || k == "nulstruct" { return retStructIndex(fn.fnRet) }
      // A `: Cat` annotated variant result (kind 8) — the slot is the VARIANT index.
      if k == "variant" { return variantIndexOf(tyNameOf(fn.fnRet)) }
      // A `: S[]` / `: ((i32) => i32)[]` annotated REF-LIST result (kind 5) — the slot is the
      // ref-list slot (`rlWrapIdx`-bearing), the dual of a `cloParamTok` kind-5 param's slot.
      if k == "reflist" { return tyAnnRefListSlot(fn.fnRet) }
      // A `: {[string]: V}` annotated MAP result (kind 6) — the slot is the map SHAPE (mono ⇒
      // -1, or the value type's mv slot), so the `$fnsig` result selects THIS map's `$mapStruct`.
      if k == "map" { return mapAnnShape(fn.fnRet) }
      return -1
    }
    // A collapsed-to-one-variant inferred result (kind 8) — the variant index.
    const cvi = cbRetVariantIdx(fe)
    if cvi >= 0 { return cvi }
    const srk = fRetKind[fe]
    if srk == "struct" { return fRetStructIdx[fe] }
    if srk == "nulstruct" { return fRetStructIdx[fe] }
    // An INFERRED map return (`() => (h)` over a captured/local map) — the map SHAPE from the
    // return expression (`mapRetExprShape`, capture-aware), so the `$fnsig` result matches the
    // returned map value's typed `$mapStruct`.
    if srk == "map" {
      const mrx = fnRetExprOf(fnStmts[fe])
      if mrx >= 0 { return mapRetExprShape(mrx, fnStmts[fe]) }
    }
    // An inferred ref-list return (`() => [{…}]` / `() => [(x) => …]`, kind 5) — its element
    // NAME (`fRetRArrElem`, set by the return-classify scan) resolves the ref-list slot.
    if srk == "reflist" { return rlSlotByName(fRetRArrElem[fe]) }
  }
  -1
}

// The `>X` RESULT suffix of `fe`'s extended `$fnsig` key — one token per distinct result
// functype shape, so two functions share a sig iff their params AND result byte-match.
// Mirrors `cloRetValKind`: `>i`/`>d`/`>I` scalars, `>S` string, `>a`/`>A`/`>D` the i32/
// string/f64 lists, `>u` a union box, `>N` `string | null`, `>sN;`/`>nN;` a struct /
// nullable-struct. "" for the kinds not yet value-callable (a `>v` void is handled by the
// caller; ref-list `5` and closure `14` returns are a later slice).
function cloRetKeySuffix(fe: i32) {
  const k = cloRetValKind(fe)
  // The slot-CARRYING result kinds: a struct / nullable-struct result keyed by
  // its struct index, a concrete-VARIANT result by its variant index — so two
  // callbacks share a sig iff they return the SAME shape.
  if k == "struct" || k == "nulstruct" || k == "variant" {
    return ">" + repSigSlotTokOfKind(k, cloRetValSlot(fe))
  }
  // A MAP result carries its map SHAPE slot (`cloRetValSlot` → the mv slot; mono = -1), so
  // two map-returning closures share a `$fnsig` exactly when their value types match, and the
  // `$fnsig` result `(ref $mapStruct)` selects THIS map's struct — the heap type the returned
  // map value and the closure's env field both carry. Makes a map-returning closure
  // representable (a non-empty key) instead of tripping the soundness floor.
  if k == "map" { return ">" + repSigSlotTokOfKind(k, cloRetValSlot(fe)) }
  // A REF-LIST result (`S[]` / `((i32) => i32)[]` / a union list): the `$fnsig`
  // result is the ref-list WRAPPER ref (slot = `cloRetValSlot`), recovered
  // non-null at the value-call site like every other ref result — the result
  // dual of the `r<idx>;` PARAM token. No resolved slot → no sig.
  if k == "reflist" {
    const rs = cloRetValSlot(fe)
    if rs >= 0 { return ">" + repSigSlotTokOfKind(k, rs) }
    return ""
  }
  // Every slot-free kind reads the shared canonical token table (emit_rep):
  // the scalars, string, the i32/string/f64 list wrappers, the union box, the
  // `string | null` niche, and a CLOSURE result (a function returning a
  // function — the shared fat-pointer, so a curried lambda lowers as a
  // callable value). "" (no sig) for the kinds still outside the value ABI —
  // and for a void/unresolved result (`null`), which the CALLER key-builds
  // as `>v` before consulting this suffix.
  const t = repSigTokOfKind(k)
  if t == "" { return "" }
  ">" + t
}

// The EXTENDED `$fnsig` key of lifted function `fe`: `fnSigKeyOf`'s key when the sig is
// value-eligible, else the same param spine with the extended RESULT suffix
// (`cloRetKeySuffix`) — void, the i32/string/f64 lists, a union box, a nullable scalar/
// struct, a struct ref. "" when any param OR the result kind is still outside the ABI.
export function cloSigKeyExt(fe: i32) {
  const base = fnSigKeyOf(fe)
  if base != "" { return base }
  if fe < 0 || fe >= fnStmts.length { return "" }
  if fe >= fRetVoid.length { return "" }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    const params = fn.fnParams
    let key = ""
    let pi = 0
    while pi < params.length {
      const tok = cloParamTok(params[pi])
      if tok == "" { return "" }
      key = key + tok
      pi = pi + 1
    }
    if fRetVoid[fe] == 1 { return key + ">v" }
    const suf = cloRetKeySuffix(fe)
    if suf == "" { return "" }
    return key + suf
  }
  ""
}

// The lifted-function position of the closure held by FIELD `prop` of struct
// `si`, resolved through the object LITERAL(s) that intern shape `si` — every
// literal of one shape carries sig-identical closures (monomorphized instances
// included), so the first match types the call. -1 when no literal of shape
// `si` sets a function-valued `prop`.
function fieldClosureFeOf(si: i32, prop: string) {
  if si < 0 { return -1 }
  let ai = 0
  while ai < P.nodes.length {
    const an = P.nodes[ai]
    if an is ObjLit {
      if structIndexOfObj(ai) == si {
        const ffe = fieldValueFeOf(objFieldVal(ai, prop))
        if ffe >= 0 { return ffe }
      }
    }
    ai = ai + 1
  }
  -1
}

// The lifted-function position of the closure a member call `recv.prop(...)`
// dispatches to, resolved as precisely as possible: first by following the
// RECEIVER to the literal that built it (a `const o = make(...)` whose maker
// returns an object literal — so two same-shaped receivers from different
// monomorphized makers each resolve their OWN closure), else by the receiver's
// struct SHAPE (`fieldClosureFeOf`). -1 when neither resolves.
export function fieldClosureFeOfRecv(recvIx: i32, prop: string, fnIx: i32) {
  const e = P.nodes[unwrapParen(recvIx)]
  if e is Ident {
    let li = -1
    if fnIx >= 0 {
      const fn = P.nodes[fnIx]
      if fn is FuncDecl { li = parentLetOf(fn.fnBody, e.identName) }
    }
    if li < 0 { li = globalLetOf(e.identName) }
    if li >= 0 {
      const d = P.nodes[li]
      if d is LetDecl {
        const ffe = fieldClosureFeOfInit(d.letInit, prop)
        if ffe >= 0 { return ffe }
      }
    }
  }
  if e is Call {
    const ffe2 = fieldClosureFeOfInit(unwrapParen(recvIx), prop)
    if ffe2 >= 0 { return ffe2 }
  }
  fieldClosureFeOf(structIndexOfExpr(recvIx, fnIx), prop)
}

// The MAKER function (`fnStmts` position) whose tail object literal built the
// receiver expression at `recvIx`: a direct `make(...)` call, or an ident bound
// (let/global) to one. -1 when the receiver's origin is not a maker call.
function recvMakerFnOf(recvIx: i32, fnIx: i32) {
  const e = P.nodes[unwrapParen(recvIx)]
  let initIx = unwrapParen(recvIx)
  if e is Ident {
    let li = -1
    if fnIx >= 0 {
      const fn = P.nodes[fnIx]
      if fn is FuncDecl { li = parentLetOf(fn.fnBody, e.identName) }
    }
    if li < 0 { li = globalLetOf(e.identName) }
    if li < 0 { return -1 }
    const d = P.nodes[li]
    if d is LetDecl { initIx = unwrapParen(d.letInit) } else { return -1 }
  }
  const ie = P.nodes[initIx]
  if ie is Call {
    const callee = P.nodes[ie.callFn]
    if callee is Ident { return fnIndexOf(callee.identName) }
  }
  -1
}

// The annotation NAME of parameter `name` of the lifted function at `fe` ("" if
// not a param / un-annotated).
function feParamTyName(fe: i32, name: string) {
  if fe < 0 || fe >= fnStmts.length { return "" }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    const params = fn.fnParams
    let i = 0
    while i < params.length {
      const p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name { return tyNameOf(p.parType) }
      }
      i = i + 1
    }
  }
  ""
}

// BOOLEAN-ness of a field-closure trap call `recv.prop(...)`. Monomorphized
// maker instances SHARE the closure body, so the closure's own inferred return
// kind cannot distinguish `wrap(true)` from `wrap(99)` — instead, follow the
// receiver to ITS maker instance and read the closure's tail through the
// instance's pinned param annotations (`function(_k) x` with the instance's
// `x: boolean` → true). Falls back to the shared closure's `fRetBool`.
function fieldCloCallIsBool(recvIx: i32, prop: string, fnIx: i32) {
  const mk = recvMakerFnOf(recvIx, fnIx)
  if mk >= 0 {
    const rx = fnRetExprOf(fnStmts[mk])
    if rx >= 0 {
      const re = P.nodes[unwrapParen(rx)]
      if re is ObjLit {
        const v = objFieldVal(unwrapParen(rx), prop)
        if v >= 0 {
          const vf = P.nodes[v]
          if vf is FuncDecl {
            const vRet = vf.fnRet
            if vRet >= 0 { return tyNameOf(vRet) == "boolean" }
            const tx = fnRetExprOf(v)
            if tx >= 0 {
              const te = P.nodes[unwrapParen(tx)]
              if te is Ident {
                const ptn = feParamTyName(mk, te.identName)
                if ptn != "" { return ptn == "boolean" }
              }
              return exprIsBool(tx, v)
            }
          }
        }
      }
    }
  }
  const bfe = fieldClosureFeOfRecv(recvIx, prop, fnIx)
  if bfe >= 0 {
    const bfn = P.nodes[fnStmts[bfe]]
    if bfn is FuncDecl {
      if bfn.fnRet >= 0 { return tyNameOf(bfn.fnRet) == "boolean" }
    }
    if bfe < fRetBool.length { return fRetBool[bfe] == 1 }
  }
  false
}

// Resolve `prop`'s closure through an INITIALIZER expression: an object literal
// reads its own field; a call to a maker follows the maker's return expression
// (its tail object literal). -1 otherwise.
function fieldClosureFeOfInit(initIx: i32, prop: string) {
  if initIx < 0 { return -1 }
  const e = P.nodes[unwrapParen(initIx)]
  if e is ObjLit {
    return fieldValueFeOf(objFieldVal(unwrapParen(initIx), prop))
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const t = fnIndexOf(callee.identName)
      if t >= 0 {
        const rx = fnRetExprOf(fnStmts[t])
        if rx >= 0 {
          const re = P.nodes[unwrapParen(rx)]
          if re is ObjLit {
            return fieldValueFeOf(objFieldVal(unwrapParen(rx), prop))
          }
        }
      }
    }
  }
  -1
}

// The position of `key` in `cloSigKeys`, or -1.
export function cloSigPosOfKey(key: string) {
  let i = 0
  while i < cloSigKeys.length {
    if cloSigKeys[i] == key { return i }
    i = i + 1
  }
  -1
}

// The `$fnsig` type index for lifted function `fe`'s own signature, or -1 when its
// signature is not value-eligible / not interned. The EXTENDED key (`cloSigKeyExt`)
// equals the value-ABI key for an eligible sig; a void / struct-returning FIELD
// closure resolves its interned `>v`/`>sN;` sig (so its function-section type IS
// that `$fnsig` and the trap call site's `ref.cast` accepts it); any other
// non-eligible sig stays -1 (its ext key is never interned).
export function fnSigIdxOfFn(fe: i32) {
  const key = cloSigKeyExt(fe)
  if key == "" { return -1 }
  const p = cloSigPosOfKey(key)
  if p < 0 { return -1 }
  cloSigBase + p
}

// The type index of the all-i32 `$fnsig` functype for value-call arity `ar`
// (`(structref, i32 * ar) -> i32`) — the signature every GENERIC value call (a
// let-bound / param / field closure `f(args)`) dispatches through. -1 if not interned.
export function fnSigIdxForArity(ar: i32) {
  let key = ""
  let i = 0
  while i < ar {
    key = key + repSigTokOfKind("i32")
    i = i + 1
  }
  const p = cloSigPosOfKey(key + ">" + repSigTokOfKind("i32"))
  if p < 0 { return -1 }
  cloSigBase + p
}

// The wasm global index for `name`, or -1 if no top-level global has that name.
export function globalIndexOf(name: string) { globalNameMap[name] ?? -1 }

// The arena index of the `LetDecl` for the global `name`, or -1 if not a global.
export function globalLetOf(name: string) {
  const gi = globalIndexOf(name)
  if gi < 0 { return -1 }
  globalStmts[gi]
}

// Whether the global `name` is a struct/array/string ref (so a bare reference to it in
// an `exprStruct`/`exprArray`/`exprString` check is recognized as that ref type). The
// global's valtype follows its `LetDecl` annotation or literal initializer, evaluated as
// a top-level constexpr (`fnIx = -1`), mirroring the local `letIsX` predicates.
function globalIsStruct(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return false }
  letIsStruct(li, -1)
}

function globalIsArray(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return false }
  letIsArray(li, -1)
}

function globalIsString(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return false }
  // A `string | null` (kind 16) global reads AS a string under narrowing — the global
  // read recovers non-null (`ref.as_non_null`), and the `!= null` check reads it raw.
  letIsString(li, -1) || letIsNulString(li, -1)
}

function globalIsRefArray(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return false }
  letIsRefArray(li, -1)
}

function globalIsStringArray(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return false }
  letIsStringArray(li, -1)
}

function globalIsMap(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return false }
  letIsMap(li, -1)
}

function globalIsF64Array(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return false }
  letIsF64Array(li, -1)
}

function globalIsNulRef(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return false }
  letIsNulRef(li, -1)
}

function globalIsNulList(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return false }
  letIsNulList(li, -1)
}

// True if the parameter `name` of function `fnIx` is a nullable struct (`S | null`).
function paramNulRef(fnIx: i32, name: string) {
  retNulRefFlag(paramTypeNode(fnIx, name)) == 1
}

// True if the parameter `name` of function `fnIx` is a NULLABLE map (`{[string]: V} | null`,
// kind `nulmap`). The map twin of `paramNulRef`/`paramNulRefArray`.
export function paramNulMap(fnIx: i32, name: string) {
  retNulMapFlag(paramTypeNode(fnIx, name)) == 1
}
// True if the global `name` is a NULLABLE map.
function globalIsNulMap(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return false }
  letIsNulMap(li, -1)
}

// True if the function `name` returns a nullable struct (`"nulstruct"`).
function fnRetNulRef(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetKind[i] == "nulstruct"
}

// True if the `LetDecl` at `letIx` declares a nullable-struct local: its annotation
// is `S | null`, OR its initializer produces one (a nullable-returning call).
export function letIsNulRef(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      if retNulRefFlag(d.letType) == 1 { return true }
    }
    return exprNullableStruct(d.letInit, fnIx)
  }
  false
}

// A bare `m[k]` map read is `V | null`. A struct (kind 9), string (16), or closure (19) value
// binds a supported nullable local — but a UNION (mv kind 2) or ref-LIST (mv kind 6) value has no
// nullable local rep, so the bare read would lower to a non-null local while `emitMapGet` yields a
// `(ref null …)`: invalid wasm. Detect that shape so the binding is a CLEAN reject (use `m[k] ??
// <default>`, which loads the non-null value) instead. Gated to un-annotated bindings — an
// annotation drives the kind explicitly and is classified before this.
export function letBareUnwiredNulMapRead(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 { return false }
    const mrs = mapReadMvSlot(d.letInit, fnIx)
    if mrs >= 0 {
      const k = mvValKind[mrs]
      return k == 2 || k == 6
    }
  }
  false
}

// True if evaluating the expression at `exprIx` yields a NULLABLE i32-list ref —
// a nullable-list-annotated param/local/global reference or a `rest: i32[]|null`
// FIELD read (code 18). The nullable-LIST dual of `exprNullableStruct`: list-op
// read sites consult it to insert the `ref.as_non_null` recover (the checker
// proved every such read guarded, so the cast can never trap).
export function exprNullableList(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Paren { return exprNullableList(e.parInner, fnIx) }
  if e is Ident {
    if paramNulList(fnIx, e.identName) { return true }
    if declaredNulList(e.identName) { return true }
    return globalIsNulList(e.identName)
  }
  if e is Member { return memberFieldCode(exprIx, fnIx) == 18 }
  // Indexing a `(i32[] | null)[]` (a kind-4 ref list whose element slot keeps the `| null`) yields a
  // NULLABLE i32 list — the read left it `(ref null $lTypeIdx)`, so `const t = xs[i]; if t != null` narrows.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemNullable.length {
        if rlElemKindTbl[slot] == 4 && rlElemNullable[slot] == 1 { return true }
      }
    }
  }
  // A call to a function whose ANNOTATED return is `i32[] | null` yields a nullable list, so an
  // un-annotated `const r = f(…)` infers kind 15 (and narrows with `if r != null`). Mirrors the
  // niche-nullable call inference for bool/string returns.
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const target = fnIndexOf(callee.identName)
      if target >= 0 {
        const fn = P.nodes[fnStmts[target]]
        if fn is FuncDecl {
          if fn.fnRet >= 0 { return retNulListFlag(fn.fnRet) == 1 }
        }
      }
      // A closure-VALUE call (`v()` with `v: () => boolean[] | null` — a binding or a
      // param) whose resolved sig result is the nullable i32-backed list (`>o`), so an
      // un-annotated `const t0 = v()` infers kind 15 and narrows with `if t0 != null`.
      return calleeRetKind(callee.identName, fnIx) == "nullist"
    }
  }
  false
}

// True if `exprIx` yields a NULLABLE REF-ARRAY (`i32[][] | null` etc., LOCAL kind 18) — the ref-array
// analogue of `exprNullableList`. An `Index` over a `(<ref-array> | null)[]` (a kind-9 ref list whose
// element slot keeps the `| null`) reads `(ref null $innerWrapper)`, so `const t = xs[i]; if t != null`.
export function exprNullableRefArray(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Paren { return exprNullableRefArray(e.parInner, fnIx) }
  if e is Ident {
    if declaredKind(e.identName) == "nulreflist" { return true }
    // A nulreflist PARAM (`p: i32[][] | null`) — its `!= null` narrow reads the `(ref null $wrapper)`
    // niche exactly like the local. (#877 wired the param signature but left this body-side arm.)
    return paramNulRefArray(fnIx, e.identName)
  }
  // A `recv.f` read of a NULLABLE ref-list FIELD (`f: S[] | null`, code 28) yields a nullable ref array.
  if e is Member { return memberFieldCode(exprIx, fnIx) == 28 }
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemNullable.length {
        if rlElemKindTbl[slot] == 9 && rlElemNullable[slot] == 1 { return true }
      }
    }
  }
  // A call to a function whose ANNOTATED return is `<ref-array> | null` yields a nullable ref array, so an
  // un-annotated `const t = mk(…)` infers kind 18 and narrows with `if t != null`. Mirrors the nullable-i32
  // -list call inference in `exprNullableList` above.
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetNulRefArrayName(callee.identName) != "" { return true }
    }
  }
  false
}

// The INNER ref-list slot of a nullable ref-array expression — a kind-18 LOCAL stores it in
// `localStructIdx`; an `Index` `v[i]` over a `(<ref-array> | null)[]` resolves it from the kind-9 element
// (its inner = `refArrElemName` of the element name, which recurses through the `| null`).
function nulRefArrayInnerSlot(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return -1 }
  const e = P.nodes[exprIx]
  if e is Paren { return nulRefArrayInnerSlot(e.parInner, fnIx) }
  if e is Ident {
    const sl = declaredSlotOf(e.identName)
    if sl >= 0 { return localStructIdx[sl] }
    // A nulreflist PARAM has no local slot — resolve its inner ref-list slot from the annotation
    // (`refArrElemName` of the `| null`-stripped ref-array name), so `p[i]` and `const t = p` agree.
    if paramNulRefArray(fnIx, e.identName) {
      const npS = nullablePartOf(tyNameOf(paramTypeNode(fnIx, e.identName)))
      if npS != "" { return rlSlotByName(refArrElemName(npS)) }
    }
    return -1
  }
  // A code-28 nullable ref-list field member: its element ref-list slot (the field's element name).
  if e is Member {
    if memberFieldCode(exprIx, fnIx) == 28 {
      return refListSlotOfExpr(exprIx, fnIx)
    }
    return -1
  }
  if e is Index {
    const slot = refListSlotOfExpr(e.idxArr, fnIx)
    if slot >= 0 && slot < rlElemName.length {
      return rlSlotByName(refArrElemName(rlElemName[slot]))
    }
  }
  // A nulreflist-returning CALL (`const t = mk()`): its inner ref-list slot is the return's inner element.
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const rn = fnRetNulRefArrayName(callee.identName)
      if rn != "" { return rlSlotByName(rn) }
    }
  }
  -1
}

// Binding test for a kind-18 nullable ref-array local: annotation `<ref-array> | null`, else an
// un-annotated init that yields a nullable ref array.
export function letIsNulRefArray(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        const np = nullablePartOf(lt.tyName)
        // A value-union-element inner (`(i32|null)[] | null`) is excluded — its annotated-local value
        // build is not yet supported, so it falls through to a clean reject rather than the kind-18 path
        // (which traps). A struct / nested-array inner is fine. The INFERRED path below is unaffected.
        if np != "" && nameIsRefArray(np) { return true }
      }
      return false
    }
    return exprNullableRefArray(d.letInit, fnIx)
  }
  false
}

// The inner ref-list slot to store for a kind-18 binding — from its annotation (`<ref-array> | null` →
// the ref-array's element slot) or its initializer.
export function nulRefArrayInnerSlotOfLet(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        const np = nullablePartOf(lt.tyName)
        if np != "" { return rlSlotByName(refArrElemName(np)) }
      }
      return -1
    }
    return nulRefArrayInnerSlot(d.letInit, fnIx)
  }
  -1
}

// Annotation-OR-init nullable-i32-list test for a BINDING: the annotation (`letIsNulList`), else an
// UN-ANNOTATED `const t = <nullable-i32-list expr>` — e.g. a code-18 field read `const t = v.f` where
// `v.f: i32[] | null`. Without the init inference such a binding took a non-null list kind, so `t != null`
// emitted a bare `null` with no list context. Mirrors `letIsNulString`'s init fallback for nullable strings.
export function letIsNulListInfer(letIx: i32, fnIx: i32) {
  if letIsNulList(letIx, fnIx) { return true }
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType < 0 { return exprNullableList(d.letInit, fnIx) }
  }
  false
}

// The DISTINCT-backing nullable-scalar-list VKind of a BINDING (`const v: string[]|null = …`), or
// "" — the annotation's `nulScalarListKind`, else an un-annotated init that yields such a list (a
// `string[]|null`-returning call / field read). Feeds the local-slot + null-seed classification.
export function letNulScalarListKind(letIx: i32, fnIx: i32): VKind | null {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 { return nulScalarListKindOfNode(d.letType) }
    return exprNulScalarListKind(d.letInit, fnIx)
  }
  null
}

// The nullable-scalar-list VKind an EXPRESSION yields (a `string[]|null`-returning call), or "" —
// the per-leaf analogue of `exprNullableList`'s call-inference arm (an un-annotated `const r = f()`).
export function exprNulScalarListKind(exprIx: i32, fnIx: i32): VKind | null {
  if exprIx < 0 { return null }
  const e = P.nodes[exprIx]
  if e is Paren { return exprNulScalarListKind(e.parInner, fnIx) }
  if e is Ident {
    // A nullable-scalar-list PARAM, a same-kind LOCAL (`const t0 = v`), or a GLOBAL cell.
    const pk = nulScalarListKindOfNode(paramTypeNode(fnIx, e.identName))
    if pk != null { return pk }
    const dk = declaredKind(e.identName)
    if isNulScalarListKind(dk) { return dk }
    const gl = globalLetOf(e.identName)
    if gl >= 0 { return letNulScalarListKind(gl, fnIx) }
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const target = fnIndexOf(callee.identName)
      if target >= 0 {
        const fn = P.nodes[fnStmts[target]]
        if fn is FuncDecl {
          if fn.fnRet >= 0 { return nulScalarListKindOfNode(fn.fnRet) }
        }
      }
    }
  }
  // Indexing a `(f64[] | null)[]` (a kind-6/7/8/10 ref list whose element slot keeps the
  // `| null`) yields the NULLABLE leaf list — the read left it `(ref null $wrapper)`, so
  // `const t = xs[i]; if t != null` narrows to the leaf list. The distinct-backing dual
  // of `exprNullableList`'s kind-4 Index arm.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemNullable.length {
        if rlElemNullable[slot] == 1 {
          const k = rlElemKindTbl[slot]
          if k == 6 { return "nulstrlist" }
          if k == 7 { return "nulf64list" }
          if k == 8 { return "nuli64list" }
          if k == 10 { return "nulf32list" }
        }
      }
    }
  }
  null
}

// ── nullable-string (`string | null`, kind 16) predicates — the ref-rep analog of
// the nullable-list family above; `null` is `ref.null $aTypeIdx`, `!= null` is
// `ref.is_null`. Unlike a nullable list, an INITIALIZER can produce one (a string
// literal, or a `string | null`-returning call), so `letIsNulString` consults the init.
export function declaredNulString(name: string) {
  declaredKind(name) == "nulstr"
}

function globalIsNulString(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return false }
  letIsNulString(li, -1)
}

function fnRetNulString(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetKind[i] == "nulstr"
}

export function letIsNulString(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      if retNulStringFlag(d.letType) == 1 { return true }
    }
    if d.letType < 0 {
      // An un-annotated `const x = if c then "hi" else null` infers `string | null`
      // (a niche the emitter can't statically derive from the if-expr arms). The
      // CHECKER typed it and exported the binding by node index; consult that first,
      // then fall back to the init-shape probe (a nullable-string param/local/call).
      if isInferLetNulStr(letIx) { return true }
      return exprNullableString(d.letInit, fnIx)
    }
  }
  false
}

// True if evaluating the expression at `exprIx` yields a `string | null` ref — a
// nullable-string param/local/global, or a `: string | null`-returning call. Consulted
// by the `!= null` `ref.is_null` path and the assignment/return/arg null-seeding.
export function exprNullableString(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetNulString(callee.identName) { return true }
      // A `string | null`-returning function VALUE (a binding / `(…) => string | null`
      // param callee) — its result is the nullable raw array, `>N`.
      return calleeRetKind(callee.identName, fnIx) == "nulstr"
    }
    // A `string | null`-returning FIELD-closure call.
    if callee is Member {
      const ffe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
      if ffe >= 0 { return fRetKind[ffe] == "nulstr" }
    }
    // FALLBACK (scoped to a CALL): a `string | null`-returning closure value call whose callee the
    // cases above miss — an INDEXED closure-array element (`arr[i](x)`). The cheap NO-RENDER
    // `nodeTyIsNullableString` reads the checker's per-node type (the niche-string dual of
    // `exprNullableStruct`'s `nodeTyIsNullableStruct` fallback).
    return nodeTyIsNullableString(exprIx)
  }
  if e is Ident {
    if paramNulString(fnIx, e.identName) { return true }
    if declaredNulString(e.identName) { return true }
    return globalIsNulString(e.identName)
  }
  // A `string | null` struct FIELD read (`a.v`, code 20) yields a nullable string ref.
  if e is Member { return memberFieldCode(exprIx, fnIx) == 20 }
  // A BARE `m[k]` over a STRING-valued map is `string | null` (kind 16) — `emitMapGet` yields the
  // `(ref null)` value unrecovered, the string dual of the bare struct-map read.
  if e is Index {
    const mrs = mapReadMvSlot(exprIx, fnIx)
    if mrs >= 0 { return mvValKind[mrs] == 3 }
    // A `(string | null)[]` element read `p[i]` yields `string | null` — the string-ref niche kept
    // `(ref null $aTypeIdx)` by the dedicated `emitIndex` arm — so `const t = p[i]` binds kind 16 and
    // `t != null` / `p[i] != null` narrows against it.
    if exprNulStrArray(e.idxArr, fnIx) { return true }
  }
  // A chained `a ?? b` over nullable strings is ITSELF nullable-string when the default
  // `b` is also nullable (the result can still be null) — the left-associative
  // `(f() ?? g()) ?? d` shape, where the classifier sees this nested `??` as `binLeft`
  // before `emitExpr` re-associates it. Keeps print-routing / `exprString` consistent
  // with the emitted rep.
  if e is BinExpr {
    if e.binOp == "??" {
      // A fused read over a NULLABLE-string-valued map (`{[string]: string | null}`) is
      // STILL `string | null`: the hit arm preserves a stored null.
      const cns = coalesceMvSlot(exprIx, fnIx)
      if cns >= 0 {
        if mvValKind[cns] == 3 && mvSlotNullable(cns) { return true }
      }
      if exprNullableString(e.binLeft, fnIx) {
        return exprNullableString(e.binRight, fnIx)
      }
    }
  }
  false
}

// The base struct index of a nullable-struct `LetDecl`: the annotation's base, or
// the initializer's resolved struct (a nullable-returning call's `fRetStructIdx`).
export function nulRefStructIdxOfLet(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const ri = retNulRefIndex(d.letType)
      if ri >= 0 { return ri }
    }
    return structIndexOfExpr(d.letInit, fnIx)
  }
  -1
}

// True if evaluating the expression at `exprIx` yields a NULLABLE struct ref —
// a nullable-annotated param/local/global reference or a `S | null`-returning call.
export function exprNullableStruct(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Paren { return exprNullableStruct(e.parInner, fnIx) }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetNulRef(callee.identName) { return true }
      // An `S | null`-returning function VALUE (a binding / `(…) => S | null` param
      // callee) — its result is the nullable struct ref, `>nN;`.
      if calleeRetKind(callee.identName, fnIx) == "nulstruct" { return true }
    }
    // An `S | null`-returning FIELD-closure call.
    if callee is Member {
      const ffe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
      if ffe >= 0 && fRetKind[ffe] == "nulstruct" { return true }
    }
    // `xs.pop()` / `xs.get(i)` over a STRUCT-element ref list yield `S | null` (the
    // host's nullable list reads — `pop` of an empty list / OOB `get` is null).
    if structListPopGetElem(exprIx, fnIx) >= 0 { return true }
    // FALLBACK (scoped to a CALL): a nullable-struct-returning closure value call whose callee the
    // cases above miss — an INDEXED closure-array element (`arr[i](x)`). The cheap NO-RENDER
    // `nodeTyIsNullableStruct` reads the checker's per-node type. The nullable dual of `exprStruct`'s
    // `nodeTyIsObj` fallback (#654), so `letIsNulRef` classifies such a binding kind-9 and its
    // `!= null` narrow gets the struct context.
    return nodeTyIsNullableStruct(exprIx)
  }
  if e is Ident {
    if paramNulRef(fnIx, e.identName) { return true }
    if declaredNulRef(e.identName) { return true }
    // A CAPTURED nullable struct (`const p: P | null = …; () => if p != null { p.x }`): the env
    // field is `(ref null $S)` (kind 9), so classify it nullable — else `p != null` reads as
    // struct equality. The struct index resolves via `capturedStructIndex`.
    if capturedKindOf(fnIx, e.identName) == "nulstruct" { return true }
    return globalIsNulRef(e.identName)
  }
  // A NESTED-STRUCT field read (code 15) is stored `(ref null $S)` — a `S|null`
  // field genuinely carries null; a plain `inner: S` field is always written
  // non-null but shares the nullable storage, so the read is nullable-classified
  // (the consumer inserts `ref.as_non_null` before a chained field access).
  if e is Member { return memberFieldCode(exprIx, fnIx) == 15 }
  // An INDEX into a NULLABLE-struct array (`(P | null)[]`, ref-list slot key "P | null")
  // yields `P | null` — the element legitimately holds null, so the read is NOT recovered
  // to non-null (unlike a `P[]` element). `const e = xs[i]` binds the kind-9 niche.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      if rlElemKindTbl[slot] == 1 {
        if nullablePartOf(rlElemName[slot]) != "" { return true }
      }
    }
    // A BARE map get `m[k]` over a STRUCT-valued map (`{[string]: S}`) is `S | null` — the
    // `vals` slot is `(ref null $S)` and `emitMapGet` yields it unrecovered (a miss is
    // `ref.null`). So `const v = m[k]` binds the kind-9 niche and narrows with `if v != null`,
    // the map-read dual of the nullable-struct ARRAY element above. (A `?? d` read over a
    // NON-null value stays the non-null struct; see the BinExpr arm below for the nullable one.)
    const mrs = mapReadMvSlot(exprIx, fnIx)
    if mrs >= 0 { return mvValKind[mrs] == 1 }
  }
  // A `m[k] ?? d` read over a NULLABLE-struct-valued map (`{[string]: S | null}`) is STILL
  // `S | null`: the hit arm PRESERVES a stored null (the default fires only on a missing key),
  // so the binding stays the kind-9 niche and narrows with `!= null`.
  if e is BinExpr {
    const cns = coalesceMvSlot(exprIx, fnIx)
    if cns >= 0 { return mvValKind[cns] == 1 && mvSlotNullable(cns) }
  }
  false
}

// The arena index of the expression an UN-ANNOTATED function returns: the body's
// trailing tail-value statement, or the first valued `return`'s argument (walking
// into if/while/for bodies). -1 when the function yields nothing (void).
export function fnRetExprOf(fnIx: i32) {
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    const b = P.nodes[fn.fnBody]
    if b is Block {
      const stmts = b.blkStmts
      if stmts.length > 0 {
        const last = stmts[stmts.length - 1]
        if stmtIsTailValue(last, fnIx) { return last }
      }
    }
    return firstValuedReturn(fn.fnBody)
  }
  -1
}

// True if `rx` is a reference to a LOCAL whose annotation is a mono `{[string]: i32}` map —
// the ordering-safe way to classify a returned map local during the GLOBAL return pass (before
// per-function local kinds are collected, so `exprMap`/`declaredMap` can't see it yet).
// The map SHAPE of a RETURN expression, resolved from ANNOTATIONS ONLY (not collected local
// state) — so it is valid at the type-section emit (before locals are collected) AND from a
// DIFFERENT function (a caller resolving a map factory's value type). A returned map PARAM reads
// its annotation (`paramMapShape`); a returned map LOCAL its `let` annotation (`mapAnnShape`); a
// `Map()`/`Set()` is the mono map (-1); a call to another map fn recurses (`fnRetMapShape`).
// -1 (mono) for anything else.
export function mapRetExprShape(rx: i32, fnIx: i32) {
  let u = rx
  let done = false
  while !done {
    const node = P.nodes[u]
    if node is Paren { u = node.parInner } else { done = true }
  }
  const e = P.nodes[u]
  if e is Ident {
    if paramMap(fnIx, e.identName) { return paramMapShape(fnIx, e.identName) }
    const fn = P.nodes[fnIx]
    if fn is FuncDecl {
      const li = parentLetOf(fn.fnBody, e.identName)
      if li >= 0 {
        const d = P.nodes[li]
        if d is LetDecl {
          if d.letType >= 0 { return mapAnnShape(d.letType) }
        }
      }
    }
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if callee.identName == "Map" || callee.identName == "Set" { return -1 }
      return fnRetMapShape(callee.identName)
    }
  }
  // A CAPTURED map return (`(q) => (h)` over an enclosing-frame map `h`): the ident is
  // neither a param nor a local of THIS function, so the arms above miss it. Resolve its
  // shape from the capture — the SAME `captureValStructIdx` the env field uses — so the
  // functype result `$mapStruct` heap type matches the env field AND the captured value.
  const cap = retCapturedMapShape(fnIx, rx)
  if cap != -3 { return cap }
  -1
}

// The map SHAPE of a return expression that is a CAPTURED map variable — an ident lifted
// function `fnIx` closes over whose enclosing binding is a `{[string]: V}` map — as the mv
// slot (>= -1; mono = -1), or -3 when the return is NOT a captured map. The capture SET
// (`captureNamesOf`) is the source of truth: only a name that is an actual env field is
// resolved here (a same-named local/param shadowing a capture stays with the local arms).
// A map-returning closure over a captured map is invisible to the local/param map tests, so
// without this its result inferred as i32 over a map-ref body — invalid wasm at the return.
function retCapturedMapShape(fnIx: i32, rx: i32): i32 {
  let u = rx
  let done = false
  while !done {
    const node = P.nodes[u]
    if node is Paren { u = node.parInner } else { done = true }
  }
  const e = P.nodes[u]
  if e is Ident {
    const fe = fnStmtsPosOf(fnIx)
    if fe >= 0 {
      const caps = captureNamesOf(fe)
      let ci = 0
      while ci < caps.length {
        if caps[ci] == e.identName {
          if captureValKind(fe, e.identName) == "map" {
            return captureValStructIdx(fe, e.identName)
          }
          return -3
        }
        ci = ci + 1
      }
    }
  }
  -3
}

function retIsMapLocalAnnot(rx: i32, fnIx: i32) {
  let u = rx
  let done = false
  while !done {
    const node = P.nodes[u]
    if node is Paren { u = node.parInner } else { done = true }
  }
  const e = P.nodes[u]
  if e is Ident {
    const fn = P.nodes[fnIx]
    if fn is FuncDecl {
      const li = parentLetOf(fn.fnBody, e.identName)
      if li >= 0 {
        const d = P.nodes[li]
        if d is LetDecl {
          if d.letType >= 0 {
            const lt = P.nodes[d.letType]
            if lt is TypeRef {
              if nameIsMap(lt.tyName) && !nameIsMapMemberUnion(lt.tyName) {
                // A supported map value type — the same classifier `retMapFlag` gates the
                // boundary with (`mvValKindOfName`); the return's SHAPE is recovered at the
                // functype-result site via `mapShapeOfExpr` over this same local.
                return mvValKindOfName(mapValNameOf(lt.tyName)) != -3
              }
            }
          }
        }
      }
    }
  }
  false
}

// The parent-`let` arena index a returned bare IDENT names in function `i`'s
// body, or -1 (the return is not an ident, or the name is a param / global —
// `parentLetOf` only finds body-declared `let`s). The lookup half of the
// returned-LOCAL classification in `criClassify`, mirroring `retIsMapLocalAnnot`.
function criRetLocalLet(rx: i32, i: i32) {
  const u = unwrapParen(rx)
  const e = P.nodes[u]
  if e is Ident {
    const fn = P.nodes[fnStmts[i]]
    if fn is FuncDecl { return parentLetOf(fn.fnBody, e.identName) }
  }
  -1
}

// Classify ONE valued return expression at `rx0` of the function at `fnStmts`
// position `i`, under the CURRENT narrowing stack — the loop body the flat
// return scan used to run, extracted so the narrowing-aware walk shares it.
export function criClassify(rx0: i32, i: i32) {
  let rx = rx0
  // A tail ASSIGNMENT yields its RHS (assignment-as-expression), so the
  // function's return kind is the RHS's kind (`function emit(s: string)
  // { acc = acc + s }` returns the new string).
  const rxe = P.nodes[rx]
  if rxe is BinExpr {
    if rxe.binOp == "=" { rx = rxe.binRight }
  }
  if fRetKind[i] != "str" && exprString(rx, fnStmts[i]) {
    criSetRetKind(i, "str")
  }
  if !retKindIsList(fRetKind[i]) && exprRefArray(rx, fnStmts[i]) {
    // Record the element type-NAME so the inferred functype result can resolve its ref-list
    // slot (`rlSlotByName`) — the annotated path fills `fRetRArrElem` from the annotation, but
    // an un-annotated `return ps` / `return ps.filter(…)` must read it off the return expr.
    if criSetRetKind(i, "reflist") {
      if i < fRetRArrElem.length && fRetRArrElem[i] == "" {
        fRetRArrElem[i] = refListElemNameOfExpr(rx, fnStmts[i])
      }
    }
  }
  if !retKindIsList(fRetKind[i]) && exprStringArray(rx, fnStmts[i]) {
    criSetRetKind(i, "strlist")
  }
  if !retKindIsList(fRetKind[i]) && exprF64Array(rx, fnStmts[i]) {
    criSetRetKind(i, "f64list")
  }
  // The i64/f32 siblings of the f64-list arm above (wrappers `il64TypeIdx` /
  // `fl32TypeIdx`). Checked BEFORE the generic `exprArray` arm below, which would
  // otherwise claim an i64/f32-magnitude return as a plain i32 list — the
  // functype result would declare the i32-list wrapper over a body building the wide list.
  if !retKindIsList(fRetKind[i]) && exprI64Array(rx, fnStmts[i]) {
    criSetRetKind(i, "i64list")
  }
  if !retKindIsList(fRetKind[i]) && exprF32Array(rx, fnStmts[i]) {
    criSetRetKind(i, "f32list")
  }
  if fRetKind[i] != "map" {
    // `exprMap` classifies a returned map PARAM (reads `parType` directly) and a `Map()`/
    // map-returning-call. A returned map LOCAL needs `retIsMapLocalAnnot` — its kind isn't
    // collected during this GLOBAL return pass, so read its `{[string]: i32}` annotation.
    if (
      exprMap(rx, fnStmts[i]) ||
      retIsMapLocalAnnot(rx, fnStmts[i]) ||
      retCapturedMapShape(fnStmts[i], rx) != -3
    ) {
      criSetRetKind(i, "map")
    }
  }
  // The not-a-list guard subsumes the old `fRetArr==0 && fRetF64Arr==0`: `exprArray`'s array-
  // literal case is `!arrLitIsRef`, and an f64 element is NOT a ref, so `exprArray` also
  // claims an f64 literal (`[1.5, 2.5]`). The f64-list kind was set just above, so this
  // skips it — no separate i32/f64 mis-classification.
  if !retKindIsList(fRetKind[i]) && exprArray(rx, fnStmts[i]) {
    criSetRetKind(i, "list")
  }
  if fRetKind[i] != "union" && exprUnion(rx, fnStmts[i]) {
    // A union return SUBSUMES a per-arm struct classification: a value-if join (`if c {
    // catVal } else { dogVal }`) has one arm a union-VARIANT object literal (which
    // `exprStruct` would also claim as a plain struct return) and another the union. If the
    // struct arm was classified FIRST it stored `"struct"` while the union was still unseen
    // (the struct arm's guard only blocks the reverse order) — and struct OUTRANKS union in
    // the chain, so a plain `criSetRetKind` would refuse. Overwrite so the union wins — else
    // the inferred-result valtype declares a struct ref over a body that yields the union
    // box. Lambda-gated: only the lambda value-if path (above) hits this order, and a named
    // function's classification must stay byte-identical.
    if fRetKind[i] == "struct" && criFnIsAnonLambda(i) {
      fRetKind[i] = "union"
      criChanged = true
    } else {
      criSetRetKind(i, "union")
    }
  }
  if (
    fRetKind[i] != "nulstruct" &&
    fRetKind[i] != "union" &&
    exprNullableStruct(rx, fnStmts[i])
  ) {
    if criSetRetKind(i, "nulstruct") {
      fRetStructIdx[i] = structIndexOfExpr(rx, fnStmts[i])
    }
  }
  if (
    fRetKind[i] != "struct" &&
    fRetKind[i] != "nulstruct" &&
    fRetKind[i] != "union" &&
    exprStruct(rx, fnStmts[i])
  ) {
    // GUARD `!= "union"`: an INFERRED struct-union return (`Cat | Dog`) stores `"union"`
    // in the A20 name pass, but each of its returns is a SINGLE object literal that
    // `exprStruct` would (wrongly) also classify as a plain struct return — the union
    // kind dominates, so don't claim `"struct"`/`fRetStructIdx` (a conflicting rep).
    if criSetRetKind(i, "struct") {
      fRetStructIdx[i] = structIndexOfExpr(rx, fnStmts[i])
    }
  }
  // A returned LOCAL `let` of a REF kind (`const c: Ctx = {…}; return c`,
  // `const xs = [[1,2]]; return xs`): during this GLOBAL pass the function's
  // locals are not collected, so the `expr*` Ident cases above miss it and the
  // functype result would default to i32 over a body that yields a ref — invalid
  // wasm. Classify through the DECLARATION (annotation first, else the
  // initializer's shape) via the shared per-let classifiers, exactly as
  // `retIsMapLocalAnnot` does for a returned map local. The scalar / string /
  // scalar-list local kinds never reach here — the checker's recorded
  // inferred-return name (the A20 pass) already covers them.
  const rll = criRetLocalLet(rx, i)
  if rll >= 0 {
    if !retKindIsList(fRetKind[i]) && letIsRefArray(rll, fnStmts[i]) {
      if criSetRetKind(i, "reflist") {
        if i < fRetRArrElem.length && fRetRArrElem[i] == "" {
          fRetRArrElem[i] = letRefListElemName(rll, fnStmts[i])
        }
      }
    }
    if (
      fRetKind[i] != "struct" &&
      fRetKind[i] != "nulstruct" &&
      fRetKind[i] != "union" &&
      !retKindIsList(fRetKind[i]) &&
      letIsStruct(rll, fnStmts[i])
    ) {
      // `structIndexOfLet` prefers the ANNOTATION's struct over the literal's
      // first field-shape match, so `const c: Ctx = {…}` returns Ctx even when
      // another declared struct shares its field names.
      if criSetRetKind(i, "struct") {
        fRetStructIdx[i] = structIndexOfLet(rll, fnStmts[i])
      }
    }
  }
  if fRetBool[i] == 0 && exprIsBool(rx, fnStmts[i]) {
    fRetBool[i] = 1
    criChanged = true
  }
  // SCALAR f64 / f32 / i64 returns, detected from the return EXPRESSION — the dual of the string
  // / list / struct cases above. A function the checker never recorded an inferred-return name for
  // — a MONOMORPHIZED instance (`f(n)` pinned to `n: f64` by the emitter, whose body the checker
  // only saw with `n` a type variable) — would otherwise default its functype result to i32 over
  // an f64/f32/i64 body: "expected i32, found f64". Gated on the flag being unset (so an annotated
  // return and every i32 return are untouched) AND on a "pure" scalar return: a value-union `?? d`
  // coalesce reads as its unboxed atom (`exprIsF64`/`exprIsI64`) but its result REP is the union
  // box, classified separately — so exclude it, and skip when another return flag already claimed
  // the function.
  let scalarOk = fRetKind[i] == "i32" && fRetBool[i] == 0
  const rxn = P.nodes[rx]
  if rxn is BinExpr {
    if rxn.binOp == "??" { scalarOk = false }
  }
  if scalarOk {
    if exprIsF64(rx, fnStmts[i]) { criSetRetKind(i, "f64") }
    else if exprIsF32(rx, fnStmts[i]) { criSetRetKind(i, "f32") }
    else if exprIsI64(rx, fnStmts[i]) { criSetRetKind(i, "i64") }
  }
  0
}

// Walk a block's statements classifying every `return <e>` under the SAME
// narrowing the emit loops apply: each `if` arm classifies under its
// condition's then/else narrowing, and a divergent guard narrows the rest of
// the block (`pushPostGuardNarrow`). The stack rewinds at block exit.
// True if lifted function `i` (an `fnStmts` index) is an ANONYMOUS lambda (no source
// name). Restricts the if-arm tail-value return classification below to lambdas, leaving
// NAMED-function return inference byte-identical (a named function's inferred-return name
// already rides `buildFnMap`'s A20 pass + `criWalkStmt`'s explicit-`return` classification;
// perturbing it would change the compiler's own self-compilation).
export function criFnIsAnonLambda(i: i32) {
  if i < 0 || i >= fnStmts.length { return false }
  const fn = P.nodes[fnStmts[i]]
  if fn is FuncDecl {
    // The emitter rewrites an anonymous lambda's empty name to the synthesized
    // `__lambda_N` (before this pass runs), so test that prefix — `fnName == ""` never
    // matches a lifted lambda here. A source function never starts with `__lambda`.
    const nm = fn.fnName
    return nm.length >= 8 && nm.slice(0, 8) == "__lambda"
  }
  false
}

export function criWalkBlock(blockIx: i32, i: i32) {
  if blockIx < 0 { return 0 }
  const b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    const savedGuardTop = narrowTop
    let k = 0
    while k < stmts.length {
      // An if-ARM's last statement may be a bare tail VALUE (an implicit return —
      // `if c { catVal } else { dogVal }`), not an explicit `return`. For an ANONYMOUS
      // LAMBDA, classify it under the arm's active narrowing so a value-if union return
      // types from its arms (a named union-returning callback already works via explicit
      // `return`s). Lambda-gated to keep named-function inference byte-identical.
      if (
        k == stmts.length - 1 &&
        criFnIsAnonLambda(i) &&
        stmtIsTailValue(stmts[k], fnStmts[i])
      ) {
        criClassify(stmts[k], i)
      }
      criWalkStmt(stmts[k], i)
      pushPostGuardNarrow(stmts[k], fnStmts[i])
      k = k + 1
    }
    restoreNarrow(savedGuardTop)
    return 0
  }
  criWalkStmt(blockIx, i)
}

function criWalkStmt(stmtIx: i32, i: i32) {
  if stmtIx < 0 { return 0 }
  const s = P.nodes[stmtIx]
  if s is RetStmt {
    if s.retArg >= 0 { criClassify(s.retArg, i) }
    return 0
  }
  if s is IfStmt {
    const savedTop = narrowTop
    setNarrowFromCond(s.ifCond, fnStmts[i])
    criWalkBlock(s.ifThen, i)
    restoreNarrow(savedTop)
    if s.ifElse >= 0 {
      const savedElseTop = narrowTop
      setNarrowFromCondElse(s.ifCond, fnStmts[i])
      criWalkBlock(s.ifElse, i)
      restoreNarrow(savedElseTop)
    }
    return 0
  }
  if s is WhileStmt { return criWalkBlock(s.whileBody, i) }
  if s is ForRange { return criWalkBlock(s.frBody, i) }
  if s is ForIn { return criWalkBlock(s.fiBody, i) }
  0
}

// Look up the wasm function index for `name`, or -1 if no such top-level function
// exists (an undefined callee — the caller fails loudly).
export function fnIndexOf(name: string) { fnNameMap[name] ?? -1 }

// `fnIndexOf` but SCOPE-AWARE for a name referenced as a VALUE inside function `fnIx`
// (a node index): when two lifted functions share a name (each `makeX` declaring its
// own nested `add`), the flat `fnIndexOf` always returns the FIRST — wrong for the
// SECOND maker's body, whose `add` captures a different frame. Prefer a lifted function
// named `name` whose PARENT is `fnIx`'s own `fnStmts` position; fall back to the flat
// lookup (a top-level function, or no nested match). Only consulted on the function-
// VALUE path (gated by `fnValUsed`), so by-name resolution elsewhere is unchanged.
export function fnIndexOfInScope(name: string, fnIx: i32) {
  // The parent-matching scan can only succeed for a NESTED function named `name`; skip
  // it entirely (→ O(1) `fnIndexOf`) when no lifted function carries this name.
  if fnIx >= 0 && (nestedNameSet[name] ?? false) {
    const pp = fnStmtsPosOf(fnIx)
    if pp >= 0 {
      let i = 0
      while i < fnStmts.length {
        const s = P.nodes[fnStmts[i]]
        if s is FuncDecl {
          if s.fnName == name {
            if i < fnParent.length && fnParent[i] == pp { return i }
          }
        }
        i = i + 1
      }
    }
  }
  fnIndexOf(name)
}

// ── capture analysis (closures) ───────────────────────────────────────────────
// The captured-variable NAMES of the lifted function at `fnStmts[fe]`, in
// encounter (= env field) order, by DIRECT WALK. A capture is a free variable: an
// identifier read in the body that is NOT one of the function's own params, NOT a
// `let`/`const` declared in the body, NOT a module global, and NOT a top-level/
// lifted function name (those are addressable directly). The walk threads a
// growable `bound` set (params, then each `let` as it is declared) and
// accumulates free names into `caps` (deduped). Mirrors the host's
// `captureCollector`. Callers go through `captureNamesOf`, which serves the
// emission phases from the capture cache instead of re-walking.
export function capComputeNamesOf(fe: i32) {
  const caps: string[] = []
  if fe < 0 || fe >= fnStmts.length { return caps }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    const bound: string[] = []
    const params = fn.fnParams
    let pi = 0
    while pi < params.length {
      const p = P.nodes[params[pi]]
      if p is Param { bound.push(p.parName) }
      pi = pi + 1
    }
    capScan(fn.fnBody, bound, caps)
  }
  caps
}

// The captured-variable NAMES of the lifted function at `fnStmts[fe]` — from the
// capture cache when it is valid (the emission phases), else by direct walk (the
// rewrite/monomorphize phases, which still mutate bodies). Returns a fresh small
// array either way (a `string[][]` cache row is not self-host-emittable).
export function captureNamesOf(fe: i32) {
  if capCacheOn && fe >= 0 && fe < capStartTbl.length {
    const caps: string[] = []
    const start = capStartTbl[fe]
    const cnt = capCountTbl[fe]
    let ci = 0
    while ci < cnt {
      caps.push(capNamesFlat[start + ci])
      ci = ci + 1
    }
    return caps
  }
  capComputeNamesOf(fe)
}

// The number of captured variables of the lifted function at `fnStmts[fe]` —
// O(1) from the cache when valid, else the direct walk's length.
export function captureCountOf(fe: i32) {
  if capCacheOn && fe >= 0 && fe < capCountTbl.length { return capCountTbl[fe] }
  const caps = capComputeNamesOf(fe)
  caps.length
}

function capRecord(name: string, bound: string[], caps: string[]) {
  if capIsBound(bound, name) { return 0 }
  if globalIndexOf(name) >= 0 { return 0 }
  if fnIndexOf(name) >= 0 { return 0 }
  if isBuiltinFnName(name) { return 0 }
  if capHas(caps, name) { return 0 }
  caps.push(name)
  0
}

// Walk a statement/expression subtree collecting free-variable captures. `bound`
// grows as `let`/`const` declarations are seen (wasm locals are function-scoped, so
// once declared a name shadows an enclosing binding for the rest of the body — a
// conservative but sound match for the corpus). A NESTED FuncDecl is NOT descended
// (it is lifted to its own function with its own capture analysis); its name, if
// any, binds locally.
export function capScan(ix: i32, bound: string[], caps: string[]) {
  if ix < 0 { return 0 }
  const n = P.nodes[ix]
  if n is Ident {
    capRecord(n.identName, bound, caps)
    return 0
  }
  if n is FuncDecl {
    if n.fnName != "" { bound.push(n.fnName) }
    // A nested function's FREE variables that THIS scope does not bind are TRANSITIVE
    // captures: the nested closure's env is built inside this lifted function
    // (`emitCaptureRead` reads each capture in the enclosing frame), so a name the
    // nested body needs from an outer frame must ride this env too. Scan the nested
    // body against its OWN bound set (params + its self-name), then filter the frees
    // through `capRecord` — names bound here (params/locals), globals, and function
    // names drop out; the rest append in encounter order.
    const ibound: string[] = []
    const iparams = n.fnParams
    let ipi = 0
    while ipi < iparams.length {
      const ip = P.nodes[iparams[ipi]]
      if ip is Param { ibound.push(ip.parName) }
      ipi = ipi + 1
    }
    if n.fnName != "" { ibound.push(n.fnName) }
    const ifree: string[] = []
    capScan(n.fnBody, ibound, ifree)
    let ifi = 0
    while ifi < ifree.length {
      capRecord(ifree[ifi], bound, caps)
      ifi = ifi + 1
    }
    return 0
  }
  if n is Block {
    const stmts = n.blkStmts
    let i = 0
    while i < stmts.length {
      capScan(stmts[i], bound, caps)
      i = i + 1
    }
    return 0
  }
  if n is LetDecl {
    if n.letInit >= 0 { capScan(n.letInit, bound, caps) }
    bound.push(n.letName)
    return 0
  }
  if n is RetStmt {
    if n.retArg >= 0 { capScan(n.retArg, bound, caps) }
    return 0
  }
  if n is IfStmt {
    capScan(n.ifCond, bound, caps)
    capScan(n.ifThen, bound, caps)
    if n.ifElse >= 0 { capScan(n.ifElse, bound, caps) }
    return 0
  }
  if n is WhileStmt {
    capScan(n.whileCond, bound, caps)
    capScan(n.whileBody, bound, caps)
    return 0
  }
  if n is ForRange {
    capScan(n.frFrom, bound, caps)
    capScan(n.frTo, bound, caps)
    if n.frStep >= 0 { capScan(n.frStep, bound, caps) }
    bound.push(n.frVar)
    capScan(n.frBody, bound, caps)
    return 0
  }
  if n is ForIn {
    capScan(n.fiIter, bound, caps)
    bound.push(n.fiVar)
    capScan(n.fiBody, bound, caps)
    return 0
  }
  if n is Call {
    capScan(n.callFn, bound, caps)
    const args = n.callArgs
    let i = 0
    while i < args.length {
      capScan(args[i], bound, caps)
      i = i + 1
    }
    return 0
  }
  if n is BinExpr {
    capScan(n.binLeft, bound, caps)
    capScan(n.binRight, bound, caps)
    return 0
  }
  if n is Unary {
    capScan(n.unArg, bound, caps)
    return 0
  }
  if n is Paren {
    capScan(n.parInner, bound, caps)
    return 0
  }
  if n is Member {
    capScan(n.memObj, bound, caps)
    return 0
  }
  if n is OptMember {
    capScan(n.omObj, bound, caps)
    return 0
  }
  if n is Index {
    capScan(n.idxArr, bound, caps)
    capScan(n.idxIndex, bound, caps)
    return 0
  }
  if n is IsExpr {
    capScan(n.isObj, bound, caps)
    return 0
  }
  if n is AsExpr {
    capScan(n.asObj, bound, caps)
    return 0
  }
  if n is ObjLit {
    const fields = n.objFields
    let i = 0
    while i < fields.length {
      const f = P.nodes[fields[i]]
      if f is FieldInit { capScan(f.fiValue, bound, caps) }
      i = i + 1
    }
    return 0
  }
  if n is ArrayLit {
    const elems = n.arrElems
    let i = 0
    while i < elems.length {
      capScan(elems[i], bound, caps)
      i = i + 1
    }
    return 0
  }
  0
}

// The env struct heap-type index for the lifted function at index `fe`, or -1 if it
// captures nothing (its closure env is `ref.null structref`). Resolved by
// `mAssignTypeIndices` into `fnEnvIdx`.
export function fnEnvIdxOf(fe: i32) {
  if fe < 0 || fe >= fnEnvIdx.length { return -1 }
  fnEnvIdx[fe]
}

// True if function `fe`'s env-leading signature matches an interned `$fnsig`
// `(structref, params...) -> ret` (`fnSigKeyOf` eligibility: i32/boolean, f64, or
// struct-ref params; an i32/boolean or f64 result; non-void). Such a function is
// declared with `fnSigIdxOfFn` as its functype (so its ACTUAL type IS `$fnsig`),
// making `ref.func` of it yield a value the `call_ref` site's `ref.cast` to `$fnsig`
// accepts. A function outside the eligible kinds keeps its own functype and cannot
// be used as a value (none in the corpus are).
export function fnSigIsClosure(fe: i32) { fnSigIdxOfFn(fe) >= 0 }

// The `fnStmts` POSITION of the enclosing frame whose binding a captured `name`
// resolves to — the direct parent when it binds `name` (a param or a body `let`),
// else the nearest ANCESTOR frame that does (a TRANSITIVE capture: every
// intermediate lifted function re-captures the name into its own env, so the VALUE
// flows env-to-env, but the TYPE lives at the owning frame's binding). -1 when no
// ancestor binds it.
function parentBindingFrameOf(fe: i32, name: string): i32 {
  if fe < 0 || fe >= fnParent.length { return -1 }
  const par = fnParent[fe]
  if par < 0 || par >= fnStmts.length { return -1 }
  const pfn = P.nodes[fnStmts[par]]
  if pfn is FuncDecl {
    const params = pfn.fnParams
    let i = 0
    while i < params.length {
      const p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name { return par }
      }
      i = i + 1
    }
    if parentLetOf(pfn.fnBody, name) >= 0 { return par }
    return parentBindingFrameOf(par, name)
  }
  -1
}

// The arena index of the enclosing frame's binding for a captured `name` — the owning
// frame's matching `Param` node, or a `LetDecl` in its body, or -1. Resolves through
// `parentBindingFrameOf`, so a TRANSITIVE capture (the binding lives frames above the
// direct parent) types exactly as a direct one. Used to resolve a capture's wasm
// valtype (its declared type lives in the owning frame).
function parentBindingOf(fe: i32, name: string) {
  const par = parentBindingFrameOf(fe, name)
  if par < 0 { return -1 }
  const pfn = P.nodes[fnStmts[par]]
  if pfn is FuncDecl {
    const params = pfn.fnParams
    let i = 0
    while i < params.length {
      const p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name { return params[i] }
      }
      i = i + 1
    }
    return parentLetOf(pfn.fnBody, name)
  }
  -1
}

// The `fbValtype` kind for a captured variable `name` of lifted function `fe`,
// resolved against the parent frame's binding (a param's annotation, or a local
// `let`'s annotation / struct-literal initializer). Defaults to i32 (kind 0).
export function captureValKind(fe: i32, name: string): VKind {
  const b = parentBindingOf(fe, name)
  if b < 0 { return "i32" }
  const bn = P.nodes[b]
  if bn is Param { return vtKindOfType(bn.parType) }
  if bn is LetDecl {
    if bn.letType >= 0 { return vtKindOfType(bn.letType) }
    // Un-annotated local: classify the INITIALIZER through the same ladder
    // `collectLocals` types the binding with (resolved in the OWNING frame), so
    // a captured list/string/struct env field carries its real ref valtype —
    // `const store = [a, b]` captured by a closure is the i32-list wrapper ref
    // (kind 2), not an i32 cell. Order mirrors `collectLocals`.
    if bn.letInit >= 0 {
      const pf = parentBindingFrameOf(fe, name)
      if letIsMap(b, pf) { return "map" }
      if letIsNulRef(b, pf) { return "nulstruct" }
      // A value union wins over a scalar-list INIT (`f64[] | string = [1.5]`) — see the
      // local-decl chain. Checked before the scalar-list cases for that reason.
      if letIsUnion(b, pf) { return "union" }
      if letIsStringArray(b, pf) { return "strlist" }
      if letIsF32Array(b, pf) { return "f32list" }
      if letIsF64Array(b, pf) { return "f64list" }
      if letIsI64Array(b, pf) { return "i64list" }
      if letIsRefArray(b, pf) { return "reflist" }
      if letIsStruct(b, pf) { return "struct" }
      if letIsArray(b, pf) { return "list" }
      if letIsString(b, pf) { return "str" }
      if letIsI64(b, pf) { return "i64" }
      if letIsF32(b) || letInfersF32(b, pf) { return "f32" }
      if letIsF64(b, pf) { return "f64" }
      if letIsClosure(b, pf) { return "closure" }
    }
  }
  "i32"
}

// The second `fbValtype` arg (struct table index) for a captured struct-ref variable.
export function captureValStructIdx(fe: i32, name: string) {
  const b = parentBindingOf(fe, name)
  if b < 0 { return -1 }
  const bn = P.nodes[b]
  // A captured MAP binding's companion slot is its map SHAPE (mono ⇒ -1, or the value
  // type's mv slot) — the SAME `mapAnnShape` the local/param/return valtypes resolve, so the
  // env field's `$mapStruct` heap type matches the captured map value's exactly (a typed
  // `{[string]: f32}` capture is `(ref $mvMapTypeIdx)`, not the mono `$mapStruct`). Mirrors
  // `captureValKind`, whose annotation arm already yields "map"; without this the annotated
  // arms fell through to `retStructIndex` (−1 for a map) and the env boxed a typed map into a
  // mono field — invalid wasm at the closure `struct.new`.
  if bn is Param {
    if retMapFlag(bn.parType) == 1 { return mapAnnShape(bn.parType) }
    return retStructIndex(bn.parType)
  }
  if bn is LetDecl {
    if bn.letType >= 0 {
      if retMapFlag(bn.letType) == 1 { return mapAnnShape(bn.letType) }
      return retStructIndex(bn.letType)
    }
    if bn.letInit >= 0 {
      const pf = parentBindingFrameOf(fe, name)
      // The kind-specific companion index, mirroring `captureValKind`'s ladder:
      // a map capture carries its mv SHAPE slot, a nullable-struct / struct
      // capture its struct table index, a ref-list capture its ref-list slot.
      if letIsMap(b, pf) { return letMapShapeOf(b, pf) }
      if letIsNulRef(b, pf) { return nulRefStructIdxOfLet(b, pf) }
      if letIsRefArray(b, pf) { return letRefListSlot(b, pf) }
      const iv = P.nodes[bn.letInit]
      if iv is ObjLit { return structIndexOfExpr(bn.letInit, pf) }
    }
  }
  -1
}

// Enter a new lexical block: remember the current binding count as this frame's
// boundary. Returns 0.
export function scopePush() {
  scopeFrames.push(scopeNames.length)
  0
}

// Leave the innermost lexical block: drop its frame boundary and discard every
// binding appended within it (truncate `scopeNames`/`scopeSlots` back to the mark).
// Returns 0.
export function scopePop() {
  if scopeFrames.length == 0 { return 0 }
  const mark = scopeFrames[scopeFrames.length - 1]
  scopeFrames.pop()
  while scopeNames.length > mark {
    scopeNames.pop()
    scopeSlots.pop()
  }
  0
}

// Bind name `name` to declared-local position `slot` in the CURRENT (innermost) frame.
// Called as each `let` is reached, so a binding is in scope only AFTER its declaration
// (sequential), which also yields correct shadowing of an outer same-named binding.
// Returns 0.
export function scopeBind(name: string, slot: i32) {
  scopeNames.push(name)
  scopeSlots.push(slot)
  0
}

// Drop the most recent binding — the loop-VARIABLE unbind. A `for` binds its
// variable in the ENCLOSING frame (no frame of its own), but the variable's
// scope is the LOOP (host parity: the loop declares it in the loop's scope), so
// both passes unbind it as the loop closes. Without this the loop var would
// keep shadowing a same-named binding that resolves through a LATER channel
// (e.g. a top-level `let` lowered to a wasm GLOBAL — locals win the lookup), so
// `for i in …` followed by `let i = 0` mis-read the dead loop counter.
// Returns 0.
export function scopeUnbind() {
  scopeNames.pop()
  scopeSlots.pop()
  0
}

// The declared-local POSITION bound to `name` by the innermost live scope frame, or
// -1 if `name` is not a live lexical binding. Searches the scope stack top-down
// (innermost first), so a shadowing inner `let` wins over an outer same-named one.
function scopeSlotOf(name: string) {
  let k = scopeNames.length
  while k > 0 {
    k = k - 1
    if scopeNames[k] == name { return scopeSlots[k] }
  }
  -1
}

// Opening a control frame: bump the running depth. Returns 0.
export function ctrlEnter() {
  ctrlDepth = ctrlDepth + 1
  0
}

// Closing a control frame (its matching `end`): drop the running depth. Returns 0.
export function ctrlLeave() {
  ctrlDepth = ctrlDepth - 1
  0
}

// The wasm local base of the ref-push scratch frame for ref-list table slot `slot`.
export function refPushScratchBaseFor(slot: i32) {
  let i = 0
  while i < fnRefPushSlots.length {
    if fnRefPushSlots[i] == slot { return refPushBaseBySlot[i] }
    i = i + 1
  }
  refPushScratchBase
}

// Resolve a value type-NAME to a struct TABLE index: a declared struct by name, or
// an inline object type `{a:T,b:U}` matched by FIELD-NAME SET against the table
// (anonymous shapes are interned from literals by `collectAnonShapes` under `#anonN`
// names, so the annotation text never matches by name — the field set is the key,
// exactly how `structIndexOfObj` binds literals). -1 when nothing matches.
function structIndexByValName(name: string) {
  const si = structIndexByName(name)
  if si >= 0 { return si }
  if name.length < 2 { return -1 }
  if name[0] != '{' { return -1 }
  if name[1] == '[' { return -1 }
  // Parse the field NAMES out of `{a:T,b:U}`: each field name runs from a `{`/`,`
  // at depth 1 to its `:`. Nested `{}`/`[]` in field types are depth-tracked so
  // their commas/colons don't split.
  const fnames: string[] = []
  let depth = 0
  let i = 0
  let start = -1
  while i < name.length {
    const c = name[i]
    if c == '{' || c == '[' {
      depth = depth + 1
      if depth == 1 { start = i + 1 }
    } else if c == '}' || c == ']' {
      depth = depth - 1
    } else if c == ',' {
      if depth == 1 { start = i + 1 }
    } else if c == ':' {
      if depth == 1 {
        if start >= 0 { fnames.push(name.slice(start, i)) }
        start = -1
      }
    }
    i = i + 1
  }
  if fnames.length == 0 { return -1 }
  // Match by exact field-name set (count + every name present).
  let s = 0
  while s < sNames.length {
    if sFieldCount[s] == fnames.length {
      let ok = true
      let k = 0
      while k < fnames.length {
        if sFieldIndex(s, fnames[k]) < 0 { ok = false }
        k = k + 1
      }
      if ok { return s }
    }
    s = s + 1
  }
  -1
}

// The mv value KIND of a map VALUE type-name — the ONE enumeration of which value types a
// string-keyed map supports (`mvValKind` vocabulary): `-1` a mono i32 value (i32 / boolean /
// literal-union atom — the value IS an i32, riding the shared mono `$mapStruct`), `-3`
// unsupported, else the per-slot kind (3 string · 11 f64 · 10 i64 · 13 f32 · 6 ref-list /
// nested-map value · 2 union box · 14 closure · 1 struct). Read by BOTH `mvShapeOfValName`
// (the slot interner — the local path) and `retMapFlag` (the param/return valtype gate) so
// the two cannot drift: when the gate enumerated the value types independently it lacked the
// scalar/atom/closure/union arms, and an annotated map return fell through to an i32 result
// valtype over a ref-returning body — invalid wasm at the return seam.
// The single non-null member of a NICHE-nullable map VALUE name — `{f: …} | null` yields
// the struct member, `{[string]: V} | null` the map member — or "" when `valName` is not
// `X | null` with exactly ONE non-null member of a kind the nullable-value map rep covers
// (a struct shape or a map). The chokepoint `mvValKindOfName` / `mvShapeOfValName` / the
// map op sites strip through, so the slot shares its vals rep (and heap dedup) with the
// non-null twin.
export function nulRefMapValInnerOf(valName: string): string {
  if !unionHasAtom(valName, "null") { return "" }
  const atoms: string[] = []
  splitUnionAtoms(valName, atoms)
  let inner = ""
  let nonNull = 0
  let i = 0
  while i < atoms.length {
    if atoms[i] != "null" {
      nonNull = nonNull + 1
      inner = atoms[i]
    }
    i = i + 1
  }
  if nonNull != 1 { return "" }
  if inner == "string" { return inner }
  if nameIsMap(inner) && !nameIsMapMemberUnion(inner) { return inner }
  // A CLOSURE member (`(() => string) | null` — the member keeps its grouping parens, so the
  // arrow sits at paren depth 1): the closure fat-pointer rides the SAME `(ref null
  // $cloStruct)` vals element a non-null closure value uses — the closure niche of the
  // nullable-value map. A top-level arrow on the RAW member would be a function RETURNING a
  // nullable (never produced by `splitUnionAtoms`, which only yields depth-0 `|` members).
  if annArrowAt(peelGroupParens(inner)) >= 0 { return inner }
  if structIndexByValName(inner) >= 0 { return inner }
  ""
}

// True when the interned mv slot's value is a NICHE-nullable ref value (`{f: …} | null` /
// `{[string]: V} | null`): the vals element legitimately holds null — the store seeds
// `ref.null <elem>` for a bare `null` and the fused `?? d` read skips the non-null recover.
export function mvSlotNullable(slot: i32) {
  if slot < 0 { return false }
  nulRefMapValInnerOf(mvValName[slot]) != ""
}

export function mvValKindOfName(valName: string): i32 {
  if valName == "i32" || valName == "boolean" { return -1 }
  // A literal-union ATOM value (`{[string]: K0}`, `K0 = "aa" | "bb"`): each value IS the
  // interned atom code — a plain i32 — so the map is the MONO i32 map. Checked BEFORE the
  // union arm, whose member count would otherwise claim the alias and BOX the values (the
  // store coerced the i32 atom into a union box the read then handed to an i32 consumer).
  if nameIsLitUnionType(valName) { return -1 }
  // A NULLABLE-ATOM value that reps as a plain i32 NICHE (no box): a nullable litunion
  // (`K0 | null` — atom ids ≥ 0, `-1` = null) or a nullable boolean (`boolean | null` —
  // 0/1, `2` = null). Each value IS an i32 with a spare sentinel, so the map is the MONO i32
  // map — NOT a ref-VALUE map. Checked BEFORE the union arm below, whose member count (`K0`'s
  // members + `null`, or `boolean` + `null`) would else claim it and BOX the values into a
  // union box (the store coerced a raw i32 niche into a `(ref $box)` cell — invalid wasm).
  if nameIsNulLitUnion(valName) || nameIsNulBool(valName) { return -1 }
  // A NULLABLE union value. Three sound shapes, one loud remainder:
  //   · a NICHE nullable REF value — ONE struct (`{f: …} | null`) or map
  //     (`{[string]: V} | null`) member + null — rides the SAME vals rep as its
  //     non-null twin: the `(ref null <elem>)` vals slot carries a stored null
  //     DIRECTLY, a bare `null` stores `ref.null <elem>`, and the fused `?? d`
  //     read PRESERVES a stored null (the hit arm skips the non-null recover —
  //     the default fires only on a MISSING key, the corpus oracle's semantics).
  //     The read binds the corresponding NULLABLE local kind (`nulstruct`/`nulmap`).
  //   · a pure scalar/string nullable value-union (`i32 | null`, `i64 | string |
  //     null`) boxes fine — the shared value box has a null tag; the nullable-atom
  //     NICHE forms (`K0 | null` / `boolean | null`) rep as a plain i32 above.
  //   · a nullable union with TWO OR MORE non-null members carrying a ref member
  //     (`{f: {[string]: f64}} | {w: i32} | null`) is a BOX union: `null` boxes as
  //     the null-tagged box at the store (`emitUnionCoerce`'s NullLit arm), so the
  //     vals element itself is never null — it falls to the union arm below.
  //   · a SINGLE list / closure / bare-string member + null has no nullable-value
  //     rep yet (`string | null` is not a value union — no box is ever minted; a
  //     list/closure niche needs its own wrapper slot): reject loudly at every op
  //     site, never invalid wasm.
  if unionHasAtom(valName, "null") {
    const nin = nulRefMapValInnerOf(valName)
    if nin != "" {
      if nin == "string" { return 3 }
      if nameIsMap(nin) { return 6 }
      // A NULLABLE-CLOSURE value (`(() => string) | null`): kind 14 — the vals element is
      // already the `(ref null $cloStruct)` fat-pointer, so the niche rides the non-null
      // closure rep (a bare `null` stores `ref.null`, the fused `?? d` read preserves a
      // stored null). A litunion RESULT (`((i32) => K0) | null`) stays a loud reject: the
      // read stays nullable (the hit arm preserves a stored null), so the call needs a
      // narrowed spelling the checker does not yet accept for this value shape — the
      // atom-result recovery the NON-null closure arm has cannot be exercised through it.
      const ncl = peelGroupParens(nin)
      const nca = annArrowAt(ncl)
      if nca >= 0 {
        let nri = nca + 2
        while nri < ncl.length && ncl[nri] == ' ' { nri = nri + 1 }
        if nameIsLitUnionType(ncl.slice(nri, ncl.length)) { return -3 }
        return 14
      }
      return 1
    }
    const nulAtoms: string[] = []
    splitUnionAtoms(valName, nulAtoms)
    let nonNull = 0
    let refMember = false
    let na = 0
    while na < nulAtoms.length {
      if nulAtoms[na] != "null" {
        nonNull = nonNull + 1
        const nvk = valueAtomKind(nulAtoms[na])
        if nvk < 0 || nvk >= 7 { refMember = true }
      }
      na = na + 1
    }
    if refMember && nonNull < 2 { return -3 }
    if !refMember && !isValueUnionName(valName) { return -3 }
  }
  let kind = -1
  if valName == "string" {
    kind = 3
  } else if valName == "f64" {
    // An f64-valued map: its vals list is the scalar f64 list (`$fl64TypeIdx` wrapper /
    // `$fa64TypeIdx` backing), NOT a ref list. Rides the existing mv-slot frame, but the
    // value is a scalar — its typed valStash is an f64 local (not a nullable ref).
    kind = 11
  } else if valName == "i64" {
    // An i64-valued map: the scalar i64 list (`$il64TypeIdx`/`$ia64TypeIdx`); valStash i64.
    kind = 10
  } else if valName == "f32" {
    // An f32-valued map: the scalar f32 list (`$fl32TypeIdx`/`$fa32TypeIdx`); valStash f32.
    kind = 13
  } else if nameIsMap(valName) && !nameIsMapMemberUnion(valName) {
    // A NESTED map (`{[string]: {[string]: V}}`): the value is an INNER map struct ref,
    // stored in a ref list whose element kind is 3 (a map element → the inner map struct).
    // Reuses the SAME ref-value spine as a struct-valued map; only the element heap differs.
    // The member-union guard keeps a map-FIRST union value (`{[string]: i32} | f64` — a name
    // `nameIsMap` matches but which is a union BOX, not a nested map) out of this arm, so it
    // reaches the union arm below (where a map MEMBER is rejected loudly — see there).
    // The inner-value chain resolves recursively to ANY depth — a triple-nested map, or one
    // bottoming out in a list of maps (`{[string]: {[string]: {[string]: f32}[]}}`) — through
    // the same `ensureRefElem`/`mvShapeOfValName` mutual recursion the intern side uses.
    kind = 6
  } else if (
    nameIsI32Array(valName) ||
    nameIsStringArray(valName) ||
    nameIsF64Array(valName) ||
    nameIsI64Array(valName) ||
    nameIsF32Array(valName)
  ) {
    // A LIST-valued map (`{[string]: i32[]}` / `string[]` / `f64[]` / `i64[]` / `f32[]` /
    // `boolean[]`): the value is a list WRAPPER ref, stored in a ref list whose element kind
    // picks the inner list's wrapper (`refArrElemKind("<value>[]")` → 4/6/7/8/10). Same ref-value
    // spine as a nested map.
    kind = 6
  } else if nameIsRefArray(valName) {
    // ANY ref-array map value — struct-list (`S[]`), union-list (`(C|D)[]`), a NESTED `S[][]` /
    // `i32[][]`, or a closure list (`((i32)=>i32)[]`): the value is a list WRAPPER ref, stored in
    // a ref-value list whose element is this value's wrapper (`ensureRefElem`, recursive). The
    // store seeds the value literal off this slot and the read classifies the value's element
    // recursively, so any nesting / leaf falls out — one predicate, no per-shape special cases.
    // A list-of-MAPS element (`{[string]: {[string]: V}[]}`) resolves through the same
    // recursion: `ensureRefElem`'s map-element arm interns the inner map's own value slot
    // BEFORE this slot's parallel arrays are pushed (`mvShapeOfValName`'s kind-6 pre-block),
    // so the deep element read lands on a fully-resolved slot.
    kind = 6
  } else if unionMemberCount(unionMemberSetOf(valName)) > 1 {
    // A UNION-valued map: each value is the shared union BOX ref (`uBoxIdx`), stored in a ref
    // list whose element kind is 2 (the union box) — the SAME ref-value spine as a struct
    // value, only the element heap + the store-coerce / read-classify differ. Covers a VALUE
    // union (`{[string]: i32 | string}`), a STRUCT / heterogeneous union (`{[string]: C | S}`),
    // a union ALIAS (`type Shape = C | S`; `unionMemberSetOf` expands it before the count`),
    // and a union with a MAP member (`{[string]: {[string]: i32} | boolean}`): the map arm
    // boxes exactly as it does in BINDING position — the store/read seams route through
    // `emitUnionBoxArg` → `emitUnionCoerce`, whose map-carrier arm tags the map-struct ref
    // with the arm's `mapSlotTag`; `mvShapeOfValName` interns the arm's mv slot
    // (`markMapUnionArms`) so the tag and the narrowed read resolve the same slot.
    kind = 2
  } else if annArrowAt(valName) >= 0 {
    // A FUNCTION-valued map (`{[string]: (i32) => i32}`): each value is a closure fat-pointer
    // (`ref $cloStructIdx`), stored in a ref list whose element kind is 5 (the closure) — the
    // SAME rep an `((i32) => i32)[]` array uses. A read yields a closure local; the call
    // resolves its sig from the value annotation. A litunion RESULT (`(i32) => K0`) rides the
    // same rep: the call's `$fnsig` keys the i32 atom (`>i`) and the atom widens to its member
    // string at the print seam — `exprString`'s value-call arm gates its per-name `>S` claim on
    // the call node's litunion-alias type, so the `??`-bound callee's SOFTENED render
    // (`(i32) => string`) never routes the raw atom into the string path.
    kind = 14
  } else {
    if structIndexByValName(valName) >= 0 { kind = 1 }
  }
  if kind < 0 { return -3 }
  kind
}

// Classify + intern a map VALUE type-name, returning the binding's map SHAPE code:
// `-1` mono i32 map (i32 / boolean / atom values), a slot `>= 0` for a ref/scalar
// value type, or `-3` unsupported (the op sites fail loudly). Interning is
// idempotent (one slot per distinct name). Kind-1 (struct) values force the
// element's ref-list types (`rlInternName`), and every ref-valued map forces the
// string-list (keys) + mono map types — the shared probe machinery and the keys
// list ride on them.
export function mvShapeOfValName(valName: string) {
  const kind = mvValKindOfName(valName)
  if kind == -1 { return -1 }
  if kind < 0 { return -3 }
  // A NICHE-nullable value name resolves its struct/map identity — and keys its vals
  // ref-list slot — through the single non-null member, so the slot SHARES the vals rep
  // (and the heap-type dedup) with its non-null twin.
  let bare = valName
  const nin = nulRefMapValInnerOf(valName)
  if nin != "" { bare = nin }
  let vsi = -1
  if kind == 1 { vsi = structIndexByValName(bare) }
  // A VALUE union also interns its scalar value-box reps; a struct/heterogeneous
  // union just rides the box payload, so no value boxes are needed. A MAP arm's mv
  // value slot is interned (`markMapUnionArms` — idempotent) so the store-coerce tag
  // (`mapSlotTag`) and the narrowed read resolve the same slot at the map-value position.
  if kind == 2 {
    if isValueUnionName(valName) { registerValueUnionName(valName) }
    markMapUnionArms(valName)
  }
  let i = 0
  while i < mvValName.length {
    if mvValName[i] == valName { return i }
    i = i + 1
  }
  // A kind-6 (ref-VALUE: nested map / list) value forces the i32-list + map types, and a
  // MAP value also interns its INNER value shape first (so a ref-valued inner map's struct
  // exists) — for the common mono inner (`{[string]: i32}`) that is a no-op
  // (`mvShapeOfValName("i32")` returns -1). ALL of the recursive interning — including the
  // vals ref-list slot (`ensureRefElem`, whose map-element arm RE-ENTERS `mvShapeOfValName`
  // for a list-of-maps value) — runs BEFORE this slot's parallel arrays are pushed: a
  // reentrant intern between `mvValName.push` and `mvRlSlot.push` would land its own
  // `mvRlSlot` entry at THIS slot's index, skewing every parallel table after it.
  let rls6 = -1
  if kind == 6 {
    lUsed = true
    aUsed = true
    if nameIsMap(bare) {
      mUsed = true
      mvShapeOfValName(mapValNameOf(bare))
    }
    // A non-i32 LIST value forces its inner list's type so the element wrapper heap exists.
    if nameIsStringArray(bare) { slUsed = true }
    else if nameIsF64Array(bare) { fa64Used = true }
    else if nameIsI64Array(bare) { ia64Used = true }
    // The vals ref-list slot, keyed by the value name with the recursively-interned inner
    // slots — the SAME `ensureRefElem` the array path uses. Its recursion strictly shrinks
    // the element spelling, so it never re-enters on `valName` itself.
    rls6 = ensureRefElem(bare)
  }
  mvValName.push(valName)
  mvValKind.push(kind)
  mvValStructIdx.push(vsi)
  if kind == 1 {
    mvRlSlot.push(rlInternName(sNames[vsi], 1))
    rlUsed = true
    raUsed = true
  } else if kind == 2 {
    // A union-VALUE ref list: element kind 2 (the union box, heap `uBoxIdx`).
    mvRlSlot.push(rlInternName(valName, 2))
    rlUsed = true
    raUsed = true
  } else if kind == 6 {
    // The map's VALUE is a ref LIST (`S[]` struct-list, `(C|D)[]` union-list, `i32[]` scalar
    // list, or a nested map): the vals ref-list slot interned above, before this slot's
    // parallel-array pushes.
    mvRlSlot.push(rls6)
    rlUsed = true
    raUsed = true
  } else if kind == 14 {
    // A CLOSURE-VALUE ref list: element kind 5 (the closure fat-pointer, heap `cloStructIdx`).
    mvRlSlot.push(rlInternName(valName, 5))
    rlUsed = true
    raUsed = true
  } else {
    mvRlSlot.push(-1)
  }
  if kind == 11 { fa64Used = true }
  if kind == 10 { ia64Used = true }
  if kind == 13 { fa32Used = true }
  // A string-valued map: force the string-LIST value flag so a bound `m.values()` (a
  // `string[]`) supports `.length` / indexing (which gate on `slUsed`).
  if kind == 3 {
    slUsed = true
    aUsed = true
  }
  mvMapTypeIdx.push(0)
  mvValName.length - 1
}

// FIND-ONLY mv-slot lookup by value type-name: `-1` for the mono i32 map
// (i32/boolean values), the interned slot otherwise. NEVER interns — all mv
// interning happens in `collectA`'s arena scan (a slot interned after
// `mAssignTypeIndices` would mint no type index) — so a miss is a compiler bug
// and fails loudly.
export function mvSlotOfValNameFind(valName: string) {
  // Mono-ness is decided by the ONE classifier the interner uses (`mvValKindOfName`):
  // i32 / boolean, a literal-union ATOM value (`{[string]: K0}` — a struct FIELD records
  // the alias name "K0" in `sFieldElemName`), and the nullable-atom niches (`K0 | null`,
  // `boolean | null`) all ride the shared mono `$mStructIdx` with NO interned slot. The
  // old two-name test rejected the atom spellings loudly ("no interned slot") even
  // though the SAME map lowers fine as a binding — the R1 map-in-field seam.
  if mvValKindOfName(valName) == -1 { return -1 }
  let i = 0
  while i < mvValName.length {
    if mvValName[i] == valName { return i }
    i = i + 1
  }
  emitFail("emitProgram: map value type has no interned slot")
  -1
}

// A kind-6 (ref-VALUE) map slot's values are either inner MAP structs (ref-list element
// kind 3) or i32-LIST wrappers (element kind 4). These split the two so a read classifies
// as the right thing — `m[k]` over a nested map is a Map, over a list-valued map an i32 list.
function mvValIsMap(slot: i32) {
  if slot < 0 { return false }
  if mvValKind[slot] != 6 { return false }
  rlElemKindTbl[mvRlSlot[slot]] == 3
}

// The list-element rep of a list-VALUED map slot — `2` i32-list (ref-list elem 4), `7`
// string-list (elem 6), `12` f64-list (elem 7), `20` i64-list (elem 8) — or -1 if the slot's
// value is not a list. Maps the ref-list element kind to the value list's classifier rep.
export function mvListValKind(slot: i32): VKind | null {
  if slot < 0 { return null }
  if mvValKind[slot] != 6 { return null }
  const ek = rlElemKindTbl[mvRlSlot[slot]]
  if ek == 4 { return "list" }
  if ek == 6 { return "strlist" }
  if ek == 7 { return "f64list" }
  if ek == 8 { return "i64list" }
  if ek == 10 {
    return "f32list" // f32-inner list → an f32-list value (kind 21)
  }
  if ek == 9 {
    return "reflist" // struct-list value → a ref list
  }
  return null
}

// The mv slot of a `m[k]` / `m[k] ?? d` read over a struct-LIST-valued map (the value is a
// struct list, element kind 9), else -1. The hook `refListElemNameOfExpr` uses to name the
// read's element (the inner struct), so `(m[k] ?? []).length` / `[i].field` resolve.
function mapReadStructListMvSlot(exprIx: i32, fnIx: i32) {
  const cm = coalesceMvSlot(exprIx, fnIx)
  if cm >= 0 {
    if mvListValKind(cm) == "reflist" { return cm }
  }
  const mr = mapReadMvSlot(exprIx, fnIx)
  if mr >= 0 {
    if mvListValKind(mr) == "reflist" { return mr }
  }
  -1
}

// ── scalar-list descriptor (the i32 / f64 / i64 list unification) ──────────────
// A SCALAR-element list (`i32[]` / `boolean[]` / `f64[]` / `i64[]`) is one shape
// parameterized by its element's valtype: a growable `{ backing, len, cap }` wrapper over
// a raw `(array (mut <elem>))`. The list ops (`.get`/`.pop`/`.slice`/index/`.map`) used to
// branch `if exprF64Array { fl64/fa64 } else { l/a }` — a binary fork with no room for a
// third element type. These descriptors map a CANONICAL element kind (the `fbValtype`
// codes: 0 i32/boolean · 11 f64 · 10 i64) to its list types + read shape, so a list op is
// written ONCE over the kind and a new scalar type is a descriptor arm, not a new branch
// in every function.

// The canonical scalar element kind of a list-valued expression — 0 (i32/boolean), 11
// (f64), 10 (i64) — or -1 (a ref / string / map list, or not a list). The single dispatch
// the scalar list ops consult instead of each re-deriving `exprF64Array`.
export function scalarListElemKind(exprIx: i32, fnIx: i32): VKind | null {
  if exprF32Array(exprIx, fnIx) { return "f32" }
  if exprF64Array(exprIx, fnIx) { return "f64" }
  if exprI64Array(exprIx, fnIx) { return "i64" }
  if exprArray(exprIx, fnIx) { return "i32" }
  return null
}

// ── active `is`-narrowing scope ───────────────────────────────────────────────
// When emitting the THEN-branch of `if n is A { … }`, the union-typed identifier
// `n` is narrowed to variant `A`, so a field read `n.f` in that branch lowers to
// the downcast. The active narrowings are a STACK (parallel `narrowNames` /
// `narrowVariants`): nested guards over DISTINCT union locals (`if ta is TyPrim { if
// tb is TyPrim { … ta.primName … tb.primName … } }`, the `sameNumeric` shape) each
// push a binding, so BOTH `ta` and `tb` stay narrowed in the inner branch — a single
// slot would lose the outer one. A branch saves the stack LENGTH and truncates back
// on exit, so nesting + the else-branch see the right scope. `narrowVariantFor`
// resolves a receiver name to its INNERMOST active variant (shadowing-correct).
// `narrowTop` is the logical stack DEPTH: only `narrowNames[0 .. narrowTop-1]` are
// active. Entries are appended on push; on branch exit the depth is rewound (the arrays
// keep their slots — no `.pop()`, so no global-list-pop self-host dependency). A push
// past the current length appends; a push within reuses/overwrites the slot.
// (`narrowNames`/`narrowVariants`/`narrowTop` and the `nli*` tables are declared
// early, before `computeRetInference` — module-level `let`s must textually
// precede the function bodies/call sites that read them.)

// The variant a union local `name` is narrowed to in the current scope (the innermost
// active binding within `narrowTop`), or "" if `name` is not currently narrowed.
export function narrowVariantFor(name: string) {
  let i = narrowTop - 1
  while i >= 0 {
    if narrowNames[i] == name { return narrowVariants[i] }
    i = i - 1
  }
  ""
}

// Push an active narrowing `name → variant`, growing the stack arrays if needed. Returns
// the new depth.
function pushNarrow(name: string, variant: string) {
  if narrowTop < narrowNames.length {
    narrowNames[narrowTop] = name
    narrowVariants[narrowTop] = variant
  } else {
    narrowNames.push(name)
    narrowVariants.push(variant)
  }
  narrowTop = narrowTop + 1
  narrowTop
}

// Append the declared-local name `name` to `localNames` as a FRESH slot (one wasm
// local PER lexical binding — no dedupe by name, so two same-named `let`s in disjoint
// branches get DISTINCT slots, hence distinct valtypes). `structIdx` is the local's
// struct table index when it is a struct ref (`isRef == 1`), else `-1`. Returns the new
// slot's POSITION in `localNames` (its wasm index is `paramCount + position`).
export function addLocalName(name: string, isRef: VKind, structIdx: i32) {
  const pos = localNames.length
  localNames.push(name)
  localIsRef.push(isRef)
  localStructIdx.push(structIdx)
  localLoopVar.push(0)
  localLitUnion.push(0)
  pos
}

// Mark the declared-local slot as a LOOP VARIABLE (a `for` counter / for-in
// element). A loop var's scope is the LOOP: while it is live the scope stack
// resolves it; once its loop closes (`scopeUnbind`) it must NOT be resolvable
// again — but the flat `localNames` fallback scan would still find it (it
// serves the scope-less DETECTION passes, which must keep seeing loop vars for
// in-body classification). RESOLUTION (`declaredIndexOf`) therefore skips
// flagged slots in its fallback, so a post-loop reference falls through to an
// outer/global binding exactly as the host's loop-scoped declaration does.
export function markLoopVarSlot(slot: i32) {
  localLoopVar[slot] = 1
  0
}

// The `.push`/`.pop` element-kind SELECTOR threaded through the reservation walkers (C2 cleanup:
// a named literal union replacing the bare 0–5 codes). `pop` only uses i32/ref/str.
type PushKind = "i32" | "ref" | "str" | "f64" | "i64" | "f32"

// The scratch pre-scan carries all six PushKinds as ONE bitmask, LSB-first in
// PushKind declaration order, so a single body walk classifies every `.push`/
// `.pop` receiver once (instead of one whole-body walk per kind per query).
function pushKindBit(kind: PushKind) {
  if kind == "i32" { return 1 }
  if kind == "ref" { return 2 }
  if kind == "str" { return 4 }
  if kind == "f64" { return 8 }
  if kind == "i64" { return 16 }
  32 // "f32"
}

// Classify the `.push`/`.pop` RECEIVER at `objIx` into its PushKind bits with one
// classifier fan-out: ref/str/f64/i64/f32 list kinds, or — when none of those
// claim it — the i32 list kind.
function pushKindBitsOf(objIx: i32, fnIx: i32) {
  let bits = 0
  if exprRefArray(objIx, fnIx) { bits = bits | 2 }
  if exprStringArray(objIx, fnIx) { bits = bits | 4 }
  if exprF64Array(objIx, fnIx) { bits = bits | 8 }
  if exprI64Array(objIx, fnIx) { bits = bits | 16 }
  if exprF32Array(objIx, fnIx) { bits = bits | 32 }
  if bits == 0 { return 1 }
  bits
}

// The receiver-kind bits of a statement-level `recv.push(x)` member-call (the
// `Call` whose `callFn` is a `Member` with property `push`), or 0 when `stmtIx`
// is no such statement. Detects which inline-push scratch locals a function
// needs; the kinds get DISTINCT scratch frames so a function may push onto any mix.
export function stmtPushBits(stmtIx: i32, fnIx: i32) {
  const s = P.nodes[stmtIx]
  if s is Call {
    const callee = P.nodes[s.callFn]
    if callee is Member {
      if callee.memProp == "push" { return pushKindBitsOf(callee.memObj, fnIx) }
    }
  }
  0
}

// The receiver-kind bits of a `recv.pop()` at `callIx` whose receiver is a
// struct-FIELD / global-field array read (a `Member`, e.g. `T.scopes.pop()`), or
// 0 otherwise. A bare-LOCAL pop needs NO scratch (it references the local in
// place), so it reports no bits — only a Member receiver, which must be
// materialized into the push frame's `recvRef` scratch slot. Lets a `.pop`-on-
// field function reserve the same scratch frame a `.push`-on-field one does.
function callPopBits(callIx: i32, fnIx: i32) {
  const c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      // `.clear()` resolves its receiver the same way `.pop()` does (a Member /
      // global receiver stages the wrapper ref in `recvRef`), so it counts too.
      if callee.memProp == "pop" || callee.memProp == "clear" {
        const recv = P.nodes[callee.memObj]
        // A struct-FIELD / global-field Member receiver, OR a bare module-GLOBAL list
        // ident — both materialize the wrapper ref into the `recvRef` scratch slot, so
        // both need the push frame reserved. A bare LOCAL pop references the local in
        // place and needs no scratch, so it is NOT counted.
        let needsScratch = false
        if recv is Member {
          needsScratch = true
        } else if recv is Ident {
          if localIndexOf(fnIx, recv.identName) < 0 {
            if globalIndexOf(recv.identName) >= 0 { needsScratch = true }
          }
        }
        if needsScratch { return pushKindBitsOf(callee.memObj, fnIx) }
      }
    }
  }
  0
}

// True if the statement at `stmtIx` is a `recv.push(x)` whose receiver's list
// kind matches `kind` (the single-kind view of `stmtPushBits`, for the ref-slot
// collectors).
export function stmtIsPushKind(stmtIx: i32, fnIx: i32, kind: PushKind) {
  (stmtPushBits(stmtIx, fnIx) & pushKindBit(kind)) != 0
}

// True if `callIx` is a Member/global-receiver `.pop`/`.clear` of list kind
// `kind` (the single-kind view of `callPopBits`, for the ref-slot collectors).
export function callIsMemberPopKind(callIx: i32, fnIx: i32, kind: PushKind) {
  (callPopBits(callIx, fnIx) & pushKindBit(kind)) != 0
}

// The Member-receiver `.pop` kind bits anywhere in the expression at `exprIx` —
// a `.pop` appears in VALUE position (`let x = T.scopes.pop()`), so the
// reservation walk must descend expressions, not just statement receivers.
export function exprPopBits(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return 0 }
  const e = P.nodes[exprIx]
  if e is Call {
    let bits = callPopBits(exprIx, fnIx)
    const args = e.callArgs
    let i = 0
    while i < args.length {
      bits = bits | exprPopBits(args[i], fnIx)
      i = i + 1
    }
    return bits
  }
  if e is BinExpr {
    return exprPopBits(e.binLeft, fnIx) | exprPopBits(e.binRight, fnIx)
  }
  if e is Member { return exprPopBits(e.memObj, fnIx) }
  if e is Index {
    return exprPopBits(e.idxArr, fnIx) | exprPopBits(e.idxIndex, fnIx)
  }
  if e is Unary { return exprPopBits(e.unArg, fnIx) }
  if e is Paren { return exprPopBits(e.parInner, fnIx) }
  0
}

// ONE walk of the block at `blockIx` (descending into if/else + while/for bodies,
// the scopes `collectLocals` walks) accumulating BOTH the statement-level `.push`
// receiver kinds and the Member-receiver `.pop` kinds in every let-init / return /
// while-cond / for-header / expression-statement position. Replaces the twelve
// per-kind walks (six push + six pop) with a single pass that classifies each
// site once. `if` CONDITIONS are deliberately not scanned here (matching the
// per-kind walkers this folds); the start-fn if-scan handles its conditions.
export function blockPushPopBits(blockIx: i32, fnIx: i32) {
  let bits = 0
  const b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      const s = P.nodes[stmts[i]]
      if s is LetDecl {
        bits = bits | exprPopBits(s.letInit, fnIx)
      } else if s is RetStmt {
        bits = bits | exprPopBits(s.retArg, fnIx)
      } else if s is BinExpr {
        bits = bits | exprPopBits(stmts[i], fnIx)
      } else if s is Call {
        bits = bits | stmtPushBits(stmts[i], fnIx) | exprPopBits(stmts[i], fnIx)
      } else if s is IfStmt {
        bits = bits | ifChainPushPopBits(stmts[i], fnIx)
      } else if s is WhileStmt {
        bits = bits |
          exprPopBits(s.whileCond, fnIx) |
          blockPushPopBits(s.whileBody, fnIx)
      } else if s is ForIn {
        bits = bits |
          exprPopBits(s.fiIter, fnIx) |
          blockPushPopBits(s.fiBody, fnIx)
      } else if s is ForRange {
        bits = bits |
          exprPopBits(s.frFrom, fnIx) |
          exprPopBits(s.frTo, fnIx) |
          blockPushPopBits(s.frBody, fnIx)
      }
      i = i + 1
    }
  }
  bits
}

// The push/pop kind bits of every arm of the `if` / `else if` chain at `ifIx` —
// the then-branch, an `else` block, OR (RECURSIVELY) a chained `else if`. Mirrors
// `collectLocalsIf`'s recursion so a push buried under several `else if` arms (the
// `parseProgram` / `parseStmt` recursive-descent dispatch shape) is detected, not just
// the first one level (the prior hand-unrolled form missed 2+-deep chains).
function ifChainPushPopBits(ifIx: i32, fnIx: i32) {
  let bits = 0
  const s = P.nodes[ifIx]
  if s is IfStmt {
    bits = blockPushPopBits(s.ifThen, fnIx)
    if s.ifElse >= 0 {
      const els = P.nodes[s.ifElse]
      if els is Block { bits = bits | blockPushPopBits(s.ifElse, fnIx) }
      else if els is IfStmt { bits = bits | ifChainPushPopBits(s.ifElse, fnIx) }
    }
  }
  bits
}

// OR a push/pop kind mask into the six per-function `fnUses*Push` scratch-frame
// flags (a `.push` and a Member-receiver `.pop` of the same kind share a frame).
export function applyPushPopBits(bits: i32) {
  if (bits & 1) != 0 { fnUsesPush = true }
  if (bits & 2) != 0 { fnUsesRefPush = true }
  if (bits & 4) != 0 { fnUsesStrPush = true }
  if (bits & 8) != 0 { fnUsesF64Push = true }
  if (bits & 16) != 0 { fnUsesI64Push = true }
  if (bits & 32) != 0 { fnUsesF32Push = true }
  0
}

// Append the ref-list table SLOT of a ref `.push` receiver to `fnRefPushSlots` if not
// already present (so each DISTINCT pushed element type gets its own typed scratch frame).
export function recordRefPushSlot(slot: i32) {
  let i = 0
  while i < fnRefPushSlots.length {
    if fnRefPushSlots[i] == slot { return 0 }
    i = i + 1
  }
  fnRefPushSlots.push(slot)
  0
}

// ── string-op detection (G6: which functions need the string scratch frame) ───
// A function reserves the shared string scratch frame iff it uses ANY string `+`,
// string `==`/`!=`, or `.slice` anywhere in an expression — so the walk below
// descends through EVERY expression position (return values, let inits, conditions,
// call args, operands, members, indices), unlike the push detection which only
// needs statement-level receivers. `exprIsStrConcat`/`exprIsStrEq`/`exprIsStrSlice`
// each classify a single node; `exprHasStrOp` recurses; `blockHasStrOp` walks
// statements. `exprString` (defined later) resolves operand string-typedness from
// the already-built `localNames`/`localIsRef` (so this runs AFTER `buildLocals`).

// True if `binIx` is a `+` whose operands are strings (string concatenation).
export function exprIsStrConcat(binIx: i32, fnIx: i32) {
  const e = P.nodes[binIx]
  if e is BinExpr {
    if e.binOp == "+" {
      // A literal-union atom is a `string` subtype, so `"x" + k` / `k + "y"` (and `k1 + k2`)
      // concatenate — the atom operand widens to its member string in `emitStrConcat`.
      const lStr = exprString(e.binLeft, fnIx) || exprIsLitAtom(e.binLeft, fnIx)
      const rStr = exprString(e.binRight, fnIx) ||
        exprIsLitAtom(e.binRight, fnIx)
      return lStr || rStr
    }
  }
  false
}

// True if the Call at `callIx` passes a literal-union ATOM into a `string` parameter — the
// atom widens to its member string (`emitAtomToStr`), which rides the string-op scratch frame.
// An over-approximation (any atom arg + any `string` param) is fine: it only reserves a frame.
function callWidensAtomToStr(callIx: i32, fnIx: i32) {
  if gLitUnionUsed == 0 { return false }
  const c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Ident {
      const target = fnIndexOf(callee.identName)
      if target >= 0 {
        const cFn = P.nodes[fnStmts[target]]
        if cFn is FuncDecl {
          let anyAtom = false
          let ai = 0
          while ai < c.callArgs.length {
            if exprIsLitAtom(c.callArgs[ai], fnIx) { anyAtom = true }
            ai = ai + 1
          }
          if anyAtom {
            const params = cFn.fnParams
            let pi = 0
            while pi < params.length {
              if vtKindOfParam(params[pi]) == "str" { return true }
              pi = pi + 1
            }
          }
        }
      }
    }
  }
  false
}

// True if the assignment at `binIx` writes a literal-union atom into a `string`-typed target (a
// local, global, or struct field) — the atom widens to its member string, riding the string-op
// scratch frame. `exprString` over the TARGET uniformly covers all three lvalue forms.
function assignWidensAtomToStr(binIx: i32, fnIx: i32) {
  if gLitUnionUsed == 0 { return false }
  const a = P.nodes[binIx]
  if a is BinExpr {
    if a.binOp == "=" {
      if exprString(a.binLeft, fnIx) {
        if exprIsLitAtom(a.binRight, fnIx) { return true }
      }
    }
  }
  false
}

// True if `initIx` is a literal-union ATOM read in a GLOBAL initializer — an `Ident` referencing
// another module global whose declared type is a literal union. (Module-global inits have no
// locals/params, so an Ident is the only atom form; a member literal is a plain string, not an
// atom.) Gates the start-fn `string`-global widening + its scratch-frame reservation.
export function globalInitIsLitAtom(initIx: i32) {
  if initIx < 0 { return false }
  const e = P.nodes[unwrapParen(initIx)]
  if e is Ident {
    const gli = globalLetOf(e.identName)
    if gli >= 0 {
      const r = letIsLitUnion(gli)
      return r
    }
  }
  false
}

// True if the global at `letIx` is a `string` cell (kind 3) initialized with a literal-union atom
// — it widens to its member string in the start function, riding the string-op scratch frame.
export function globalInitWidensAtomToStr(letIx: i32) {
  if gLitUnionUsed == 0 { return false }
  if letIx < 0 { return false }
  const gk = globalCellKind(letIx)
  if gk != "str" && gk != "nulstr" { return false }
  const d = P.nodes[letIx]
  if d is LetDecl {
    const r = globalInitIsLitAtom(d.letInit)
    return r
  }
  false
}

// True if the binding at `letIx` is annotated `: string` and initialized with a literal-union
// atom — it widens to its member string at the init, riding the string-op scratch frame.
function letWidensAtomToStr(letIx: i32, fnIx: i32) {
  if gLitUnionUsed == 0 { return false }
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      if tyNameOf(d.letType) == "string" {
        if exprIsLitAtom(d.letInit, fnIx) { return true }
      }
    }
  }
  false
}

// True if `retArgIx` is a literal-union atom returned from a `string`-typed function (`fnIx`'s
// `fnRet`) — it widens to its member string at the return, riding the string-op scratch frame.
function retWidensAtomToStr(retArgIx: i32, fnIx: i32) {
  if gLitUnionUsed == 0 { return false }
  if retArgIx < 0 { return false }
  if fnIx < 0 { return false }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    if tyNameOf(fn.fnRet) == "string" {
      if exprIsLitAtom(retArgIx, fnIx) { return true }
    }
    // The INFERRED-string dual (mirrors `emitReturnValue`'s widen): an UN-annotated
    // function whose A20 return is `string` (one path returns a member literal,
    // another the atom) widens an atom return too — reserve the frame.
    if fn.fnRet < 0 && cloRetIsString(fnStmtsPosOf(fnIx)) {
      if exprIsLitAtom(retArgIx, fnIx) { return true }
    }
  }
  false
}

// True if `binIx` is `==`/`!=` whose operands are strings (string value-equality).
export function exprIsStrEq(binIx: i32, fnIx: i32) {
  const e = P.nodes[binIx]
  if e is BinExpr {
    if e.binOp == "==" || e.binOp == "!=" {
      // A comparison with `null` is a NULL-CHECK (handled by the nullable-string /
      // -struct / -list `ref.is_null` paths), never element-wise string equality — a
      // `string | null` operand would otherwise be element-compared against `null`.
      if P.nodes[unwrapParen(e.binLeft)] is NullLit { return false }
      if P.nodes[unwrapParen(e.binRight)] is NullLit { return false }
      return exprString(e.binLeft, fnIx) || exprString(e.binRight, fnIx)
    }
  }
  false
}

// True if `binIx` is an ORDERING comparison (`<`/`>`/`<=`/`>=`) over two STRING operands
// — a lexicographic compare (`emitStrLessCore`), not the numeric `i32.lt_s` path that
// would compare the array refs. BOTH operands must be strings (the checker rejects a
// mixed string/numeric ordering); the frame reserved by `exprHasStrOp` carries the loop.
export function exprIsStrOrder(binIx: i32, fnIx: i32) {
  const e = P.nodes[binIx]
  if e is BinExpr {
    const op = e.binOp
    if op == "<" || op == ">" || op == "<=" || op == ">=" {
      return exprString(e.binLeft, fnIx) && exprString(e.binRight, fnIx)
    }
  }
  false
}

// True if `binIx` is a `==`/`!=` whose union-box value compare can hit the
// STRING arm — a box compared against a string operand, or two boxes whose
// shared arms include `string`. Those payload compares stage their operands in
// the string scratch frame (`emitStrEqCore`), so the frame must be reserved.
function exprIsUnionStrEq(binIx: i32, fnIx: i32) {
  const e = P.nodes[binIx]
  if e is BinExpr {
    if e.binOp == "==" || e.binOp == "!=" {
      const lU = exprUnion(e.binLeft, fnIx)
      const rU = exprUnion(e.binRight, fnIx)
      if lU && rU {
        const ln = unionNameOfExpr(e.binLeft, fnIx)
        const rn = unionNameOfExpr(e.binRight, fnIx)
        return unionHasAtom(ln, "string") && unionHasAtom(rn, "string")
      }
      if lU { return exprString(e.binRight, fnIx) }
      if rU { return exprString(e.binLeft, fnIx) }
    }
  }
  false
}

// True if `binIx` is a same-shape STRUCT `==`/`!=` (a field-wise compare). Its
// string/array field compares stage operands in the string-op scratch frame, so
// it counts as a string op for frame reservation.
function exprIsStructEq(binIx: i32, fnIx: i32) {
  const e = P.nodes[binIx]
  if e is BinExpr {
    if e.binOp == "==" || e.binOp == "!=" {
      const lsi = structIndexOfExpr(e.binLeft, fnIx)
      if lsi >= 0 { return lsi == structIndexOfExpr(e.binRight, fnIx) }
    }
  }
  false
}

// ── list `==`/`!=`/`+` detection (which functions need the list-op frames) ────
// The list-op operand KIND of an expression: `0` an i32 list, `3` a string
// list, `4` an `i32[][]` (a ref list of i32-list elements), or -1 (not a list /
// an unsupported element kind). Order mirrors `emitIndex`'s receiver dispatch.
function listOpKindOf(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return -1 }
  if exprString(exprIx, fnIx) { return -1 }
  if exprStringArray(exprIx, fnIx) { return 3 }
  if exprF64Array(exprIx, fnIx) { return -1 }
  if exprRefArray(exprIx, fnIx) {
    const slot = refListSlotOfExpr(exprIx, fnIx)
    if slot >= 0 && slot < rlElemKindTbl.length {
      if rlElemKindTbl[slot] == 4 { return 4 }
    }
    return -1
  }
  if exprArray(exprIx, fnIx) { return 0 }
  -1
}

// The list-op kind of a `==`/`!=`/`+` BinExpr whose operands are BOTH lists of
// one kind, or -1 (not a list op — the caller keeps its existing dispatch).
export function listOpKindOfBin(binIx: i32, fnIx: i32) {
  const e = P.nodes[binIx]
  if e is BinExpr {
    if e.binOp == "==" || e.binOp == "!=" || e.binOp == "+" {
      const lk = listOpKindOf(e.binLeft, fnIx)
      if lk < 0 { return -1 }
      const rk = listOpKindOf(e.binRight, fnIx)
      if rk != lk { return -1 }
      return lk
    }
  }
  -1
}

// True if struct shape `si` carries a function-typed field (code 14), looking
// through nested-struct fields (code 15). `seen` guards recursive shapes.
function shapeHasCloField(si: i32, seen: i32[]) {
  let k = 0
  while k < seen.length {
    if seen[k] == si { return false }
    k = k + 1
  }
  seen.push(si)
  let fi = 0
  while fi < sFieldCount[si] {
    const code = sFieldTypeAt(si, fi)
    if code == 14 { return true }
    if code == 15 {
      const nsi = structIndexByName(sFieldElemNameAt(si, fi))
      if nsi >= 0 {
        if shapeHasCloField(nsi, seen) { return true }
      }
    }
    fi = fi + 1
  }
  false
}

// Note one BinExpr's function-identity equality site (`f == g`, or a struct
// equality whose shape carries a function-typed field) into `fnUsesCloEq` — the
// compare stages both operands in the 2-slot closure-eq frame.
export function cloEqNoteBin(binIx: i32, fnIx: i32) {
  const e = P.nodes[binIx]
  if e is BinExpr {
    if e.binOp == "==" || e.binOp == "!=" {
      if exprIsClosure(e.binLeft, fnIx) || exprIsClosure(e.binRight, fnIx) {
        fnUsesCloEq = true
        return 0
      }
      const si = structIndexOfExpr(e.binLeft, fnIx)
      if si >= 0 {
        const seen: i32[] = []
        if shapeHasCloField(si, seen) { fnUsesCloEq = true }
      }
    }
  }
  0
}

// True if `callIx` is a `recv.slice(start, end)` over a STRING receiver.
export function exprIsStrSlice(callIx: i32, fnIx: i32) {
  const c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      if callee.memProp == "slice" { return exprString(callee.memObj, fnIx) }
    }
  }
  false
}

// True if `callIx` is a `recv.indexOf(sub)` / `recv.includes(sub)` over a STRING
// receiver — both ride the same indexOf scan (`includes` negates the -1 compare).
export function exprIsStrIndexOf(callIx: i32, fnIx: i32) {
  const c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      if callee.memProp == "indexOf" || callee.memProp == "includes" {
        return exprString(callee.memObj, fnIx)
      }
    }
  }
  false
}

// True if `callIx` is a `recv.charCodeAt(i)` over a STRING receiver.
export function exprIsStrCharCode(callIx: i32, fnIx: i32) {
  const c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      if callee.memProp == "charCodeAt" {
        return exprString(callee.memObj, fnIx)
      }
    }
  }
  false
}

// True if the expression at `exprIx` (or any sub-expression) is a string `+`,
// string `==`/`!=`, or string `.slice`.
export function exprHasStrOp(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is BinExpr {
    if exprIsStrConcat(exprIx, fnIx) { return true }
    if exprIsStrEq(exprIx, fnIx) { return true }
    // A string ORDERING (`<`/`>`/`<=`/`>=`) rides the same lexicographic compare loop.
    if exprIsStrOrder(exprIx, fnIx) { return true }
    // A union-box `==`/`!=` whose value compare can hit the STRING arm stages
    // its payloads in the same frame (`emitStrEqCore`).
    if exprIsUnionStrEq(exprIx, fnIx) { return true }
    // A struct `==`/`!=` stages its string/array FIELD compares in the same frame.
    if exprIsStructEq(exprIx, fnIx) { return true }
    // An assignment of a literal-union atom into a `string` target widens (`emitAtomToStr`),
    // which stages the atom id in the string-op scratch frame.
    if assignWidensAtomToStr(exprIx, fnIx) { return true }
    if exprHasStrOp(e.binLeft, fnIx) { return true }
    return exprHasStrOp(e.binRight, fnIx)
  }
  if e is Call {
    if exprIsStrSlice(exprIx, fnIx) { return true }
    // A literal-union atom argument flowing into a `string` param widens (`emitAtomToStr`),
    // which stages the atom id in the string-op scratch frame.
    if callWidensAtomToStr(exprIx, fnIx) { return true }
    // `s.indexOf(sub)` / `s.includes(sub)` stage their receiver + needle + loop
    // counters in the same string scratch frame. (`charCodeAt` is a bare
    // `array.get` — no frame needed; its operands recurse below.)
    if exprIsStrIndexOf(exprIx, fnIx) { return true }
    // `print(<string>)` rides the string-op scratch frame (the streaming loop's
    // string ref + cursor + length live there).
    const pcal = P.nodes[e.callFn]
    if pcal is Ident {
      if pcal.identName == "print" {
        if e.callArgs.length == 1 {
          if exprString(e.callArgs[0], fnIx) { return true }
          // `print(<literal-union atom>)` widens to its member string — its per-member print chain rides
          // the same string-op scratch frame.
          if exprIsLitAtom(e.callArgs[0], fnIx) { return true }
        }
      }
      // `__trap__(<string>)` prints its reason through the same string streaming
      // loop before the abort, so it rides the string-op scratch frame too.
      if pcal.identName == "__trap__" {
        if e.callArgs.length == 1 {
          if exprString(e.callArgs[0], fnIx) { return true }
        }
      }
      // `toString(x)` builds its digits in the string-op scratch frame.
      if pcal.identName == "toString" { return true }
      // `fromCodePoints(xs)` stages its length + result there too.
      if pcal.identName == "fromCodePoints" { return true }
    }
    if exprHasStrOp(e.callFn, fnIx) { return true }
    const args = e.callArgs
    let i = 0
    while i < args.length {
      if exprHasStrOp(args[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  if e is Member { return exprHasStrOp(e.memObj, fnIx) }
  if e is Index {
    if exprHasStrOp(e.idxArr, fnIx) { return true }
    return exprHasStrOp(e.idxIndex, fnIx)
  }
  // An if-EXPRESSION in value position (`print(if a < b then …)`): a string op in the
  // condition or either arm needs the frame reserved too.
  if e is IfStmt {
    if exprHasStrOp(e.ifCond, fnIx) { return true }
    // An ATOM arm under a `string`-typed join widens (`emitRefIfArm` →
    // `emitAtomToStr`), staging the atom id in the string-op frame — reserve it.
    // Mirrors the emit decision (join type recorded by the checker, any arm).
    if tyKindOf(nodeTyIxOf(exprIx)) == 3 {
      if ifChainHasAtomArm(exprIx, fnIx) { return true }
    }
    if blockHasStrOp(e.ifThen, fnIx) { return true }
    if e.ifElse >= 0 { return blockHasStrOp(e.ifElse, fnIx) }
    return false
  }
  if e is Unary { return exprHasStrOp(e.unArg, fnIx) }
  if e is Paren { return exprHasStrOp(e.parInner, fnIx) }
  if e is IsExpr {
    // A string-LITERAL `is` (`s is "a"`) lowers through `emitStrEqCore`, so it
    // stages operands in the string scratch frame like a string `==`.
    if e.isVariant.length > 0 && e.isVariant[0] == '"' { return true }
    return exprHasStrOp(e.isObj, fnIx)
  }
  if e is AsExpr { return exprHasStrOp(e.asObj, fnIx) }
  if e is ObjLit {
    const fields = e.objFields
    let i = 0
    while i < fields.length {
      const f = P.nodes[fields[i]]
      if f is FieldInit {
        if exprHasStrOp(f.fiValue, fnIx) { return true }
        // A literal-union atom field value widens to a string (`string` field) — reserve the
        // string-op frame. (Any atom field value is destined for a `string` field; a literal-
        // union FIELD is not yet a rep, so this is a safe over-approximation.)
        if exprIsLitAtom(f.fiValue, fnIx) { return true }
      }
      i = i + 1
    }
    return false
  }
  if e is ArrayLit {
    const elems = e.arrElems
    let i = 0
    while i < elems.length {
      if exprHasStrOp(elems[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  false
}

// True if any arm TAIL of the value if/else-if chain at `ifIx` is a literal-union
// atom (`if c then k else "cc"` — under a `string`-typed join the atom arm widens
// to its member string, which rides the string-op scratch frame).
function ifChainHasAtomArm(ifIx: i32, fnIx: i32) {
  const s = P.nodes[ifIx]
  if s is IfStmt {
    const tv = ifThenValueIx(ifIx)
    if tv >= 0 {
      if exprIsLitAtom(tv, fnIx) { return true }
    }
    if s.ifElse >= 0 {
      const els = P.nodes[s.ifElse]
      if els is IfStmt { return ifChainHasAtomArm(s.ifElse, fnIx) }
      if els is Block {
        if els.blkStmts.length == 1 {
          return exprIsLitAtom(els.blkStmts[0], fnIx)
        }
      }
    }
  }
  false
}

// True if any statement in the block at `blockIx` (descending into if/else branches
// and while bodies, the scopes `collectLocals` walks) contains a string op. A
// wrapper restores the narrowing depth the scan's post-guard pushes (mirroring
// the emit loops) may leave behind on an early `true`.
export function blockHasStrOp(blockIx: i32, fnIx: i32) {
  const savedGuardTop = narrowTop
  const hit = blockHasStrOpScan(blockIx, fnIx)
  restoreNarrow(savedGuardTop)
  hit
}

function blockHasStrOpScan(blockIx: i32, fnIx: i32) {
  const b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      const s = P.nodes[stmts[i]]
      if s is LetDecl {
        if exprHasStrOp(s.letInit, fnIx) { return true }
        // A literal-union atom initializing a `string` local widens — reserve the frame.
        if letWidensAtomToStr(stmts[i], fnIx) { return true }
      } else if s is RetStmt {
        if exprHasStrOp(s.retArg, fnIx) { return true }
        // A literal-union atom returned as `string` widens — reserve the string-op frame.
        if retWidensAtomToStr(s.retArg, fnIx) { return true }
      } else if s is BinExpr {
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is Call {
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is ObjLit {
        // A bare trailing object-literal statement is a function's implicit-return value
        // (e.g. `mkTok` returns `{ …, text: gSrc.slice(…), … }`). Its field initializers
        // can contain string ops, so descend — `exprHasStrOp` walks `objFields`.
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is Member {
        // A bare trailing MEMBER access is also an implicit-return value — and its
        // receiver may be a string op, e.g. `s.slice(a, b).length` (a `.length` over
        // a slice call). Without this the slice's scratch frame goes unreserved and
        // the slice emit references an unallocated local. `exprHasStrOp` walks `memObj`.
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is Index {
        // Likewise a trailing `xs[i]` / `m[k]` index whose receiver/key uses a string op.
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is Paren {
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is Unary {
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is IsExpr {
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is AsExpr {
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is IfStmt {
        if ifChainHasStrOp(stmts[i], fnIx) { return true }
      } else if s is WhileStmt {
        if exprHasStrOp(s.whileCond, fnIx) { return true }
        if blockHasStrOp(s.whileBody, fnIx) { return true }
      } else if s is ForIn {
        if exprHasStrOp(s.fiIter, fnIx) { return true }
        if blockHasStrOp(s.fiBody, fnIx) { return true }
      } else if s is ForRange {
        if exprHasStrOp(s.frFrom, fnIx) { return true }
        if exprHasStrOp(s.frTo, fnIx) { return true }
        if blockHasStrOp(s.frBody, fnIx) { return true }
      }
      // Post-guard complement narrowing (mirrors the emit loops) — so a string
      // read below a returning guard (`if x is i32 { return 0 } print(x)`) is
      // detected under the SAME narrowing the emit applies. The wrapper restores.
      pushPostGuardNarrow(stmts[i], fnIx)
      i = i + 1
    }
  }
  false
}

// True if any arm of the `if` / `else if` chain at `ifIx` contains a string op — its
// condition, then-branch, `else` block, OR (RECURSIVELY) a chained `else if`. Mirrors
// `ifChainPushPopBits`: walks the WHOLE else-if chain, not just one level.
function ifChainHasStrOp(ifIx: i32, fnIx: i32) {
  const s = P.nodes[ifIx]
  if s is IfStmt {
    if exprHasStrOp(s.ifCond, fnIx) { return true }
    // Narrow across the THEN-branch (mirroring `emitStmt`/`collectLocalsIf`) so a string
    // op over a NARROWED variant field (`if n is A { … n.strField == x … }`, and nested
    // guards over distinct locals) is detected — `exprString` resolves a variant field's
    // string type only while the receiver's narrowing is active. Save/restore the depth.
    const savedTop = narrowTop
    const narrowed = setNarrowFromCond(s.ifCond, fnIx)
    const hit = blockHasStrOp(s.ifThen, fnIx)
    if narrowed { restoreNarrow(savedTop) }
    if hit { return true }
    if s.ifElse >= 0 {
      // A VALUE union narrows to the COMPLEMENT set in the else-arm (mirroring
      // `emitStmt`'s else lowering), so `else { print(v) }` with `v` now `string`
      // is detected as a string print and reserves the scratch frame.
      const savedElseTop = narrowTop
      const narrowedElse = setNarrowFromCondElse(s.ifCond, fnIx)
      const els = P.nodes[s.ifElse]
      let hitElse = false
      if els is Block { hitElse = blockHasStrOp(s.ifElse, fnIx) }
      else if els is IfStmt { hitElse = ifChainHasStrOp(s.ifElse, fnIx) }
      if narrowedElse { restoreNarrow(savedElseTop) }
      if hitElse { return true }
    }
  }
  false
}

// True if the FuncDecl at `fnIx` uses any string op (`+`/`==`/`!=`/`.slice`) — so it
// reserves the shared string scratch frame.
export function fnHasStrOp(fnIx: i32) {
  const fn = P.nodes[fnIx]
  if fn is FuncDecl { return blockHasStrOp(fn.fnBody, fnIx) }
  false
}

// ── array-intrinsic detection (std-design D1 / collections-design §LS.2) ──────
// `__array_new__(n, fill)` / `__array_new_default__(n)` / `__array_copy__(…)` /
// `__trap__()` lower INLINE at the call site (host parity: toWasm.ts lowers the
// same names to array.new / array.new_default / array.copy / unreachable). The
// two allocators reserve the 1-slot `arrNewScratchBase` frame; these walkers
// find them anywhere in a body — a pure NAME walk (no classification, so no
// narrowing bookkeeping is needed, unlike the string-op scan).

// The intrinsic-allocation ELEMENT KIND of the Call at `callIx`: `0` = the i32
// list (i32/boolean fills — the i32 backing), `1` = the f64 list (an f64 fill),
// `-1` = not an intrinsic allocation. `__array_new_default__` is always the i32
// list natively: its element kind is not derivable from the argument list (an
// f64 default needs `__array_new__(n, 0.0)`); the host covers it generically.
export function arrNewIntrKind(callIx: i32, fnIx: i32) {
  const c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Ident {
      if callee.identName == "__array_new__" {
        if c.callArgs.length == 2 {
          if exprIsF64(c.callArgs[1], fnIx) { return 1 }
          // A STRING fill (kind 2) builds the string list; a STRUCT/object-literal
          // fill (kind 3) builds the ref list for that element struct. (Ref
          // long-tail: closures / nested arrays / maps as fills still fail loudly.)
          if exprString(c.callArgs[1], fnIx) { return 2 }
          const anf = P.nodes[c.callArgs[1]]
          if anf is ObjLit { return 3 }
          if exprStruct(c.callArgs[1], fnIx) { return 3 }
        }
        return 0
      }
      if callee.identName == "__array_new_default__" { return 0 }
    }
  }
  -1
}

// The declared-local POSITION of `name`: the innermost live lexical binding if the
// scope stack has one (so a same-named binding in a disjoint/inner block resolves to
// ITS own slot, with its own valtype), else the first `localNames` slot of that name
// as a safety net (used when no scope frame is active, e.g. the `fnUses*` detection
// pass, where any same-named slot's type suffices). -1 if `name` is not a local.
// The RESOLUTION variant of `declaredSlotOf`: identical, except the flat
// fallback scan SKIPS loop-variable slots (`localLoopVar`). At resolution time
// the scope stack is maintained in lockstep with the walk, so a live loop var
// always resolves through it; a flat-scan hit on a loop var would be a DEAD
// binding (its loop already closed) shadowing the outer/global the host would
// resolve (see `markLoopVarSlot`). Detection/classifier passes keep using
// `declaredSlotOf` (they run scope-less and must see in-body loop vars).
function declaredSlotLive(name: string) {
  const scoped = scopeSlotOf(name)
  if scoped >= 0 { return scoped }
  let pos = 0
  while pos < localNames.length {
    if localNames[pos] == name && localLoopVar[pos] == 0 { return pos }
    pos = pos + 1
  }
  -1
}

function declaredSlotOf(name: string) {
  const scoped = scopeSlotOf(name)
  if scoped >= 0 { return scoped }
  let pos = 0
  while pos < localNames.length {
    if localNames[pos] == name { return pos }
    pos = pos + 1
  }
  -1
}

// The `VKind` of declared local `name`, or `null` if there is no such declared local. The
// single `declaredSlotOf` + `localIsRef` lookup the `declared*` type predicates share —
// each compares the result against its kind atom (`"list"` i32-list, `"reflist"`,
// `"strlist"`, `"f64list"`, `"i64list"`, `"struct"`, `"union"`, `"map"`, `"str"`, the
// `"nul*"` niche nullables, `"i64"`/`"f64"`/`"f32"` scalars). The `null` arm matches no
// atom, so an absent local reads as "none of these" exactly as the old `-1` sentinel did.
export function declaredKind(name: string): VKind | null {
  const slot = declaredSlotOf(name)
  if slot < 0 { return null }
  localIsRef[slot]
}

// The wasm local index of declared local `name`, or -1 if it is not a declared
// local. Declared locals sit AFTER the params, so the slot is `paramCount + pos`
// where `pos` is the name's resolved declared-local position (`declaredSlotOf`).
function declaredIndexOf(fnIx: i32, name: string) {
  const pos = declaredSlotLive(name)
  if pos < 0 { return -1 }
  if fnIx < 0 {
    // Module scope = the START FUNCTION's body (top-level statements — a `for`
    // loop's var/bound live here). It has no params, so the local index IS the
    // slot. (A global-section constexpr init also runs with fnIx -1, but the
    // scope stack is empty there, so `declaredSlotOf` already returned -1.)
    return pos
  }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl { return envSlotShift(fnIx) + fn.fnParams.length + pos }
  -1
}

// The wasm-local-index offset introduced by the env-leading closure param: when ANY
// function value exists in the module (`fnValUsed`), EVERY function (except the start
// fn, `fnIx < 0`) carries a hidden leading `structref env` at local 0, so its declared
// params shift to locals 1..p and its declared locals to p+1... Zero otherwise — so a
// no-lambda module keeps the original 0-based param layout and stays byte-identical.
export function envSlotShift(fnIx: i32) {
  if fnValUsed && fnIx >= 0 { return 1 }
  0
}

// Resolve an identifier `name` to its wasm local index for function `fnIx`: a param
// first (locals 0..p-1, shifted past the env param when `fnValUsed`), else a declared
// local. Returns -1 if neither.
export function localIndexOf(fnIx: i32, name: string) {
  const pIx = paramIndexOf(fnIx, name)
  if pIx >= 0 { return envSlotShift(fnIx) + pIx }
  declaredIndexOf(fnIx, name)
}

// Emit the instructions for the returned expression at `exprIx` onto `body`, in
// stack order, resolving identifiers against function `fnIx`'s params. Returns 0
// on success, or calls `emitFail` and returns -1 on any unsupported shape.
//
// Supported operands (any of which may nest as children):
//   NumLit  -> i32.const <value>           (the literal, via parseI32 + slebToArr)
//   Ident   -> local.get <param index>     (a parameter reference)
//   BinExpr -> emit(left), emit(right), <opcode>   (operands first, then the op,
//              the natural wasm post-order stack encoding; arithmetic OR comparison).
//              Logical `&&`/`||` instead lower to a SHORT-CIRCUIT value-typed `if`
//              (blocktype 0x7f): `a && b` ≡ if(a){b}else{0}, `a || b` ≡ if(a){1}else{b}.
//   Unary   -> negation `-x` as i32.const 0, emit(x), i32.sub; logical `!a` as eqz (0x45)
//   Call    -> emit each arg left-to-right, then `call <funcIndex>` (the callee is
//              an `Ident` resolved through the function-index map; recursion works
//              because the function's own name is mapped before its body is emitted)
//   Paren   -> the inner expression (parentheses carry no runtime instruction)
//
// Node shapes read (all from `compiler/ast.vl`):
//   NumLit  { numText: string }
//   Ident   { identName: string }
//   Unary   { unOp: string, unArg: i32 }
//   BinExpr { binOp: string, binLeft: i32, binRight: i32 }
//   Call    { callFn: i32, callArgs: i32[] }
//   Paren   { parInner: i32 }
// The wasm struct field index of `name` within struct `si` (declaration order), or
// -1 if that struct has no such field.
export function sFieldIndex(si: i32, name: string) {
  if si < 0 {
    return -1 // unresolved struct (e.g. an inferred ref with no interned shape)
  }
  const start = sFieldStart[si]
  const cnt = sFieldCount[si]
  let j = 0
  while j < cnt {
    if sFieldNames[start + j] == name { return j }
    j = j + 1
  }
  -1
}

// The wasm-type code (`0` i32, `3` string, `4` i32-list, `5` ref-list) of struct `si`'s
// field at field index `fi`.
export function sFieldTypeAt(si: i32, fi: i32) {
  sFieldTypes[sFieldStart[si] + fi]
}

// The ref-list element type-NAME of struct `si`'s field `fi` (a code-5 field), "" else.
export function sFieldElemNameAt(si: i32, fi: i32) {
  sFieldElemName[sFieldStart[si] + fi]
}

// True if struct `si`'s field `fi` is a literal-union ATOM field (code 0 whose recorded elem name
// is a literal union) — construction/read/assign seed the atom rep (`pendingLitUnion`) for it.
export function sFieldIsLitUnion(si: i32, fi: i32) {
  if sFieldTypeAt(si, fi) != 0 { return false }
  const r = nameIsLitUnionType(sFieldElemNameAt(si, fi))
  r
}

// True if struct `si`'s field `fi` is an ATOM-ARRAY field (`f: K[]` — code 4 whose recorded
// elem name is a litunion array). The field IS the i32 list; construction/assign seed the
// atom-element context so member literals build the i32 backing (not a string list whose
// wrapper ref would mismatch the field type — the `{f: K0[]}` invalid-wasm hole).
export function sFieldIsLitUnionArray(si: i32, fi: i32) {
  if sFieldTypeAt(si, fi) != 4 { return false }
  const r = nameIsLitUnionArray(sFieldElemNameAt(si, fi))
  r
}

// The union-VARIANT twin of `sFieldIsLitUnionArray`: variant `vi`'s field `fj` is an
// ATOM-ARRAY field (`f: K[]`, code 4 with a recorded litunion-array element name) — the
// variant payload build (`emitVariantStruct`) seeds the atom context so the literal
// builds the i32 list of atom ids, not a string list.
export function variantFieldIsLitUnionArray(vi: i32, fj: i32) {
  if variantFieldTypeAt(vi, fj) != 4 { return false }
  nameIsLitUnionArray(variantFieldElemName(vi, fj))
}

// The struct table index whose name is `name`, or -1 if `name` is not a declared
// struct type.
export function structIndexByName(name: string) {
  let i = 0
  while i < sNames.length {
    if sNames[i] == name { return i }
    i = i + 1
  }
  -1
}

// The struct table index whose field-name SET matches the object literal at `objIx`
// EXACTLY (same count, every literal field present in the struct), or -1 if no struct
// matches. With distinct field-name sets across structs this disambiguates which
// struct an `{ … }` literal constructs (the struct analogue of `objVariantName`).
export function structIndexOfObj(objIx: i32) { structIndexOfObjCtx(objIx, -1) }

// The context-aware variant: `fnIx` (when >= 0) classifies field VALUES through
// the expression family too, so a monomorphized instance's SHARED tail literal
// (`{ x: self.x + b.x }`) resolves per instance — f64 against the f64-param
// instance, i32 against the i32 one.
export function structIndexOfObjCtx(objIx: i32, fnIx: i32) {
  const o = P.nodes[objIx]
  if o is ObjLit {
    const nf = o.objFields.length
    let si = 0
    while si < sNames.length {
      if sFieldCount[si] == nf {
        let ok = true
        let k = 0
        while k < nf {
          const f = P.nodes[o.objFields[k]]
          if f is FieldInit {
            const mfi = sFieldIndex(si, f.fiName)
            if mfi < 0 {
              ok = false
            } else {
              // F64 DISCRIMINATION: an `{x}` literal matches the i32 `{x}` and
              // the f64 `{x}` shapes by NAME — split them on the value's float-
              // ness so `{x: 1.5}` builds the f64 shape and `{x: 1}` the i32
              // one (monomorphized `addx` instances each pin their own). Only
              // the f64 axis discriminates; every other code keeps the lenient
              // name-only match (a `{v: 5}` literal still matches a
              // `{v: i32|null}` union-field shape).
              const sc = sFieldTypeAt(si, mfi)
              const vc = anonFieldCode(f.fiValue)
              let isFloat = vc == 17
              if !isFloat && fnIx >= 0 {
                if exprIsF64(f.fiValue, fnIx) { isFloat = true }
              }
              if isFloat {
                if sc != 17 && sc != 24 && sc != 16 { ok = false }
              } else if vc == 23 {
                // I64 DISCRIMINATION (the i64 axis of the float rule above): an
                // i64-coded value (a magnitude literal, or a context-ADOPTED small
                // literal — `anonFieldCode` reads the recorded type) must not match
                // an i32-field shape; `{f: 5}` adopted to `{f: i64}` would else claim
                // a coexisting `{f: i32}` struct and store an i64 into its field.
                if sc != 23 && sc != 16 { ok = false }
              } else if sc == 17 {
                if fnIx >= 0 || vc >= 0 { ok = false }
              }
            }
          } else {
            ok = false
          }
          k = k + 1
        }
        if ok { return si }
      }
      si = si + 1
    }
  }
  -1
}

// True if lifted function `fe` has any UN-ANNOTATED parameter — a generic (its un-annotated param
// is a per-call-site inference hole). Such a function monomorphizes per direct call but i32-defaults
// when taken as a VALUE, so the value site rejects it.
export function fnHasUnannotatedParam(fe: i32) {
  if fe < 0 || fe >= fnStmts.length { return false }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    const ps = fn.fnParams
    let i = 0
    while i < ps.length {
      const p = P.nodes[ps[i]]
      if p is Param {
        if p.parType < 0 { return true }
      }
      i = i + 1
    }
  }
  false
}

export function optChainStructIdxOf(exprIx: i32, fnIx: i32) {
  const e = P.nodes[unwrapParen(exprIx)]
  if e is OptMember {
    const psi = optChainStructIdxOf(e.omObj, fnIx)
    if psi < 0 { return -1 }
    const pfi = sFieldIndex(psi, e.omProp)
    if pfi < 0 { return -1 }
    if sFieldTypeAt(psi, pfi) != 15 { return -1 }
    return structIndexByName(sFieldElemNameAt(psi, pfi))
  }
  structIndexOfExpr(exprIx, fnIx)
}

// The union ATOM the concrete (non-box) side of a union `==` compares under —
// the same rep ladder `emitUnionCoerce` classifies a coerced value with.
export function unionEqAtomOf(otherIx: i32, unionName: string, fnIx: i32) {
  let atom = "i32"
  if exprString(otherIx, fnIx) {
    atom = "string"
  } else if exprIsF32(otherIx, fnIx) {
    atom = "f32"
  } else if exprIsF64(otherIx, fnIx) {
    atom = "f64"
  } else if exprIsI64(otherIx, fnIx) {
    atom = "i64"
  } else if exprIsBool(otherIx, fnIx) {
    atom = "boolean"
  } else {
    if !unionHasAtom(unionName, "i32") && unionHasAtom(unionName, "i64") {
      atom = "i64"
    }
    const bare = P.nodes[unwrapParen(otherIx)]
    if bare is NumLit {
      if !numLexFitsI32(bare.numText) { atom = "i64" }
    }
  }
  atom
}

// True if the member access at `memIx` reads a field of a CURRENTLY-narrowed union
// identifier (the receiver `Ident` has an active binding on the narrowing stack).
export function memIsNarrowed(memIx: i32) {
  if narrowTop == 0 { return false }
  const m = P.nodes[memIx]
  if m is Member {
    const recv = P.nodes[m.memObj]
    if recv is Ident {
      if narrowVariantFor(recv.identName) != "" { return true }
    }
    // A nested union-FIELD receiver (`t.v.a` where `t.v` is narrowed to a variant): the
    // receiver is itself a Member, narrowed by its path key (`t.v`).
    if recv is Member {
      const pk = memberPathKeyOf(m.memObj)
      if pk != "" {
        if narrowVariantFor(pk) != "" { return true }
      }
    }
  }
  false
}

// The variant table index the Member `memIx`'s receiver is currently narrowed to, or -1
// if its receiver is not a narrowed union identifier. Resolves each receiver's OWN active
// narrowing — so simultaneously-narrowed locals each map to their own variant.
export function memNarrowVariantIndex(memIx: i32) {
  const m = P.nodes[memIx]
  if m is Member {
    const recv = P.nodes[m.memObj]
    if recv is Ident { return variantIndexOf(narrowVariantFor(recv.identName)) }
    if recv is Member {
      const pk = memberPathKeyOf(m.memObj)
      if pk != "" { return variantIndexOf(narrowVariantFor(pk)) }
    }
  }
  -1
}

// The VALUE-union name of a union-typed struct FIELD read `o.y` (field code 16),
// or "" when the member is not a union-box field. Covers a NARROWED-variant receiver
// too (`v.f` where `v` is narrowed to a union arm carrying a value-union field `f`) —
// the field then rides the VARIANT tables, not the incrementally-built struct table.
export function memberUnionFieldName(memIx: i32, fnIx: i32) {
  const m = P.nodes[memIx]
  if m is Member {
    const si = structIndexOfExpr(m.memObj, fnIx)
    if si >= 0 {
      const fi = sFieldIndex(si, m.memProp)
      if fi >= 0 {
        if sFieldTypeAt(si, fi) == 16 { return sFieldElemNameAt(si, fi) }
      }
    }
    // The receiver is a narrowed union arm (`v.f`, `v` narrowed to a struct variant):
    // resolve `f` through the variant field tables.
    const nvi = memNarrowVariantIndex(memIx)
    if nvi >= 0 {
      const vfi = variantFieldIndex(nvi, m.memProp)
      if vfi >= 0 {
        if variantFieldTypeAt(nvi, vfi) == 16 {
          return variantFieldElemName(nvi, vfi)
        }
      }
    }
    // NARROWING-BLIND last resort (the frame pre-pass): the receiver is an IDENT
    // declared as a union whose STRUCT arm carries a code-16 field named `memProp` —
    // probe both field tables across the arms, the `unionStructArmMapFieldMember`
    // discipline. The pre-pass runs before any narrowing is active, so the probes
    // above miss and a `const t1 = t0.f` binding's field union resolved "" — its map
    // ops then indexed scratch locals past the frame (invalid wasm). At emit the
    // narrowed probes above answer first, so this is strictly additive. GATED on the
    // checker having typed the READ a union (a cheap arena test): an ordinary struct
    // member read misses both probes above on every classifier query, and the
    // ident-union resolution below (`parentLetOf` body walks) is too hot for that.
    if !nodeTyIsUnion(memIx) { return "" }
    const mObj = P.nodes[unwrapParen(m.memObj)]
    if mObj is Ident {
      const mun = unionNameOfIdent(mObj.identName, fnIx)
      if mun != "" {
        let mset = unionMemberSetOf(mun)
        if mset == "" { mset = mun }
        const mAtoms: string[] = []
        splitUnionAtoms(mset, mAtoms)
        let mi = 0
        while mi < mAtoms.length {
          const ma = mAtoms[mi]
          if ma != "null" {
            const msi = structIndexByName(ma)
            if msi >= 0 {
              const mfi = sFieldIndex(msi, m.memProp)
              if mfi >= 0 {
                if sFieldTypeAt(msi, mfi) == 16 {
                  return sFieldElemNameAt(msi, mfi)
                }
              }
            }
            const mvi = variantIndexOf(ma)
            if mvi >= 0 {
              const mvfi = variantFieldIndex(mvi, m.memProp)
              if mvfi >= 0 {
                if variantFieldTypeAt(mvi, mvfi) == 16 {
                  return variantFieldElemName(mvi, mvfi)
                }
              }
            }
          }
          mi = mi + 1
        }
      }
    }
  }
  ""
}

// Record a distinct (kind, ref-list slot) source frame requirement.
export function mfRecordSrc(kind: MfKind, slot: i32) {
  let i = 0
  while i < mfSrcKinds.length {
    if mfSrcKinds[i] == kind && mfSrcSlots[i] == slot { return 0 }
    i = i + 1
  }
  mfSrcKinds.push(kind)
  mfSrcSlots.push(slot)
  0
}

// Record a distinct (result-element-kind, ref-list slot) dest frame requirement. `slot` is the
// ref-list table slot for a kind-2 (ref-list) dest (so two struct-array filters of DIFFERENT
// element types get distinct backing locals), -1 for a non-ref dest.
export function mfRecordDst(kind: MfKind, slot: i32) {
  let i = 0
  while i < mfDstKinds.length {
    if mfDstKinds[i] == kind && mfDstSlots[i] == slot { return 0 }
    i = i + 1
  }
  mfDstKinds.push(kind)
  mfDstSlots.push(slot)
  0
}

// The wasm local holding the SOURCE wrapper ref for (kind, slot), or -1.
export function mfSrcLocalFor(kind: MfKind, slot: i32) {
  let i = 0
  while i < mfSrcKinds.length {
    if mfSrcKinds[i] == kind && mfSrcSlots[i] == slot {
      if i < mfSrcBases.length { return mfSrcBases[i] }
    }
    i = i + 1
  }
  -1
}

// The wasm local holding the DEST backing ref for result (kind, slot), or -1.
export function mfDstLocalFor(kind: MfKind, slot: i32) {
  let i = 0
  while i < mfDstKinds.length {
    if mfDstKinds[i] == kind && mfDstSlots[i] == slot {
      if i < mfDstBases.length { return mfDstBases[i] }
    }
    i = i + 1
  }
  -1
}

// True if function `fnIx` operates on a map — it has a map PARAM, or `buildLocals`
// flagged a map LOCAL (code `6`). Drives the map scratch-frame reservation. (Run
// AFTER `buildLocals`, so `localIsRef` is populated.)
export function fnHasMap(fnIx: i32) {
  let i = 0
  while i < localNames.length {
    if localIsRef[i] == "map" { return true }
    // A map-ARRAY local (`{[string]:i32}[]`, code 5 with element kind 3) lets map ops
    // run on an indexed element (`scopes[i][k]`) — so the function needs the map scratch
    // frame even though no bare map local is declared.
    if localIsRef[i] == "reflist" {
      const s = localStructIdx[i]
      if s >= 0 {
        if s < rlElemKindTbl.length {
          if rlElemKindTbl[s] == 3 { return true }
        }
      }
    }
    i = i + 1
  }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    const params = fn.fnParams
    let pj = 0
    while pj < params.length {
      const p = P.nodes[params[pj]]
      if p is Param {
        if p.parType >= 0 {
          const ty = P.nodes[p.parType]
          if ty is TypeRef {
            if nameIsMap(ty.tyName) { return true }
          }
        }
      }
      pj = pj + 1
    }
  }
  false
}

// True if the statement/expression tree at `ix` contains a function-VALUE call (a
// `Call` whose callee is a closure value rather than a known function name) — so the
// function needs the closure scratch slot for `call_ref`. (Lambdas.)
export function blockHasCallRef(ix: i32, fnIx: i32) {
  if ix < 0 { return false }
  const n = P.nodes[ix]
  if n is Call {
    const callee = P.nodes[n.callFn]
    let isVal = false
    if callee is Ident {
      const t = fnIndexOf(callee.identName)
      if t < 0 {
        if exprIsClosure(n.callFn, fnIx) { isVal = true }
        // `t()` where `t` is a union binding with a bare-closure arm (`const t = p.f; t()`,
        // `const e = arr[0]; e()`): the `is`-narrowing that makes `t` a closure is NOT active
        // during this pre-pass, so `exprIsClosure(t)` is false — reserve `callRefSlot`
        // conservatively so the narrowed emit's `call_ref` has its scratch local (an unused
        // reservation is a harmless spare local, never invalid wasm). The bare-binding twin of
        // the `calleeIsUnionClosureArrayIndex` reservation below.
        if !isVal && calleeIsUnionClosureIdent(n.callFn, fnIx) { isVal = true }
      } else {
        // A direct call to a CAPTURING function is lowered via call_ref too.
        if captureCountOf(t) > 0 { isVal = true }
      }
    } else {
      if exprIsClosure(n.callFn, fnIx) { isVal = true }
      // `p[0]()` where `p` is a union with a CLOSURE-ARRAY arm (`(() => f64)[] | i64`): the
      // `is`-narrowing that makes `p` a closure array is NOT active during this frame pre-pass,
      // so `exprIsClosure(p[0])` (which needs the narrowing to see `p` as a ref array) is false —
      // reserve `callRefSlot` conservatively so the narrowed emit's `call_ref` has its scratch
      // local (an unused reservation is a harmless spare local, never invalid wasm).
      if !isVal && calleeIsUnionClosureArrayIndex(n.callFn, fnIx) {
        isVal = true
      }
      // `t0.f[0]()` where `t0`'s union has a struct arm carrying a CLOSURE-ARRAY field
      // (`{a: i32, f: ((i32) => K0)[], z: f64} | i32`): the `is`-narrowing that resolves
      // the member chain is not active in this pre-pass — reserve conservatively (the
      // indexed-member twin of the two reservations around it).
      if !isVal && calleeIsUnionArmCloArrayIndex(n.callFn, fnIx) {
        isVal = true
      }
      // `t0.f.f()` where `t0`'s union has a struct arm whose (possibly nested) field
      // chain ends in a CLOSURE field: the `is`-narrowing that resolves the chain is
      // not active in this pre-pass — reserve conservatively (a spare local is
      // harmless; an unreserved `call_ref` spill shares the next frame's local —
      // invalid wasm).
      if !isVal && calleeIsUnionArmClosureMember(n.callFn, fnIx) {
        isVal = true
      }
    }
    if isVal { return true }
    if blockHasCallRef(n.callFn, fnIx) { return true }
    const args = n.callArgs
    let i = 0
    while i < args.length {
      if blockHasCallRef(args[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  if n is Block {
    const stmts = n.blkStmts
    let i = 0
    while i < stmts.length {
      if blockHasCallRef(stmts[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  if n is LetDecl {
    if n.letInit >= 0 { return blockHasCallRef(n.letInit, fnIx) }
    return false
  }
  if n is RetStmt {
    if n.retArg >= 0 { return blockHasCallRef(n.retArg, fnIx) }
    return false
  }
  if n is IfStmt {
    if blockHasCallRef(n.ifCond, fnIx) { return true }
    if blockHasCallRef(n.ifThen, fnIx) { return true }
    if n.ifElse >= 0 { return blockHasCallRef(n.ifElse, fnIx) }
    return false
  }
  if n is WhileStmt {
    if blockHasCallRef(n.whileCond, fnIx) { return true }
    return blockHasCallRef(n.whileBody, fnIx)
  }
  if n is ForRange {
    if blockHasCallRef(n.frFrom, fnIx) { return true }
    if blockHasCallRef(n.frTo, fnIx) { return true }
    if n.frStep >= 0 {
      if blockHasCallRef(n.frStep, fnIx) { return true }
    }
    return blockHasCallRef(n.frBody, fnIx)
  }
  if n is ForIn {
    if blockHasCallRef(n.fiIter, fnIx) { return true }
    return blockHasCallRef(n.fiBody, fnIx)
  }
  if n is BinExpr {
    if blockHasCallRef(n.binLeft, fnIx) { return true }
    return blockHasCallRef(n.binRight, fnIx)
  }
  if n is Unary { return blockHasCallRef(n.unArg, fnIx) }
  if n is Paren { return blockHasCallRef(n.parInner, fnIx) }
  // An `is` operand (`f(x) is i32`) may itself be a function-value call — without this the
  // closure scratch slot (`callRefSlot`) goes unreserved and the inline `call_ref` reads a
  // non-existent local 0.
  if n is IsExpr { return blockHasCallRef(n.isObj, fnIx) }
  if n is AsExpr { return blockHasCallRef(n.asObj, fnIx) }
  if n is Member { return blockHasCallRef(n.memObj, fnIx) }
  if n is Index {
    if blockHasCallRef(n.idxArr, fnIx) { return true }
    return blockHasCallRef(n.idxIndex, fnIx)
  }
  if n is ObjLit {
    const fields = n.objFields
    let i = 0
    while i < fields.length {
      const f = P.nodes[fields[i]]
      if f is FieldInit {
        if blockHasCallRef(f.fiValue, fnIx) { return true }
      }
      i = i + 1
    }
    return false
  }
  if n is ArrayLit {
    const elems = n.arrElems
    let i = 0
    while i < elems.length {
      if blockHasCallRef(elems[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  false
}

// Lower an index READ `a[i]` onto `body`. The element store is the raw `(array (mut
// i32))` in BOTH cases, but a list receiver carries it inside the wrapper struct:
//   list `a[i]`   → eval `a` (a wrapper ref), `struct.get $lTypeIdx 0` (backing), eval
//                   `i`, then `array.get $aTypeIdx` — the element i32.
//   string `s[i]` → eval `s` (a raw array ref), eval `i`, `array.get $aTypeIdx` — the
//                   i32 CODE POINT (unchanged from the fixed-array string rep).
// `array.get` is `0xfb 0x0b <typeidx>` (the `_s/_u` forms `0x0c/0x0d` are only for
// PACKED arrays; an unpacked i32 array uses `0x0b`).
// The bounds-check wrapper-ref slot for list kind `kind` (`slot` = the ref-list
// table slot for kind "ref", else 0) — found in this function's lazily grown
// `liKinds` table, or reserved now. Slot 0 of the frame (`listIdxScratchBase`)
// is the shared i32 index stash; wrapper slot k lives at `base + 1 + k`. The
// frame's base is fixed by `fbBeginFunc` (it lays out after every eager frame),
// so handing slots out mid-lowering is safe, and first-use order keeps the
// layout deterministic (the locals vector is derived from the same table).
// The bounds-check frame kind for a SCALAR list element kind (`scalarListElemKind`
// only ever yields the four scalar members of `VKind`).
export function listIdxKindOf(ek: VKind): MfKind {
  if ek == "f64" { return "f64" }
  if ek == "i64" { return "i64" }
  if ek == "f32" { return "f32" }
  "i32"
}

export function listIdxWrapSlot(kind: MfKind, slot: i32) {
  let k = 0
  while k < liKinds.length {
    if liKinds[k] == kind && liSlots[k] == slot && liBack[k] == 0 {
      return listIdxScratchBase + 1 + k
    }
    k = k + 1
  }
  liKinds.push(kind)
  liSlots.push(slot)
  liBack.push(0)
  listIdxScratchBase + liKinds.length
}

// The single tail-value expression of an if-expression's THEN arm (the parser wraps
// `then <expr>` as a one-statement Block), or -1. The arms share the checker's join
// type, so the then arm's rep classifies the whole if-expression.
function ifThenValueIx(ifIx: i32) {
  const s = P.nodes[ifIx]
  if s is IfStmt {
    const b = P.nodes[s.ifThen]
    if b is Block {
      const stmts = b.blkStmts
      if stmts.length == 1 { return stmts[0] }
    }
  }
  -1
}

// The `fbValtype` KIND of a REF-typed if-expression join — string (3), string-list (7),
// f64-list (12), ref-list (5), i32-list (2), or struct (1) — classified from the THEN
// arm's tail value. -1 for a numeric join (the single-byte path) and for a value-union /
// concrete-variant join (handled by `emitUnionIfValue` / `emitVariantIfValue` upstream).
// The array predicates run BEFORE the i32-list `exprArray` (which would also claim a
// string/ref/f64 list via its typed-IR fast path).
export function ifExprRefKind(ifIx: i32, fnIx: i32): VKind | null {
  const tv = ifThenValueIx(ifIx)
  if tv < 0 { return null }
  // A CLOSURE join (`if c then (x) => x + 1 else (x) => x - 1`) — kind 14, `(ref $cloStruct)`.
  // Checked FIRST: a bare lambda arm is a function value, not a string/array/struct. Each arm
  // emits via `emitClosureValue` (the default `emitRefIfArm` path), and the binding/return
  // classifies as a closure (`exprIsClosure` / `fnReturnsClosure`).
  if exprIsClosure(tv, fnIx) { return "closure" }
  // The JOIN's checked type is the arm-order-independent string signal: a `string`-typed
  // join (an ATOM arm + a string/member-literal arm — `if c then k else "cc"`, either
  // order) is the string ref kind even when the THEN arm alone doesn't classify stringy
  // (an atom ident reads as its litunion, not `string`); the atom arm then widens at
  // `emitRefIfArm`. A pure-atom join types the LITUNION (not `string`), so it stays the
  // bare i32 path.
  if tyKindOf(nodeTyIxOf(ifIx)) == 3 { return "str" }
  if exprString(tv, fnIx) { return "str" }
  if exprStringArray(tv, fnIx) { return "strlist" }
  if exprF64Array(tv, fnIx) { return "f64list" }
  if exprRefArray(tv, fnIx) { return "reflist" }
  if exprArray(tv, fnIx) { return "list" }
  if structIndexOfExpr(tv, fnIx) >= 0 { return "struct" }
  // An object LITERAL arm in a struct-typed CONTEXT (return / binding seeds
  // `pendingStructIdx`) — it has no self-derivable struct index.
  const tn = P.nodes[tv]
  if tn is ObjLit {
    if pendingStructIdx >= 0 { return "struct" }
  }
  // A NULLABLE-struct join whose THEN arm is `null` (its rep doesn't classify) — the checker typed the
  // whole if `S | null`. Return the struct kind so the nullable blocktype + struct/null arms lower; the
  // struct index resolves from the checker's inner struct in `ifExprRefSlot`. (The null-in-ELSE case is
  // already caught above via the THEN arm's struct rep.)
  if nodeTyIsNullableStruct(ifIx) { return "struct" }
  null
}

// The `fbValtype` SLOT (second arg) for a REF-typed if-expression join of `kind`: the
// struct table index (kind 1) or the ref-list wrapper slot (kind 5); the other ref kinds
// (string/string-list/f64-list/i32-list) ignore the slot. Prefers the pending context
// seed (a struct/list RETURN or binding) over the then-arm's own derivation.
export function ifExprRefSlot(ifIx: i32, fnIx: i32, kind: VKind) {
  const tv = ifThenValueIx(ifIx)
  if kind == "struct" {
    const si = structIndexOfExpr(tv, fnIx)
    if si >= 0 { return si }
    if pendingStructIdx >= 0 { return pendingStructIdx }
    // THEN arm is `null` with no binding seed — resolve the struct from the checker's nullable join
    // type (`P | null` → its inner `P`), so the arm rep + nullable blocktype find the layout.
    const inn = nodeNulStructInnerName(ifIx)
    if inn != "" { return structIndexOfTypeName(inn) }
    return pendingStructIdx
  }
  if kind == "reflist" {
    if pendingListKind == 5 { return pendingListSlot }
    return refListSlotOfExpr(tv, fnIx)
  }
  -1
}

// True if the single statement `stmtIx` is usable as an if-expression ARM value: a plain tail value
// (`stmtIsTailValue`), OR a NESTED if-EXPRESSION (an `IfStmt` with an else + value arms, emitted via
// `emitExpr` → `emitIfExpr`). Kept SEPARATE from `stmtIsTailValue` so the function-tail nullable path —
// which gates on `stmtIsTailValue` and routes an else-ful nullable tail through `emitIfTail` — is
// untouched; only the if-expression arm emitters opt into nesting.
export function ifArmIsValue(stmtIx: i32, fnIx: i32) {
  if stmtIsTailValue(stmtIx, fnIx) { return true }
  const s = P.nodes[stmtIx]
  if s is IfStmt { return ifTailIsValue(stmtIx, fnIx) }
  false
}

// The single-byte blocktype valtype for a value-position if-expression: the widest
// numeric rep across its arms (checked f64 → f32 → i64, else the i32 default).
export function ifExprValtype(ifIx: i32, fnIx: i32) {
  if exprIsF64(ifIx, fnIx) {
    return 124 // 0x7c f64
  }
  if exprIsF32(ifIx, fnIx) {
    return 125 // 0x7d f32
  }
  if exprIsI64(ifIx, fnIx) {
    return 126 // 0x7e i64
  }
  127 // 0x7f i32
}

// True if the DECLARED LOCAL `name` is an i64 slot (kind 10 in the local registry).
function declaredI64(name: string) { declaredKind(name) == "i64" }

// True if the module GLOBAL `name` is an i64 cell.
function globalIsI64(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return false }
  letIsI64(li, -1)
}

// The unboxed scalar atom KIND of a value-union null-coalesce `lhs ?? d` (where `lhs`
// is an ident or call yielding `T | null` with ONE non-null scalar atom): the result
// of `??` is that atom, so `print`-routing + numeric context coercion classify it by
// the atom (`i64`/`f64`/`f32` need their own import / convert). -1 when the expression
// is not such a `??`, or the union keeps ≥2 non-null atoms (still a box, not a scalar).
function coalesceAtomKind(exprIx: i32, fnIx: i32) {
  const e = P.nodes[unwrapParen(exprIx)]
  if e is BinExpr {
    if e.binOp == "??" {
      const nm = unionNameOfExpr(e.binLeft, fnIx)
      if nm != "" {
        if isValueUnionName(nm) && unionHasAtom(nm, "null") {
          const k = valueAtomKind(removeAtomFrom(nm, "null"))
          if k >= 0 && k != 6 { return k }
        }
      }
    }
  }
  -1
}

// True if evaluating the expression at `exprIx` yields an i64 — a reference to an
// i64 param/local/global, or a parenthesized such. Drives the `print` import choice
// (`__print_i64__`, import 4). Arithmetic/calls returning i64 are Slice 2; here only
// the direct-reference forms (the Slice-1 `print(x)` shape) classify as i64.
export function exprIsI64(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  if tyKindOf(nodeTyIxOf(exprIx)) == 10 {
    return true // typed-IR fast path (see exprIsF64)
  }
  if coalesceAtomKind(exprIx, fnIx) == 3 { return true }
  // `m[k] ?? d` over an i64-VALUED map yields an i64 (the value type).
  const cmi = coalesceMvSlot(exprIx, fnIx)
  if cmi >= 0 {
    if mvValKind[cmi] == 10 { return true }
  }
  const e = P.nodes[exprIx]
  // An explicit `x as T` cast has exactly its target rep (see exprIsF64).
  if e is AsExpr { return e.asTy == "i64" }
  if e is Paren { return exprIsI64(e.parInner, fnIx) }
  // A field read `s.x` whose struct field is an i64 slot (code 23) yields an i64.
  if e is Member { return memFieldTypeCode(exprIx, fnIx) == 23 }
  // A bare `m[k]` read over an i64-valued map yields an i64.
  if e is Index {
    // An indexed read of an i64 list (`xs[i]` over `i64[]`) is an i64 — the syntactic dual of
    // `exprIsF64`'s Index case. Needed for a SYNTHETIC `c[0]` (e.g. a captured-mutation box) that
    // carries no checker-recorded type for the typed-IR fast path above.
    if exprI64Array(e.idxArr, fnIx) { return true }
    const mri = mapReadMvSlot(exprIx, fnIx)
    if mri >= 0 {
      if mvValKind[mri] == 10 { return true }
    }
  }
  // A bare INTEGER literal past the i32 range is typed i64 by the checker (the
  // host's `defaultIntegerType` magnitude rule) and lowers as `i64.const`, so it
  // classifies as i64 here too (a float `.` literal is f64, never i64).
  if e is NumLit {
    if numTextIsFloat(e.numText) { return false }
    return !numLexFitsI32(e.numText)
  }
  if e is Ident {
    // A VALUE-union ident classifies by its narrowed atom (the read unboxes to
    // that rep); an un-narrowed union ident is the box, never a scalar.
    const uk = unionIdentReadKind(exprIx, fnIx)
    if uk != -3 { return uk == 3 }
    if paramIsI64(fnIx, e.identName) { return true }
    if declaredI64(e.identName) { return true }
    return globalIsI64(e.identName)
  }
  // Slice 2: an ARITHMETIC / BITWISE / SHIFT op yields i64 when EITHER operand is i64
  // (the i32 side widens). COMPARISONS (`==` `!=` `<` `>` `<=` `>=`) and logical
  // connectives produce an i32 BOOL even over i64 operands, so they are NOT i64.
  if e is BinExpr {
    const op = e.binOp
    if (
      op == "+" ||
      op == "-" ||
      op == "*" ||
      op == "/" ||
      op == "%" ||
      op == "&" ||
      op == "|" ||
      op == "^" ||
      op == "<<" ||
      op == ">>" ||
      op == ">>>"
    ) {
      if exprIsI64(e.binLeft, fnIx) { return true }
      return exprIsI64(e.binRight, fnIx)
    }
    return false
  }
  // Unary negation `-x` / bitwise NOT `~x` preserve the operand's i64-ness. (`!`
  // is a bool, never i64; `p+`/`p-` ride their operand but are statement-level.)
  if e is Unary {
    if e.unOp == "-" || e.unOp == "~" {
      // EXCEPT `-2147483648`: the host folds the sign into the literal before
      // defaulting, so a NEGATED magnitude-2^31 literal is i32 (it sits at
      // I32_MIN) even though the bare operand literal classifies i64 above.
      if e.unOp == "-" {
        const negInner = P.nodes[unwrapParen(e.unArg)]
        if negInner is NumLit {
          if !numTextIsFloat(negInner.numText) {
            if numLexIs2Pow31(negInner.numText) { return false }
          }
        }
      }
      return exprIsI64(e.unArg, fnIx)
    }
    return false
  }
  // A call to an i64-returning function yields i64.
  if e is Call {
    // An INDEXED closure call `fs[i](x)` whose element signature returns i64.
    if cloArrCallRetKind(exprIx, fnIx) == "i64" { return true }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const target = fnIndexOf(callee.identName)
      if target >= 0 { return fRetKind[target] == "i64" }
      // An i64-returning function VALUE (a binding / `(…) => i64` param callee).
      return calleeReturnsI64(callee.identName, fnIx)
    }
    // An i64-returning FIELD-closure call (`o.f(x)` over an `(…) => i64` field).
    if callee is Member {
      const ffe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
      if ffe >= 0 { return fRetKind[ffe] == "i64" }
    }
    return false
  }
  // A value-position if-EXPRESSION is i64 when either arm's value is i64.
  if e is IfStmt { return ifExprArmIsKind(exprIx, fnIx, "i64") }
  false
}

// True if the DECLARED LOCAL `name` is an f32 slot (kind 13 in the local registry).
function declaredF32(name: string) { declaredKind(name) == "f32" }

// True if the UN-annotated `LetDecl` at `letIx` should INFER an f32 slot — its initializer
// already yields an f32 (`exprIsF32`: an f32 field/index/param/local read, an f32-returning
// call, or f32 arithmetic). f32 is the checker's weak spot (no f32 typed-IR), so `letIsF32`
// is annotation-only; without this an un-annotated `let y = s.x` over an f32 source would
// default to an i32 slot and store an f32 into it (invalid wasm). This is the f32 analogue of
// the init fallback `letIsF64`/`letIsI64` already carry. A BARE float literal init stays f64
// (it is not `exprIsF32`), so `let y = 1.5` is unaffected.
export function letInfersF32(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 { return false }
    if d.letInit < 0 { return false }
    return exprIsF32(d.letInit, fnIx)
  }
  false
}

// True if the module GLOBAL `name` is an f32 cell. (Slice 5.)
function globalIsF32(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return false }
  letIsF32(li)
}

// True if evaluating the expression at `exprIx` yields an f32: a reference to an f32
// param/local/global, f32 arithmetic (either operand f32 — the other side, an i32 or a
// float LITERAL, coerces to f32), or unary `-`/parens over such. A BARE float literal is
// NOT f32 (it defaults f64 — `exprIsF64`); it becomes f32 only as the operand of an f32
// op or the init of an `: f32` binding. Checked BEFORE `exprIsF64` at every dispatch so
// a mixed f32/float-literal expression routes to the f32 instructions. (Slice 5.)
// Is the expression at `exprIx` (peeling parens) a FLOAT number literal (`2.5`)? A float literal is
// polymorphic across the float types — it adapts DOWN to an f32 operand — so it does NOT force f64
// the way a genuine f64 reference/result/variable does.
function exprIsFloatLit(exprIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[unwrapParen(exprIx)]
  if e is NumLit { return numTextIsFloat(e.numText) }
  false
}

// Does a binary op over `leftIx`/`rightIx` have a GENUINE (non-literal) f64 operand? Such an operand
// makes the whole op f64 — an f32 / i32 / float-literal side widens to it (`f32var + f64var` is f64,
// computed in f64). A float LITERAL is NOT genuine f64 (it adapts down to an f32 operand), so it does
// not trigger this. Drives both the `exprIsF32` classification and the f32 emit slice: when true,
// the op is f64 (the f64 slice), not f32 — without which the f32 slice demoted the f64 and trapped.
export function binMixHardF64(leftIx: i32, rightIx: i32, fnIx: i32) {
  if exprIsF64(leftIx, fnIx) {
    if !exprIsFloatLit(leftIx) { return true }
  }
  if exprIsF64(rightIx, fnIx) {
    if !exprIsFloatLit(rightIx) { return true }
  }
  false
}

export function exprIsF32(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  if tyKindOf(nodeTyIxOf(exprIx)) == 13 {
    return true // typed-IR fast path (see exprIsF64)
  }
  if coalesceAtomKind(exprIx, fnIx) == 5 { return true }
  const e = P.nodes[exprIx]
  // An explicit `x as T` cast has exactly its target rep (see exprIsF64).
  if e is AsExpr { return e.asTy == "f32" }
  if e is Paren { return exprIsF32(e.parInner, fnIx) }
  // An index read `xs[i]` over an `f32[]` yields an f32 element.
  if e is Index {
    if exprF32Array(e.idxArr, fnIx) { return true }
  }
  // A field read `s.x` whose struct field is an f32 slot (code 24) yields an f32.
  if e is Member { return memFieldTypeCode(exprIx, fnIx) == 24 }
  if e is Ident {
    // A VALUE-union ident classifies by its narrowed atom (see exprIsI64).
    const uk = unionIdentReadKind(exprIx, fnIx)
    if uk != -3 { return uk == 5 }
    if paramIsF32(fnIx, e.identName) { return true }
    if declaredF32(e.identName) { return true }
    return globalIsF32(e.identName)
  }
  // Arithmetic yields f32 when EITHER operand is f32. Comparisons / logical connectives
  // produce an i32 BOOL even over f32 operands, so they are NOT f32.
  if e is BinExpr {
    const op = e.binOp
    if op == "+" || op == "-" || op == "*" || op == "/" {
      // f32 arithmetic yields f32 only when NO operand is a genuine f64 — a genuine f64 side makes
      // the op f64 (the f32 side widens). A float literal does not count (it adapts down to f32).
      if binMixHardF64(e.binLeft, e.binRight, fnIx) { return false }
      if exprIsF32(e.binLeft, fnIx) { return true }
      return exprIsF32(e.binRight, fnIx)
    }
    return false
  }
  if e is Unary {
    if e.unOp == "-" { return exprIsF32(e.unArg, fnIx) }
    return false
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const target = fnIndexOf(callee.identName)
      if target >= 0 { return fRetKind[target] == "f32" }
    }
    return false
  }
  // A value-position if-EXPRESSION is f32 when either arm's value is f32.
  if e is IfStmt { return ifExprArmIsKind(exprIx, fnIx, "f32") }
  false
}

// The non-i32 numeric rep an if-expression arm can carry. A pure SELECTOR (never encoded):
// it tags which `exprIs*` classifier `armValueIsKind` consults, replacing the bare wasm
// blocktype bytes 124 (f64) / 125 (f32) / 126 (i64) the call sites used to thread through.
// The actual blocktype byte is emitted elsewhere (`ifExprValtype`/`emitIfExprRef`). (C2 cleanup.)
type BtKind = "f64" | "f32" | "i64"

// True if a value-position if-EXPRESSION (`ifIx`) carries the numeric rep named by `kind`:
// either arm's tail value is of that kind, recursing through an `else if` chain in the else
// slot. Drives both the whole-expression classification (`exprIsF64`/`exprIsF32`/`exprIsI64`
// above, so print routing and context coercion see the joined type) and the blocktype
// `emitIfExpr` picks. A bare i32-arm if-expression matches none of these and stays the i32 default.
function ifExprArmIsKind(ifIx: i32, fnIx: i32, kind: BtKind) {
  const s = P.nodes[ifIx]
  if s is IfStmt {
    if s.ifElse < 0 { return false }
    const thenV = ifArmValueExpr(s.ifThen)
    if armValueIsKind(thenV, fnIx, kind) { return true }
    const els = P.nodes[s.ifElse]
    if els is IfStmt { return ifExprArmIsKind(s.ifElse, fnIx, kind) }
    return armValueIsKind(ifArmValueExpr(s.ifElse), fnIx, kind)
  }
  false
}

// Classify a single arm-value expression against a numeric rep `kind`.
function armValueIsKind(exprIx: i32, fnIx: i32, kind: BtKind) {
  match kind {
    "f64" => exprIsF64(exprIx, fnIx)
    "f32" => exprIsF32(exprIx, fnIx)
    "i64" => exprIsI64(exprIx, fnIx)
  }
}

// True if the DECLARED LOCAL `name` is an f64 slot (kind 11 in the local registry).
function declaredF64(name: string) { declaredKind(name) == "f64" }

// True if the module GLOBAL `name` is an f64 cell. (Slice 3.)
function globalIsF64(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return false }
  letIsF64(li, -1)
}

// True if evaluating the expression at `exprIx` yields an f64: a float `.` literal,
// a reference to an f64 param/local/global, f64 arithmetic (either operand f64 — the
// i32 side widens via `f64.convert_i32_s`), unary `-`/parens over such, or a call to
// an f64-returning function. Drives the `print` import choice (`__print_f64__`) and the
// per-operand opcode selection in the BinExpr path. (Slice 3.)
export function exprIsF64(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  // Typed-IR fast path through the single `tyKindOf` mapping (additive — only turns false
  // into true, so the flow/union-narrowed cases below still apply; a node with no recorded
  // type, e.g. a monomorphized instance body, reads -1 and falls through to the syntactic
  // derivation).
  if tyKindOf(nodeTyIxOf(exprIx)) == 11 { return true }
  if coalesceAtomKind(exprIx, fnIx) == 4 { return true }
  // `m[k] ?? d` / `m.get(k) ?? d` over an f64-VALUED map yields an f64 (the value type).
  const cmf = coalesceMvSlot(exprIx, fnIx)
  if cmf >= 0 {
    if mvValKind[cmf] == 11 { return true }
  }
  const e = P.nodes[exprIx]
  // An explicit `x as T` cast has exactly its target rep — classify syntactically
  // (robust where `nodeTyIx` is absent, e.g. a monomorphized body).
  if e is AsExpr { return e.asTy == "f64" }
  if e is NumLit { return numTextIsFloat(e.numText) }
  if e is Paren { return exprIsF64(e.parInner, fnIx) }
  // An index read into an `f64[]` yields an f64 element (Slice 4) — so it routes to
  // `__print_f64__` and participates in f64 arithmetic. A bare `m[k]` read over an
  // f64-valued map likewise yields an f64.
  if e is Index {
    if exprF64Array(e.idxArr, fnIx) { return true }
    const mrs = mapReadMvSlot(exprIx, fnIx)
    if mrs >= 0 {
      if mvValKind[mrs] == 11 { return true }
    }
    return false
  }
  if e is Ident {
    // A VALUE-union ident classifies by its narrowed atom (see exprIsI64).
    const uk = unionIdentReadKind(exprIx, fnIx)
    if uk != -3 { return uk == 4 }
    if paramIsF64(fnIx, e.identName) { return true }
    if declaredF64(e.identName) { return true }
    return globalIsF64(e.identName)
  }
  // Arithmetic yields f64 when EITHER operand is f64. Comparisons / logical connectives
  // produce an i32 BOOL even over f64 operands, so they are NOT f64.
  if e is BinExpr {
    const op = e.binOp
    if op == "+" || op == "-" || op == "*" || op == "/" {
      if exprIsF64(e.binLeft, fnIx) { return true }
      return exprIsF64(e.binRight, fnIx)
    }
    // `xs.get(i) ?? d` over an f64 list yields an f64 (the fused checked read);
    // the default `d` shares the element type, so classify by the right side.
    if op == "??" {
      const lhs = P.nodes[unwrapParen(e.binLeft)]
      if lhs is Call {
        const lcallee = P.nodes[lhs.callFn]
        if lcallee is Member {
          if lcallee.memProp == "get" || lcallee.memProp == "pop" {
            if exprF64Array(lcallee.memObj, fnIx) { return true }
          }
        }
      }
      return false
    }
    return false
  }
  // Unary negation `-x` preserves f64-ness (`~` is integer-only; `!` is bool).
  if e is Unary {
    if e.unOp == "-" { return exprIsF64(e.unArg, fnIx) }
    return false
  }
  if e is Call {
    // An INDEXED closure call `fs[i](x)` whose element signature returns f64.
    if cloArrCallRetKind(exprIx, fnIx) == "f64" { return true }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const target = fnIndexOf(callee.identName)
      if target >= 0 { return fRetKind[target] == "f64" }
      // A function-VALUE (closure) callee returning f64 — its result routes as f64.
      return calleeReturnsF64(callee.identName, fnIx)
    }
    // A FIELD-closure call `t.op(x)` whose field function returns f64.
    if callee is Member {
      const ffe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
      if ffe >= 0 { return cloRetKindOf(ffe) == "f64" }
    }
    return false
  }
  // A field read `p.x` whose struct field is an f64 slot (code 17) yields an f64.
  if e is Member { return memFieldTypeCode(exprIx, fnIx) == 17 }
  // A value-position if-EXPRESSION is f64 when either arm's value is f64 (the
  // branch-join widens to f64); an `else if` chain recurses through the else slot.
  if e is IfStmt { return ifExprArmIsKind(exprIx, fnIx, "f64") }
  false
}

export function exprIsBool(ix: i32, fnIx: i32) {
  if ix < 0 { return false }
  // Typed-IR fast path (additive — only turns false into true, mirroring exprIsF64):
  // the checker recorded this node as the `boolean` prim. Boolean shares the i32 rep
  // everywhere, so the syntactic derivations below lose the boolean TAG through several
  // read paths — a struct-FIELD read (field code 0 = i32/boolean), a map `??` result, a
  // closure-VALUE call result, a `boolean[]` PARAM element — and `print` rendered 0/1.
  if nodeTyWidenedRepName(ix) == "boolean" { return true }
  const e = P.nodes[ix]
  if e is BoolLit { return true }
  if e is IsExpr { return true }
  if e is Paren { return exprIsBool(e.parInner, fnIx) }
  if e is Index {
    // An element read over a BOOLEAN-element list prints as true/false: a `.map` result
    // whose callback returns boolean (`xs.map(function(n: i32) n > 2)[i]`), OR a directly
    // declared `boolean[]` (`bs[i]`). Any other index read keeps its i32 classification.
    if mfArrElemIsBool(e.idxArr, fnIx) { return true }
    return listElemIsBool(e.idxArr, fnIx)
  }
  if e is Unary { return e.unOp == "!" }
  if e is Ident {
    // A VALUE-union ident narrowed to `boolean` unboxes to the bool rep and
    // prints true/false (see exprIsI64 for the classification rule).
    const uk = unionIdentReadKind(ix, fnIx)
    if uk != -3 { return uk == 1 }
    // A `boolean|null` NICHE binding read (narrowed non-null in its branch)
    // prints true/false. Plain `boolean` idents stay unclassified (existing rule).
    if exprNulBool(ix, fnIx) { return true }
    // A CAPTURED boolean (a closure returning its maker's `x: boolean` param,
    // e.g. a monomorphized `wrap(true)` index-trap instance) — so the closure's
    // inferred return kind (`fRetBool`) sees the bool-ness through the env.
    if capturedIsBool(fnIx, e.identName) { return true }
    // A plain boolean local/param/global — recovered from the binding's annotation
    // or initializer, since a boolean local registers identically to an i32.
    if boundBoolByName(e.identName, fnIx) { return true }
  }
  if e is BinExpr {
    const op = e.binOp
    if op == "==" || op == "!=" { return true }
    if op == "<" || op == ">" || op == "<=" || op == ">=" { return true }
    if op == "&&" || op == "||" { return true }
    // `lhs ?? d` over a BOOLEAN-list `.get`/`.pop` (or a binding seeded by one)
    // yields a boolean — render true/false. Other `??` reads keep i32 (map gets).
    if op == "??" {
      const lhs = P.nodes[unwrapParen(e.binLeft)]
      if lhs is Call {
        const lcallee = P.nodes[lhs.callFn]
        if lcallee is Member {
          if lcallee.memProp == "get" || lcallee.memProp == "pop" {
            if !exprMap(lcallee.memObj, fnIx) {
              return listElemIsBool(lcallee.memObj, fnIx)
            }
          }
        }
      }
      if lhs is Ident { return identNullableBoolPop(lhs.identName, fnIx) }
    }
    return false
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    // A FIELD-CLOSURE call (`(wb."[]")(0)` — an index-trap dispatch) classifies
    // by the field function's return: the receiver's ORIGIN resolves the exact
    // monomorphized MAKER instance, so `wrap(true)`'s trap prints true while
    // `wrap(99)`'s prints 99 (the instances SHARE the closure body — bool-ness
    // lives in the instance's pinned param annotation, not the shared closure).
    if callee is Member {
      if (
        drwFieldClosure(structIndexOfExpr(callee.memObj, fnIx), callee.memProp)
      ) {
        return fieldCloCallIsBool(callee.memObj, callee.memProp, fnIx)
      }
    }
    if callee is Ident {
      const target = fnIndexOf(callee.identName)
      if target >= 0 {
        const fn = P.nodes[fnStmts[target]]
        if fn is FuncDecl {
          if fn.fnRet >= 0 {
            const rt = P.nodes[fn.fnRet]
            if rt is TypeRef { return rt.tyName == "boolean" }
          } else {
            // Un-annotated: `computeRetInference` has classified the callee's first
            // valued return into `fRetBool` (fixed point, so a mutually-recursive
            // group resolves).
            return fRetBool[target] == 1
          }
        }
      }
    }
    // G8: a map membership test `m.has(k)` and a `m.delete(k)` both yield a boolean
    // (print true/false): `.has` = is-present, `.delete` = was-present-and-removed.
    if callee is Member {
      if callee.memProp == "has" { return exprMap(callee.memObj, fnIx) }
      if callee.memProp == "delete" { return exprMap(callee.memObj, fnIx) }
      // A string `s.includes(sub)` yields a boolean (print true/false).
      if callee.memProp == "includes" { return exprString(callee.memObj, fnIx) }
    }
  }
  false
}

// Lower a function-VALUE call `f(args)` via `call_ref` over the closure fat-pointer.
// The closure is evaluated ONCE into a scratch local, then: push its env
// (`struct.get 1`), push the args, push its code funcref (`struct.get 0`), and
// `call_ref $fnsig`. Mirrors the host's `indirectCall` (adapted to `call_ref`).
// A NAMED argument needs the callee's parameter names, which a function VALUE
// (its `TyFunc`) does not carry — fail loudly rather than mis-map positionally.
// The closure `$fnsig` KEY for the elements of a closure-element ref list (kind 5): the
// slot's element type-NAME is the parenthesized function type `((i32) => i32)`; strip the
// grouping parens to `(i32) => i32` and read its signature key (`annSigKey`, which agrees
// byte-for-byte with `fnSigKeyOf`/`cloSigKeyExt`). "" for a non-closure slot or an
// un-keyable signature. Lets an INDEXED closure call (`fs[i](x)`) cast to the ELEMENT's
// real functype instead of the all-i32 arity fallback — which a non-i32-signature array
// (`((f64) => f64)[]`) doesn't even have interned.
function cloArrSlotSigKey(slot: i32) {
  if slot < 0 || slot >= rlElemName.length { return "" }
  if rlElemKindTbl[slot] != 5 { return "" }
  let nm = rlElemName[slot]
  // A NULLABLE-closure element slot keys the full `"<closure> | null"` (the niche read
  // discipline) — peel the `| null` to reach the parenthesized function type; the narrowed
  // indexed call (`if e != null { e(1) }`) casts to the same functype a non-null element does.
  const nmp = nullablePartOf(nm)
  if nmp != "" { nm = nmp }
  if nm.length < 2 { return "" }
  if nm[0] != '(' || nm[nm.length - 1] != ')' { return "" }
  return annSigKey(nm.slice(1, nm.length - 1))
}

// The closure RESULT type-NAME of a closure-element ref-list slot (kind 5): the element name is the
// parenthesized function type `(() => K0 | null)`; strip the grouping parens and return the text
// after the top-level `=>` (`K0 | null`). "" for a non-closure slot / an un-parseable element. Lets
// an INDEXED closure call (`p[i]()`) classify its result niche (`exprNulLitUnion` → `p[i]() : K|null`).
export function cloArrSlotRetName(slot: i32) {
  if slot < 0 || slot >= rlElemName.length { return "" }
  if rlElemKindTbl[slot] != 5 { return "" }
  let nm = rlElemName[slot]
  // A NULLABLE-closure element slot: peel the `| null` (the call classifies on the
  // narrowed non-null closure), mirroring `cloArrSlotSigKey`.
  const nmrp = nullablePartOf(nm)
  if nmrp != "" { nm = nmrp }
  if nm.length < 2 { return "" }
  if nm[0] != '(' || nm[nm.length - 1] != ')' { return "" }
  const inner = nm.slice(1, nm.length - 1)
  const at = annArrowAt(inner)
  if at < 0 { return "" }
  return inner.slice(at + 2, inner.length)
}

// The wide-SCALAR coercion kind of parameter `idx` read from a `$fnsig` KEY's param-token
// spine: `"i64"` / `"f64"` / `"f32"`, or `null` (i32 / a ref kind — no coercion). Each
// token decodes through the ONE char→kind table (`repKindOfSigTok`); a slot-carrying ref
// token (`s<idx>;` / `V<idx>;` / `r<idx>;`) skips its `;`-terminated digits via the
// table's own slot predicate (`repSigTokHasSlot`). Lets a value CALL widen an i32-literal
// argument into an i64 / f32 / f64 parameter, exactly as a direct call does — without it
// the `call_ref` pushes an i32 and traps.
export function sigParamCoerceKind(key: string, idx: i32): VKind | null {
  let i = 0
  let p = 0
  while i < key.length {
    const c = key[i]
    if c == '>' { return null }
    const k = repKindOfSigTok(c)
    if p == idx {
      if k == "i64" || k == "f64" || k == "f32" { return k }
      return null
    }
    if repSigTokHasSlot(k) {
      while i < key.length && key[i] != ';' { i = i + 1 }
      i = i + 1
    } else {
      i = i + 1
    }
    p = p + 1
  }
  null
}

// The callee's interned `$fnsig` KEY for a value call (`f(x)`, `(o.field)(x)`, `fs[i](x)`), or "" —
// the param tokens drive argument coercion and the key resolves the functype the `call_ref` casts to.
export function cloCallSigKey(callIx: i32, fnIx: i32) {
  const c = P.nodes[callIx]
  if c is Call {
    const cre = P.nodes[c.callFn]
    // The syntactic resolvers — fast (no type render): a function-typed binding/param Ident, a struct
    // field closure, an indexed closure-array element.
    if cre is Ident {
      const k = calleeCloSigKey(cre.identName, fnIx)
      if k != "" { return k }
    }
    if cre is Member {
      const mfe = fieldClosureFeOfRecv(cre.memObj, cre.memProp, fnIx)
      if mfe >= 0 { return cloSigKeyExt(mfe) }
    }
    if cre is Index {
      if exprRefArray(cre.idxArr, fnIx) {
        const k = cloArrSlotSigKey(refListSlotOfExpr(cre.idxArr, fnIx))
        if k != "" { return k }
      }
    }
    // GENERAL FALLBACK — derive the key from the callee's CHECKER type, uniformly for ANY callee the
    // syntactic resolvers miss (an indexed closure-array element returning a struct/union, a value
    // INFERRED from a factory call `const g = mk()`). `nodeTyName` renders the closure's `(params)=>ret`
    // name (the checker proved its TyFunc), then the SAME `annSigKey` the annotation path uses produces
    // a byte-identical key — so the call-site `ref.cast` resolves the functype the lambda interned, with
    // no per-position sig producer. Off the hot path: reached only after the syntactic resolvers, so a
    // common closure call (annotated binding/param) never renders.
    const tn = nodeTyName(c.callFn)
    if tn != "" {
      if annArrowAt(tn) >= 0 { return annSigKey(tn) }
    }
  }
  ""
}

// True if the list at `arrIx` carries BOOLEAN elements: a `[true, ...]` literal, a
// `boolean[]` annotation, a name tracing to either (local let or module global), or
// a `.map`/`.filter` result whose callback returns boolean (`mfArrElemIsBool`).
// Boolean elements ride the i32 list rep (0/1), with the spare value 2 encoding the
// `boolean | null` of a checked `.pop()` — the niche sentinel, mirroring the host.
export function listElemIsBool(arrIx: i32, fnIx: i32) {
  if arrIx < 0 { return false }
  const inner = unwrapParen(arrIx)
  const e = P.nodes[inner]
  if e is ArrayLit {
    if e.arrElems.length > 0 { return exprIsBool(e.arrElems[0], fnIx) }
    return false
  }
  if e is Ident {
    let li = -1
    if fnIx >= 0 {
      const fn = P.nodes[fnIx]
      if fn is FuncDecl { li = parentLetOf(fn.fnBody, e.identName) }
    }
    if li < 0 { li = globalLetOf(e.identName) }
    if li >= 0 {
      const d = P.nodes[li]
      if d is LetDecl {
        if d.letType >= 0 {
          const lt = P.nodes[d.letType]
          if lt is TypeRef {
            if lt.tyName == "boolean[]" { return true }
          }
        }
        if d.letInit >= 0 {
          if unwrapParen(d.letInit) != inner {
            return listElemIsBool(d.letInit, fnIx)
          }
        }
      }
    }
    return false
  }
  mfArrElemIsBool(arrIx, fnIx)
}

// True if `name` is a binding whose initializer is a checked `.pop()` over a
// BOOLEAN-element list — its i32 cell holds 0/1 or the niche sentinel 2 (`null`),
// so a later `name ?? d` must compare against 2, not test a ref.
export function identNullableBoolPop(name: string, fnIx: i32) {
  let li = -1
  if fnIx >= 0 {
    const fn = P.nodes[fnIx]
    if fn is FuncDecl { li = parentLetOf(fn.fnBody, name) }
  }
  if li < 0 { li = globalLetOf(name) }
  if li >= 0 {
    const d = P.nodes[li]
    if d is LetDecl {
      if d.letInit >= 0 {
        const ini = P.nodes[unwrapParen(d.letInit)]
        if ini is Call {
          const callee = P.nodes[ini.callFn]
          if callee is Member {
            if callee.memProp == "pop" {
              return listElemIsBool(callee.memObj, fnIx)
            }
          }
        }
      }
    }
  }
  false
}

// Lower a `.map`/`.filter` HOF call onto `body`, leaving the RESULT list wrapper ref
// on the stack. Mirrors the host's `lowerMapMethodCall` (`toWasm.ts:2143–2245`) over
// the `call_ref` closure ABI — the generic closure-calling loop ONLY (the inline
// desugar of single-expression callbacks is a documented non-goal; `vl build -O`
// devirtualizes + inlines it):
//   map:    n = len(src); back = array.new_default(<outElemArr>, n)
//           for i in 0..n:  back[i] = call_ref(clo, [elem(i)])
//           result = wrapper{ back, n, n }
//   filter: n = len(src); back = array.new_default(<elemArr>, n); j = 0
//           for i in 0..n:  if call_ref(clo, [elem(i)]): back[j] = elem(i); j++
//           result = wrapper{ back, j, n }          // len = j, cap = n
// The receiver is evaluated ONCE into the typed src slot; the callback's closure
// value is built ONCE before the loop (an inline literal / named function emits
// `emitClosureValue`; a let-bound value reads its binding). `filter` re-reads
// `elem(i)` off the src backing for the survivor store (a pure re-read — the host
// materializes it the same way). The result element kind is the callback's RETURN
// kind for `map` (an i32→bool callback yields a bool/i32-element list; an f64
// callback the f64 backing + wrapper), the receiver's element kind for `filter`.
// The interned `$fnsig` KEY of a `.map`/`.filter` callback that is a CLOSURE VALUE — a function-typed
// param or binding (`xs.map(f)` with `f: (i32) => i32`), NOT a literal lambda / named function (those
// resolve a lifted `mfCallbackFe`). "" otherwise. Lets `.map`/`.filter` accept a runtime callback (the
// `call_ref` loop already does), so a higher-order function can forward a callback to `.map`.
export function mfCallbackCloKey(cbIx: i32, fnIx: i32) {
  const cb = P.nodes[unwrapParen(cbIx)]
  if cb is Ident {
    if fnIndexOf(cb.identName) >= 0 {
      return "" // a named fn — uses the lifted-fe path
    }
    return calleeCloSigKey(cb.identName, fnIx)
  }
  ""
}

// Map a closure SIG-RETURN kind (`sigKeyRetKind`) to a `.map` RESULT element kind
// (`mfResultKindOf`'s vocabulary), for a closure-value callback. A STRUCT return maps to a
// ref-list result — its slot comes from `mfResultSlotOf`'s closure-value branch. `null`
// for a void result / still-unwired ref kind.
function mfResKindFromSigRet(k: VKind | null): MfKind | null {
  if k == "i32" { return "i32" }
  if k == "f64" { return "f64" }
  if k == "i64" { return "i64" }
  if k == "str" { return "str" }
  if k == "struct" { return "ref" }
  null
}

// If the `if` condition at `condIx` is `n is Variant` over a bare union identifier
// `n`, PUSH the narrowing (`narrowNames`/`narrowVariants`) so the then-branch's
// `n.field` reads downcast through the box, and return true. Otherwise leave the
// narrowing stack untouched and return false. A non-identifier receiver (e.g. `f(x) is
// A`) is not narrowable (no stable name to re-read) and is left un-narrowed. The caller
// saves the stack length and truncates back on branch exit (`restoreNarrow`).
export function setNarrowFromCond(condIx0: i32, fnIx: i32) {
  // A parenthesized condition guards identically (`if (x is A)` ≡ `if x is A`), and
  // the checker's narrowing collectors already peel `Paren` — match them here so the
  // emitter narrows every branch the checker proved narrowed. Every matcher below
  // (including the `&&`-conjunct recursion) sees the bare condition shape.
  const condIx = unwrapParen(condIx0)
  const c = P.nodes[condIx]
  if c is IsExpr {
    const recv = P.nodes[c.isObj]
    if recv is Ident {
      if exprUnion(c.isObj, fnIx) {
        pushNarrow(recv.identName, c.isVariant)
        return true
      }
    }
    // `o.y is T` over a UNION-typed struct FIELD narrows the member PATH (the
    // narrowing key is the path string `o.y`; `emitMem` unboxes under it).
    const mrecv = P.nodes[unwrapParen(c.isObj)]
    if mrecv is Member {
      if memberUnionFieldName(unwrapParen(c.isObj), fnIx) != "" {
        const mk = memberPathKeyOf(unwrapParen(c.isObj))
        if mk != "" {
          pushNarrow(mk, c.isVariant)
          return true
        }
      }
    }
    // `x?.y is T` narrows the member PATH exactly like `x.y is T` — the then-arm
    // only runs when every chain link held AND the union field matched, so the
    // plain `x.y` reads inside it unbox under the same path key.
    if mrecv is OptMember {
      const omSi = optChainStructIdxOf(mrecv.omObj, fnIx)
      if omSi >= 0 {
        const omFi = sFieldIndex(omSi, mrecv.omProp)
        if omFi >= 0 {
          if sFieldTypeAt(omSi, omFi) == 16 {
            const omRoot = P.nodes[unwrapParen(mrecv.omObj)]
            if omRoot is Ident {
              pushNarrow(omRoot.identName + "." + mrecv.omProp, c.isVariant)
              return true
            }
          }
        }
      }
    }
  }
  // `a && b` composes: the then-branch sees BOTH conjuncts' narrowings (the
  // host's A5 — the RHS is even CHECKED under the LHS's narrowing). The pushes
  // stack; the caller's save/restore of `narrowTop` unwinds them together.
  if c is BinExpr {
    if c.binOp == "&&" {
      const nl = setNarrowFromCond(c.binLeft, fnIx)
      const nr = setNarrowFromCond(c.binRight, fnIx)
      return nl || nr
    }
  }
  // `!cond` swaps the branch senses: the then-arm of `if !(x is A) { … }` sees the
  // ELSE-narrowing of the inner condition (the host's negation complement).
  if c is Unary {
    if c.unOp == "!" {
      return setNarrowFromCondElse(unwrapParen(c.unArg), fnIx)
    }
  }
  // `x == null` / `x != null` over a BOXED VALUE union narrows the THEN-branch:
  // `==` pins `x` to the `null` member; `!=` strips `null` from the current set
  // (so `i32 | null` fully unboxes to `i32` in the non-null branch).
  const nm = valueUnionNullCmpName(condIx, fnIx)
  if nm != "" {
    const cn = P.nodes[condIx]
    if cn is BinExpr {
      if cn.binOp == "==" {
        pushNarrow(nm, "null")
        return true
      }
      const rest = removeAtomFrom(currentNarrowSetOf(nm, fnIx), "null")
      if rest != "" {
        pushNarrow(nm, rest)
        return true
      }
    }
  }
  // The same null-compare narrowing over a BOXED STRUCT union with a `null` member
  // (`v: A | B | null`): `!=` strips `null` (so an inner `is`/else chain subtracts
  // toward a single variant), `==` pins `null`. The 1-struct niche (`S | null`) is
  // excluded — it is a nullable REF, not a box, and keeps its existing lowering.
  const snm = structUnionNullCmpName(condIx, fnIx)
  if snm != "" {
    const scn = P.nodes[condIx]
    if scn is BinExpr {
      if scn.binOp == "==" {
        pushNarrow(snm, "null")
        return true
      }
      const srest = removeAtomFrom(currentStructNarrowSetOf(snm, fnIx), "null")
      if srest != "" {
        pushNarrow(snm, srest)
        return true
      }
    }
  }
  false
}

// The receiver NAME when the condition at `condIx` is `<ident> == null` /
// `<ident> != null` over a BOXED STRUCT union (2+ struct variants plus a `null`
// member), else "". The value-union and 1-struct-niche forms are excluded (each
// keeps its own narrowing path).
function structUnionNullCmpName(condIx: i32, fnIx: i32) {
  const c = P.nodes[condIx]
  if c is BinExpr {
    if c.binOp == "==" || c.binOp == "!=" {
      const lhs = P.nodes[unwrapParen(c.binLeft)]
      const rhs = P.nodes[unwrapParen(c.binRight)]
      let refIx = -1
      if rhs is NullLit { refIx = unwrapParen(c.binLeft) }
      if lhs is NullLit { refIx = unwrapParen(c.binRight) }
      if refIx >= 0 {
        const r = P.nodes[refIx]
        if r is Ident {
          const un = unionNameOfIdent(r.identName, fnIx)
          if un != "" {
            if !isValueUnionName(un) {
              const uset = unionMemberSetOf(un)
              if unionHasAtom(uset, "null") && nonNullMemberCountOf(uset) >= 2 {
                return r.identName
              }
            }
          }
        }
      }
    }
  }
  ""
}

// The receiver NAME when the condition at `condIx` is `<ident> == null` /
// `<ident> != null` over a boxed VALUE union, else "". (A struct union / niche
// nullable keeps its existing lowering and narrowing behavior.)
function valueUnionNullCmpName(condIx: i32, fnIx: i32) {
  const c = P.nodes[condIx]
  if c is BinExpr {
    if c.binOp == "==" || c.binOp == "!=" {
      const lhs = P.nodes[unwrapParen(c.binLeft)]
      const rhs = P.nodes[unwrapParen(c.binRight)]
      let refIx = -1
      if rhs is NullLit { refIx = unwrapParen(c.binLeft) }
      if lhs is NullLit { refIx = unwrapParen(c.binRight) }
      if refIx >= 0 {
        const r = P.nodes[refIx]
        if r is Ident {
          const un = unionNameOfIdent(r.identName, fnIx)
          if un != "" {
            if isValueUnionName(un) { return r.identName }
          }
        }
      }
    }
  }
  ""
}

// The ELSE-branch dual of `setNarrowFromCond`, for VALUE unions only: the guard
// was FALSE there, so `is T` strips `T` from the current set (a 2-member union
// fully discriminates — `string | i32` minus `i32` is `string`, which unboxes),
// `== null` strips `null`, and `!= null` pins `null`. Struct unions keep their
// existing (no else-narrowing) behavior — their member reads must not change.
export function setNarrowFromCondElse(condIx0: i32, fnIx: i32) {
  // Peel `Paren` exactly like `setNarrowFromCond` — the else-arm of `if (x is A)`
  // complement-narrows the same as the bare spelling.
  const condIx = unwrapParen(condIx0)
  const c = P.nodes[condIx]
  if c is IsExpr {
    if valueAtomKind(c.isVariant) >= 0 {
      const recv = P.nodes[unwrapParen(c.isObj)]
      if recv is Ident {
        const un = unionNameOfIdent(recv.identName, fnIx)
        if un != "" {
          if isValueUnionName(un) {
            const rest = removeAtomFrom(
              currentNarrowSetOf(recv.identName, fnIx),
              c.isVariant,
            )
            if rest != "" {
              pushNarrow(recv.identName, rest)
              return true
            }
          }
        }
      }
      // `o.y is T` over a UNION-typed struct FIELD: the guard was FALSE there, so
      // `T` is stripped from the path's current set — a 2-member field union fully
      // discriminates (`string | i32` minus `i32` reads as `string`), unboxing the
      // else-arm's `o.y` under the same path key `setNarrowFromCond` pushes.
      if recv is Member {
        const mun = memberUnionFieldName(unwrapParen(c.isObj), fnIx)
        if mun != "" {
          const mk = memberPathKeyOf(unwrapParen(c.isObj))
          if mk != "" {
            let mcur = unionMemberSetOf(mun)
            const mNar = narrowVariantFor(mk)
            if mNar != "" { mcur = mNar }
            const mrest = removeAtomFrom(mcur, c.isVariant)
            if mrest != "" {
              pushNarrow(mk, mrest)
              return true
            }
          }
        }
      }
      // A MIXED union — struct arm(s) alongside the tested VALUE atom (`{f: i32} |
      // i32`) — is NOT a value union, so the Ident arm above skipped it. Fall
      // THROUGH to the struct-union complement below: the guard was false, so
      // subtracting the tested atom leaves the struct arm(s), and the else-arm's
      // `v.f` reads through the same narrowed-member downcast the positive arm
      // uses. (The #923-observed hole: the checker's subtract-narrow answered the
      // struct, but the emitter never registered the negative arm — a GLOBAL
      // receiver's `v.f` then read the box RAW, invalid wasm; a local rejected
      // loudly. Both spellings now narrow.) Anything else keeps the reject.
      let elseMixed = false
      if recv is Ident {
        const mxun = unionNameOfIdent(recv.identName, fnIx)
        if mxun != "" {
          if !isValueUnionName(mxun) { elseMixed = true }
        }
      }
      if !elseMixed { return false }
    }
    // STRUCT-union complement (host flow narrowing): the guard was FALSE, so the
    // tested VARIANT is stripped from the receiver's current set. When one member
    // remains, the else-arm fully discriminates (`if v is A {…} else { v.y }`
    // reads `v` as the `B` variant); a multi-member rest ("N2|N3") keeps a later
    // `else if` arm subtracting toward its own singleton. Only a BOXED struct
    // union narrows (`exprUnion` — the 1-struct niche is a nullable ref, whose
    // member reads must not change).
    const srecv = P.nodes[unwrapParen(c.isObj)]
    if srecv is Ident {
      if exprUnion(c.isObj, fnIx) {
        const srest = removeAtomFrom(
          currentStructNarrowSetOf(srecv.identName, fnIx),
          c.isVariant,
        )
        if srest != "" {
          pushNarrow(srecv.identName, srest)
          return true
        }
      }
    }
    return false
  }
  // `!cond` in the ELSE-arm: the inner condition was TRUE there, so the else sees
  // the inner condition's THEN-narrowing (`if !(n is Program) {…} else { n.progStmts }`).
  if c is Unary {
    if c.unOp == "!" { return setNarrowFromCond(unwrapParen(c.unArg), fnIx) }
  }
  const nm = valueUnionNullCmpName(condIx, fnIx)
  if nm != "" {
    const cn = P.nodes[condIx]
    if cn is BinExpr {
      if cn.binOp == "!=" {
        pushNarrow(nm, "null")
        return true
      }
      const rest = removeAtomFrom(currentNarrowSetOf(nm, fnIx), "null")
      if rest != "" {
        pushNarrow(nm, rest)
        return true
      }
    }
  }
  // The struct-union dual: in the else of `v != null` the value IS `null`; in the
  // else of `v == null` it is the non-null variant set.
  const snm = structUnionNullCmpName(condIx, fnIx)
  if snm != "" {
    const scn = P.nodes[condIx]
    if scn is BinExpr {
      if scn.binOp == "!=" {
        pushNarrow(snm, "null")
        return true
      }
      const srest = removeAtomFrom(currentStructNarrowSetOf(snm, fnIx), "null")
      if srest != "" {
        pushNarrow(snm, srest)
        return true
      }
    }
  }
  false
}

// Rewind the narrowing stack depth back to `n` (drop bindings a branch pushed). The
// arrays keep their backing slots — only the logical depth changes, so no `.pop()`.
export function restoreNarrow(n: i32) {
  narrowTop = n
  0
}

// After a GUARD `if` — one with NO else whose then-branch always returns — the
// rest of the enclosing block only runs when the guard was FALSE, so it sees
// the same complement narrowing an explicit else-arm would (the host's flow
// narrowing after an early return): `if x is boolean { return 0 } return x`
// reads `x` as the unboxed `i32` below the guard. Pushes via
// `setNarrowFromCondElse` (VALUE unions only — struct unions keep their
// no-else-narrowing behavior); the CALLER restores the depth at block exit.
export function pushPostGuardNarrow(stmtIx: i32, fnIx: i32) {
  const s = P.nodes[stmtIx]
  if s is IfStmt {
    if s.ifElse < 0 {
      if blockAlwaysReturns(s.ifThen) { setNarrowFromCondElse(s.ifCond, fnIx) }
    }
  }
  // ASSIGNMENT narrowing (A-infer-null, the host's `assignmentNarrowing`): a
  // straight-line `x = <non-null expr>` over a null-bearing VALUE union makes
  // `x` provably non-null for the REST of the enclosing block — `let x = null;
  // x = 5; x + 1` reads the unboxed i32 with no null tax. Emitted only for a
  // plain `=` to a bare name whose RHS is itself non-null (a `x = maybeNull()`
  // RHS, or a bare `null`, leaves `x` un-narrowed). The CALLER restores the
  // depth at block exit, so a branch-local assignment never leaks past the join.
  if s is BinExpr {
    if s.binOp == "=" {
      const tgt = P.nodes[s.binLeft]
      if tgt is Ident {
        const un = unionNameOfIdent(tgt.identName, fnIx)
        if un != "" && isValueUnionName(un) && unionHasAtom(un, "null") {
          const rhs = P.nodes[unwrapParen(s.binRight)]
          let rhsNullable = false
          if rhs is NullLit { rhsNullable = true }
          const rn = unionNameOfExpr(s.binRight, fnIx)
          if rn != "" {
            if unionHasAtom(rn, "null") { rhsNullable = true }
          }
          if !rhsNullable {
            pushNarrow(tgt.identName, removeAtomFrom(un, "null"))
          }
        }
      }
    }
  }
  0
}

export function forInElemKind(iterIx: i32, fnIx: i32): VKind | null {
  const e = P.nodes[iterIx]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if exprMap(callee.memObj, fnIx) {
        if callee.memProp == "keys" { return "str" }
        if callee.memProp == "values" {
          // A SET's `.values()` yields its ELEMENTS — the string keys (kind 3),
          // not the i32 membership booleans. A map's yields its VALUES: i32 for
          // the mono map, the value's kind for a ref-valued map (string 3 /
          // struct 1 — the loop var binds that kind).
          if mapIsSetExpr(callee.memObj, fnIx) { return "str" }
          const vsl = mapShapeOfExpr(callee.memObj, fnIx)
          if vsl >= 0 {
            if mvValKind[vsl] == 3 {
              return "str" // string value
            }
            if mvValKind[vsl] == 11 {
              return "f64" // f64 value (scalar local)
            }
            if mvValKind[vsl] == 10 {
              return "i64" // i64 value (scalar local)
            }
            if mvValKind[vsl] == 13 {
              return "f32" // f32 value (scalar local)
            }
            if mvValKind[vsl] == 14 {
              return "closure" // closure value (`{[string]: (i32) => i32}` — loop var calls each)
            }
            // A LIST value (`{[string]: i32[]}` / `f64[]` / `S[]` …): the loop var binds the inner
            // VALUE LIST, exactly as a nested-array `for row in g` over `i32[][]` does — its
            // loop-var kind is the value-list's rep (`mvListValKind` → 2/7/12/20/21, or 5 for a
            // struct/ref list). The `#l` temp is the vals ref-list wrapper (`forInMapValsSlot`).
            if mvValKind[vsl] == 6 { return mvListValKind(vsl) }
            return "struct" // struct value
          }
          return "i32"
        }
      }
    }
  }
  // A bare MAP iterable (`for k in m`) iterates its KEYS — like `m.keys()` (kind 3).
  if exprMap(iterIx, fnIx) { return "str" }
  if exprStringArray(iterIx, fnIx) { return "str" }
  // A STRUCT-element ref list (`S[]`): the element is a struct ref, so bind the loop
  // var as a code-`1` struct local. (Union-box (`2`) / map-array ref lists are not
  // yet supported here — they fall through to the unsupported -1.)
  if exprRefArray(iterIx, fnIx) {
    const rslot = refListSlotOfExpr(iterIx, fnIx)
    if rlElemKindTbl[rslot] == 1 {
      // A NULLABLE-struct element ref list (`(P | null)[]`, slot key "P | null"): the loop var
      // binds as a kind-9 niche (`for e in xs { if e != null { … e.v … } }`), and the element
      // read stays nullable (no `ref.as_non_null`). A plain `S[]` is the non-null kind 1.
      if nullablePartOf(rlElemName[rslot]) != "" { return "nulstruct" }
      return "struct"
    }
    // A UNION-box element ref list (`(C | S)[]`, kind 2): the loop var binds as a kind-4
    // union-box local (the element-kind code IS the loop-var local kind, as struct's `1` is),
    // so `for x in arr { … x is S … }` narrows each element. The `#l` temp is the ref-list
    // wrapper (code 5), same as the struct case.
    if rlElemKindTbl[rslot] == 2 { return "union" }
    // A NESTED-ARRAY element ref list (`i32[][]`/`string[][]`/`f64[][]`/`i64[][]`, element kind
    // 4/6/7/8 = the inner list wrapper): the loop var binds the INNER LIST — a list local of
    // kind 2/7/12/20 (i32/string/f64/i64 list). The element read is a ref (the inner wrapper,
    // recovered non-null), like the struct case; the `#l` temp is the outer ref-list wrapper.
    if rlElemKindTbl[rslot] == 4 { return "list" }
    if rlElemKindTbl[rslot] == 6 { return "strlist" }
    if rlElemKindTbl[rslot] == 7 { return "f64list" }
    if rlElemKindTbl[rslot] == 8 { return "i64list" }
    if rlElemKindTbl[rslot] == 10 {
      return "f32list" // f32-inner list -> an f32-list local (kind 21)
    }
    // A CLOSURE-element ref list (`((i32) => i32)[]`, element kind 5): the loop var binds as a
    // kind-14 closure local — `for f in fs { … f(x) … }` calls each via `call_ref`. The element
    // read recovers the closure ref non-null (like a struct); the `#l` temp is the ref-list
    // wrapper (code 5).
    if rlElemKindTbl[rslot] == 5 { return "closure" }
    // A NESTED REF array (`S[][]`/`(C|D)[][]`/`S[][][]`, element kind 9): the loop var binds the
    // INNER REF LIST — a kind-5 ref-list local carrying the inner slot. `for row in g { … row[j]
    // … }` then indexes/iterates it. The element read recovers the inner wrapper non-null; the
    // `#l` temp is the outer ref-list wrapper. Recurses (the inner slot may itself be kind 9).
    if rlElemKindTbl[rslot] == 9 { return "reflist" }
    return null
  }
  // An f64 element list (`f64[]`): the loop var binds as a scalar f64 local (code 11, the
  // same code a `let x: f64` uses, so `fbValtype` types it `0x7c` automatically), and the
  // `#l` temp is the f64-list (code 12). Recognized through `exprF64Array`, which trusts the
  // checker's recorded type, so an `f64[]`-returning call iterates too. Checked before the
  // i32 default (an f64 element is not an i32).
  // An f32 element list (`f32[]`): the loop var binds as a scalar f32 local (code 13).
  if exprF32Array(iterIx, fnIx) { return "f32" }
  if exprF64Array(iterIx, fnIx) { return "f64" }
  // An i64 element list (`i64[]`): the loop var binds as a scalar i64 local (code 10), and
  // the `#l` temp is the i64-list (code 20).
  if exprI64Array(iterIx, fnIx) { return "i64" }
  // A STRING iterable (`for ch in s`): each code unit is an i32 (loop-var code 0, same as an
  // `i32[]`), but the source is the RAW i32 array — the `#l` temp is the string itself (code 3),
  // and the length/element reads skip the list-wrapper `struct.get`. `forInStringSrc` flags it
  // at the temp-kind and emit sites. Checked before `exprArray` (a string is not an i32 list).
  if exprString(iterIx, fnIx) { return "i32" }
  if exprArray(iterIx, fnIx) { return "i32" }
  return null
}

// Whether a `for v in <iter>` iterable is a STRING (`for ch in s`) — the i32-code-unit walk over
// the raw array, distinct from an `i32[]` (code 0 too) whose backing hides behind a list wrapper.
export function forInStringSrc(iterIx: i32, fnIx: i32) {
  if forInElemKind(iterIx, fnIx) != "i32" { return false }
  exprString(iterIx, fnIx)
}

// The mv SLOT of a `for v in m.values()` walk over a REF-VALUED map, or -1 (not a
// map walk / a mono map / a set). The values walk then types its loop var + list
// temp off the slot's value type instead of a ref-array's element.
export function forInMapValsSlot(iterIx: i32, fnIx: i32) {
  const e = P.nodes[iterIx]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "values" {
        if exprMap(callee.memObj, fnIx) {
          if mapIsSetExpr(callee.memObj, fnIx) { return -1 }
          const sl = mapShapeOfExpr(callee.memObj, fnIx)
          if sl >= 0 { return sl }
        }
      }
    }
  }
  -1
}

// The element struct TABLE INDEX of a `for v in <S[]>` iterable (the struct that the
// code-`1` loop var binds), or -1 when the iterable is not a struct ref list. Mirrors
// the index-read resolution (`structIndexOfExpr` over `xs[i]`): the element name comes
// from the ref-list slot, then its struct table index. A STRUCT-VALUED map's
// `.values()` walk binds the slot's value struct.
export function forInRefArrayStructIdx(iterIx: i32, fnIx: i32) {
  const mvs = forInMapValsSlot(iterIx, fnIx)
  if mvs >= 0 {
    if mvValKind[mvs] == 1 { return mvValStructIdx[mvs] }
    return -1
  }
  if !exprRefArray(iterIx, fnIx) { return -1 }
  // Strip a `| null` niche suffix (`(P | null)[]` → "P") so the nullable-struct loop var
  // carries P's struct index.
  structIdxOfElemName(refListElemNameOfExpr(iterIx, fnIx))
}

// True if the map-typed expression at `exprIx` is a SET (`Set()`-seeded binding or
// the constructor itself). Consulted by the `.values()` paths: a set's `.values()`
// yields its ELEMENTS (the keys list), not the membership booleans in `vals` —
// mirroring the checker (`typecheck.vl`: a set's values() returns `mKey[]`).
// Params have no Set-distinguishing annotation, so a set passed as a parameter is
// out of scope (the checker's surface gating keeps `.values()` calls on it valid
// only for sets, but the flavor bit can't cross the call boundary yet).
export function mapIsSetExpr(exprIx: i32, fnIx: i32) {
  mapShapeOfExpr(exprIx, fnIx) == -2
}

// The mv SLOT a map READ expression resolves to: `m[k]` (Index over a ref-valued
// map) or `m.get(k)` (the method form), else -1. The chokepoint the expression-kind
// resolvers (`exprString` / struct resolution / `??` lowering) consult so a
// ref-valued `m[k] ?? d` classifies as its VALUE type.
function mapReadMvSlot(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return -1 }
  const e = P.nodes[exprIx]
  if e is Index {
    if exprMap(e.idxArr, fnIx) {
      const sl = mapShapeOfExpr(e.idxArr, fnIx)
      if sl >= 0 { return sl }
    }
    return -1
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "get" {
        if exprMap(callee.memObj, fnIx) {
          const sl = mapShapeOfExpr(callee.memObj, fnIx)
          if sl >= 0 { return sl }
        }
      }
    }
  }
  -1
}

// The mv slot of a `lhs ?? d` READ-WITH-DEFAULT over a ref-valued map, else -1. Parens are peeled on
// BOTH the whole expression and the LHS so a `(m[k]) ?? d` classifies its VALUE type identically to
// the bare form — the classifier must agree with the `??` emit (which also peels parens), else a
// parenthesized string/f64/struct map-get is emitted as its real type but the print/coerce routing
// defaults it to i32 (invalid wasm).
function coalesceMvSlot(exprIx: i32, fnIx: i32) {
  const e = P.nodes[unwrapParen(exprIx)]
  if e is BinExpr {
    if e.binOp == "??" { return mapReadMvSlot(unwrapParen(e.binLeft), fnIx) }
  }
  -1
}

// The list-element rep (2/7/12/20 — see `mvListValKind`) of a bare `m[k]` or `m[k] ?? d`
// read over a list-VALUED map, else -1. The single classifier hook each `expr*Array` uses to
// claim a list-valued-map read of its own element type.
function mapReadListKind(exprIx: i32, fnIx: i32): VKind | null {
  const cm = coalesceMvSlot(exprIx, fnIx)
  if cm >= 0 { return mvListValKind(cm) }
  return mvListValKind(mapReadMvSlot(exprIx, fnIx))
}

// The map RECEIVER arena index of a `for v in m.keys()` / `m.values()` iterable, or -1
// when the iterable is not a map keys/values walk. Drives the tombstone-aware skip in
// the for-in loop (the map's `live` array is consulted per entry).
export function forInMapRecv(iterIx: i32, fnIx: i32) {
  const e = P.nodes[iterIx]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "keys" || callee.memProp == "values" {
        if exprMap(callee.memObj, fnIx) { return callee.memObj }
      }
    }
  }
  // A bare map iterable (`for k in m`) IS its own receiver — the live-skip walks it.
  if exprMap(iterIx, fnIx) { return iterIx }
  -1
}

export function fnRetNullBearing(fnIx: i32) {
  const fn = P.nodes[fnIx]
  if !(fn is FuncDecl) { return false }
  const r = fn.fnRet
  if tyIsNulBool(r) { return true }
  if retNulStringFlag(r) == 1 { return true }
  if retNulRefFlag(r) == 1 { return true }
  if retNulListFlag(r) == 1 { return true }
  if retNulMapFlag(r) == 1 { return true }
  if retUnionFlag(r) == 1 { return unionHasAtom(tyNameOf(r), "null") }
  if r < 0 {
    const im = inferRetNameOf(fn.fnName)
    if isValueUnionName(im) { return unionHasAtom(im, "null") }
    if inferNicheNullByName(fn.fnName) != "" { return true }
  }
  false
}

// True if the statement at `stmtIx` is a BARE VALUE EXPRESSION usable as an IMPLICIT
// RETURN — a VL function whose last statement is an expression (no `return` keyword)
// yields that expression's value (the idiom every `ast.vl` constructor uses:
// `addNode(n)` / `out` as the final line). Recognized: literals, an identifier, a
// unary, a non-assignment `BinExpr`, a paren, a member / index access, an `is` guard,
// an object / array literal, and a value-returning CALL (`f(..)` whose callee is an
// Ident — NOT a `recv.push(x)` member-call, which is void). A `LetDecl`/`RetStmt`/
// `IfStmt`/`WhileStmt`/assignment/`.push` is a STATEMENT, not a tail value, so it is
// lowered normally by `emitStmt`.
export function stmtIsTailValue(stmtIx: i32, fnIx: i32) {
  const s = P.nodes[stmtIx]
  // A bare lambda tail `(a) => (b) => …` is an implicit-return VALUE (a closure), so the
  // outer arrow's body — `(b) => …` — emits as the function's result. Without this the tail
  // is mis-read as a statement, the body emits nothing, and the function is just `unreachable`.
  if s is FuncDecl { return true }
  if s is NumLit { return true }
  // A trailing `null` IS an implicit-return value (the function returns null) — seeded
  // per the return type by `emitReturnValue` (`ref.null` / sentinel / boxed null), the
  // same as `return null`. Without this a `{ … null }` tail fell through to the
  // statement path and failed `unsupported statement in body`.
  if s is NullLit { return true }
  if s is StrLit { return true }
  if s is CharLit { return true }
  if s is BoolLit { return true }
  if s is Ident { return true }
  if s is Unary { return true }
  if s is Paren { return true }
  if s is Member { return true }
  if s is Index { return true }
  if s is IsExpr { return true }
  if s is AsExpr { return true }
  if s is ObjLit { return true }
  if s is ArrayLit { return true }
  if s is BinExpr {
    if s.binOp == "=" {
      // A trailing assignment over an IDENT target IS a tail value — assignment
      // yields its RHS (DECISIONS: assignment-as-expression), so
      // `function bump() { count = count + 1 }` returns the new count. Index/
      // Member-target assignments stay statements (value form not lowered yet).
      const tgt = P.nodes[s.binLeft]
      if tgt is Ident { return true }
      return false
    }
    return true
  }
  if s is Call {
    // A value-returning call `f(..)` is a tail value; a `recv.push(x)` member-call,
    // a `print(...)`, and a call to a VOID function (`fRetVoid`) are statements.
    const callee = P.nodes[s.callFn]
    if callee is Ident {
      if callee.identName == "print" { return false }
      // The void memory intrinsics are statements, never tail values.
      if callee.identName == "__store_i32__" { return false }
      if callee.identName == "__log__" { return false }
      // The void array intrinsics likewise: `__array_copy__` yields nothing;
      // `__trap__` diverges (no value).
      if callee.identName == "__array_copy__" { return false }
      if callee.identName == "__trap__" { return false }
      const target = fnIndexOf(callee.identName)
      if target >= 0 { return fRetVoid[target] == 0 }
      // A CLOSURE-VALUE callee (a `() => void` param / a void-function binding, invisible
      // to `fnIndexOf`): a void one (`>v` sig) yields nothing, so it is a STATEMENT tail,
      // not a value — the signal that makes `run(g: () => void) { g() }` infer void.
      if fnIx >= 0 && calleeReturnsVoid(callee.identName, fnIx) { return false }
      return true
    }
    return false
  }
  false
}

// True if the BLOCK at `blockIx` ends in a bare tail VALUE statement (an implicit
// return), as opposed to an explicit `return`/`while`/etc. — i.e. lowering it in tail
// position would need `emitStmtTail`. A nested `if`/`else` tail recurses (any arm).
export function blockTailIsValue(blockIx: i32, fnIx: i32) {
  const b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    const n = stmts.length
    if n == 0 { return false }
    const last = stmts[n - 1]
    const s = P.nodes[last]
    if s is IfStmt { return ifTailIsValue(last, fnIx) }
    return stmtIsTailValue(last, fnIx)
  }
  false
}

// True if the `if`/`else` at `stmtIx` (in tail position) has any arm that ends in a
// bare value expression rather than an explicit `return` — so it must be lowered via
// `emitIfTail`. An `if` WITHOUT an `else` can fall through with no value, so it never
// qualifies (the existing void-if path handles it). Recurses through `else if` chains.
function ifTailIsValue(stmtIx: i32, fnIx: i32) {
  const s = P.nodes[stmtIx]
  if s is IfStmt {
    // An else-less `if` NEVER qualifies here (it can fall through with no value). This is
    // load-bearing: `ifTailIsValue` feeds `blockTailIsValue` → the `fRetVoid` fixpoint in
    // `buildFnMap`, where treating a void procedure's recursive tail `if n>0 { rec(n-1) }`
    // as a value would wrongly keep it non-void. The else-less NULLABLE-return tail
    // (`function f(c) { if c then 5 }` → `i32 | null`) is handled separately at emit time
    // by `elseLessNullableTail` (gated on the FINAL nullable classification).
    if s.ifElse < 0 { return false }
    if blockTailIsValue(s.ifThen, fnIx) { return true }
    const els = P.nodes[s.ifElse]
    if els is Block { return blockTailIsValue(s.ifElse, fnIx) }
    return ifTailIsValue(s.ifElse, fnIx)
  }
  false
}

// True if the statement at `stmtIx` is a body-tail `if`/`else` whose arms yield a
// value (implicit return) and so must be lowered tail-aware by `emitIfTail`.
export function lastStmtIsValueIf(stmtIx: i32, fnIx: i32) {
  const s = P.nodes[stmtIx]
  if s is IfStmt { return ifTailIsValue(stmtIx, fnIx) }
  false
}

// True if the body-tail statement at `stmtIx` is an ELSE-LESS `if` whose then-arm yields
// a value AND function `fnIx` returns a NULLABLE type — so the false fall-through is the
// `null` of that nullable (lowered by the function-end `emitNullForRet`), exactly the
// #484 fall-through but written `if c then v` with no else. Distinct from
// `lastStmtIsValueIf`: this is consulted only at EMIT time, where `fRetVoid` is final, so
// it never perturbs the `fRetVoid` fixpoint (a void procedure's `if n>0 { rec(n-1) }`
// stays void — `fnRetNullBearing` is false for it).
export function elseLessNullableTail(stmtIx: i32, fnIx: i32) {
  const s = P.nodes[stmtIx]
  if s is IfStmt {
    if s.ifElse >= 0 { return false }
    if !blockTailIsValue(s.ifThen, fnIx) { return false }
    return fnRetNullBearing(fnIx)
  }
  false
}

// True if the function's TOP-LEVEL body block at `blockIx` ends in an instruction
// that the wasm validator treats as making the function's fallthrough UNREACHABLE —
// i.e. its last statement is an explicit `return` (`RetStmt`) or a bare tail value
// (lowered by `emitFuncBody` as `emitExpr` + `return`). In those cases the function's
// trailing `end` is reached only via the polymorphic post-`return` stack, so no
// padding is needed. Otherwise (the body ends in an `if`/`while`/assignment/`.push`
// whose own `return`s exit from INSIDE a structured block) control structurally falls
// through to `end` with an empty stack — which fails the result-type check unless an
// explicit `unreachable` precedes the `end`. The typechecker has already proven such
// a fallthrough is dynamically dead (every path returns), so the `unreachable` is
// sound padding, never executed.
export function bodyEndsInReturn(blockIx: i32, fnIx: i32) {
  const b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    const n = stmts.length
    if n == 0 { return false }
    const last = stmts[n - 1]
    const s = P.nodes[last]
    if s is RetStmt { return true }
    return stmtIsTailValue(last, fnIx)
  }
  false
}

// The per-function mv frame base for mv slot `slot` (valid when `fnUsesMap`).
export function fnMvMapRefLocal(slot: i32) { fnMvBase + slot * 3 }

export function fnMvValsBkLocal(slot: i32) { fnMvBase + slot * 3 + 1 }

export function fnMvValStashLocal(slot: i32) { fnMvBase + slot * 3 + 2 }

// The `m.values()` per-mv-slot OUTPUT backing local for mv slot `slot`.
export function fnMvValsOutLocal(slot: i32) { mvValsOutBase + slot }

// The result list REP-kind of a `m.values()` call — `2` i32-list, `7` string-list, `12`
// f64-list, `20` i64-list, `5` ref-list (struct / nested-list / nested-map values) — or -1
// if `exprIx` is not a `.values()` over a map. The result element type IS the map's value
// type, so each `expr*Array` classifier compares against its own rep.
function mapValuesResultKind(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return -1 }
  const e = P.nodes[exprIx]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "values" {
        if exprMap(callee.memObj, fnIx) {
          const sh = mapShapeOfExpr(callee.memObj, fnIx)
          if sh == -1 {
            return 2 // mono i32 map → i32 list
          }
          if sh == -2 {
            return 7 // a Set's values() ARE its string keys
          }
          if sh >= 0 {
            const vk = mvValKind[sh]
            if vk == 3 {
              return 7 // string-valued → string list
            }
            if vk == 11 {
              return 12 // f64-valued → f64 list
            }
            if vk == 10 {
              return 20 // i64-valued → i64 list
            }
            return 5 // struct / nested-list / nested-map → ref list
          }
        }
      }
    }
  }
  -1
}

// The fnStmts POSITION of the FuncDecl at arena index `fnIx`, or -1.
export function fnStmtsPosOf(fnIx: i32) {
  let i = 0
  while i < fnStmts.length {
    if fnStmts[i] == fnIx { return i }
    i = i + 1
  }
  // A monomorphized slot was REPLACED in place (a count-0 instance overwrote `fnStmts[fe]`), so the
  // ORIGINAL node — a lambda literal a binding still points at — is no longer found by the scan
  // above. `monoOrigNode[fe]` still records it, so recover the slot from there. (Pure fallback: a
  // non-replaced slot is found above; a non-function node matches neither and stays -1.)
  let j = 0
  while j < monoOrigNode.length {
    if monoOrigNode[j] == fnIx { return j }
    j = j + 1
  }
  -1
}

// The struct table index a type NAME names: a declared struct name directly, or an
// INLINE object-shape name (`{x:i32,y:i32}`) matched by field-name SET against the
// interned shapes (the anonymous literals interned the same sets). -1 if neither.
export function structIndexOfTypeName(name: string) {
  const si = structIndexByName(name)
  if si >= 0 { return si }
  // Only a SINGLE shape spanning the WHOLE name is a bare struct — a composite (`{…}|null`,
  // `{…}|{…}`, `{…}[]`) is not, so its first `{`'s matching `}` must be the LAST char. Without this
  // guard a nullable-struct name (`{x:i32}|null`) mis-matches its LEADING shape as the bare struct,
  // silently masking the `| null` (e.g. `annRetKind` would key a nullable result `>s` instead of
  // `>n`, breaking a nullable-returning closure value call).
  let spanOk = false
  if name.length >= 2 && name[0] == '{' && name[1] != '[' {
    let d0 = 0
    let closeAt = -1
    let q = 0
    while q < name.length {
      const cc = name[q]
      if cc == '{' {
        d0 = d0 + 1
      } else if cc == '}' {
        d0 = d0 - 1
        if d0 == 0 && closeAt < 0 { closeAt = q }
      }
      q = q + 1
    }
    if closeAt == name.length - 1 { spanOk = true }
  }
  if spanOk {
    // Collect the top-level field NAMES + TYPE texts (`shapeFieldParse` — the
    // variant resolver's grammar: depth-aware over `{}` `[]` `()`, spaces
    // stripped so the canonical and spaced renders parse the same), then match
    // by field-name set TIGHTENED with the field-TYPE layout guard
    // (`shapeFieldTypeCompat`, the `variantIndexOfTypeName` discipline): two
    // shapes sharing field names but differing in a field's TYPE must not
    // collide onto the wrong slot — structural identity alone is not layout
    // identity.
    const fnames: string[] = []
    const ftypes: string[] = []
    shapeFieldParse(name, fnames, ftypes)
    let si2 = 0
    while si2 < sNames.length {
      if sFieldCount[si2] == fnames.length {
        let ok = true
        let k = 0
        while k < fnames.length {
          const fj = sFieldIndex(si2, fnames[k])
          if fj < 0 {
            ok = false
          } else if (
            !shapeFieldTypeCompat(
              ftypes[k],
              sFieldTypeAt(si2, fj),
              sFieldElemNameAt(si2, fj),
            )
          ) {
            ok = false
          }
          k = k + 1
        }
        if ok { return si2 }
      }
      si2 = si2 + 1
    }
  }
  -1
}

// The union-VARIANT table index whose field-set matches a `{meow: i32}` SHAPE name (a
// collapsed `.map` callback return the checker rendered structurally) — the variant
// analogue of `structIndexOfTypeName`. -1 if no variant matches. A NAME that is already a
// variant alias resolves directly. Field-name parsing mirrors `structIndexOfTypeName`.
// Parse a canonical inline SHAPE name `{a:T,b:U}` into PARALLEL field-name / field-type
// string lists (appended to `outNames` / `outTypes`). Depth-aware over `{}` `[]` AND `()`
// so a nested struct / list / closure field type is captured whole (a closure type carries
// its own `,` between params and `:`-free `=>`). Spaces are stripped so both the canonical
// (`tyToEmitName`) and spaced (`tyToStr`) renders parse the same. A non-`{…}` name appends
// nothing. Shared by the variant / struct field-set resolvers so a field-NAME match can be
// tightened with a field-TYPE (`nameFieldCode`) check — two shapes sharing field names but
// differing in a field's TYPE (`{a:i32,f:i64,z:f64}` vs a union arm
// `{a:boolean,f:()=>{…},z:i32}`) no longer collide onto the wrong slot.
function shapeFieldParse(name: string, outNames: string[], outTypes: string[]) {
  if name.length >= 2 && name[0] == '{' && name[1] != '[' {
    let curN = ""
    let curT = ""
    let depth = 0
    let collecting = true // true: reading the field NAME; false: reading its TYPE
    let i = 1
    while i < name.length - 1 {
      const c = name[i]
      if c == '{' || c == '[' || c == '(' {
        depth = depth + 1
        if !collecting { curT = curT + fromCodePoint(c) }
      } else if c == '}' || c == ']' || c == ')' {
        depth = depth - 1
        if !collecting { curT = curT + fromCodePoint(c) }
      } else if depth == 0 && c == ':' && collecting {
        collecting = false
      } else if depth == 0 && c == ',' {
        outNames.push(curN)
        outTypes.push(curT)
        curN = ""
        curT = ""
        collecting = true
      } else if c != ' ' {
        if collecting {
          curN = curN + fromCodePoint(c)
        } else {
          curT = curT + fromCodePoint(c)
        }
      }
      i = i + 1
    }
    outNames.push(curN)
    outTypes.push(curT)
  }
}

// True if two map VALUE type-names denote the SAME map rep — the code-19 tightening the
// field-set matchers apply (every map field shares code 19, so the code alone cannot
// separate an i32-valued from a string-valued map field: two shapes sharing field names
// but differing in a map field's VALUE collided onto the wrong slot — invalid wasm at the
// construct). Kind-classified through `mvValKindOfName` (the interner's own classifier):
//   · either side unclassifiable (-3) — LENIENT (never a false reject);
//   · a checker RENDER collapses a litunion alias value to `string` (`tyToEmitName`
//     widens member literals), so a string-vs-declared-alias pair is the SAME map seen
//     through two vocabularies — lenient;
//   · otherwise kinds must agree, and slot-bearing values must share the canonical rep
//     (`mvCanonRepOf` — the `variantFieldLayoutEq` code-19 discipline).
function mvValNamesCompat(va: string, ve: string): boolean {
  const ka = mvValKindOfName(va)
  const ke = mvValKindOfName(ve)
  if ka == -3 || ke == -3 { return true }
  if ka != ke {
    if ka == 3 && ke == -1 && nameIsLitUnionType(ve) { return true }
    if ke == 3 && ka == -1 && nameIsLitUnionType(va) { return true }
    return false
  }
  const sa = mvSlotOfMapValNameOrMono(va)
  const se = mvSlotOfMapValNameOrMono(ve)
  if sa >= 0 && se >= 0 { return mvCanonRepOf(sa) == mvCanonRepOf(se) }
  true
}

// True if a shape field TYPE-string `t` (from `shapeFieldParse`) is compatible with the
// emitter field CODE `code` — i.e. NOT a proven mismatch. A definitive mismatch (both codes
// known and unequal, e.g. i64 `23` vs closure `14`) is the field-name-collision signal.
// When the type-string cannot be classified (`nameFieldCode` -1, e.g. an inline nested
// struct `{…}`) the check stays LENIENT (true), preserving the legacy name-only match for
// shapes the code layer can't render — never a false REJECT of a real twin. A MAP field
// (code 19) is additionally tightened by its VALUE rep (`mvValNamesCompat` against the
// slot's recorded `elem` name) — the code alone is value-blind.
function shapeFieldTypeCompat(t: string, code: i32, elem: string): boolean {
  const want = nameFieldCode(t)
  if want < 0 || code < 0 {
    // A NESTED-STRUCT candidate field (code 15) whose spelled type `nameFieldCode`
    // cannot classify is (almost always) an INLINE nested shape — tighten by the
    // canonical structural key so two unions' arms sharing a field-name set but
    // differing in the nested layout (`{f: {f: f32}} | X` vs `{f: {f: i64}} | Y` in
    // one program) do not collide onto the first arm's variant (invalid wasm at the
    // construct — the code-19 lesson applied to code 15). PROVEN mismatches only:
    // either side unresolvable through the checker stays lenient.
    if code == 15 && elem != "" {
      let tb = t
      const tnb = nullablePartOf(tb)
      if tnb != "" { tb = tnb }
      return nestedStructNamesCompat(tb, elem)
    }
    return true
  }
  if want != code {
    // The AMBIGUOUS nullable-closure render: a code-22 field (`f: (() => i64) | null`)
    // RENDERS ungrouped (`()=>i64|null` — the checker drops a union member's grouping
    // parens), which `nameFieldCode` reads as a top-level arrow (code 14) returning a
    // nullable. The grouped and ungrouped spellings render identically, so the text alone
    // cannot refute the 22 layout — stay LENIENT (not a proven mismatch) when the arrow's
    // RESULT carries a depth-0 `| null` tail. A genuine closure field with a non-nullable
    // result (`f: () => i64`) keeps the proven-mismatch reject.
    if code == 22 && want == 14 {
      const aa = annArrowAt(t)
      if aa >= 0 && nullablePartOf(t.slice(aa + 2, t.length)) != "" {
        return true
      }
    }
    return false
  }
  if want == 19 && elem != "" { return mvValNamesCompat(mapValNameOf(t), elem) }
  if want == 15 && elem != "" {
    // A DECLARED-name nested-struct field (`inner: Inner`) against the variant's
    // recorded target: the same canonical-key tightening as the inline spelling.
    let tb15 = t
    const tnb15 = nullablePartOf(tb15)
    if tnb15 != "" { tb15 = tnb15 }
    return nestedStructNamesCompat(tb15, elem)
  }
  true
}

// True unless the two nested-struct TYPE spellings `ta` / `elem` are PROVEN to denote
// distinct structures: both resolve through the checker's canonical structural key
// (`repNameCanonKey`, the variant/map slot-layer vocabulary) and the keys differ.
// Either side unresolvable ("" key) stays lenient — never a false reject of a twin
// the canon layer does not cover.
function nestedStructNamesCompat(ta: string, elem: string): boolean {
  if ta == elem { return true }
  const ka = repNameCanonKey(ta)
  if ka == "" { return true }
  const ke = repNameCanonKey(elem)
  if ke == "" { return true }
  ka == ke
}

function variantIndexOfTypeName(name: string) {
  const direct = variantIndexOf(name)
  if direct >= 0 { return direct }
  if name.length >= 2 && name[0] == '{' && name[1] != '[' {
    const fnames: string[] = []
    const ftypes: string[] = []
    shapeFieldParse(name, fnames, ftypes)
    let vi = 0
    while vi < uVariants.length {
      if uFieldCount[vi] == fnames.length {
        let ok = true
        let k = 0
        while k < fnames.length {
          const fj = variantFieldIndex(vi, fnames[k])
          if fj < 0 {
            ok = false
          } else if (
            !shapeFieldTypeCompat(
              ftypes[k],
              variantFieldTypeAt(vi, fj),
              variantFieldElemName(vi, fj),
            )
          ) {
            // A shared field NAME but a mismatched field TYPE — a distinct shape that
            // merely collides on names (a closure returning `{a:i32,f:i64,z:f64}` is NOT
            // the union arm `{a:boolean,f:()=>…,z:i32}`). Not this variant.
            ok = false
          }
          k = k + 1
        }
        if ok { return vi }
      }
      vi = vi + 1
    }
  }
  -1
}

// The union-VARIANT index a lifted callback `fe` returns when it COLLAPSES to a single
// variant (`(a) => if a is Cat { a } else { catShape }`), read from the checker's recorded
// node-keyed return shape, or -1. Lets `.map`/`.filter` classify the result as the variant
// ref list (the checker types it `Cat[]`, but the emitter's syntactic union inference would
// otherwise widen the narrowed receiver to the box).
export function cbRetVariantIdx(fe: i32) {
  if fe < 0 || fe >= fnStmts.length { return -1 }
  return variantIndexOfTypeName(inferRetNameByNode(fnStmts[fe]))
}

// The RETURN-type NAME of a function-VALUE callee `name` (in scope of `fnIx`): the return
// part of its source function-type annotation — a closure-typed PARAM of the enclosing
// function, a closure-typed LOCAL/GLOBAL binding, or a union arm narrowed to a bare closure.
// "" when `name` is not a resolvable closure value or its annotation is not a `(…) => R`
// arrow. Lets the niche-nullable classifiers recognize `p()` where `p: () => boolean | null`
// (a closure-param call `fnIndexOf` can't see) as the niche its RETURN type declares — the
// resolved `$fnsig` key can't (a `boolean|null` niche rides `>i`, same as a plain `boolean`).
export function calleeCloRetName(name: string, fnIx: i32) {
  let ft = ""
  // A union binding narrowed to a bare-closure arm carries the arm's `(…) => R` name.
  const nc = narrowedClosureOf(name)
  if nc != "" {
    ft = nc
  } else if fnIx >= 0 {
    // A closure-typed PARAM of the enclosing function.
    const fn = P.nodes[fnIx]
    if fn is FuncDecl {
      const params = fn.fnParams
      let i = 0
      while i < params.length {
        const p = P.nodes[params[i]]
        if p is Param {
          if p.parName == name {
            const pn = tyNameOf(p.parType)
            if annArrowAt(pn) >= 0 { ft = pn }
          }
        }
        i = i + 1
      }
    }
  }
  // A closure-typed LOCAL / GLOBAL binding annotation.
  if ft == "" { ft = identFnTypeAnnName(name, fnIx) }
  const at = annArrowAt(ft)
  if at < 0 { return "" }
  return ft.slice(at + 2, ft.length)
}

// True if the expression is a NAME (param / local / module global) annotated
// `boolean|null` — the niche scalar nullable.
export function exprNulBool(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  // Typed-IR fast path (additive — only turns false into true, mirroring `exprIsBool`):
  // the checker recorded this node's type as `boolean | null`. Recovers the niche for a
  // form the syntactic arms below can't trace — a `(boolean | null)[]` element read
  // `p[i]`, or an inferred `const t = p[i]` bound to it — so its `!= null` compares
  // against the sentinel 2 rather than emitting a bare null.
  if nodeTyIsNulBool(exprIx) { return true }
  const e = P.nodes[unwrapParen(exprIx)]
  // A CALL of a function annotated `: boolean | null` — its result is the niche i32.
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const t = fnIndexOf(callee.identName)
      if t >= 0 {
        const cfn = P.nodes[fnStmts[t]]
        if cfn is FuncDecl {
          if tyIsNulBool(cfn.fnRet) { return true }
          // ...or an UN-ANNOTATED function whose return INFERS to `boolean | null`.
          if cfn.fnRet < 0 {
            if inferNicheNullByName(callee.identName) == "boolean|null" {
              return true
            }
          }
          return false
        }
      }
      // A call of a closure-typed VALUE (`p()` where `p: () => boolean | null`) — a
      // param / local / global `fnIndexOf` can't see: read its return-type annotation.
      if nameIsNulBool(calleeCloRetName(callee.identName, fnIx)) { return true }
    }
    return false
  }
  if e is Ident {
    if fnIx >= 0 {
      const fn = P.nodes[fnIx]
      if fn is FuncDecl {
        const params = fn.fnParams
        let i = 0
        while i < params.length {
          const p = P.nodes[params[i]]
          if p is Param {
            if p.parName == e.identName { return tyIsNulBool(p.parType) }
          }
          i = i + 1
        }
        const li = parentLetOf(fn.fnBody, e.identName)
        if li >= 0 { return letNulBool(li, fnIx) }
      }
    }
    const gi = globalLetOf(e.identName)
    if gi >= 0 { return letNulBool(gi, -1) }
    return false
  }
  // A `boolean | null` struct FIELD read (`a.v`, code 21) is the niche i32 sentinel.
  if e is Member { return memberFieldCode(exprIx, fnIx) == 21 }
  // A chained `a ?? b` over `boolean | null` is itself `boolean | null` when the default
  // `b` is also nullable — the left-associative `(f() ?? g()) ?? d` shape (see the
  // `exprNullableString` companion). Keeps `??` print-routing consistent with the rep.
  if e is BinExpr {
    if e.binOp == "??" {
      if exprNulBool(e.binLeft, fnIx) { return exprNulBool(e.binRight, fnIx) }
    }
  }
  false
}

// A `let`/`const` binding is `boolean | null` if it is so ANNOTATED, or (un-annotated)
// its initializer is a `boolean | null` value — e.g. `const r = f()` where `f` returns
// the niche. Mirrors `letUnionNameOf`'s annotation-or-init resolution for value unions.
export function letNulBool(letIx: i32, fnIx: i32) {
  if letIx < 0 { return false }
  if letIsNulBoolAnn(letIx) { return true }
  // An un-annotated `const x = if c then true else null` infers `boolean | null` (a
  // niche the emitter can't statically derive from the if-expr arms). The CHECKER
  // typed it and exported the binding by node index; consult that before the init probe.
  if isInferLetNulBool(letIx) { return true }
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType < 0 { return exprNulBool(d.letInit, fnIx) }
  }
  false
}

// True if `exprIx` is a `K | null` NICHE value (the i32 atom with the spare `-1` = null) — a
// `K|null`-annotated param / local / global, or a call of a `K|null`-returning function. The
// litunion dual of `exprNulBool`; consulted at the `== null` compare and the `null`-seed boundaries.
export function exprNulLitUnion(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[unwrapParen(exprIx)]
  // A `(K | null)[]` element READ `p[i]` — the niche i32 (a member id or the `-1` null sentinel).
  // Recovered from the array's element type so an inferred `const t = p[i]` and a direct `p[i] !=
  // null` narrow against `-1` rather than emitting a bare null. Scoped to an Index whose receiver is
  // the litunion-niche list (NOT the broad node-type probe, which `exprIsLitAtom` consumes and would
  // over-widen the construction path).
  if e is Index {
    if nodeArrayElemIsNulLitUnion(e.idxArr) { return true }
  }
  // A fused `m[k] ?? d` read over a NULLABLE-atom-valued map (`{[string]: K | null}`) yields
  // the `K | null` niche i32 (a member id or the `-1` sentinel — a stored null is preserved),
  // so an un-annotated `const t = m[k] ?? d` binds the niche and narrows with `!= null`.
  if e is BinExpr {
    if e.binOp == "??" {
      const nbl = P.nodes[unwrapParen(e.binLeft)]
      if nbl is Index {
        if nodeTyMapValIsNulLitUnion(nbl.idxArr) { return true }
      }
    }
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const t = fnIndexOf(callee.identName)
      if t >= 0 {
        const cfn = P.nodes[fnStmts[t]]
        if cfn is FuncDecl {
          if cfn.fnRet >= 0 { return nodeTyIsNulLitUnion(cfn.fnRet) }
        }
      }
      // A call of a closure-typed VALUE (`p()` where `p: () => K | null`) — a param /
      // local / global whose `K | null` niche return `fnIndexOf` can't see.
      if nameIsNulLitUnion(calleeCloRetName(callee.identName, fnIx)) {
        return true
      }
    }
    // An INDEXED closure-array call (`p[i]()` where `p: (() => K | null)[]`): the element's
    // closure result is the `K | null` niche. `cloArrSlotRetName` reads it off the ref-list slot,
    // the indexed dual of the Ident `calleeCloRetName` above — so `const t0 = p[i]()` binds the
    // kind-0 litunion niche (an i32) instead of mis-inferring the softened `string | null` ref.
    if callee is Index {
      if exprRefArray(callee.idxArr, fnIx) {
        const rn = cloArrSlotRetName(refListSlotOfExpr(callee.idxArr, fnIx))
        if nameIsNulLitUnion(rn) { return true }
      }
    }
    return false
  }
  if e is Ident {
    if fnIx >= 0 {
      const fn = P.nodes[fnIx]
      if fn is FuncDecl {
        const params = fn.fnParams
        let i = 0
        while i < params.length {
          const p = P.nodes[params[i]]
          if p is Param {
            if p.parName == e.identName {
              return nodeTyIsNulLitUnion(p.parType)
            }
          }
          i = i + 1
        }
        const li = parentLetOf(fn.fnBody, e.identName)
        if li >= 0 { return letNulLitUnion(li, fnIx) }
      }
    }
    const gi = globalLetOf(e.identName)
    if gi >= 0 { return letNulLitUnion(gi, -1) }
    return false
  }
  // A `K | null` struct FIELD read (`a.f`, code 30) is the niche i32 with the `-1`
  // sentinel — the litunion dual of `exprNulBool`'s Member arm. Covers the plain
  // struct receiver AND the `is`-narrowed variant receiver (`memberFieldCode`
  // resolves both), so an inferred `const t0 = v.f` binds the niche and its
  // `!= null` narrows against `-1`.
  if e is Member { return memberFieldCode(exprIx, fnIx) == 30 }
  false
}

// A `let`/`const` binding is `K | null` if it is so ANNOTATED, or (un-annotated) its initializer is
// a `K | null` value. The litunion dual of `letNulBool`.
export function letNulLitUnion(letIx: i32, fnIx: i32) {
  if letIx < 0 { return false }
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 { return nodeTyIsNulLitUnion(d.letType) }
    return exprNulLitUnion(d.letInit, fnIx)
  }
  false
}

// True if `name` resolves (param / local / module global) to a BOOLEAN binding:
// either a `: boolean`/`: bool` annotation, or an un-annotated `const`/`let` whose
// initializer is itself boolean. A boolean local registers as kind 0 (== i32), so
// bool-ness must be recovered from the binding here, not the local registry.
function boundBoolByName(name: string, fnIx: i32) {
  if fnIx >= 0 {
    const fn = P.nodes[fnIx]
    if fn is FuncDecl {
      const params = fn.fnParams
      let i = 0
      while i < params.length {
        const p = P.nodes[params[i]]
        if p is Param {
          if p.parName == name { return tyIsBool(p.parType) }
        }
        i = i + 1
      }
      const li = parentLetOf(fn.fnBody, name)
      if li >= 0 {
        const d = P.nodes[li]
        if d is LetDecl {
          if d.letType >= 0 { return tyIsBool(d.letType) }
          return exprIsBool(d.letInit, fnIx)
        }
      }
    }
  }
  const gi = globalLetOf(name)
  if gi >= 0 {
    const g = P.nodes[gi]
    if g is LetDecl {
      if g.letType >= 0 { return tyIsBool(g.letType) }
      return exprIsBool(g.letInit, -1)
    }
  }
  false
}

export function retNulRefFlag(tyIx: i32) {
  if tyIx >= 0 {
    // STRUCTURAL fast-path (C1): the checker recorded this node's type as a nullable declared
    // struct (`S | null`). Confirms only; `string | null` and everything else fall to the name path.
    if nodeTyIsNulStruct(tyIx) { return 1 }
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      const base = nullablePartOf(ty.tyName)
      // `string` is the raw i32 array, NOT a struct — `string | null` is the kind-16
      // nullable-string ref (`retNulStringFlag`), never a nullable struct. Exclude it
      // here so it isn't mis-claimed as kind 9 (which would read the box as a struct).
      if base == "string" { return 0 }
      if base != "" {
        if structIndexOfTypeName(base) >= 0 { return 1 }
      }
    }
  }
  0
}

// The base struct table index of a `S | null` annotation at `tyIx`, or -1.
export function retNulRefIndex(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      const base = nullablePartOf(ty.tyName)
      if base != "" { return structIndexOfTypeName(base) }
    }
  }
  -1
}

// `1` if the type-annotation node at `tyIx` names the struct, else `0` (i32 / none).
// Used for functype param/result valtypes and the `"struct"` return kind. Returning the
// flag (not pushing bytes) keeps each call free of a `0→1` local reassignment, which
// pins a `let x = 0` to the literal `0` type and fails to typecheck.
export function retTRFlag(tyIx: i32) {
  if tyIx >= 0 {
    // STRUCTURAL fast-path (C1): the checker recorded this node's type as a declared struct —
    // confirm directly, skipping the O(nodes) `nameIsStructDecl` scan `isSName` walks. Only
    // CONFIRMS (never denies), so anything it doesn't cover falls to the name test below.
    if nodeTyIsStruct(tyIx) { return 1 }
    return 0
  }
  0
}

// The struct table index named by the type-annotation node at `tyIx`, or -1 if it
// names no declared struct.
export function retStructIndex(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      const si = structIndexByName(ty.tyName)
      if si >= 0 { return si }
      // A union-variant name carries its VARIANT index here (consumed by `pushVT`'s
      // `kind == 8` variant-struct case); not a standalone struct, so it is -1 above.
      const vi = variantIndexOf(ty.tyName)
      if vi >= 0 { return vi }
      // A `S | null` annotation resolves to its BASE struct's index — the single
      // chokepoint the param/local/return struct lookups read, so a nullable-struct
      // binding's member layout resolves without separate plumbing.
      const base = nullablePartOf(ty.tyName)
      if base != "" { return structIndexOfTypeName(base) }
      return -1
    }
  }
  -1
}

// The `pendingListKind` a type-annotation node at `tyIx` names (1 = struct/MAP ref list,
// 2 = union box ref list, 3 = string list), or 0 when it is not a list annotation. Shared
// by the let / return / call-arg / global seeding so each position threads the SAME
// annotation-derived list context into `emitArr` (so a non-empty `B[]` literal in a return
// or argument position builds B's list, not the first-element field-shape guess). A
// `LetDecl`-specific wrapper (`letAnnRefListKind`) forwards its `letType` here.
export function tyAnnRefListKind(tyIx: i32) {
  if tyIx >= 0 {
    const lt = P.nodes[tyIx]
    if lt is TypeRef {
      // A NULLABLE ref-array annotation (`S[] | null`, kind 18) threads the same kind as its non-null ref
      // array, so the value literal builds the list (a value-union inner -> kind 2 boxes its bare scalars).
      let rln = lt.tyName
      const rnp = nullablePartOf(rln)
      if rnp != "" && nameIsRefArray(rnp) { rln = rnp }
      if nameIsRefArray(rln) {
        if refArrElemKind(rln) == 2 { return 2 }
        // A closure-element ref list (`((i32) => i32)[]`, kind 5) threads kind 5 so
        // `emitArr` builds the closure backing (not a struct-shape guess).
        if refArrElemKind(rln) == 5 { return 5 }
        return 1
      }
      if nameIsStringArray(lt.tyName) { return 3 }
      // A `(boolean | null)[]` annotation (kind 8): an i32-backed list whose elements
      // carry the boolean sentinel niche (`null → 2`). Threads so an all-`null` `[null]`
      // (which self-infers as `null[]`) builds the i32 wrapper and seeds `pendingNulBool`
      // for its elements. Checked before the scalar-array arms (it is an i32 list).
      if nameIsNulBoolList(lt.tyName) { return 8 }
      // A `(K | null)[]` annotation (kind 9): an i32-backed atom list whose elements carry the
      // litunion sentinel niche (`null → -1`, a member literal → its id). Threads so an all-`null`
      // `[null]` (which self-infers as `null[]`) builds the i32 wrapper and seeds `pendingNulLitUnion`
      // + `pendingLitUnion` for its elements. Checked before the scalar-array arms (it is an i32 list).
      if nameIsNulLitUnionList(lt.tyName) { return 9 }
      // An `f64[]` annotation: an empty `[]` builds the f64-list wrapper (kind 4).
      if nameIsF64Array(lt.tyName) { return 4 }
      // An `i64[]` annotation: an empty `[]` builds the i64-list wrapper (kind 6).
      if nameIsI64Array(lt.tyName) { return 6 }
      // An `f32[]` annotation (kind 7): threads even for a NON-empty literal, since a bare
      // `[1.5]` does not self-identify as f32 (it defaults to f64).
      if nameIsF32Array(lt.tyName) { return 7 }
    }
  }
  0
}

// The ref-list TABLE SLOT a type-annotation node at `tyIx` names (`Tok[]` → the `Tok`
// slot), or 0 when it is not a ref-array annotation. Mirror of `tyAnnRefListKind` for the
// slot; threads `pendingListSlot` so a ref-list literal builds the annotation's distinct
// element type.
export function tyAnnRefListSlot(tyIx: i32) {
  if tyIx >= 0 {
    const lt = P.nodes[tyIx]
    if lt is TypeRef {
      let rln = lt.tyName
      const rnp = nullablePartOf(rln)
      if rnp != "" && nameIsRefArray(rnp) { rln = rnp }
      if nameIsRefArray(rln) {
        const s = rlSlotByName(refArrElemName(rln))
        if s >= 0 { return s }
      }
    }
  }
  0
}

// `1` if the type-annotation node at `tyIx` is a REF array (`S[]`/`N[]`), else `0`.
// Feeds the `kind == 5` (ref list) branch of `pushVT`.
export function retRefArrFlag(tyIx: i32) {
  if tyIx >= 0 {
    // STRUCTURAL fast-path (C1): the checker recorded this node as an array of a declared struct
    // (`S[]`) — the clean base case of `nameIsRefArray`, without the O(nodes) name scan its bare
    // element match walks. Confirms only; nested / union / niche ref arrays fall to the name path.
    if nodeTyIsStructArray(tyIx) { return 1 }
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      if nameIsRefArray(ty.tyName) { return 1 }
    }
  }
  0
}

// `1` if the type-annotation node at `tyIx` is a NULLABLE ref array (`<ref-array> | null` — e.g.
// `S[] | null`, `((i32) => f64)[] | null`, `i32[][] | null`), else `0`. The value/composite-position
// analogue of the local ladder's `letIsNulRefArray` (kind 18, `"nulreflist"`): a `(ref null $wrapper)`
// slot over the inner ref-list's element wrapper — null is `ref.null $wrapper`, a non-null list value
// subtypes it. Feeds the `"nulreflist"` arm of `vtKindOfType`, so a nullable ref-list crosses a
// RETURN / PARAM / GLOBAL boundary with the SAME sound rep the local already gives it (was: `nameIsRefArray`
// misses the `| null` suffix and the classifier fell through to `"i32"` → an `(ref …)` value in an i32
// slot, INVALID-WASM). The inner-slot resolution is `tyAnnRefListSlot` (already `| null`-aware). A
// value-union-ELEMENT inner (`(i32|null)[] | null`) is excluded implicitly — `nameIsRefArray` returns 0
// for it — so it keeps failing loudly rather than mis-riding this niche.
export function retNulRefArrFlag(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      const np = nullablePartOf(ty.tyName)
      if np != "" && nameIsRefArray(np) { return 1 }
    }
  }
  0
}

// The folded LIST-rep code of a function RETURN annotation `tyIx`: `2` i32-list, `5`
// ref-list, `7` string-list, `12` f64-list, or `0` (not a list). The four `nameIs*Array`
// predicates are mutually exclusive by name, so the priority order is immaterial. Feeds
// the list arms of `retAnnKindChain` (was `retArrFlag`/`retRefArrFlag`/`retStrArrFlag`/
// `retF64ArrFlag` into four parallel boolean tables).
export function retListKindFlag(tyIx: i32) {
  if retArrFlag(tyIx) == 1 { return 2 }
  if retRefArrFlag(tyIx) == 1 { return 5 }
  if retStrArrFlag(tyIx) == 1 { return 7 }
  if retF64ArrFlag(tyIx) == 1 { return 12 }
  0
}

// The ref-list element type-NAME of a function RETURN type node `tyIx` (an `S[]`/`N[]`),
// or "". Populates `fRetRArrElem`.
export function retRefArrElemName(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      if nameIsRefArray(ty.tyName) { return refArrElemName(ty.tyName) }
    }
  }
  ""
}

// C1 endgame: an emitter-SYNTHESIZED type-annotation node (a mono clone, an inferred-list synthesis,
// a contextual return/param pin). Records the CONCRETE type on the new node so the structural
// classifiers cover it (unresolvable emitter-internal names record -1 = same as uncovered). See
// `recordClonedNodeTy`. Every synthesis site routes through here so coverage stays uniform.
export function synthTypeRef(name: string, pos: i32) {
  const n = mkTypeRef(name, pos)
  recordClonedNodeTy(n, name)
  n
}

// The nullable-scalar-list VKind of a DISTINCT-backing nullable list type name (`string[] | null`,
// `f64[] | null`, `i64[] | null`, `f32[] | null`), or "" for anything else. Each leaf has its OWN
// wrapper heap type, so — unlike the i32-backed `nameIsNulI32List` fold — each is a genuinely
// distinct `(ref null $wrapper)` cell. A bare `= null` init lowers as `ref.null $wrapper`; a list
// value stores its (non-null) wrapper ref, which subtypes the nullable slot.
export function nulScalarListKind(name: string): VKind | null {
  const b = nullablePartOf(name)
  if nameIsStringArray(b) { return "nulstrlist" }
  if nameIsF64Array(b) { return "nulf64list" }
  if nameIsI64Array(b) { return "nuli64list" }
  if nameIsF32Array(b) { return "nulf32list" }
  null
}
// The nullable-scalar-list VKind of annotation node `tyIx`, or `null`.
export function nulScalarListKindOfNode(tyIx: i32): VKind | null {
  if tyIx < 0 { return null }
  const ty = P.nodes[tyIx]
  if ty is TypeRef { return nulScalarListKind(ty.tyName) }
  null
}
// The `emitArr` list-build code (`pendingListKind` / `ExpCtx.listKind`) a nullable-scalar-list
// value's list literal builds with: strlist 3 · f64list 4 · i64list 6 · f32list 7 (the leaf-list
// build codes), or 0 if `kind` is not a nullable scalar list.
export function nulScalarListBuildKind(kind: VKind | null): i32 {
  if kind == "nulstrlist" { return 3 }
  if kind == "nulf64list" { return 4 }
  if kind == "nuli64list" { return 6 }
  if kind == "nulf32list" { return 7 }
  0
}
// True if `kind` is one of the four distinct-backing nullable-scalar-list VKinds.
export function isNulScalarListKind(kind: VKind | null): boolean {
  if kind == null { return false }
  kind == "nulstrlist" ||
    kind == "nulf64list" ||
    kind == "nuli64list" ||
    kind == "nulf32list"
}

export function vtKindOfType(tyIx: i32): VKind {
  // repOf-FIRST (the strangler seam, roadmap Next#1): where the checker's arena covers the
  // annotation's shape, the descriptor (`emit_rep.vl`) decides the kind — ONE structural
  // derivation instead of this ladder re-testing name arms. Since rep-rewrite Stage B wave 1
  // the descriptor's kind is itself the recursive Rep TREE's projection (`repOfTy` is
  // tree-primary), so this delegation reads the tree wherever the flat arms claim coverage.
  // The ladder below remains the fallback for the uncovered remainder (typed-value maps,
  // union-element lists, nested arrays, nullable lists beyond `i32[] | null`, …) and shrinks
  // as coverage widens.
  const rd = repOfNode(tyIx)
  if rd.rdCovered == 1 { return rd.rdKind }
  // A literal-union annotation (`type K = "a" | "b"`) is an i32-backed interned atom (`"i32"`), NOT
  // a value-union box — checked first (it IS a `TyUnion`, so `retUnionFlag` would claim it).
  if tyIx >= 0 {
    if P.nodes[tyIx] is TypeRef {
      if nodeTyIsLitUnionAlias(tyIx) { return "i32" }
    }
  }
  // A NULLABLE literal-union (`K | null`) is the SAME i32 atom (`"i32"`), with the spare value `-1`
  // encoding `null` (no box). Checked before the `string | null` niche (`"nulstr"`) — `canonEmitName`
  // preserves the litunion members, but a defensive position keeps it ahead of any base-collapse.
  if tyIx >= 0 {
    if P.nodes[tyIx] is TypeRef {
      if nodeTyIsNulLitUnion(tyIx) { return "i32" }
    }
  }
  // A NULLABLE function `(fn) | null` is the closure fat-pointer made nullable, `"nulclosure"` —
  // checked BEFORE `tyIsFuncType` (whose `=>` test would otherwise claim it as the non-null
  // `"closure"`). The non-null part is a function, but the `| null` makes the slot nullable.
  if nulCloFlag(tyIx) == 1 { return "nulclosure" }
  // An ARRAY OF FUNCTIONS (`((i32) => i32)[]`) is a closure-element REF LIST (`"reflist"`),
  // NOT a single closure — checked BEFORE `tyIsFuncType`, whose `=>` substring test would
  // otherwise claim the whole array as `"closure"`. The element arrow is NESTED; a TOP-LEVEL
  // arrow with a trailing `[]` (`(i32) => i32[]`, a function RETURNING a list) is a real
  // closure value and stays `"closure"` below.
  if nameIsClosureArrayTy(tyIx) == 1 { return "reflist" }
  // A function-typed annotation (a name carrying `=>` — incl. the synthetic
  // `"=>sigkey"` a monomorphized closure param is pinned with) is the closure
  // fat-pointer, `"closure"`. Checked first; no other name contains an arrow.
  if tyIsFuncType(tyIx) { return "closure" }
  // A string-keyed MAP annotation (`{[string]: V}`) is the map struct ref, `"map"` — checked
  // before the struct/object arms (an inline `{[…]:…}` is not a field-struct shape). Its
  // `fbValtype` arg is the map shape slot (mono i32 ⇒ -1, via `paramStructIdxOf`/`retStructIndex`).
  if retMapFlag(tyIx) == 1 { return "map" }
  // A NULLABLE string-keyed map (`{[string]: V} | null`) — the `(ref null $mapStruct)` niche
  // (`"nulmap"`), the map twin of `nulstruct`. AFTER `retMapFlag` (a bare map is never nullable);
  // disjoint from it anyway (a `| null` map name is a `nameIsMapMemberUnion`, which `retMapFlag`
  // excludes). Its shape arg is `mapAnnShape` (now `| null`-aware), resolving THIS map's `$mapStruct`.
  if retNulMapFlag(tyIx) == 1 { return "nulmap" }
  if retNulRefFlag(tyIx) == 1 { return "nulstruct" }
  if retNulStringFlag(tyIx) == 1 { return "nulstr" }
  if retNulListFlag(tyIx) == 1 { return "nullist" }
  // A NULLABLE ref array (`<ref-array> | null`) — the `(ref null $wrapper)` niche (kind 18,
  // `"nulreflist"`), the local ladder's rep hoisted to the value/composite positions. BEFORE
  // `retRefArrFlag` (whose non-null `"reflist"` slot cannot hold `null`) and the union arms (a
  // `T[] | null` reads as a union NAME). Disjoint from `retNulListFlag` above: an i32-backed
  // list (`i32[]|null`) is a `"nullist"`, a ref-element / nested list (`S[]|null`, `i32[][]|null`)
  // is a `"nulreflist"` — `nameIsRefArray` excludes the i32-list backing.
  if retNulRefArrFlag(tyIx) == 1 { return "nulreflist" }
  if retStrArrFlag(tyIx) == 1 { return "strlist" }
  if retF64ArrFlag(tyIx) == 1 { return "f64list" }
  if retI64ArrFlag(tyIx) == 1 { return "i64list" }
  if retF32ArrFlag(tyIx) == 1 { return "f32list" }
  if retRefArrFlag(tyIx) == 1 { return "reflist" }
  if retUnionFlag(tyIx) == 1 { return "union" }
  if retVariantFlag(tyIx) == 1 { return "variant" }
  if retTRFlag(tyIx) == 1 { return "struct" }
  if retArrFlag(tyIx) == 1 { return "list" }
  if retStrFlag(tyIx) == 1 { return "str" }
  if retI64Flag(tyIx) == 1 { return "i64" }
  if retF64Flag(tyIx) == 1 { return "f64" }
  if retF32Flag(tyIx) == 1 { return "f32" }
  "i32"
}

// `1` if the type-annotation node at `tyIx` is a string-keyed map (`{[string]: V}`), else `0`.
// Feeds the `kind == 6` (map struct ref) branch of `vtKindOfType`, so a map can be a param /
// return / functype valtype (the `(ref $mapStruct)` cell), not only a local.
export function retMapFlag(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      // A string-keyed map crosses a call boundary as kind 6 (`(ref $mapStruct)`). Its
      // `fbValtype` arg is the map SHAPE (`mapAnnShape`): -1 for the mono map, or the
      // per-value-type mv slot (the value type's interned `$mapStruct` carries across the
      // boundary). The gate is the SAME classifier the local path interns with
      // (`mvValKindOfName`) — every map value type that binds locally also crosses a
      // param/return boundary; anything outside it stays a loud rejection.
      // A map-member UNION (`{[string]: V} | X`) also STARTS with `{[`, so `nameIsMap` matches
      // the whole union name — but it is a union BOX, not a map. Guard so a struct FIELD (or any
      // `vtKindOfType` consumer) of a map-member-union type falls through to `retUnionFlag` and
      // rides the union box valtype, rather than mis-typing the field as a bare map struct. The
      // param/return paths already catch the union in an earlier branch; this guard makes the
      // classifier consistent everywhere. (The `nameIsMapMemberUnion` twin of the let/field guards.)
      if nameIsMap(ty.tyName) && !nameIsMapMemberUnion(ty.tyName) {
        if mvValKindOfName(mapValNameOf(ty.tyName)) != -3 { return 1 }
      }
    }
  }
  0
}

// The BARE (non-null) inner map name of a `{[string]: V} | null` type-name — the `nullablePartOf`
// (which peels an EXACT `X | null`), when that part is a bare map. "" for anything that is not a
// nullable map (a plain map, a genuine map-member union `{[..]}|X`, a 3-way `{[..]}|X|null`). The
// single chokepoint every `nulmap` classifier strips through, so `mapValNameOf`/`mvValKindOfName`/
// `mapAnnShape` see the inner `{[string]: V}` (never the garbled `boolean}|null` a raw `mapValNameOf`
// of the `| null` name would slice).
export function nulMapInnerName(name: string) {
  const np = nullablePartOf(name)
  if np != "" && nameIsMap(np) && !nameIsMapMemberUnion(np) { return np }
  ""
}
// `1` if the type-annotation node at `tyIx` is a NULLABLE string-keyed map (`{[string]: V} | null`),
// else `0`. The map analogue of `retNulRefFlag`/`retNulRefArrFlag`: a `(ref null $mapStruct)` niche —
// null is `ref.null $mapStruct`, a non-null map value subtypes it (the `struct → nulstruct` relation
// hoisted to the map struct). Gated to the SAME supported value kinds as the non-null `retMapFlag`
// (`mvValKindOfName(mapValNameOf(inner)) != -3`), so a nullable map over an unrepresentable value type
// keeps failing loudly rather than mis-riding this niche. Feeds the `"nulmap"` arm of `vtKindOfType`.
export function retNulMapFlag(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      const inner = nulMapInnerName(ty.tyName)
      if inner != "" {
        if mvValKindOfName(mapValNameOf(inner)) != -3 { return 1 }
      }
    }
  }
  0
}

// The map SHAPE (`fbValtype`/`mapTypeIdxOf` second arg) of a string-keyed map type annotation:
// -1 for the mono i32/boolean map (rides the shared `$mapStruct`), or the value type's interned
// mv slot for a `string`-valued map. A non-map / un-interned value type yields -1 (the mono
// shape) — safe, since `retMapFlag` only lets the supported value types reach kind 6. Shared by
// the param valtype (`paramStructIdxOf`), the return valtype, and the body shape resolution
// (`mapShapeOfExpr`) so all three agree on which `$mapStruct` a map param/return is.
export function mapAnnShape(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      // A NULLABLE map annotation (`{[string]: V} | null`) resolves its shape from the BARE inner
      // map — its `(ref null $mapStruct)` cell selects the SAME `$mapStruct` its non-null twin does.
      let mn = ty.tyName
      const nim = nulMapInnerName(mn)
      if nim != "" { mn = nim }
      if nameIsMap(mn) {
        const vn = mapValNameOf(mn)
        if vn == "i32" || vn == "boolean" { return -1 }
        let i = 0
        while i < mvValName.length {
          if mvValName[i] == vn { return i }
          i = i + 1
        }
      }
    }
  }
  -1
}

// The map SHAPE of the map PARAM `name` of function `fnIx` (its annotation's value type),
// or -1. Lets `mapShapeOfExpr` resolve a map param's VALUE type instead of assuming mono i32.
function paramMapShape(fnIx: i32, name: string) {
  if fnIx < 0 { return -1 }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    const params = fn.fnParams
    let i = 0
    while i < params.length {
      const p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name { return mapAnnShape(p.parType) }
      }
      i = i + 1
    }
  }
  -1
}

// The map SHAPE a function `name` RETURNS (its return annotation's value type), or -1 (the mono
// map / an un-annotated return whose shape is not annotation-derived). Lets a caller resolve the
// VALUE type of `mk()[k]` over a `string`-valued map factory.
function fnRetMapShape(name: string) {
  const fe = fnIndexOf(name)
  if fe >= 0 {
    const fn = P.nodes[fnStmts[fe]]
    if fn is FuncDecl {
      if fn.fnRet >= 0 { return mapAnnShape(fn.fnRet) }
      // An UN-annotated map return (`function passthru(m) { return m }`): derive the shape from
      // the returned expression (a map param/local/`Map()`), so a caller of a `string`-valued
      // map factory resolves the value type.
      const rx = fnRetExprOf(fnStmts[fe])
      if rx >= 0 { return mapRetExprShape(rx, fnStmts[fe]) }
    }
  }
  -1
}

// `1` if the type-annotation node at `tyIx` names a union VARIANT struct (e.g. `TyObj`
// of `Ty`), else `0`. Feeds the `kind == 8` (concrete variant struct ref) branch of
// `pushVT`. A variant-struct param/result is the unboxed variant ref directly — gap #2.
export function retVariantFlag(tyIx: i32) {
  if tyIx >= 0 {
    // STRUCTURAL fast-path (C1): the checker recorded this node's type as a union-variant member.
    if nodeTyIsVariant(tyIx) { return 1 }
    return 0
  }
  0
}

// `1` if the type-annotation node at `tyIx` names the declared union alias, else `0`.
// Feeds the `kind == 4` (union box) branch of `pushVT`.
export function retUnionFlag(tyIx: i32) {
  if tyIx >= 0 {
    // STRUCTURAL fast-path (C1): the checker recorded this node's type as a declared value-union box.
    if nodeTyIsUnionAlias(tyIx) { return 1 }
    return 0
  }
  0
}

// The `pushVT` `VKind` for a parameter node at `paramIx` (`"struct"`, `"list"`,
// `"str"`, `"i32"`, …) — its annotation's `vtKindOfType`, or `"i32"` for a node
// that is not a `Param`.
export function vtKindOfParam(paramIx: i32): VKind {
  const p = P.nodes[paramIx]
  if p is Param { return vtKindOfType(p.parType) }
  "i32"
}

// The second `fbValtype` arg for the parameter node at `paramIx` (from its annotation).
// For a STRUCT param (kind 1) this is its struct table index (or -1); for a REF-ARRAY
// param (kind 5) it is the ref-list TABLE SLOT for the element type (`B[]` → B's slot)
// — `fbValtype`'s kind-5 arm now indexes `rlWrapIdx[slot]`, so it must NOT collapse to
// -1/slot 0. Mirrors `tyAnnRefListSlot` (how `let`/return annotations resolve `T[]`).
export function paramStructIdxOf(paramIx: i32) {
  const p = P.nodes[paramIx]
  if p is Param {
    if retRefArrFlag(p.parType) == 1 { return tyAnnRefListSlot(p.parType) }
    // A NULLABLE ref-array param (kind 18) — its `(ref null $wrapper)` slot is the inner ref-list
    // element wrapper (`tyAnnRefListSlot` is `| null`-aware), mirroring the non-null ref-array above.
    if retNulRefArrFlag(p.parType) == 1 { return tyAnnRefListSlot(p.parType) }
    // A string-keyed MAP param's second `fbValtype` arg is the map SHAPE (mono ⇒ -1, or the
    // value type's mv slot for a `string`-valued map), so the param valtype selects THIS map's
    // `$mapStruct`.
    if retMapFlag(p.parType) == 1 { return mapAnnShape(p.parType) }
    // A NULLABLE map param (`{[string]: V} | null`, kind `nulmap`) — the SAME map SHAPE selects its
    // `(ref null $mapStruct)` cell's heap type (`mapAnnShape` is `| null`-aware).
    if retNulMapFlag(p.parType) == 1 { return mapAnnShape(p.parType) }
    // A concrete-VARIANT param (kind 8) — its `fbValtype` slot is the VARIANT index
    // (`uVarHeap[vi]`), which `retStructIndex` (standalone structs) misses.
    if retVariantFlag(p.parType) == 1 {
      const ptv = P.nodes[p.parType]
      if ptv is TypeRef { return variantIndexOf(ptv.tyName) }
    }
    return retStructIndex(p.parType)
  }
  -1
}

// The `pushVT` `kind` for a module global from its literal INITIALIZER at `initIx`:
// `1` struct ref (object literal), `2` list ref (array literal), `3` string ref (string
// literal), else `0` i32. The global's valtype must match the init's wasm type so the
// constexpr validates; the literal cases are the only ones in scope (a non-literal init
// fails loudly when `emitExpr` lowers it as a constexpr with `fnIx = -1`).
function globalKind(initIx: i32): VKind {
  if initIx < 0 { return "i32" }
  const e = P.nodes[initIx]
  // A function-literal init (`const add = function(...)...`) — or a bare reference to a
  // top-level function name in value position — is a closure fat-pointer cell (kind 14).
  if e is FuncDecl { return "closure" }
  if e is Ident {
    if fnIndexOf(e.identName) >= 0 { return "closure" }
  }
  // An un-annotated float `.` literal init (`const a = 1.5`) is an f64 cell (kind 11),
  // lowered as `f64.const`. (Slice 3 — additive; bare integer globals stay kind 0.)
  if e is NumLit {
    if numTextIsFloat(e.numText) { return "f64" }
  }
  if e is ObjLit {
    // A literal matching a standalone struct is that struct ref (kind 1) — even in a
    // union program. Otherwise, in a union program it boxes into the union (kind 4).
    if structIndexOfObj(initIx) >= 0 { return "struct" }
    if uDeclared { return "union" }
    return "struct"
  }
  if e is ArrayLit {
    // A ref-element array literal is a ref list (kind 5); a STRING-element literal
    // is the string list (kind 7); an f64-element literal is the f64 list (kind 12,
    // Slice 4); an i32/empty literal is the i32 list (kind 2). A module-global empty
    // `[]` over a ref type is out of scope (a global ref-list constexpr needs the
    // binding annotation — deferred).
    if arrLitIsRef(initIx) { return "reflist" }
    if arrLitIsStr(initIx, -1) { return "strlist" }
    if arrLitIsF64(initIx, -1) { return "f64list" }
    if arrLitIsI64(initIx, -1) { return "i64list" }
    return "list"
  }
  if e is StrLit { return "str" }
  // A NON-LITERAL initializer (a concat `"a" + "b"`, a `fromCodePoint(...)` or
  // user-function call, a reference to another global): classify via the expression
  // family with no enclosing function (`fnIx = -1`) — the same predicates the local
  // `letIs*` ladder uses. The cell zero-inits (`ref.null` via the non-const path)
  // and the start function `global.set`s the computed value. An i32-producing
  // expression matches none of these and stays kind 0 — programs without ref-typed
  // global expressions emit byte-identical bytes.
  // A non-literal init that evaluates to a function value — a call returning a closure
  // (`const f = makeAdder(5)`) or a member read of a function-valued field (`const h =
  // o.go`) — is a closure fat-pointer cell (kind 14). Checked FIRST among the
  // expression-family cases (it never overlaps the others, and only fires in a program
  // that uses function values, so non-closure globals stay byte-identical).
  if exprIsClosure(initIx, -1) { return "closure" }
  if exprNullableStruct(initIx, -1) { return "nulstruct" }
  if exprMap(initIx, -1) { return "map" }
  if exprString(initIx, -1) { return "str" }
  if exprStringArray(initIx, -1) { return "strlist" }
  if exprRefArray(initIx, -1) { return "reflist" }
  if exprF64Array(initIx, -1) { return "f64list" }
  if exprI64Array(initIx, -1) { return "i64list" }
  if exprF32Array(initIx, -1) { return "f32list" }
  if exprUnion(initIx, -1) { return "union" }
  if exprStruct(initIx, -1) { return "struct" }
  if exprArray(initIx, -1) { return "list" }
  // A SCALAR f64 / i64 non-literal init (f64 / i64 ARITHMETIC `2.0 + 4.5`, or an
  // f64-returning call `dbl(2.0)`) — kind 11 / 10, the module-scope analogue of the local
  // `letIsF64` / `letIsI64` inference (which is gated to inside a function). A single
  // float literal already classifies above; this covers the COMPOSITE init. (`exprIsF64`
  // /`exprIsI64` may recurse into another global, terminating for an acyclic program — the
  // same shape the `exprString` / `exprStruct` cases above already rely on.)
  if exprIsF64(initIx, -1) { return "f64" }
  if exprIsI64(initIx, -1) { return "i64" }
  // A SCALAR f32 non-literal init (an f32 map-`??` read, f32 arithmetic, an f32-returning
  // call) — kind 13, the module-scope analogue of the local `letIsF32` inference. Without
  // this arm the cell stays i32 while the start-fn stores an f32 — invalid wasm.
  if exprIsF32(initIx, -1) { return "f32" }
  "i32"
}

// Whether the module global `name` has a non-const initializer — used at READ sites
// (`global.get`) to decide whether the (nullable) cell needs a `ref.as_non_null`.
export function globalNameIsNonConst(name: string) {
  globalIsNonConst(globalLetOf(name))
}

// The `fbValtype` kind for a module global's CELL. When the binding has a TYPE
// ANNOTATION (const init OR not), the kind is derived from that annotation via the
// `letIs*` ladder — so a global agrees with a same-typed local/param/field on its
// valtype (kind + struct index). Only an UN-annotated const global (`let g = { … }`,
// no `: T`) falls back to the literal-initializer kind (`globalKind`); the `g_globals`
// golden's struct global IS annotated, and its annotation names the SAME struct its
// literal infers, so the emitted bytes are unchanged. A non-const init's literal kind is
// meaningless (member/index/call), so it likewise rides the annotation ladder. Mirrors
// `buildLocals`' annotation→kind ladder (map 6, string-array 7, ref-array 5, struct 1,
// array 2, string 3, else i32 0).
export function globalCellKind(letIx: i32): VKind {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if globalHasTypeAnn(letIx) {
      // A NULLABLE-function global (`let g: ((i32) => i32) | null = inc`) is a nullable
      // closure cell (kind 19) — checked BEFORE the bare-function kind 14, mirroring
      // `vtKindOfType` / `fieldTypeCode`: `((i32) => i32) | null` is a nullable function,
      // whereas `(i32) => i32 | null` is a function returning a nullable.
      if nulCloFlag(d.letType) == 1 { return "nulclosure" }
      // A function-typed global (`const g: (i32) => i32 = inc`) is a closure fat-pointer
      // cell (kind 14), like a function-valued local.
      if tyIsFuncType(d.letType) { return "closure" }
      if letIsNulRef(letIx, -1) { return "nulstruct" }
      if letIsNulList(letIx, -1) { return "nullist" }
      // A DISTINCT-backing nullable scalar list global (`string[]|null`, `f64[]|null`,
      // `i64[]|null`, `f32[]|null`): its own `(ref null $wrapper)` cell — BEFORE the non-null
      // list arms (whose init fallback would else claim a bare list value as a non-null cell).
      const gNulSL = nulScalarListKindOfNode(d.letType)
      if gNulSL != null { return gNulSL }
      // A NULLABLE map global cell (`let g: {[string]: V} | null = …`, kind `nulmap`) — BEFORE
      // `letIsMap` (a nullable annotation/init must not collapse to the non-null `"map"` cell).
      if letIsNulMap(letIx, -1) { return "nulmap" }
      if letIsMap(letIx, -1) { return "map" }
      // A UNION-annotated global cell is the box ref (kind 4), exactly as `buildLocals`
      // classifies a union local — BEFORE the struct/string/scalar-list cases (a `string |
      // i32` / `f64[] | string` annotation is none of those, and a scalar-list INIT must not
      // claim the cell). `S | null` / `boolean | null` never register as union names (they
      // keep their niche kinds above).
      if letIsLitUnion(letIx) { return "i32" }
      if letIsLitUnion(letIx) { return "i32" }
      if letIsUnion(letIx, -1) { return "union" }
      if letIsStringArray(letIx, -1) { return "strlist" }
      if letIsRefArray(letIx, -1) { return "reflist" }
      if letIsF32Array(letIx, -1) { return "f32list" }
      if letIsF64Array(letIx, -1) { return "f64list" }
      if letIsI64Array(letIx, -1) { return "i64list" }
      if letIsStruct(letIx, -1) { return "struct" }
      if letIsArray(letIx, -1) { return "list" }
      if letIsNulString(letIx, -1) { return "nulstr" }
      if letIsString(letIx, -1) { return "str" }
      if letIsI64(letIx, -1) { return "i64" }
      if letIsF64(letIx, -1) { return "f64" }
      if letIsF32(letIx) { return "f32" }
      return "i32"
    }
    // No annotation: a const literal init types itself; a non-const un-annotated init is
    // out of scope (no annotation to derive from) and `globalKind` returns its best guess.
    // An empty `[]` whose PUSHES infer a string element is the string list (kind 7).
    if letInfStrListByUse(letIx) { return "strlist" }
    // An un-annotated global whose init PRODUCES a union (`const a = make(42)` with
    // a union-returning `make`) carries the box (kind 4), as a local would.
    if letIsUnion(letIx, -1) { return "union" }
    // An un-annotated global bound to a `string | null`-returning call (`const r = f()`)
    // carries the kind-16 nullable-string cell, as a local would.
    if letIsNulString(letIx, -1) { return "nulstr" }
    return globalKind(d.letInit)
  }
  "i32"
}

// The struct table index for a global cell of kind 1 (struct ref), else -1. When the
// binding has a struct ANNOTATION the index comes from THAT annotation (`structIndexOfLet`,
// which prefers the annotation over the init) — so a struct global agrees with a same-
// typed local/param/field. An un-annotated const struct global infers from its literal.
export function globalCellStructIdx(letIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if globalHasTypeAnn(letIx) { return structIndexOfLet(letIx, -1) }
    return structIndexOfExpr(d.letInit, -1)
  }
  -1
}

// The ref-list TABLE SLOT for a kind-5 (ref array) global cell: the annotation's
// element type when present, else the element type INFERRED from the initializer —
// so an un-annotated `const g = [[1,2]]` declares ITS OWN wrapper type, not slot 0's
// (two un-annotated ref-list globals of distinct element types would otherwise both
// declare the first's wrapper and fail validation). 0 (slot fallback) if unresolvable.
export function globalRefListSlot(letIx: i32) {
  const s = letRefListSlot(letIx, -1)
  if s < 0 { return 0 }
  s
}

// True if the type-name `name` refers to one of the declared struct types.
export function isSName(name: string) { structIndexByName(name) >= 0 }

// The struct-table index for a ref-list element NAME, stripping a `| null` niche suffix first
// (a NULLABLE-struct array's slot keys on the full `"P | null"`, but the struct it stores/reads
// is the bare `P`). Nominal first (`structIndexByName`), then the structural bridge
// (`structIndexOfTypeName`): an INLINE-SHAPE element spelling (`{v:i32}` of a `{v:i32}[]`
// param) that `collectAnnShapes` deduped onto its declared twin has no `sNames` entry of its
// own, so only the layout-guarded field-set match resolves it.
export function structIdxOfElemName(name: string) {
  let n = name
  const nn = nullablePartOf(name)
  if nn != "" { n = nn }
  structIndexOfTypeName(n)
}

// The non-null STRUCT name of a NULLABLE-struct array element (`(P | null)[]` → "P"), or "".
// `P | null` is a nullable-struct NICHE (a `(ref null $P)` slot), NOT a union box — so it is a
// struct ref-list whose elements legitimately hold null (its backing is already nullable). The
// SLOT keys on the full `"P | null"` so a read can tell it from a non-null `P[]` (different slot)
// and skip the `ref.as_non_null` recover. A value-niche element (`(i32 | null)[]`) is excluded —
// its non-null part is not a declared struct, so it stays the value-union-box path.
// The inner map of a `({[string]: V} | null)[]` nullable-MAP array element, else "".
function nullMapArrElemOf(name: string) {
  const elem = parenUnionArrElemName(name)
  if elem == "" { return "" }
  const nn = nullablePartOf(elem)
  if nn == "" { return "" }
  if nameIsMap(nn) && !nameIsMapMemberUnion(nn) { return nn }
  ""
}

function nullStructArrElem(name: string) {
  const elem = parenUnionArrElemName(name)
  if elem == "" { return "" }
  const nn = nullablePartOf(elem)
  if nn == "" { return "" }
  if structIndexByName(nn) >= 0 { return nn }
  ""
}

// The inner-list element of a `(<list> | null)[]` nullable-LIST array — `(i32[] | null)[]` → `i32[]`,
// else "". Such an array reuses the `i32[][]` (kind 4) rep: a ref list over a `(ref null $lTypeIdx)`
// backing (already nullable, so the `| null` element rides for free). It differs from `i32[][]` ONLY by
// its slot key keeping the `| null` (so the index READ stays nullable — no `ref.as_non_null` — for the
// `e != null` narrow). The inner array reuses its NON-nullable rep RECURSIVELY (kind 4 i32-list inner,
// a DISTINCT-backing scalar/string inner — kinds 6/7/8/10, `(f64[] | null)[]` over the `$fl64` wrapper
// singleton, the list-position dual of the `nulf64list` binding niche — or kind 9 a nested ref-array
// inner — `(i32[][]|null)[]`, `({f:i32}[]|null)[]`, …); the structured `rlElemNullable` bit drives the
// nullable read-skip + null-element generically over the inner kind.
function nullArrayArrElem(name: string) {
  const elem = parenUnionArrElemName(name)
  if elem == "" { return "" }
  const nn = nullablePartOf(elem)
  if nn == "" { return "" }
  if !nameIsArray(nn) { return "" }
  const ik = refArrElemKind(nn + "[]")
  if ik == 4 || ik == 6 || ik == 7 || ik == 8 || ik == 9 || ik == 10 {
    return nn
  }
  ""
}

// The DECLARED-struct index an inline-SHAPE element spelling (`{v:i32}` of a
// `{v:i32}[]` annotation) resolves to via the structural bridge
// (`structIndexOfTypeName`), or -1. GATED on a DECLARED twin
// (`nameIsStructDecl`): an inline spelling matching only an anonymous-literal /
// interned-shape slot keeps its legacy classification — admitting it would
// route a shape-armed union (`t is {f: boolean}[]` over an inferred closure-call
// binding) into the union-arm narrow machinery, whose read side still
// mis-lowers that flow (the pre-existing nominal `T[]`-arm hole), so the loud
// REJECT must hold until that path is fixed. A non-`{...}` base fast-rejects.
function shapeElemDeclaredStructIdx(base: string) {
  if base.length < 2 { return -1 }
  if base[0] != '{' || base[1] == '[' { return -1 }
  const si = structIndexOfTypeName(base)
  if si < 0 { return -1 }
  if nameIsStructDecl(sNames[si]) { return si }
  -1
}

// True if the array type-name `name` is a REF-element list — `S[]` over a declared
// struct, `N[]` over the declared union alias (the box-ref element), or `{[string]:i32}[]`
// (a map-struct element). Either lowers to the `{ backing: (ref $raTypeIdx), len, cap }`
// wrapper over a `(ref null $elem)` backing (G7-ref). A non-`[]` name or an `i32[]` is
// NOT a ref array. The element name is recovered by checking each declared struct/union
// name + `"[]"` (a `string + string` concat; a `string + i32` would be a type error).
export function nameIsRefArray(name: string) {
  // A TOP-LEVEL arrow is a FUNCTION TYPE (`(i32) => S[]` — a closure RETURNING an array), NEVER a
  // ref array, even though it ends in `[]`. Guarded first so a closure-returning-array LOCAL /
  // param / result is classified as the closure fat-pointer, not mis-picked as a ref-list rep (the
  // array-of-closures `((i32) => i32)[]` has its arrow NESTED, so `annArrowAt` — paren-aware —
  // returns -1 and that case still reaches `nameIsClosureArray` below).
  if annArrowAt(name) >= 0 { return false }
  // A literal-union array (`K[]`) is an i32 ATOM array, NOT a ref list — exclude it before the
  // union-name match below (a literal union registers as a union name, which would otherwise
  // mis-claim `K[]` as a union-box ref array, the wrong rep).
  if nameIsLitUnionArray(name) { return false }
  // A `(P | null)[]` nullable-struct array is a (struct) ref list — checked before the
  // value/struct-union element test so its niche element is not mis-read as a union box.
  if nullStructArrElem(name) != "" { return true }
  // A `(i32[] | null)[]` nullable-LIST array is a ref list (kind-4 i32[][] rep) — likewise checked
  // before the union test so `i32[] | null` is not mis-read as a value union.
  if nullArrayArrElem(name) != "" { return true }
  // A NESTED `i32[][]` (also `boolean[][]` / literal-union `K[][]`) is a ref list whose
  // elements are the i32-list wrapper (element kind 4) — the existing ref-pair machinery
  // serves it; only the element heap type differs (`lTypeIdx`). All three share the i32[]
  // backing (`nameIsI32ListArray`); `nameIsLitUnionArray` above already excluded the 1-D
  // atom array `K[]`, so this only fires on the 2-D case.
  if nameIsI32ListArray(name) { return true }
  // A nested NON-i32 scalar / string 2D array (`i64[][]` / `f64[][]` / `string[][]`): the
  // element is the inner list's WRAPPER (kinds 8 / 7 / 6 — the same the LIST-valued map vals
  // ref-list uses). `refArrElemKind` already maps these names; recognize them here so a direct
  // 2D array (not only a map value) is a supported ref list.
  if (
    name == "i64[][]" ||
    name == "f64[][]" ||
    name == "f32[][]" ||
    name == "string[][]"
  ) {
    return true
  }
  // An array whose ELEMENT is a string-backed list (`(string | null)[][]` — the string
  // niche list shares the `$mkListIdx` wrapper `string[]` uses, so the outer array is the
  // same kind-6 ref list as `string[][]`). `nameIsStringArray` admits both spellings.
  if nameIsArray(name) && nameIsStringArray(name.slice(0, name.length - 2)) {
    return true
  }
  // A NESTED REF array (`S[][]`, `(C|D)[][]`, `((i32)=>i32)[][]`, `S[][][]`, …): the element is
  // ITSELF a ref array. Recurses to the leaf (a struct / union / closure / scalar-2D ref array),
  // so any DEPTH and any ref leaf falls out — the outer element's heap is the inner list's
  // wrapper (`refArrElemKind` → 9), resolved through the recursively-interned inner slot.
  if nameIsArray(name) && nameIsRefArray(refArrElemName(name)) { return true }
  // A `(string|i32)[]` annotation — a VALUE-union element list. The element
  // slots hold the same `{tag, value}` boxes a bare union binding does (the
  // host stores the coerced union value), so it is a kind-2 ref list.
  if parenUnionArrElemName(name) != "" { return true }
  if nameIsMapArray(name) { return true }
  // An ARRAY OF FUNCTIONS (`((i32) => i32)[]`) — a closure-element ref list (kind 5).
  if nameIsClosureArray(name) { return true }
  // Otherwise a `<Struct>[]` / `<Union>[]`: strip the trailing `[]` ONCE and match the bare
  // element NAME against the struct/union tables. (The old form compared `name` to
  // `sNames[i] + "[]"` — a fresh string allocation PER struct PER call; on a struct-heavy
  // program this `O(structs)` garbage dominated emit time + GC. The strip-once form does the
  // same match with no per-iteration allocation.)
  const n = name.length
  if n >= 3 && name[n - 2] == '[' && name[n - 1] == ']' {
    const base = name.slice(0, n - 2)
    if structIndexByName(base) >= 0 { return true }
    // An INLINE-SHAPE element (`{v:i32}[]`) whose shape deduped onto a DECLARED
    // struct at intern time (so the spelling has no `sNames` entry): the
    // structural bridge resolves it — the shape-vs-declared twin of `S[]`.
    if shapeElemDeclaredStructIdx(base) >= 0 { return true }
    // A `Cat[]` over a concrete union VARIANT — a ref list of bare variant structs.
    if variantIndexOf(base) >= 0 { return true }
    let u = 0
    while u < unNames.length {
      if base == unNames[u] { return true }
      u = u + 1
    }
  }
  false
}

// The ref-element kind for an array type-name (assumes `nameIsRefArray(name)`):
// `1` = a struct element, `2` = a union-box element (`uBoxIdx`), `3` = a map-struct
// element (`mStructIdx`, the scope-chain `{[string]:i32}[]`).
// Intern the ref-list slot whose ELEMENT type is `elemName`, recursively interning a nested
// inner list's element slot FIRST — so the inner wrapper lands at a LOWER type index and the
// outer element heap (`rlElemHeap`, kind 9) resolves to it. The DRY core that makes arbitrary
// `X[]…[]` nesting of any ref leaf (struct / union / closure) fall out: interning is inner-first,
// recursively, bottoming out at the leaf array (whose element is not itself a ref array, k != 9).
export function ensureRefElem(elemName: string) {
  if elemName == "" { return -1 }
  // Re-form the element's ARRAY name to read its kind. A nullable-LIST element (`i32[] | null`) needs its
  // grouping parens back (`(elem)[]`) — without them `refArrElemKind` mis-reads `i32[] | null[]` as a
  // plain struct element (kind 1) instead of the kind-4 nullable-i32-list element. Scoped to a nullable
  // element whose non-null part is an ARRAY, so value-union (`i32 | null`) / nullable-struct (`P | null`)
  // elements keep their existing (munged-name) kind and are unaffected.
  let arrName = elemName + "[]"
  const enp = nullablePartOf(elemName)
  if (
    enp != "" &&
    (nameIsArray(enp) ||
      nameIsFuncTypeAtom(enp) ||
      (nameIsMap(enp) && !nameIsMapMemberUnion(enp)))
  ) {
    // A nullable-LIST element (`i32[] | null`), a nullable-CLOSURE element
    // (`((i32) => boolean) | null` — the kind-5 niche), and a nullable-MAP element
    // (`{[string]: V} | null`) all need their grouping parens back to read the kind.
    arrName = "(" + elemName + ")[]"
  } else if (
    parenUnionArrElemName("(" + elemName + ")[]") != "" &&
    (isValueUnionName(elemName) || nullablePartOf(elemName) == "")
  ) {
    // A VALUE-UNION / heterogeneous-union element (`f64 | {w: i32}`, `K0[] | {w: i32}`) — nested as the
    // element of an outer array (`(f64 | {w: i32})[] | null` reached via the kind-9 recursion below, or a
    // bare `(f64 | {w: i32})[]`) — likewise needs its grouping parens back: without them `elemName + "[]"`
    // is `f64 | {w: i32}[]`, which `refArrElemKind` mis-splits (paren-blind) into a plain struct element
    // (kind 1) instead of the kind-2 union box, so the reflist wrapper backs `{w: i32}` refs and the raw
    // f64 arm stores into a ref slot (INVALID-WASM). `parenUnionArrElemName` recognizes exactly the
    // top-level-`|` element that needs grouping (it carries the arrow guard, so a closure element is left
    // alone), and the wrapped `(elem)[]` is identical to the nullable-array branch above. The soundness
    // gate `isValueUnionName(elemName) || nullablePartOf(elemName) == ""` mirrors `collectA`'s reject at the
    // top-level nullable-ref-array path: a NICHE-nullable-scalar element (`string | null`, `boolean | null`)
    // has NO union-box rep (its `| null` is a niche, not a tag), so it must NOT be wrapped into a kind-2
    // element here — leaving it un-grouped keeps its existing (kind-1) classification and its clean REJECT,
    // rather than silently interning an unsound box (INVALID-WASM). A value union with null (`i32 | null`)
    // and any null-free heterogeneous union (`f64 | {w: i32}`, `K0[] | {w: i32}`) box soundly and wrap.

    arrName = "(" + elemName + ")[]"
  }
  const k = refArrElemKind(arrName)
  if k == 9 { ensureRefElem(refArrElemName(elemName)) }
  // A MAP element (`{[string]: V}[]`, kind 3): force the map heap types + intern the element
  // map's VALUE mv slot, so a TYPED-value map in a COMPOSITION position (a list element, a
  // struct field, a nested-map value) resolves the SAME per-value map struct a standalone
  // `{[string]: V}` binding does — position-independent. A mono / atom value interns nothing
  // (`mvShapeOfValName` returns -1), riding the shared mono `$mapStruct`.
  if k == 3 {
    mUsed = true
    lUsed = true
    aUsed = true
    // A NULLABLE map element strips to its inner map for the value intern — the slot
    // shares the map struct (and mv slot) with the non-null element.
    let mve = elemName
    const nme = nulMapInnerName(elemName)
    if nme != "" { mve = nme }
    mvShapeOfValName(mapValNameOf(mve))
  }
  // Force the leaf list-type wrapper `Used` flags for a SCALAR inner-list element, so its
  // singleton wrapper (`lTypeIdx` / `mkListIdx` / `fl64TypeIdx` / `il64TypeIdx`) is allocated. A
  // ref inner list (k 9) forces these in the recursion above; a struct / union / closure element
  // (k 1/2/5) needs none. Lets BOTH the array path and the map-value path share this one helper.
  if k == 4 {
    lUsed = true
    aUsed = true
  } else if k == 6 {
    slUsed = true
    aUsed = true
  } else if k == 7 {
    fa64Used = true
  } else if k == 8 {
    ia64Used = true
  } else if k == 10 {
    fa32Used = true
  }
  rlInternName(elemName, k)
}

export function refArrElemKind(name: string) {
  // `i32[][]`, `boolean[][]`, and literal-union `K[][]` all carry the i32-list wrapper element
  // (kind 4) — one i32[] backing (`nameIsI32ListArray`), not three special cases.
  if nameIsI32ListArray(name) { return 4 }
  // Nested lists of a NON-i32 scalar/string element — the element is that inner list's
  // WRAPPER (kinds 6/7/8 → `mkListIdx` / `fl64TypeIdx` / `il64TypeIdx`). Used for a
  // string[]/f64[]/i64[]-VALUED map's vals ref-list (the value analogue of `i32[][]` kind 4).
  if nameIsArray(name) && nameIsStringArray(name.slice(0, name.length - 2)) {
    // `string[][]` AND the niche `(string | null)[][]`: the element is the string-list
    // wrapper (`$mkListIdx`) either way — the nullable rides INSIDE the inner elements.
    return 6
  }
  if name == "f64[][]" { return 7 }
  if name == "i64[][]" { return 8 }
  if name == "f32[][]" {
    return 10 // f32 inner list (element is the `$fl32TypeIdx` wrapper)
  }
  // A NESTED REF array (`S[][]`, `(C|D)[][]`, `((i32)=>i32)[][]`, `S[][][]`, …): the element is
  // itself a ref array, stored as the inner list's WRAPPER — kind 9. Recurses to any depth via
  // the interned inner slots. The scalar-leaf 2D names above are NOT ref arrays at the inner
  // level (a scalar inner list is a singleton wrapper), so they keep their explicit kinds.
  if nameIsArray(name) && nameIsRefArray(refArrElemName(name)) { return 9 }
  if nameIsMapArray(name) { return 3 }
  // A `(P | null)[]` nullable-struct array is a STRUCT ref list (kind 1) — its element is a
  // `(ref null $P)` niche, not a union box. Checked before the value-union test below.
  if nullStructArrElem(name) != "" { return 1 }
  // A `({[string]: V} | null)[]` nullable-MAP array is a MAP ref list (kind 3) — the same
  // `(ref null $mapStruct)` backing the non-null map element uses; the slot key keeps the
  // `| null` so the index read stays nullable (`rlElemNullable`) for the `e != null` narrow.
  if nullMapArrElemOf(name) != "" { return 3 }
  // A `(i32[] | null)[]` nullable-LIST array is the i32[][] rep (kind 4) — its element is a
  // `(ref null $lTypeIdx)` i32-list niche, not a union box. Checked before the value-union test.
  if nullArrayArrElem(name) != "" {
    return refArrElemKind(nullArrayArrElem(name) + "[]")
  }
  // A `(((i32) => boolean) | null)[]` nullable-CLOSURE array is a closure ref list (kind 5)
  // — its element is a `(ref null $cloStruct)` niche, not a union box. Checked before the
  // value-union test below (whose kind-2 box has no rep for a niche-nullable closure).
  if nullClosureArrElem(name) != "" { return 5 }
  // A `(string|i32)[]` value-union element list is a union-box list (kind 2).
  if parenUnionArrElemName(name) != "" { return 2 }
  // An `((i32) => i32)[]` array of functions is a closure-element list (kind 5).
  if nameIsClosureArray(name) { return 5 }
  // A `<Union>[]` element list is kind 2 — strip the `[]` once and match the bare union name
  // (no per-iteration `+ "[]"` concat). Anything else (a struct array) is kind 1.
  const n = name.length
  if n >= 3 && name[n - 2] == '[' && name[n - 1] == ']' {
    const base = name.slice(0, n - 2)
    let u = 0
    while u < unNames.length {
      if base == unNames[u] { return 2 }
      u = u + 1
    }
  }
  1
}

// The per-field wasm-type code for a struct / union-variant field whose type node is
// `tyIx` (a `TypeRef`). Mirrors the inline classifier `collectS`/`collectVariantFields`
// used to use, EXTENDED with array-typed fields (gap #5): a field of array type stores a
// REF to a list wrapper, so its code records WHICH wrapper:
//   `0` = i32 / boolean   (`0x7f`)
//   `3` = string          (`(ref $aTypeIdx)`)
//   `4` = i32 list  `i32[]`         (`(ref $lTypeIdx)`)
//   `5` = ref list  `T[]` / `N[]`   (`(ref $rlTypeIdx)`)
// An `X[]` whose element `X` is not `i32` is a REF list (`5`) — its element is a struct
// or the union box; the element-kind (`rElemKind`) is fixed globally by `collectA`, so it
// is not stored per-field. An unsupported field type yields `-1` (caller fails loudly).
// (`string[]` is NOT yet supported — it would need a string-ref list distinct from the
// struct/union ref backing — so it falls through to `-1`.)
// Force the backing+wrapper type pair for a SCALAR-LIST field code (25 = f64[], 26 = i64[], 27 = f32[]),
// so the wrapper heap type exists whenever a struct/inline-shape field uses it — the field analogue of a
// ref-list field forcing `rlUsed`. A scalar-list LOCAL forces this via its annotation scan; a field-only
// program must force it here (the field's own TypeRef scan is not guaranteed to set the flag).
export function forceScalarListField(code: i32) {
  if code == 25 { fa64Used = true }
  if code == 26 { ia64Used = true }
  if code == 27 { fa32Used = true }
  0
}

// True if `name` is a `<ref-list> | null` — a NULLABLE ref-list field/local (`S[] | null`, `(i32|null)[] |
// null`, `{g:i32}[] | null`), the ref-list analogue of `nameIsNulI32List`. Its non-null part is a ref array
// (a struct / union / nested-array element list). NOT an `i32[] | null` (that is code 18, kind 15).
export function nameIsNulRefList(name: string) {
  const np = nullablePartOf(name)
  if np == "" { return false }
  return nameIsRefArray(np)
}

export function fieldTypeCode(tyIx: i32) {
  if tyIx < 0 { return -1 }
  // A NULLABLE-function field (`op: ((i32) => i32) | null`) stores a NULLABLE closure
  // fat-pointer (code 22) — the field analogue of a kind-19 local. Checked BEFORE the
  // bare-function test (and before `tyIsFuncType`, exactly as `vtKindOfType` orders it):
  // `((i32) => i32) | null` is a nullable function (arrow nested under a top-level `|`),
  // whereas `(i32) => i32 | null` is a function RETURNING a nullable (handled elsewhere).
  if nulCloFlag(tyIx) == 1 { return 22 }
  // A function-typed field (`op: (i32) => i32`) stores the closure fat-pointer (code 14),
  // the field analogue of a function-valued local. Checked first (a `=>` name).
  if tyIsFuncType(tyIx) { return 14 }
  const ty = P.nodes[tyIx]
  if ty is TypeRef {
    if ty.tyName == "i32" { return 0 }
    if ty.tyName == "boolean" { return 0 }
    // An f64 field (`x: f64`) stores a raw f64 valtype slot — code 17. An i64 / f32 field is
    // the same idea in the other scalar valtypes — codes 23 / 24 (0x7e / 0x7d storage).
    if ty.tyName == "f64" { return 17 }
    if ty.tyName == "i64" { return 23 }
    if ty.tyName == "f32" { return 24 }
    // A literal-union field (`kind: K`) stores an interned-i32 ATOM — code 0 (i32 valtype),
    // NOT a box. Checked before the value/struct-union tests (a literal union registers as a
    // union name, which would otherwise claim it as code 16). The field's union name is recorded
    // in `sFieldElemName` so construction/read/assign recover the atom rep + membership.
    if nodeTyIsLitUnionAlias(tyIx) { return 0 }
    if nameIsString(ty.tyName) { return 3 }
    if nameIsArray(ty.tyName) {
      if nameIsI32Array(ty.tyName) { return 4 }
      // A `string[]` field is a string-ref list (code `6`) — it reuses the map keys
      // list types (`mkListIdx`/`mkArrIdx`). Any OTHER `X[]` is a struct/union ref list.
      if nameIsStringArray(ty.tyName) { return 6 }
      // A SCALAR-element list field stores its scalar-list wrapper (code 25/26/27), NOT a ref-list
      // wrapper (code 5 is for struct/union/closure elements only — returning 5 here emitted the wrong
      // heap type, the invalid-wasm hole).
      if nameIsF64Array(ty.tyName) { return 25 }
      if nameIsI64Array(ty.tyName) { return 26 }
      if nameIsF32Array(ty.tyName) { return 27 }
      return 5
    }
    // A NULLABLE i32-list field (`rest: i32[] | null`) stores a NULLABLE ref to
    // the same wrapper as code 4 — code 18 (`0x63 lTypeIdx`). Checked before the
    // value-union test (`i32[]` is not a value atom, so 16 never claims it).
    if nameIsNulI32List(ty.tyName) { return 18 }
    if nameIsNulRefList(ty.tyName) { return 28 }
    // A MAP-typed field (`children: {[string]: Tree}`) stores a non-null ref to
    // its value-type's map struct — code 19. The mv SLOT is interned by
    // `collectA`'s arena TypeRef scan (this same annotation node), so emission
    // re-finds it by the value name (`fieldRefElemName`).
    // A map-MEMBER union field (`{[string]: string} | string`) starts with `{[` too, but it is a
    // union BOX field (code 16), not a map — `!nameIsMapMemberUnion` lets it fall to the union test.
    if nameIsMap(ty.tyName) && !nameIsMapMemberUnion(ty.tyName) { return 19 }
    // A NULLABLE map field (`links: {[string]: V} | null`) stores a NULLABLE ref to the value
    // type's map struct — code 29, the field analogue of the `nulmap` local/param/return niche
    // (the map twin of code 28's nullable ref-list field). Gated to the SAME supported value
    // kinds as the non-null map field (`retNulMapFlag`'s gate), so a nullable map over an
    // unrepresentable value type keeps failing loudly (-1, no interned shape).
    if nulMapInnerName(ty.tyName) != "" {
      if mvValKindOfName(mapValNameOf(nulMapInnerName(ty.tyName))) != -3 {
        return 29
      }
    }
    // A `string | null` niche field — `(ref null $aTypeIdx)`, code 20. Checked before
    // the value-union test (it is NOT a value union — a single ref + null is a niche).
    if nameIsNulString(ty.tyName) { return 20 }
    // A `boolean | null` niche field — i32 sentinel, code 21.
    if nameIsNulBool(ty.tyName) { return 21 }
    // A `K | null` nullable-litunion niche field — the i32 atom slot with the spare
    // value `-1` = `null` (member ids are interned ≥ 0), code 30. The field analogue
    // of the kind-0 `K | null` binding niche; checked before the value-union test
    // (a single atom set + null is a niche, not a box).
    if nameIsNulLitUnion(ty.tyName) { return 30 }
    // A BOX-union field — a VALUE union (`v: i32 | null`, `y: string | i32`) OR a
    // registered STRUCT / HETEROGENEOUS union (`v: A | B`, `v: A | i32`) — stores the
    // shared union BOX ref (code 16). Checked BEFORE the nullable-struct strip, exactly
    // like `nameFieldCode` (the annotation-shape path), so a declared `type Opt = { v:
    // i32 | null }` carries the same rep as the inline `{v:i32|null}` annotation.
    if isValueUnionName(ty.tyName) { return 16 }
    if isUName(ty.tyName) { return 16 }
    // A field naming ANOTHER STRUCT (`inner: Inner`) or a NULLABLE struct
    // (`next: Node|null`) stores a `(ref null $S)` — code 15. Resolved via the
    // DECLARATION scan (not the incrementally-built struct table) so a forward /
    // mutually-recursive reference ties in the shared rec group.
    let base = ty.tyName
    const nb = nullablePartOf(base)
    if nb != "" { base = nb }
    if nameIsStructDecl(base) { return 15 }
    // An INLINE-SHAPE struct field (`inner: {x:i32}`) — not a declared name, so resolve it
    // STRUCTURALLY to its interned struct (pre-interned by `collectNestedFieldShapes`). The
    // structural→nominal bridge applied at field classification, the dual of a nominal `inner: Inner`.
    // GUARD against an array base (`{x:i32}[]` of a `{x:i32}[] | null` field): `structIndexOfTypeName`
    // ignores the trailing `[]` and would match the element shape, mis-coding a NULLABLE STRUCT-LIST
    // field as a nullable struct (code 15) — invalid wasm. A nominal `Node[] | null` already falls to
    // -1 (clean reject); this brings the inline form to par until nullable ref-list fields are repped.
    if !nameIsArray(base) && structIndexOfTypeName(base) >= 0 { return 15 }
    return -1
  }
  -1
}

// True if `name` is a STANDALONE struct `type` declaration's name — independent of
// the (incrementally-built) struct table, so a struct field may reference a LATER
// struct declaration. Union aliases and union variants are excluded (their fields
// ride the variant tables, not the struct table).
function nameIsStructDecl(name: string) {
  if name == "" { return false }
  if isUName(name) { return false }
  if variantIndexOf(name) >= 0 { return false }
  let i = 0
  while i < P.nodes.length {
    const nd = P.nodes[i]
    if nd is TypeDecl {
      if nd.tdName == name { return true }
    }
    i = i + 1
  }
  false
}

// The ref-list ELEMENT type-NAME of a field whose type node is `tyIx` — the table key
// into `rlElemName` — when `fieldTypeCode(tyIx) == 5` (a struct/union ref list); "" for
// any other field. Strips the trailing `"[]"` directly so it does NOT depend on `sNames`
// being fully populated (collectS builds it incrementally; a field may reference a
// later-declared struct). Used to fill `sFieldElemName`/`uFieldElemName`.
export function fieldRefElemName(tyIx: i32) {
  const code = fieldTypeCode(tyIx)
  // A VALUE-UNION field (code 16) records its union NAME — the key into the
  // atom-set tables (and `registerValueUnionName` interns its box reps at the
  // collection site).
  if code == 16 {
    const ty16 = P.nodes[tyIx]
    if ty16 is TypeRef { return ty16.tyName }
    return ""
  }
  // A NESTED-STRUCT field (code 15) records its TARGET struct name (the `S` of
  // `inner: S` / `next: S|null`) — resolved to a struct table index at use sites.
  if code == 15 {
    const ty15 = P.nodes[tyIx]
    if ty15 is TypeRef {
      let base = nullablePartOf(ty15.tyName)
      if base == "" { base = ty15.tyName }
      // An INLINE-SHAPE field (`inner: {x:i32}`) records the NOMINAL name of its interned struct
      // (`structIndexOfTypeName` resolves the shape — to its own `{x:i32}` key, or a matching declared
      // struct), so every nominal-keyed use site (`structIndexByName`) resolves it like `inner: Inner`.
      const idx = structIndexOfTypeName(base)
      if idx >= 0 { return sNames[idx] }
      return base
    }
    return ""
  }
  // A MAP-typed field (code 19) records its VALUE type-name (`Tree` of
  // `{[string]: Tree}`) — the mv-slot interning key (`mvValName`).
  if code == 19 {
    const ty19 = P.nodes[tyIx]
    if ty19 is TypeRef { return mapValNameOf(ty19.tyName) }
    return ""
  }
  // A NULLABLE map field (code 29) records the `| null`-stripped map's VALUE type-name —
  // the same mv-slot key its non-null twin uses, so both resolve one slot.
  if code == 29 {
    const ty29 = P.nodes[tyIx]
    if ty29 is TypeRef { return mapValNameOf(nulMapInnerName(ty29.tyName)) }
    return ""
  }
  // A NULLABLE REF-LIST field (code 28, `S[] | null`): its element is the ref-array element of the
  // non-null part (`refArrElemName(nullablePartOf(name))` — `S[]|null` -> `S`, `(i32|null)[]|null` ->
  // `i32|null`), so `sFieldRefSlot` (`rlSlotByName`) finds the element's interned slot.
  if code == 28 {
    const ty28 = P.nodes[tyIx]
    if ty28 is TypeRef { return refArrElemName(nullablePartOf(ty28.tyName)) }
    return ""
  }
  // An ATOM-ARRAY field (`f: K[]`, code 4 via `nameIsLitUnionArray`) records its ARRAY
  // type-name so `sFieldIsLitUnionArray` recovers the atom-element rep at the construct/
  // assign sites (a plain `i32[]`/`boolean[]` field stays ""). The ARRAY name — not the
  // element — so `sFieldIsLitUnion` (code-0 scalar atoms, `nameIsLitUnionType`-keyed)
  // does not claim the list-ref field.
  if code == 4 {
    const ty4 = P.nodes[tyIx]
    if ty4 is TypeRef {
      if nameIsLitUnionArray(ty4.tyName) { return ty4.tyName }
    }
    return ""
  }
  if code != 5 { return "" }
  const ty = P.nodes[tyIx]
  if ty is TypeRef { return ty.tyName.slice(0, ty.tyName.length - 2) }
  ""
}

// Validate an array type-name as a supported element type: `i32[]` (the value list),
// or a REF list `S[]`/`N[]` over the declared struct / union alias (G7-ref). A nested
// `i32[][]` or an array of an unknown / unsupported element fails loudly. Returns 0 on
// success, or -1 (via `emitFail`).
export function checkArrName(name: string) {
  if nameIsI32Array(name) { return 0 }
  if nameIsRefArray(name) { return 0 }
  emitFail(
    "emitProgram: only i32[] arrays and struct/union element arrays are supported",
  )
}

// True when `name` is `T[]` for some declared FuncDecl type parameter `T`.
export function genTyParamArr(name: string) {
  if genTyParamNames.length == 0 { return false }
  const n = name.length
  if n < 2 { return false }
  if name[n - 2] != '[' { return false }
  if name[n - 1] != ']' { return false }
  const base = name.slice(0, n - 2)
  let i = 0
  while i < genTyParamNames.length {
    if genTyParamNames[i] == base { return true }
    i = i + 1
  }
  false
}

// True if the array literal at `arrIx` has ref ELEMENTS — its first element is a
// struct object literal (a `T[]` element) or a union-variant object literal (an
// `N[]` element). An empty literal is NOT detectable here (it has no elements); its
// kind comes from the binding annotation (`pendingListKind`).
export function arrLitIsRef(arrIx: i32) {
  const a = P.nodes[arrIx]
  if a is ArrayLit {
    if a.arrElems.length < 1 { return false }
    // A literal of FUNCTION VALUES the checker typed as a closure array (`[add, mul]`,
    // `[inc, (x) => x]`): its element name carries a `=>`. Checker-driven (not a first-element
    // `fnIndexOf` guess), so a local shadowing a function name is never mis-claimed — and it
    // subsumes the lambda-literal case below for any closure array the checker concretely typed.
    const cen = nodeArrayElemName(arrIx)
    if cen != "" {
      if strContains(cen, "=>") { return true }
    }
    const e0 = P.nodes[a.arrElems[0]]
    if e0 is ObjLit { return true }
    // A CLOSURE-element literal (`[(x) => x + 1]`) is a ref list (element kind 5), NOT an i32
    // list — without this `exprArray` claims it (its `!arrLitIsRef` default), the inferred-return
    // scan mints a `>a` (i32-list) closure sig, and a closure VALUE returning it miscompiles. As a
    // ref list it routes through `exprRefArray` (kind 5) like a struct-element literal.
    if e0 is FuncDecl { return true }
    // A NESTED array literal (`[[1, 2], [3, 4]]`, `[["a"]]`, `[[1.5]]`,
    // `[[6000000000]]`) is a ref list whose element is the INNER list's wrapper —
    // element kind 4 (i32-ish leaves) or 6/7/8 (string / f64 / i64 leaves, via
    // `arrLitElemKind`'s inner probe). Keying every scalar/string leaf here (not
    // only i32) makes a SELF-classified nested literal — an un-annotated binding,
    // a lambda result — build the SAME rep its leaves need: an i64-magnitude leaf
    // (`[[62321678167]]`) previously still keyed the `i32[]` element while its
    // inner literal built the i64 wrapper — a wrapper-heap mismatch, INVALID WASM
    // (the `() => i64[][]` global). A REF inner literal (`[[{v: 1}]]`) stays
    // annotation-driven (the threaded `pendingListKind`/slot path).
    if e0 is ArrayLit {
      if !arrLitIsRef(a.arrElems[0]) { return true }
    }
  }
  false
}

// True if the array literal at `arrIx` has STRING elements — its first element is a
// string-typed expression (a `"…"` literal, or a string-returning call / string
// param/local). An empty literal is NOT detectable here; its kind comes from the
// binding/field annotation (`pendingListKind == 3`).
export function arrLitIsStr(arrIx: i32, fnIx: i32) {
  const a = P.nodes[arrIx]
  if a is ArrayLit {
    if a.arrElems.length < 1 { return false }
    // An ATOM-element literal (the checker adopted a `K[]` context onto it) is the i32
    // atom-id list, NOT a string list: its member elements are string exprs syntactically,
    // but each lowers as its interned atom id (`emitArr` seeds `pendingLitUnion` off the
    // same recorded type). Without this, the literal claims the string-list slot/collect/
    // build while every consumer reads the atom rep — invalid wasm at the first use.
    if nodeArrayElemIsLitUnion(arrIx) { return false }
    // A `(K | null)[]` literal (`["a", null]`) is likewise the i32 atom-niche list, NOT a string list:
    // its member elements lower as atom ids and a `null` as the `-1` sentinel. Its INFERRED element
    // type is the expanded `"a" | null` union (a null member + str-lit members), which
    // `nodeArrayElemIsNulLitUnion` recognizes — without this exclusion a string-FIRST literal claims
    // the string-list slot/collect while every consumer reads the atom rep (invalid wasm).
    if nodeArrayElemIsNulLitUnion(arrIx) { return false }
    // A `(string | null)[]` literal with NO string-typed first element (`[null]`, `[null,
    // "x"]`): the recorded context-adoption type is the only signal — it IS the string-ref
    // niche list (`emitArr` seeds `pendingNulString` off the same recorded type), so the
    // string-list build is authoritative even though the first-element probe below misses.
    if nodeArrayElemIsNulStr(arrIx) { return true }
    return exprString(a.arrElems[0], fnIx)
  }
  false
}

// True if the array literal at `arrIx` has f64 ELEMENTS — its first element is an
// f64-typed expression (a `.` float literal, or an f64-returning expression). An empty
// literal is NOT detectable here; its kind comes from the binding annotation
// (`pendingListKind == 4`). (Slice 4.)
export function arrLitIsF64(arrIx: i32, fnIx: i32) {
  const a = P.nodes[arrIx]
  if a is ArrayLit {
    if a.arrElems.length < 1 { return false }
    return exprIsF64(a.arrElems[0], fnIx)
  }
  false
}

// The ref-element kind of the array literal at `arrIx` (assumes `arrLitIsRef`): `2`
// when the FIRST element is a union variant (boxes into the union), else `1` (a direct
// struct element). Per-element-type: a `Tok[]` literal whose element is a plain struct
// is kind `1` even in a program that ALSO declares a union (which `Node[]` uses).
export function arrLitElemKind(arrIx: i32) {
  const a = P.nodes[arrIx]
  if a is ArrayLit {
    // A closure-element literal (the checker typed the element as a function type) is kind 5.
    const cen = nodeArrayElemName(arrIx)
    if cen != "" {
      if strContains(cen, "=>") { return 5 }
    }
    if a.arrElems.length >= 1 {
      const e0 = P.nodes[a.arrElems[0]]
      // A nested-list element: the INNER literal's leaf picks the element kind —
      // string 6 / f64 7 / i64 8, else the i32-list wrapper (4). Mirrors
      // `arrLitElemName`'s leaf keying (the two must agree per slot).
      if e0 is ArrayLit {
        if arrLitIsStr(a.arrElems[0], -1) { return 6 }
        if arrLitIsF64(a.arrElems[0], -1) { return 7 }
        if arrLitIsI64(a.arrElems[0], -1) { return 8 }
        return 4
      }
      if e0 is ObjLit {
        // A union-variant element boxes into the union (kind 2); a plain struct is kind 1.
        if uDeclared {
          if objVariantName(a.arrElems[0]) != "" { return 2 }
        }
        return 1
      }
    }
  }
  if uDeclared { return 2 }
  1
}

// The ref-list ELEMENT type-NAME of the array literal at `arrIx` (assumes `arrLitIsRef`):
// the union alias name for a union-variant element, else the matched struct's name. This
// is the table key (`rlElemName`) the per-element-type interning uses.
export function arrLitElemName(arrIx: i32) {
  const a = P.nodes[arrIx]
  if a is ArrayLit {
    // A closure-element literal: the parenthesized function-type table key the checker recorded.
    const cen = nodeArrayElemName(arrIx)
    if cen != "" {
      if strContains(cen, "=>") { return cen }
    }
    if a.arrElems.length >= 1 {
      const e0 = P.nodes[a.arrElems[0]]
      // A nested-list element keys the INNER list's name by its leaf — the table
      // key `arrLitElemKind` picks the matching kind for (6/7/8, else 4).
      if e0 is ArrayLit {
        if arrLitIsStr(a.arrElems[0], -1) { return "string[]" }
        if arrLitIsF64(a.arrElems[0], -1) { return "f64[]" }
        if arrLitIsI64(a.arrElems[0], -1) { return "i64[]" }
        return "i32[]"
      }
      if e0 is ObjLit {
        if uDeclared {
          const vn = objVariantName(a.arrElems[0])
          if vn != "" { return unionNameOfVariant(variantIndexOf(vn)) }
        }
        const si = structIndexOfObj(a.arrElems[0])
        if si >= 0 { return sNames[si] }
      }
    }
  }
  ""
}

// The element type-NAME for a ref-array type-name (assumes `nameIsRefArray(name)`): the
// element is `name` with the trailing `"[]"` removed — i.e. the struct / union alias
// name. Mirrors `refArrElemKind` but yields the table key.
export function refArrElemName(name: string) {
  const ranp = nullablePartOf(name)
  if ranp != "" && nameIsArray(ranp) { return refArrElemName(ranp) }
  // `i32[][]` -> `i32[]`, `boolean[][]` -> `boolean[]`, `K[][]` -> `K[]`: the immediate i32-backed
  // inner list is the slot key (all kind-4 `lTypeIdx` elements), mirroring the `i32[][]` case.
  if nameIsI32ListArray(name) { return name.slice(0, name.length - 2) }
  // A nested NON-i32 scalar / string 2D array — the inner list's name is the slot key (kind
  // 8 / 7 / 6 element), mirroring `i32[][]` → `i32[]`.
  if name == "i64[][]" { return "i64[]" }
  if name == "f64[][]" { return "f64[]" }
  if name == "f32[][]" { return "f32[]" }
  if nameIsArray(name) && nameIsStringArray(name.slice(0, name.length - 2)) {
    return name.slice(0, name.length - 2)
  }
  if nameIsMapArray(name) { return name.slice(0, name.length - 2) }
  // `(string|i32)[]` → `string|i32` (the parens are annotation grouping only —
  // the TABLE key is the bare atom-set name every other union position uses).
  const pun = parenUnionArrElemName(name)
  if pun != "" { return pun }
  // `((i32) => i32)[]` → `((i32) => i32)` (the parenthesized function-type element, the
  // table key for the closure-element slot — all such slots share `cloStructIdx`).
  if nameIsClosureArray(name) { return name.slice(0, name.length - 2) }
  // A `<Union>[]` / `<Struct>[]`: strip the trailing `[]` ONCE and confirm the bare name is a
  // registered union/struct (the stripped base IS the table key — no per-iteration `+ "[]"`
  // concat, which allocated a string per struct/union per call).
  const n = name.length
  if n >= 3 && name[n - 2] == '[' && name[n - 1] == ']' {
    const base = name.slice(0, n - 2)
    let u = 0
    while u < unNames.length {
      if base == unNames[u] { return base }
      u = u + 1
    }
    if structIndexByName(base) >= 0 { return base }
    // An INLINE-SHAPE element (`{v:i32}[]`) resolving to a DECLARED struct by the
    // structural bridge — the SPELLING stays the table key (its slot twins with the
    // declared name's slot at the heap layer, so the pair still dedups). Keyed
    // exactly like `nameIsRefArray`'s bridge (the two must agree).
    if shapeElemDeclaredStructIdx(base) >= 0 { return base }
    // A `Cat[]` concrete-variant element list — the bare variant name is the table key.
    if variantIndexOf(base) >= 0 { return base }
    // A NESTED ref array (`Cell[]` as the element of `Cell[][]`): the base is itself a ref array
    // — the inner list's name keys its slot. Recurses to the leaf struct/union/closure array.
    if nameIsRefArray(base) { return base }
  }
  ""
}

// Intern a ref-list element type-NAME into the per-element-type table, returning its
// SLOT index (existing slot if already present). `kind` is 1 (struct) or 2 (union box).
// Heap/backing/wrapper indices are filled later in `emitModule`.
// A ref-list element is a NULLABLE NICHE (the index read leaves it `(ref null $elem)`) iff it is a
// niche-bearing KIND — a struct (1), a closure (5, the `(ref null $cloStruct)` fat-pointer), an
// inner LIST of any leaf (4, the distinct-backing scalar/string 6/7/8/10, or a ref inner 9) — AND
// its name carries `| null`. A value-union BOX (kind 2) is NOT a niche even though `i32 | null`
// also has `| null` (its null is a tag inside a non-null box). The KIND is the discriminator;
// recording it once here keeps the read/build sites kind-agnostic.
function rlElemNicheNullable(kind: i32, name: string) {
  if (
    kind != 1 &&
    kind != 3 &&
    kind != 4 &&
    kind != 5 &&
    kind != 6 &&
    kind != 7 &&
    kind != 8 &&
    kind != 9 &&
    kind != 10
  ) {
    return false
  }
  return nullablePartOf(name) != ""
}

export function rlInternName(name: string, kind: i32) {
  if name == "" { return -1 }
  let i = 0
  while i < rlElemName.length {
    if rlElemName[i] == name { return i }
    i = i + 1
  }
  rlElemName.push(name)
  rlElemHeap.push(0)
  rlBackIdx.push(0)
  rlWrapIdx.push(0)
  rlElemKindTbl.push(kind)
  if rlElemNicheNullable(kind, name) {
    rlElemNullable.push(1)
  } else {
    rlElemNullable.push(0)
  }
  rlElemName.length - 1
}

// The table SLOT for a ref-list element type-NAME. Nominal exact-name match is
// the fast path; on a miss, the CANONICAL fallback (the struct table's
// nominal-then-structural pattern, extended to the ref-list layer): a STRUCT
// element spelled differently from the interned key — an inline shape vs its
// declared twin (`{v:i32}` vs `A`), or two structurally-identical declared
// names — resolves to the slot whose element backs the SAME heap type. The
// two-layer discipline holds: the element names must resolve to struct slots
// that are canonical-key AND field-code-layout twins (`repStructSlotsTwin`),
// and the `| null` niche parity must agree (a niche-nullable element's index
// read stays nullable — merging it with a non-null slot would change the read
// discipline, not just the heap type). -1 when nothing matches.
export function rlSlotByName(name: string) {
  let i = 0
  while i < rlElemName.length {
    if rlElemName[i] == name { return i }
    i = i + 1
  }
  // A LITUNION-ALIAS atom inside a union ELEMENT name (`K0|i32` — the verbatim text of an
  // `is (K0 | i32)[]` variant or its narrow key): the interning side keys the slot on the
  // emit-canonical name, which renders a litunion member as its boxed `string` atom
  // (`string|i32` — a litunion boxes as a string ref, R3's rule), so the verbatim spelling
  // misses. Retry the exact match with each litunion-alias atom widened to `string`.
  // Sound for the same reason the `is K0` string-tag compare is: a real `string` member
  // cannot coexist with a litunion in one union (`K0 | string` collapses to `string`).
  if unionMemberCount(name) > 1 {
    const luAtoms: string[] = []
    splitUnionAtoms(name, luAtoms)
    let luChanged = false
    let luCanon = ""
    let luI = 0
    while luI < luAtoms.length {
      let a = luAtoms[luI]
      if nameIsLitUnionType(a) {
        a = "string"
        luChanged = true
      }
      if luI > 0 { luCanon = luCanon + "|" }
      luCanon = luCanon + a
      luI = luI + 1
    }
    if luChanged {
      let li = 0
      while li < rlElemName.length {
        if rlElemName[li] == luCanon { return li }
        li = li + 1
      }
    }
  }
  const qn = nullablePartOf(name)
  let qBase = name
  if qn != "" { qBase = qn }
  const qsi = structIndexOfTypeName(qBase)
  if qsi < 0 { return -1 }
  let j = 0
  while j < rlElemName.length {
    if rlElemKindTbl[j] == 1 {
      const en = rlElemName[j]
      const enn = nullablePartOf(en)
      let parity = false
      if qn == "" && enn == "" { parity = true }
      if qn != "" && enn != "" { parity = true }
      if parity {
        let eBase = en
        if enn != "" { eBase = enn }
        const esi = structIndexOfTypeName(eBase)
        if esi >= 0 && repStructSlotsTwin(qsi, esi) == 1 { return j }
      }
    }
    j = j + 1
  }
  -1
}

// ── Canonical layout twins, MAP-VALUE slot layer (roadmap repOf, slot layer) ──
// The struct table dedups by canonical key + field codes (`sTwin`), the ref-list
// table by resolved element heap (`rlTwin`). The map-VALUE table (`mvValName`)
// is the next name-keyed layer: each slot mints its own 7-field map struct
// (`mvMapTypeIdx`) whose ONLY varying field is the vals-list wrapper, so two
// slots whose VALUE types are layout twins emit byte-identical map structs —
// which, inside the single rec group, are still DISTINCT heap types unless they
// share one index (a `{[string]: B}` passed where a `{[string]: A}` twin is
// expected was invalid wasm). `repMapValSlotsTwin` is the pairwise equivalence,
// TIMING-INDEPENDENT (no heap index is consulted, so it is queryable before
// `mAssignTypeIndices` assigns anything): the struct template's two-layer
// discipline, with the structural key resolved through the checker
// (`repNameCanonKey`) and the layout guard delegated per value KIND to the
// layer that owns the rep.

// True when ref-list slots `a` and `b` resolve the SAME element heap type — the
// pairwise LAYOUT-twin equivalence over the ref-list table, mirroring the
// `rlSig` arms of `mAssignTypeIndices` from checker-level data only (each arm
// below must stay at least as strict as its `rlSig` twin, so a claimed twin
// always resolves equal (backing, wrapper) pairs there):
//   · singleton element heaps — the union box (2), the i32-list wrapper (4),
//     the closure fat-pointer (5), the string/f64/i64/f32 inner-list wrappers
//     (6/7/8/10) — kind equality IS heap equality;
//   · a struct-LIST element (9, `S[][]`) twins iff the inner lists do;
//   · a MAP element (3) twins iff both are the shared mono map or their value
//     slots are `repMapValSlotsTwin` (the mutual recursion bottoms out — every
//     step descends into a strictly shorter element spelling);
//   · a struct / nullable-struct element twins per `repStructSlotsTwin` with
//     matching `| null` niche parity (stricter than heap identity — the
//     `rlSlotByName` discipline: a niche-nullable element's read stays
//     nullable, so parity is part of slot equivalence, not just heap identity);
//   · a variant element only twins with ITSELF (the variant table is the next
//     name-keyed layer; until it dedups, distinct indices are distinct heaps).
export function rlSlotsLayoutTwin(a: i32, b: i32): i32 {
  if a == b { return 1 }
  if a < 0 || b < 0 { return 0 }
  const ka = rlElemKindTbl[a]
  if ka != rlElemKindTbl[b] { return 0 }
  if (
    ka == 2 ||
    ka == 4 ||
    ka == 5 ||
    ka == 6 ||
    ka == 7 ||
    ka == 8 ||
    ka == 10
  ) {
    return 1
  }
  if ka == 9 {
    return rlSlotsLayoutTwin(
      rlSlotByName(refArrElemName(rlElemName[a])),
      rlSlotByName(refArrElemName(rlElemName[b])),
    )
  }
  if ka == 3 {
    const ma = mvSlotOfMapValNameOrMono(mapValNameOf(rlElemName[a]))
    const mb = mvSlotOfMapValNameOrMono(mapValNameOf(rlElemName[b]))
    if ma == -1 && mb == -1 { return 1 }
    if ma < 0 || mb < 0 { return 0 }
    return repMapValSlotsTwin(ma, mb)
  }
  const na = rlElemName[a]
  const nb = rlElemName[b]
  const nna = nullablePartOf(na)
  const nnb = nullablePartOf(nb)
  let parity = false
  if nna == "" && nnb == "" { parity = true }
  if nna != "" && nnb != "" { parity = true }
  if !parity { return 0 }
  const sa = structIdxOfElemName(na)
  const sb = structIdxOfElemName(nb)
  if sa >= 0 && sb >= 0 { return repStructSlotsTwin(sa, sb) }
  0
}

// True when map-value slots `a` and `b` share ONE map-struct WasmGC heap type:
// the canonical structural key of the VALUE type (through the checker) plus the
// per-kind layout guard. Scalar/string values (3/10/11/13) ride fixed singleton
// vals lists; a union-box value (2) rides the ONE shared `uBoxIdx` box; a
// closure value (14) the ONE `cloStructIdx` fat pointer — for those the kind +
// canonical key decide. A struct value (1) guards with `repStructSlotsTwin`, a
// ref-list / nested-map value (6) with `rlSlotsLayoutTwin` over the vals slots.
export function repMapValSlotsTwin(a: i32, b: i32): i32 {
  if a == b { return 1 }
  if a < 0 || b < 0 { return 0 }
  const k = mvValKind[a]
  if k != mvValKind[b] { return 0 }
  const ka = repNameCanonKey(mvValName[a])
  if ka == "" { return 0 }
  if ka != repNameCanonKey(mvValName[b]) { return 0 }
  if k == 3 || k == 10 || k == 11 || k == 13 { return 1 }
  if k == 2 || k == 14 { return 1 }
  if k == 1 { return repStructSlotsTwin(mvValStructIdx[a], mvValStructIdx[b]) }
  if k == 6 { return rlSlotsLayoutTwin(mvRlSlot[a], mvRlSlot[b]) }
  0
}

// The canonical REPRESENTATIVE map-value slot for `slot`: the smallest slot that
// is a `repMapValSlotsTwin` layout twin (the equivalence is transitive — key
// equality composes, and every guard layer is itself a canonical-key + layout
// equivalence — so first-twin picks one stable representative per class). The
// heap mint (`mAssignTypeIndices`), the union-box tag (`mapSlotTag`), and the
// arm-slot guard (`unionHasMapArmSlot`) all canonicalize through this ONE
// chokepoint, so a twin-spelled map arm boxes, tags, and casts as its
// representative. A negative slot (mono `-1` / unsupported `-3`) passes through.
export function mvCanonRepOf(slot: i32): i32 {
  if slot < 0 { return slot }
  let t = 0
  while t < slot {
    if repMapValSlotsTwin(t, slot) == 1 { return t }
    t = t + 1
  }
  slot
}

// The struct field-type CODE for an ANONYMOUS-shape field, from its literal VALUE
// (an anonymous literal has no `type` annotation to read): a number/boolean is i32
// (`0`), a string literal is a string ref (`3`), a function VALUE is a closure
// fat-pointer (`14` — a `(ref $cloStruct)`, the same kind #306 uses for a closure
// cell). A function value is either a FuncDecl literal (an inline lambda) or a bare
// Ident naming a function. Anything else (a nested literal, a call, …) returns -1 —
// the whole shape is then left un-interned and the literal fails loudly downstream.
export function anonFieldCode(valIx: i32) {
  if valIx < 0 { return -1 }
  const e = P.nodes[valIx]
  if e is NumLit {
    // A float `.` literal field (`x: 1.5`) is an f64 slot (code 17) — UNLESS the context
    // adopted an f32 slot (the checker recorded f32 on the node, `objRetWidenAdopt`'s
    // f32-field arm): code 24, and the literal re-encodes exactly at f32 at the field store.
    if numTextIsFloat(e.numText) {
      if tyKindOf(nodeTyIxOf(valIx)) == 13 { return 24 }
      return 17
    }
    // An i64-magnitude literal field (`x: 6000000000`) is an i64 slot (code 23) — an
    // i32-coded shape would `struct.new` the i64 operand into an i32 field: invalid
    // wasm (the lambda-returning-`{f: i64}` hole; a named function's ANNOTATED return
    // shape already coded 23 via `fieldTypeCode`).
    if !numLexFitsI32(e.numText) { return 23 }
    // A SMALL int literal whose context adopted a wider slot — the checker recorded
    // i64/f64 on the node (`objRetWidenAdopt`, a lambda returning `{f: 5}` against
    // `() => {f: i64}`): code the wide slot; the literal re-encodes at the field store.
    const tk = tyKindOf(nodeTyIxOf(valIx))
    if tk == 10 { return 23 }
    if tk == 11 { return 17 }
    return 0
  }
  if e is BoolLit { return 0 }
  if e is StrLit { return 3 }
  if e is FuncDecl { return 14 }
  if e is Ident {
    if nameNamesFunction(e.identName) { return 14 }
    return -1
  }
  // An ARITHMETIC field value (`x: x * s` — an operator-overload maker scaling
  // its params) is i32 too; a `+` whose operand is a string literal is a concat
  // (not classifiable here).
  if e is BinExpr {
    const bop = e.binOp
    if bop == "-" || bop == "*" || bop == "/" || bop == "%" { return 0 }
    if bop == "+" {
      const bl = P.nodes[unwrapParen(e.binLeft)]
      const br = P.nodes[unwrapParen(e.binRight)]
      let strSide = false
      if bl is StrLit { strSide = true }
      if br is StrLit { strSide = true }
      if !strSide { return 0 }
      return -1
    }
    return -1
  }
  // A NUMERIC-element array literal field: an i32 list (code 4) for i32-range elements,
  // the f64 / i64 scalar-list codes (25 / 26) for a float / i64-magnitude first element —
  // the same leaf split the NumLit field takes (an i32-coded list field over an f64/i64
  // literal mismatched the built list's wrapper).
  if e is ArrayLit {
    if e.arrElems.length > 0 {
      const ae = P.nodes[e.arrElems[0]]
      if ae is NumLit {
        if numTextIsFloat(ae.numText) { return 25 }
        if !numLexFitsI32(ae.numText) { return 26 }
        return 4
      }
    }
    return -1
  }
  // A NESTED object-literal field (`pos: { x: 1 }`) is a nested-struct ref (code
  // 15) once the inner literal's shape resolves — the parser interns children
  // before parents (lower arena indices), so a linear collect sees it.
  if e is ObjLit {
    if structIndexOfObj(valIx) >= 0 { return 15 }
    return -1
  }
  -1
}

// The `sFieldElemName` entry for an ANONYMOUS-shape field: the nested struct's
// table NAME for a code-15 field (`pos: { x: 1 }` → the inner shape's synthetic
// name), "" otherwise.
export function anonFieldElemName(valIx: i32, code: i32) {
  if code != 15 { return "" }
  const si = structIndexOfObj(valIx)
  if si >= 0 { return sNames[si] }
  ""
}

// The per-field wasm-type code an INLINE OBJECT-TYPE annotation member names
// (`x:i32` → 0, `name:string` → 3, `tags:i32[]` → 4, …) — the NAME-level mirror
// of `fieldTypeCode` (which reads a TypeRef node).
export function nameFieldCode(t: string) {
  // A NULLABLE function field text (`((i32) => i32) | null`) is the nullable closure
  // fat-pointer, code 22 — the text mirror of `fieldTypeCode`'s `nulCloFlag` arm.
  if nameIsNulClosure(t) { return 22 }
  // A function-typed field name — a TOP-LEVEL arrow (`(i32)=>i32`) — is the closure rep,
  // code 14. Depth-aware (`annArrowAt`, not a substring test): a UNION carrying a closure
  // MEMBER (`(() => i32) | string`) nests its arrow in parens and is a value union (code
  // 16, the box) — the substring test claimed it as a bare closure and the constructed
  // box ref mismatched the closure-typed field (an unparseable module when global).
  if annArrowAt(t) >= 0 { return 14 }
  if t == "i32" { return 0 }
  if t == "boolean" { return 0 }
  if t == "f64" { return 17 }
  if t == "i64" { return 23 }
  if t == "f32" { return 24 }
  // A literal-union field (`kind: K`, or inline `"a"|"b"`) — an interned-i32 ATOM, code 0 (the
  // name-based mirror of `fieldTypeCode`'s litunion branch). Before the union/string tests.
  if nameIsLitUnionType(t) { return 0 }
  if nameIsString(t) { return 3 }
  if nameIsArray(t) {
    if nameIsI32Array(t) { return 4 }
    if nameIsStringArray(t) { return 6 }
    // Scalar-element list fields (code 25/26/27), same as `fieldTypeCode`.
    if nameIsF64Array(t) { return 25 }
    if nameIsI64Array(t) { return 26 }
    if nameIsF32Array(t) { return 27 }
    return 5
  }
  // A MAP-typed field (`m: {[string]: i32}`) — code 19, the name-level mirror of the
  // `fieldTypeCode` map case. Its mv SLOT is resolved at emit by the value name recorded in
  // `sFieldElemName` (see `internInlineShape`/`internShapeAs`).
  // A map-MEMBER union field (`{[string]: V} | X`) starts with `{[` too, but it is a union BOX
  // field (code 16), not a map — `!nameIsMapMemberUnion` lets it fall to the union test below,
  // exactly as `fieldTypeCode`'s node-based map arm does. Without this an inline object-type
  // field of a map-member-union type mis-stored the union box in a map-struct field slot
  // (invalid wasm). (The `nameIsMapMemberUnion` twin of `fieldTypeCode`.)
  if nameIsMap(t) && !nameIsMapMemberUnion(t) { return 19 }
  // A NULLABLE map field (`{[string]: V} | null`) — code 29, the name-level mirror of
  // `fieldTypeCode`'s nullable-map arm, with the same supported-value-kind gate.
  if nulMapInnerName(t) != "" {
    if mvValKindOfName(mapValNameOf(nulMapInnerName(t))) != -3 { return 29 }
  }
  // A NULLABLE i32-list field (`rest: i32[] | null`) — code 18 (see fieldTypeCode).
  if nameIsNulI32List(t) { return 18 }
  if nameIsNulRefList(t) { return 28 }
  // The niche FIELDS: `string | null` (`(ref null $aTypeIdx)`, code 20) and
  // `boolean | null` (i32 sentinel, code 21) — before the value-union test (a single
  // ref/scalar + null is a niche, not a box).
  if nameIsNulString(t) { return 20 }
  if nameIsNulBool(t) { return 21 }
  // A `K | null` nullable-litunion niche field — i32 with the `-1` null sentinel,
  // code 30 (the name-based mirror of `fieldTypeCode`'s arm).
  if nameIsNulLitUnion(t) { return 30 }
  // A BOX-union field — a VALUE union (`y: string | i32`) OR a registered STRUCT /
  // HETEROGENEOUS union (`v: A | B`, `v: A | i32`) — stores the union BOX ref (code 16);
  // its union name rides `sFieldElemName` (the tag set + value-box / variant reps).
  // Checked before the nullable-struct strip (`i32|null` is a value union, not a
  // nullable struct name).
  if isValueUnionName(t) { return 16 }
  if isUName(t) { return 16 }
  let base = t
  const nb = nullablePartOf(base)
  if nb != "" { base = nb }
  if nameIsStructDecl(base) { return 15 }
  -1
}

// Intern every INLINE OBJECT-TYPE annotation (`(p: { x: i32 })`, `: { x: i32 } |
// null` — the synthetic `{x:i32}` TypeRef names) as an anonymous struct shape, so
// a literal with the same field-name SET (`{ x: n }`, even one whose field VALUES
// are param reads `anonFieldCode` cannot classify) matches it via
// `structIndexOfObj`, and `S|null` returns/params resolve their base shape.
// Idempotent per field-name set; a module with no inline object annotation interns
// nothing (byte-identical goldens).
// Split union name `nm` on TOP-LEVEL `|`, tracking ALL grouper depth — braces, brackets, AND
// parens (plus string-literal atoms, so a quoted litunion member never splits) — appending the
// arms to `out`. The paren-aware sibling of `splitUnionAtoms` (whose brace/bracket-only depth
// mis-splits a `(...)`-grouped arm): used ONLY by `internShapeDeep`'s union-arm interning, where
// a grouped arm must stay whole (`(i32|null)[] | null` → `(i32|null)[]` + `null`; a struct arm
// with a grouped element list `{f: (boolean|string)[]} | f64` splits at its real top seam). A
// TOP-LEVEL `=>` absorbs the rest of the name into the current arm, exactly like
// `splitUnionAtoms`: `(i32) => i32 | {w: i32}` is ONE function-type atom whose `|` binds to the
// RETURN (splitting it interned a bogus `{w: i32}` struct arm — a shape-order side effect that
// regressed the pinned net). A name with no top-level `|` appends one arm.
function splitUnionArmsAllDepth(nm: string, out: string[]) {
  let depth = 0
  let inStr = false
  let start = 0
  let i = 0
  while i < nm.length {
    const c = nm[i]
    if inStr {
      if c == '"' { inStr = false }
    } else if c == '"' {
      inStr = true
    } else if c == '{' || c == '[' || c == '(' {
      depth = depth + 1
    } else if c == '}' || c == ']' || c == ')' {
      depth = depth - 1
    } else if (
      c == '=' &&
      depth == 0 &&
      i + 1 < nm.length &&
      nm[i + 1] == '>'
    ) {
      // Top-level function arrow: the remainder (its return, `|`s included) is this arm's.
      break
    } else if (c == '|' && depth == 0) {
      out.push(nm.slice(start, i))
      start = i + 1
    }
    i = i + 1
  }
  out.push(nm.slice(start, nm.length))
  0
}

// Intern each union arm whose CORE (trailing `[]`s peeled) is an INLINE `{…}` shape (a struct or
// map arm) via `internShapeDeep` — the shared body of the paren-free and paren-carrying splits.
function internShapeArms(arms: string[]) {
  let uai = 0
  while uai < arms.length {
    let uCore = arms[uai]
    while (
      uCore.length > 2 &&
      uCore[uCore.length - 2] == '[' &&
      uCore[uCore.length - 1] == ']'
    ) {
      uCore = uCore.slice(0, uCore.length - 2)
    }
    if uCore.length >= 1 && uCore[0] == '{' {
      internShapeDeep(arms[uai])
    } else if annArrowAt(monoUnwrapParens(uCore)) >= 0 {
      // A CLOSURE arm (`((i32) => {a: f64, f: K0, z: string}[]) | f64`): the inline
      // shapes buried in its params/result are otherwise unreachable — the arm is ONE
      // spelling inside the union name, so a narrowed arm's value-call result read found
      // no interned struct ("field access but no struct type declared"). Route through
      // the soundness-gated functype interner (`funcTypeShapeLowerable` keeps an
      // unsupported-field shape un-interned — a clean reject, never invalid wasm).
      internFuncTypeShapes(arms[uai])
    }
    uai = uai + 1
  }
  0
}

// Recursively peel the COMPOSITION wrappers off a type name — grouping parens, a trailing `| null`, and
// trailing `[]` suffixes, in any order and to any depth — interning the inline-shape STRUCT reached at the
// bottom (`internInlineShape` then recurses into the shape's own fields). Reaches a shape however deeply it
// is nested under arrays / nullables / groupings: `({g:i32}[] | null)[]` -> `{g:i32}`, `{f:i32}[][]` ->
// `{f:i32}`. A non-shape leaf (`i32`, a named type, a map) interns as a no-op.
export function internShapeDeep(nm: string) {
  if nm.length < 2 { return 0 }
  // Peel ONLY a grouping pair that wraps the WHOLE name. A functype whose leading `(` is its
  // own PARAM LIST (`(i32)=>(()=>{a:i64,f:i32,z:f64})`) must NOT be blind-peeled — the garbled
  // remainder (`i32)=>…`) dead-ends every case below, so the shapes buried in its RESULT spine
  // never intern (and a chained value call's struct read then finds no interned shape).
  const uw = monoUnwrapParens(nm)
  if uw.length != nm.length { return internShapeDeep(uw) }
  // A VALUE UNION leaf (`i32 | null`, `string | i32`) — register its box reps. Do NOT peel its `| null`:
  // here the null is a union ATOM (a tag in a non-null box), NOT a nullable-niche wrapper. Checked AFTER
  // the parens peel (so `(i32|null)` reaches here) but BEFORE the `| null` peel (which would lose the atom).
  if isValueUnionName(nm) {
    registerValueUnionName(nm)
    // A CLOSURE atom of the value union (`((i32) => {a: f64, f: K0, z: string}[]) | f64`)
    // may bury inline shapes in its params/result — unreachable through the box
    // registration (the arm is one spelling inside the union name), so a narrowed arm's
    // value-call result read found no interned struct. Descend each arrow arm through
    // the soundness-gated functype interner (`funcTypeShapeLowerable` keeps an
    // unsupported-field shape un-interned — a clean reject, never invalid wasm).
    if strContains(nm, "=>") {
      const vArms: string[] = []
      splitUnionArmsAllDepth(nm, vArms)
      let va = 0
      while va < vArms.length {
        const vc = monoUnwrapParens(vArms[va])
        if annArrowAt(vc) >= 0 { internFuncTypeShapes(vc) }
        va = va + 1
      }
    }
    return 0
  }
  const np = nullablePartOf(nm)
  if np != "" { return internShapeDeep(np) }
  // A MIXED / composite UNION (`{f:i64}[] | f64`, `{[string]: K}[] | string`, `{f:i64}[] | {w:i32}`):
  // the all-scalar case was handled by the `isValueUnionName` branch above, so a top-level `|` here
  // means at least one arm is a COMPOSITE. Intern an arm whose CORE (trailing `[]`s peeled) is an
  // INLINE STRUCT / MAP shape (`{f:i64}[]`, `{[string]:V}[]`, a bare `{w:i32}`) NOW — during
  // `collectAnnShapes`, BEFORE the literal that carries it is seen by `collectAnonShapes` (which would
  // otherwise name the same shape `#anonN`, leaving the union-arm's name-based `refArrElemName` /
  // `unionHasRefArrayArmSlot` lookup unable to find the reflist slot the literal interns — a silent
  // fall-through to scalar-boxing, invalid wasm). A PAREN-FREE name splits via `splitUnionAtoms`
  // (its legacy brace/bracket-depth behavior, kept byte-identical) and RETURNS — the descent below
  // is for non-union names. A PAREN-CARRYING name (`{f: (boolean | string)[]} | f64` — a struct arm
  // whose FIELD groups a union element) previously skipped arm interning entirely (`splitUnionAtoms`
  // is paren-blind, so a `(...)`-grouped arm mis-splits): its `{`-cored arm then interned only
  // LAZILY at emit, AFTER `collectA`'s type-index assignment, so the arm's ref-list FIELD element
  // (`boolean|string`) had no interned slot and `pushFieldStorage` read `rlWrapIdx` out of bounds —
  // a compiler CRASH (empty table) or a wrong wrapper. Split those on ALL-grouper depth (parens
  // included, so grouped arms stay whole), intern the `{`-cored arms, then FALL THROUGH to the
  // legacy paren descent (closure unions etc. keep their existing path).
  if !strContains(nm, "(") {
    const uArms: string[] = []
    splitUnionAtoms(nm, uArms)
    if uArms.length > 1 {
      internShapeArms(uArms)
      return 0
    }
  } else {
    const pArms: string[] = []
    splitUnionArmsAllDepth(nm, pArms)
    if pArms.length > 1 { internShapeArms(pArms) }
  }
  if nm.length > 2 && nm[nm.length - 2] == '[' && nm[nm.length - 1] == ']' {
    return internShapeDeep(nm.slice(0, nm.length - 2))
  }
  // A MAP name (`{[string]: V}`): the inline shapes buried in the VALUE position are
  // otherwise unreachable — the whole map is ONE TypeRef name, so a struct-valued map
  // (`{[string]: {f:f32}}`), a nested-map value (`{[string]: {[string]: i64}}`), a
  // struct value whose field is itself a map (`{[string]: {f: {[string]: i64}}}`), or
  // any list value hides its shape from `internInlineShape` (which no-ops on a map).
  // Descend into the value so its shapes intern — the mv-slot interner (`collectA` →
  // `mvShapeOfValName`) then finds the struct via `structIndexByValName` (position-
  // INDEPENDENT map-value resolution, the #837 template). A NAMED-alias value already
  // interned via its own TypeRef; this is the inline dual, idempotent for either.
  if nameIsMap(nm) { return internShapeDeep(mapValNameOf(nm)) }
  // A FUNCTION-TYPE name (`(p1,p2)=>ret`): the inline shapes buried in a PARAM or
  // the RESULT position are otherwise unreachable — the whole functype is ONE
  // TypeRef name, so a composite closure result (`(i32)=>{f:i32}`, `()=>{a:i32,b:i32}`,
  // `(i32)=>{f:{g:i32}}`) or a composite param hides its shape from
  // `internInlineShape`. A lambda's inferred return literal (`{f:x}` with a param
  // field value `anonFieldCode` codes -1) then has no interned shape to name-set
  // match, and the closure functype result fails loudly ("ref valtype with no
  // interned shape"). `internFuncTypeShapes` interns each PLAINLY-LOWERABLE shape
  // reached — see the soundness note there.
  if annArrowAt(nm) >= 1 && nm[0] == '(' { return internFuncTypeShapes(nm) }
  internInlineShape(nm) // no-op for any non-shape leaf
  0
}

// Whether field CODE `c` is a scalar / string / scalar-list / nested-struct field —
// the reps a struct lowers as a closure result/param WITHOUT touching an unsupported
// composite field (a typed-value MAP is R1, a value-UNION box is R3, a nullable/ref
// list is R5/R6). Nested-struct fields (code 15) are checked recursively at the
// `funcTypeShapeLowerable` leaf.
function funcTypeFieldCodeSafe(c: i32): boolean {
  c == 0 ||
    c == 3 ||
    c == 4 ||
    c == 6 ||
    c == 15 ||
    c == 17 ||
    c == 23 ||
    c == 24 ||
    c == 25 ||
    c == 26 ||
    c == 27
}

// True if `nm` is a NESTED array bottoming out at a SCALAR/STRING leaf list —
// `i32[][]` / `boolean[][]` / `K[][]` (kind 4), `string[][]` / `f64[][]` / `i64[][]` /
// `f32[][]` (kinds 6/7/8/10), or a deeper recursion over those (`i32[][][]`, kind 9
// whose element is itself such an array). NOT a struct/union/closure/map-element
// array (their leaf reps carry the R6/R3/R1 composition seams). The R4 leaf test the
// closure-result shape gate uses: such a field is a plain code-5 ref-list slot whose
// element machinery is fully interned by the `collectA` field pass (`ensureRefElem`).
export function nameIsNestedScalarLeafArray(nm: string): boolean {
  if !nameIsRefArray(nm) { return false }
  const k = refArrElemKind(nm)
  if k == 4 || k == 6 || k == 7 || k == 8 || k == 10 { return true }
  if k == 9 { return nameIsNestedScalarLeafArray(refArrElemName(nm)) }
  false
}

// True if `t` is a STRUCT-element array (`S[]`, `{g: f64}[]`) whose element itself
// lowers as a closure-result field: a declared plain struct name (NOT a union
// variant — its list rides the variant machinery), or an inline shape that
// recursively passes `funcTypeShapeLowerable`. The struct-through-list closure-result
// admission (R6): the element interns like any struct-field element (the code-5
// `ensureRefElem` pass), so the field is a plain ref-list slot. A union / map /
// closure / nullable element stays un-admitted (their reps carry the R1/R3/R5 seams).
function structElemArrayLowerable(t: string): boolean {
  if t.length < 3 || t[t.length - 2] != '[' || t[t.length - 1] != ']' {
    return false
  }
  const base = t.slice(0, t.length - 2)
  if base.length >= 2 && base[0] == '{' && base[1] != '[' {
    return funcTypeShapeLowerable(base)
  }
  nameIsStructDecl(base) && variantIndexOf(base) < 0
}

// Whether inline shape `nm` (`{f:i32,g:{h:i32}}`) lowers as a closure result/param
// with NO unsupported composite field, recursing through nested inline shapes (and
// their `| null`). A map / value-union / nullable-list / closure field makes it
// un-lowerable — those reps are R1/R3/R5, out of THIS slice, and the closure must
// stay a CLEAN reject (never invalid wasm), so the shape is not interned.
// A NESTED-array field with a scalar/string leaf (`{f: boolean[][]}` — code 5, but its
// element is a leaf LIST, no struct-through-list seam) IS lowerable: the field is a
// plain ref-list slot the field pass interns like any binding's (the R4 dissolution).
// A STRUCT-element list field (`{f: {g: f64}[]}` / `{f: S[]}`) is likewise lowerable
// when its element is (`structElemArrayLowerable`) — the element shape pre-interns in
// `internFuncTypeShapes` and the slot rides the same code-5 field pass.
function funcTypeShapeLowerable(nm: string): boolean {
  if nm.length < 2 || nm[0] != '{' || nm[1] == '[' || nm[nm.length - 1] != '}' {
    return false
  }
  const inner = nm.slice(1, nm.length - 1)
  let depth = 0
  let start = 0
  let k = 0
  let okAll = true
  let fieldCount = 0
  while k <= inner.length {
    const atEnd = k == inner.length
    let brk = false
    if !atEnd {
      const ch = inner[k]
      if ch == '{' || ch == '[' || ch == '(' { depth = depth + 1 }
      if ch == '}' || ch == ']' || ch == ')' { depth = depth - 1 }
      if ch == ',' && depth == 0 { brk = true }
    } else {
      brk = true
    }
    if brk {
      const part = inner.slice(start, k)
      const ci = part.indexOf(":")
      if ci <= 0 {
        okAll = false
      } else {
        const ftxt = part.slice(ci + 1, part.length)
        const fc = nameFieldCode(ftxt)
        if fc < 0 {
          // A NESTED inline-shape field (`g:{h:i32}` / `g:{h:i32}|null`): recurse
          // into the base shape — lowerable only if IT is.
          let base = ftxt
          const nb = nullablePartOf(base)
          if nb != "" { base = nb }
          if !funcTypeShapeLowerable(base) { okAll = false }
        } else if !funcTypeFieldCodeSafe(fc) {
          // A code-5 field whose type is a nested SCALAR-LEAF array (`f: boolean[][]`)
          // or a lowerable STRUCT-element array (`f: {g: f64}[]`, `f: S[]`) is a plain
          // ref-list slot — lowerable (see the header note). A code-19 MAP field whose
          // VALUE kind the mv interner represents (`mvValKindOfName != -3`) is likewise
          // lowerable: the field is a plain map-struct slot the `collectA` field pass
          // interns (`mvShapeOfValName`) exactly as for a non-closure struct field —
          // the R1 composition rep the original gate predated. A code-16 union-BOX
          // field whose union is REGISTERED (`isUName` — `registerInlineUnion`'s
          // functype-return descent registers a result shape's field unions in
          // `collectU`, before this gate runs from `internShapeDeep`) is a plain box
          // ref slot the same machinery a non-closure struct field uses. A code-22
          // NULLABLE-CLOSURE field (`f: (() => i64) | null`) is the shared
          // `(ref null $cloStruct)` fat-pointer slot — the SAME rep the field carries in
          // any non-closure-result struct, so the shape interns and the literal that
          // builds it name-set-matches THIS shape (un-interned, the literal self-coded
          // the field 14 — a non-null layout the code-22 reads then mis-cast). Any other
          // unsafe code keeps the shape un-interned (the clean closure reject).
          if (
            !(fc == 5 &&
              (nameIsNestedScalarLeafArray(ftxt) ||
              structElemArrayLowerable(ftxt))) &&
            !(fc == 19 && mvValKindOfName(mapValNameOf(ftxt)) != -3) &&
            !(fc == 16 && isUName(ftxt)) &&
            fc != 22
          ) {
            okAll = false
          }
        }
        fieldCount = fieldCount + 1
      }
      start = k + 1
    }
    k = k + 1
  }
  okAll && fieldCount > 0
}

// Whether the inline shape text `nm` (`{f: f32}`, `{a: i64, f: i64, z: boolean}`) will
// intern cleanly as a NESTED struct at the `collectA` phase — the PURE (intern-free)
// mirror of `internInlineShape`'s acceptance, usable during `collectU` (the struct
// table does not exist yet; `collectS`'s reset would wipe anything interned there).
// A field `nameFieldCode` can classify is accepted as-is; an unclassifiable field
// recurses into its own (`|null`-stripped) nested shape, exactly as the interner
// does. Acceptance here OBLIGATES the `collectA` variant-field pass to intern `nm`
// (idempotent), and is monotone-safe: union registration only grows between the two
// phases, so a field code can only improve from -1 — never the reverse.
export function variantNestedShapeOk(nm: string): boolean {
  if nm.length < 2 || nm[0] != '{' || nm[1] == '[' || nm[nm.length - 1] != '}' {
    return false
  }
  const inner = nm.slice(1, nm.length - 1)
  let depth = 0
  let start = 0
  let k = 0
  let okAll = true
  let fieldCount = 0
  while k <= inner.length {
    const atEnd = k == inner.length
    let brk = false
    if !atEnd {
      const ch = inner[k]
      if ch == '{' || ch == '[' || ch == '(' { depth = depth + 1 }
      if ch == '}' || ch == ']' || ch == ')' { depth = depth - 1 }
      if ch == ',' && depth == 0 { brk = true }
    } else {
      brk = true
    }
    if brk {
      const part = inner.slice(start, k)
      const ci = part.indexOf(":")
      if ci <= 0 {
        okAll = false
      } else {
        const ftxt = part.slice(ci + 1, part.length)
        if nameFieldCode(ftxt) < 0 {
          // A nested inline-shape field (`g: {h: i32}` / `g: {h: i32} | null`):
          // lowerable only if ITS shape is.
          let base = ftxt
          const nb = nullablePartOf(base)
          if nb != "" { base = nb }
          if !variantNestedShapeOk(base) { okAll = false }
        }
        fieldCount = fieldCount + 1
      }
      start = k + 1
    }
    k = k + 1
  }
  okAll && fieldCount > 0
}

// Intern the PLAINLY-LOWERABLE inline shapes buried in the params / result of a
// function-type name `nm` (`(i32)=>{f:i32}`, `({a:i32})=>{b:i32}`), peeling the
// grouping / nullable / array / nested-functype wrappers around each position. Only
// a fully-lowerable struct leaf (`funcTypeShapeLowerable`) is interned — a shape
// with an unsupported composite field (map / value-union / nullable-list) is LEFT
// un-interned so the closure stays a clean reject, exactly as before this slice
// (never invalid wasm). Idempotent (`annShapeIndexOf`); registers no value union
// and interns no map, so a functype over unsupported reps is byte-identical to the
// pre-slice behavior.
function internFuncTypeShapes(nm: string): i32 {
  if nm.length < 2 { return 0 }
  // Peel ONLY a grouping pair that wraps the WHOLE name (`(()=>{f:i32})` → `()=>{f:i32}`).
  // A functype whose leading `(` is its own PARAM LIST (`(i32)=>(()=>{f:i32})`) must NOT be
  // blind-peeled — that garbles the name (`i32)=>(()=>{f:i32}`) and the shapes buried in a
  // NESTED functype result never intern (a chained value call's struct read then finds no
  // interned shape).
  const uw = monoUnwrapParens(nm)
  if uw.length != nm.length { return internFuncTypeShapes(uw) }
  const np = nullablePartOf(nm)
  if np != "" { return internFuncTypeShapes(np) }
  if nm.length > 2 && nm[nm.length - 2] == '[' && nm[nm.length - 1] == ']' {
    return internFuncTypeShapes(nm.slice(0, nm.length - 2))
  }
  const fa = annArrowAt(nm)
  if fa >= 1 && nm[0] == '(' && nm[fa - 1] == ')' {
    const inner = nm.slice(1, fa - 1)
    if inner.length > 0 {
      const parts: string[] = []
      annSplitParams(inner, parts)
      let pi = 0
      while pi < parts.length {
        internFuncTypeShapes(parts[pi])
        pi = pi + 1
      }
    }
    return internFuncTypeShapes(nm.slice(fa + 2, nm.length))
  }
  if nm[0] == '{' && nm[1] != '[' && nm[nm.length - 1] == '}' {
    if funcTypeShapeLowerable(nm) {
      internShapeFieldElems(nm)
      internInlineShape(nm)
    }
  }
  0
}

// Pre-intern the inline-SHAPE leaves of `nm`'s array-typed fields (`{f: {g: f64}[]}`
// → intern `{g: f64}`), so `internInlineShape`'s code-5 arm resolves each element
// name (its raw-text fallback requires the element already interned — interning
// mid-field-loop would corrupt the flat `sField*` arrays). The functype twin of
// `collectNestedFieldShapes`' leaf strip: peel every trailing `[]` pair and intern a
// `{…}` leaf (`internInlineShape` no-ops on any other text). Runs only on a shape
// `funcTypeShapeLowerable` accepted, BEFORE the shape itself interns.
function internShapeFieldElems(nm: string) {
  const inner = nm.slice(1, nm.length - 1)
  let depth = 0
  let start = 0
  let k = 0
  while k <= inner.length {
    const atEnd = k == inner.length
    let brk = false
    if !atEnd {
      const ch = inner[k]
      if ch == '{' || ch == '[' || ch == '(' { depth = depth + 1 }
      if ch == '}' || ch == ']' || ch == ')' { depth = depth - 1 }
      if ch == ',' && depth == 0 { brk = true }
    } else {
      brk = true
    }
    if brk {
      const part = inner.slice(start, k)
      const ci = part.indexOf(":")
      if ci > 0 {
        let ftxt = part.slice(ci + 1, part.length)
        let peeled = false
        while (
          ftxt.length > 2 &&
          ftxt[ftxt.length - 2] == '[' &&
          ftxt[ftxt.length - 1] == ']'
        ) {
          ftxt = ftxt.slice(0, ftxt.length - 2)
          peeled = true
        }
        if peeled && ftxt.length >= 2 && ftxt[0] == '{' && ftxt[1] != '[' {
          internInlineShape(ftxt)
        }
      }
      start = k + 1
    }
    k = k + 1
  }
  0
}

// Intern the inline object-shape TEXT `nm` (`{x:i32}`, `{v:{x:i32}|null}`) as an
// anonymous struct shape, returning its struct table index — or -1 when `nm` is
// not an internable shape (a map `{[…]}`, a named type, a field with no code).
// A field whose type is itself an inline shape (`v:{x:i32}` / `v:{x:i32}|null`)
// RECURSES: the nested shape interns first, the field takes a nullable struct
// ref on it (code 15) — only a nested text with no code fails the whole shape.
// Idempotent per field-name+code set (`annShapeIndexOf`), so a literal-interned
// twin (`collectAnonShapes`) and a re-visited annotation share one entry.
export function internInlineShape(nm: string) {
  if nm.length < 2 { return -1 }
  if nm[0] != '{' || nm[1] == '[' || nm[nm.length - 1] != '}' { return -1 }
  const inner = nm.slice(1, nm.length - 1)
  // Split `x:i32,y:string` into names + codes at depth 0. `texts` keeps each
  // field's type TEXT (a code-16 union field interns its union and records the
  // name in `sFieldElemName`; a code-15 nested field records its base shape).
  const names: string[] = []
  const codes: i32[] = []
  const texts: string[] = []
  let ok = true
  let depth = 0
  let start = 0
  let k = 0
  while k <= inner.length {
    const atEnd = k == inner.length
    let brk = false
    if !atEnd {
      if inner[k] == '{' || inner[k] == '[' || inner[k] == '(' {
        depth = depth + 1
      }
      if inner[k] == '}' || inner[k] == ']' || inner[k] == ')' {
        depth = depth - 1
      }
      if inner[k] == ',' && depth == 0 { brk = true }
    } else {
      brk = true
    }
    if brk {
      const part = inner.slice(start, k)
      // part is `name:type` — split at the first `:`.
      const ci = part.indexOf(":")
      if ci <= 0 {
        ok = false
      } else {
        let ftxt = part.slice(ci + 1, part.length)
        // PRE-INTERN any inline shape / value union buried in the field type BEFORE classifying. A
        // nullable ref-list field (`{g:i32}[] | null` / `(i32|null)[] | null`, code 28) needs its element
        // shape interned (or value-union registered) for `nameFieldCode` to even recognize the non-null
        // part as a ref array. `internShapeDeep` peels array / nullable / grouping wrappers to the leaf and
        // interns/registers it; a no-op for a scalar / nominal / map field. MUST be the parse loop (the
        // outer shape is pushed to `sNames` only after this, so the flat `sField*` arrays aren't corrupted).
        internShapeDeep(ftxt)
        let fc = nameFieldCode(ftxt)
        if fc < 0 {
          // A NESTED inline-shape field: intern the nested shape (its `|null`
          // wrapper stripped) and store a struct ref on it.
          let base = ftxt
          const fnb = nullablePartOf(base)
          if fnb != "" { base = fnb }
          if internInlineShape(base) >= 0 {
            fc = 15
            ftxt = base
          }
        }
        if fc < 0 { ok = false }
        names.push(part.slice(0, ci))
        codes.push(fc)
        texts.push(ftxt)
      }
      start = k + 1
    }
    k = k + 1
  }
  if !ok || names.length == 0 { return -1 }
  const existing = annShapeIndexOf(names, codes, texts)
  if existing >= 0 { return existing }
  sDeclared = true
  // Interned under the ANNOTATION TEXT itself (`{v:i32}`) — a real key, so
  // `structIndexByName` on the annotation (or on a ref-list element name
  // `{v:i32}[]` → `{v:i32}`) resolves directly.
  sNames.push(nm)
  sFieldStart.push(sFieldNames.length)
  sFieldCount.push(codes.length)
  let pi = 0
  while pi < codes.length {
    sFieldNames.push(names[pi])
    sFieldTypes.push(codes[pi])
    forceScalarListField(codes[pi])
    if codes[pi] == 16 {
      // The union FIELD's name keys its atom set; registering it interns the
      // shared box + the value-box reps it needs (this runs after `collectU`,
      // but before any type-index math).
      sFieldElemName.push(texts[pi])
      registerValueUnionName(texts[pi])
    } else if codes[pi] == 15 {
      // The nested-struct field's TARGET name (`|null` stripped) — `emitObj`
      // seeds a nested literal to it, `structIndexByName`-resolvable.
      let b15 = texts[pi]
      const nb15 = nullablePartOf(b15)
      if nb15 != "" { b15 = nb15 }
      sFieldElemName.push(b15)
    } else if codes[pi] == 19 {
      // A MAP field records its VALUE type-name (`i32` of `{[string]: i32}`) — the mv-slot
      // interning key. The slot itself is interned in `collectA` (which resets `mvValName`,
      // so interning here would be wiped); the inner map of an inline `{m:{[string]:V}}` is
      // not a standalone TypeRef that `collectA`'s scan sees, so it interns code-19 FIELDS.
      sFieldElemName.push(mapValNameOf(texts[pi]))
    } else if codes[pi] == 29 {
      // A NULLABLE map field records the `| null`-stripped map's VALUE type-name — the
      // same mv-slot key as code 19, interned by the same `collectA` field loop.
      sFieldElemName.push(mapValNameOf(nulMapInnerName(texts[pi])))
    } else if codes[pi] == 5 {
      // A REF-LIST field (`f: N[]` / `f: (i32|null)[]`): record its element name (the CANONICAL ref-array
      // element name — parens stripped for a value-union element so it keys the same slot every other
      // union position uses), so `sFieldRefSlot` (`rlSlotByName`) finds the element's interned slot.
      // Without this an inline-shape ref-list field stored "" and the read failed to resolve the element.
      // A value-union element additionally interns its box reps here (the code-16 field parity).
      let e5 = refArrElemName(texts[pi])
      // A ref-list element that is itself an INLINE SHAPE (`{g:i32}[]`) is invisible to `refArrElemName`
      // until the shape is interned, so it returns "". The shape was pre-interned by
      // `collectNestedFieldShapes` (interning mid-field-loop would corrupt the flat `sField*` arrays), so
      // here just key it by its stripped text. A nominal / union / scalar element keeps `refArrElemName`.
      if e5 == "" {
        const raw5 = texts[pi].slice(0, texts[pi].length - 2)
        if structIndexByName(raw5) >= 0 { e5 = raw5 }
      }
      sFieldElemName.push(e5)
      if isValueUnionName(e5) { registerValueUnionName(e5) }
    } else if codes[pi] == 28 {
      // A NULLABLE ref-list field (`f: S[] | null`): its element name is the ref-array element of the
      // non-null part; the element shape/union was pre-interned in the parse loop (`internShapeDeep`).
      let e28 = refArrElemName(nullablePartOf(texts[pi]))
      if e28 == "" {
        let raw28 = nullablePartOf(texts[pi])
        if raw28.length > 2 { raw28 = raw28.slice(0, raw28.length - 2) }
        if structIndexByName(raw28) >= 0 { e28 = raw28 }
      }
      sFieldElemName.push(e28)
      if isValueUnionName(e28) { registerValueUnionName(e28) }
    } else if codes[pi] == 0 && nameIsLitUnionType(texts[pi]) {
      // A literal-union atom FIELD (code 0): record its union name so construction/read/assign
      // recover the atom rep + membership (`sFieldIsLitUnion`).
      sFieldElemName.push(texts[pi])
    } else if codes[pi] == 4 && nameIsLitUnionArray(texts[pi]) {
      // An ATOM-ARRAY field (`f: K[]`, code 4): record the array type-name so
      // `sFieldIsLitUnionArray` seeds the atom-element context at construct/assign
      // (and `collectA`'s field-table pass forces the i32 list types off it).
      sFieldElemName.push(texts[pi])
    } else if codes[pi] == 30 {
      // A NULLABLE-litunion niche field (`f: K | null`, code 30): record the
      // non-null union name so membership/atom recovery mirrors the code-0 field.
      sFieldElemName.push(nulLitUnionInnerName(texts[pi]))
    } else {
      sFieldElemName.push("")
    }
    pi = pi + 1
  }
  sNames.length - 1
}

// Intern the inline shape name `nm` (`{a:i32,b:i32}`) as the NAMED struct
// `key` — the same field parsing as `collectAnnShapes`, but keyed under the
// alias name so `structIndexByName(key)` resolves params/locals/literals.
export function internShapeAs(key: string, nm: string) {
  const inner = nm.slice(1, nm.length - 1)
  const names: string[] = []
  const codes: i32[] = []
  let depth = 0
  let start = 0
  let k = 0
  while k <= inner.length {
    const atEnd = k == inner.length
    let brk = false
    if !atEnd {
      if inner[k] == '{' || inner[k] == '[' || inner[k] == '(' {
        depth = depth + 1
      }
      if inner[k] == '}' || inner[k] == ']' || inner[k] == ')' {
        depth = depth - 1
      }
      if inner[k] == ',' && depth == 0 { brk = true }
    } else {
      brk = true
    }
    if brk {
      const part = inner.slice(start, k)
      const ci = part.indexOf(":")
      if ci <= 0 { return emitFail("emitProgram: malformed struct field") }
      const fc = nameFieldCode(part.slice(ci + 1, part.length))
      if fc < 0 {
        return emitFail(
          "emitProgram: only i32 / boolean / string / array struct fields are supported",
        )
      }
      names.push(part.slice(0, ci))
      codes.push(fc)
      start = k + 1
    }
    k = k + 1
  }
  if names.length == 0 {
    return emitFail("emitProgram: empty struct alias shape")
  }
  sDeclared = true
  sNames.push(key)
  sFieldStart.push(sFieldNames.length)
  sFieldCount.push(codes.length)
  let pi = 0
  while pi < codes.length {
    sFieldNames.push(names[pi])
    sFieldTypes.push(codes[pi])
    sFieldElemName.push("")
    pi = pi + 1
  }
  0
}

// The struct table index whose field-name SET matches `names` exactly, or -1.
function annShapeIndexOf(names: string[], codes: i32[], texts: string[]) {
  let si = 0
  while si < sNames.length {
    if sFieldCount[si] == names.length {
      let allIn = true
      let i = 0
      while i < names.length {
        const fi = sFieldIndex(si, names[i])
        if fi < 0 {
          allIn = false
        } else if sFieldTypeAt(si, fi) != codes[i] {
          // The same field-NAME set with a DIFFERENT field type (`{y:i32}` vs
          // `{y:string|i32}`) is a DISTINCT shape — intern it separately so each
          // annotation resolves its own struct (host: structural interning).
          allIn = false
        } else {
          // Same field name AND code, but a REF field (nested struct / union / …) with a DIFFERENT
          // ELEMENT type is STILL a distinct shape. Without this, `{f:{f:i32}}` and `{f:{f:{f:i32}}}`
          // — both field `f`, code 15 — wrongly dedup (the recursion produces identical name+code at
          // every level when field names repeat). Compare the stored element name to this field's
          // element text (code 15 strips the `|null` wrapper exactly as the interner stores it).
          const en = sFieldElemNameAt(si, fi)
          if en != "" {
            let bi = texts[i]
            if codes[i] == 15 {
              const nbi = nullablePartOf(bi)
              if nbi != "" { bi = nbi }
            }
            if en != bi { allIn = false }
          }
        }
        i = i + 1
      }
      if allIn { return si }
    }
    si = si + 1
  }
  -1
}

// The registry slot of generic-alias base `name`, or -1.
function gaeIndexOf(name: string) {
  let i = 0
  while i < gaeBases.length {
    if gaeBases[i] == name { return i }
    i = i + 1
  }
  -1
}

// Intern the application `name` ("Box<i32>") as a struct shape, once. A field
// the emitter cannot type (an unbound param, an unsupported shape) leaves the
// application un-interned — its use then fails loudly downstream, never a trap.
export function gaeEnsure(name: string) {
  if name.length < 3 { return 0 }
  if name[name.length - 1] != '>' { return 0 }
  const ltAt = gaeLtAt(name)
  if ltAt <= 0 { return 0 }
  if structIndexByName(name) >= 0 { return 0 }
  const gi = gaeIndexOf(name.slice(0, ltAt))
  if gi < 0 { return 0 }
  const pnames: string[] = []
  gaeSplitArgs(gaeParams[gi], pnames)
  const args: string[] = []
  gaeSplitArgs(name.slice(ltAt + 1, name.length - 1), args)
  if args.length != pnames.length { return 0 }
  const names: string[] = []
  const codes: i32[] = []
  const elems: string[] = []
  let ok = true
  const fs = gaeFieldStart[gi]
  const fc = gaeFieldCount[gi]
  let fi = 0
  while fi < fc {
    const tn = gaeApplyFieldTy(gaeFieldTyNames[fs + fi], pnames, args)
    // A field that is ITSELF an application (or an array of one) interns
    // depth-first, so the ref/elem lookups below resolve.
    let base = tn
    while (
      base.length > 2 &&
      base[base.length - 2] == '[' &&
      base[base.length - 1] == ']'
    ) {
      base = base.slice(0, base.length - 2)
    }
    gaeEnsure(base)
    let code = nameFieldCode(tn)
    let elem = ""
    if code < 0 {
      // An interned application name is a struct-ref field (`nameFieldCode`
      // only consults TypeDecl names, which an application is not).
      if structIndexByName(tn) >= 0 {
        code = 15
        elem = tn
      }
    } else if code == 15 {
      const nb = nullablePartOf(tn)
      if nb != "" { elem = nb } else { elem = tn }
    } else if code == 5 {
      elem = tn.slice(0, tn.length - 2)
    } else if code == 16 {
      elem = tn
      registerValueUnionName(tn)
    } else if code == 4 && nameIsLitUnionArray(tn) {
      // An ATOM-ARRAY field of a generic instance (`f: K[]`) — same recording as the
      // inline-shape path, so `sFieldIsLitUnionArray` covers monomorphized shapes.
      elem = tn
    }
    if code < 0 { ok = false }
    names.push(gaeFieldNames[fs + fi])
    codes.push(code)
    elems.push(elem)
    fi = fi + 1
  }
  if !ok { return 0 }
  if names.length == 0 { return 0 }
  sDeclared = true
  sNames.push(name)
  sFieldStart.push(sFieldNames.length)
  sFieldCount.push(codes.length)
  let pi = 0
  while pi < codes.length {
    sFieldNames.push(names[pi])
    sFieldTypes.push(codes[pi])
    sFieldElemName.push(elems[pi])
    pi = pi + 1
  }
  0
}

// ── literal-union ATOMS (`type K = "a" | "b"`) ────────────────────────────────
// A literal-union value is an INTERNED i32 id: each distinct member STRING (interned lazily by its raw
// `StrLit` text) gets one id. The literal members come from the CHECKER (which preserves them); the
// emit-side `udVariants` are widened to `"string"` and must NOT be used. Slice 1: scalar atoms + `==`.
let litAtomId: {[string]: i32} = Map()

let litAtomNext: i32 = 0

// Seeded around a literal-union BOUNDARY (binding init / `==` operand) so a member `StrLit` lowers as its
// interned i32 id instead of a string. The atom analogue of `pendingNulString`.
export let pendingLitUnion: i32 = 0

// Whether the module uses ANY literal-union type (named or inline). Set ONCE per program by a single
// `P.nodes` scan; every per-node litunion detector (`exprIsLitAtom`, the `*WidensAtomToStr` predicates)
// early-outs on it, so a program with no literal unions — e.g. the self-hosted compiler — pays none of
// the per-node atom-detection cost during the str-op scan / classification.
let gLitUnionUsed: i32 = 0

export function resetLitAtoms() {
  litAtomId = Map()
  litAtomNext = 0
  gLitUnionUsed = 0
  if anyLitUnionUsed() { gLitUnionUsed = 1 }
  0
}

export function internAtom(text: string) {
  if litAtomId.has(text) {
    const got = litAtomId[text] ?? 0
    return got
  }
  const id = litAtomNext
  litAtomId[text] = id
  litAtomNext = id + 1
  id
}

// True if the binding/global at `letIx` is annotated with a literal-union type (an i32-backed atom).
export function letIsLitUnion(letIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const r = nodeTyIsLitUnionAlias(d.letType)
      return r
    }
  }
  false
}

// True if the binding at `letIx` is UN-annotated and its initializer is a literal-union ATOM —
// e.g. `const sk = xs[i]` over a `K[]`, or `const k2 = k` off an atom local. Such a local holds
// an i32 atom id, so it must be the i32 atom slot (kind 0 + `localLitUnion`), NOT the `string`
// ref slot its checker type (a `string` subtype) would otherwise pick — which stores the i32
// atom into a `(ref $array)` cell (invalid wasm). The init-side dual of `letIsLitUnion`.
export function letInitIsLitAtom(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType < 0 && d.letInit >= 0 { return exprIsLitAtom(d.letInit, fnIx) }
  }
  false
}

// True if `exprIx` is a literal-union ATOM VALUE (an i32 id) — a litunion-flagged local or a litunion-
// annotated param. Distinguishes a real atom from a checker-inferred literal union (which is a string).
export function exprIsLitAtom(exprIx: i32, fnIx: i32) {
  if gLitUnionUsed == 0 { return false }
  // A `K | null` NICHE binding/call (param / local / global / `K|null`-returning call) holds an i32
  // atom id (or the `-1` null sentinel). In any position that consumes it AS an atom — a `print`
  // widen, a litunion-param arg, a member compare — the checker has narrowed it non-null, so it is a
  // valid atom. The narrowed member texts come from the node's narrowed type (`nodeLitUnionMemberTexts`).
  if exprNulLitUnion(exprIx, fnIx) { return true }
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Ident {
    const slot = declaredSlotOf(e.identName)
    if slot >= 0 && slot < localLitUnion.length {
      if localLitUnion[slot] == 1 { return true }
    }
    const pt = paramTypeNode(fnIx, e.identName)
    if pt >= 0 {
      const r = nodeTyIsLitUnionAlias(pt)
      return r
    }
    const gli = globalLetOf(e.identName)
    if gli >= 0 {
      // An annotated `: K` global OR an UN-annotated global whose init is an atom
      // (`const r = pick(ks)` / `const r = ks[0]`) — the global dual of the
      // `localLitUnion` init classification `collectLocals` applies (`letInitIsLitAtom`),
      // so a `print(r)` widens the atom to its member string instead of printing the raw id.
      return letIsLitUnion(gli) || letInitIsLitAtom(gli, -1)
    }
  }
  if e is Index {
    // `xs[i]` over a literal-union ARRAY yields an atom element (the array's i32 backing holds ids).
    const r = nodeArrayElemIsLitUnion(e.idxArr)
    return r
  }
  if e is IfStmt {
    // A VALUE if-expression joining two ATOMS (`if c then k else k2`) yields an atom —
    // the join rep is the bare i32 id, so the binding/print classifiers must see through
    // it. Both arms must be atoms; a mixed atom/string join types `string` (its atom arm
    // widens at the string-join seam), so it deliberately does NOT classify here.
    if e.ifElse < 0 { return false }
    const tb = P.nodes[e.ifThen]
    if tb is Block {
      if tb.blkStmts.length == 1 {
        if exprIsLitAtom(tb.blkStmts[0], fnIx) {
          const eb = P.nodes[e.ifElse]
          // An `else if` chain recurses on the nested IfStmt directly.
          if eb is IfStmt { return exprIsLitAtom(e.ifElse, fnIx) }
          if eb is Block {
            if eb.blkStmts.length == 1 {
              return exprIsLitAtom(eb.blkStmts[0], fnIx)
            }
          }
        }
      }
    }
    return false
  }
  if e is Member {
    // `t0.f` reading a literal-union atom FIELD through a NARROWED union receiver
    // (`t0 is {f: K0} { print(t0.f) }`) or a variant-typed receiver yields the atom —
    // the variant-table twin of the struct-receiver case below (the `memFieldTypeCode`
    // dispatch order). Without it the read printed the raw atom id.
    const mIxA = unwrapParen(exprIx)
    let mviA = -1
    if memIsNarrowed(mIxA) {
      mviA = memNarrowVariantIndex(mIxA)
    } else {
      mviA = exprVariantIndex(e.memObj, fnIx)
    }
    if mviA >= 0 {
      const mvfiA = variantFieldIndex(mviA, e.memProp)
      if mvfiA >= 0 && variantFieldTypeAt(mviA, mvfiA) == 0 {
        const rv = nameIsLitUnionType(variantFieldElemName(mviA, mvfiA))
        return rv
      }
    }
    // `b.kind` reading a literal-union atom FIELD yields the atom.
    const msi = structIndexOfExpr(e.memObj, fnIx)
    if msi >= 0 {
      const mfi = sFieldIndex(msi, e.memProp)
      if mfi >= 0 {
        const r = sFieldIsLitUnion(msi, mfi)
        return r
      }
    }
  }
  if e is Call {
    // ANY call whose CHECKED result type is an aliased litunion holds an i32 atom (its functype
    // result reps i32, the rep #843 established) — widen at print. Covers a closure VALUE call
    // (`v(0)`), a struct-field closure call (`s.f.f(0)`), and an indexed-closure call, none of
    // which the callee-Ident named arm below can reach. A NAMED call to an INLINE-litunion-returning
    // function reps as a string ref, so `nodeTyIsLitUnionAlias` (alias-only) correctly excludes it.
    if nodeTyIsLitUnionAlias(unwrapParen(exprIx)) { return true }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const target = fnIndexOf(callee.identName)
      if target >= 0 {
        const cf = P.nodes[fnStmts[target]]
        if cf is FuncDecl {
          if cf.fnRet >= 0 {
            const r = nodeTyIsLitUnionAlias(cf.fnRet)
            return r
          }
        }
      }
    }
  }
  if e is BinExpr {
    // `m[k] ?? d` over an ATOM-valued map yields the atom — the mono vals list holds
    // ids, so the fused get's result is a real i32 atom (like an atom array element).
    if e.binOp == "??" {
      const bl = P.nodes[unwrapParen(e.binLeft)]
      if bl is Index { return nodeTyMapValIsLitUnion(bl.idxArr) }
    }
  }
  false
}

// The ELEMENT/TARGET name a shape-text field records in `uFieldElemName`: a
// ref-list field its element name, a nested-struct field its (non-null) target
// name, a value-union field its atom-set name; "" otherwise.
export function shapeFieldElemName(ftxt: string, code: i32) {
  if code == 5 {
    const e5 = refArrElemName(ftxt)
    if e5 != "" { return e5 }
    // A NAMED-struct/union or inline-shape element (`S[]`, `{f: f64}[]`) is invisible
    // to `refArrElemName` while the struct/union tables are still empty (`collectU`
    // registers shape-text variants BEFORE `collectS`/`collectAnnShapes` run). The
    // stripped element text IS the canonical slot key for exactly those spellings
    // (the table-independent element sorts — paren-union / closure / map / scalar-2D
    // — already resolved above), so record it DEFERRED; `collectA`'s variant field
    // pass interns the element (`ensureRefElem`) once the tables exist.
    if nameIsArray(ftxt) { return ftxt.slice(0, ftxt.length - 2) }
    return ""
  }
  if code == 15 {
    const nb = nullablePartOf(ftxt)
    if nb != "" { return nb }
    return ftxt
  }
  if code == 16 { return ftxt }
  // A NULLABLE REF-LIST field (code 28, `S[] | null`): the ref-array element of the
  // non-null part — the shape-text mirror of `fieldRefElemName`'s code-28 arm, with
  // the same deferred-intern fallback the code-5 arm uses for a not-yet-registered
  // struct/union element (`collectA`'s variant field pass interns it once tables exist).
  if code == 28 {
    const b28 = nullablePartOf(ftxt)
    const e28 = refArrElemName(b28)
    if e28 != "" { return e28 }
    if nameIsArray(b28) { return b28.slice(0, b28.length - 2) }
    return ""
  }
  // A MAP-typed field (code 19) records its VALUE type-name — the mv-slot key, the
  // shape-text mirror of `fieldRefElemName`'s code-19 arm. Without it a shape-text
  // union VARIANT with a map field (`{f: {[string]: i32}} | i32`) recorded "" and
  // every op site then failed the loud slot find (the R1 map-in-union-arm seam).
  if code == 19 { return mapValNameOf(ftxt) }
  // A NULLABLE map field (code 29): the `| null`-stripped map's value name — same key.
  if code == 29 { return mapValNameOf(nulMapInnerName(ftxt)) }
  // A literal-union ATOM field (code 0 named `K`) / ATOM-ARRAY field (code 4 named `K[]`)
  // records its union (array) name, so the variant tables recover the atom rep + membership
  // exactly as `sFieldElemName` does (`internInlineShape` / `collectS` parity) — without it a
  // union-arm struct field `{f: K0} | i64` stored "" and construction emitted the raw member
  // string ref into the i32 atom slot.
  if code == 0 && nameIsLitUnionType(ftxt) { return ftxt }
  if code == 4 && nameIsLitUnionArray(ftxt) { return ftxt }
  if code == 4 { return "" }
  // A NULLABLE-litunion niche field (code 30): the non-null union name, the
  // code-0 recording over the `| null`-stripped part.
  if code == 30 { return nulLitUnionInnerName(ftxt) }
  ""
}

// The wasm-type code (`0` i32, `3` string) of variant `vi`'s field at field index `fi`.
export function variantFieldTypeAt(vi: i32, fi: i32) {
  uFieldTypes[uFieldStart[vi] + fi]
}

// The ref-list table SLOT of variant `vi`'s ref-list field `fi`, or -1 if not a ref list.
export function variantFieldRefSlot(vi: i32, fi: i32) {
  rlSlotByName(uFieldElemName[uFieldStart[vi] + fi])
}

// The ELEMENT/atom-set NAME recorded for variant `vi`'s field `fi` — a union-box field
// (code 16) records its atom-set name (the key `emitUnionCoerce` boxes against), a
// ref-list its element name, a nested-struct its target. "" for a plain scalar field.
export function variantFieldElemName(vi: i32, fi: i32) {
  uFieldElemName[uFieldStart[vi] + fi]
}

// ── Canonical layout twins, VARIANT slot layer (roadmap repOf, slot layer) ────
// Two union-variant slots share ONE variant-struct WasmGC heap type under the
// struct template's two-layer discipline: the canonical structural key of the
// variant's TYPE (its name — a declared alias or an inline `{…}` shape —
// resolved through the checker, `repNameCanonKey`), then a layout guard over
// the emitted field storage (`variantFieldLayoutEq`): per-field CODE equality
// plus, for the codes whose storage references another interned heap type, twin
// equivalence of the referenced layer — a ref-list field (5) via
// `rlSlotsLayoutTwin`, a nested-struct field (15) via `repStructSlotsTwin`, a
// map field (19) via the canonical map-value representative. Fixed-storage
// codes (scalars, string, the shared union box / closure / scalar-list
// wrappers) need only the code. The SAME variant name declared into two unions
// (`type U = Cat | Dog` / `type V = Cat | Bird` both pushing `Cat`) is the
// degenerate twin (equal keys, equal fields); structural twins (`Cat`/`Kot`, a
// declared name vs its inline `{…}` spelling) dedup the same way.

// The per-field storage layout guard (the `structFieldCodesEq` analogue).
function variantFieldLayoutEq(a: i32, b: i32): i32 {
  if uFieldCount[a] != uFieldCount[b] { return 0 }
  let fi = 0
  while fi < uFieldCount[a] {
    const ca = uFieldTypes[uFieldStart[a] + fi]
    if ca != uFieldTypes[uFieldStart[b] + fi] { return 0 }
    if ca == 5 || ca == 28 {
      // Code 28 (`<ref-array> | null`) stores through the same per-slot wrapper as a
      // plain ref-list field — twin equivalence is the same referenced-layer guard.
      if (
        rlSlotsLayoutTwin(
          variantFieldRefSlot(a, fi),
          variantFieldRefSlot(b, fi),
        ) ==
        0
      ) {
        return 0
      }
    } else if ca == 15 {
      if (
        repStructSlotsTwin(
          structIndexByName(uFieldElemName[uFieldStart[a] + fi]),
          structIndexByName(uFieldElemName[uFieldStart[b] + fi]),
        ) ==
        0
      ) {
        return 0
      }
    } else if ca == 19 {
      const ma = mvSlotOfMapValNameOrMono(uFieldElemName[uFieldStart[a] + fi])
      const mb = mvSlotOfMapValNameOrMono(uFieldElemName[uFieldStart[b] + fi])
      let mOk = false
      if ma == -1 && mb == -1 { mOk = true }
      if ma >= 0 && mb >= 0 {
        if mvCanonRepOf(ma) == mvCanonRepOf(mb) { mOk = true }
      }
      if !mOk { return 0 }
    }
    fi = fi + 1
  }
  1
}

// Populate `uVarTwin` (parallel to `uVariants`): `uVarTwin[i]` is the smallest
// earlier layout twin, or `i` itself when `i` is the first of its layout. Keys
// are computed ONCE up front (`buildStructTwins` discipline — the compiler's own
// unions carry hundreds of variants, so a per-pair key recomputation is the
// audit's hot-path anti-pattern); a non-participating slot ("" key — an
// unresolvable spelling) is always its own representative. Called from
// `mAssignTypeIndices` before the variant heap indices allocate.
export function buildVariantTwins() {
  const keys: string[] = []
  let i = 0
  while i < uVariants.length {
    keys.push(repNameCanonKey(uVariants[i]))
    i = i + 1
  }
  uVarTwin = []
  i = 0
  while i < uVariants.length {
    let rep = i
    if keys[i] != "" {
      let j = 0
      while j < i {
        if keys[j] == keys[i] && variantFieldLayoutEq(j, i) == 1 {
          rep = j
          j = i // stop at the first (smallest) twin
        }
        j = j + 1
      }
    }
    uVarTwin.push(rep)
    i = i + 1
  }
}

// The structural signature of variant `vi` — its field names joined with `,` (a
// stable per-shape key). Two variants with the same field-name set share a sig (and
// so, under structural typing, are the same variant — `docs/unions.md`); the slice's
// AST-style unions use DISTINCT field-name prefixes per variant, so every sig differs.
export function variantSig(vi: i32) {
  let out = ""
  const start = uFieldStart[vi]
  const cnt = uFieldCount[vi]
  let j = 0
  while j < cnt {
    if j > 0 { out = out + "," }
    out = out + uFieldNames[start + j]
    j = j + 1
  }
  out
}

// The GLOBALLY-stable tag of a value-union atom: every struct variant takes the
// dense ranks `0 .. uVariants.length-1` (`assignTags`), so atom kinds claim the
// fixed slots above them. Stable across every union in the module (mirroring the
// host's interned `tagOf(variantKey)` global table), so a value boxed as
// `string | i32 | boolean` keeps its tag inside the sub-union `string | i32`.
export function scalarTagOf(atom: string) {
  uVariants.length + valueAtomKind(atom)
}

// The globally-stable tag of the REF-ELEMENT-ARRAY arm whose interned reflist slot is `slot`.
// Value-atom tags fill the fixed band `uVariants.length + 0..12` (the `valueAtomKind` codes —
// scalar/string/null/scalar-list/closure), so ref-array arms claim the band ABOVE it. Ref-array
// and MAP arms can coexist in one union (`S[] | {[string]: i32}`) with INDEPENDENT intern-slot
// tables, so the two bands interleave by PARITY to stay collision-free: ref-arrays take the
// offsets `uVariants.length + 13 + 2*slot`, maps the opposite-parity offsets (`mapSlotTag`). A
// distinct element type interns a distinct reflist slot (`rlSlotByName`), so it gets a distinct,
// deterministic tag stable across every sub-union (mirroring `scalarTagOf`). The `+ 13` clears
// the value-atom band.
export function refArrSlotTag(slot: i32) { uVariants.length + 13 + slot * 2 }

// The tag of a ref-element-array union ARM by its type NAME (`S[]`, `(() => f64)[]`,
// `(C | D)[]`), or -1 when the arm's reflist slot was never interned (a mis-registered
// union — a loud caller failure, never a silent wrong tag).
export function refArrTagOf(atom: string) {
  const slot = rlSlotByName(refArrElemName(atom))
  if slot < 0 { return -1 }
  refArrSlotTag(slot)
}

// The globally-stable tag of the MAP arm whose interned map value-slot is `slot` (the mono i32 /
// atom map rides slot `-1`, its shared `$mStructIdx`). Maps claim the offsets of the band above
// the value-atom band — `uVariants.length + 16 + 2*slot` — parity-interleaved with the ref-array
// band (`refArrSlotTag`) so a union carrying BOTH a ref-array and a map arm never collides. The
// `slot+1` shift (folded into `16 = 13 + 3`) maps the mono `-1` slot to the first offset (`+14`),
// typed value slots to `+16`, `+18`, … A distinct map VALUE type interns a distinct mv slot
// (`mvShapeOfValName`), so it gets a distinct, deterministic, sub-union-stable tag.
// The slot canonicalizes through `mvCanonRepOf` first: layout-TWIN value spellings
// (`{[string]: A}` boxed, `is {[string]: {v: i32}}` tested) share one map-struct heap
// type (`mAssignTypeIndices`), so they must share ONE tag — keying the tag on the
// nominal slot would make the `is` compare miss its own twin-spelled value.
export function mapSlotTag(slot: i32) {
  let s = slot
  if s >= 0 { s = mvCanonRepOf(s) }
  uVariants.length + 16 + s * 2
}

// The tag of a map union ARM by its type NAME (`{[string]: string}`, `{[string]: i32}`), keyed on
// its map VALUE's interned mv slot (`-1` for a mono/atom value). Non-failing: an un-interned value
// resolves to the mono slot, so a map arm the union failed to register would tag as the mono map
// rather than trap — a mis-registration is a loud caller failure at boxing/`is` time, not here.
export function mapTagOf(atom: string) {
  mapSlotTag(mvSlotOfMapValNameOrMono(mapValNameOf(atom)))
}

// The interned VALUE-BOX heap-type index for a scalar atom (`boolean` shares the
// i32 box — same wasm rep), or -1 for `string`/`null` (no inner box: a string ref
// is already an `anyref` subtype; a null payload is `ref.null`).
export function vbHeapIdxOfAtom(atom: string) {
  const k = valueAtomKind(atom)
  if k == 0 || k == 1 { return vbI32Idx }
  if k == 3 { return vbI64Idx }
  if k == 4 { return vbF64Idx }
  if k == 5 { return vbF32Idx }
  // k == 2 (string) / 7..10, 12 (lists) / 11 (closure) ride the box anyref directly —
  // no per-rep scalar box (see `atomIsRef`).
  -1
}

// Register the VALUE union `name` in the per-union table (no variant structs —
// its atoms tag via `scalarTagOf`, its payloads ride the shared value boxes).
// Idempotent; a non-value-union name is a no-op. Callable from any collection
// phase (it reads no statement table) — `collectAnnShapes` registers a union
// FIELD's atom set through it after `collectU` has run.
export function registerValueUnionName(name: string) {
  if isUName(name) { return 0 }
  // A value union with a litunion-ALIAS arm (`K0 | i64`) registers here too: the alias
  // arm rides the box as its member-string atom (tag `string`, the litunion box rep), so
  // the union is value-box-shaped even though `valueAtomKind("K0")` is -1 — without the
  // registration its scalar arms' value boxes are never minted and a boxed return emits
  // a raw scalar into the box anyref (invalid wasm).
  if !isValueUnionName(name) && !nameIsLitUnionArmValueUnion(name) { return 0 }
  uDeclared = true
  unNames.push(name)
  unMemberSet.push(name)
  unVarStart.push(uVariants.length)
  unVarCount.push(0)
  markValueUnionAtoms(name)
  0
}

// Mark the per-rep value-box usage flags for every scalar atom of the value union
// `name` (registration-time, so `mAssignTypeIndices` interns exactly the used reps).
export function markValueUnionAtoms(name: string) {
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  let i = 0
  while i < atoms.length {
    const k = valueAtomKind(atoms[i])
    if k == 0 || k == 1 { vbI32Used = true }
    // A STRING member rides the box's anyref `value` as the raw string-array ref (`$aTypeIdx`),
    // so force that array type even when the module CONSTRUCTS no string (`string | i32 = 42`):
    // the narrowed string read's `ref.cast $aTypeIdx` is emitted (dead in the i32 branch, but it
    // must still VALIDATE) and without the type allocated the cast pointed at a bogus heap index.
    if k == 2 { aUsed = true }
    if k == 3 { vbI64Used = true }
    if k == 4 { vbF64Used = true }
    if k == 5 { vbF32Used = true }
    // A LIST member (codes 7..10, 12) forces its list type so the wrapper heap the box
    // payload rides exists — the union annotation alone may be the only mention of that
    // list type.
    if k == 7 {
      lUsed = true
      aUsed = true
    }
    if k == 8 { fa64Used = true }
    if k == 9 {
      slUsed = true
      aUsed = true
    }
    if k == 10 { ia64Used = true }
    if k == 12 { fa32Used = true }
    // A CLOSURE member (code 11) rides the box anyref as the `$cloStructIdx` fat-pointer —
    // force the closure rec-group types so that heap type exists (the union annotation may be
    // the only mention of a function value in the program), the string/list analogue above.
    if k == 11 { fnValUsed = true }
    // A litunion-ALIAS member (`K0` in `K0 | i64`) rides the box anyref as its member-STRING
    // ref (the litunion box rep), so force the string array type exactly like a `string`
    // member — the narrowed `is K0` read's `ref.cast $aTypeIdx` must validate even when the
    // module constructs no string.
    if k < 0 && nameIsLitUnionType(atoms[i]) { aUsed = true }
    i = i + 1
  }
  0
}

// Intern the reflist wrapper slot for every REF-ELEMENT-ARRAY arm of the union `name` (`S[]`,
// `(() => f64)[]`, `(C | D)[]`) — its box payload rides that wrapper ref, and `refArrTagOf`
// needs the slot to exist. The ref-array analogue of `markValueUnionAtoms` (which marks the
// scalar arms' value-box reps). `internShapeDeep` first interns any INLINE-shape element struct
// (`{a: f32}[]`) so `refArrElemName`/`ensureRefElem` resolve it; then `ensureRefElem` interns
// the element's reflist slot (recursively for a nested `S[][]`). Gated on a NON-value array atom
// (`valueAtomKind < 0`), so scalar-element lists (`i32[]`, kinds 7-10 — `markValueUnionAtoms`
// owns those) are skipped. A no-op for a union with no ref-array arm; called from BOTH the inline
// and named registration paths so the two spellings intern identically.
export function markRefArrayArms(name: string) {
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  let i = 0
  while i < atoms.length {
    const a = atoms[i]
    if a != "null" && valueAtomKind(a) < 0 && nameIsArray(a) {
      internShapeDeep(a)
      const elem = refArrElemName(a)
      if elem != "" {
        ensureRefElem(elem)
        // Force the ref-list flags so the backing/wrapper heaps emit and the index/`.length`
        // machinery is enabled — a ref-array mentioned ONLY as a union arm (`S[] | {w:i32}`)
        // otherwise leaves `raUsed`/`rlUsed` false and the narrowed `x[i]` read fails "ref array
        // type not collected". The union-arm analogue of the array-literal / ref-array-local flips.
        rlUsed = true
        raUsed = true
      }
    }
    i = i + 1
  }
  0
}

// Intern the map value-slot for every MAP arm of the union `name` (`{[string]: string}`,
// `{[string]: () => boolean}`) — its box payload rides that arm's map STRUCT ref, and `mapTagOf`
// needs the slot to exist. The map analogue of `markRefArrayArms` / `markValueUnionAtoms`. Forces
// the shared map heap flags (`mUsed`/`lUsed`/`aUsed` — the mono `$mStructIdx` + its key/val lists)
// and interns the arm's VALUE shape via `mvShapeOfValName` (recursively, for a typed/ref/closure
// value), exactly the `ensureRefElem` kind-3 (map element) path. A mono/atom value interns no slot
// (rides `-1`); a typed value gets a distinct mv slot → a distinct `mapSlotTag`. A no-op for a union
// with no map arm; called from BOTH the inline and named registration paths so the two spellings
// intern identically. Runs in `collectA` too (the AUTHORITATIVE re-intern after the mv-table reset).
export function markMapUnionArms(name: string) {
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  let i = 0
  while i < atoms.length {
    const a = atoms[i]
    if a != "null" && nameIsMap(a) {
      mUsed = true
      lUsed = true
      aUsed = true
      mvShapeOfValName(mapValNameOf(a))
    }
    i = i + 1
  }
  0
}

// Force the shared map machinery + intern the mv value slot of a MAP reached only as
// a CLOSURE RESULT inside a composite annotation — a union arm
// (`(() => {[string]: f64}) | {w: i32}`), the nullable-closure niche
// (`((i32) => {[string]: f64}) | null`), or a curried result. The whole spelling is
// ONE TypeRef whose map is invisible to every branch of the `collectA` scan, so the
// narrowed arm's call-result map ops rejected "map type not collected" even though
// the result names a map — the R2×R1 combo seam. Self-gating: a name with no arrow
// arm (or no map result) forces nothing — byte-identical for every other program. A
// value-UNION result (`() => {[string]: i32} | boolean`) is deliberately NOT forced:
// that closure result stays a loud reject until its rep is minted.
export function forceCloResultMapTypes(nm: string) {
  // Cheap pre-gate (this runs per arena TypeRef): only a name spelling BOTH an
  // arrow and a map can carry a closure-result map — two substring scans, no
  // allocation, before the arm split allocates anything.
  if !strContains(nm, "=>") || !strContains(nm, "{[") { return 0 }
  const arms: string[] = []
  splitUnionArmsAllDepth(nm, arms)
  let i = 0
  while i < arms.length {
    const a = monoUnwrapParens(arms[i])
    const fa = annArrowAt(a)
    if fa >= 1 && a.length > 0 && a[0] == '(' {
      let res = monoUnwrapParens(a.slice(fa + 2, a.length))
      const rn = nulMapInnerName(res)
      if rn != "" { res = rn }
      if nameIsMap(res) && !nameIsMapMemberUnion(res) {
        mUsed = true
        lUsed = true
        aUsed = true
        mvShapeOfValName(mapValNameOf(res))
      } else if annArrowAt(res) >= 0 {
        // A curried result (`() => () => {[string]: V}`) recurses to ITS result.
        forceCloResultMapTypes(res)
      }
    }
    i = i + 1
  }
  0
}

// Force the wrapper/backing types of a SCALAR-LEAF (or string) LIST reached only as a
// CLOSURE RESULT inside a composite annotation — the nullable-closure niche
// (`((i32) => f32[]) | null`), a union arm, a closure-typed param, or a curried result.
// The whole spelling is ONE TypeRef whose result list is invisible to every branch of the
// `collectA` scan, so a narrowed arm's value-call index read rejected "list type not
// collected" whenever the program never CONSTRUCTS such a list itself (`useIt(null)`).
// The list dual of `forceCloResultMapTypes`. Self-gating: a name with no arrow arm (or a
// non-list result) forces nothing — byte-identical for every other program. A REF-element
// list result resolves through its own annotation branches (`ensureRefElem`); a
// nullable-LIST result (`boolean[] | null`) forces its non-null leaf list (the niche slot
// only changes the valtype's nullability, not the types needed).
export function forceCloResultListTypes(nm: string) {
  // Cheap pre-gate (this runs per arena TypeRef): only a name spelling BOTH an arrow
  // and an array can carry a closure-result list — two substring scans, no allocation.
  if !strContains(nm, "=>") || !strContains(nm, "[]") { return 0 }
  const arms: string[] = []
  splitUnionArmsAllDepth(nm, arms)
  let i = 0
  while i < arms.length {
    const a = monoUnwrapParens(arms[i])
    const fa = annArrowAt(a)
    if fa >= 1 && a.length > 0 && a[0] == '(' {
      let res = monoUnwrapParens(a.slice(fa + 2, a.length))
      const rp = nullablePartOf(res)
      if rp != "" { res = rp }
      if nameIsStringArray(res) {
        slUsed = true
        aUsed = true
      } else if nameIsF64Array(res) {
        fa64Used = true
      } else if nameIsI64Array(res) {
        ia64Used = true
      } else if nameIsF32Array(res) {
        fa32Used = true
      } else if nameIsI32Array(res) {
        lUsed = true
        aUsed = true
      } else if nameIsRefArray(res) {
        // A REF-element list result (`((i32) => {a,f,z}[]) | f64` — a struct-element
        // array returned by a union-arm / nullable-niche closure): intern its element
        // slot + force the ref-list machinery, exactly as a BARE `S[]` annotation's
        // branch does — else a narrowed arm's value call keys a `>r<slot>;` sig no
        // producer interned (its slot unresolvable), or the read finds no wrapper.
        rlUsed = true
        raUsed = true
        ensureRefElem(refArrElemName(res))
      } else if annArrowAt(res) >= 0 {
        // A curried result (`() => () => f32[]`) recurses to ITS result.
        forceCloResultListTypes(res)
      }
    }
    i = i + 1
  }
  0
}

// True if the union member-set `name` has a MAP arm whose interned map value-slot is `slot` — the
// guard `emitUnionCoerce` uses to confirm a map carrier actually matches an arm before boxing it
// with that arm's `mapSlotTag`. A map expr whose value-slot matches no arm falls through (a
// checker-impossible case) rather than mis-tag. The map twin of `unionHasRefArrayArmSlot`.
// Arm and carrier compare CANONICALLY (`mvCanonRepOf`): a twin-spelled carrier (a
// `{[string]: B}` boxed into a `{[string]: {v: i32}} | X`) matches the arm it lowers as.
export function unionHasMapArmSlot(name: string, slot: i32) {
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  let i = 0
  while i < atoms.length {
    const a = atoms[i]
    if a != "null" && nameIsMap(a) {
      if (
        mvCanonRepOf(mvSlotOfMapValNameOrMono(mapValNameOf(a))) ==
        mvCanonRepOf(slot)
      ) {
        return true
      }
    }
    i = i + 1
  }
  false
}

// True when the union member-set `name` carries a map arm whose VALUE spelling is the bare
// `string` — the checker's RENDER of a litunion-valued map (`{[string]: K0}` renders
// `{[string]: string}`; the litunion bit lives on the NODE, not the name), so a union
// registered through a rendered spelling (a lambda's pinned result, an inline expanded
// litunion) interned the STRING-map slot for what is a MONO-map value. The box seam
// (`emitUnionCoerce`'s map-carrier arm) consults this when a mono litunion-valued map
// misses the slot match: the collapsed arm IS this value's arm, and the box tags MONO
// (`mapSlotTag(-1)`) — the same tag an `is {[string]: K0}` test derives from its own
// (litunion → mono) spelling, so store and narrow resolve one tag.
export function unionHasCollapsedStringMapArm(name: string) {
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  let i = 0
  while i < atoms.length {
    const a = atoms[i]
    if a != "null" && nameIsMap(a) && !nameIsMapMemberUnion(a) {
      if mapValNameOf(a) == "string" { return true }
    }
    i = i + 1
  }
  false
}

// True if the union member-set `name` has a MAP arm (`{[string]: V}`). Resolves an alias to its
// member set first. Used by the frame pre-pass (`exprHasMapOp` → `unionMapArmIdent`) to reserve the
// map scratch frame for a `t[k]` on a union binding narrowed to its map arm — the narrowing is not
// active in that pass, so the map op must be spotted from the binding's DECLARED union.
export function unionHasMapArm(name: string) {
  let nm = unionMemberSetOf(name)
  if nm == "" { nm = name }
  const atoms: string[] = []
  splitUnionAtoms(nm, atoms)
  let i = 0
  while i < atoms.length {
    if nameIsMap(atoms[i]) { return true }
    i = i + 1
  }
  false
}

// True if `exprIx` is an IDENT whose DECLARED union has a map arm — the receiver shape the frame
// pre-pass reserves the map scratch for (`t[k]` / `t[k] ?? d` / `t.has(k)` on a union narrowed to
// a map). Narrowing-blind: reads the binding's declared union, not the active narrowing.
export function unionMapArmIdent(exprIx: i32, fnIx: i32) {
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Ident {
    const un = unionNameOfIdent(e.identName, fnIx)
    if un != "" { return unionHasMapArm(un) }
    // The typed-IR fallback: a union binding whose NAME the syntactic resolution cannot
    // render (`const t1 = t0()` off a narrowed nullable-closure rebind — the Ident-callee
    // miss) still records the union on its node type. The emitter lowers the narrowed map
    // read regardless, so the frame pre-pass must reserve the map scratch from the same
    // signal. (An over-reservation is a harmless spare.)
    return nodeTyUnionHasMapArm(exprIx)
  }
  false
}

// True when the CHECKED type of `exprIx` is a union carrying a MAP member, or a bare
// MAP (a narrowed occurrence records the NARROWED arm type, so the then-branch ident
// of `if t1 is {[string]: i32}` types TyMap, not the union) — the typed-IR net behind
// `unionMapArmIdent`'s syntactic miss.
function nodeTyUnionHasMapArm(exprIx: i32): boolean {
  const ty = nodeTyIxOf(exprIx)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyMap { return true }
  if t is TyUnion {
    let i = 0
    while i < t.uMembers.length {
      if T.tys[t.uMembers[i]] is TyMap { return true }
      i = i + 1
    }
  }
  false
}

// True if `exprIx` is a MEMBER read (`t[i].f`) whose object indexes an IDENT declared as a
// union with a REF-ARRAY arm whose ELEMENT struct's field `.f` is a MAP (code 19) — the
// struct-field-map receiver shape (`t[i].f[k] ?? d` after an `is S[]` narrow) the frame
// pre-pass must reserve the map scratch for. Narrowing-blind, like `unionMapArmIdent`: the
// `is`-narrow that makes `t[i]` a struct is not active in the pre-pass, so `exprMap`'s
// `memFieldTypeCode` resolution misses the receiver and the map read then clobbered the i32
// scratch slots with map refs — invalid wasm. (An over-reservation is a harmless spare.)
export function unionListElemMapFieldMember(exprIx: i32, fnIx: i32) {
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Member {
    const obj = P.nodes[unwrapParen(e.memObj)]
    if obj is Index {
      const arr = P.nodes[unwrapParen(obj.idxArr)]
      if arr is Ident {
        const un = unionNameOfIdent(arr.identName, fnIx)
        if un != "" {
          let nm = unionMemberSetOf(un)
          if nm == "" { nm = un }
          const atoms: string[] = []
          splitUnionAtoms(nm, atoms)
          let i = 0
          while i < atoms.length {
            const a = atoms[i]
            if nameIsRefArray(a) {
              // The arm's element struct: `refArrElemName` for a nominal element, the raw
              // `[]`-stripped text for an inline shape it cannot see (the interner's key).
              let en = refArrElemName(a)
              if en == "" && a.length > 2 { en = a.slice(0, a.length - 2) }
              const si = structIndexByName(en)
              if si >= 0 {
                const fi = sFieldIndex(si, e.memProp)
                if fi >= 0 {
                  if sFieldTypeAt(si, fi) == 19 { return true }
                }
              }
            }
            i = i + 1
          }
        }
      }
    }
  }
  false
}

// True if `exprIx` is a MEMBER read (`t.f`) whose object is an IDENT declared as a union
// with a STRUCT arm whose field `.f` is a MAP (code 19) — the struct-arm map-field receiver
// shape (`t.f[k] ?? d` after an `is {f: {[string]: V}}` narrow) the frame pre-pass must
// reserve the map scratch for. Narrowing-blind, like the list-element sibling above: the
// `is`-narrow that makes `t` a struct is not active in the pre-pass, so `exprMap`'s
// `memFieldTypeCode` resolution misses the receiver and the narrowed map read then indexed
// scratch locals past the frame — invalid wasm. Probes BOTH field tables: the struct table
// (a `{f:…} | i32` arm interned by `internShapeDeep`) and the variant table (a declared
// struct arm of a 2+-struct union lives in `uVariants`). (An over-reservation is a
// harmless spare local, never invalid wasm.)
export function unionStructArmMapFieldMember(exprIx: i32, fnIx: i32) {
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Member {
    const obj = P.nodes[unwrapParen(e.memObj)]
    if obj is Ident {
      const un = unionNameOfIdent(obj.identName, fnIx)
      if un != "" {
        let nm = unionMemberSetOf(un)
        if nm == "" { nm = un }
        const atoms: string[] = []
        splitUnionAtoms(nm, atoms)
        let i = 0
        while i < atoms.length {
          const a = atoms[i]
          if a != "null" {
            const si = structIndexByName(a)
            if si >= 0 {
              const fi = sFieldIndex(si, e.memProp)
              if fi >= 0 {
                if sFieldTypeAt(si, fi) == 19 { return true }
              }
            }
            const vi = variantIndexOf(a)
            if vi >= 0 {
              const vfi = variantFieldIndex(vi, e.memProp)
              if vfi >= 0 {
                if variantFieldTypeAt(vi, vfi) == 19 { return true }
              }
            }
          }
          i = i + 1
        }
      }
    }
  }
  false
}

// True if the union member-set `name` has a CLOSURE-ARRAY arm (`(() => f64)[]`). `p[0]()` on
// such a union (narrowed to the closure array) is a `call_ref`, so the frame pre-pass reserves
// `callRefSlot` for it — see `blockHasCallRef`. Resolves an alias to its member set first.
export function unionHasClosureArrayArm(name: string) {
  let nm = unionMemberSetOf(name)
  if nm == "" { nm = name }
  const atoms: string[] = []
  splitUnionAtoms(nm, atoms)
  let i = 0
  while i < atoms.length {
    if nameIsClosureArray(atoms[i]) { return true }
    i = i + 1
  }
  false
}

// True if `exprIx` is `p[0]` where `p` is a union IDENT whose union has a closure-array arm —
// the callee shape `blockHasCallRef` reserves `callRefSlot` for (the narrowing-blind pre-pass).
export function calleeIsUnionClosureArrayIndex(exprIx: i32, fnIx: i32) {
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Index {
    const arr = P.nodes[unwrapParen(e.idxArr)]
    if arr is Ident {
      const un = unionNameOfIdent(arr.identName, fnIx)
      if un != "" { return unionHasClosureArrayArm(un) }
    }
  }
  false
}

// True if the union member-set `name` has a BARE-CLOSURE arm (`(() => i64) | {w:i32}`,
// `(() => i64) | i32`). A closure is value-atom KIND 11 (a REF atom riding the box anyref as
// the `$cloStructIdx` fat-pointer), so — unlike the ref-array / map arms — it needs no new tag
// band: its `scalarTagOf` (`uVariants.length + 11`) already discriminates. Resolves an alias to
// its member set first, mirroring `unionHasClosureArrayArm` (which tests the closure-ELEMENT
// array arm, a distinct shape whose arrow is nested inside `[]`).
export function unionHasClosureArm(name: string) {
  let nm = unionMemberSetOf(name)
  if nm == "" { nm = name }
  const atoms: string[] = []
  splitUnionAtoms(nm, atoms)
  let i = 0
  while i < atoms.length {
    if valueAtomKind(atoms[i]) == 11 { return true }
    i = i + 1
  }
  false
}

// The BARE-CLOSURE arm NAME of the union member-set `name` (`(() => i64)` in `(() => i64) | i32`),
// or "" when it has none. `emitUnionCoerce` boxes a closure carrier with this arm's `scalarTagOf`.
// (A union with two distinct closure arms shares one kind-11 tag — a pre-existing value-atom-scheme
// limitation, not exercised by the supported single-closure-arm shapes; returns the FIRST here.)
export function unionClosureArmName(name: string) {
  let nm = unionMemberSetOf(name)
  if nm == "" { nm = name }
  const atoms: string[] = []
  splitUnionAtoms(nm, atoms)
  let i = 0
  while i < atoms.length {
    if valueAtomKind(atoms[i]) == 11 { return atoms[i] }
    i = i + 1
  }
  ""
}

// True if `exprIx` is an IDENT whose declared union has a bare-closure arm — the callee shape
// `blockHasCallRef` reserves `callRefSlot` for (the `is`-narrowing that makes the ident a closure
// is NOT active during the narrowing-blind frame pre-pass, so `exprIsClosure` is false there).
// The bare-binding analogue of `calleeIsUnionClosureArrayIndex` (`const t = p.f; t()` /
// `const e = arr[0]; e()`, where the closure arm was extracted to a plain union binding first).
export function calleeIsUnionClosureIdent(exprIx: i32, fnIx: i32) {
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Ident {
    const un = unionNameOfIdent(e.identName, fnIx)
    if un != "" { return unionHasClosureArm(un) }
  }
  false
}

// True if `exprIx` is a member CHAIN (`t0.f.f`) rooted at an IDENT declared as a union,
// whose field path walks — NARROWING-BLINDLY through the arms' field tables (struct AND
// variant), across code-15 nested-struct hops — to a CLOSURE field (code 14, or the
// nullable-closure niche 22). The member-chain callee shape `blockHasCallRef` reserves
// `callRefSlot` for: the `is`-narrowing that makes the root a struct arm is not active
// during the frame pre-pass, so `exprIsClosure` misses the chain and the narrowed
// `call_ref`'s closure spill landed on an UNRESERVED index — shared with the next frame
// (the mv map frame in the observed case), a type-mismatched local (invalid wasm). An
// over-reservation is a harmless spare local.
export function calleeIsUnionArmClosureMember(exprIx: i32, fnIx: i32) {
  if !uDeclared {
    return false // no unions declared — nothing to probe (cheap bail)
  }
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Member {
    // Collect the field chain root-first: `t0.f.g` → root `t0`, props [f, g].
    const props: string[] = []
    let cur = unwrapParen(exprIx)
    let rootName = ""
    let guard = 0
    while guard < 32 {
      guard = guard + 1
      const cn = P.nodes[cur]
      if cn is Member {
        props.push(cn.memProp)
        cur = unwrapParen(cn.memObj)
      } else if cn is Ident {
        rootName = cn.identName
        break
      } else {
        return false
      }
    }
    if rootName == "" || props.length == 0 { return false }
    // props collected leaf-first — reverse into walk order.
    const path: string[] = []
    let pr = props.length - 1
    while pr >= 0 {
      path.push(props[pr])
      pr = pr - 1
    }
    const un = unionNameOfIdent(rootName, fnIx)
    if un == "" { return false }
    let uset = unionMemberSetOf(un)
    if uset == "" { uset = un }
    const atoms: string[] = []
    splitUnionAtoms(uset, atoms)
    let ai = 0
    while ai < atoms.length {
      if atoms[ai] != "null" {
        if unionArmPathIsClosure(atoms[ai], path) { return true }
      }
      ai = ai + 1
    }
  }
  false
}

// Walk field path `path` from union arm `arm`: the FIRST hop resolves through the arm's
// struct-table OR variant-table row, every MID hop must be a code-15 nested-struct field
// (following its target), and the LAST hop is a closure field (code 14 / 22).
// True if `exprIx` is an INDEX whose receiver is a member CHAIN (`t0.f[0]`) rooted at an
// IDENT declared as a union, whose field path walks — narrowing-blindly, same discipline as
// `calleeIsUnionArmClosureMember` — to a CLOSURE-ELEMENT ARRAY field (a code-5 reflist field
// whose element name is a function type). The indexed-member callee shape `blockHasCallRef`
// reserves `callRefSlot` for: the `is`-narrowing that resolves the chain is not active during
// the frame pre-pass, so `exprIsClosure` misses `t0.f[0]` and the narrowed `call_ref`'s
// closure spill landed on an unreserved (i32-typed) index — invalid wasm. An over-reservation
// is a harmless spare local.
export function calleeIsUnionArmCloArrayIndex(exprIx: i32, fnIx: i32) {
  if !uDeclared { return false }
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Index {
    const m = P.nodes[unwrapParen(e.idxArr)]
    if m is Member {
      const props: string[] = []
      let cur = unwrapParen(e.idxArr)
      let rootName = ""
      let guard = 0
      while guard < 32 {
        guard = guard + 1
        const cn = P.nodes[cur]
        if cn is Member {
          props.push(cn.memProp)
          cur = unwrapParen(cn.memObj)
        } else if cn is Ident {
          rootName = cn.identName
          break
        } else {
          return false
        }
      }
      if rootName == "" || props.length == 0 { return false }
      const path: string[] = []
      let pr = props.length - 1
      while pr >= 0 {
        path.push(props[pr])
        pr = pr - 1
      }
      const un = unionNameOfIdent(rootName, fnIx)
      if un == "" { return false }
      let uset = unionMemberSetOf(un)
      if uset == "" { uset = un }
      const atoms: string[] = []
      splitUnionAtoms(uset, atoms)
      let ai = 0
      while ai < atoms.length {
        if atoms[ai] != "null" {
          if unionArmPathIsCloArray(atoms[ai], path) { return true }
        }
        ai = ai + 1
      }
    }
  }
  false
}

// Walk field path `path` from union arm `arm` (the `unionArmPathIsClosure` walk), leafing
// at a CLOSURE-ELEMENT ARRAY field: a code-5 reflist field whose element name is a function
// type (`f: ((i32) => K0)[]`).
function unionArmPathIsCloArray(arm: string, path: string[]): boolean {
  let hop = 0
  let curSi = structIndexByName(arm)
  const vi0 = variantIndexOf(arm)
  while hop < path.length {
    let code = -1
    let elem = ""
    if hop == 0 && curSi < 0 && vi0 >= 0 {
      const vfi = variantFieldIndex(vi0, path[0])
      if vfi < 0 { return false }
      code = variantFieldTypeAt(vi0, vfi)
      elem = variantFieldElemName(vi0, vfi)
    } else {
      if curSi < 0 { return false }
      const fi = sFieldIndex(curSi, path[hop])
      if fi < 0 { return false }
      code = sFieldTypeAt(curSi, fi)
      elem = sFieldElemNameAt(curSi, fi)
    }
    if hop == path.length - 1 {
      return code == 5 && annArrowAt(peelGroupParens(elem)) >= 0
    }
    if code != 15 { return false }
    curSi = structIndexByName(elem)
    hop = hop + 1
  }
  false
}

function unionArmPathIsClosure(arm: string, path: string[]): boolean {
  // (code, elem) of the first hop, from whichever table holds the arm.
  let hop = 0
  let curSi = structIndexByName(arm)
  const vi0 = variantIndexOf(arm)
  while hop < path.length {
    let code = -1
    let elem = ""
    if hop == 0 && curSi < 0 && vi0 >= 0 {
      const vfi = variantFieldIndex(vi0, path[0])
      if vfi < 0 { return false }
      code = variantFieldTypeAt(vi0, vfi)
      elem = variantFieldElemName(vi0, vfi)
    } else {
      if curSi < 0 { return false }
      const fi = sFieldIndex(curSi, path[hop])
      if fi < 0 { return false }
      code = sFieldTypeAt(curSi, fi)
      elem = sFieldElemNameAt(curSi, fi)
    }
    if hop == path.length - 1 { return code == 14 || code == 22 }
    if code != 15 { return false }
    curSi = structIndexByName(elem)
    hop = hop + 1
  }
  false
}

// True if the union member-set `name` (pipe-joined atoms) has a REF-ELEMENT array arm whose
// interned reflist slot is `slot` — the guard `emitUnionCoerce` uses to confirm a ref-array
// carrier actually matches an arm before boxing it with that arm's `refArrSlotTag`. A ref-array
// expr whose slot matches no arm falls through (a checker-impossible case) rather than mis-tag.
export function unionHasRefArrayArmSlot(name: string, slot: i32) {
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  let i = 0
  while i < atoms.length {
    const a = atoms[i]
    if a != "null" && valueAtomKind(a) < 0 && nameIsRefArray(a) {
      if rlSlotByName(refArrElemName(a)) == slot { return true }
    }
    i = i + 1
  }
  false
}

// The interned reflist SLOT of a UNION-BOX-ELEMENT ref-array arm of the union member-set
// `name` (`(i32 | string)[]`, `N[]` over a union alias, `(C | D)[]`) whose element union
// admits the member atom `elemAtom` (exact atom match — `"string"` ∈ `i32|string`, a
// variant name `"C"` ∈ `C|D`), or -1 when no arm matches. An EMPTY `elemAtom` (an empty
// `[]` literal, no element to classify) matches the FIRST union-box-element arm — the
// checker already proved the literal fits the union, and an empty list's element type is
// vacuous. `emitUnionCoerce` uses this to route a list LITERAL whose own classification
// is a scalar list (`["a"]` → `string[]`) or a concrete struct list (`[{a:1}]` → `C[]`)
// — neither of which interns the ARM's slot — into the arm's box-element build + tag.
export function unionRefArrayArmSlotForElem(name: string, elemAtom: string) {
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  let i = 0
  while i < atoms.length {
    const a = atoms[i]
    if a != "null" && valueAtomKind(a) < 0 && nameIsRefArray(a) {
      const en = refArrElemName(a)
      const slot = rlSlotByName(en)
      if slot >= 0 && rlElemKindTbl[slot] == 2 {
        if elemAtom == "" { return slot }
        let es = unionMemberSetOf(en)
        if es == "" { es = en }
        const eAtoms: string[] = []
        splitUnionAtoms(es, eAtoms)
        let j = 0
        while j < eAtoms.length {
          if eAtoms[j] == elemAtom { return slot }
          j = j + 1
        }
      }
    }
    i = i + 1
  }
  -1
}

// The interned reflist SLOT of an ARRAY-OF-MAP arm of the union member-set `name`
// (`{[string]: i64}[] | f64`) whose element MAP's value rep matches the literal
// element's map shape `mvShape` (canonical rep — `mvCanonRepOf`; mono matches mono),
// or -1 when no arm matches. `emitUnionCoerce` routes an array literal whose elements
// are MAP exprs (`[h0]` — invisible to `exprRefArray`, so the ref-array carrier path
// misses) into the arm's build + tag through this; an unmatched literal keeps the
// loud reject.
export function unionRefArrayArmSlotForMapElem(name: string, mvShape: i32) {
  if mvShape < -1 { return -1 }
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  let i = 0
  while i < atoms.length {
    const a = atoms[i]
    if a != "null" && valueAtomKind(a) < 0 && nameIsRefArray(a) {
      const en = refArrElemName(a)
      if nameIsMap(en) && !nameIsMapMemberUnion(en) {
        const slot = rlSlotByName(en)
        if (
          slot >= 0 &&
          slot < rlElemKindTbl.length &&
          rlElemKindTbl[slot] == 3
        ) {
          const armMv = mvSlotOfMapValNameOrMono(mapValNameOf(en))
          if armMv == -1 && mvShape == -1 { return slot }
          if armMv >= 0 && mvShape >= 0 {
            if mvCanonRepOf(armMv) == mvCanonRepOf(mvShape) { return slot }
          }
        }
      }
    }
    i = i + 1
  }
  -1
}

// The interned reflist SLOT of the SINGLE NESTED-ARRAY arm of the union member-set
// `name` (`string[][] | string`, `i64[][] | boolean | null` — an arm whose element is
// itself a list, kinds 4/6/7/8/9/10), or -1 when the union has no such arm OR more
// than one (an ambiguous route stays the loud reject — the checker cannot disambiguate
// which arm a bare nested literal meant here). `emitUnionCoerce` routes an ArrayLit
// carrier through this arm's OWN build (`pendingListKind = 1` + the arm's slot, the
// same threading an annotated `T[][]` binding uses), so the inner lists build the
// ARM's leaf — an `i64[][]` arm widens bare-int leaves at the store (`emitExprAsI64`),
// a `string[][]` arm builds string inner lists — where the literal's SELF-classified
// slot (`i32[][]`, or no ref classification at all for a string/f64-leaf literal)
// either mismatched the arm (the old loud reject) or fell through toward the scalar
// value-atom ladder (nested reject).
export function unionNestedArrayArmSlot(name: string) {
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  let found = -1
  let n = 0
  let i = 0
  while i < atoms.length {
    const a = atoms[i]
    if a != "null" && valueAtomKind(a) < 0 && nameIsRefArray(a) {
      const slot = rlSlotByName(refArrElemName(a))
      if slot >= 0 && slot < rlElemKindTbl.length {
        const k = rlElemKindTbl[slot]
        if k == 4 || k == 6 || k == 7 || k == 8 || k == 9 || k == 10 {
          found = slot
          n = n + 1
        }
      }
    }
    i = i + 1
  }
  if n == 1 { return found }
  -1
}

// True if the union member-set `name` has an ARRAY-OF-MAP arm (`{[string]: V}[]`).
// The frame pre-pass consults this (via `unionMapArrayElemIndex`) to reserve the map
// scratch for a `t[i][k]` read on a union binding narrowed to its map-array arm — the
// narrowing is not active in that pass, so the map op must be spotted from the
// binding's DECLARED union (the map-array twin of `unionHasMapArm`).
export function unionHasMapArrayArm(name: string) {
  let nm = unionMemberSetOf(name)
  if nm == "" { nm = name }
  const atoms: string[] = []
  splitUnionAtoms(nm, atoms)
  let i = 0
  while i < atoms.length {
    const a = atoms[i]
    if a != "null" && nameIsArray(a) {
      const en = refArrElemName(a)
      if nameIsMap(en) && !nameIsMapMemberUnion(en) { return true }
    }
    i = i + 1
  }
  false
}

// True if `exprIx` is an INDEX read (`t[i]`) whose array indexes an IDENT declared as
// a union with an ARRAY-OF-MAP arm — the receiver shape (`t[i][k]` / `t[i][k] ?? d` /
// `t[i].has(k)` after an `is {[string]: V}[]` narrow) the frame pre-pass reserves the
// map scratch for. Narrowing-blind, like `unionMapArmIdent`. (An over-reservation is a
// harmless spare local, never invalid wasm.)
export function unionMapArrayElemIndex(exprIx: i32, fnIx: i32) {
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Index {
    const arr = P.nodes[unwrapParen(e.idxArr)]
    if arr is Ident {
      const un = unionNameOfIdent(arr.identName, fnIx)
      if un != "" { return unionHasMapArrayArm(un) }
    }
  }
  false
}

// The inferred `T|null` union name of the null-init `LetDecl` at `letIx`, or "".
export function nliNameOf(letIx: i32) {
  let i = 0
  while i < nliLetIxs.length {
    if nliLetIxs[i] == letIx { return nliNames[i] }
    i = i + 1
  }
  ""
}

// The value-union NAME an un-annotated if-EXPRESSION binding init carries (`const x =
// if c then 5 else null` → `i32|null`, the else-less `if c then 5` → `i32|null`, `if c
// then 5 else "hi"` → `i32|string`), or "" when it is not a value union the box can hold
// (a non-union `if c then 5 else 6`, a `string | null` niche, or an arm the static pre-
// pass cannot classify). The canonical name is the deduped arm atoms (arm order) with a
// trailing `|null` when any arm / the else-less path is null.
export function ifExprNliName(ifIx: i32) {
  const atoms: string[] = []
  const hn = ifExprCollectAtoms(ifIx, atoms)
  if hn == -2 { return "" }
  if atoms.length == 0 { return "" }
  // Mixed NUMERIC arms WIDEN to a single numeric (`i32` + `f64` → `f64`, #490) — they
  // are not a union, and this static atom list cannot do that lattice join. Bail so the
  // numeric value-position-if path (`letIsF64`/`letIsI64`) handles them. A SINGLE numeric
  // scalar (optionally + null, + a non-numeric like `string`) is fine.
  let numCount = 0
  let j = 0
  while j < atoms.length {
    const k = valueAtomKind(atoms[j])
    if k == 0 || k == 3 || k == 4 || k == 5 { numCount = numCount + 1 }
    j = j + 1
  }
  if numCount >= 2 { return "" }
  let nm = ""
  let i = 0
  while i < atoms.length {
    if nm != "" { nm = nm + "|" }
    nm = nm + atoms[i]
    i = i + 1
  }
  if hn == 1 { nm = nm + "|null" }
  // Only a value union the box rep can hold (≥2 non-null atoms, or one NUMERIC scalar +
  // null) registers here — a `string | null` niche / a non-union stay on their own paths.
  if !isValueUnionName(nm) { return "" }
  nm
}

// The per-union table index that OWNS global variant `vi` (the union whose variant
// slice contains it), or -1. Mirrors the `structIndexByName`-style resolver.
function unionOfVariant(vi: i32) {
  let u = 0
  while u < unNames.length {
    const start = unVarStart[u]
    if vi >= start && vi < start + unVarCount[u] { return u }
    u = u + 1
  }
  -1
}

// The position of variant struct `name` in `uVariants` (its heap-type is
// `uVarHeap[pos]`), or -1 if `name` is not a variant of the declared union.
export function variantIndexOf(name: string) {
  let i = 0
  while i < uVariants.length {
    if uVariants[i] == name { return i }
    i = i + 1
  }
  -1
}

// True if the type-name `name` is ANY declared union alias.
export function isUName(name: string) {
  let u = 0
  while u < unNames.length {
    if unNames[u] == name { return true }
    u = u + 1
  }
  false
}

// The union alias name that owns global variant `vi` (assumes `vi` is a variant of some
// declared union), or "" if none. Used to intern a ref-list-of-union by the SPECIFIC
// union (so `Node[]` and `Ty[]` are distinct table slots).
function unionNameOfVariant(vi: i32) {
  const u = unionOfVariant(vi)
  if u >= 0 { return unNames[u] }
  ""
}

// The wasm struct field index of `field` within variant `vi` (declaration order), or
// -1 if that variant has no such field.
export function variantFieldIndex(vi: i32, field: string) {
  const start = uFieldStart[vi]
  const cnt = uFieldCount[vi]
  let j = 0
  while j < cnt {
    if uFieldNames[start + j] == field { return j }
    j = j + 1
  }
  -1
}

// True if the function `name` declares the struct as its return type (flat lookup
// over the stored kind `buildFnMap` recorded — no arena rescan).
function fnRetStruct(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetKind[i] == "struct"
}

// True if the parameter `name` of function `fnIx` is the struct type.
function paramStruct(fnIx: i32, name: string) {
  const pt = paramTypeNode(fnIx, name)
  // STRUCTURAL fast-path (C1): a recorded declared-struct param, else the name test.
  if nodeTyIsStruct(pt) { return true }
  false
}

// True if evaluating the expression at `exprIx` yields the struct (a `(ref $0)`):
// an object literal (constructs it), a struct-returning call, a struct param/local
// reference, or a parenthesized struct expression. Anything else is an i32 value.
export function exprStruct(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is ObjLit { return true }
  if e is Paren { return exprStruct(e.parInner, fnIx) }
  // An if-EXPRESSION whose branch join is a struct — an un-annotated binding classifies kind 1
  // (the THEN arm's rep, the arms agreeing by the checker), matching `structIndexOfExpr`.
  if e is IfStmt {
    const tv = ifThenValueIx(exprIx)
    return tv >= 0 && exprStruct(tv, fnIx)
  }
  // A `m[k] ?? default` over a STRUCT-valued map (`{[string]: S}`) yields the value struct — so a
  // bound `const p = m[k] ?? d` classifies as a struct local and `(m[k] ?? d).x` resolves.
  // A NULLABLE-value slot (`{[string]: S | null}`) yields `S | null` instead (a stored null is
  // PRESERVED through `??`) — `exprNullableStruct` claims it, not this non-null arm.
  if e is BinExpr {
    const cms = coalesceMvSlot(exprIx, fnIx)
    if cms >= 0 { return mvValKind[cms] == 1 && !mvSlotNullable(cms) }
    // A `<S|null> ?? <S>` coalesce yields the non-null struct (the generic nullable-struct `??` emit) —
    // so a bound `const p = r ?? d` classifies struct and `(r ?? d).x` resolves. The left is the
    // nullable struct; the right is a plain struct default.
    if e.binOp == "??" {
      if exprNullableStruct(e.binLeft, fnIx) { return true }
      return exprStruct(e.binRight, fnIx)
    }
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetStruct(callee.identName) { return true }
      // A struct-returning function VALUE (a binding / `(i32) => S` param callee): its
      // resolved `>sN;` sig (mirrors `structIndexOfExpr`'s closure case). Falls through to the
      // per-node-type fallback below when the sig path misses (a factory-inferred value).
      if calleeReturnsStructIdx(callee.identName, fnIx) >= 0 { return true }
    }
    // A FIELD-CLOSURE call (`(a."*")(2)` — a rewritten operator/index trap)
    // yields the field function's return struct (mirrors `structIndexOfExpr`).
    if callee is Member {
      if (
        drwFieldClosure(structIndexOfExpr(callee.memObj, fnIx), callee.memProp)
      ) {
        const cfe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
        if cfe >= 0 {
          if fRetKind[cfe] == "struct" { return true }
        }
      }
    }
    // FALLBACK (scoped to a CALL): a struct-returning closure value call whose callee the cases above
    // miss — an INDEXED closure-array element (`arr[i](x)`) or a factory-inferred value. The cheap
    // NO-RENDER `nodeTyIsObj` reads the checker's per-node type. Boolean dual of `structIndexOfExpr`'s
    // fallback, so `letIsStruct` classifies such a binding (kind 1) and its field reads resolve.
    return nodeTyIsObj(exprIx)
  }
  if e is Ident {
    if paramStruct(fnIx, e.identName) { return true }
    if declaredStruct(e.identName) { return true }
    return globalIsStruct(e.identName)
  }
  // `xs[i]` over a STRUCT-element ref list yields the struct (G7-ref). Per-slot: the
  // element kind comes from the receiver's distinct ref-list slot (1 = struct).
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      return rlElemKindTbl[slot] == 1
    }
  }
  // A NULLABLE struct value (`S | null`) participates in the struct machinery
  // (member layout resolution); the field-read path inserts the non-null recover.
  exprNullableStruct(exprIx, fnIx)
}

// True if the already-collected declared local `name` is a nullable struct (code 9).
function declaredNulRef(name: string) { declaredKind(name) == "nulstruct" }

// True if `name` is a declared NULLABLE function-value local (`fn | null`, kind 19) — the
// closure dual of `declaredNulRef`.
function declaredNulClosure(name: string) { declaredKind(name) == "nulclosure" }

// True if the expression at `exprIx` is a NULLABLE function value (`fn | null`, kind 19) —
// currently a kind-19 local ident. Drives the `== null` / `!= null` test (`ref.is_null`)
// and the narrowed-call recover, the closure analogue of `exprNullableStruct`.
export function exprNulClosure(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const ux = unwrapParen(exprIx)
  const e = P.nodes[ux]
  if e is Ident {
    if paramNulClosure(fnIx, e.identName) { return true }
    if declaredNulClosure(e.identName) { return true }
    // A module-global nullable-closure cell (kind 19).
    const gl = globalLetOf(e.identName)
    if gl >= 0 { return globalCellKind(gl) == "nulclosure" }
    return false
  }
  // A CALL of a function whose return type is a nullable closure (`mk()` where `mk:
  // (…) => (fn | null)`): the result is the kind-19 niche `(ref null $cloStruct)`. A named
  // function reads its `fnRet`; a closure-typed VALUE callee reads its return-type annotation
  // (`calleeCloRetName`). Drives the local-kind inference (`const f = mk()`) and the `f !=
  // null` compare, the closure analogue of `exprNullableStruct`'s call classification.
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const t = fnIndexOf(callee.identName)
      if t >= 0 {
        const cfn = P.nodes[fnStmts[t]]
        if cfn is FuncDecl { return nulCloFlag(cfn.fnRet) == 1 }
      }
      if nameIsNulClosure(calleeCloRetName(callee.identName, fnIx)) {
        return true
      }
    }
    // An INDEXED closure-array element call (`v[0](1)` over a `((i32) => (fn | null))[]`)
    // or a struct-FIELD closure call whose resolved `$fnsig` result is the
    // nullable-closure niche (`>C`): the result is the kind-19 `(ref null $cloStruct)`,
    // so `const f = v[0](1)` binds the niche and `f != null` narrows — the same
    // `cloCallSigKey` resolution the call emit casts with, so the two always agree.
    return sigKeyRetKind(cloCallSigKey(ux, fnIx)) == "nulclosure"
  }
  // A nullable-closure struct FIELD read (`recv.op` over a `((i32) => i32) | null` field,
  // code 22): the raw `(ref null $cloStruct)` — its `!= null` lowers to `ref.is_null` and
  // the narrowed call recovers non-null (`ref.as_non_null`) at the call site.
  if e is Member { return memberFieldCode(ux, fnIx) == 22 }
  // A bare `m[k]` over a FUNCTION-valued map (mv kind 14) reads back a NULLABLE closure
  // `(ref null $cloStruct)` — `const f = m[k]` binds the kind-19 niche, narrowed `if f != null`.
  if e is Index {
    // Indexing a `(((i32) => boolean) | null)[]` (a kind-5 ref list whose element slot keeps
    // the `| null`) yields a NULLABLE closure — the read left it `(ref null $cloStruct)`, so
    // `const f = xs[i]; if f != null` narrows. The closure dual of `exprNullableList`'s arm.
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemNullable.length {
        if rlElemKindTbl[slot] == 5 && rlElemNullable[slot] == 1 { return true }
      }
    }
    const mrs = mapReadMvSlot(ux, fnIx)
    if mrs >= 0 { return mvValKind[mrs] == 14 }
  }
  // A `m[k] ?? d` read over a NULLABLE-closure-valued map (`{[string]: (() => T) | null}`) is
  // STILL nullable: the hit arm PRESERVES a stored null (the default fires only on a missing
  // key), so the binding stays the kind-19 niche and narrows with `!= null` — the closure dual
  // of `exprNullableStruct`'s coalesce arm.
  if e is BinExpr {
    const cns = coalesceMvSlot(ux, fnIx)
    if cns >= 0 { return mvValKind[cns] == 14 && mvSlotNullable(cns) }
  }
  false
}

// True if an UN-annotated `const f = <init>` should infer a NULLABLE-closure (kind 19) slot —
// its init reads back a nullable closure (a bare `m[k]` over a function-valued map). The
// annotated form is `letIsNulClosure`; this is its init-driven dual (it lives here, not in
// `emit_query`, because it consults the wasmEmit-side `exprNulClosure`).
export function letInfersNulClosure(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 { return false }
    if d.letInit < 0 { return false }
    return exprNulClosure(d.letInit, fnIx)
  }
  false
}

// True if the already-collected declared local `name` is a nullable i32 list (kind 15).
function declaredNulList(name: string) { declaredKind(name) == "nullist" }

// True if the already-collected declared local `name` is a struct ref. Resolves to
// the IN-SCOPE binding's slot (so a same-named binding in a sibling/inner block reads
// ITS own valtype, not an unrelated branch's).
function declaredStruct(name: string) { declaredKind(name) == "struct" }

// True if the `LetDecl` at `letIx` declares a struct-typed local: its annotation
// names the struct, OR its initializer produces the struct. Picks the local's
// valtype (`(ref $0)` vs i32) in `collectLocals`.
// True if the binding's annotation is a SINGLE inline object shape (`{ … }`, with a trailing `| null`
// stripped) that is NOT interned as a struct — i.e. its shape could not be built (an unsupported field
// type). A map (`{[…]}`) is excluded. Checked only AFTER union / nullable-struct / struct classification,
// so a valid inline-struct binding never reaches it; this catches the un-internable remainder so it
// rejects cleanly instead of mis-emitting its object literal (a soundness guard).
export function letAnnIsUninternedShape(letIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType < 0 { return false }
    let nm = tyNameOf(d.letType)
    const nb = nullablePartOf(nm)
    if nb != "" { nm = nb }
    if nm.length < 2 { return false }
    if nm[0] != '{' || nm[1] == '[' || nm[nm.length - 1] != '}' { return false }
    return structIndexByName(nm) < 0
  }
  false
}

export function letIsStruct(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if isSName(lt.tyName) { return true }
      }
    }
    return exprStruct(d.letInit, fnIx)
  }
  false
}

// True if the `LetDecl` at `letIx` binds a CONCRETE union-VARIANT value (`const c: Cat =
// …` where `Cat` is a variant of the declared union) — a kind-8 local `(ref
// $(uVarHeap[vi]))`, distinct from the union box (kind 4) and a standalone struct (kind 1). Annotation
// first, else the init's variant value (a variant param/local read). Checked AFTER the
// struct/union local cases so only an explicit variant annotation / variant-valued init
// reaches here.
export function letIsVariant(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if variantIndexOf(lt.tyName) >= 0 { return true }
      }
    }
    return exprVariantIndex(d.letInit, fnIx) >= 0
  }
  false
}

// The union-variant table index a variant-typed `LetDecl` binds (annotation first, else
// the init's variant value), or -1.
export function variantIndexOfLet(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        const vi = variantIndexOf(lt.tyName)
        if vi >= 0 { return vi }
      }
    }
    return exprVariantIndex(d.letInit, fnIx)
  }
  -1
}

// ── multi-struct index resolution ─────────────────────────────────────────────
// Parallel to the boolean `exprStruct` family, these return the STRUCT TABLE INDEX a
// struct-typed expression / param / local / return produces, so a field read/write
// can resolve the right heap type + field layout. Return -1 when not a struct.

// The struct table index of the param `name` of function `fnIx` (from its annotation),
// or -1.
function paramStructIndex(fnIx: i32, name: string) {
  if fnIx < 0 {
    return -1 // module-scope initializer (no enclosing function)
  }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    const params = fn.fnParams
    let i = 0
    while i < params.length {
      const p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            const ty = P.nodes[p.parType]
            if ty is TypeRef {
              // A plain struct name, or the `S | null` nullable BASE. (NOT a union
              // variant — a variant-typed param rides the gap-#2 path, and its
              // VARIANT index must not leak into the struct tables.)
              const psi = structIndexByName(ty.tyName)
              if psi >= 0 { return psi }
              const pbase = nullablePartOf(ty.tyName)
              if pbase != "" { return structIndexOfTypeName(pbase) }
            }
          }
          return -1
        }
      }
      i = i + 1
    }
  }
  -1
}

// The union-variant table index of the param `name` of function `fnIx` (when its
// annotation names a VARIANT struct of the declared union, e.g. `o: TyObj`), or -1.
// A variant-struct param's value IS the concrete variant struct ref `(ref
// $(uVarHeap[vi]))` — already narrowed/unboxed by the caller — so a field read on it reads the
// variant struct directly (no box unwrap), the gap-#2 boundary.
function paramVariantIndex(fnIx: i32, name: string) {
  variantIndexOf(tyNameOf(paramTypeNode(fnIx, name)))
}

// The union-variant table index an expression at `exprIx` yields a CONCRETE variant
// struct ref for (a variant-typed param reference, or a parenthesized one), or -1. The
// receiver shape for a gap-#2 field read `o.field` where `o: TyObj`.
export function exprVariantIndex(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return -1 }
  const e = P.nodes[exprIx]
  if e is Paren { return exprVariantIndex(e.parInner, fnIx) }
  if e is Ident {
    const pvi = paramVariantIndex(fnIx, e.identName)
    if pvi >= 0 { return pvi }
    return declaredVariantIndex(e.identName)
  }
  // A call to a `: Cat`-returning function yields the concrete variant ref.
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident { return fnRetVariantIndex(callee.identName) }
  }
  // An index into a `Cat[]` variant-element ref list yields the bare variant struct.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      return variantIndexOf(refListElemNameOfExpr(e.idxArr, fnIx))
    }
  }
  -1
}

// The union-VARIANT table index a function `name` returns (its `: Cat` return
// annotation), or -1.
function fnRetVariantIndex(name: string) {
  const fe = fnIndexOf(name)
  if fe >= 0 {
    const fn = P.nodes[fnStmts[fe]]
    if fn is FuncDecl {
      if fn.fnRet >= 0 {
        const rt = P.nodes[fn.fnRet]
        if rt is TypeRef { return variantIndexOf(rt.tyName) }
      }
    }
  }
  -1
}

// The union-variant table index of the declared local `name` (a kind-8 variant local —
// its `localStructIdx` holds the variant index), or -1.
function declaredVariantIndex(name: string) {
  const slot = declaredSlotOf(name)
  if slot < 0 { return -1 }
  if localIsRef[slot] == "variant" { return localStructIdx[slot] }
  -1
}

// The struct table index of the declared local `name` (recorded in `localStructIdx`),
// or -1 if `name` is not a struct local.
function declaredStructIndex(name: string) {
  const slot = declaredSlotOf(name)
  if slot < 0 { return -1 }
  if localIsRef[slot] == "struct" { return localStructIdx[slot] }
  if localIsRef[slot] == "nulstruct" { return localStructIdx[slot] }
  -1
}

// The struct table index a function `name` returns (recorded in `fRetStructIdx`), or -1.
function fnRetStructIndex(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return -1 }
  fRetStructIdx[i]
}

// The struct table index of a module global `name` (from its annotation/initializer),
// or -1.
function globalStructIndex(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return -1 }
  structIndexOfLet(li, -1)
}

// The struct table index that the expression at `exprIx` produces, or -1 if it is not
// a struct value. Mirrors `exprStruct`'s cases.
// The struct table index of a CAPTURED struct-ref variable `name` of the capturing
// lifted function `fnIx`, or -1 if `name` is not a captured struct of `fnIx`. Mirrors
// `emitCapturedRead`'s guards so a captured struct receiver (`p.x` where `p` is a
// captured `{ … }` in an enclosing frame) resolves to its struct type exactly as a
// param/local/global receiver would — the value itself is read from the env by
// `emitCapturedRead`; this only supplies the heap type so `emitMem` can pick the field.
function capturedStructIndex(fnIx: i32, name: string) {
  if fnIx < 0 { return -1 }
  if !fnValUsed { return -1 }
  const fe = fnStmtsPosOf(fnIx)
  if fe < 0 { return -1 }
  if fnEnvIdxOf(fe) < 0 { return -1 }
  const caps = captureNamesOf(fe)
  let ci = 0
  while ci < caps.length {
    if caps[ci] == name { return captureValStructIdx(fe, name) }
    ci = ci + 1
  }
  -1
}

// True if the CAPTURED variable `name` of the capturing lifted function `fnIx`
// is BOOLEAN-typed in the parent frame (a `boolean` param annotation, a
// `boolean`-annotated let, or a bool-literal init). Bool rides in an i32, so
// `capturedKindOf` cannot carry it — this is the print/`fRetBool` side channel.
function capturedIsBool(fnIx: i32, name: string) {
  if fnIx < 0 { return false }
  if !fnValUsed { return false }
  const fe = fnStmtsPosOf(fnIx)
  if fe < 0 { return false }
  const caps = captureNamesOf(fe)
  let isCap = false
  let ci = 0
  while ci < caps.length {
    if caps[ci] == name { isCap = true }
    ci = ci + 1
  }
  if !isCap { return false }
  const b = parentBindingOf(fe, name)
  if b < 0 { return false }
  const bn = P.nodes[b]
  if bn is Param { return tyNameOf(bn.parType) == "boolean" }
  if bn is LetDecl {
    if bn.letType >= 0 { return tyNameOf(bn.letType) == "boolean" }
    if bn.letInit >= 0 {
      const iv = P.nodes[unwrapParen(bn.letInit)]
      if iv is BoolLit { return true }
    }
  }
  false
}

// The VALUE KIND of a CAPTURED variable `name` of the capturing lifted function
// `fnIx` (the same `fbValtype` codes `captureValKind` types the env field with),
// or -1 if `name` is not a captured variable of `fnIx`. Same guards as
// `capturedStructIndex` — this is the classifier-side mirror, so an expression
// classifier (`exprArray` & co) can type a captured-list/string read exactly as
// a param/local/global receiver would.
function capturedKindOf(fnIx: i32, name: string): VKind | null {
  if fnIx < 0 { return null }
  if !fnValUsed { return null }
  const fe = fnStmtsPosOf(fnIx)
  if fe < 0 { return null }
  if fnEnvIdxOf(fe) < 0 { return null }
  const caps = captureNamesOf(fe)
  let ci = 0
  while ci < caps.length {
    if caps[ci] == name { return captureValKind(fe, name) }
    ci = ci + 1
  }
  null
}

// The union member-set NAME of a CAPTURED union-box variable `name` (kind 4) of the capturing
// function `fnIx` — resolved from the PARENT frame's binding annotation / init, so `a is Cat`
// narrows a captured `a: Cat | Dog`. "" when `name` is not a captured union. The union-name
// dual of `capturedStructIndex`.
function capturedUnionName(fnIx: i32, name: string) {
  if capturedKindOf(fnIx, name) != "union" { return "" }
  const fe = fnStmtsPosOf(fnIx)
  if fe < 0 { return "" }
  const b = parentBindingOf(fe, name)
  if b < 0 { return "" }
  const bn = P.nodes[b]
  if bn is Param {
    const pn = tyNameOf(bn.parType)
    if isUName(pn) { return pn }
    return ""
  }
  if bn is LetDecl {
    const par = fnParent[fe]
    if par >= 0 { return letUnionNameOf(b, fnStmts[par]) }
  }
  ""
}

export function structIndexOfExpr(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return -1 }
  const e = P.nodes[exprIx]
  if e is ObjLit { return structIndexOfObjCtx(exprIx, fnIx) }
  if e is Paren { return structIndexOfExpr(e.parInner, fnIx) }
  // An if-EXPRESSION whose join is a struct (`const b = if c { mk(1) } else { mk(2) }`): the
  // THEN arm's struct index classifies the whole `if` (the checker proved the arms agree), so an
  // un-annotated binding resolves the same struct heap type the `emitIfExprRef` join emits.
  if e is IfStmt {
    const tv = ifThenValueIx(exprIx)
    if tv >= 0 { return structIndexOfExpr(tv, fnIx) }
  }
  // A `m[k] ?? default` over a STRUCT-valued map resolves to the value type's struct index (the
  // mv slot's `mvValStructIdx`), so the field-read layout is found.
  if e is BinExpr {
    const cms = coalesceMvSlot(exprIx, fnIx)
    if cms >= 0 {
      if mvValKind[cms] == 1 { return mvValStructIdx[cms] }
    }
    // A `<S|null> ?? <S>` coalesce resolves to the (inner) struct index — so `(r ?? d).field` finds
    // the layout. The left's nullable struct drives it (its inner struct), else the right default.
    if e.binOp == "??" {
      const ls = structIndexOfExpr(e.binLeft, fnIx)
      if ls >= 0 { return ls }
      return structIndexOfExpr(e.binRight, fnIx)
    }
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const ri = fnRetStructIndex(callee.identName)
      if ri >= 0 { return ri }
      // A struct-returning function VALUE (a binding / `(i32) => S` param callee, invisible
      // to `fnRetStructIndex`): the struct index from its resolved `>sN;` sig. Falls through to the
      // per-node-type fallback below when the sig path misses (a value INFERRED from a factory call —
      // `const g = mk()` — whose `>sN;` the syntactic path can't recover).
      const ci = calleeReturnsStructIdx(callee.identName, fnIx)
      if ci >= 0 { return ci }
    }
    // A FIELD-CLOSURE call (`(a."[]")(i)` — a chained index trap whose "[]"
    // returns another trap object) yields the field function's return struct.
    if callee is Member {
      if (
        drwFieldClosure(structIndexOfExpr(callee.memObj, fnIx), callee.memProp)
      ) {
        const cfe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
        if cfe >= 0 {
          if fRetKind[cfe] == "struct" || fRetKind[cfe] == "nulstruct" {
            return fRetStructIdx[cfe]
          }
        }
      }
    }
    // `xs.pop()` / `xs.get(i)` over a struct-element ref list yield that list's
    // element struct (as `S | null` — see `structListPopGetElem`).
    const slv = structListPopGetElem(exprIx, fnIx)
    if slv >= 0 { return slv }
    // FALLBACK (scoped to a CALL): a struct-returning closure value call whose callee the cases above
    // miss — an INDEXED closure-array element (`arr[i](x).field`) or a value INFERRED from a factory
    // call (`const g = mk(); g(x).field`). Resolve the struct from the checker's per-node type: gate on
    // the cheap `nodeTyIsObj` (no render), then resolve the rendered inline shape to its declared index
    // by field-set match (`structIndexOfTypeName`). The struct dual of the union `nodeUnionName`
    // fallback, and the consumer half of the `cloCallSigKey` `nodeTyName` producer fallback. Off the
    // hot path — declared / param / field-closure struct receivers resolve syntactically above.
    if nodeTyIsObj(exprIx) {
      const sn = nodeTyName(exprIx)
      if sn != "" { return structIndexOfTypeName(sn) }
    }
    // The NULLABLE-struct dual: a `S | null`-returning closure value call (`arr[i](x)` over a
    // `((i32) => P | null)[]`) resolves to its INNER struct's layout index, so the kind-9 binding's
    // `!= null` narrow and field read find `P`. `nodeNulStructInnerName` renders only the inner shape.
    const nn = nodeNulStructInnerName(exprIx)
    if nn != "" { return structIndexOfTypeName(nn) }
    return -1
  }
  if e is Ident {
    const pi = paramStructIndex(fnIx, e.identName)
    if pi >= 0 { return pi }
    const di = declaredStructIndex(e.identName)
    if di >= 0 { return di }
    const gi = globalStructIndex(e.identName)
    if gi >= 0 { return gi }
    return capturedStructIndex(fnIx, e.identName)
  }
  // `xs[i]` over a STRUCT-element ref list yields that list's element struct. The
  // element struct TABLE INDEX comes from the receiver's per-element-type slot's name
  // (`Tok[]` → `Tok` → its struct index), so distinct struct ref-lists resolve to
  // distinct struct types — not always heap-type 0.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      let nm = refListElemNameOfExpr(e.idxArr, fnIx)
      // A NULLABLE-struct element (`(P | null)[]`, slot key "P | null") resolves to the bare
      // struct `P` — strip the `| null` so a narrowed `xs[i].field` finds P's layout. The
      // structural bridge (`structIndexOfTypeName`) then also resolves an INLINE-SHAPE
      // element (`{v:i32}[]` param) to its declared twin's layout.
      const nmnn = nullablePartOf(nm)
      if nmnn != "" { nm = nmnn }
      const si = structIndexOfTypeName(nm)
      if si >= 0 { return si }
    }
    // A BARE `m[k]` over a STRUCT-valued map resolves to the value type's struct index, so a
    // narrowed `(m[k]).field` finds the layout — the Index dual of the `?? default` BinExpr case.
    const mrs = mapReadMvSlot(exprIx, fnIx)
    if mrs >= 0 {
      if mvValKind[mrs] == 1 { return mvValStructIdx[mrs] }
    }
  }
  // A field read `o.inner` whose field is a NESTED STRUCT (code 15) yields the
  // field's target struct — so `o.inner.v` chains and `n.next` re-enters as `S|null`.
  if e is Member {
    const msi = structIndexOfExpr(e.memObj, fnIx)
    if msi >= 0 {
      const mfi = sFieldIndex(msi, e.memProp)
      if mfi >= 0 {
        if sFieldTypeAt(msi, mfi) == 15 {
          return structIndexByName(sFieldElemNameAt(msi, mfi))
        }
      }
      return -1
    }
    // A NARROWED union member (`t0.f` after `is {f: {f: f32}}`) and a VARIANT-typed
    // receiver resolve through the VARIANT field tables — the code-15 twin of
    // `mapShapeOfExpr`'s Member dispatch (without it the struct-table miss returned -1
    // and the nested read had no layout). AFTER the struct probe, and only on its
    // receiver MISS: the struct path answers every plain receiver without paying the
    // narrow-key/variant resolution (`memIsNarrowed` builds a path-key string — hot).
    if memIsNarrowed(exprIx) {
      const nvi = memNarrowVariantIndex(exprIx)
      if nvi >= 0 {
        const nvfi = variantFieldIndex(nvi, e.memProp)
        if nvfi >= 0 {
          if variantFieldTypeAt(nvi, nvfi) == 15 {
            return structIndexByName(variantFieldElemName(nvi, nvfi))
          }
        }
      }
    }
    const pvi = exprVariantIndex(e.memObj, fnIx)
    if pvi >= 0 {
      const pvfi = variantFieldIndex(pvi, e.memProp)
      if pvfi >= 0 {
        if variantFieldTypeAt(pvi, pvfi) == 15 {
          return structIndexByName(variantFieldElemName(pvi, pvfi))
        }
      }
    }
  }
  -1
}

// The struct table index a struct-typed `LetDecl` binds: from its annotation if
// present, else inferred from its initializer. -1 if not a struct local.
export function structIndexOfLet(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        const si = structIndexByName(lt.tyName)
        if si >= 0 { return si }
        // A NULLABLE annotation (`{n:i32} | null`, `Config | null`) resolves its
        // NON-NULL part — `collectAnnShapes` interns an inline shape under the
        // bare text (the `|null` wrapper stripped), and a named alias interns
        // under its own name. Needed when the initializer is a bare `null` (no
        // struct literal to infer the index from).
        const nb = nullablePartOf(lt.tyName)
        if nb != "" {
          const si2 = structIndexByName(nb)
          if si2 >= 0 { return si2 }
        }
      }
    }
    return structIndexOfExpr(d.letInit, fnIx)
  }
  -1
}

// ── union-typedness of expressions (G1) ───────────────────────────────────────
// Parallel to the struct family: decide whether an expression / param / local / let
// is the declared UNION (a `(ref $uBoxIdx)` boxed value). Unlike structs, an object
// literal's INTRINSIC type is its variant struct, NOT the union — boxing happens at a
// flow boundary (a `let n: U = …`, a union-returning `return`, a union-typed arg). So
// `exprUnion` is true for a union-returning call / union param / union local, but NOT
// a bare object literal (its boxing is driven by the EXPECTED type at the boundary).

// True if function `name` declares the union as its return type.
function fnRetUnion(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetKind[i] == "union"
}

// True if the parameter `name` of function `fnIx` is the union type.
function paramUnion(fnIx: i32, name: string) {
  const pt = paramTypeNode(fnIx, name)
  // STRUCTURAL fast-path (C1): a recorded declared value-union param, else the name test.
  if nodeTyIsUnionAlias(pt) { return true }
  false
}

// True if the already-collected declared local `name` is a union ref (code `4`).
function declaredUnion(name: string) { declaredKind(name) == "union" }

// True if evaluating the expression at `exprIx` yields the union box: a union-returning
// call, a union param/local reference, or a parenthesized union expression. (A bare
// object literal is NOT a union here — see the family note.)
export function exprUnion(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Paren { return exprUnion(e.parInner, fnIx) }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetUnion(callee.identName) { return true }
      // A union-returning function VALUE (a binding / `(…) => A | B` param callee) — its
      // result is the union box, `>u`.
      if calleeRetKind(callee.identName, fnIx) == "union" { return true }
      // A miss here is NOT authoritative: a closure REBOUND from a composed carrier with
      // no annotation (`const v = xs[0]; v(1)` over a union-result closure element) has no
      // sig the syntactic resolution sees, yet its call_ref yields the union BOX — fall
      // through to the checker-typed `nodeTyIsUnion` fallback below (the same net the
      // Index-callee spelling already lands in), so the binding slot classifies as the box
      // and the narrowed read unboxes instead of a raw i32 slot taking the ref.
    }
    // A union-returning FIELD-closure call.
    if callee is Member {
      const ffe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
      if ffe >= 0 { return fRetKind[ffe] == "union" }
    }
    // A union-returning INDEXED closure-element call (`xs[i](1)` over a
    // `((i32) => A | B)[]`): the element signature's result token is the box (`>u`).
    // The checker net below can miss it (a union WITH null records nullable-shaped),
    // so the sig-derived kind is consulted like the other `cloArrCallRetKind` arms.
    if cloArrCallRetKind(exprIx, fnIx) == "union" { return true }
    // A PURE-litunion result (`pick(ks)` → `K`) reps as the i32 atom / string ref,
    // never the box — the checker-typed net must not claim it as a union value.
    if nodeTyIsPureLitUnion(exprIx) { return false }
    // A nullable NUMERIC-scalar result (`f32 | null` from a chained value call
    // `v(1)()`) is the value-union box (`repOfNullable`'s scalar arm) — the checker-typed
    // net's TyNullable case. The niche nullables (string/boolean/litunion/struct/closure/
    // list `| null`) are structurally excluded by the classifier.
    if nodeTyIsNulScalarBox(exprIx) { return true }
    return nodeTyIsUnion(exprIx)
  }
  if e is Ident {
    // A VALUE-union ident narrowed to ONE scalar atom (`if u is i32 { … u … }`)
    // reads UNBOXED in this scope — it is no longer a union value here (the host's
    // narrowing types it as the member). A sub-union narrowing (2+ atoms) keeps
    // the box.
    if narrowedValueAtomOf(e.identName) != "" { return false }
    // A union binding narrowed to a REF-ELEMENT array arm reads UNBOXED to the reflist
    // wrapper (`if x is (i32 | string)[] { const t = x … }`): in this scope it is a
    // LIST, not a union value — the ref-array twin of the scalar-atom rule above.
    // Without it a REBIND under the narrow classified as a union BOX while the init
    // emitted the unboxed wrapper ref — invalid wasm.
    if narrowedRefArrayOf(e.identName) != "" { return false }
    if paramUnion(fnIx, e.identName) { return true }
    if declaredUnion(e.identName) { return true }
    // A CAPTURED union box (`const a: C | D = …; () => … a is C …`): the env field is the union
    // box (kind 4). `capturedUnionName` resolves its member set from the parent binding so `is`
    // narrows; here we only need to know it IS a union value.
    if capturedKindOf(fnIx, e.identName) == "union" { return true }
    // A module GLOBAL union binding (a union annotation, or a union-returning
    // init): top-level `const a = make(42)` / `let w: string | i32 = "a"`.
    const gi = globalLetOf(e.identName)
    if gi >= 0 { return letIsUnion(gi, -1) }
    return false
  }
  // `ns[i]` over a UNION-element ref list yields the union box (G7-ref) — so the value
  // is usable with `is`-narrowing (a `let n0 = ns[i]` is a union local). Per-slot: the
  // element kind comes from the receiver's distinct ref-list slot (2 = union box).
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      return rlElemKindTbl[slot] == 2
    }
    // A bare `m[k]` over a UNION-valued map yields the value union box.
    const mri = mapReadMvSlot(exprIx, fnIx)
    if mri >= 0 { return mvValKind[mri] == 2 }
  }
  // `m[k] ?? d` over a UNION-valued map yields the value union box.
  if e is BinExpr {
    const cmu = coalesceMvSlot(exprIx, fnIx)
    if cmu >= 0 { return mvValKind[cmu] == 2 }
  }
  // A plain read of a VALUE-UNION struct field (`o.y`, code 16) yields the field's
  // union BOX — a union value usable wherever a union is expected (`return o.y`, a
  // union arg, `const u = o.y`). A read NARROWED to one scalar atom unboxes (mirrors
  // the code-16 read path in emitMem), so it is no longer a union here — same as the
  // narrowed IDENT case above; a sub-union narrowing keeps the box (stays a union).
  if e is Member {
    if memberUnionFieldName(exprIx, fnIx) == "" { return false }
    const mAtom = narrowVariantFor(memberPathKeyOf(exprIx))
    const mk = valueAtomKind(mAtom)
    if mk >= 0 && mk != 6 { return false }
    return true
  }
  false
}

// True if the `LetDecl` at `letIx` declares a union-typed local: its annotation names
// the union, OR its initializer produces the union (a union-returning call etc.). An
// object-literal init under a union annotation is BOXED as the union (`emitStmt`).
export function letIsUnion(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        // A literal union (`type K = "a" | "b"`, or an inline `"a" | "b"`) is an interned-i32
        // ATOM, not a value-union box — never classify it kind 4.
        if isUName(lt.tyName) && !nodeTyIsLitUnionAlias(d.letType) {
          return true
        }
      }
    }
    // The init's union-ness applies ONLY when no annotation pinned the cell: an explicit
    // NON-union annotation (`const x: i32 = r` where `r` is a value-union narrowed to `i32`)
    // makes `x` that concrete type — the init UNBOXES the narrowed atom into it, it does NOT
    // box. (A UNION annotation already returned true above; a litunion ATOM init under a
    // `: string` annotation is an atom, not a box, so it must not box the cell either.)
    if d.letType < 0 {
      if exprUnion(d.letInit, fnIx) && !exprIsLitAtom(d.letInit, fnIx) {
        return true
      }
    }
    // A null-hole binding (`let x = null`, A-infer-null) is its inferred union.
    return nliNameOf(letIx) != ""
  }
  false
}

// ── value-union name resolution (the union a value flows as) ─────────────────
// The registered union NAME a binding `name` carries in function `fnIx` (its param
// annotation, its `let` annotation, an inferred union-returning init, or a module
// global's), or "" when the binding is not union-typed. The name string IS the
// atom set (`"boolean|i32"`), so narrowing complements split it directly.
export function unionNameOfIdent(name: string, fnIx: i32) {
  if fnIx >= 0 {
    const fn = P.nodes[fnIx]
    if fn is FuncDecl {
      // Read the body field BEFORE the Param narrowing below pins its own binding.
      const body = fn.fnBody
      const params = fn.fnParams
      let i = 0
      while i < params.length {
        const p = P.nodes[params[i]]
        if p is Param {
          if p.parName == name {
            const pn = tyNameOf(p.parType)
            if isUName(pn) { return pn }
            return ""
          }
        }
        i = i + 1
      }
      const li = parentLetOf(body, name)
      if li >= 0 { return letUnionNameOf(li, fnIx) }
      // A `for <name> in <(C|S)[]>` loop variable is a kind-4 union box but is NOT a
      // `LetDecl`, so `parentLetOf` misses it — resolve its member set from the iterable's
      // union-box element type so `x is C` narrows inside the loop body. GUARDED on the slot
      // already being a kind-4 union box, so a non-union loop var (an f32 `for v in
      // m.values()`, a struct `for s in ss`) never reaches the ref-array reclassification
      // below (which could mis-name it and corrupt its codegen).
      if declaredKind(name) == "union" {
        const iter = forInIterBlock(body, name)
        if iter >= 0 {
          if exprRefArray(iter, fnIx) {
            const slot = refListSlotOfExpr(iter, fnIx)
            if rlElemKindTbl[slot] == 2 { return rlElemName[slot] }
          }
        }
      }
    }
  }
  // A CAPTURED union box — resolve its member set from the parent frame's binding.
  const cun = capturedUnionName(fnIx, name)
  if cun != "" { return cun }
  const gi = globalLetOf(name)
  if gi >= 0 { return letUnionNameOf(gi, -1) }
  ""
}

// The ITERABLE expression node of an enclosing `for <name> in <iter>` loop within the
// statement list `stmts` (recursing into nested if / while / for / for-in bodies), or -1.
// A for-in loop variable is not a `LetDecl`, so `parentLetOf` cannot resolve its type;
// this lets `unionNameOfIdent` recover a union loop var's member set from its iterable.
function forInIterIn(stmts: i32[], name: string) {
  let i = 0
  while i < stmts.length {
    const s = P.nodes[stmts[i]]
    if s is ForIn {
      if s.fiVar == name { return s.fiIter }
      const rf = forInIterBlock(s.fiBody, name)
      if rf >= 0 { return rf }
    } else if s is IfStmt {
      const rt = forInIterBlock(s.ifThen, name)
      if rt >= 0 { return rt }
      if s.ifElse >= 0 {
        const els = P.nodes[s.ifElse]
        if els is Block {
          const re = forInIterBlock(s.ifElse, name)
          if re >= 0 { return re }
        } else {
          const one: i32[] = []
          one.push(s.ifElse)
          const r2 = forInIterIn(one, name)
          if r2 >= 0 { return r2 }
        }
      }
    } else if s is WhileStmt {
      const rw = forInIterBlock(s.whileBody, name)
      if rw >= 0 { return rw }
    } else if s is ForRange {
      const rr = forInIterBlock(s.frBody, name)
      if rr >= 0 { return rr }
    }
    i = i + 1
  }
  -1
}

// Recurse into a Block node's statement list to find a for-in binding `name` (else -1).
function forInIterBlock(blockIx: i32, name: string) {
  if blockIx < 0 { return -1 }
  const b = P.nodes[blockIx]
  if b is Block { return forInIterIn(b.blkStmts, name) }
  -1
}

// The union name of a `LetDecl`: its annotation when that names a union, else the
// union its (un-annotated) initializer produces (`const r = pick(true)`).
export function letUnionNameOf(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    const an = tyNameOf(d.letType)
    if isUName(an) { return an }
    if d.letType < 0 {
      const inf = unionNameOfExpr(d.letInit, fnIx)
      if inf != "" { return inf }
      // A null-hole binding (`let x = null` filled by a later `x = e`) carries
      // its inferred `T|null` value union (A-infer-null).
      return nliNameOf(letIx)
    }
  }
  ""
}

// The UNION return of a function-type NAME (`(i32) => A | B` → "A | B", an alias `(i32) => Sh` → its
// member set via `isUName`), or "" when the name is not a function type returning a multi-member union.
function unionRetOfFnType(fnTyName: string) {
  const arrowAt = annArrowAt(fnTyName)
  if arrowAt >= 1 && fnTyName.length > 0 && fnTyName[0] == '(' {
    const ret = monoUnwrapParens(fnTyName.slice(arrowAt + 2, fnTyName.length))
    if isUName(ret) { return ret }
    if isValueUnionName(ret) { return ret }
    // A value union with a litunion-ALIAS arm (`K0 | i64`): never a registered union
    // alias (a litunion decl is a `UnionDecl`, not a struct `TypeDecl`, so
    // `isVariantBoxUnion` declines it) and not `isValueUnionName` (a `K0` atom is no
    // value atom) — but it boxes as a value union (the alias arm rides the box as its
    // member-string atom), so the name IS the atom set a narrowed read unboxes with.
    if nameIsLitUnionArmValueUnion(ret) { return ret }
  }
  ""
}

// The union return-type NAME of a closure-typed PARAM `name` of function `fnIx` (`g: (i32) => A | B`
// → "A | B"), or "" when `name` is not a union-returning closure param. Lets a value call THROUGH a
// closure param (`g(x)` inside a HOF) classify its result union so a narrowed read unboxes.
function paramUnionRetName(fnIx: i32, name: string) {
  if fnIx < 0 { return "" }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    let i = 0
    while i < fn.fnParams.length {
      const p = P.nodes[fn.fnParams[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            const ty = P.nodes[p.parType]
            if ty is TypeRef { return unionRetOfFnType(ty.tyName) }
          }
          return ""
        }
      }
      i = i + 1
    }
  }
  ""
}

// The union NAME the expression at `exprIx` produces (the name-typed mirror of the
// boolean `exprUnion`): a union-returning call's return annotation, a union-typed
// ident, a parenthesized union. "" when the expression is not union-valued.
export function unionNameOfExpr(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return "" }
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const t = fnIndexOf(callee.identName)
      if t >= 0 {
        const fn = P.nodes[fnStmts[t]]
        if fn is FuncDecl {
          const rn = tyNameOf(fn.fnRet)
          if isUName(rn) { return rn }
          // An UN-annotated function whose returns JOIN to a value union: its inferred
          // name drives the same narrowing/unboxing (`is string` unboxes the box) as an
          // annotation would. Without this an inferred-union binding stays the raw box
          // and a narrowed read mis-types (arrayref vs the union box).
          if fn.fnRet < 0 {
            const im = inferRetNameOf(callee.identName)
            // A value union (`isValueUnionName`) OR a registered struct union (`isUName`
            // — registered from this same inferred name in `collectU`): either drives the
            // binding's narrowing/unboxing exactly as an annotation would.
            if isValueUnionName(im) { return im }
            if im != "" && isUName(im) { return im }
          }
        }
      }
      // A union-returning function VALUE callee (`const f = g; const r = f(7)`): resolve
      // the union name from the underlying lifted function, mirroring the named path above
      // — so a union from a CLOSURE call narrows/unboxes (`if r is i32 { … r … }`), not
      // just one from a named call. Without this the binding keeps the raw box and a
      // narrowed read mis-types (the box ref vs the unboxed scalar).
      const cfe = identClosureFe(callee.identName, fnIx)
      if cfe >= 0 {
        const cfn = P.nodes[fnStmts[cfe]]
        if cfn is FuncDecl {
          const crn = tyNameOf(cfn.fnRet)
          if isUName(crn) { return crn }
          // A VALUE-union annotated return (`i32 | string`, pinned on the lambda by `synthRetAnnots`):
          // `isUName` covers struct unions only, so its narrowed result would not unbox without this.
          if isValueUnionName(crn) { return crn }
          if cfn.fnRet < 0 {
            const cim = inferRetNameOf(cfn.fnName)
            if isValueUnionName(cim) { return cim }
            if cim != "" && isUName(cim) { return cim }
          }
        }
      }
      // A union-returning closure PARAM callee (`callIt(g: (i32) => A | B, x) { … g(x) … }`): resolve
      // the union from the param's function-type annotation, so a narrowed VALUE-union result unboxes
      // inside the HOF body (the struct case reads a field off the variant, so it needs no name).
      const pun = paramUnionRetName(fnIx, callee.identName)
      if pun != "" { return pun }
      // A closure binding whose function-type is INFERRED from a CALL (`const g = mk()` where `mk():
      // (i32) => A | B`): `identClosureFe` can't see through the call result, so recover the closure
      // type from `identFnTypeAnnName` and take its union return.
      const bun = unionRetOfFnType(identFnTypeAnnName(callee.identName, fnIx))
      if bun != "" { return bun }
    }
    // A union-returning FIELD-closure callee (`const r = o.run(7)` over a `(…) => A | B`
    // field) — the Member analogue of the binding case above: resolve the field's lifted
    // function's union name so the result narrows/unboxes.
    if callee is Member {
      const mfe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
      if mfe >= 0 {
        const mfn = P.nodes[fnStmts[mfe]]
        if mfn is FuncDecl {
          const mrn = tyNameOf(mfn.fnRet)
          if isUName(mrn) { return mrn }
          if mfn.fnRet < 0 {
            const mim = inferRetNameOf(mfn.fnName)
            if isValueUnionName(mim) { return mim }
            if mim != "" && isUName(mim) { return mim }
          }
        }
      }
    }
    // FALLBACK (scoped to a CALL — never an if-expr, which has its own union rep path): a union-valued
    // call whose callee the cases above miss (an indexed closure-array element `arr[i](x)`) — render its
    // union from the checker's per-node type, for the value-union UNBOX. The name-typed dual of
    // `exprUnion`'s Call `nodeTyIsUnion` fallback; reached only here, so the costly render is off the
    // hot path (declared / param / binding unions resolve from the cheap annotation above).
    return nodeUnionName(exprIx)
  }
  if e is Ident { return unionNameOfIdent(e.identName, fnIx) }
  // `m[k] ?? d` over a UNION-valued map yields the value union's box — resolve its name (the
  // mv slot's value name) so an un-annotated `const v = m[k] ?? d` narrows/unboxes.
  if e is BinExpr {
    const cmu = coalesceMvSlot(unwrapParen(exprIx), fnIx)
    if cmu >= 0 {
      if mvValKind[cmu] == 2 { return mvValName[cmu] }
    }
  }
  // `ns[i]` over a UNION-element ref list yields the element union's box (the
  // name-typed mirror of `exprUnion`'s Index case) — so an un-annotated
  // `const a = arr[0]` binding resolves its union name for narrowing/unboxing.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemKindTbl.length {
        if rlElemKindTbl[slot] == 2 { return rlElemName[slot] }
      }
    }
    // A bare `m[k]` over a UNION-valued map (the value union's box).
    const mri = mapReadMvSlot(unwrapParen(exprIx), fnIx)
    if mri >= 0 {
      if mvValKind[mri] == 2 { return mvValName[mri] }
    }
  }
  // The name-typed mirror of `exprUnion`'s Member case: a code-16 field read carries
  // the field's union name (its atom set), unless narrowed to one scalar (unboxed).
  if e is Member {
    const mix = unwrapParen(exprIx)
    const mAtom = narrowVariantFor(memberPathKeyOf(mix))
    const mk = valueAtomKind(mAtom)
    if mk >= 0 && mk != 6 { return "" }
    return memberUnionFieldName(mix, fnIx)
  }
  ""
}

// The single scalar atom a binding `name` is currently narrowed to (`"i32"`,
// `"string"`, `"boolean"`, `"i64"`, `"f64"`, `"f32"`), or "" when it is not
// narrowed / narrowed to a sub-union (a pipe-joined set classifies as no atom) /
// narrowed to `null` / narrowed to a struct variant. A non-"" answer means an
// ident READ unboxes to that atom's rep.
export function narrowedValueAtomOf(name: string) {
  const v = narrowVariantFor(name)
  if v == "" { return "" }
  const k = valueAtomKind(v)
  if k >= 0 && k != 6 { return v }
  // A litunion-alias narrow (`x is K0` where `type K0 = "a" | "b"`) unboxes as the
  // STRING ref the box stores its litunion member as (`emitUnionCoerce` boxes it so).
  if k < 0 && nameIsLitUnionType(v) { return "string" }
  ""
}

// The REF-ELEMENT-ARRAY arm a union binding `name` is currently narrowed to (`if x is S[]`
// → `S[]`, `if x is (() => f64)[]` → `(() => f64)[]`), or "" when it is not narrowed to a
// ref array (un-narrowed / a scalar atom / a struct variant / `null` / a sub-union). The
// ref-array analogue of `narrowedValueAtomOf`: a non-"" answer means an ident READ recovers
// the reflist WRAPPER ref from the box (`ref.cast` of the anyref payload) so indexing /
// `.length` see the list directly.
export function narrowedRefArrayOf(name: string) {
  const v = narrowVariantFor(name)
  if v == "" { return "" }
  if valueAtomKind(v) >= 0 { return "" }
  if nameIsRefArray(v) { return v }
  ""
}

// The BARE-CLOSURE arm a union binding `name` is currently narrowed to (`if x is () => i64` →
// `() => i64`), or "" when it is not narrowed to a closure. A closure is value-atom KIND 11, so
// the narrowed READ already unboxes via `narrowedValueAtomOf` + `emitValueUnionUnboxRead` (which
// casts the box payload to `$cloStructIdx`); this filter isolates the closure case so `exprIsClosure`
// can route the narrowed ident's CALL to `call_ref` (and `calleeCloSigKey` to the arm's `$fnsig`).
export function narrowedClosureOf(name: string) {
  const v = narrowedValueAtomOf(name)
  if v != "" && valueAtomKind(v) == 11 { return v }
  ""
}

// The MAP arm a union binding `name` is currently narrowed to (`if x is {[string]: string}` →
// `{[string]: string}`), or "" when it is not narrowed to a map (un-narrowed / a scalar atom /
// a struct variant / a ref array / `null` / a sub-union). The map analogue of `narrowedRefArrayOf`:
// a non-"" answer means an ident READ recovers the MAP STRUCT ref from the box (`ref.cast` of the
// anyref payload) so `x[k]` / `x[k] ?? d` / `x.has(k)` route through the map lowering directly.
export function narrowedMapOf(name: string) {
  const v = narrowVariantFor(name)
  if v == "" { return "" }
  if valueAtomKind(v) >= 0 { return "" }
  // A narrow can land on a member SET, not a single arm: `t != null` over a map-member
  // union (`{[string]: V} | string | null`) narrows to `{[string]: V}|string` — a name
  // that STARTS with `{[` (so `nameIsMap` matches) but is still a union BOX, not a bare
  // map. Without the member-union guard a rebind under that narrow (`const t1 = t0`)
  // classified as a MONO map local and every read of it emitted the wrong rep — invalid
  // wasm (the same guard every `paramMap` / `retMapFlag` / `nameFieldCode` site carries).
  if nameIsMap(v) && !nameIsMapMemberUnion(v) { return v }
  ""
}

// The atom KIND an IDENT expression currently reads as, for the scalar/string
// classifiers (`exprString`/`exprIsBool`/`exprIsI64`/`exprIsF64`/`exprIsF32`):
// `valueAtomKind` codes when the ident is a union binding narrowed to ONE scalar
// atom (the read unboxes to that atom's rep), -2 when it is a union binding NOT
// narrowed to a single atom (the read is the BOX ref — no scalar classification,
// even if the binding's INIT was a string/bool literal), or -3 when the
// expression is not a union-typed ident at all (the caller keeps its existing
// classification rules).
function unionIdentReadKind(exprIx: i32, fnIx: i32) {
  const e = P.nodes[exprIx]
  if e is Ident {
    if unionNameOfIdent(e.identName, fnIx) != "" {
      const a = narrowedValueAtomOf(e.identName)
      if a != "" { return valueAtomKind(a) }
      return -2
    }
  }
  -3
}

// The member-path dual of `unionIdentReadKind`: the atom KIND a UNION-typed
// struct-FIELD read (`o.y`, field code 16) currently reads as — the narrowed
// single atom's kind when the member PATH is narrowed (the read unboxes to that
// atom's rep), -2 for an un-narrowed box read, -3 when the expression is not a
// union-field member at all.
function memberUnionReadKind(exprIx: i32, fnIx: i32) {
  const e = P.nodes[exprIx]
  if e is Member {
    if memberUnionFieldName(exprIx, fnIx) != "" {
      const a = narrowedValueAtomOf(memberPathKeyOf(exprIx))
      if a != "" { return valueAtomKind(a) }
      return -2
    }
  }
  -3
}

// The CURRENT narrowed atom set of the union binding `name`: its innermost active
// narrowing when one exists (which may already be a sub-union), else its declared
// union's full member set (the union name itself). "" when not a union binding.
export function currentNarrowSetOf(name: string, fnIx: i32) {
  const v = narrowVariantFor(name)
  if v != "" { return v }
  unionNameOfIdent(name, fnIx)
}

// The FULL pipe-joined member set of the union named `name`: a registered alias
// returns its `unMemberSet` entry (a declared `type N = A | B` expands to "A|B",
// atom members like `null` kept); an unregistered / already-pipe-joined name
// passes through unchanged. Lets complement narrowing subtract variants from an
// ALIAS-annotated binding's set.
export function unionMemberSetOf(name: string) {
  let u = 0
  while u < unNames.length {
    if unNames[u] == name { return unMemberSet[u] }
    u = u + 1
  }
  name
}

// The CURRENT narrowed variant set of a STRUCT-union binding `name`: its innermost
// active narrowing when one exists (which may already be a subtracted sub-set),
// else its declared union's FULL member set (alias names expanded so subtraction
// sees every variant + a `null` member). "" when not a union binding.
export function currentStructNarrowSetOf(name: string, fnIx: i32) {
  const v = narrowVariantFor(name)
  if v != "" { return v }
  unionMemberSetOf(unionNameOfIdent(name, fnIx))
}

// The map-value compat of an object literal's field VALUE against a candidate
// variant's code-19 field: the literal's checker-recorded map value type must not
// contradict the variant's recorded value rep (`elem`). Lenient when the value is
// not classifiable as a map (a non-map value already fails the construct loudly
// downstream); an ATOM-valued literal field is compatible with any MONO elem (both
// ride the shared `$mStructIdx` — the checker render would collapse it to `string`,
// so it is classified through the recorded litunion bit BEFORE rendering).
function objMapFieldCompat(objIx: i32, fname: string, elem: string): boolean {
  const valIx = objFieldVal(objIx, fname)
  if valIx < 0 { return true }
  if !nodeTyIsMap(valIx) { return true }
  if nodeTyMapValIsLitUnion(valIx) { return mvValKindOfName(elem) == -1 }
  mvValNamesCompat(nodeTyMapValName(valIx), elem)
}

// The nested-struct compat of an object literal's field VALUE against a candidate
// variant's code-15 field: a nested LITERAL value's field-NAME set must equal the
// recorded target struct's (`elem`) — the code-15 twin of `objMapFieldCompat`.
// NAME-set only, deliberately: the checker records the literal's INFERRED leaf types
// (`{f: 663810583}` reads i32 where the arm declares i64), so a canonical-key compare
// here false-rejects every widening construct. A non-literal value stays lenient (its
// type already checked at the boundary; a wrong one fails loudly downstream).
function objNestedFieldCompat(
  objIx: i32,
  fname: string,
  elem: string,
): boolean {
  const valIx = objFieldVal(objIx, fname)
  if valIx < 0 { return true }
  const v = P.nodes[unwrapParen(valIx)]
  if v is ObjLit {
    const si = structIndexByName(elem)
    if si < 0 { return true }
    if v.objFields.length != sFieldCount[si] { return false }
    let fi = 0
    while fi < sFieldCount[si] {
      if objFieldVal(valIx, sFieldNames[sFieldStart[si] + fi]) < 0 {
        return false
      }
      fi = fi + 1
    }
  }
  true
}

// The variant struct name an object literal at `objIx` matches: the union variant
// whose field-name set EQUALS the literal's field names (order-independent), or "" if
// none. Used to pick the tag + variant struct when boxing an object literal into the
// union. A MAP-typed candidate field (code 19) is additionally tightened by its VALUE
// rep (`objMapFieldCompat`): two unions' arms sharing the field-name set but differing
// in the map's VALUE (`{f: {[string]: i32}} | i32` and `{f: {[string]: string}} | i64`
// in one program) must not collide onto the first arm's slot — the literal's typed map
// ref then mis-fed the other value rep's struct (invalid wasm at the construct).
export function objVariantName(objIx: i32) {
  const o = P.nodes[objIx]
  if o is ObjLit {
    let vi = 0
    while vi < uVariants.length {
      if objMatchesVariantIdx(objIx, vi) { return uVariants[vi] }
      vi = vi + 1
    }
  }
  ""
}

// Whether the object literal at `objIx` matches variant `vi`: the field-name set
// EQUALS the variant's (order-independent), tightened per field by the value rep — a
// map field (code 19) by `objMapFieldCompat`, a nested-struct field (code 15) by
// `objNestedFieldCompat`. The one matcher behind `objVariantName` (global scan) and
// `unionArmVariantForObj` (union-context scan), so the two resolutions never diverge.
function objMatchesVariantIdx(objIx: i32, vi: i32): boolean {
  const o = P.nodes[objIx]
  if o is ObjLit {
    const cnt = uFieldCount[vi]
    if cnt != o.objFields.length { return false }
    const start = uFieldStart[vi]
    let allMatch = true
    let fj = 0
    while fj < cnt {
      if objFieldVal(objIx, uFieldNames[start + fj]) < 0 {
        allMatch = false
      } else if uFieldTypes[start + fj] == 19 {
        if (
          !objMapFieldCompat(
            objIx,
            uFieldNames[start + fj],
            uFieldElemName[start + fj],
          )
        ) {
          allMatch = false
        }
      } else if uFieldTypes[start + fj] == 15 {
        // A NESTED-STRUCT candidate field (code 15) is tightened by its target's
        // field-name set, exactly as a map field is by its value rep.
        if (
          !objNestedFieldCompat(
            objIx,
            uFieldNames[start + fj],
            uFieldElemName[start + fj],
          )
        ) {
          allMatch = false
        }
      }
      fj = fj + 1
    }
    return allMatch
  }
  false
}

// The VARIANT table index of the arm OF THE UNION whose registered member set is
// `unionSet` (pipe-joined) that the object literal at `objIx` matches, or -1. The
// union-CONTEXT-restricted `objVariantName`: `emitUnionCoerce` KNOWS its target
// union, so the literal must match one of ITS arms — the global scan's first
// name-set match can land on ANOTHER union's arm sharing the field names (two
// unions' nested-struct arms differing only in a nested layout collided onto the
// first arm's tag — a silent wrong-arm construct). Falls back to -1 (caller keeps
// the global scan) when the set is not a registered union.
export function unionArmVariantForObj(unionSet: string, objIx: i32): i32 {
  let u = 0
  while u < unNames.length {
    if unNames[u] == unionSet || unMemberSet[u] == unionSet {
      let vi = unVarStart[u]
      while vi < unVarStart[u] + unVarCount[u] {
        if objMatchesVariantIdx(objIx, vi) { return vi }
        vi = vi + 1
      }
      return -1
    }
    u = u + 1
  }
  -1
}

// ── array-typedness of expressions ───────────────────────────────────────────
// Parallel to the struct family above: decide whether an expression / param / local
// PRODUCES the i32 array (a `(ref $aTypeIdx)`) rather than an i32. An index read
// `a[i]` and `a.length` are i32 (NOT arrays), so they are deliberately absent here.

// True if the function `name` declares an array (`i32[]`) as its return type.
function fnRetArray(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetKind[i] == "list"
}

// True if the already-collected declared local `name` is an i32-array ref (code `2`).
function declaredArray(name: string) { declaredKind(name) == "list" }

// True if evaluating the expression at `exprIx` yields the i32 array: an array
// literal (with i32 / no elements — a ref-element literal is NOT this), an
// array-returning call, an array param/local reference, or a parenthesized array
// The wasm-type code of the struct / variant FIELD a `Member` expression at `memIx`
// reads (`0` i32, `3` string, `4` i32-list, `5` ref-list), or `-1` if `memIx` is not a
// field read of a known struct/variant field. Mirrors `exprString`'s Member dispatch:
// a read on a NARROWED union identifier reads the variant field's type; otherwise the
// receiver's struct field's type. Used by `exprArray`/`exprRefArray` to type array-field
// reads (gap #5) so `.length` / indexing / assignment treat the result as a list.
function memFieldTypeCode(memIx: i32, fnIx: i32) {
  const e = P.nodes[memIx]
  if e is Member {
    if memIsNarrowed(memIx) {
      const vi = memNarrowVariantIndex(memIx)
      if vi >= 0 {
        const vfi = variantFieldIndex(vi, e.memProp)
        if vfi >= 0 { return variantFieldTypeAt(vi, vfi) }
      }
      return -1
    }
    // A field read on a VARIANT-typed param `o.field` (`o: TyObj`) reads the variant
    // struct's field type directly (gap #2) — same table as a narrowed read, but the
    // receiver is the unboxed param, not a `narrowName` ident.
    const pvi = exprVariantIndex(e.memObj, fnIx)
    if pvi >= 0 {
      const pvfi = variantFieldIndex(pvi, e.memProp)
      if pvfi >= 0 { return variantFieldTypeAt(pvi, pvfi) }
    }
    const si = structIndexOfExpr(e.memObj, fnIx)
    if si >= 0 {
      const fi = sFieldIndex(si, e.memProp)
      if fi >= 0 { return sFieldTypeAt(si, fi) }
    }
  }
  -1
}

// expression. An index read / `.length` yields an i32, so neither counts.
// True when the ident `name`, read inside frame `fnIx`, is SHADOWED by a binding of
// the frame itself — a declared param of `fnIx`, or a collected declared local (the
// per-function `localNames` registry; at module scope the registry holds the start
// function's loop vars / block-nested lets). The `expr*Array` GLOBAL fallbacks must
// not resolve `name` through a module global when such an inner binding exists:
// scope resolution picks the inner binding whatever its kind, so the global's kind
// is not this read's kind. (The #922 shadow hole: a param/local list named like a
// GLOBAL list of a DIFFERENT element kind routed `.push` through the global's
// classification — the push frame's typed locals then mismatched the receiver's
// actual wrapper ref, invalid wasm.) Each classifier checks its OWN param/declared
// kind BEFORE its global fallback, so gating only the fallback preserves every
// same-kind answer and only turns the cross-kind global claim off.
function identShadowedByFrame(fnIx: i32, name: string) {
  if paramIndexOf(fnIx, name) >= 0 { return true }
  declaredSlotOf(name) >= 0
}

export function exprArray(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  if tyKindOf(nodeTyIxOf(exprIx)) == 2 {
    return true // typed-IR fast path (see exprIsF64)
  }
  const e = P.nodes[exprIx]
  if e is ArrayLit { return !arrLitIsRef(exprIx) }
  if e is Paren { return exprArray(e.parInner, fnIx) }
  if e is Call {
    // An INDEXED closure call `fs[i](x)` whose element signature returns `i32[]`.
    if cloArrCallRetKind(exprIx, fnIx) == "list" { return true }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      // The intrinsic allocators yield an i32 list unless the fill is f64
      // (`arrNewIntrKind` 1 — then `exprF64Array` claims the call).
      if arrNewIntrKind(exprIx, fnIx) == 0 { return true }
      if fnRetArray(callee.identName) { return true }
      // A closure-VALUE call (`g(x)` with `g: (i32) => i32[]`) whose resolved sig
      // result is the i32 list (`>a`) — so `const xs = g(x)` types `xs` as a
      // list and its `.length` / index reads lower through the list machinery.
      return calleeRetKind(callee.identName, fnIx) == "list"
    }
    // `xs.map(f)` / `xs.filter(p)` yield a NEW list — the i32 list exactly when the
    // result ELEMENT kind is i32/boolean (map: the callback's return kind; filter:
    // the receiver's element kind).
    if callIsMapFilter(exprIx, fnIx) {
      return mfResultKindOf(exprIx, fnIx) == "i32"
    }
    // `xs.slice(...)` yields the same list kind as its receiver — an i32 list iff the
    // receiver is one.
    if callIsArrSlice(exprIx, fnIx) {
      return mfResultKindOf(exprIx, fnIx) == "i32"
    }
    // `m.values()` over an i32-valued map yields an i32 list.
    if mapValuesResultKind(exprIx, fnIx) == 2 { return true }
    return false
  }
  if e is Ident {
    // A value-union ident narrowed to a KIND-7 i32-backed LIST atom classifies as an
    // i32 list in the narrowed branch, checked FIRST — the binding's DECLARED type is
    // the union, so the param/local/global tests below miss it. Two narrowing spellings:
    // `is i32[]` / `is (boolean | null)[]` / `is (K | null)[]` read UNBOXED via
    // `emitValueUnionUnboxRead` (the union-ident read kind), and `is K0[]` (a
    // litunion-array member on the i32-list backing) via the narrowed value-atom.
    if unionIdentReadKind(exprIx, fnIx) == 7 { return true }
    if valueAtomKind(narrowedValueAtomOf(e.identName)) == 7 { return true }
    if paramArray(fnIx, e.identName) { return true }
    if declaredArray(e.identName) { return true }
    if globalIsArray(e.identName) {
      if !identShadowedByFrame(fnIx, e.identName) { return true }
    }
    // A NULLABLE i32-list binding (`i32[] | null`, kind 15) participates in the
    // list machinery — narrowing is type-level, so every list op classifies the
    // read as a list; the op's read site inserts the `ref.as_non_null` recover.
    if paramNulList(fnIx, e.identName) { return true }
    if declaredNulList(e.identName) { return true }
    if globalIsNulList(e.identName) {
      if !identShadowedByFrame(fnIx, e.identName) { return true }
    }
    // A CAPTURED i32-list read (`store[k]` inside a closure capturing `store`).
    return capturedKindOf(fnIx, e.identName) == "list"
  }
  // A list CONCAT `a + b` yields a NEW i32 list (collections-design §VL.4).
  if e is BinExpr {
    if e.binOp == "+" {
      if (
        exprArray(e.binLeft, fnIx) &&
        !exprStringArray(e.binLeft, fnIx) &&
        !exprRefArray(e.binLeft, fnIx)
      ) {
        return exprArray(e.binRight, fnIx)
      }
    }
    // `m[k] ?? d` over an i32-LIST-valued map (`{[string]: i32[]}`) yields the value i32 list.
    if e.binOp == "??" {
      if mvListValKind(coalesceMvSlot(exprIx, fnIx)) == "list" { return true }
    }
    return false
  }
  // A field read `p.items` whose struct field is an `i32[]` (code `4`) yields the i32
  // list wrapper ref — so `.length` / indexing / assignment treat it as a list (gap #5).
  // A NULLABLE list field (code 18) classifies the same way (see the Ident rule).
  if e is Member {
    if memFieldTypeCode(exprIx, fnIx) == 4 { return true }
    if memFieldTypeCode(exprIx, fnIx) == 18 { return true }
  }
  // `m[i]` over an `i32[][]` ref list (element kind 4) yields the INNER i32 list,
  // so a chained `m[i][j]` / `m[i].length` treats it as a list.
  if e is Index {
    if nestedRefListElemIs(e.idxArr, fnIx, 4) { return true }
    // A bare `m[k]` over an i32-LIST-valued map yields the value i32 list (`V | null` — the
    // list machinery recovers non-null at the read site).
    if mvListValKind(mapReadMvSlot(exprIx, fnIx)) == "list" { return true }
  }
  false
}

// True if the `LetDecl` at `letIx` declares an array-typed local: its annotation is an
// array type (`i32[]`), OR its initializer produces an array. Picks the local's
// valtype (`(ref $aTypeIdx)` vs i32) in `collectLocals`.
export function letIsArray(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsI32Array(lt.tyName) { return true }
      }
    }
    return exprArray(d.letInit, fnIx)
  }
  false
}

// ── ref-array-typedness of expressions (G7-ref) ───────────────────────────────
// Parallel to the i32-array family: decide whether an expression / param / local
// PRODUCES a REF list — `Tok[]` / `Node[]`, a `(ref $rlTypeIdx)`. Its receiver shapes
// mirror `exprArray` but for `S[]`/`N[]` annotations (the index/`.length` reads still
// yield i32 / the element, not the list). `localIsRef` code `5` flags a ref-list local.

// True if function `name` declares a ref array (`S[]`/`N[]`) as its return type.
function fnRetRefArray(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetKind[i] == "reflist"
}

// True if the parameter `name` of function `fnIx` is a ref-array type.
function paramRefArray(fnIx: i32, name: string) {
  const pt = paramTypeNode(fnIx, name)
  // STRUCTURAL fast-path (C1): a recorded array-of-declared-struct param, else the name test.
  if nodeTyIsStructArray(pt) { return true }
  nameIsRefArray(tyNameOf(pt))
}

// True if the parameter `name` of function `fnIx` is a NULLABLE ref-array type (`<ref-array> | null`,
// kind 18 — e.g. `i32[][] | null`, `S[] | null`). The param analogue of `paramRefArray`: `retNulRefArrFlag`
// (already `| null`-aware) recognizes the annotation. Lets `exprNullableRefArray` / `exprRefArray` classify
// a nulreflist PARAM (its `!= null` narrow + narrowed indexing), which #877 wired only for a LOCAL.
function paramNulRefArray(fnIx: i32, name: string) {
  retNulRefArrFlag(paramTypeNode(fnIx, name)) == 1
}

// True if the already-collected declared local `name` is a ref-list ref (code `5`).
function declaredRefArray(name: string) { declaredKind(name) == "reflist" }

// True if evaluating the expression at `exprIx` yields a ref list: a ref-element array
// literal, a ref-array-returning call, a ref-array param/local reference, or a
// parenthesized ref-array expression. An index read / `.length` is NOT a list.
export function exprRefArray(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is ArrayLit { return arrLitIsRef(exprIx) }
  if e is Paren { return exprRefArray(e.parInner, fnIx) }
  // `m[k]` / `m[k] ?? d` over a struct-LIST-valued map yields a struct ref list.
  if mapReadListKind(exprIx, fnIx) == "reflist" { return true }
  if e is Call {
    // `__array_new__(n, {…})` builds a ref list of the element struct (kind 3).
    if arrNewIntrKind(exprIx, fnIx) == 3 { return true }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetRefArray(callee.identName) { return true }
      // A closure-VALUE callee returning a ref list (`mk: () => S[]`) — its resolved `$fnsig`
      // result is the ref-list wrapper (`>r<slot>;`), so `mk()[i]` indexes it directly.
      return calleeRetKind(callee.identName, fnIx) == "reflist"
    }
    // A `.filter` over a struct/union array yields the SAME ref list (kind 2).
    if callee is Member {
      if mfResultKindOf(exprIx, fnIx) == "ref" { return true }
    }
    // `m.values()` over a struct- / nested-list- / nested-map-valued map yields a ref list.
    if mapValuesResultKind(exprIx, fnIx) == 5 { return true }
    // GENERAL FALLBACK: a value call the resolvers above miss — a NARROWED union
    // binding's closure arm (`t0(1)` after `if t0 is (i32) => S[]`), a struct-FIELD
    // closure (`v.f(1)`), an INDEXED closure-array element (`v[0](1)`) — classifies by
    // its resolved `$fnsig` result (`cloCallSigKey`, whose own fallback derives the key
    // from the callee's CHECKER type). The consumer dual of the call emit's sig
    // resolution, so the two always agree. A UNION-BOX element slot (kind 2 —
    // `(i64 | string)[]`) is claimed too: the element's narrowed binding read rides the
    // interned union-box element machinery, and the lambda-side sig now adopts the
    // union-element list result, so the producers agree with this claim.
    const gk = cloCallSigKey(exprIx, fnIx)
    if sigKeyRetKind(gk) == "reflist" {
      const gs = sigKeyRetSlot(gk)
      if gs >= 0 && gs < rlElemKindTbl.length { return true }
    }
    return false
  }
  if e is Ident {
    // A union binding NARROWED to a ref-element array arm (`if x is S[]` then `x[i]` / `x.length`):
    // its box unboxes to the reflist wrapper, so it IS a ref array in the narrowed branch. Checked
    // FIRST — the binding's DECLARED type is a union, so the param/local/global tests below miss it.
    if narrowedRefArrayOf(e.identName) != "" { return true }
    // A kind-18 NULLABLE ref-array local is a ref array too (narrowed `if t != null`) — so indexing /
    // `.length` reuse the ref-array machinery; the index emit recovers non-null for the niche receiver.
    if declaredKind(e.identName) == "nulreflist" { return true }
    // A nulreflist PARAM narrowed non-null is a ref array too — index / `.length` reuse the
    // ref-array machinery (the index emit recovers non-null for the niche receiver).
    if paramNulRefArray(fnIx, e.identName) { return true }
    if paramRefArray(fnIx, e.identName) { return true }
    if declaredRefArray(e.identName) { return true }
    if identShadowedByFrame(fnIx, e.identName) { return false }
    return globalIsRefArray(e.identName)
  }
  // A field read `p.items` whose struct field is a `T[]`/`N[]` (code `5`) yields the ref
  // list wrapper ref — so `.length` / indexing / assignment treat it as a ref list.
  if e is Member {
    if memFieldTypeCode(exprIx, fnIx) == 5 { return true }
  }
  // Indexing a NESTED ref array (`g[i]` where `g: S[][]`, kind-9 elements): each element IS the
  // inner ref list, so the index yields a ref array. Recurses — `g[i][j]` over `S[][][]` is a ref
  // array too (the inner slot is itself kind 9).
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemKindTbl.length {
        return rlElemKindTbl[slot] == 9
      }
    }
  }
  false
}

// The ref-list ELEMENT type-NAME a ref-array param `name` of function `fnIx` declares
// (`p: Tok[]` → `Tok`), or "" if not a ref-array param.
function paramRefArrayName(fnIx: i32, name: string) {
  if fnIx < 0 {
    return "" // module-scope initializer (no enclosing function)
  }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    const params = fn.fnParams
    let i = 0
    while i < params.length {
      const p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            const ty = P.nodes[p.parType]
            if ty is TypeRef {
              if nameIsRefArray(ty.tyName) { return refArrElemName(ty.tyName) }
            }
          }
          return ""
        }
      }
      i = i + 1
    }
  }
  ""
}

// The ref-list ELEMENT type-NAME a function `name` returns (from its `S[]`/`N[]` return
// annotation, recorded in `fRetRArrElem`), or "".
function fnRetRefArrayName(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return "" }
  fRetRArrElem[i]
}

// The INNER ref-list element type-NAME a function `name` returns when its return is a NULLABLE ref array
// (`i32[][] | null` → the inner `i32[]`), else "". Reads the return-type node directly (`fRetRArrElem`
// records only the NON-null ref-array element), so a consumer `const t = mk()` infers the kind-18 niche
// and its `!= null` narrow + narrowed indexing resolve the inner ref-list slot.
function fnRetNulRefArrayName(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return "" }
  const fn = P.nodes[fnStmts[i]]
  if fn is FuncDecl {
    if fn.fnRet >= 0 {
      const np = nullablePartOf(tyNameOf(fn.fnRet))
      if np != "" && nameIsRefArray(np) { return refArrElemName(np) }
    }
  }
  ""
}

// The ref-list ELEMENT type-NAME of the declared local `name` (recorded in
// `localStructIdx` as its table SLOT for code-5 locals), or "".
function declaredRefArrayName(name: string) {
  const i = declaredSlotOf(name)
  if i >= 0 {
    if localIsRef[i] == "reflist" {
      const slot = localStructIdx[i]
      if slot >= 0 {
        if slot < rlElemName.length { return rlElemName[slot] }
      }
    }
  }
  ""
}

// The ref-list ELEMENT type-NAME a module global `name` declares (`S[]`/`N[]`), or "".
function globalRefArrayName(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return "" }
  letRefListElemName(li, -1)
}

// The ref-list ELEMENT type-NAME the expression at `exprIx` produces, or "" if it is not
// a ref list. Mirrors `exprRefArray`'s receiver shapes — used to resolve the per-element-
// type table SLOT (`refListSlotOfExpr`) at every push / index / `.length` / store site.
export function refListElemNameOfExpr(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return "" }
  const e = P.nodes[exprIx]
  if e is ArrayLit { return arrLitElemName(exprIx) }
  if e is Paren { return refListElemNameOfExpr(e.parInner, fnIx) }
  // `m[k]` / `m[k] ?? d` over a struct-LIST-valued map — the element is the value's struct.
  const slsMv = mapReadStructListMvSlot(exprIx, fnIx)
  if slsMv >= 0 { return refArrElemName(mvValName[slsMv]) }
  if e is Call {
    // `__array_new__(n, {…})` — the ref-list element name is the fill's struct.
    if arrNewIntrKind(exprIx, fnIx) == 3 {
      const asi = structIndexOfExpr(e.callArgs[1], fnIx)
      if asi >= 0 { return sNames[asi] }
      return ""
    }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const fn = fnRetRefArrayName(callee.identName)
      if fn != "" { return fn }
      // A nulreflist-returning function (`mk: () => i32[][] | null`): the INNER ref-list element name.
      const nfn = fnRetNulRefArrayName(callee.identName)
      if nfn != "" { return nfn }
      // A closure-VALUE callee returning a ref list (`mk: () => S[]`): its element name is the
      // `rlElemName` of the `>r<slot>;` result slot parsed off the callee's resolved `$fnsig`
      // (kind-gated on `"reflist"` — the shared slot reader parses ANY slot-carrying result).
      const ck = calleeCloSigKey(callee.identName, fnIx)
      if sigKeyRetKind(ck) == "reflist" {
        const rs = sigKeyRetSlot(ck)
        if rs >= 0 && rs < rlElemName.length { return rlElemName[rs] }
      }
      // A NARROWED union binding's closure arm (`t0(1)` after `if t0 is (i32) => S[]`):
      // the name-based `calleeCloSigKey` misses it, but the general `cloCallSigKey`
      // fallback derives the key from the callee's CHECKER type — the same key the call
      // emit resolves, so the element slot always matches the called functype's. A
      // union-box element slot (kind 2) resolves too, like `exprRefArray`'s fallback.
      const nk = cloCallSigKey(exprIx, fnIx)
      if sigKeyRetKind(nk) == "reflist" {
        const nrs = sigKeyRetSlot(nk)
        if nrs >= 0 && nrs < rlElemName.length { return rlElemName[nrs] }
      }
      return ""
    }
    // A ref-valued `m.values()` yields a ref list whose element is the map's VALUE — read
    // its name off the value's mv ref-list slot (`mvRlSlot`). Checked before the `.filter`
    // result-slot path (a `.values()` is not a `.map`/`.filter`).
    if callee is Member {
      if callee.memProp == "values" {
        if exprMap(callee.memObj, fnIx) {
          const vsh = mapShapeOfExpr(callee.memObj, fnIx)
          if vsh >= 0 {
            const rs = mvRlSlot[vsh]
            if rs >= 0 { return rlElemName[rs] }
          }
        }
      }
      const ms = mfResultSlotOf(exprIx, fnIx)
      if ms >= 0 { return rlElemName[ms] }
    }
    // A struct-FIELD closure call (`v.f(1)` — the callee is a Member) or an INDEXED
    // closure-array element call (`v[0](1)` — the callee is an Index) whose result is a
    // ref list: the resolved `$fnsig` result slot names the element (the same
    // `cloCallSigKey` fallback as the Ident-callee arm above; a union-box element slot
    // — kind 2 — likewise resolves).
    const mk2 = cloCallSigKey(exprIx, fnIx)
    if sigKeyRetKind(mk2) == "reflist" {
      const mrs2 = sigKeyRetSlot(mk2)
      if mrs2 >= 0 && mrs2 < rlElemName.length { return rlElemName[mrs2] }
    }
    return ""
  }
  if e is Ident {
    // A union binding NARROWED to a ref-element array arm (`if x is S[]` then `x[i]`): its element
    // name is the arm's, so `refListSlotOfExpr` resolves the wrapper the narrowed read casts to.
    const raN = narrowedRefArrayOf(e.identName)
    if raN != "" { return refArrElemName(raN) }
    // A kind-18 nullable ref-array local stores its INNER ref-list slot in `localStructIdx`; its element
    // name is that inner slot's element name, so `refListSlotOfExpr` round-trips back to the inner slot.
    if declaredKind(e.identName) == "nulreflist" {
      const sl18 = declaredSlotOf(e.identName)
      if sl18 >= 0 {
        const is18 = localStructIdx[sl18]
        if is18 >= 0 && is18 < rlElemName.length { return rlElemName[is18] }
      }
    }
    // A nulreflist PARAM (`p: i32[][] | null`) — its inner ref-list element name is the ref-array's
    // element (`refArrElemName` of the `| null`-stripped annotation), so `refListSlotOfExpr` resolves
    // the inner wrapper the narrowed `p[i]` read casts to (the param analogue of the local block above).
    if paramNulRefArray(fnIx, e.identName) {
      const np18 = nullablePartOf(tyNameOf(paramTypeNode(fnIx, e.identName)))
      if np18 != "" { return refArrElemName(np18) }
    }
    const pn = paramRefArrayName(fnIx, e.identName)
    if pn != "" { return pn }
    const dn = declaredRefArrayName(e.identName)
    if dn != "" { return dn }
    return globalRefArrayName(e.identName)
  }
  if e is Member {
    // A `recv.field` ref-list field read — the field's element name from the receiver's
    // struct / narrowed variant.
    if memIsNarrowed(exprIx) {
      const vi = memNarrowVariantIndex(exprIx)
      if vi >= 0 {
        const vfi = variantFieldIndex(vi, e.memProp)
        if vfi >= 0 { return uFieldElemName[uFieldStart[vi] + vfi] }
      }
      return ""
    }
    const si = structIndexOfExpr(e.memObj, fnIx)
    if si >= 0 {
      const fi = sFieldIndex(si, e.memProp)
      if fi >= 0 { return sFieldElemNameAt(si, fi) }
    }
  }
  // Indexing a NESTED ref array (`g[i]` where `g: S[][]`): the element of `g[i]` is the element
  // of `g`'s element list — strip ONE `[]` off `g`'s element name (`S[]` → `S`). Recurses for
  // deeper nesting (`g[i][j]` over `S[][][]`).
  if e is Index {
    const outer = refListElemNameOfExpr(e.idxArr, fnIx)
    if outer != "" && nameIsArray(outer) { return refArrElemName(outer) }
  }
  ""
}

// The per-element-type ref-list table SLOT the expression at `exprIx` produces, or 0
// (slot fallback) if the element type can't be resolved — every migrated site uses this
// to pick the right backing/wrapper/element indices.
export function refListSlotOfExpr(exprIx: i32, fnIx: i32) {
  const nm = refListElemNameOfExpr(exprIx, fnIx)
  const s = rlSlotByName(nm)
  if s < 0 { return 0 }
  s
}

// True if the `LetDecl` at `letIx` declares a ref-list local: its annotation is a ref
// array (`S[]`/`N[]`), OR its initializer produces a ref list. Picks the local's valtype
// (`(ref $rlTypeIdx)`) and the code-`5` flag in `collectLocals`.
export function letIsRefArray(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        // A UNION annotation (even `S[] | i64`, a union WITH a ref-array member) is a union-BOX
        // local, NOT a reflist local — the init coerces into the box. Return false so a ref-array
        // INIT below does not mis-pick the reflist valtype (an invalid boxed-store otherwise).
        if isUName(lt.tyName) { return false }
        if nameIsRefArray(lt.tyName) { return true }
      }
    }
    return exprRefArray(d.letInit, fnIx)
  }
  false
}

// The ref-list ELEMENT type-NAME a ref-list `LetDecl` binds: from its `S[]`/`N[]`
// annotation if present, else inferred from its initializer (`refListElemNameOfExpr`).
// "" if not a ref-list local.
function letRefListElemName(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsRefArray(lt.tyName) { return refArrElemName(lt.tyName) }
      }
    }
    return refListElemNameOfExpr(d.letInit, fnIx)
  }
  ""
}

// The ref-list TABLE SLOT a ref-list `LetDecl` binds (stored in `localStructIdx` for a
// code-5 local so `declaredRefArrayName` can recover its element type), or -1.
export function letRefListSlot(letIx: i32, fnIx: i32) {
  rlSlotByName(letRefListElemName(letIx, fnIx))
}

// The ref-list element kind a `LetDecl`'s ANNOTATION declares (`S[]` → 1, `N[]` → 2),
// or `0` when it is not a ref-array annotation. Used to type an empty `[]` initializer
// (a non-empty literal types itself from its elements).
export function letAnnRefListKind(letIx: i32) {
  // `pendingListKind` semantics: 1 = struct/MAP ref list (use `pendingListSlot`),
  // 2 = union box ref list, 3 = string list. Delegates to the shared `tyAnnRefListKind`
  // over the let's `letType` so the let / return / call-arg / global seeds agree.
  const d = P.nodes[letIx]
  if d is LetDecl {
    const k = tyAnnRefListKind(d.letType)
    if k == 0 {
      // An UN-ANNOTATED empty `[]` whose pushes infer a string element
      // (`letInfStrListByUse`) seeds the string-list kind, so the empty literal
      // builds the string-list wrapper (not the default i32 list).
      if letInfStrListByUse(letIx) { return 3 }
    }
    return k
  }
  0
}

// The ref-list TABLE SLOT a `LetDecl`'s ref-array annotation names (`let xs: Tok[] = []`
// → the `Tok` slot), or 0 when it is not a ref-array annotation. Threads `pendingListSlot`
// so an empty `[]` initializer builds the annotation's distinct element type.
export function letAnnRefListSlot(letIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl { return tyAnnRefListSlot(d.letType) }
  0
}

// The STRUCT TABLE INDEX a `LetDecl`'s annotation names (`let b: B = { … }` → B's index),
// or -1 when the let is un-annotated OR its annotation names a non-struct (a union alias,
// `i32`, an array). Threads `pendingStructIdx` so an annotated struct literal builds the
// annotation's struct over a first-field-name match. An un-annotated `let` is left to the
// literal's own field-shape (-1).
export function letAnnStructIdx(letIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef { return structIndexByName(lt.tyName) }
    }
  }
  -1
}

// The union-VARIANT table index a `LetDecl`'s annotation names (`const c: Cat`), or -1.
// Seeds `pendingVariantIdx` so the object-literal init builds the bare variant (kind 8).
export function letAnnVariantIdx(letIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef { return variantIndexOf(lt.tyName) }
    }
  }
  -1
}

// Shared `g[i]` NESTED-array test for the scalar-element list families (string / f64 /
// f32 / i64): indexing a `T[][]` ref list whose INNER element kind is `elemKind` yields
// the inner `T[]`, so `g[i][j]` reads the scalar. The four `exprXArray` walks used a
// byte-identical block differing only in the `rlElemKindTbl` constant (string 6, f64 7,
// i64 8, f32 10); this is that block, parameterized by `elemKind`. (The i32 `exprArray`
// and the ref `exprRefArray` Index cases carry extra per-type logic and stay inline.)
function nestedRefListElemIs(idxArr: i32, fnIx: i32, elemKind: i32) {
  if exprRefArray(idxArr, fnIx) {
    const slot = refListSlotOfExpr(idxArr, fnIx)
    if slot >= 0 && slot < rlElemKindTbl.length {
      // A NULLABLE-niche element (`(f64[] | null)[]`, kinds 6/7/8/10 with the `| null`
      // slot key) reads `(ref null $wrapper)` — a nullable leaf list (`nulf64list` …,
      // `exprNulScalarListKind`'s Index arm), NOT the non-null leaf list; claiming it
      // here would route an unnarrowed read through the non-null scalar path.
      if rlElemNullable[slot] == 1 { return false }
      if rlElemKindTbl[slot] == elemKind { return true }
    }
  }
  false
}

// ── string-array-typedness of expressions (`string[]`) ────────────────────────
// Parallel to the ref-array family: decide whether an expression / param / local
// PRODUCES a string list — a `(ref $mkListIdx)`. Receiver shapes: a `string[]` literal,
// a `string[]` param/local, a parenthesized string-array, or a `string[]` FIELD read
// (code `6`). An index read `xs[i]` (a string) / `.length` (i32) is NOT a list.

// True if the already-collected declared local `name` is a string-list ref (code `7`).
function declaredStringArray(name: string) { declaredKind(name) == "strlist" }

// True if function `name` declares (or, un-annotated, infers) a `string[]` return type
// (`"strlist"`). Mirrors `fnRetArray`/`fnRetRefArray` — lets a `string[]`-returning call
// classify so an untyped `let x = snap()` picks the string-list local kind (code `7`).
function fnRetStringArray(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetKind[i] == "strlist"
}

// True if function `name` declares (or, un-annotated, infers) an `f64[]` return — the f64
// analogue of `fnRetStringArray`, so an untyped `let x = mk()` / a call argument classifies as
// an f64 list (kind 12) instead of falling through to i32.
function fnRetF64Array(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetKind[i] == "f64list"
}

// True if function `name` returns a string-keyed mono map (`{[string]: i32}`, annotated or
// inferred — `"map"`). Lets `exprMap`/`mapShapeOfExpr` classify a call to it, so
// `const r = mk()` (or `mk()[k]`) routes through the map lowering.
function fnRetMap(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetKind[i] == "map"
}

// True if evaluating the expression at `exprIx` yields a string list: a string-element
// array literal, a `string[]`-returning call, a `string[]` param/local reference, a
// parenthesized string-array, or a `string[]` field read (code `6`). An index read /
// `.length` is NOT a list.
export function exprStringArray(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  if tyKindOf(nodeTyIxOf(exprIx)) == 7 {
    return true // typed-IR fast path (see exprIsF64)
  }
  // `m[k]` / `m[k] ?? d` over a string[]-VALUED map yields a string list.
  if mapReadListKind(exprIx, fnIx) == "strlist" { return true }
  const e = P.nodes[exprIx]
  if e is ArrayLit { return arrLitIsStr(exprIx, fnIx) }
  if e is Paren { return exprStringArray(e.parInner, fnIx) }
  if e is Call {
    // `__array_new__(n, "s")` builds a string list (intrinsic kind 2).
    if arrNewIntrKind(exprIx, fnIx) == 2 { return true }
    // An INDEXED closure call `fs[i](x)` whose element signature returns `string[]`.
    if cloArrCallRetKind(exprIx, fnIx) == "strlist" { return true }
    // `xs.slice(...)` over a string list yields a string list.
    if callIsArrSlice(exprIx, fnIx) {
      return mfResultKindOf(exprIx, fnIx) == "str"
    }
    // `m.keys()` over a string-keyed map yields a string list of its keys.
    const kcallee = P.nodes[e.callFn]
    if kcallee is Member {
      if kcallee.memProp == "keys" {
        if exprMap(kcallee.memObj, fnIx) { return true }
      }
    }
    // `m.values()` over a string-valued map (or a Set) yields a string list.
    if mapValuesResultKind(exprIx, fnIx) == 7 { return true }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetStringArray(callee.identName) { return true }
      // A closure-VALUE call (`g(x)` with `g: (i32) => string[]`) whose resolved sig
      // result is the string list (`>A`).
      return calleeRetKind(callee.identName, fnIx) == "strlist"
    }
    return false
  }
  if e is Ident {
    // A VALUE-union ident narrowed to a string-backed LIST arm (`is string[]`, `is
    // (string | null)[]` — value-atom kind 9) reads UNBOXED as the string list.
    if unionIdentReadKind(exprIx, fnIx) == 9 { return true }
    if paramStringArray(fnIx, e.identName) { return true }
    if declaredStringArray(e.identName) { return true }
    if globalIsStringArray(e.identName) {
      if !identShadowedByFrame(fnIx, e.identName) { return true }
    }
    // A CAPTURED string-list read (incl. a boxed captured-mutated `string` local). Kind 7.
    return capturedKindOf(fnIx, e.identName) == "strlist"
  }
  // A field read `p.names` whose field is a `string[]` (code `6`) yields the string-list
  // wrapper ref — so `.length` / indexing / assignment / `.push` treat it as a string list.
  if e is Member {
    if memFieldTypeCode(exprIx, fnIx) == 6 { return true }
  }
  // `g[i]` over a `string[][]` (ref-list element kind 6 — the inner string-list wrapper)
  // yields a `string[]`, so `g[i][j]` reads the string element.
  if e is Index {
    if nestedRefListElemIs(e.idxArr, fnIx, 6) { return true }
  }
  false
}

// True if the expression at `exprIx` produces a `(string | null)[]` — the string-ref niche list
// (`nameIsNulStrList`), whose backing IS a plain string list but whose element READ stays `(ref null)`
// (a `nulstr`, narrowed) instead of recovering non-null. Recognizes the receiver by its recorded array
// element type (the node-type fast path) and by a param / declared-local `(string | null)[]` annotation
// (a nulstrlist local is collected as a plain `strlist`, so the annotation carries the nullable bit).
// Drives the dedicated element-read arm in `emitIndex`, checked BEFORE `exprStringArray`.
export function exprNulStrArray(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  if nodeArrayElemIsNulStr(exprIx) { return true }
  const e = P.nodes[exprIx]
  if e is Paren { return exprNulStrArray(e.parInner, fnIx) }
  if e is Ident {
    const pt = paramTypeNode(fnIx, e.identName)
    if pt >= 0 { return nameIsNulStrList(tyNameOf(pt)) }
    // A union binding narrowed to the `(string | null)[]` arm reads unboxed as the
    // string list whose ELEMENT stays `(ref null)` — the same nullable read discipline.
    if nameIsNulStrList(narrowVariantFor(e.identName)) { return true }
  }
  false
}

// Usage-driven element inference for an un-annotated empty `[]` LOCAL, the richer
// dual of `letInfStrListByUse` (which only sees a string LITERAL push): with the
// enclosing function `fnIx` in hand it also recognises a push of any STRING-typed
// expression — `out.push(self[i])` over a `string[]` param, `out.push(s)` over a
// string local — so a build-loop accumulator (`slice`/`reverse` over `string[]`)
// classifies as `string[]`. The `gStrInfLet` guard breaks the `out.push(out[0])`
// self-reference cycle (the push arg's `exprString` would re-enter this binding).
export function letInfStrListByUseV(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 { return false }
    if d.letInit < 0 { return false }
    const ini = P.nodes[unwrapParen(d.letInit)]
    if ini is ArrayLit {
      if ini.arrElems.length != 0 { return false }
      if gStrInfLet == letIx { return false }
      const saved = gStrInfLet
      gStrInfLet = letIx
      let found = false
      let i = 0
      while i < P.nodes.length {
        const nd = P.nodes[i]
        if nd is Call {
          const callee = P.nodes[nd.callFn]
          if callee is Member {
            if callee.memProp == "push" {
              const recv = P.nodes[callee.memObj]
              if recv is Ident {
                if recv.identName == d.letName && nd.callArgs.length == 1 {
                  const argN = P.nodes[unwrapParen(nd.callArgs[0])]
                  if argN is StrLit {
                    found = true
                  } else if fnIx >= 0 && exprString(nd.callArgs[0], fnIx) {
                    found = true
                  }
                }
              }
            }
          }
        }
        i = i + 1
      }
      gStrInfLet = saved
      return found
    }
  }
  false
}

// True if the `LetDecl` at `letIx` declares a `string[]` local: its annotation is
// `string[]`, OR its initializer produces a string list. Picks the local's valtype
// (`(ref $mkListIdx)`) and the code-`7` flag in `collectLocals`.
export function letIsStringArray(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsStringArray(lt.tyName) { return true }
        // A REF-array annotation (a union-element list) is authoritative — see `letIsF64Array`.
        if nameIsRefArray(lt.tyName) { return false }
        // A `(K | null)[]` annotation is the i32 atom-niche list, authoritative over a string-FIRST
        // init literal (`["a", null]`): its member elements are atom ids, not string refs. Without
        // this the init's `exprStringArray` claimed the string-list slot while the construct/read
        // used the i32 rep (invalid wasm). Mirrors the `nameIsRefArray` authority above.
        if nameIsNulLitUnionList(lt.tyName) { return false }
      }
    }
    if exprStringArray(d.letInit, fnIx) { return true }
    return letInfStrListByUseV(letIx, fnIx)
  }
  false
}

// ── f64-array-typedness of expressions (Slice 4) ──────────────────────────────
// Parallel to the i32/string-array families: decide whether an expression / param /
// local PRODUCES an `f64[]` list — a `(ref $fl64TypeIdx)`. Drives the index-read
// dispatch (an f64-array `xs[i]` yields an f64 from `array.get $fa64TypeIdx`) and the
// f64-list local/global cell kind (`12`). `localIsRef` code `12` flags an f64-list local.

// True if the already-collected declared local `name` is an f64-list ref (code `12`).
function declaredF64Array(name: string) { declaredKind(name) == "f64list" }

// True if evaluating the expression at `exprIx` yields an f64 list: an f64-element
// array literal, an f64-array param/local reference, or a parenthesized one.
// THE single typed-IR → emitter-kind mapping (the unification centerpiece): map a checker
// type-arena index to the emitter's local/value KIND code the per-rep predicates speak
// (0 i32 · 3 string · 10 i64 · 11 f64 · 13 f32 · 2 i32-list · 7 string-list · 12 f64-list).
// One place classifies a type; consumers compare the result to a specific kind instead of
// each re-deriving it. Scalars and scalar-element lists resolve fully; a struct / ref / map
// / nullable / closure type returns -1 (its lowering needs a slot/table the kind code alone
// can't carry), and a node with no recorded type (a monomorphized instance body, whose
// shared leaves can't hold a per-instance type) also reads -1 — both keep the syntactic path.
function tyKindOf(tyIx: i32) {
  if tyIx < 0 { return -1 }
  const t = T.tys[tyIx]
  if t is TyPrim {
    const n = t.primName
    if n == "i32" { return 0 }
    if n == "f64" { return 11 }
    if n == "i64" { return 10 }
    if n == "f32" { return 13 }
    if n == "string" { return 3 }
    if n == "boolean" { return 0 }
    return -1
  }
  if t is TyArray {
    if t.aElem < 0 { return -1 }
    const el = T.tys[t.aElem]
    if el is TyPrim {
      const en = el.primName
      if en == "i32" { return 2 }
      if en == "f64" { return 12 }
      if en == "i64" { return 20 }
      if en == "string" { return 7 }
      if en == "boolean" { return 2 }
    }
    return -1 // struct / ref / nested-list element — needs the ref-list slot
  }
  -1
}

// TYPED-IR consumer: is the type the checker recorded for `tyIx` an `f64[]`? Lets the emitter
// recognize an f64 list the SYNTACTIC predicates miss (e.g. an `f64[]`-returning call, which
// `calleeRetKind` doesn't map to a list kind) without a bespoke per-position predicate.
function tyIsF64Array(tyIx: i32) { tyKindOf(tyIx) == 12 }

export function exprF64Array(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  // Typed-IR fast path: trust the checker's recorded type when it has one. Emitter-
  // synthesized nodes (monomorphized instance bodies) read back -1 and fall through to the
  // syntactic derivation below, so generic lowering is unaffected.
  if tyIsF64Array(nodeTyIxOf(exprIx)) { return true }
  // `m[k]` / `m[k] ?? d` over an f64[]-VALUED map yields an f64 list.
  if mapReadListKind(exprIx, fnIx) == "f64list" { return true }
  const e = P.nodes[exprIx]
  if e is ArrayLit { return arrLitIsF64(exprIx, fnIx) }
  if e is Paren { return exprF64Array(e.parInner, fnIx) }
  if e is Ident {
    // A VALUE-union ident narrowed to the `f64[]` LIST arm (value-atom kind 8) reads
    // UNBOXED as the f64 list — the string/i32-list classifiers carry the same arm.
    if unionIdentReadKind(exprIx, fnIx) == 8 { return true }
    if paramF64Array(fnIx, e.identName) { return true }
    if declaredF64Array(e.identName) { return true }
    if globalIsF64Array(e.identName) {
      if !identShadowedByFrame(fnIx, e.identName) { return true }
    }
    // A CAPTURED f64-list read (`xs[i]` inside a closure capturing `xs` — incl. a boxed
    // captured-mutated `f64` local, lowered to a length-1 `f64[]`). Kind 12 = f64 list.
    return capturedKindOf(fnIx, e.identName) == "f64list"
  }
  // A `.map`/`.filter` whose result ELEMENT kind is f64 yields an f64 list (an f64
  // receiver's filter, or a map whose callback returns f64). (Slices 3–4.)
  if e is Call {
    // `__array_new__(n, <f64 fill>)` yields an f64 list.
    if arrNewIntrKind(exprIx, fnIx) == 1 { return true }
    if callIsMapFilter(exprIx, fnIx) {
      return mfResultKindOf(exprIx, fnIx) == "f64"
    }
    // `xs.slice(...)` over an f64 list yields an f64 list.
    if callIsArrSlice(exprIx, fnIx) {
      return mfResultKindOf(exprIx, fnIx) == "f64"
    }
    // An INDEXED closure call `fs[i](x)` whose element signature returns `f64[]`.
    if cloArrCallRetKind(exprIx, fnIx) == "f64list" { return true }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      // A NAMED function returning `f64[]` (annotated or inferred, `"f64list"`).
      if fnRetF64Array(callee.identName) { return true }
      // A closure-VALUE call (`g(x)` with `g: (i32) => f64[]`) whose resolved sig
      // result is the f64 list (`>D`).
      return calleeRetKind(callee.identName, fnIx) == "f64list"
    }
    return false
  }
  // `g[i]` over an `f64[][]` (ref-list element kind 7 — the inner f64-list wrapper) yields an
  // `f64[]`, so `g[i][j]` reads the f64 scalar.
  if e is Index {
    if nestedRefListElemIs(e.idxArr, fnIx, 7) { return true }
  }
  false
}

// ── f32-array typedness (the f32 sibling of the f64-array family, rep code 21) ──
// f32 is the checker's weak spot (a float literal types f64), so these lean on the SYNTACTIC
// path — an `f32[]` annotation (`nameIsF32Array`) on a let/param/global/return — rather than a
// typed-IR fast path. A bare `[1.5]` literal stays f64 (it is NOT claimed here), so a value is
// f32[] only when its declared type says so.
function tyIsF32Array(tyIx: i32) { tyKindOf(tyIx) == 21 }

// The checker-recorded type `tyIx` tested for an f32-element ARRAY — scoped to CALL
// results only (`exprF32Array`'s curried-call arm). `tyKindOf` deliberately carries no
// f32-array kind (a float LITERAL types f64, so a general typed claim would mis-claim a
// literal-built f64 list as f32); a call result's f32-ness comes from the callee's
// functype and is reliable.
function callResTyIsF32Array(tyIx: i32) {
  if tyIx < 0 { return false }
  const t = T.tys[tyIx]
  if t is TyArray {
    if t.aElem < 0 { return false }
    const el = T.tys[t.aElem]
    if el is TyPrim { return el.primName == "f32" }
  }
  false
}

function declaredF32Array(name: string) { declaredKind(name) == "f32list" }

function globalIsF32Array(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return false }
  letIsF32Array(li, -1)
}

function fnRetF32Array(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetKind[i] == "f32list"
}

export function letIsF32Array(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsF32Array(lt.tyName) { return true }
        // A REF-array annotation (`(f32 | null)[]`) is authoritative — see `letIsF64Array`.
        if nameIsRefArray(lt.tyName) { return false }
      }
    }
    return exprF32Array(d.letInit, fnIx)
  }
  false
}

export function exprF32Array(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  if tyIsF32Array(nodeTyIxOf(exprIx)) { return true }
  // A read of an `f32[]`-valued map (`m[k] ?? []`, or a bare `m[k]`) — its value-list rep is the
  // f32 list (`mvListValKind` → 21), the f32 dual of the f64-list (12) case above.
  if mapReadListKind(exprIx, fnIx) == "f32list" { return true }
  const e = P.nodes[exprIx]
  if e is Paren { return exprF32Array(e.parInner, fnIx) }
  if e is Ident {
    // A VALUE-union ident narrowed to the `f32[]` LIST arm (value-atom kind 12) reads
    // UNBOXED as the f32 list — the checker's typed-IR carries no f32-array claim (a
    // float literal types f64), so the narrowed-atom kind is the only signal here.
    if unionIdentReadKind(exprIx, fnIx) == 12 { return true }
    if paramF32Array(fnIx, e.identName) { return true }
    if declaredF32Array(e.identName) { return true }
    if globalIsF32Array(e.identName) {
      if !identShadowedByFrame(fnIx, e.identName) { return true }
    }
    // A CAPTURED f32-list read (incl. a boxed captured-mutated `f32` local). Kind 21 = f32 list.
    return capturedKindOf(fnIx, e.identName) == "f32list"
  }
  // A struct-field READ of an `f32[]` field (code 27) — the checker's per-node type does not always
  // carry f32[] through a member, so recognize it directly by the field code (the f64/i64 duals get
  // this from their typed-IR fast path; this keeps f32 fields on par).
  if e is Member {
    if memberFieldCode(exprIx, fnIx) == 27 { return true }
  }
  if e is Call {
    // `xs.map(f)` / `xs.filter(p)` whose result element is f32 (mf-result kind 13) — a `.map`
    // with an f32-returning callback, or a `.filter` over an f32 list (preserves the element).
    if callIsMapFilter(exprIx, fnIx) {
      return mfResultKindOf(exprIx, fnIx) == "f32"
    }
    // `xs.slice(...)` over an f32 list yields an f32 list.
    if callIsArrSlice(exprIx, fnIx) {
      return mfResultKindOf(exprIx, fnIx) == "f32"
    }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetF32Array(callee.identName) { return true }
      // A closure-VALUE call (`g()` with `g: () => f32[]`) whose resolved sig result is
      // the f32 list (`>F`) — the f32 dual of the i64/f64-list callee arms.
      return calleeRetKind(callee.identName, fnIx) == "f32list"
    }
    // A CURRIED / composed value call (`t0()(1)` — the callee is itself a Call): the
    // checker's recorded RESULT type decides. Reliable here, unlike a general typed-IR
    // claim (see `tyIsF32Array`'s note — a float LITERAL types f64): a call result's
    // f32-ness comes from the callee's functype, not a literal's default.
    return callResTyIsF32Array(nodeTyIxOf(exprIx))
  }
  // `g[i]` over an `f32[][]` (ref-list element kind 10 — the inner f32-list wrapper) yields an
  // `f32[]`, so `g[i][j]` reads the f32 scalar.
  if e is Index {
    if nestedRefListElemIs(e.idxArr, fnIx, 10) { return true }
  }
  false
}

// ── i64-array typedness (the i64 sibling of the f64-array family) ──────────────
// These mirror the f64 predicates over the i64-list rep (code 20, wrapper `il64TypeIdx`).
// The typed-IR fast path (`tyKindOf == 20`) carries the annotated cases; the syntactic
// fallback covers a monomorphized body whose nodes have no recorded type.
function tyIsI64Array(tyIx: i32) { tyKindOf(tyIx) == 20 }

function declaredI64Array(name: string) { declaredKind(name) == "i64list" }

export function letIsI64Array(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsI64Array(lt.tyName) { return true }
        // A REF-array annotation (`(i64 | null)[]`) is authoritative — see `letIsF64Array`.
        if nameIsRefArray(lt.tyName) { return false }
      }
    }
    return exprI64Array(d.letInit, fnIx)
  }
  false
}

function globalIsI64Array(name: string) {
  const li = globalLetOf(name)
  if li < 0 { return false }
  letIsI64Array(li, -1)
}

export function arrLitIsI64(arrIx: i32, fnIx: i32) {
  const a = P.nodes[arrIx]
  if a is ArrayLit {
    if a.arrElems.length < 1 { return false }
    return exprIsI64(a.arrElems[0], fnIx)
  }
  false
}

export function exprI64Array(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  if tyIsI64Array(nodeTyIxOf(exprIx)) { return true }
  // `m[k]` / `m[k] ?? d` over an i64[]-VALUED map yields an i64 list.
  if mapReadListKind(exprIx, fnIx) == "i64list" { return true }
  const e = P.nodes[exprIx]
  if e is ArrayLit { return arrLitIsI64(exprIx, fnIx) }
  if e is Paren { return exprI64Array(e.parInner, fnIx) }
  if e is Ident {
    if paramI64Array(fnIx, e.identName) { return true }
    if declaredI64Array(e.identName) { return true }
    if globalIsI64Array(e.identName) {
      if !identShadowedByFrame(fnIx, e.identName) { return true }
    }
    // A CAPTURED i64-list read (incl. a boxed captured-mutated `i64` local). Kind 20 = i64 list.
    return capturedKindOf(fnIx, e.identName) == "i64list"
  }
  if e is Call {
    if callIsMapFilter(exprIx, fnIx) {
      return mfResultKindOf(exprIx, fnIx) == "i64"
    }
    if callIsArrSlice(exprIx, fnIx) {
      return mfResultKindOf(exprIx, fnIx) == "i64"
    }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      // A closure-VALUE call (`g()` with `g: () => i64[]`) whose resolved sig result is
      // the i64 list (`>L`) — the i64 dual of the f64/f32-list callee arms. A NAMED
      // function returning `i64[]` is recognized via the typed-IR fast path above.
      return calleeRetKind(callee.identName, fnIx) == "i64list"
    }
    return false
  }
  // `g[i]` over an `i64[][]` (ref-list element kind 8 — the inner i64-list wrapper) yields an
  // `i64[]`, so `g[i][j]` reads the i64 scalar.
  if e is Index {
    if nestedRefListElemIs(e.idxArr, fnIx, 8) { return true }
  }
  false
}

// True if the `LetDecl` at `letIx` declares an `f64[]` local: its annotation is `f64[]`,
// OR its initializer produces an f64 list. Picks the local's valtype (`(ref $fl64TypeIdx)`)
// and the code-`12` flag in `collectLocals`.
export function letIsF64Array(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsF64Array(lt.tyName) { return true }
        // A REF-array annotation (`(f64 | null)[]` — union-BOX elements) is authoritative:
        // the float-literal init must not claim the binding as a scalar f64 list (kind 12)
        // when the slot is a kind-2 ref list — the literal's elements box instead.
        if nameIsRefArray(lt.tyName) { return false }
        // An `f32[]` annotation is authoritative too: its float-literal init reads as
        // `exprF64Array`, so without this guard a GLOBAL `const a: f32[] = [1.5]` claims
        // BOTH kinds — the ordered ladders (`buildLocals`, `globalCellKind`) pick f32
        // first, but `exprF64Array`'s Ident arm consults `globalIsF64Array` directly and
        // the double claim routed `.push` through the f64 frame against the f32 cell
        // (invalid wasm). The annotation names the kind; the init must not override it.
        if nameIsF32Array(lt.tyName) { return false }
      }
    }
    return exprF64Array(d.letInit, fnIx)
  }
  false
}

// ── map-typedness of expressions (G8: `{[string]: i32}`) ──────────────────────
// Parallel to the array family: decide whether an expression / param / local PRODUCES
// a string-keyed MAP — a `(ref $mStructIdx)`. The receiver shapes that matter for the
// self-host checker are a map LOCAL (`let m: {[string]: i32} = Map()` → code `6`), a
// map PARAM, and `Map()` itself (the empty-map constructor). An index read `m[k]` /
// `m.has(k)` yields an i32, NOT a map, so neither counts here.

// True if the already-collected declared local `name` is a map ref (code `6`).
function declaredMap(name: string) { declaredKind(name) == "map" }
function declaredNulMap(name: string) { declaredKind(name) == "nulmap" }

// True if evaluating the expression at `exprIx` yields a NULLABLE MAP ref (`{[string]: V} | null`,
// kind `nulmap`) — a nulmap-annotated param / local / global reference, or a nulmap-returning call.
// The map analogue of `exprNullableStruct` / `exprNullableRefArray`: the `!= null` narrow reads the
// `(ref null $mapStruct)` niche, and the narrowed map ops recover it non-null at the receiver.
export function exprNullableMap(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Paren { return exprNullableMap(e.parInner, fnIx) }
  if e is Ident {
    if paramNulMap(fnIx, e.identName) { return true }
    if declaredNulMap(e.identName) { return true }
    return globalIsNulMap(e.identName)
  }
  // A `recv.f` read of a NULLABLE map FIELD (`f: {[string]: V} | null`, code 29) yields a
  // nullable map — `const t = v.f` infers kind `nulmap` and narrows with `if t != null`.
  if e is Member { return memFieldTypeCode(exprIx, fnIx) == 29 }
  // A read over a NULLABLE-inner-map-valued map (`{[string]: {[string]: V} | null}`) yields
  // `map | null` — the fused `?? d` hit arm preserves a stored null, and the bare `m[k]` is
  // nullable by construction. The binding infers kind `nulmap`; its shape resolves through
  // `mapShapeOfExpr`'s composition arm (the inner map's own value slot).
  if e is BinExpr {
    const cnm = coalesceMvSlot(exprIx, fnIx)
    if cnm >= 0 { return mvValIsMap(cnm) && mvSlotNullable(cnm) }
  }
  if e is Index {
    // An INDEX into a nullable-map array (`({[string]: V} | null)[]`, element kind 3 with the
    // nullable bit): the element legitimately holds null — `const e = xs[i]` binds `nulmap`.
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemNullable.length {
        if rlElemKindTbl[slot] == 3 && rlElemNullable[slot] == 1 { return true }
      }
    }
    const mnm = mapReadMvSlot(exprIx, fnIx)
    if mnm >= 0 { return mvValIsMap(mnm) && mvSlotNullable(mnm) }
  }
  // A call whose ANNOTATED return is `{[string]: V} | null` yields a nullable map, so an
  // un-annotated `const t = mk(…)` infers kind `nulmap` and narrows with `if t != null`.
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const target = fnIndexOf(callee.identName)
      if target >= 0 {
        const fn = P.nodes[fnStmts[target]]
        if fn is FuncDecl {
          if fn.fnRet >= 0 { return retNulMapFlag(fn.fnRet) == 1 }
        }
      }
    }
  }
  false
}

// True if evaluating the expression at `exprIx` yields a string-keyed map: the
// `Map()` constructor call, a map param/local reference, or a parenthesized map
// expression.
export function exprMap(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Paren { return exprMap(e.parInner, fnIx) }
  if e is Call {
    const callee = P.nodes[e.callFn]
    // A `Set()` is a boolean-valued string map — the SAME 7-field struct — so a
    // `Set()`-bound value is treated as a map throughout the emitter. A NAMED function
    // returning a map (`fnRetMap`) yields one too — so `mk()[k]` / `const r = mk()` route
    // through the map lowering.
    if callee is Ident {
      if callee.identName == "Map" || callee.identName == "Set" { return true }
      if fnRetMap(callee.identName) { return true }
    }
    // `scopes.pop()` over a map ref list (`{[string]:i32}[]`) yields a Map ref.
    if callee is Member {
      if callee.memProp == "pop" {
        if exprRefArray(callee.memObj, fnIx) {
          const slot = refListSlotOfExpr(callee.memObj, fnIx)
          if slot >= 0 && slot < rlElemKindTbl.length {
            return rlElemKindTbl[slot] == 3
          }
        }
      }
    }
    // FALLBACK: a map-returning CLOSURE-VALUE / factory call whose callee the syntactic cases miss (a
    // closure local `v()`, an indexed closure `arr[i]()`) — the checker recorded a map type for the node.
    // The map dual of `structIndexOfExpr`'s `nodeTyIsObj` fallback: a `v()[k] ?? d` (or any map op on the
    // call result) routes through the map lowering regardless of how the map value was produced.
    if nodeTyIsMap(exprIx) { return true }
    return false
  }
  if e is Ident {
    // A union binding NARROWED to a MAP arm (`if x is {[string]: string}` then `x[k]`): its box
    // unboxes to the map struct ref, so it IS a map in the narrowed branch. Checked FIRST — the
    // binding's DECLARED type is a union, so `paramMap`/`declaredMap`/`globalIsMap` below miss it.
    if narrowedMapOf(e.identName) != "" { return true }
    if paramMap(fnIx, e.identName) { return true }
    if declaredMap(e.identName) { return true }
    if globalIsMap(e.identName) { return true }
    // A CAPTURED map variable of a lifted lambda (`() => (h0)` with `h0` a parent-frame
    // map binding): its env field carries the map ref — classify it exactly as a
    // param/local receiver would, so a captured map flowing into a union-boxed RESULT
    // (`() => {[string]: string} | boolean`) takes the map-arm boxing, not the raw ref.
    if capturedKindOf(fnIx, e.identName) == "map" { return true }
    // A NULLABLE map binding (`{[string]: V} | null`, kind `nulmap`) IS a map ref in the narrowed
    // (`!= null`) branch — the checker proved the map op guarded. The map-op receiver recovers it
    // non-null (`ref.as_non_null` in `emitMapPrep`); its shape resolves through `mapShapeOfExpr`
    // (the nulmap arms below). Checked here so `t["k"]` / `t["k"] ?? d` route to the map lowering.
    return exprNullableMap(exprIx, fnIx)
  }
  // A MAP-typed struct field read (`node.children`, code 19) yields a Map ref —
  // map member/index ops on it route to the existing map lowering.
  if e is Member {
    if memFieldTypeCode(exprIx, fnIx) == 19 { return true }
  }
  // `outer[k] ?? d` over a NESTED map (value kind 6) yields the inner Map ref — so a
  // chained `(outer[k] ?? d)[j]` routes through the map lowering.
  if e is BinExpr {
    const cmm = coalesceMvSlot(exprIx, fnIx)
    if cmm >= 0 {
      // A NULLABLE inner-map value (`{[string]: {[string]: V} | null}`) yields `map | null`
      // (a stored null is preserved through `??`) — `exprNullableMap` claims it instead.
      if mvValIsMap(cmm) && !mvSlotNullable(cmm) { return true }
    }
  }
  // `scopes[i]` over a MAP ref list (`{[string]:i32}[]`, element kind 3) yields a Map ref
  // — so map member/index ops on it route to the existing map lowering. Per-slot: the
  // element kind comes from the receiver's distinct ref-list slot. A bare `outer[k]` over a
  // nested map (value kind 6) likewise yields the inner Map.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      // `refListSlotOfExpr` falls back to slot 0 for an UN-INTERNED element name (the ref-list
      // tables can be empty when the only ref-array-shaped type is never interned — e.g. a
      // nullable array-of-map field of a union arm). Bound-check before the read, the idiom the
      // sibling ref-list classifiers already use — else `rlElemKindTbl[0]` on an empty table is a
      // compiler-internal OOB trap. (Same guard added to the `.pop()` twin above.)
      if slot >= 0 && slot < rlElemKindTbl.length {
        // A NULLABLE map element (`({[string]: V} | null)[]`) yields `map | null` —
        // `exprNullableMap`'s element arm claims it, not this non-null arm.
        return rlElemKindTbl[slot] == 3 && rlElemNullable[slot] == 0
      }
    }
    const mri = mapReadMvSlot(exprIx, fnIx)
    if mri >= 0 {
      // A bare read of a NULLABLE inner-map value stays `map | null` — `exprNullableMap`'s.
      if mvValIsMap(mri) && !mvSlotNullable(mri) { return true }
    }
  }
  false
}

// ── G8: map ops on a GLOBAL struct-field map-array element ─────────────────────
// `fnHasMap` (above) reserves the map scratch frame from map PARAMS / map LOCALS /
// map-array LOCALS (code 5 + element kind 3). But a map op can also run on an
// element of a GLOBAL struct-field map-array — e.g. `T.scopes[top][name] = v` in the
// self-host checker's `declare`, where `T` is a module global struct and `scopes` is
// a `{[string]:i32}[]` field. Such a function has NO map local, so the local scan
// misses it and `mapScratchBase` points past the locals → `invalid local index`.
//
// This walk fires on EXACTLY the four shapes `emitExpr`/`emitStmt` lower as map ops —
// each gated by `exprMap` on the same receiver (`exprMap` already resolves a
// global-field map-array element via `exprRefArray`→`memFieldTypeCode`==5 +
// `rlElemKindTbl`==3): the map GET `recv[k]`, the fused `recv[k] ?? d`, the
// `.has(k)` member-call, and the map SET `recv[k] = v`. Matching the lowered set
// EXACTLY means it never over-reserves: a function with no map-op shape stays
// byte-identical. The map LOCAL / param cases are already handled by `fnHasMap`, so
// this is OR'd in only as the additional global-field coverage.
//
// (No narrowing is applied here — a global-field map-array receiver resolves through
// `structIndexOfExpr` on a global ident, independent of any active variant narrowing,
// and this helper must stay declare-before-use-safe relative to the narrow stack.)

// True if the expression at `exprIx` (recursively) contains a map-op shape whose
// receiver `exprMap` resolves — i.e. a shape the emitter lowers via the map scratch
// frame.
export function exprHasMapOp(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Index {
    // Map GET `recv[k]`.
    if exprMap(e.idxArr, fnIx) { return true }
    // A union binding with a MAP arm indexed `t[k]`: the `is`-narrowing that makes `t` a map is
    // not active in this frame pre-pass, so `exprMap` misses it — spot the union-with-map-arm ident
    // directly so the map scratch frame is reserved (an unused reservation is a harmless spare).
    if unionMapArmIdent(e.idxArr, fnIx) { return true }
    // A MAP-FIELD read through a union's ref-array arm (`t[i].f[k]` after an `is S[]` narrow):
    // likewise invisible to `exprMap` here — spot the member shape from the declared union.
    if unionListElemMapFieldMember(e.idxArr, fnIx) { return true }
    // A MAP-FIELD read through a union's STRUCT arm (`t.f[k]` after an `is {f:{[string]:V}}`
    // narrow): likewise invisible — spot it from the declared union's arm field tables.
    if unionStructArmMapFieldMember(e.idxArr, fnIx) { return true }
    // A map read through a union's ARRAY-OF-MAP arm (`t[i][k]` after an `is {[string]:V}[]`
    // narrow): likewise invisible — spot the index shape from the declared union.
    if unionMapArrayElemIndex(e.idxArr, fnIx) { return true }
    if exprHasMapOp(e.idxArr, fnIx) { return true }
    return exprHasMapOp(e.idxIndex, fnIx)
  }
  if e is BinExpr {
    // Fused map get-with-default `recv[k] ?? d` (and the method form `recv.get(k) ?? d`).
    if e.binOp == "??" {
      const lhs = P.nodes[e.binLeft]
      if lhs is Index {
        if exprMap(lhs.idxArr, fnIx) { return true }
        if unionMapArmIdent(lhs.idxArr, fnIx) { return true }
        if unionListElemMapFieldMember(lhs.idxArr, fnIx) { return true }
        if unionStructArmMapFieldMember(lhs.idxArr, fnIx) { return true }
        if unionMapArrayElemIndex(lhs.idxArr, fnIx) { return true }
      }
      if lhs is Call {
        const lcallee = P.nodes[lhs.callFn]
        if lcallee is Member {
          if lcallee.memProp == "get" {
            if exprMap(lcallee.memObj, fnIx) { return true }
          }
        }
      }
    }
    // Map SET `recv[k] = v` (an assignment is a statement, but walk it defensively).
    if e.binOp == "=" {
      const target = P.nodes[e.binLeft]
      if target is Index {
        if exprMap(target.idxArr, fnIx) { return true }
        if unionMapArmIdent(target.idxArr, fnIx) { return true }
        if unionListElemMapFieldMember(target.idxArr, fnIx) { return true }
        if unionStructArmMapFieldMember(target.idxArr, fnIx) { return true }
        if unionMapArrayElemIndex(target.idxArr, fnIx) { return true }
      }
    }
    if exprHasMapOp(e.binLeft, fnIx) { return true }
    return exprHasMapOp(e.binRight, fnIx)
  }
  if e is Call {
    // `recv.has(k)` map membership / `recv.delete(k)` map removal — both touch a map.
    // `m.keys()` / `m.values()` ITERATION also needs the map scratch frame (slot 0
    // holds the map ref for the tombstone-aware `live[i]` skip in the for-in loop).
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "has" {
        if exprMap(callee.memObj, fnIx) { return true }
        if unionMapArmIdent(callee.memObj, fnIx) { return true }
        if unionMapArrayElemIndex(callee.memObj, fnIx) { return true }
      }
      if callee.memProp == "delete" {
        if exprMap(callee.memObj, fnIx) { return true }
        if unionMapArmIdent(callee.memObj, fnIx) { return true }
      }
      if callee.memProp == "keys" || callee.memProp == "values" {
        if exprMap(callee.memObj, fnIx) { return true }
        if unionMapArmIdent(callee.memObj, fnIx) { return true }
      }
    }
    if exprHasMapOp(e.callFn, fnIx) { return true }
    const args = e.callArgs
    let i = 0
    while i < args.length {
      if exprHasMapOp(args[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  if e is Member { return exprHasMapOp(e.memObj, fnIx) }
  if e is Unary { return exprHasMapOp(e.unArg, fnIx) }
  if e is Paren { return exprHasMapOp(e.parInner, fnIx) }
  if e is IsExpr { return exprHasMapOp(e.isObj, fnIx) }
  if e is AsExpr { return exprHasMapOp(e.asObj, fnIx) }
  if e is ObjLit {
    const fields = e.objFields
    let i = 0
    while i < fields.length {
      const f = P.nodes[fields[i]]
      if f is FieldInit {
        if exprHasMapOp(f.fiValue, fnIx) { return true }
      }
      i = i + 1
    }
    return false
  }
  if e is ArrayLit {
    const elems = e.arrElems
    let i = 0
    while i < elems.length {
      if exprHasMapOp(elems[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  false
}

// True if any statement in the block at `blockIx` (descending into if/else branches
// and while bodies) contains a map op. An assignment statement (`recv[k] = v`) is a
// bare `BinExpr` with `binOp == "="` — `exprHasMapOp` recognizes its SET shape.
export function blockHasMapOp(blockIx: i32, fnIx: i32) {
  const b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      const s = P.nodes[stmts[i]]
      if s is LetDecl {
        if exprHasMapOp(s.letInit, fnIx) { return true }
      } else if s is RetStmt {
        if exprHasMapOp(s.retArg, fnIx) { return true }
      } else if s is BinExpr {
        if exprHasMapOp(stmts[i], fnIx) { return true }
      } else if s is Call {
        if exprHasMapOp(stmts[i], fnIx) { return true }
      } else if s is IfStmt {
        if ifChainHasMapOp(stmts[i], fnIx) { return true }
      } else if s is WhileStmt {
        if exprHasMapOp(s.whileCond, fnIx) { return true }
        if blockHasMapOp(s.whileBody, fnIx) { return true }
      } else if s is ForIn {
        if exprHasMapOp(s.fiIter, fnIx) { return true }
        if blockHasMapOp(s.fiBody, fnIx) { return true }
      } else if s is ForRange {
        if exprHasMapOp(s.frFrom, fnIx) { return true }
        if exprHasMapOp(s.frTo, fnIx) { return true }
        if blockHasMapOp(s.frBody, fnIx) { return true }
      }
      i = i + 1
    }
  }
  false
}

// True if any arm of the `if` / `else if` chain at `ifIx` contains a map op — its
// condition, then-branch, `else` block, OR (recursively) a chained `else if`.
function ifChainHasMapOp(ifIx: i32, fnIx: i32) {
  const s = P.nodes[ifIx]
  if s is IfStmt {
    if exprHasMapOp(s.ifCond, fnIx) { return true }
    if blockHasMapOp(s.ifThen, fnIx) { return true }
    if s.ifElse >= 0 {
      const els = P.nodes[s.ifElse]
      if els is Block {
        if blockHasMapOp(s.ifElse, fnIx) { return true }
      } else if els is IfStmt {
        if ifChainHasMapOp(s.ifElse, fnIx) { return true }
      }
    }
  }
  false
}

// True if the FuncDecl at `fnIx` performs a map op on a GLOBAL struct-field map-array
// element (or any map-op shape `fnHasMap`'s local scan does not already cover) — so it
// reserves the shared 12-slot map scratch frame. OR'd into `fnUsesMap`.
export function fnHasGlobalMapOp(fnIx: i32) {
  const fn = P.nodes[fnIx]
  if fn is FuncDecl { return blockHasMapOp(fn.fnBody, fnIx) }
  false
}

// True if the `LetDecl` at `letIx` declares a map-typed local: its annotation is a map
// type (`{[string]: i32}`), OR its initializer produces a map (`Map()`). Picks the
// local's valtype (`(ref $mStructIdx)`) and the code-`6` flag in `collectLocals`.
export function letIsMap(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        // A UNION annotation whose FIRST atom is a map (`{[string]: string} | f64`) has a name that
        // STARTS with `{[`, so `nameIsMap` matches the whole union name — but it is a union BOX local,
        // NOT a map (the map arm boxes into the union). A bare map has ONE top-level atom; a union has
        // 2+. Gate so the union rides its box, and the map arm's read narrows through the union.
        if nameIsMap(lt.tyName) && !nameIsMapMemberUnion(lt.tyName) {
          return true
        }
        // Any registered UNION annotation (a map-member union — map-FIRST `{[..]}|X`, whose
        // `nameIsMap` name the branch above already excluded, or a map-LAST `X|{[..]}` whose
        // name does not start with `{[`) is a union BOX local whose INIT is the bare map ARM
        // (`const v: {[string]: i32} | f64 = h0`). Return false — the annotation is
        // authoritative — so the `exprMap(init)` fall-through below cannot reclaim the box as a
        // bare map; `collectLocals` then reaches `letIsUnion` and the cell rides its union box.
        if isUName(lt.tyName) { return false }
      }
    }
    return exprMap(d.letInit, fnIx)
  }
  false
}

// True if the `LetDecl` at `letIx` declares a NULLABLE map local (`{[string]: V} | null`,
// kind `nulmap`): its annotation is a nullable map, OR its initializer produces one (a
// nulmap param/local passthrough, or a nulmap-returning call). Checked BEFORE `letIsMap` in
// the collect ladder so a nullable init does not collapse to the non-null kind `"map"`.
export function letIsNulMap(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      if retNulMapFlag(d.letType) == 1 { return true }
    }
    return exprNullableMap(d.letInit, fnIx)
  }
  false
}
// The map SHAPE code of a nulmap-typed `LetDecl` (the same vocabulary as `letMapShapeOf`:
// `-2` Set, mv slot >= 0, `-1` mono, `-3` unsupported). Annotation-first (the `| null`-aware
// `mapAnnShape`), else the nulmap initializer's shape.
export function nulMapShapeOf(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      if retNulMapFlag(d.letType) == 1 { return mapAnnShape(d.letType) }
    }
    return mapShapeOfExpr(d.letInit, fnIx)
  }
  -1
}

// The map SHAPE code of a map-typed `LetDecl`: `-2` a Set, an mv SLOT (>= 0) for a
// ref-valued map (from the annotation's value type-name), `-1` the mono i32 map,
// `-3` an unsupported value type (op sites fail loudly). Annotation-first, else the
// initializer's shape (a `Map()`/`Set()` constructor, or a map-typed passthrough).
export function letMapShapeOf(letIx: i32, fnIx: i32) {
  if letIsSet(letIx) { return -2 }
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        // A map-member UNION annotation is NOT a bare map (see `letIsMap`) — skip it so the union
        // box, not a garbled map value shape, is picked.
        if nameIsMap(lt.tyName) && !nameIsMapMemberUnion(lt.tyName) {
          return mvShapeOfValName(mapValNameOf(lt.tyName))
        }
      }
    }
    return mapShapeOfExpr(d.letInit, fnIx)
  }
  -1
}

// The map SHAPE code of a map-typed EXPRESSION (the receiver of a map op): `-2`
// Set, mv slot >= 0, `-1` mono, `-3` unsupported. Mirrors `exprMap`'s resolution
// chain: constructor calls, locals (the kind-6 parallel slot stored by
// `collectLocals`), globals (their `LetDecl`'s shape), and the mono-only map-array
// element / `.pop()` forms. Map-typed PARAMS stay mono-only (no `vtKindOfParam`
// map case exists yet — a ref-valued map cannot cross a call boundary).
export function mapShapeOfExpr(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return -1 }
  const e = P.nodes[exprIx]
  if e is Paren { return mapShapeOfExpr(e.parInner, fnIx) }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if callee.identName == "Set" { return -2 }
      // A map-returning function yields its declared map SHAPE (mono ⇒ -1, or a `string`-valued
      // map's mv slot); a `Map()` constructor is the mono map (-1).
      const fe = fnIndexOf(callee.identName)
      if fe >= 0 { return fnRetMapShape(callee.identName) }
    }
    // FALLBACK: a map-returning CLOSURE-VALUE / factory call whose callee the syntactic path misses (a
    // closure local `v()`, an indexed closure `arr[i]()`) — resolve the shape from the checker's recorded
    // map VALUE type (mono/atom ⇒ -1, else the value name's mv slot). Mirrors the `exprMap` fallback and
    // `structIndexOfExpr`'s `nodeTyName` struct fallback, so `v()[k] ?? d` picks the right value rep.
    if nodeTyIsMap(exprIx) {
      // An ATOM-valued map (`{[string]: K0}`) is the MONO i32 map, but its RENDERED value
      // name collapses to `string` (`tyToEmitName` widens each member literal) — which the
      // slot resolver would treat as a slot-less STRING-valued map and reject loudly. Gate
      // on the checker's recorded litunion first (the atom map has no slot by design).
      // Same for the NULLABLE-atom niche (`{[string]: K0 | null}` — the `-1` sentinel rides
      // the mono map; its rendered value name would collapse to `string | null`).
      if nodeTyMapValIsLitUnion(exprIx) { return -1 }
      if nodeTyMapValIsNulLitUnion(exprIx) { return -1 }
      return mvSlotOfMapValNameOrMono(nodeTyMapValName(exprIx))
    }
    return -1
  }
  if e is Ident {
    // A union binding NARROWED to a MAP arm resolves its shape from the arm's VALUE type (mono ⇒
    // -1, or a typed value's mv slot) — the map ops in the narrowed branch read that value type,
    // not the mono i32 assumption a bare -1 would force. Checked FIRST (the declared type is a
    // union, so `declaredMap`/`paramMap`/global below miss it), mirroring `exprMap`.
    const nm = narrowedMapOf(e.identName)
    if nm != "" { return mvSlotOfMapValNameOrMono(mapValNameOf(nm)) }
    if declaredMap(e.identName) {
      const slot = declaredSlotOf(e.identName)
      if slot >= 0 { return localStructIdx[slot] }
      return -1
    }
    // A map PARAM's shape is its annotation's value type (mono ⇒ -1, or a `string`-valued
    // map's mv slot) — so the body's map ops resolve the param's VALUE type, not the mono i32
    // assumption a bare `-1` would force.
    if paramMap(fnIx, e.identName) { return paramMapShape(fnIx, e.identName) }
    // A NULLABLE map binding narrowed non-null — its shape is the `| null`-stripped map value type,
    // resolved from the local slot (`declaredNulMap`) or the param annotation (`paramNulMap`), so the
    // narrowed `t["k"]` reads THIS map's value rep (not the mono i32 assumption).
    if declaredNulMap(e.identName) {
      const nslot = declaredSlotOf(e.identName)
      if nslot >= 0 { return localStructIdx[nslot] }
      return -1
    }
    if paramNulMap(fnIx, e.identName) {
      return paramMapShape(fnIx, e.identName)
    }
    // A CAPTURED map variable of a lifted lambda: resolve its shape from the PARENT
    // frame's binding, the map dual of `capturedUnionName` — so a captured typed-value
    // map boxes/reads with its own mv slot rather than the mono -1.
    if capturedKindOf(fnIx, e.identName) == "map" {
      const cfe = fnStmtsPosOf(fnIx)
      if cfe >= 0 {
        const cb = parentBindingOf(cfe, e.identName)
        if cb >= 0 {
          const cbn = P.nodes[cb]
          if cbn is LetDecl {
            const cpar = parentBindingFrameOf(cfe, e.identName)
            if cpar >= 0 { return letMapShapeOf(cb, fnStmts[cpar]) }
          }
        }
      }
      return -1
    }
    const gl = globalLetOf(e.identName)
    if gl >= 0 {
      if letIsMap(gl, -1) { return letMapShapeOf(gl, -1) }
      if letIsNulMap(gl, -1) { return nulMapShapeOf(gl, -1) }
    }
  }
  // A MAP-typed struct field read (`node.children`, code 19): the shape is the
  // field's value-type mv slot (-1 = the mono i32 map). Mirrors `memberFieldCode`'s
  // receiver dispatch — a NARROWED union member (`t0.f` after `is {f:{[string]:V}}`)
  // and a VARIANT-typed value resolve through the variant field tables (without the
  // arms the read fell to the mono -1 and the typed map ref mismatched its
  // mono-typed scratch local — invalid wasm), a plain struct receiver through the
  // struct table.
  if e is Member {
    if memIsNarrowed(exprIx) {
      const nvi = memNarrowVariantIndex(exprIx)
      if nvi >= 0 {
        const nvfi = variantFieldIndex(nvi, e.memProp)
        if nvfi >= 0 {
          const nvc = variantFieldTypeAt(nvi, nvfi)
          if nvc == 19 || nvc == 29 {
            return mvSlotOfValNameFind(variantFieldElemName(nvi, nvfi))
          }
        }
      }
    }
    const pvi = exprVariantIndex(e.memObj, fnIx)
    if pvi >= 0 {
      const pvfi = variantFieldIndex(pvi, e.memProp)
      if pvfi >= 0 {
        const pvc = variantFieldTypeAt(pvi, pvfi)
        if pvc == 19 || pvc == 29 {
          return mvSlotOfValNameFind(variantFieldElemName(pvi, pvfi))
        }
      }
    }
    const msi = structIndexOfExpr(e.memObj, fnIx)
    if msi >= 0 {
      const mfi = sFieldIndex(msi, e.memProp)
      if mfi >= 0 {
        const mfc = sFieldTypeAt(msi, mfi)
        if mfc == 19 || mfc == 29 {
          return mvSlotOfValNameFind(sFieldElemNameAt(msi, mfi))
        }
      }
    }
  }
  // A composition MAP READ that yields a typed-value map — either a NESTED-map read
  // (`outer[k]` / `outer[k] ?? d`, whose receiver's VALUE is itself a map) or a LIST-of-maps
  // element read (`xs[i]`). The read produces the element map, whose shape is the element
  // map's OWN value slot. Without this the binding falls to the mono map (-1) and its
  // `(ref $mStructIdx)` local rejects the typed map ref the read produces.
  const cms2 = compositionMapReadSlot(exprIx, fnIx)
  if cms2 != -2 { return cms2 }
  -1
}

// The mv slot of the map a COMPOSITION read yields, `-1` for a mono/atom-valued map (it
// rides the shared `$mStructIdx`), or the sentinel `-2` when the expression is not a
// composition map read at all (so the caller keeps its own `-1` default). Two shapes:
//   · a NESTED-map read (`outer[k]` / `outer[k] ?? d`): the inner map is the receiver's
//     vals ref-list element (`{[string]: V}` → `V`).
//   · a LIST-of-maps element read (`xs[i]`): the map is the ref-list element itself.
function compositionMapReadSlot(exprIx: i32, fnIx: i32): i32 {
  // Nested-map read: resolve the receiver's mv slot, then its inner map value.
  let os = coalesceMvSlot(exprIx, fnIx)
  if os < 0 { os = mapReadMvSlot(exprIx, fnIx) }
  if os >= 0 && mvValIsMap(os) {
    return mvSlotOfMapValNameOrMono(mapValNameOf(rlElemName[mvRlSlot[os]]))
  }
  // List-of-maps element read: the element name is the map type; its value picks the slot.
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemKindTbl.length && rlElemKindTbl[slot] == 3 {
        // A NULLABLE map element strips to its inner map for the value-slot resolve.
        let cen = rlElemName[slot]
        const cnin = nulMapInnerName(cen)
        if cnin != "" { cen = cnin }
        return mvSlotOfMapValNameOrMono(mapValNameOf(cen))
      }
    }
  }
  -2
}

// The mv slot whose map value type-name is `iv`, `-1` for a mono / atom value
// (`i32` / `boolean` / literal-union atom — never interned, rides `$mStructIdx`), or
// `-3` for a TYPED value whose slot was never interned (unsupported — op sites fail
// loudly, never the silent mono fallback). A mono-tolerant find (unlike
// `mvSlotOfValNameFind`, which fails loudly on the mono miss) for the composition
// read resolvers.
export function mvSlotOfMapValNameOrMono(iv: string): i32 {
  if mvValKindOfName(iv) == -1 { return -1 }
  let i = 0
  while i < mvValName.length {
    if mvValName[i] == iv { return i }
    i = i + 1
  }
  // A TYPED value name (kind != -1) with NO interned slot: the map was reached through a
  // seam whose collect pass missed it. Returning the mono `-1` here silently lowered the
  // read/store as the i32 map — the value rep then mismatched (invalid wasm). `-3`
  // (unsupported) keeps the op sites' loud-reject contract instead.
  -3
}

// ── string-typedness of expressions ──────────────────────────────────────────
// Parallel to the array family above: decide whether an expression / param / local
// PRODUCES a `string` (CURRENTLY the same `(array (mut i32))` of code points an array
// is — `docs/strings-design.md`). Used to route `s.length` to `array.len` and `s[i]`
// to `array.get`, and to give string locals/params the array ref valtype. Like the
// array family, a `.length`/index READ yields an i32 (NOT a string), so neither
// counts here. Concatenation (`+`), equality (`==`), and `slice`/`indexOf` are DEFERRED
// (this slice covers only literal construction + `.length` + index read), so no
// binary/call op below produces a string except a `string`-returning call.

// True if the function `name` declares `string` as its return type. The `fromCodePoint`
// compiler builtin (H2) constructs a single-character VL string, so it is `string`-
// returning too — classifying it here (the single chokepoint `exprString` consults for
// a named call) routes `value + fromCodePoint(cp)` to string concat, flags
// `let s = fromCodePoint(n)` as a string local, etc., exactly as a user `string`-
// returning function would be.
function fnRetString(name: string) {
  if name == "fromCodePoint" { return true }
  if name == "fromCodePoints" { return true }
  if name == "toString" { return true }
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetKind[i] == "str"
}

// True if the parameter `name` of function `fnIx` is `string`-typed.
function paramString(fnIx: i32, name: string) {
  const pt = paramTypeNode(fnIx, name)
  if retNulStringFlag(pt) == 1 { return true }
  nameIsString(tyNameOf(pt))
}

// True if the already-collected declared local `name` is a string ref (code `3`).
function declaredString(name: string) {
  // A `string | null` (kind 16) local reads AS a string for string ops — it is narrowed
  // non-null at every such read (the checker gates string ops on the narrowed branch),
  // and the array ops (`array.len`/`array.get`) accept the nullable ref. The `!= null`
  // null-check reads it through `exprNullableString` FIRST, so this never mis-routes it.
  const dk = declaredKind(name)
  return dk == "str" || dk == "nulstr"
}

// True if evaluating the expression at `exprIx` yields a string: a string literal, a
// `string`-returning call, a string param/local reference, or a parenthesized string
// expression. An index read / `.length` yields an i32, so neither counts.
// The wasm-type CODE (`0` i32/bool, `3` string, `4` i32[], `5` ref list, `6` string
// list) of the field a `Member` access `recv.field` reads, resolving the receiver
// through the three field-bearing shapes — a NARROWED union local (`if n is A {…}`),
// a VARIANT-TYPED value/param (`fn f(n: A)`, the `checkXNode(n: Variant)` idiom), or a
// plain declared struct — or -1 when the receiver is none of these. The single place
// the `exprString`/`exprStruct`/`exprArray`/`exprMap` classifiers consult so a field
// read of ANY receiver shape resolves to its declared field type.
function memberFieldCode(memIx: i32, fnIx: i32) {
  const e = P.nodes[memIx]
  if e is Member {
    if memIsNarrowed(memIx) {
      const vi = memNarrowVariantIndex(memIx)
      if vi >= 0 {
        const vfi = variantFieldIndex(vi, e.memProp)
        if vfi >= 0 { return variantFieldTypeAt(vi, vfi) }
      }
      return -1
    }
    const pvi = exprVariantIndex(e.memObj, fnIx)
    if pvi >= 0 {
      const pvfi = variantFieldIndex(pvi, e.memProp)
      if pvfi >= 0 { return variantFieldTypeAt(pvi, pvfi) }
      return -1
    }
    const si = structIndexOfExpr(e.memObj, fnIx)
    if si >= 0 {
      const fi = sFieldIndex(si, e.memProp)
      if fi >= 0 { return sFieldTypeAt(si, fi) }
    }
  }
  -1
}

export function exprString(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is StrLit { return true }
  if e is Paren { return exprString(e.parInner, fnIx) }
  // An if-EXPRESSION whose branch join is a STRING (`const b = if c { "x" } else { "y" }`):
  // the value is a string ref, so an UN-annotated binding classifies kind 3 — matching the
  // `(ref $aTypeIdx)` the `emitIfExprRef` join already emits. The checker proved both arms
  // agree, so the THEN arm's rep classifies the whole `if` (the numeric `exprIsF64`/`exprIsI64`
  // duals consult `ifExprArmIsKind` the same way). Without this an un-annotated string if-value
  // bound an i32 local while the `if` yielded a string ref — a wasm type mismatch.
  if e is IfStmt {
    // The JOIN's checked type is the arm-order-independent signal: a `string`-typed
    // join may LEAD with an atom arm (`if c then k else "cc"`), which alone doesn't
    // read stringy — the atom arm widens at `emitRefIfArm`, so the value IS a string.
    if tyKindOf(nodeTyIxOf(exprIx)) == 3 { return true }
    const tv = ifThenValueIx(exprIx)
    return tv >= 0 && exprString(tv, fnIx)
  }
  if e is Call {
    // G6: `s.slice(...)` over a string receiver produces a string. Otherwise a
    // bare call produces a string iff the callee declares a `string` return.
    if exprIsStrSlice(exprIx, fnIx) { return true }
    // An INDEXED closure call `fs[i](x)` whose element signature returns `string`.
    if cloArrCallRetKind(exprIx, fnIx) == "str" { return true }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetString(callee.identName) { return true }
      // A string-returning function VALUE (a binding / `(i32) => string` param callee,
      // invisible to `fnRetString`): its resolved `>S` sig. EXCEPT a call the checker
      // typed as an aliased LITUNION (`t(3)` where `t: (i32) => K0` came off a map
      // `?? d` read): the binding's sig resolves through the checker's RENDERED type
      // name, which softens `K0` to `string` — keying `>S` — while the call_ref's
      // result reps the i32 ATOM. The node-type gate on the per-node fallback below
      // already excludes it; the per-name claim needs the same gate, else `print`
      // hands the raw atom to the string path (invalid wasm). The atom widens at
      // `exprIsLitAtom` instead.
      if calleeReturnsString(callee.identName, fnIx) {
        if !nodeTyIsLitUnionAlias(exprIx) { return true }
      }
    }
    // A string-returning FIELD-closure call (`o.label(3)` over a `(i32) => string` field).
    if callee is Member {
      const ffe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
      if ffe >= 0 { return fRetKind[ffe] == "str" }
    }
    // A closure-VALUE call whose callee sig the per-NAME resolvers above cannot key — a local
    // whose closure type was inferred from a Member/Index init (`const t0 = v[0].f`, a
    // nullable-closure struct field narrowed non-null). `calleeCloSigKey` (per name) lacks the
    // `nodeTyName` fallback the actual `call_ref` lowering (`cloCallSigKey`, per call node) uses,
    // so the two disagreed: the call emitted a `() => string` `call_ref` (a string ref) while this
    // classifier said i32 → `print` dispatched `__print_i32__` on a string (invalid wasm). Resolve
    // the call node's sig the SAME way the emitter does so print/coerce dispatch agrees — but only
    // when the checker ALSO typed the result a plain `string` (kind 3). A string-LITERAL-union result
    // (`(i32) => K0`, `K0 = "a" | "b"`) keys `>S` too yet reps as the i32 ATOM, so the sig alone would
    // mis-claim it a string (a `(ref $type)` vs i32 mismatch); the node-type gate excludes it.
    if tyKindOf(nodeTyIxOf(exprIx)) == 3 {
      if sigKeyRetKind(cloCallSigKey(exprIx, fnIx)) == "str" { return true }
    }
    return false
  }
  if e is BinExpr {
    // A `m[k] ?? d` / `m.get(k) ?? d` read over a STRING-valued map yields a
    // string ref (the value type). A NULLABLE-string value (`{[string]: string | null}`)
    // yields `string | null` instead (a stored null is preserved) — `exprNullableString`'s.
    const cms = coalesceMvSlot(exprIx, fnIx)
    if cms >= 0 { return mvValKind[cms] == 3 && !mvSlotNullable(cms) }
    // `r ?? d` over a `string | null` LHS yields a (non-null) string — the coalesce
    // recovers the non-null array ref, so `.length`/`+`/etc. on the result work.
    if e.binOp == "??" {
      if exprNullableString(e.binLeft, fnIx) { return true }
    }
    // G6: string concatenation `a + b` produces a string; no other binary operator
    // does (`==`/`!=` yield an i32).
    return exprIsStrConcat(exprIx, fnIx)
  }
  if e is Ident {
    // A VALUE-union ident is a string ONLY when narrowed to the `string` atom
    // (the unboxed read is the array ref); an un-narrowed union binding is the
    // BOX, even when its init was a string literal (see exprIsI64).
    const uk = unionIdentReadKind(exprIx, fnIx)
    if uk != -3 { return uk == 2 }
    if paramString(fnIx, e.identName) { return true }
    if declaredString(e.identName) { return true }
    // A CAPTURED string (`const s = "…"; () => s.length`): the env field is a string ref (kind
    // 3), so classify it like a string param/local — else `s.length` reads as a struct field.
    if capturedKindOf(fnIx, e.identName) == "str" { return true }
    return globalIsString(e.identName)
  }
  // An index read over a STRING list (`names[i]`, a `string[]` element) yields a
  // string ref. (An index over an i32 list or a string `s[i]` yields an i32 — the
  // string-array check is the only string-producing index form.)
  if e is Index {
    if exprStringArray(e.idxArr, fnIx) { return true }
  }
  // A field read `p.f` where `f` is a STRING struct field yields a string ref (gap #2:
  // `let k = t.kind` must give `k` the string type, not i32).
  if e is Member {
    // A UNION-typed field read narrowed to the `string` atom unboxes to the
    // string ref (the member-path dual of the Ident rule above).
    const muk = memberUnionReadKind(exprIx, fnIx)
    if muk != -3 { return muk == 2 }
    // A field read whose declared field type is `string` (code 3), or a `string | null`
    // niche field (code 20) read as a VALUE (it recovers the non-null string ref) —
    // resolved through the narrowed-local / variant-param / plain-struct shapes by
    // `memberFieldCode`.
    const mfc = memberFieldCode(exprIx, fnIx)
    return mfc == 3 || mfc == 20
  }
  false
}

// True if the `LetDecl` at `letIx` declares a string-typed local: its annotation is
// `string`, OR its initializer produces a string. Picks the local's valtype
// (`(ref $aTypeIdx)` vs i32) in `collectLocals`.
export function letIsString(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsString(lt.tyName) { return true }
      }
    }
    return exprString(d.letInit, fnIx)
  }
  false
}

// True if the `LetDecl`/global at `letIx` declares an `i64` binding. ANNOTATION-ONLY:
// a bare integer literal stays i32 by design (Slice 1 keeps existing programs
// byte-identical), so only an explicit `: i64` annotation selects the i64 slot
// (valtype `0x7e`, kind 10). The initializer literal is then lowered as `i64.const`.
export function letIsI64(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if lt.tyName == "i64" { return true }
      }
      return false
    }
    // Un-annotated: infer i64 from the initializer (`const m = n` where `n: i64`, i64
    // arithmetic, an i64-returning call), mirroring the host and `letIsF64`. At MODULE
    // scope (`fnIx < 0`) this recurses through `globalIsI64` for a global-ident operand,
    // terminating for an acyclic program (each global's init is below it) — the same shape
    // `globalKind`'s expression-family classifiers already rely on.
    if d.letInit >= 0 { return exprIsI64(d.letInit, fnIx) }
  }
  false
}

// True if the `LetDecl`/global at `letIx` declares an `f64` binding: an explicit
// `: f64` annotation, OR an UN-annotated binding whose initializer is a float `.`
// literal (e.g. `const a = 1.5`). Such a binding selects the f64 slot (valtype 0x7c,
// kind 11) and lowers its init literal as `f64.const`. An un-annotated float `let`
// was previously a hard error (`checkExprI32` rejects `.`), so accepting it here is
// strictly additive — no existing i32 program changes. (Slice 3.)
export function letIsF64(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if lt.tyName == "f64" { return true }
      }
      return false
    }
    if d.letInit >= 0 {
      const ie = P.nodes[d.letInit]
      if ie is NumLit { return numTextIsFloat(ie.numText) }
      // Un-annotated: infer f64 from the initializer (`const r = 1.5 + 2.5` / `const m =
      // x` where `x: f64` / a float-returning call). At MODULE scope (`fnIx < 0`) this
      // recurses through `globalIsF64` for a global-ident operand, which terminates for an
      // acyclic program (each global's init is below it) — the same shape `globalKind`'s
      // expression-family classifiers (`exprString` / `exprStruct` / …) already rely on.
      return exprIsF64(d.letInit, fnIx)
    }
  }
  false
}

// True if the `LetDecl` at `letIx` binds a FUNCTION VALUE (kind 14): its initializer is
// a `function(...)` literal, a bare reference to a top-level/lifted function name, or a
// call returning a function value. The cell is the closure fat-pointer `(ref
// $cloStructIdx)`. (Lambdas.)
export function letIsClosure(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letInit < 0 { return false }
    return exprIsClosure(d.letInit, fnIx)
  }
  false
}

// True if the expression at `exprIx` evaluates to a function value (a closure
// fat-pointer): a `function(...)` literal, a bare reference to a top-level/lifted
// function name, a reference to a closure-typed param/local, or a call returning a
// function value (a function whose body's tail is itself a function value).
export function exprIsClosure(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Paren { return exprIsClosure(e.parInner, fnIx) }
  if e is FuncDecl { return true }
  // An if-EXPRESSION whose branch join is a CLOSURE (`const f = if c then g else h`): the value
  // is a closure ref, so an un-annotated binding classifies kind 14 — the THEN arm's rep (the
  // arms agreeing by the checker), matching the `(ref $cloStruct)` `emitIfExprRef` emits.
  if e is IfStmt {
    const tv = ifThenValueIx(exprIx)
    return tv >= 0 && exprIsClosure(tv, fnIx)
  }
  if e is Ident {
    if fnIndexOf(e.identName) >= 0 { return true }
    // A union binding NARROWED to a bare-closure arm (`if x is () => i64 { x() }`): its box
    // payload IS the closure fat-pointer (`emitValueUnionUnboxRead` casts to `$cloStructIdx`),
    // so it calls via `call_ref` exactly like a closure local — route the CALL here. Checked
    // FIRST since the binding's DECLARED type is a union, so the param/local closure tests miss it.
    if narrowedClosureOf(e.identName) != "" { return true }
    // A closure-typed param/local (kind 14), or a NULLABLE one (kind 19) — both call via
    // `call_ref`; the nullable cell is recovered to non-null at the call site (after the
    // `if c != null` narrowing the checker requires).
    if paramIsClosure(fnIx, e.identName) { return true }
    if paramNulClosure(fnIx, e.identName) { return true }
    const slot = declaredSlotOf(e.identName)
    if slot >= 0 {
      return localIsRef[slot] == "closure" || localIsRef[slot] == "nulclosure"
    }
    // A module-global closure cell — a bare closure (kind 14) or a NULLABLE one (kind 19).
    const gl = globalLetOf(e.identName)
    if gl >= 0 {
      const gk = globalCellKind(gl)
      return gk == "closure" || gk == "nulclosure"
    }
    return false
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const t = fnIndexOf(callee.identName)
      if t >= 0 { return fnReturnsClosure(t) }
      // A CLOSURE-VALUE callee (`f(4)` where `f: (i32) => ((i32) => i32)`) whose result is
      // itself a closure — resolved from `f`'s `$fnsig` result (`>c`). Lets a curried lambda
      // `const g = f(4)` bind `g` as a closure and call it.
      return calleeRetKind(callee.identName, fnIx) == "closure"
    }
    // A CHAINED value call `g()()` — the callee is itself a Call (`g()`) yielding a closure.
    // The whole call is a closure iff the checker typed its RESULT as a function type; the
    // inner call lowers via its own `exprIsClosure`/`call_ref`. Reads the checker type
    // directly (the same source `cloCallSigKey` keys off), so no per-position resolver.
    const tn = nodeTyName(exprIx)
    return tn != "" && annArrowAt(tn) >= 0
  }
  if e is Member {
    // A closure FIELD of a NARROWED union receiver (`t0 is {a, f: (i32) => K0, z} {
    // t0.f(1) }`) or a variant-typed receiver reads back a closure exactly like a plain
    // struct's — the variant-table twin of `memberIsClosure` (the `memFieldTypeCode`
    // dispatch order), so the call routes to `call_ref`.
    let mviC = -1
    if memIsNarrowed(exprIx) {
      mviC = memNarrowVariantIndex(exprIx)
    } else {
      mviC = exprVariantIndex(e.memObj, fnIx)
    }
    if mviC >= 0 {
      const mvfiC = variantFieldIndex(mviC, callMemProp(exprIx))
      if mvfiC >= 0 {
        const vfcC = variantFieldTypeAt(mviC, mvfiC)
        if vfcC == 14 || vfcC == 22 { return true }
      }
    }
    // A struct field holding a function value reads back as a closure.
    return memberIsClosure(e.memObj, callMemProp(exprIx), fnIx)
  }
  // An index `xs[i]` into an ARRAY OF FUNCTIONS (`((i32) => i32)[]`, ref-list element
  // kind 5) reads back a closure fat-pointer — callable via `call_ref`.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemKindTbl.length {
        return rlElemKindTbl[slot] == 5
      }
    }
    // A bare `m[k]` over a FUNCTION-valued map (`{[string]: (i32) => i32}`, mv kind 14) reads
    // back the closure (nullable — narrow with `if f != null`).
    const mrs = mapReadMvSlot(exprIx, fnIx)
    if mrs >= 0 { return mvValKind[mrs] == 14 }
  }
  // `m[k] ?? d` over a function-valued map yields the closure.
  if e is BinExpr {
    const cm = coalesceMvSlot(exprIx, fnIx)
    if cm >= 0 { return mvValKind[cm] == 14 }
  }
  false
}

// The closure-ABI param-kind code for a type NAME — the annotation-string analogue of
// `cloParamTok` (which reads the AST), producing the IDENTICAL token per valtype so a
// value call over an annotated higher-order callee (`g: (string) => i32`) resolves the
// same interned `$fnsig` the passed lambda was minted under. "" for a type outside the
// value-call ABI (the all-i32 arity fallback / soundness floor then applies).
function annParamKind(t: string) {
  if t == "i32" || t == "boolean" { return repSigTokOfKind("i32") }
  if t == "f64" { return repSigTokOfKind("f64") }
  if t == "i64" { return repSigTokOfKind("i64") }
  if t == "f32" { return repSigTokOfKind("f32") }
  if isUName(t) { return repSigTokOfKind("union") }
  if nameIsString(t) { return repSigTokOfKind("str") }
  if nameIsI32Array(t) { return repSigTokOfKind("list") }
  if nameIsStringArray(t) { return repSigTokOfKind("strlist") }
  if nameIsF64Array(t) { return repSigTokOfKind("f64list") }
  if nameIsI64Array(t) { return repSigTokOfKind("i64list") }
  if nameIsF32Array(t) { return repSigTokOfKind("f32list") }
  const si = structIndexByName(t)
  if si >= 0 { return repSigSlotTokOfKind("struct", si) }
  // A concrete-variant name (`Cat`), keyed by the variant index (matches `cloParamTok`).
  const vti = variantIndexOf(t)
  if vti >= 0 { return repSigSlotTokOfKind("variant", vti) }
  // A ref-LIST param (`S[]`, `(C|D)[]`, a closure / nested list) — the recursive dual of
  // `annRetKind`'s ref-list result and `cloParamTok`'s ref-list param. BEFORE the arrow
  // case so a closure-ELEMENT array's nested `=>` is not misread as a single closure. The
  // slot resolves via the element name — the SAME `rlSlotByName(refArrElemName(...))` the
  // AST producer uses.
  if nameIsRefArray(t) {
    const rs = rlSlotByName(refArrElemName(t))
    if rs >= 0 { return repSigSlotTokOfKind("reflist", rs) }
  }
  // A FUNCTION-type param (`(i32) => i32`) is the shared closure fat-pointer, matching
  // `cloParamTok`. Without this a higher-order closure param (a callback that itself takes
  // a callback) left the value's `$fnsig` un-interned: the call fell back to the all-i32
  // arity sig and emitted INVALID WASM. The arrow finder is recursive (a top-level `=>` at
  // paren depth 0).
  if annArrowAt(t) >= 0 { return repSigTokOfKind("closure") }
  // A struct param the CHECKER rendered structurally (`{x: i32}`, not a nominal `P`) — the call-site
  // `nodeTyName` fallback in `cloCallSigKey` produces such a name. `structIndexOfTypeName` resolves
  // BOTH a nominal name (above, via `structIndexByName`) and an inline shape (by field-set match), to
  // the SAME struct index the AST producer's `cloParamTok` keys — so the two sig producers agree.
  const sti = structIndexOfTypeName(t)
  if sti >= 0 { return repSigSlotTokOfKind("struct", sti) }
  ""
}

function annRetKind(t: string) {
  if t == "i32" || t == "boolean" { return ">" + repSigTokOfKind("i32") }
  if t == "f64" { return ">" + repSigTokOfKind("f64") }
  // A LITERAL-UNION result (`type K = "a"|"b"`, or inline `"a"|"b"`), OR a NULLABLE literal-union
  // (`K | null`): both rep as the interned i32 ATOM (`vtKindOfType` → "i32", the `-1`-sentinel niche
  // for the nullable), so the result token is `>i` — the SAME token `cloRetKeySuffix` yields (its
  // `cloRetValKind` reads `vtKindOfType`). Checked BEFORE the union-split below, which would
  // otherwise mis-key a litunion's 2+ string atoms as a value-union box (`>u`). Without this the
  // annotation and construct sig producers disagreed on a litunion closure result.
  if nameIsLitUnionType(t) || nameIsNulLitUnion(t) {
    return ">" + repSigTokOfKind("i32")
  }
  // Void is the ABSENCE of a result kind, not a member of the `VKind` vocabulary
  // (`repSigTokOfKind` deliberately has no arm for it) — stays a literal token.
  if t == "void" { return ">v" }
  if t == "string" { return ">" + repSigTokOfKind("str") }
  if t == "i64" { return ">" + repSigTokOfKind("i64") }
  if t == "f32" { return ">" + repSigTokOfKind("f32") }
  // A LIST return — `i32[]`, `string[]`, `f64[]` (matching `cloRetKeySuffix` for the
  // underlying function), so a `(i32) => i32[]` callback resolves the interned signature
  // and its value call lowers. `nameIsI32Array` (not a literal `"i32[]"`) so `boolean[]`,
  // `(boolean | null)[]` and a litunion `K[]` — all sharing the i32-list "a" backing that
  // `cloRetValKind` → `vtKindOfType` reports as "list" — key the SAME `>a` the concrete
  // lambda interns; the param dual (`annParamKind`) already keys these via `nameIsI32Array`.
  if nameIsI32Array(t) { return ">" + repSigTokOfKind("list") }
  if nameIsStringArray(t) { return ">" + repSigTokOfKind("strlist") }
  if nameIsF64Array(t) { return ">" + repSigTokOfKind("f64list") }
  if nameIsI64Array(t) { return ">" + repSigTokOfKind("i64list") }
  if nameIsF32Array(t) { return ">" + repSigTokOfKind("f32list") }
  // A REF-LIST return — `S[]` / `((i32) => i32)[]` / a union list, matching
  // `cloRetKeySuffix`. BEFORE the closure case so a closure-ELEMENT array's nested `=>` is not
  // misread as a single-closure result. The slot resolves via the element name — the SAME
  // `rlSlotByName(refArrElemName(...))` the AST producer's `cloRetValSlot` uses, so the two
  // producers' keys byte-match (else the value-call `ref.cast` to this `$fnsig` traps).
  if nameIsRefArray(t) {
    const rs = rlSlotByName(refArrElemName(t))
    if rs >= 0 { return ">" + repSigSlotTokOfKind("reflist", rs) }
  }
  // A MAP return — `{[string]: V}`, matching `cloRetKeySuffix`'s map result token so the AST
  // and annotation sig producers agree (a value call's `ref.cast` to this `$fnsig` must
  // byte-match). The slot is the map SHAPE (mono ⇒ -1, else the value type's mv slot) — the
  // SAME `mapAnnShape`/`cloRetValSlot` the AST producer keys. BEFORE the closure case (a map
  // annotation carries no top-level arrow, but keep the ABI arms grouped).
  // A map-member UNION (`{[string]: f32} | {w: i32}`) also STARTS with `{[`, so `nameIsMap`
  // matches it — but it is a union BOX, not a bare map. Exclude it (`nameIsMapMemberUnion`) so
  // it falls through to the union arm below (`>u`), byte-matching the lambda's pinned map-union
  // `$fnsig` (`cloRetKeySuffix` reaches the box via `cloRetValKind` → "union"). Without this the
  // value call keyed `>m` while the closure interned `>u` — a "no interned signature" reject.
  if nameIsMap(t) && !nameIsMapMemberUnion(t) {
    return ">" +
      repSigSlotTokOfKind("map", mvSlotOfMapValNameOrMono(mapValNameOf(t)))
  }
  // A CLOSURE return — a function-type result (`(i32) => ((i32) => i32)`), matching
  // `cloRetKeySuffix`'s closure-result token so the AST and annotation sig producers agree
  // (a curried lambda's `$fnsig` must byte-match, else the value-call `ref.cast` traps). The
  // result often arrives PARENTHESIZED (`((i32) => i32)` — source groups the arrow result),
  // hiding its arrow one paren-depth down, so peel a single fully-wrapping `(...)` first.
  let tc = t
  if tc.length >= 2 && tc[0] == '(' {
    let depth = 0
    let ci = 0
    let wraps = true
    while ci < tc.length {
      const cch = tc[ci]
      if cch == '(' {
        depth = depth + 1
      } else if cch == ')' {
        depth = depth - 1
        if depth == 0 && ci < tc.length - 1 { wraps = false }
      }
      ci = ci + 1
    }
    if wraps { tc = tc.slice(1, tc.length - 1) }
  }
  if annArrowAt(tc) >= 0 { return ">" + repSigTokOfKind("closure") }
  // `structIndexOfTypeName` (not `structIndexByName`) so a struct return the CHECKER rendered as an
  // inline shape (`{x: i32}` — the `cloCallSigKey` `nodeTyName` fallback's form) resolves by field-set
  // to the same index the AST producer's `cloRetValSlot` keys, as well as a nominal `P`.
  const si = structIndexOfTypeName(t)
  if si >= 0 { return ">" + repSigSlotTokOfKind("struct", si) }
  // A UNION / NULLABLE return — `string | null`, `S | null`, a 2+-member union → the box
  // (matching `cloRetKeySuffix` for the underlying function). An `i32 | null` boxed niche
  // and any other shape stay "" (un-resolvable here). A union ALIAS (`type Sh = C | S`) is
  // resolved to its member set first (`unionMemberSetOf`), so a closure returning the alias
  // (`(i32) => Sh`) keys the union box — matching `cloRetKeySuffix`, which reaches the box
  // via `vtKindOfType` recognizing the alias. (A non-union name passes through unchanged.)
  const parts: string[] = []
  annSplitPipe(unionMemberSetOf(t), parts)
  if parts.length >= 2 {
    const nonNull: string[] = []
    let hasNull = false
    let pi = 0
    while pi < parts.length {
      const p = parts[pi]
      if p == "null" { hasNull = true }
      else if p.length > 0 { nonNull.push(p) }
      pi = pi + 1
    }
    if hasNull && nonNull.length == 1 {
      if nonNull[0] == "string" { return ">" + repSigTokOfKind("nulstr") }
      // A NULLABLE i32-backed LIST result (`boolean[] | null`, `i32[] | null`, a litunion
      // `K0[] | null` — kind 15): the i32-list wrapper made nullable, slot-free. Matches
      // `cloRetKeySuffix`'s `>o` (via `cloRetValKind` → `vtKindOfType` → "nullist"), so the
      // value call's `ref.cast` byte-matches the closure's interned `$fnsig`. The
      // distinct-backing nullable lists (`i64[] | null`, …) keep falling through to ""
      // (outside the ABI — a loud reject, never invalid wasm).
      if nameIsI32Array(nonNull[0]) { return ">" + repSigTokOfKind("nullist") }
      const msi = structIndexOfTypeName(nonNull[0])
      if msi >= 0 { return ">" + repSigSlotTokOfKind("nulstruct", msi) }
      // A NULLABLE-CLOSURE result (`((i32) => K0) | null`, kind 19): the shared closure
      // fat-pointer made nullable (`(ref null $cloStruct)`, slot-free). Matches
      // `cloRetKeySuffix`'s `>C` (via `cloRetValKind` → "nulclosure"), so the value call's
      // `ref.cast` byte-matches the closure's pinned `$fnsig` — without it the call keyed ""
      // and fell to the all-i32 arity sig (an invalid `(ref $cloStruct)`-where-i32 cast).
      if strContains(nonNull[0], "=>") {
        return ">" + repSigTokOfKind("nulclosure")
      }
      // A nullable numeric scalar (`i32 | null`, `i64 | null`, `f64 | null`, `f32 | null`) reps
      // its result as the value-union {tag,value} BOX (`repOfNullable`'s scalar arm → "union",
      // proven by a constructed `(i32) => i32 | null` interning `i>u`), so the token is `>u` —
      // matching `cloRetKeySuffix`. Lets a value call over a nullable-scalar-returning closure
      // resolve its interned sig; the boxed result recovers exactly as the annotated form's
      // does. (`boolean | null` is the i32-sentinel NICHE, not a box — excluded: its result
      // valtype is plain i32, so the all-i32 arity fallback already agrees.)
      if (
        nonNull[0] == "i32" ||
        nonNull[0] == "i64" ||
        nonNull[0] == "f64" ||
        nonNull[0] == "f32"
      ) {
        return ">" + repSigTokOfKind("union")
      }
      return ""
    }
    if nonNull.length >= 2 { return ">" + repSigTokOfKind("union") }
  }
  ""
}

// The `$fnsig` KEY of a SOURCE function-type annotation `(params)=>ret` — the SAME
// encoding `fnSigKeyOf` produces for a function (`"i>i"`, `"d>d"`, `"s3;>i"`), so a value
// call over an annotated callee resolves the interned signature. "" if any param/return
// type is outside the value-call ABI (the all-i32 arity fallback then applies).
function annSigKey(name: string) {
  const arrowAt = annArrowAt(name)
  if arrowAt < 1 { return "" }
  if name[0] != '(' { return "" }
  if name[arrowAt - 1] != ')' { return "" }
  const paramsStr = name.slice(1, arrowAt - 1)
  const retStr = name.slice(arrowAt + 2, name.length)
  let key = ""
  if paramsStr.length > 0 {
    const parts: string[] = []
    annSplitParams(paramsStr, parts)
    let i = 0
    while i < parts.length {
      const pc = annParamKind(parts[i])
      if pc == "" { return "" }
      key = key + pc
      i = i + 1
    }
  }
  const rc = annRetKind(retStr)
  if rc == "" { return "" }
  key + rc
}

// The `$fnsig` KEY of a union MEMBER-SET arm (a `splitUnionAtoms` atom), or "" for a
// non-closure arm / a signature outside the value-call ABI. A closure arm arrives WRAPPED
// in the disambiguating parens the source requires (`(()=>i64)` — an unwrapped top-level
// arrow would bind the trailing `|` into its RETURN, so `splitUnionAtoms` never splits one
// out) and may carry `| `-split whitespace; neither is peeled by `annSigKey`. Normalize —
// trim, then strip ONE fully-wrapping paren pair — so the key byte-matches the one the
// narrowed CALL site derives (`narrowedClosureOf` → `annSigKey` on the bare `()=>i64`).
export function unionArmSigKey(arm: string) {
  // Trim surrounding ASCII whitespace.
  let lo = 0
  let hi = arm.length
  while lo < hi && (arm[lo] == ' ' || arm[lo] == '\t') { lo = lo + 1 }
  while hi > lo && (arm[hi - 1] == ' ' || arm[hi - 1] == '\t') { hi = hi - 1 }
  let t = arm.slice(lo, hi)
  // Peel a single fully-wrapping `(...)` (the arrow lives one paren-depth down).
  if t.length >= 2 && t[0] == '(' {
    let depth = 0
    let ci = 0
    let wraps = true
    while ci < t.length {
      const cch = t[ci]
      if cch == '(' {
        depth = depth + 1
      } else if cch == ')' {
        depth = depth - 1
        if depth == 0 && ci < t.length - 1 { wraps = false }
      }
      ci = ci + 1
    }
    if wraps { t = t.slice(1, t.length - 1) }
  }
  if annArrowAt(t) < 0 { return "" }
  annSigKey(t)
}

// The lifted-function position (`fnStmts` index) of the function VALUE bound to `let`/
// `const`/global `name` in scope of `fnIx` — `const f = dbl` traces to `dbl`, `const f =
// function(…)…` to the lifted lambda. -1 when `name` is not a binding holding a bare
// function value. Lets a closure call over an INFERRED binding resolve the callee's real
// signature (`fnSigKeyOf`), not the all-i32 arity sig.
export function identClosureFe(name: string, fnIx: i32) {
  if fnIx >= 0 {
    const fn = P.nodes[fnIx]
    if fn is FuncDecl {
      const li = parentLetOf(fn.fnBody, name)
      if li >= 0 {
        const d = P.nodes[li]
        if d is LetDecl { return fieldValueFeOf(d.letInit) }
      }
    }
  }
  const gi = globalLetOf(name)
  if gi >= 0 {
    const gd = P.nodes[gi]
    if gd is LetDecl { return fieldValueFeOf(gd.letInit) }
  }
  -1
}

// The function-type ANNOTATION NAME (`(f64)=>f64`) of a `let`/`const`/global `name` in
// scope of `fnIx`, or "" when `name` is not a function-typed binding.
export function identFnTypeAnnName(name: string, fnIx: i32) {
  if fnIx >= 0 {
    const fn = P.nodes[fnIx]
    if fn is FuncDecl {
      const li = parentLetOf(fn.fnBody, name)
      if li >= 0 {
        const d = P.nodes[li]
        if d is LetDecl {
          if tyIsFuncType(d.letType) { return tyNameOf(d.letType) }
          // A NULLABLE-closure annotation (`(() => string | null) | null`, kind 19): return
          // its name — `cloNameSigKey` peels the `| null` + grouping parens to the bare
          // closure — so a narrowed call through a null-seeded binding (`const v: (fn) | null
          // = null; const t0 = v; if t0 != null { t0() }`) resolves its sig from the
          // annotation even when no closure VALUE exists to trace. Every other caller guards
          // on a top-level arrow (`annArrowAt`), which a nulclosure name never has.
          if nulCloFlag(d.letType) == 1 { return tyNameOf(d.letType) }
          // An UN-annotated closure local from a CALL result (`const g = f(4)` where `f`
          // returns a closure): recover the function type from the checker's recorded type of
          // the init, so its `$fnsig` resolves (the intermediate binding of a curried lambda).
          // Restricted to a Call init: for a bare LAMBDA init the authoritative sig is the
          // lifted function's own `cloSigKeyExt` (via `identClosureFe`), and the checker's
          // INFERRED return for that lambda can disagree (an assignment-tail lambda the checker
          // reads as i32-returning but the emitter lowers as void) — which would mis-cast.
          if d.letType < 0 && d.letInit >= 0 {
            const ini = P.nodes[d.letInit]
            if ini is Call {
              const itn = nodeTyName(d.letInit)
              if annArrowAt(itn) >= 0 { return itn }
            }
            // A COPY of another closure binding (`const t0 = p` where `p: ((i32) => string) | null`
            // — the intermediate the nullable-read pattern `const t0 = p; if t0 != null { t0(1) }`
            // introduces). The init is a bare Ident, so its checked type is authoritative (unlike a
            // lambda, whose inferred return can disagree with the lowering). Return that type NAME —
            // a plain closure OR a nullable closure (`cloNameSigKey` peels the latter) — so the
            // narrowed call classifies its result instead of defaulting to i32 (invalid wasm).
            // A `??`-DEFAULTED closure binding (`const t0 = v["k"] ?? d` over a `{[string]: (i32) =>
            // i32 | null}` map): the coalesce has NO single lifted fe (a runtime pick between the
            // map value and the default), so `identClosureFe` can't see it — recover the function
            // type from the checker's join type of the `??` expression (both arms share it), so its
            // `$fnsig` resolves and the call's result classifies. Like the Call arm, and SAFE for the
            // same reason: NOT a bare lambda (whose lifted `cloSigKeyExt` is authoritative), so the
            // checker's inferred return cannot disagree with the emitter's lowering.
            if ini is BinExpr {
              if ini.binOp == "??" {
                const jtn = nodeTyName(d.letInit)
                if annArrowAt(jtn) >= 0 { return jtn }
              }
            }
            // An UN-annotated binding read from a CLOSURE-element ref list (`const f = xs[i]`
            // over `((i32) => R)[]` / `(((i32) => R) | null)[]`): the kind-5 slot's element
            // name IS the function type — return it (grouping parens peeled for a plain
            // element; a nullable element keeps its `| null`, which `cloNameSigKey` peels) so
            // a call through the binding resolves the ELEMENT's real `$fnsig`, exactly as the
            // direct indexed call (`xs[i](1)` → `cloArrSlotSigKey`) does.
            if ini is Index {
              if exprRefArray(ini.idxArr, fnIx) {
                const islot = refListSlotOfExpr(ini.idxArr, fnIx)
                if islot >= 0 && islot < rlElemKindTbl.length {
                  if rlElemKindTbl[islot] == 5 {
                    const enm = rlElemName[islot]
                    if nullablePartOf(enm) != "" { return enm }
                    return peelGroupParens(enm)
                  }
                }
              }
            }
          }
        }
      }
    }
  }
  const gi = globalLetOf(name)
  if gi >= 0 {
    const gd = P.nodes[gi]
    if gd is LetDecl {
      if tyIsFuncType(gd.letType) { return tyNameOf(gd.letType) }
      // The global dual of the local nulclosure-annotation arm above.
      if nulCloFlag(gd.letType) == 1 { return tyNameOf(gd.letType) }
    }
  }
  ""
}

// The `$fnsig` KEY for a function-VALUE callee Ident `name` (in scope of `fnIx`): a
// function-typed PARAM (its annotation / monomorphized pin), a function-typed LOCAL/GLOBAL
// annotation, or — for an INFERRED binding — the underlying function's own sig. "" → the
// all-i32 arity fallback applies (an unresolved or non-value-ABI signature, incl. void).
// The `$fnsig` key of a function-type NAME that may be a plain closure (`(i32) => string`, a
// top-level arrow) OR a NULLABLE closure (`((i32) => string) | null`, kind 19 — its arrow nested
// one paren-depth down, invisible to `annArrowAt`). For the nullable form, peel `| null` + the
// grouping parens to the bare closure first. "" when neither resolves — the call keeps its all-i32
// arity fallback. Recovers the result token so a narrowed nullable-closure CALL classifies its
// result correctly (print routing / numeric coercion) instead of the pre-fix i32 default.
function cloNameSigKey(nm: string) {
  if annArrowAt(nm) >= 0 { return annSigKey(nm) }
  if nameIsNulClosure(nm) {
    const clo = peelGroupParens(nullablePartOf(nm))
    if annArrowAt(clo) >= 0 { return annSigKey(clo) }
  }
  ""
}

// The SOURCE binding name of an inferred COPY `const name = <Ident>` in scope of `fnIx` (`const
// t0 = p` → `"p"`), or "" when `name` is not such a copy. Lets a closure-VALUE call resolve its
// sig through the intermediate binding the nullable/closure read pattern introduces (`const t0 =
// p; if t0 != null { t0(1) }`) — the checker records no type on a plain Ident init node, so the
// callee sig is recovered by chasing the copy to its source (a param / annotated binding).
function identCopySource(name: string, fnIx: i32) {
  if fnIx < 0 { return "" }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    const li = parentLetOf(fn.fnBody, name)
    if li >= 0 {
      const d = P.nodes[li]
      if d is LetDecl {
        if d.letType < 0 && d.letInit >= 0 {
          const ini = P.nodes[d.letInit]
          if ini is Ident { return ini.identName }
        }
      }
    }
  }
  ""
}

function calleeCloSigKey(name: string, fnIx: i32) {
  // A union binding narrowed to a bare-closure arm (`if x is () => i64 { x() }`): the arm's
  // function-type name interns the SAME `$fnsig` an annotated closure would — so the `call_ref`
  // casts to the right functype and the result classifiers (`calleeReturnsI64`/…) read its return.
  const nc = narrowedClosureOf(name)
  if nc != "" {
    const nk = annSigKey(nc)
    if nk != "" { return nk }
  }
  const pk = paramCloSigKey(fnIx, name)
  if pk != "" { return pk }
  const an = identFnTypeAnnName(name, fnIx)
  if an != "" {
    const ak = cloNameSigKey(an)
    if ak != "" { return ak }
  }
  const fe = identClosureFe(name, fnIx)
  // The EXTENDED key (not just `fnSigKeyOf`) so a VOID-returning binding (`const f = hi`)
  // resolves its `>v` sig — interned above for void function values. A value-eligible
  // (i32/f64) binding takes the same key `fnSigKeyOf` would give.
  if fe >= 0 { return cloSigKeyExt(fe) }
  // An inferred COPY of another closure binding (`const t0 = p`): chase the source so a call
  // through the intermediate binding classifies its result (nullable-closure read pattern).
  const src = identCopySource(name, fnIx)
  if src != "" && src != name { return calleeCloSigKey(src, fnIx) }
  ""
}

// True if the function-VALUE callee `name` (in scope of `fnIx`) returns f64 — its resolved
// `$fnsig` key's result kind is `"f64"`. Drives the closure-call RESULT classification
// (print routing, numeric-context coercion), the value-call analogue of `fRetF64` for a
// named function.
function calleeReturnsF64(name: string, fnIx: i32) {
  calleeRetKind(name, fnIx) == "f64"
}

// True if the function-VALUE callee `name` (in scope of `fnIx`) returns void — its
// resolved `$fnsig` key carries the `>v` void marker (`sigKeyRetIsVoid`, NOT the `null`
// an unresolved key also decodes to). A void closure call leaves NOTHING on the stack, so
// its statement form must NOT `drop` (the value-call analogue of `fRetVoid` for a named
// function — which `fnIndexOf` can't see for a param / binding closure value).
export function calleeReturnsVoid(name: string, fnIx: i32) {
  sigKeyRetIsVoid(calleeCloSigKey(name, fnIx))
}

// True if the function-VALUE callee `name` (in scope of `fnIx`) returns a string — its
// resolved `$fnsig` key's result kind is `"str"`. The value-call analogue of
// `fnRetString` for a named function — drives the closure-call RESULT's string typing
// (binding cell, print routing).
function calleeReturnsString(name: string, fnIx: i32) {
  calleeRetKind(name, fnIx) == "str"
}

// True if the function-VALUE callee `name` (in scope of `fnIx`) returns i64 — its resolved
// `$fnsig` key's result kind is `"i64"`. The value-call analogue of `fRetI64` for a named
// function — drives the closure-call RESULT's i64 typing (print routing, numeric-context
// coercion).
function calleeReturnsI64(name: string, fnIx: i32) {
  calleeRetKind(name, fnIx) == "i64"
}

// The struct-table INDEX a function-VALUE callee `name` (in scope of `fnIx`) returns, or
// -1. Its resolved `$fnsig` key's result kind is `"struct"` (`>sN;`) or `"nulstruct"`
// (`>nN;`); the slot digits parse through the shared result-slot reader
// (`sigKeyRetSlot`). The value-call analogue of `fnRetStructIndex` — drives the closure-
// call RESULT's struct typing (`p.x` over `const p = f(5)`, struct or nullable-struct).
function calleeReturnsStructIdx(name: string, fnIx: i32) {
  const k = calleeCloSigKey(name, fnIx)
  const rk = sigKeyRetKind(k)
  if rk == "struct" || rk == "nulstruct" { return sigKeyRetSlot(k) }
  -1
}

// The position of a `$fnsig` key's RESULT token char — just past the LAST `>` (params
// never contain one, so the last `>` begins the result spine) — or -1 for an empty /
// result-less key. The ONE last-`>` scan: every result-side reader (`sigKeyRetKind` /
// `sigKeyRetIsVoid` / `sigKeyRetSlot`) decodes through it instead of re-scanning the
// key string per site.
function sigKeyRetTokIx(k: string) {
  const n = k.length
  let gt = -1
  let i = 0
  while i < n {
    if k[i] == '>' { gt = i }
    i = i + 1
  }
  if gt < 0 || gt + 1 >= n { return -1 }
  gt + 1
}

// The `cloRetValKind`-style RESULT kind of a function-VALUE callee `name` (in scope of
// `fnIx`), decoded from the trailing `>X` token of its resolved `$fnsig` key — the `VKind`
// the token names, or `null` for a void result / when `name` resolves to no value-call
// sig (the two are indistinguishable here; no consumer needs to tell them apart). Drives
// the per-kind closure-call RESULT classifiers.
// The RESULT value-KIND encoded in a closure `$fnsig` key (the atom after the final `>`),
// or `null` when the key is empty / malformed. Shared by the Ident-callee path
// (`calleeRetKind`), the indexed-element path (`cloArrCallRetKind`), and — for a
// monomorphized closure-pinned param (`"=>i>d"`) — the instance-return pin (emit_mono).
export function sigKeyRetKind(k: string): VKind | null {
  const ti = sigKeyRetTokIx(k)
  if ti < 0 { return null }
  const c = k[ti]
  // Void is the ABSENCE of a result kind, not a member of the token
  // vocabulary — tested before the shared table.
  if c == 'v' { return null }
  // ONE vocabulary with the encode sites: the token decodes through the
  // canonical char→kind table (`repKindOfSigTok` — the inverse of the
  // `repSigTokOfKind` the encoders read). An encoder arm can no longer exist
  // without its decoder twin.
  repKindOfSigTok(c)
}

// True when a `$fnsig` key's result token is the literal void marker (`…>v`) —
// distinguishable from an EMPTY/unresolved key, which `sigKeyRetKind` folds into the
// same `null` a void result yields.
function sigKeyRetIsVoid(k: string) {
  const ti = sigKeyRetTokIx(k)
  ti >= 0 && k[ti] == 'v'
}

// True when a closure value CALL's DECLARED result is a value UNION but the resolved
// closure `$fnsig` reps its result as a NON-union — a single concrete member (a plain
// struct / scalar, not the shared `{tag, value}` box). This is the deferred VALUE-UNION-
// with-a-COMPOSITE-member closure-RESULT family (the typecheck.vl C2/C3 note): the union
// box READ does not yet compose through a closure result, so the lambda's body self-infers
// its single concrete arm (`(q0) => ({w:77})` reps a bare `{w:i32}`) while the checker types
// the call as the whole union `f32 | {w:i32}`. The narrow that consumes it (`t0 is f32`)
// then mis-reads the plain struct rep as the box — INVALID WASM (a dead-but-invalid narrowed
// arm printing a `(ref)` via `__print_f32__`). The value-call emitter REJECTS on this so the
// hole is a clean loud REJECT, never silent invalid wasm. A SUPPORTED value-union closure
// result (the lambda adopted the union, its `$fnsig` result keys `>u`) returns false — as
// does every non-union result. Mirrors the binding-position loud reject.
export function cloCallUnionResultUnrepresentable(
  callIx: i32,
  fnIx: i32,
): boolean {
  // CASE A (nullable-closure-union RESULT, `() => (() => i32 | boolean) | null`): the resolved
  // sig claims a value-union BOX result (`>u`) but NO value union is declared in the program —
  // the box only arose inside an UN-CONSTRUCTED nested closure-result type, so `uBoxIdx` is
  // never minted and `fbValtype("union")` would emit `(ref 0)` (the string/array type): invalid
  // wasm at the inner call's `struct.get` tag read. The box read through this closure-result
  // nesting is the deferred #875 family (a plain-binding nullable-closure-union already rejects
  // cleanly); reject here too so the closure-RESULT position never leaks invalid wasm.
  const ckeyA = cloCallSigKey(callIx, fnIx)
  if ckeyA != "" {
    const rkA = sigKeyRetKind(ckeyA)
    if rkA != null && rkA == "union" && !uDeclared { return true }
  }
  const ty = nodeTyIxOf(callIx)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if !(t is TyUnion) { return false }
  if t.uMembers.length < 2 { return false }
  // A "boxing" value union: at least one SCALAR (`TyPrim` — i32/f64/f32/i64/boolean/string)
  // member AND at least one COMPOSITE (object/array/map/closure) member. Their reps differ,
  // so the union needs the shared `{tag, value}` box — the case a closure result does not yet
  // compose. A pure-scalar value union (`i64 | boolean`) OR a pure litunion (`TyLit` members)
  // is REP-uniform and already lowers (its sig keys `>u` / `>i`); a struct/variant union
  // (`Cat | Dog`, no scalar member) reps via the variant tag. Only the heterogeneous
  // scalar+composite mix is the deferred hole, so gate on it precisely.
  let hasScalar = false
  let hasComposite = false
  let i = 0
  while i < t.uMembers.length {
    const mt = T.tys[t.uMembers[i]]
    if mt is TyPrim { hasScalar = true }
    else if mt is TyObj { hasComposite = true }
    else if mt is TyArray { hasComposite = true }
    else if mt is TyMap { hasComposite = true }
    else if mt is TyFunc { hasComposite = true }
    i = i + 1
  }
  if !hasScalar || !hasComposite { return false }
  // Rep-consistent only when the resolved closure `$fnsig` result IS the union box (`>u`).
  // No sig, an unparseable result, or a concrete-member result token (`>s…`, a scalar) means
  // the box read has nothing to recover — the deferred hole. Reject.
  const ckey = cloCallSigKey(callIx, fnIx)
  if ckey == "" { return true }
  const rk = sigKeyRetKind(ckey)
  if rk == null { return true }
  rk != "union"
}

// The interned SLOT of a slot-carrying result token (`>s3;`, `>n1;`, `>V0;`, `>r2;`,
// `>m0;`) — the `;`-terminated decimal after the token char — or -1 when the key's
// result kind carries no slot (`repSigTokHasSlot`, the encode side's own predicate) or
// the digits are malformed. The ONE result-slot digit parser; callers gate on
// `sigKeyRetKind` for WHICH table the slot indexes (struct / variant / ref-list / map).
function sigKeyRetSlot(k: string) {
  const ti = sigKeyRetTokIx(k)
  if ti < 0 { return -1 }
  if !repSigTokHasSlot(repKindOfSigTok(k[ti])) { return -1 }
  let j = ti + 1
  let acc = 0
  let saw = false
  while j < k.length && k[j] != ';' {
    const d = k[j]
    if d < '0' || d > '9' { return -1 }
    acc = acc * 10 + (d - '0')
    saw = true
    j = j + 1
  }
  if !saw { return -1 }
  acc
}

function calleeRetKind(name: string, fnIx: i32): VKind | null {
  return sigKeyRetKind(calleeCloSigKey(name, fnIx))
}

// The RESULT value-KIND of a call whose CALLEE is an INDEX into a closure array
// (`fs[i](x)`): the closure-element signature's return atom (`cloArrSlotSigKey` →
// `sigKeyRetKind`). `null` when the call's callee is not an indexed closure value. The
// expr classifiers (`exprString`/`exprIsF64`/… Call arms) consult this so an indexed
// closure call's result routes to the right print / arithmetic / store path — the dual of
// the call-SIGNATURE resolution `emitCallRef` does for the same shape.
function cloArrCallRetKind(callIx: i32, fnIx: i32): VKind | null {
  const c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Index {
      if exprRefArray(callee.idxArr, fnIx) {
        return sigKeyRetKind(
          cloArrSlotSigKey(refListSlotOfExpr(callee.idxArr, fnIx)),
        )
      }
    }
  }
  null
}

function paramCloSigKey(fnIx: i32, name: string) {
  if fnIx < 0 { return "" }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    const params = fn.fnParams
    let i = 0
    while i < params.length {
      const p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            const ty = P.nodes[p.parType]
            if ty is TypeRef {
              const nm = ty.tyName
              if nm.length > 2 {
                // A MONOMORPHIZED closure-pinned param carries the bare `"=>sigkey"`.
                if nm[0] == '=' && nm[1] == '>' {
                  return nm.slice(2, nm.length)
                }
                // A NULLABLE-closure param (`((i32) => string) | null`, kind 19) OR a SOURCE
                // function-type annotation `(params)=>ret`: derive its sig key so a non-i32 (e.g.
                // f64) signature casts to the right functype, and — for a nullable closure whose
                // arrow is nested one paren-depth down — the RESULT classifiers (`calleeReturns*`,
                // print routing) recover the closure's result token instead of defaulting to i32
                // (the pre-fix invalid-wasm: a narrowed `p(1)` string result printed as i32).
                if strContains(nm, "=>") { return cloNameSigKey(nm) }
              }
            }
          }
          return ""
        }
      }
      i = i + 1
    }
  }
  ""
}

// True if the function at `fnStmts` position `t` returns a function value — its body's
// tail expression is itself a function value (a bare function name, a `function(...)`
// literal, or a closure-typed local). Drives `exprIsClosure` for call results
// (`const f = makeAdder(5)` where `makeAdder` returns its inner closure).
export function fnReturnsClosure(t: i32) {
  if t < 0 || t >= fnStmts.length { return false }
  const fn = P.nodes[fnStmts[t]]
  if fn is FuncDecl {
    // An ANNOTATED function-type return (`: (i32) => i32`) is a closure result regardless of
    // how the body yields it — e.g. `return f(x)`, a higher-order call the tail scan can't see
    // (`exprIsClosureNoLocal` has no Call case). The annotated result valtype is already kind 14.
    if fn.fnRet >= 0 && tyIsFuncType(fn.fnRet) { return true }
    return blockTailIsClosure(fn.fnBody, fnStmts[t])
  }
  false
}

// True if the block's tail (implicit-return) expression is a function value.
function blockTailIsClosure(blockIx: i32, fnIx: i32) {
  const b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    const n = stmts.length
    if n == 0 { return false }
    const last = stmts[n - 1]
    const s = P.nodes[last]
    if s is RetStmt {
      if s.retArg >= 0 { return exprIsClosureNoLocal(s.retArg, fnIx) }
      return false
    }
    return exprIsClosureNoLocal(last, fnIx)
  }
  false
}

// `exprIsClosure` restricted to forms safe to query during return-kind classification
// (avoids recursion through `declaredSlotOf`, which needs the local registry built):
// a function name, a `function(...)` literal, or an object field. Captures the common
// `return add` / `{ go: add }` escaping-closure tails.
function exprIsClosureNoLocal(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Paren { return exprIsClosureNoLocal(e.parInner, fnIx) }
  if e is FuncDecl { return true }
  if e is Ident { return fnIndexOf(e.identName) >= 0 }
  if e is ObjLit { return false }
  false
}

// True if member access `obj.prop` yields a function value — `prop` is a struct field
// whose declared type is a function type. (For `objects/equality-function-field.vl` and
// `escaping.vl`'s `o.go`.) Resolved against the receiver's struct table fields.
function memberIsClosure(objIx: i32, prop: string, fnIx: i32) {
  const si = structIndexOfExpr(objIx, fnIx)
  if si >= 0 { return structFieldIsClosure(si, prop) }
  // A NARROWED union receiver (`t0.f(1)` after `if t0 is {f: (i32) => boolean[]}` over a
  // `{f: …} | f64` binding): the receiver's struct index is not resolvable from its
  // DECLARED (union) type, but the narrowed VARIANT's field tables carry the field code —
  // a closure field (14) / nullable-closure field (22) reads back a closure and calls via
  // `call_ref` (the member READ itself lowers through `emitNarrowedMem`).
  const o = P.nodes[unwrapParen(objIx)]
  if o is Ident {
    const nv = narrowVariantFor(o.identName)
    if nv != "" {
      const vi = variantIndexOf(nv)
      if vi >= 0 {
        const vfi = variantFieldIndex(vi, prop)
        if vfi >= 0 {
          const vfc = variantFieldTypeAt(vi, vfi)
          return vfc == 14 || vfc == 22
        }
      }
    }
  }
  false
}

// True if field `prop` of struct table index `si` is a function-valued field — a bare
// closure (code 14) or a NULLABLE closure (code 22). Both read back as a closure and call
// via `call_ref`; the nullable one is recovered to non-null at the call site.
function structFieldIsClosure(si: i32, prop: string) {
  if si < 0 || si >= sNames.length { return false }
  const cnt = sFieldCount[si]
  const start = sFieldStart[si]
  let fj = 0
  while fj < cnt {
    if sFieldNames[start + fj] == prop {
      const fc = sFieldTypeAt(si, fj)
      return fc == 14 || fc == 22
    }
    fj = fj + 1
  }
  false
}

// `xs.pop()` / `xs.get(i)` over a STRUCT-element ref list — the host types both as
// `S | null`. Returns the element STRUCT TABLE INDEX, or -1 when the call is not such
// a read. Restricted to plain-struct elements (`rlElemKindTbl == 1`): map-array
// (`{[string]:i32}[]`, kind 3) and union-element (kind 2) pops keep their existing
// classification (g_maparray's golden bytes depend on it).
export function structListPopGetElem(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return -1 }
  const e = P.nodes[exprIx]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "pop" || callee.memProp == "get" {
        if exprRefArray(callee.memObj, fnIx) {
          const slot = refListSlotOfExpr(callee.memObj, fnIx)
          if slot >= 0 && slot < rlElemKindTbl.length {
            if rlElemKindTbl[slot] == 1 {
              return structIdxOfElemName(rlElemName[slot])
            }
          }
        }
      }
    }
  }
  -1
}

// ── `.map` / `.filter` classification (Slices 3–4) ─────────────────────────────

// True if the expression at `exprIx` is a `.map`/`.filter` HOF call over a LIST
// receiver (one callback argument). A member call named `map`/`filter` over a
// NON-list receiver (e.g. a function-valued struct field) is NOT a HOF site.
function callIsMapFilter(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "map" || callee.memProp == "filter" {
        if e.callArgs.length == 1 {
          return mfRecvKindOf(callee.memObj, fnIx) != null
        }
      }
    }
  }
  false
}

// True if the expression at `exprIx` is an array `.slice(start, end?)` over a LIST
// receiver — a sublist of the SAME element type. (A string `.slice` is a separate
// `exprIsStrSlice` path; this is the array dual.)
export function callIsArrSlice(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "slice" {
        if e.callArgs.length == 1 || e.callArgs.length == 2 {
          return mfRecvKindOf(callee.memObj, fnIx) != null
        }
      }
    }
  }
  false
}

// The RECEIVER list kind of a `.map`/`.filter` call: `0` (i32/boolean list), `1`
// (f64 list), `2` (struct/union ref list), or -1 (not a supported list — a string
// list or a non-list receiver).
export function mfRecvKindOf(recvIx: i32, fnIx: i32): MfKind | null {
  if exprF64Array(recvIx, fnIx) { return "f64" }
  if exprI64Array(recvIx, fnIx) { return "i64" }
  if exprF32Array(recvIx, fnIx) { return "f32" }
  if exprRefArray(recvIx, fnIx) { return "ref" }
  if exprStringArray(recvIx, fnIx) { return "str" }
  if exprArray(recvIx, fnIx) { return "i32" }
  null
}

// The RESULT element kind of the `.map`/`.filter` call at `callIx`: `0` (i32/boolean
// element — an i32 list result), `1` (f64 element — an f64 list result), or -1
// (unsupported). `filter` keeps the receiver's element kind (a ref-list filter is
// out of scope — it fails loudly at emit); `map`'s result element kind IS the
// callback's RETURN kind (`cloRetKindOf`).
export function mfResultKindOf(callIx: i32, fnIx: i32): MfKind | null {
  const c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      // `.slice` preserves the element type — its result kind IS the receiver's.
      if callee.memProp == "slice" { return mfRecvKindOf(callee.memObj, fnIx) }
      if callee.memProp == "filter" { return mfRecvKindOf(callee.memObj, fnIx) }
      if c.callArgs.length == 1 {
        const fe = mfCallbackFe(c.callArgs[0], fnIx)
        if fe < 0 {
          // A CLOSURE-VALUE callback (`xs.map(f)`, `f` a function-typed param/binding) — its result
          // kind comes from the closure's sig RETURN token, not a lifted fe (scalar returns only).
          const ck = mfCallbackCloKey(c.callArgs[0], fnIx)
          if ck != "" { return mfResKindFromSigRet(sigKeyRetKind(ck)) }
          return null
        }
        // A string-returning callback maps to a string-list result (kind 3) — checked first
        // since `cloRetKindOf` folds string into -1.
        if cloRetIsString(fe) { return "str" }
        // A STRUCT-returning callback maps to a NEW ref list of the result struct (kind 2) —
        // `cloRetKindOf` folds a struct into -1, so consult `cloRetValKind` (which classifies
        // the struct result as kind 1) directly. The result element type DIFFERS from the
        // source (`P[].map((p) => Q-shape)` ⇒ `Q[]`), so the dst slot is the RESULT struct's
        // ref-list slot, not the source's (`mfResultSlotOf`).
        if cloRetValKind(fe) == "struct" { return "ref" }
        // A concrete-VARIANT-returning callback (a collapse) maps to a ref list of bare
        // variant structs (kind 2, element a variant) — checked before the union case since
        // `cloRetValKind` already prefers the variant.
        if cloRetValKind(fe) == "variant" { return "ref" }
        // A UNION-returning callback maps to a ref list of union BOXES (kind 2, element kind
        // 2). All unions share `$uBox`, so the result element is the declared union; its box
        // body is produced by the callback's own union-boxing return path.
        if cloRetValKind(fe) == "union" { return "ref" }
        // An i64- / f32-returning callback maps to an i64- / f32-list result (mf-kinds 4 / 13).
        // `cloRetKindOf` folds these to -1 (out of the value-CALL ABI), so consult
        // `cloRetValKind` (10 = i64, 13 = f32) directly, as the struct/union cases above do.
        if cloRetValKind(fe) == "i64" { return "i64" }
        if cloRetValKind(fe) == "f32" { return "f32" }
        const rk2 = cloRetKindOf(fe)
        if rk2 == "i32" { return "i32" }
        if rk2 == "f64" { return "f64" }
      }
      return null
    }
  }
  null
}

// The ref-list TABLE SLOT of a kind-2 `.map`/`.filter` result, or -1. `.filter` preserves the
// receiver's element list, so the result slot IS the source ref-list slot.
export function mfResultSlotOf(callIx: i32, fnIx: i32) {
  const c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      // `.slice` preserves the ref-list element — its result slot IS the receiver's.
      if callee.memProp == "slice" {
        if mfRecvKindOf(callee.memObj, fnIx) == "ref" {
          return refListSlotOfExpr(callee.memObj, fnIx)
        }
      }
      if callee.memProp == "filter" {
        if mfRecvKindOf(callee.memObj, fnIx) == "ref" {
          return refListSlotOfExpr(callee.memObj, fnIx)
        }
      }
      // A STRUCT-returning `.map`: the result is a NEW ref list whose element is the
      // callback's RETURN struct — its ref-list slot (interned by `mfScan`).
      if callee.memProp == "map" && c.callArgs.length == 1 {
        const fe = mfCallbackFe(c.callArgs[0], fnIx)
        if fe >= 0 && cloRetValKind(fe) == "struct" {
          const si = cloRetValSlot(fe)
          if si >= 0 && si < sNames.length { return rlSlotByName(sNames[si]) }
        }
        // A struct-returning CLOSURE-VALUE callback (`xs.map(f)`, `f: (i32) => P`): no lifted fe, so the
        // result struct index comes from the closure's `>s<idx>;` sig-return token. Its ref-list slot
        // (`P[]`) is the `.map` result — the closure-value dual of the lifted-fe branch above.
        if fe < 0 {
          const ck = mfCallbackCloKey(c.callArgs[0], fnIx)
          if ck != "" && sigKeyRetKind(ck) == "struct" {
            const csi = sigKeyRetSlot(ck)
            if csi >= 0 && csi < sNames.length {
              return rlSlotByName(sNames[csi])
            }
          }
        }
        // A concrete-VARIANT `.map`: the result element is the variant — its ref-list slot
        // is keyed by the variant NAME (`uVariants[vi]`).
        if fe >= 0 && cloRetValKind(fe) == "variant" {
          const vi = cloRetValSlot(fe)
          if vi >= 0 && vi < uVariants.length {
            return rlSlotByName(uVariants[vi])
          }
        }
        // A UNION-returning `.map`: the result is a ref list of the declared union (all
        // unions share `$uBox`, so the element key is the union alias name).
        if fe >= 0 && cloRetValKind(fe) == "union" && unNames.length > 0 {
          return rlSlotByName(unNames[0])
        }
      }
    }
  }
  -1
}

// Resolve a `.map`/`.filter` CALLBACK argument to its lifted-function position in
// `fnStmts`: an inline `function(...)` literal (lifted by `collectFns`), a named
// function reference, or a let-bound function value whose binding initializer is one
// of those (a local `let` in the enclosing function, else a module global). -1 when
// the callback's target function cannot be statically resolved.
export function mfCallbackFe(cbIx: i32, fnIx: i32) {
  if cbIx < 0 { return -1 }
  const inner = unwrapParen(cbIx)
  const e = P.nodes[inner]
  if e is FuncDecl { return fnStmtsPosOf(inner) }
  if e is Ident {
    const t = fnIndexOf(e.identName)
    if t >= 0 { return t }
    let li = -1
    if fnIx >= 0 {
      const fn = P.nodes[fnIx]
      if fn is FuncDecl { li = parentLetOf(fn.fnBody, e.identName) }
    }
    if li < 0 { li = globalLetOf(e.identName) }
    if li >= 0 {
      const d = P.nodes[li]
      if d is LetDecl {
        if d.letInit >= 0 {
          // Guard the degenerate self-referential binding against infinite recursion.
          if unwrapParen(d.letInit) != inner {
            return mfCallbackFe(d.letInit, fnIx)
          }
        }
      }
    }
  }
  -1
}

// True if the lifted callback at `fe` returns a BOOLEAN (its annotation, or the
// inferred `fRetBool`) — the element-bool-ness of a `.map` result, threaded to the
// print import choice (`__print_bool__` renders true/false).
function mfCbRetIsBool(fe: i32) {
  if fe < 0 || fe >= fnStmts.length { return false }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    if fn.fnRet >= 0 {
      const rt = P.nodes[fn.fnRet]
      if rt is TypeRef { return rt.tyName == "boolean" }
      return false
    }
    if fe < fRetBool.length { return fRetBool[fe] == 1 }
  }
  false
}

// True if an INDEX READ over the list at `arrIx` yields a boolean element. Today the
// only boolean-element list producer is a `.map` whose callback returns boolean
// (`xs.map(function(n: i32) n > 2)`); a `.filter` keeps its receiver's element
// bool-ness, and a module-global binding traces through its initializer.
function mfArrElemIsBool(arrIx: i32, fnIx: i32) {
  if arrIx < 0 { return false }
  const inner = unwrapParen(arrIx)
  const e = P.nodes[inner]
  if e is Call {
    if callIsMapFilter(inner, fnIx) {
      const callee = P.nodes[e.callFn]
      if callee is Member {
        if callee.memProp == "filter" {
          return mfArrElemIsBool(callee.memObj, fnIx)
        }
        return mfCbRetIsBool(mfCallbackFe(e.callArgs[0], fnIx))
      }
    }
    return false
  }
  if e is Ident {
    const li = globalLetOf(e.identName)
    if li >= 0 {
      const d = P.nodes[li]
      if d is LetDecl {
        if d.letInit >= 0 {
          if unwrapParen(d.letInit) != inner {
            return mfArrElemIsBool(d.letInit, -1)
          }
        }
      }
    }
  }
  false
}

// Detect `.map`/`.filter` HOF sites up front (one arena scan, mirroring the print
// scan): ANY site makes the program function-value-using (`fnValUsed` — the callback
// is a closure value even when it is a bare named-function reference), and a `.map`
// whose callback returns i32/boolean (f64) forces the i32 (f64) list types for the
// RESULT list — the receiver may be a ref/f64 list that never otherwise touches
// them. `.filter` reuses the receiver's own (already-collected) types. Runs after
// `computeRetInference` (an un-annotated callback's return kind is inferred);
// programs without `.map`/`.filter` set nothing — every golden stays byte-identical.
// True if the expression at `ix` is a bare Ident naming a top-level function —
// a function VALUE use when it sits in a value position (an initializer, an
// assignment's right side, an equality operand).
export function exprIsBareFnName(ix: i32) {
  if ix < 0 { return false }
  const e = P.nodes[ix]
  if e is Ident { return fnIndexOf(e.identName) >= 0 }
  false
}

// The concrete annotation NAME for the argument expression at `ix` inside
// function `fnIx` (-1 = top level) — the same classification ladder the return-
// kind inference runs (`exprString`/`exprArray`/…), rendered back to the
// annotation name an instance's pinned `TypeRef` carries. "" = a kind this pass
// cannot name (the caller fails loudly).
// The RESULT type NAME of lifted function `fe` (`i32`, `string`, `i32[]`, a struct
// name, …) — its declared return annotation, or the inferred kind mapped back to a
// name. Used to build a closure argument's function-type name for generic binding.
export function cloRetTypeName(fe: i32) {
  if fe < 0 || fe >= fnStmts.length { return "" }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    if fn.fnRet >= 0 { return tyNameOf(fn.fnRet) }
  }
  const k = cloRetValKind(fe)
  if k == "i32" { return "i32" }
  if k == "f64" { return "f64" }
  if k == "i64" { return "i64" }
  if k == "f32" { return "f32" }
  if k == "str" { return "string" }
  if k == "list" { return "i32[]" }
  if k == "strlist" { return "string[]" }
  if k == "f64list" { return "f64[]" }
  if k == "struct" {
    const slot = cloRetValSlot(fe)
    if slot >= 0 && slot < sNames.length { return sNames[slot] }
  }
  ""
}

// The function-TYPE name `(p1, p2) => ret` of a closure-VALUE argument (a lambda
// literal or a bare top-level function name) — the form `monoBindFromAnn` matches a
// generic closure param `(A, T) => A` against. "" when the argument is not a resolvable
// closure value or a param/return type lies outside the name vocabulary. (Distinct from
// `monoArgTyName`'s `"=>sigkey"` pin, which an UN-annotated closure param wants.)
// Resolve any STRUCTURAL shapes inside a `(params)=>ret` function-type name to their NOMINAL names —
// the single structural→nominal bridge (`resolveShapeToNominal`, which also peels `[]`) applied to each
// param and the return. The checker renders a lambda's struct part as `{x: i32}` / `{x: i32}[]`; the
// monomorphizer's type-param bindings and every nominal-keyed emitter site (`nameIsRefArray`,
// `rlSlotByName`, `structIndexByName`) want `P` / `P[]`. Applied ONCE at the mono boundary so the
// instance is nominal throughout. A non-function name, or one with no resolvable shape, passes through.
export function nominalizeFnType(name: string) {
  const at = annArrowAt(name)
  if at < 1 { return name }
  if name[0] != '(' { return name }
  if name[at - 1] != ')' { return name }
  const paramsStr = name.slice(1, at - 1)
  const retStr = name.slice(at + 2, name.length)
  let out = "("
  if paramsStr.length > 0 {
    const parts: string[] = []
    annSplitParams(paramsStr, parts)
    let i = 0
    while i < parts.length {
      if i > 0 { out = out + "," }
      out = out + resolveShapeToNominal(parts[i])
      i = i + 1
    }
  }
  out + ")=>" + resolveShapeToNominal(retStr)
}

// Strip ONE layer of wrapping parens when they enclose the WHOLE string (`((i32,i32)=>i32)` →
// `(i32,i32)=>i32`, the grouping parens a function type carries as an array element); leaves a name
// whose leading `(` is not the outermost wrapper (`(i32,i32)=>i32`) untouched.
export function monoUnwrapParens(s: string) {
  const n = s.length
  if n < 2 { return s }
  if s[0] != '(' { return s }
  if s[n - 1] != ')' { return s }
  let depth = 0
  let i = 0
  while i < n {
    if s[i] == '(' {
      depth = depth + 1
    } else if s[i] == ')' {
      depth = depth - 1
      if depth == 0 {
        if i == n - 1 { return s.slice(1, n - 1) }
        return s
      }
    }
    i = i + 1
  }
  s
}

// Does struct `si` carry a CLOSURE-valued field `name` (code 14)?
export function drwFieldClosure(si: i32, name: string) {
  if si < 0 { return false }
  const fi = sFieldIndex(si, name)
  if fi < 0 { return false }
  sFieldTypeAt(si, fi) == 14
}

// Give each un-annotated parameter the concrete scalar/string type the checker recorded for
// it (`nodeTyName`) — a contextually-inferred callback param (`xs.map((x) => x * 2.0)` ⇒
// `x: f64`) whose annotation the emitter otherwise defaults to i32 (`checkParams`), so an
// f64/string-element callback mis-lowered. Emit-time, post-check (fmt untouched); a generic
// hole / already-annotated / non-scalar param yields "" and is left as-is.
// Resolve a checker-rendered type-shape NAME to the emitter's NOMINAL form: a struct shape
// (`{x: i32}`) to its declared name (matched by field-set), a variant shape to its variant name,
// and — RECURSIVELY — a ref-array shape to `<resolved element>[]` at any depth. A scalar / closure
// / already-nominal name passes through. One recursive resolver, so a new container shape (a
// nested list, a list-of-lists) falls out instead of being special-cased per depth.
export function resolveShapeToNominal(name: string) {
  if name == "" { return "" }
  if nameIsArray(name) {
    const inner = resolveShapeToNominal(name.slice(0, name.length - 2))
    if inner == "" { return "" }
    return inner + "[]"
  }
  const si = structIndexOfTypeName(name)
  if si >= 0 { return sNames[si] }
  const vti = variantIndexOfTypeName(name)
  if vti >= 0 { return uVariants[vti] }
  name
}
