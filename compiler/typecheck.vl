// A type-checker for a meaningful subset of VL, written in VL
// (Track H / H3 self-hosting — the compiler stage after the lexer and parser).
//
// Side-by-side with `compiler/typecheck.ts`, whose SHAPE it follows (a type
// algebra, a scope chain, inference from initializers, structural assignability,
// a diagnostics channel) but reimplemented idiomatically for VL — it is NOT a
// transliteration. VL has no module system yet, so the TS driver
// (`tests/selfhost_typecheck_test.ts`) concatenates `compiler/ast.vl`,
// `compiler/parser.vl`, this file, then a `.vl` harness before compiling, so the
// AST types/constructors, the global parser state `P`, the parse entry points,
// and `i32ToStr` are already in scope. The checker consumes the REAL parser's
// node arena (`P.nodes`): it lexes nothing and parses nothing itself, it walks
// the union AST the parser built.
//
// ── Finding 1 — the type algebra is a TYPE ARENA ─────────────────────────────
// VL's `compiler/typecheck.ts` represents types as a RECURSIVE union `VLType`
// whose members nest more `VLType`s (an `Object` property's type is a `VLType`, a
// `Function`'s return is a `VLType`). That encoding is NOT expressible in VL: a
// `type` union alias cannot self- or forward-reference its own members (the same
// limitation that forced the AST to use arena indices for child nodes — see
// `ast.vl`). So types live in their OWN flat arena `T.tys: Ty[]` and every place
// a type would nest another type holds an `i32` INDEX into that arena instead:
//   - `TyObj.objFieldTypes : i32[]`  (a field's type is a type-arena index)
//   - `TyFunc.fnParamTypes : i32[]`, `TyFunc.fnRet : i32`
//   - `TyUnion.uMembers : i32[]`, `TyNullable.nInner : i32`
// This is the same workaround the AST node arena uses, applied to the type
// algebra — the predicted gap, now confirmed (PR gap inventory #1).
//
// ── Finding 2 (RESOLVED) — the mono-visitor constraint is lifted ─────────────
// Historically, two distinct functions that `is`-narrowed the SAME union and were
// mutually recursive through it MISCOMPILED ("Object has no field …"), which forced
// every per-variant body to be INLINED into the single `checkNode` mega-function.
// That host bug is FIXED — pinned by `tests/cases/types/union-two-visitors.vl` and
// `union-narrowed-helper-recursion.vl` — so the visitor is now factored naturally:
// per-kind helpers (`checkCallNode`, `checkFuncDeclNode`, `checkProgramNode`) take
// the NARROWED variant as a struct parameter, narrow further `Node` children
// themselves, and recurse back through `checkNode`. Remaining small arms stay
// inline in `checkNode` for readability, not out of necessity.
//
// Checker state lives in the global `T` (a `Checker` struct), like the parser's
// `P` — a style choice for call-site brevity. (The old struct-param-into-recursive-
// group miscompile is also fixed, pinned by
// `tests/cases/functions/struct-param-mutual-recursion-global.vl`.)

// The AST data layer (`compiler/ast.vl`): the global parser state `P` (whose
// `P.nodes` arena the checker walks), the int→string helper, and every `Node`
// variant type the single `checkNode` visitor `is`-narrows. The checker's own
// `Ty` type algebra stays PRIVATE to this module.
import { f32LitOverflows, f64LitOverflows } from "./emit_bignum"
import {
  ArrayLit,
  AsExpr,
  BinExpr,
  Block,
  BoolLit,
  BreakStmt,
  Call,
  CharLit,
  ContinueStmt,
  ErrExpr,
  FieldDef,
  FieldInit,
  ForIn,
  ForRange,
  FuncDecl,
  Ident,
  IfStmt,
  ImportDecl,
  Index,
  IsExpr,
  LetDecl,
  MatchExpr,
  Member,
  NullLit,
  NumLit,
  ObjLit,
  OptMember,
  Param,
  Paren,
  Program,
  RetStmt,
  StrLit,
  TypeDecl,
  TypeRef,
  Unary,
  UnionDecl,
  WhileStmt,
  mkBinary,
  mkBlock,
  mkIf,
} from "./ast"
import {
  P,
  declNameTokOf,
  hasNamedArgs,
  i32ToStr,
  nodeToks,
  orderArgsByParamNames,
  ufcsAliasOf,
} from "./ast"
import {
  ArrayLit,
  AsExpr,
  BinExpr,
  Block,
  BoolLit,
  BreakStmt,
  Call,
  CharLit,
  ContinueStmt,
  ErrExpr,
  FieldDef,
  FieldInit,
  ForIn,
  ForRange,
  FuncDecl,
  Ident,
  IfStmt,
  Index,
  IsExpr,
  LetDecl,
  Member,
  NullLit,
  NumLit,
  ObjLit,
  OptMember,
  Param,
  Paren,
  Program,
  RetStmt,
  StrLit,
  TypeDecl,
  TypeRef,
  Unary,
  UnionDecl,
  WhileStmt,
} from "./ast"
import {
  SYM_MEM_METHOD,
  redunECol,
  redunELine,
  redunName,
  redunSCol,
  redunSLine,
  redunTok,
  redunType,
  scopeResKind,
  scopeResName,
  scopeResType,
  symBindKind,
  symBindNode,
  symBindType,
  symEnabled,
  symMemCol,
  symMemEndCol,
  symMemLine,
  symMemNode,
  symMemTy,
  symOccDecl,
  symOccIsDecl,
  symOccTok,
  symVisEC,
  symVisEL,
  symVisKind,
  symVisName,
  symVisNode,
  symVisSC,
  symVisSL,
} from "./check_state"

// ── Type-arena variants ──────────────────────────────────────────────────────
// One struct per type KIND, prefixed field names so `is` discriminates the union
// (the AST's convention). A nested type is always an `i32` index into `T.tys`.

// A primitive: `primName` is one of "i32" | "i64" | "f32" | "f64" | "boolean" |
// "string" | "void" | "null" | "never".
export type TyPrim = { primName: string }
// The error/unknown type — produced on a type failure so checking continues
// without cascading (akin to TS `Never`/`Unknown`); assignable to/from anything.
type TyErr = { errKind: string }
// A structural object: parallel arrays of field names and their type-arena
// indices. (Constructed by the harness to seed object-typed bindings; the parser
// subset has no object-type literal syntax yet, so it is not built from source.)
export type TyObj = { objFieldNames: string[], objFieldTypes: i32[] }
// A function: parameter type indices and a return type index.
export type TyFunc = { fnParamTypes: i32[], fnRet: i32 }
// A union `A | B | …`: member type-arena indices.
export type TyUnion = { uMembers: i32[] }
// A nullable `T?` / `T | null`: the inner type-arena index.
export type TyNullable = { nInner: i32 }
// A growable array `T[]`: the element type-arena index (`-1` for an empty `[]`
// whose element is not yet known — assignable to any array, like a hole).
export type TyArray = { aElem: i32 }
// A string-keyed map `{[K]: V}` or a Set over it: key and value type-arena
// indices (`-1` for the holes of a bare `Map()`/`Set()`, pinned by the binding
// annotation or the first `.set`/`.add`). `mSet` is 1 for the SET flavor — a set
// is internally a boolean-valued map but exposes ONLY `.add`/`.has`/`.delete`/
// `.length`/`.values()` (the Map surface — `.set`/`.get`/`.keys` — must not leak).
export type TyMap = { mKey: i32, mVal: i32, mSet: i32 }
// A generic TYPE PARAMETER (`T` in `function id<T>(x: T): T`): opaque inside the
// generic body (assignable both ways, like the err hole); at a CALL site each
// TyVar param BINDS to its argument's type and the return substitutes through.
type TyVar = { tvName: string }
// A LITERAL type — the host's `StringLiteral`/`IntegerLiteral`/`RealLiteral`:
// a single-inhabitant type (`"a"`, `0`, `1.5`), the member unit of a literal
// union. `litKind` is "str" | "int" | "flt"; `litText` is the member's text —
// the RAW characters between the quotes for "str" (escapes unresolved; both
// the annotation and the literal expression carry the same raw lexeme, so
// membership compares consistently), the numeric lexeme for "int"/"flt".
export type TyLit = { litKind: string, litText: string }
// A NEGATION `!T` (A4) — "anything but `T`". Almost always consumed by
// `intersectTy` (`A & !B` subtracts); a residual standalone negation accepts
// any source NOT assignable to its inner type.
export type TyNeg = { negTy: i32 }

// The unified type. Declared after its members (a union alias can't forward-
// reference). Discriminated with `is`, exactly like the AST `Node`.
export type Ty = TyPrim |
  TyErr |
  TyObj |
  TyFunc |
  TyUnion |
  TyNullable |
  TyArray |
  TyMap |
  TyVar |
  TyLit |
  TyNeg

// A type diagnostic: a message plus the AST node index it was raised at. VL has
// no exceptions, so errors are accumulated on `T.diags`, not thrown.
// `tline`/`tcol` are the SOURCE position of the node's anchor token (1-based
// line, 0-based column — the lexer's convention), resolved by `tErr` through the
// `nodeToks` side table at raise time; `tline == 0` means "no position" (the
// node had no token mapping), in which case the diagnostic renders bare.
// `tcode` is the stable CATEGORY code: "" for a type-soundness rejection (the
// default), or `CODE_UNSUPPORTED_LOWERING` for a program the type system
// accepts but codegen cannot lower yet (see `tErrUnsupported`).
type TDiag = { tmsg: string, tat: i32, tline: i32, tcol: i32, tcode: string }

// The stable category code for EMITTER-CAPABILITY rejections: the construct is
// type-valid, but codegen cannot lower it yet. Machine-distinguishable from a
// type-soundness verdict (the LSP/tooling read it via `diagCodeLen`/
// `diagCodeByte`), yet still an error — a program that cannot build must not
// pass `vl check`.
const CODE_UNSUPPORTED_LOWERING = "unsupported-lowering"

// ── Checker state (one struct, held in the global `T`) ───────────────────────
// `tys`     — the type arena (every type is an index into it).
// `scopes`  — the scope chain: an array of `name → type-index` maps. Index 0 is
//             the global scope; entering a block/function pushes a fresh map,
//             leaving pops it. Shadowing is innermost-wins lookup.
// `diags`   — accumulated diagnostics.
// `curRet`  — the type-arena index of the enclosing function's return type while
//             checking its body (`-1` outside any function), so `return e` can be
//             checked against it.
export type Checker = {
  tys: Ty[],
  scopes: {[string]: i32}[],
  diags: TDiag[],
  curRet: i32,
}

// The single checker instance. The harness calls `initChecker()` then the entry
// point `checkProgram(root)` and reads `T.diags`.
export let T: Checker = { tys: [], scopes: [], diags: [], curRet: -1 }

let symDeclScope: {[string]: i32}[] = []

// The OPEN-scope span stack, pushed/popped in lockstep with `symDeclScope`: the
// top is the span of the scope a `symDecl` binds into. A narrowing-only scope (no
// owner node) pushes a full-file sentinel — it never holds a binding. `SCOPE_EOF`
// is a line past any real source line, so the global scope (and any sentinel)
// contains every in-file position while staying the LOOSEST (so an inner scope
// always shadows it).
const SCOPE_EOF = 1000000000
let scopeSL: i32[] = []
let scopeSC: i32[] = []
let scopeEL: i32[] = []
let scopeEC: i32[] = []

// `cUserTypes` — declared struct/union types: a `name → type-arena index` map built
// in a pre-pass over the program's `type` declarations (so a struct name in a
// param/return/let annotation, or in a later struct's field, resolves). A MODULE
// GLOBAL rather than a `Checker` field: the emitter handles a bare-map global but not
// a bare-map struct field, and there is exactly one checker instance, so this is
// equivalent (and keeps the full compiler self-emittable). Reset by `initChecker`.
export let cUserTypes: {[string]: i32} = Map()

// ── Arena-mutation generations (the emit-side repOf memo invalidation) ───────
// `tyMutEpoch` advances on EVERY in-place mutation of an EXISTING `T.tys` entry
// — empty-collection pinning (`aElem`/`mKey`/`mVal`/`nInner`), return-inference
// patching (`fnRet`), hole-shape field recording — i.e. any event that can
// change a type's canonical structural key (`repCanonKey`, emit_rep.vl). Its
// memos there are stamped with this epoch; a stale stamp discards the memo, so
// a bump is always SAFE (worst case a recompute) while a MISSED bump is a
// soundness bug (a stale key could merge/split struct slots wrongly). Minting a
// NEW arena index needs no bump: no existing type's key walk can reach it.
// `cUserTypesVer` advances on every `cUserTypes` WRITE (decl registration,
// `resolveAnnot` memoization) — any event that can change which declared arena
// index a struct-slot NAME resolves to (the `repSlotOfTy` scan input). Both
// also advance in `initChecker`: the arena is re-minted per program, so no memo
// stamped under an earlier program may survive on a shared instance.
export let tyMutEpoch = 0
export let cUserTypesVer = 0

// GENERIC TYPE ALIASES (A10 stage 3, host `instantiateAlias`): a parameterized
// `type Box<T> = { value: T }` registers here (NOT in `cUserTypes` — it has no
// concrete type until applied). Three parallel arrays: the base name ("Box"),
// the comma-joined parameter names ("T" / "A,B"), and the `TypeDecl` node index
// whose fields are re-resolved per APPLICATION (`Box<i32>`) under a type-param
// binding environment. Applications memoize into `cUserTypes` under their full
// synthetic name ("Box<i32>"), which also closes recursive applications.
let gaNames: string[] = []
let gaParamLists: string[] = []
let gaDeclIxs: i32[] = []

// The TYPE-PARAM BINDING ENVIRONMENT consulted by `nameToTy` (innermost LAST):
// a generic function's `<T>` names bind to their TyVars while its annotations
// resolve (`resolveAnnot`), and an alias application's params bind to the
// argument types while the alias body resolves (`applyGenAlias`).
let tpEnvNames: string[] = []
let tpEnvTys: i32[] = []

// DEMANDED HOLE SHAPES (host: `getChildType` pins an `Infer<Unknown>` to a
// GROWING `{…}` object): a member access on an inference-hole param
// (`self.x` where `self` is the hole `?add.0`) records field `x` on the
// hole's demanded shape — a TyObj that grows one DERIVED hole
// (`?fld.x.?add.0`) per accessed field. Each call site then checks its
// argument against the demanded shape (so `getx(5)` rejects when the body
// read `o.x`), and `substTyDeep` resolves the derived holes against the
// call's bindings (`?fld.x.?getx.0` → field `x` of the pinned argument).
let holeShapeNames: string[] = []
let holeShapeTys: i32[] = []
// Hole NAMES that were INDEXED (`self[i]`) — so the hole demands an array. The call site
// rejects a non-indexable scalar argument bound to such a param (`head(5)` where the body
// read `self[0]`), the indexing analogue of the demanded-shape check above.
let holeArrayDemand: string[] = []

// DEFERRED binary-op constraints over un-annotated-param holes. When `a + b` / `s + "!"` / `n < 2`
// has a HOLE operand, its validity can't be decided in the body (a hole is permissively assignable
// to string AND numeric, so the eager check greedily picks a branch). Record `(lt, op, rt)`; the
// generic call-site re-validates each under the SUBSTITUTED argument types via `binOpDefinedFor` —
// one rule for the whole capability: numeric (`n + 1` rejects a string), string (`s + "!"` rejects
// a number), and RELATIONAL (`a + b` rejects `(i32, string)`) all fall out of one check. Operand
// TYPE indices are stored (a hole is a `TyVar` index, stable in the arena); `substTyDeep` maps them
// to the concrete argument types at the call.
let binCstrLt: i32[] = []
let binCstrOp: string[] = []
let binCstrRt: i32[] = []

// DEFERRED call-argument constraints over un-annotated-param holes: inside a generic
// body a HOLE flowed as an argument into a CONCRETE parameter (`function f(x) { g(x) }`
// with `g(n: i32)`). The body can't judge it — a hole is permissively assignable both
// ways — so the demand is recorded (hole type, expected param type, callee name) and the
// generic CALL SITE re-validates it under the substituted argument types, exactly like
// the binary-op constraints above. Indices are arena type indices; `substTyDeep` maps
// the hole to the call's concrete argument type.
let argCstrAt: i32[] = []
let argCstrExp: i32[] = []
let argCstrWho: string[] = []

// The const-binding chain, PARALLEL to `T.scopes`: each frame records which of
// its names were bound `const` (immutable NAME, not immutable data — a field
// write through a const stays legal). Kept module-level (not a `Checker` field)
// so the exported struct shape is unchanged.
let constScopes: {[string]: boolean}[] = []

// UN-INFERRED EMPTY-COLLECTION FLOOR (mirrors the host's `reportUninferredBinding`
// in `compiler/typecheck.ts`): an un-annotated empty `[]` / `Map()` / `Set()` whose
// element/key/value hole is never pinned — by an annotation or a downstream
// `.push`/`.set`/`.add` — has a genuinely unknown type. We can't decide that at the
// declaration (a later use may still pin it), so each such binding is RECORDED here
// (its name, its type-arena index, the decl node) and re-examined at scope close /
// program end: if the hole is STILL open (`aElem < 0`, or `mKey`/`mVal < 0`), it
// "cannot be inferred" and an annotation is required. Three parallel arrays + a
// per-record scope-depth, flushed by `flushUninferred(depth)` (avoids a nested
// `Pending[][]`). An ANNOTATED empty collection never lands here (the binding takes
// the annotation's element type), so the compiler's own annotated `let x: T[] = []`
// / `Map()` / `Set()` bindings are untouched.
let pendNames: string[] = []
let pendTys: i32[] = []
let pendAts: i32[] = []
let pendDepths: i32[] = []

// FLOW-NARROWED PROPERTY PATHS (mirrors the host's `narrowedPaths` overlay):
// a stack of `key → type-arena index` entries (`"o.v" → i32`) overlaid while a
// branch body is checked, plus per-scope frame marks so `popScope` unwinds the
// entries pushed inside that scope. Bare-NAME narrowings keep riding the scope
// chain (a shadowing `declare`); only dotted paths land here.
let npKeys: string[] = []
let npTys: i32[] = []
let npFrames: i32[] = []

// CYCLE GUARD stacks for `assignable` over recursive named types (A11): a
// (src, dst) pair already being compared higher in the recursion is assumed
// assignable — coinductive, mirroring the host's lazy alias-leaf leniency for
// self-referential types (`left: Tree | null` terminates, not expands).
let asgSrcStack: i32[] = []
let asgDstStack: i32[] = []

// CYCLE GUARD stacks for the generic call-site binding walk (`bindGenWalk`)
// and the deep substitution (`substTyDeep`) — a recursive named type is cyclic
// in the arena, so both walks remember what they are already visiting.
let bgSrcStack: i32[] = []
let bgDstStack: i32[] = []
let stSeenStack: i32[] = []

// DEPTH GUARD for `tyToStr` on recursive named types (A11): a cyclic arena
// shape would otherwise render forever — past a fixed depth it prints `…`.
let tyToStrDepth = 0

// Places already union-SUBTRACTED by a post-guard fall-through in the current
// scope (one subtraction per place per block — see the guard-clause comment in
// the IfStmt arm), with per-scope frame marks like the path overlay's.
let pgKeys: string[] = []
let pgFrames: i32[] = []

// INFERRED TYPE-GUARD functions (A6b, host `guards`): a named function whose
// body is exactly `return <null-test-on-a-param>` becomes a guard — calling it
// in a condition narrows the argument's null-ness. Parallel arrays: the guard's
// name, the tested param's index, and 1 when the non-null branch is THEN
// (`self != null`) / 0 when it is ELSE (`p == null`).
let guardNames: string[] = []
let guardParamIdxs: i32[] = []
let guardThens: i32[] = []

// Record an un-annotated empty-collection binding for the deferred scope-close check.
function notePending(name: string, ty: i32, at: i32) {
  pendNames.push(name)
  pendTys.push(ty)
  pendAts.push(at)
  pendDepths.push(T.scopes.length - 1)
  0
}

// Does type-arena index `ty` still reach an UNRESOLVED collection hole — an empty
// `[]` element (`aElem < 0`) or a bare `Map()`/`Set()` key/value (`mKey`/`mVal < 0`)
// that no annotation or downstream use ever pinned? Mirrors the host's
// `containsUnresolvedHole`, but over the arena's `-1` hole sentinel.
function unresolvedHole(ty: i32) {
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyArray { return t.aElem < 0 }
  if t is TyMap { return t.mKey < 0 || t.mVal < 0 }
  false
}

// USAGE-DRIVEN INFERENCE through a TYPED context: when an empty `[]` / bare
// `Map()`/`Set()` (open holes) flows into a slot with a concrete shape — a `T[]`
// param at a call site, an annotated assignment (`const ys: i32[] = zs`), or a
// `T[]`-returning tail — PIN the source's open holes to the destination's, in place,
// so the binding is no longer uninferable. Mirrors the host's `constrainElementHole`.
// A no-op unless the source is an array/map with an open hole and the destination
// supplies the matching shape; recurses into element types so a nested empty pins too.
function constrainEmpty(srcTy: i32, dstTy: i32) {
  if srcTy < 0 || dstTy < 0 { return 0 }
  const s = T.tys[srcTy]
  const d = T.tys[dstTy]
  if s is TyArray {
    if d is TyArray {
      if s.aElem < 0 {
        s.aElem = d.aElem
        tyMutEpoch = tyMutEpoch + 1 // in-place element pin — canonical keys change
      } else {
        constrainEmpty(s.aElem, d.aElem)
      }
    }
    return 0
  }
  if s is TyMap {
    if d is TyMap {
      if s.mKey < 0 {
        s.mKey = d.mKey
        tyMutEpoch = tyMutEpoch + 1 // in-place key pin
      }
      if s.mVal < 0 {
        s.mVal = d.mVal
        tyMutEpoch = tyMutEpoch + 1 // in-place value pin
      }
    }
    return 0
  }
  0
}

// Flush every pending binding recorded at scope `depth` (called just before the
// scope is popped, and for the global scope at program end). A binding whose hole is
// still open at this point will never be pinned, so report the unified
// "cannot infer a type" diagnostic — the same wording the host raises.
function flushUninferred(depth: i32) {
  const keepN: string[] = []
  const keepT: i32[] = []
  const keepA: i32[] = []
  const keepD: i32[] = []
  let i = 0
  while i < pendNames.length {
    if pendDepths[i] == depth {
      if unresolvedHole(pendTys[i]) {
        tErr(
          "cannot infer a type for '" + pendNames[i] + "' — add a type annotation",
          pendAts[i],
        )
      }
    } else {
      keepN.push(pendNames[i])
      keepT.push(pendTys[i])
      keepA.push(pendAts[i])
      keepD.push(pendDepths[i])
    }
    i = i + 1
  }
  pendNames = keepN
  pendTys = keepT
  pendAts = keepA
  pendDepths = keepD
  0
}

// ── definite-assignment flow (A-definite-assign) ─────────────────────────────
// Mirrors `compiler/typecheck.ts`'s host analysis (which lives in `parser.ts`):
// an uninitialized `let x: T` (no initializer) starts UNASSIGNED and is non-null,
// so a READ before it is provably written on every preceding path is a "used
// before it is assigned" error — closing the silent-`0` soundness gap
// (`let x: i32; return x` used to compile and return a fabricated 0). The
// declaration is fine; only the read is gated.
//
// `daUnassigned` is the live set of binding NAMES still un-written on the CURRENT
// path (a plain list — the set is tiny, only uninitialized lets in scope). A
// `let x: T` with no initializer adds its name; `x = …` removes it; a read of a
// still-present name errors (and drops it, so the same hole doesn't re-fire on
// every later read). The host keys by `Binding` identity for exact shadowing; VL
// keys by name (innermost-wins like `lookup`/`isConstName`) — sound for the
// subset since the compiler's own source has NO uninitialized lets and no source
// shadows an uninitialized let. Fork/join for `if`/`else` and loops is explicit
// (snapshot/restore/join), modelled on the host. `daWriteTarget` is the node
// index of a plain-`=` LHS Ident currently being evaluated as a WRITE (not a
// read) so the `Ident` arm does not trip use-before-assign on it; a compound
// `x += …` desugars to `x = x + (…)` whose RHS reads `x` and IS checked.
const daUnassigned: string[] = []
let daWriteTarget = -1

// True if `name` is currently in the live unassigned set.
function daIsUnassigned(name: string) {
  let i = 0
  while i < daUnassigned.length {
    if daUnassigned[i] == name { return true }
    i = i + 1
  }
  false
}

// Mark `name` unassigned on the current path (a `let x: T` with no initializer).
function daAdd(name: string) {
  if !daIsUnassigned(name) { daUnassigned.push(name) }
  0
}

// Mark `name` assigned on the current path (a write or a checked read), removing
// it from the live set. Rebuilds the survivors into a temp, then refills the
// global IN PLACE (`.clear()` + push) — the global array reference is never
// reassigned (mirrors the host's `unassigned.delete`, and keeps the self-emitter
// on its supported in-place-mutation path).
function daMarkAssigned(name: string) {
  const keep: string[] = []
  let i = 0
  while i < daUnassigned.length {
    if daUnassigned[i] != name { keep.push(daUnassigned[i]) }
    i = i + 1
  }
  daClear()
  let j = 0
  while j < keep.length {
    daUnassigned.push(keep[j])
    j = j + 1
  }
  0
}

// Empty the live set IN PLACE (never reassigns the global reference).
function daClear() {
  // The self-host emitter lowers `.pop()` (and `.length`) as statements but not
  // `.clear()`, so empty the array in place by popping until empty.
  while daUnassigned.length > 0 { daUnassigned.pop() }
  0
}

// Check a READ of `name`: if still unassigned on this path, report it and drop it
// so the same hole doesn't re-fire on every later read.
function daCheckRead(name: string, at: i32) {
  if daIsUnassigned(name) {
    daMarkAssigned(name)
    tErr("`" + name + "` is used before it is assigned", at)
  }
  0
}

// Snapshot the live unassigned set (a copy), for forking and joining paths.
function daSnapshot() {
  const snap: string[] = []
  let i = 0
  while i < daUnassigned.length {
    snap.push(daUnassigned[i])
    i = i + 1
  }
  snap
}

// Restore the live set from a snapshot (in place — never reassigns the global).
function daRestore(snap: string[]) {
  daClear()
  let i = 0
  while i < snap.length {
    daUnassigned.push(snap[i])
    i = i + 1
  }
  0
}

// Join two surviving paths into the live set: a name is assigned-after-the-merge
// only if it is assigned on BOTH — equivalently it is STILL unassigned if it is
// unassigned on EITHER. So the joined live set is the UNION of the two paths'
// unassigned sets. (`a` is taken as the current live set; `b` is folded in.)
function daJoinInto(b: string[]) {
  let i = 0
  while i < b.length {
    daAdd(b[i])
    i = i + 1
  }
  0
}

// True if the statement at node `ix` ALWAYS exits its enclosing path (so its end
// is unreachable and it contributes nothing to a definite-assignment join). A
// `return`/`break`/`continue` diverges; a `Block` diverges if its last statement
// does; an `if … else …` diverges only if BOTH arms diverge (a chain recurses
// through its `ifElse`). Mirrors the host's `divergesStatement` for the subset.
function daBranchDiverges(ix: i32) {
  if ix < 0 { return false }
  const s = P.nodes[ix]
  if s is RetStmt {
    return true
  } else if s is BreakStmt {
    return true
  } else if s is ContinueStmt {
    return true
  } else if s is Block {
    const st = s.blkStmts
    if st.length > 0 { return daBranchDiverges(st[st.length - 1]) }
    return false
  } else if s is IfStmt {
    if s.ifElse < 0 { return false }
    return daBranchDiverges(s.ifThen) && daBranchDiverges(s.ifElse)
  }
  false
}

// ── missing-return totality (soundness) ──────────────────────────────────────
// The condition node under any `Paren` wrappers (`((x is T))` → `x is T`). The
// condition-SHAPE matchers (chain discrimination, exhaustiveness) peel through this
// so a parenthesized guard classifies exactly like the bare spelling — keeping them
// in agreement with the narrowing collectors, which already peel `Paren`.
function condUnderParens(ix: i32) {
  const n = P.nodes[ix]
  if n is Paren { return condUnderParens(n.parInner) }
  ix
}

// True if the `if`-condition at `ifCondIx` opens a DISCRIMINATING chain — `x is T`, or a
// `place == <literal>` over a literal-union-bearing place. Such an ELSE-LESS chain may be
// EXHAUSTIVE (cover every variant), which the dedicated exhaustiveness check adjudicates;
// the general missing-return rule defers to it rather than double-flagging. Mirrors the
// `isChain` detection in that check.
function ifCondIsDiscriminating(ifCondIx: i32) {
  const fc = P.nodes[condUnderParens(ifCondIx)]
  if fc is IsExpr { return true }
  if fc is BinExpr {
    if fc.binOp == "==" {
      let eqPlace = -1
      if litTyOfExpr(fc.binRight) >= 0 { eqPlace = fc.binLeft }
      else if litTyOfExpr(fc.binLeft) >= 0 { eqPlace = fc.binRight }
      if eqPlace >= 0 {
        const eqObj = P.nodes[eqPlace]
        if eqObj is Ident {
          if isLitBearing(lookup(eqObj.identName)) { return true }
        }
      }
    }
  }
  false
}

// True if executing the node at `ix` always produces a RETURN VALUE or DIVERGES — i.e.
// control never falls off its end without a value. Unlike `daBranchDiverges`, a bare
// trailing VALUE EXPRESSION counts (an implicit return — `!isStmtNode`), so this is the
// totality test for "a non-void function must yield a value on every path". A `Block` is
// total iff its last statement is; an `if`/`else` iff BOTH arms are (an `else if` chain
// recurses through `ifElse`); a `while true { … }` never falls through (diverges or
// returns from inside) so it is total — every other loop / if-without-else / statement
// can complete without a value and is NOT total.
function nodeIsTotal(ix: i32) {
  if ix < 0 { return false }
  const n = P.nodes[ix]
  if n is Block {
    const st = n.blkStmts
    if st.length == 0 { return false }
    return nodeIsTotal(st[st.length - 1])
  }
  if n is RetStmt { return true }
  if n is BreakStmt { return true }
  if n is ContinueStmt { return true }
  if n is IfStmt {
    if n.ifElse < 0 {
      // An ELSE-LESS `if`: a discriminating `is` / literal-equality chain may be
      // EXHAUSTIVE — defer to the dedicated exhaustiveness check (it knows the union's
      // variants). A plain else-less `if` always has a fall-through, so it is NOT total.
      if ifCondIsDiscriminating(n.ifCond) { return true }
      return false
    }
    return nodeIsTotal(n.ifThen) && nodeIsTotal(n.ifElse)
  }
  if n is WhileStmt {
    // `while true { … }` never completes normally — it diverges or returns inside.
    const c = P.nodes[n.whileCond]
    if c is BoolLit { return c.boolVal != 0 }
    return false
  }
  // A bare trailing value expression IS the implicit return.
  return !isStmtNode(ix)
}

// True if `name` resolves (innermost-first) to a `const` binding.
function isConstName(name: string) {
  let i = T.scopes.length - 1
  while i >= 0 {
    if T.scopes[i].has(name) {
      if i < constScopes.length { return constScopes[i].has(name) }
      return false
    }
    i = i - 1
  }
  false
}

// Well-known primitive type-arena indices, pinned by `initChecker` so the hot
// primitives are interned once (not re-pushed per use). `-1` until initialized.
export let TY_I32 = -1
let TY_I64 = -1
let TY_F64 = -1
let TY_F32 = -1
let TY_BOOL = -1
let TY_STR = -1
let TY_VOID = -1
let TY_ERR = -1
let TY_NULL = -1
// `never` — the EMPTY type (host `Never`): what an intersection of disjoint
// concrete types folds to. The bottom type: assignable to anything, nothing
// (but itself / err) assignable to it.
let TY_NEVER = -1

// ── type-arena constructors ──────────────────────────────────────────────────
// Each appends a variant to `T.tys` and returns its index. (The same shape as the
// AST's `mk*` constructors, for the parallel arena.)

function addTy(t: Ty) {
  T.tys.push(t)
  T.tys.length - 1
}

function mkPrim(name: string) {
  const t: Ty = { primName: name }
  addTy(t)
}

function mkErrTy() {
  const t: Ty = { errKind: "error" }
  addTy(t)
}

export function mkObjTy(names: string[], typeIxs: i32[]) {
  const t: Ty = { objFieldNames: names, objFieldTypes: typeIxs }
  addTy(t)
}

function mkFuncTy(params: i32[], ret: i32) {
  const t: Ty = { fnParamTypes: params, fnRet: ret }
  addTy(t)
}

function mkUnionTy(members: i32[]) {
  const t: Ty = { uMembers: members }
  addTy(t)
}

function mkNullableTy(inner: i32) {
  const t: Ty = { nInner: inner }
  addTy(t)
}

function mkArrayTy(elem: i32) {
  const t: Ty = { aElem: elem }
  addTy(t)
}

function mkMapTy(key: i32, val: i32, isSet: i32) {
  const t: Ty = { mKey: key, mVal: val, mSet: isSet }
  addTy(t)
}

function mkTyVar(name: string) {
  const t: Ty = { tvName: name }
  addTy(t)
}

// The CANONICAL decimal form of an integer literal LEXEME (`0x10` → `16`,
// `1_000` → `1000`, `007` → `7`), so literal-type identity compares VALUES,
// not raw source spellings — `0x10` is a member of `16 | 32`. A lexeme whose
// value exceeds the i32 range keeps its raw spelling (an i64-sized literal
// never denotes a literal-union member; identity then stays textual, exactly
// as before).
function canonIntLexeme(t: string) {
  if !intLexemeFitsI32(t) { return t }
  let v = 0
  let i = 0
  let base = 10
  if t.length >= 2 && t[0] == '0' {
    const p = t[1]
    if p == 'x' || p == 'X' {
      base = 16
      i = 2
    } else if p == 'b' || p == 'B' {
      base = 2
      i = 2
    } else if p == 'o' || p == 'O' {
      base = 8
      i = 2
    }
  }
  while i < t.length {
    const c = t[i]
    if c != '_' {
      let d = 0
      if c >= '0' && c <= '9' { d = c - '0' }
      else if c >= 'a' && c <= 'f' { d = c - 'a' + 10 }
      else { d = c - 'A' + 10 }
      v = v * base + d
    }
    i = i + 1
  }
  i32ToStr(v)
}

function mkLitTy(kind: string, text: string) {
  let canon = text
  if kind == "int" { canon = canonIntLexeme(text) }
  const t: Ty = { litKind: kind, litText: canon }
  addTy(t)
}

function mkNegTy(inner: i32) {
  const t: Ty = { negTy: inner }
  addTy(t)
}

// ── return-type inference state (module globals, reset by initChecker) ────────
// An un-annotated function's hoisted return type is the PENDING sentinel `-2`
// until its body is checked. `fnDeclIx` maps a top-level function name to its
// FuncDecl arena index so a forward call can infer the callee ON DEMAND;
// `inferStack` is the in-progress set (cycle detection); `inferObserved` /
// `inferSawErr` accumulate what a pending body's `return`s / trailing expression
// yielded (first concrete type wins; an in-cycle call contributes only "err").
let fnDeclIx: {[string]: i32} = Map()
let inferStack: string[] = []
let inferObserved = -1
let inferSawErr = false
// The VALUE type of the most recently checked Block — its trailing expression's type
// (the block's implicit-return value), or TY_VOID when the block ends in a statement.
// `checkNode(Block)` itself returns TY_VOID (a block is a statement); this carries the
// tail value out-of-band so an `if … { v } else { w }` EXPRESSION can join its branch
// values. Read immediately after a `checkNode(block)`.
let blockTailTy = -1
// True while checking a node whose VALUE is the enclosing function's return (an
// implicit-return tail position): the function-body tail statement, and — propagated —
// the tail of each branch of a tail `if`/`else`. Gates seeding `inferObserved` from a
// branch value so a base-case branch pins the type before a recursive sibling branch is
// checked (`if n<2 { n } else { rec(n-1)+rec(n-2) }`), WITHOUT a non-tail `if`'s branch
// values polluting the inferred return.
let retTailPos = false

// Every top-level (module-scope) `let`/`const` NAME, hoisted in pass 1.5 so a
// function body — checked in pass 2 OR pulled early by demand-inference — resolves
// it regardless of source order, exactly as it already resolves a top-level
// function. Membership also drives the pass-2 redeclare-error skip (the hoist owns
// the canonical declaration). Reset per compile in initChecker.
let moduleGlobals: {[string]: boolean} = Map()

// Recursive return-type inference (binding-group fixpoint). A function whose return
// only becomes knowable AFTER a recursive cycle resolves can't be inferred in one
// demand pass — the cycle-break commits a provisional `void`. So a SUPPRESSED
// return-inference PRE-PASS resolves every un-annotated return BEFORE the real check
// pass, iterating the cycle-poisoned ("tentative") functions to a fixpoint. This is
// standard SCC binding-group inference, realized lazily through the existing demand
// inference (the demand call stack IS the dependency-order traversal). `bodyChecked`
// lets the real pass still check each body once (the pre-pass only resolved types).
let topUnannotFns: i32[] = []
// The top-level statement list, captured at `checkProgram` entry so the return-inference
// floor can reverse-map an inferred struct-union's object members to named types
// (`structUnionRetName`) — the floor must accept EXACTLY the unions the emitter can
// lower (all members named), so it uses the same predicate as the export.
let gRootStmts: i32[] = []
// A20: parallel arrays (name -> inferred concrete return-type name) for each
// un-annotated top-level function, exported for the emitter so it can classify a
// return from the inferred TYPE rather than re-deriving from the return expression
// (which misses a plain-variable return). Kept OUT of the AST `fnRet` so `fmt` never
// re-adds the annotation. A string-VALUED map would do, but a `{[string]: string}`
// with `?? ""` mis-lowers (nullable-ref vs ref), so the TYPE stays in arrays. Reset per compile.
let inferRetFn: string[] = []
let inferRetTy: string[] = []
// Name → its FIRST index in the arrays, so the hot `inferRetNameOf` is an O(1) map lookup
// instead of a linear scan (it was ~6% of self-compile time). An i32-VALUED map (the well-
// supported `{[string]: i32}` path — the string-valued map above mis-lowers), kept in sync via
// `recordInferRet`. FIRST-wins, matching the old scan. The arrays stay for the emitter's INDEXED
// access (`inferRetCount`/`inferRetTyAt`) and to hold the string type the map can't.
let inferRetIdx: {[string]: i32} = Map()
// The binding analogue of `inferRetFn`/`inferRetTy`: an un-annotated `const`/`let`
// whose INFERRED type is a value union is recorded by its LetDecl NODE INDEX, so the
// emitter classifies + lowers it like an annotated nullable/value-union binding even
// when the initializer is one it can't statically classify (an `if`-expression with an
// ident/expression arm). Captured DURING the check (scope live), keyed by node index.
let inferLetIx: i32[] = []
let inferLetTy: string[] = []
// The NICHE analogue of `inferLetIx`: an un-annotated `const x = if c then "hi" else
// null` infers `string | null`, which is a niche ref rep (`ref.null $aTypeIdx`), NOT a
// value-union box — so `valueUnionRetName` renders "" and the `inferLetIx` table skips
// it. Record such bindings by LetDecl NODE INDEX so the emitter's `letIsNulString`
// classifies the slot as the kind-16 nullable-string rep and reuses the annotated
// `string | null` if-binding lowering. No name is needed (the niche is monomorphic).
let inferLetNulStrIx: i32[] = []
// The `boolean | null` companion of `inferLetNulStrIx` — the other niche scalar
// nullable (an i32 0/1 with sentinel 2 = null). Same recording discipline: an
// un-annotated `const x = if c then true else null` by LetDecl NODE INDEX, so the
// emitter classifies the slot as the niche i32 rep and reuses the annotated lowering.
let inferLetNulBoolIx: i32[] = []
let bodyChecked: {[string]: boolean} = Map()
// TYPED-IR FOUNDATION: node index → resolved type-arena index, recorded for EVERY node on
// the real (non-quiet) check pass so the EMITTER can consume the checker's already-computed
// type instead of re-deriving it syntactically from the AST (the per-kind `letIs*`/`expr*`
// predicate ladders). A flat table sized to the node arena at `checkProgram`. Nodes the
// emitter SYNTHESIZES after checking (monomorphized instance bodies) fall past the end and
// read back -1 via `nodeTyIxOf`, so a consumer falls back to its syntactic path there.
let nodeTyIx: i32[] = []
// NOMINAL-IDENTITY sidecar (C1): the `Ty`-arena indices of DECLARED STRUCT types (`cStructTyIxs`)
// and of UNION-VARIANT MEMBER types (`cVariantMemberTyIxs`). A struct annotation's node reads
// `nodeTyIsStruct` = "its recorded type IS a declared struct and NOT a variant member" — the emitter's
// nominal classifier then confirms structurally instead of an O(nodes) `nameIsStructDecl` AST scan.
// The arena stays purely STRUCTURAL (`TyObj` has no name); nominal-ness is checker metadata, not a Ty.
let cStructTyIxs: i32[] = []
let cVariantMemberTyIxs: i32[] = []
// Declared UNION-ALIAS `Ty` indices (`type T = A | B`), for the emitter's `isUName` (C1).
let cUnionTyIxs: i32[] = []
// The declared NAME of each `cUnionTyIxs` entry (parallel array), so a union type index can
// resolve back to its alias name — used to pin an anonymous lambda's litunion return as the
// ALIAS (an inline litunion spelling reps as a string ref, so the alias name is required).
let cUnionNames: string[] = []
// Litunion alias PROVENANCE (rep-rewrite Stage B, b1). The narrowing/join/
// intersection algebra re-mints a declared litunion alias as a fresh arena
// COPY (`K | null` inferred through `joinTys`, `!= null` through `subtractTy`,
// `K & !"a"` through `isectDistribute`): a `TyUnion` sharing the alias's
// `TyLit` members but at an index `tyIxIsUnionAliasDecl` cannot recognize —
// so "alias-ness" (the atom-vs-string rep axis) was unanswerable at those
// indices, and the rep tree's `litunion:noalias` bucket was dominated by
// them. These parallel arrays record (copy index → source alias index) at the
// mint sites; `tyLitUnionAliasIx` reads them back. Only a copy whose member
// set is CONTAINED in the alias's (narrowing only ever subtracts) records —
// a join that ADDS a foreign literal is not that alias. A genuinely-inline
// litunion (`: "a" | "b"` spelled with no alias source) records nothing.
let cLitUnionCopyTyIxs: i32[] = []
let cLitUnionCopyAliasIxs: i32[] = []
// A single placeholder `TyFunc` arena index for monomorphizer `=>sigkey` closure pins (C1 endgame).
let cFuncPinTyIx = -1
// A single placeholder `TyObj` arena index for interned anonymous-shape `#anonN` names (C1 endgame).
let cObjPinTyIx = -1
let inferQuiet = false
let cycleBreakCount = 0
let inferTentative: string[] = []
let unresolvedFns: string[] = []
let fnSawValueRet = false

// Redundant RETURN-type annotation rule: `retNatural` is the body's NATURAL inferred
// return (first non-void/non-error, mirroring noteInferredRet) accumulated for an
// ANNOTATED function, so the rule can compare it to the explicit `: T`. A match means
// removing the annotation yields the identical inferred return. Saved/reset/restored
// per function in checkFuncDeclNode.
let retNatural = -1
let retNaturalErr = false

// CONTEXTUAL (bidirectional) inference for un-annotated function-literal params. When an
// expression is checked in a position with a known EXPECTED type, a lambda `(x) => …` sitting
// there infers its params from the expected function type — even when nested inside a composite
// (an `((i32) => i32)[]` array, a `{ f: (i32) => i32 }` object). `seedExpected` walks the
// expected type and the expression in lockstep and records, PER LAMBDA NODE, its expected param
// types; the lambda's `checkFuncDeclNode` then reads them by node index. Node-keyed rather than
// a single-shot global, so the MANY lambdas of one composite each get their own seed and a seed
// never leaks into an unrelated body. Every contextual position routes through `seedExpected`
// (a HOF call arg, a `.map`/`.filter` receiver, an annotated `let`/return/field/element) — one
// mechanism, all positions.
let cbExpNode: i32[] = [] // lambda node index
let cbExpOff: i32[] = []  // offset of its param-type run in `cbExpPool`
let cbExpLen: i32[] = []  // run length (param count)
let cbExpPool: i32[] = [] // flattened expected param-type arena indices

// The contextual expected RETURN type per lambda node — the return-side dual of the
// param seeding above. A lambda whose body infers a NARROWER numeric than the expected
// return (`const v: () => i64 = () => (5)`) ADOPTS the expected return, so the widening
// happens INSIDE the body at the return seam (where codegen inserts the convert) instead
// of riding function-type variance, which has no adapter (see `fnSlotAssignable`).
let cbExpRetNode: i32[] = []
let cbExpRetTy: i32[] = []

// Record `retTy` as the expected return type of the lambda at `nodeIx` (latest wins).
function recordCbExpectedRet(nodeIx: i32, retTy: i32) {
  cbExpRetNode.push(nodeIx)
  cbExpRetTy.push(retTy)
  0
}

// The expected return type recorded for the lambda at `nodeIx` — the LAST recorded one
// (the real pass overrides the pre-inference pass), or -1 when none.
function cbExpectedRetFor(nodeIx: i32) {
  let found = -1
  let i = 0
  while i < cbExpRetNode.length {
    if cbExpRetNode[i] == nodeIx { found = cbExpRetTy[i] }
    i = i + 1
  }
  found
}

// Lambda nodes that are the init of an UN-annotated `const`/`let` binding (`const add = (a, b) =>
// a + b`). Such a lambda's un-annotated params are inference HOLES — monomorphized per use exactly
// like a named generic function (the emitter value-flow-monomorphizes them, env and all) — rather
// than rejected as uninferable. Any OTHER no-context anonymous lambda stays a clean rejection.
let valBindLambda: i32[] = []
function noteValBindLambda(nodeIx: i32) { valBindLambda.push(nodeIx) }
function isValBindLambda(nodeIx: i32) {
  let i = 0
  while i < valBindLambda.length {
    if valBindLambda[i] == nodeIx { return true }
    i = i + 1
  }
  false
}

// Record `paramTys` as the expected param types of the lambda at `nodeIx` (latest wins).
function recordCbExpected(nodeIx: i32, paramTys: i32[]) {
  cbExpNode.push(nodeIx)
  cbExpOff.push(cbExpPool.length)
  cbExpLen.push(paramTys.length)
  let i = 0
  while i < paramTys.length {
    cbExpPool.push(paramTys[i])
    i = i + 1
  }
  0
}

// The expected param types recorded for the lambda at `nodeIx` — the LAST recorded run (the
// real pass overrides the pre-inference pass), or `[]` when none.
function cbExpectedFor(nodeIx: i32) {
  let found = -1
  let i = 0
  while i < cbExpNode.length {
    if cbExpNode[i] == nodeIx { found = i }
    i = i + 1
  }
  const out: i32[] = []
  if found >= 0 {
    let j = 0
    while j < cbExpLen[found] {
      out.push(cbExpPool[cbExpOff[found] + j])
      j = j + 1
    }
  }
  out
}

// The body's TAIL expression of a lambda (its implicit-return value) — the last statement's
// return argument, or a bare trailing-expression statement. A lambda body is always a (possibly
// synthetic one-statement) Block. -1 when there is no tail value. Lets `seedExpected` flow an
// expected RESULT type into a lambda's body, so a CURRIED `(a) => (b) => …` reaches its inner
// lambda.
function lambdaBodyTail(bodyIx: i32) {
  if bodyIx < 0 { return -1 }
  const b = P.nodes[bodyIx]
  if b is Block {
    const stmts = b.blkStmts
    if stmts.length == 0 { return -1 }
    const last = stmts[stmts.length - 1]
    const ln = P.nodes[last]
    if ln is RetStmt { return ln.retArg }
    return last
  }
  -1
}

// FIELD-LEVEL contextual return adoption — the object dual of the scalar rule in
// `checkFuncDeclNode`: an object-literal-bodied lambda whose inferred return shape widens
// FIELD-WISE into the contextual expected return (`const v: () => {f: i64} = () => ({f: 5})`)
// ADOPTS the expected shape. Sound only when every widening field's VALUE is a small int
// literal — the literal re-encodes at the wider rep inside the body, and the expected field
// type is RECORDED on the literal node so the emitter's literal-shape interner
// (`anonFieldCode`, which otherwise codes a small literal i32) interns the wide slot.
// Anything else keeps the inferred shape, and `objNumWidens` in `fnSlotAssignable` rejects
// it loudly (a function value's field rep is fixed; only a literal body can re-encode).
// The FIELD WALK of `objRetWidenAdopt`, factored out so a NESTED object field recurses:
// `litIx` is an ObjLit whose inferred type `sTyIx` adopts the expected `dTyIx` field-wise,
// appending each re-encodable value node + its adopted field type to `recNodes`/`recTys`.
// Returns false on any proven field mismatch (the caller keeps the inferred type).
function objLitWidenFields(
  litIx: i32,
  sTyIx: i32,
  dTyIx: i32,
  recNodes: i32[],
  recTys: i32[],
): boolean {
  const lit = P.nodes[litIx]
  if !(lit is ObjLit) { return false }
  const s = T.tys[sTyIx]
  const d = T.tys[dTyIx]
  if !(s is TyObj) { return false }
  if !(d is TyObj) { return false }
  if s.objFieldNames.length != d.objFieldNames.length { return false }
  let i = 0
  while i < d.objFieldNames.length {
    const dty = d.objFieldTypes[i]
    const sty = objFieldType(s, d.objFieldNames[i])
    if sty < 0 { return false }
    // The field's VALUE expression in the literal body (shared by the numeric-widen
    // and the float-literal→f32 arms below).
    let fv = -1
    const fl = lit.objFields
    let fi = 0
    while fi < fl.length {
      const fn = P.nodes[fl[fi]]
      if fn is FieldInit {
        if fn.fiName == d.objFieldNames[i] { fv = fn.fiValue }
      }
      fi = fi + 1
    }
    if numWidens(sty, dty) {
      // The widening field's value must be a small int literal in the literal body.
      if fv < 0 { return false }
      const fvn = P.nodes[fv]
      if fvn is NumLit {
        if hasDot(fvn.numText) { return false }
        if !intLexemeFitsI32(fvn.numText) { return false }
        recNodes.push(fv)
        recTys.push(dty)
      } else {
        return false
      }
    } else if primNameOf(dty) == "f32" && isFloatLitExpr(fv) {
      // FLOAT-LITERAL → f32 field (`() => ({a: 3.5, …})` against `{a: f32, …}`): the field
      // infers f64 but the literal re-encodes exactly at f32 (the field dual of the scalar
      // arm above). Record f32 on the value node so `anonFieldCode` interns the f32 field
      // slot (it would else code the float literal's default f64).
      recNodes.push(fv)
      recTys.push(dty)
    } else if assignable(sty, dty) && !assignable(dty, sty) {
      // The field WIDENS by BOXING — a bare scalar/struct arm into a UNION or NULLABLE
      // field (`{f: false}` against `{f: boolean | {w: i32}}`, `{f: 99}` against
      // `{f: i64 | string}`). Adopt when the literal value re-encodes at the wider field
      // type (`assignableExpr`, field-wise) — the object dual of the value-union return
      // arm. Record the field type so the emitter boxes the field slot and coerces the
      // ObjLit value into the box, exactly as the annotated `: {f: boolean | {w: i32}}`
      // named-function return already lowers. `synthRetAnnots` pins the lambda's `fnRet`
      // to the whole struct shape (`nameIsStructWithUnionField`), so its `$fnsig` result
      // is the union-field struct — without which the value call mis-recovered the plain
      // struct (MISMATCH / INVALID-WASM at the boxed field read).
      // A NESTED object field whose INNER field widens (`{f: {f: 16743}}` against
      // `{f: {f: i32 | string}}`): the value is itself an ObjLit — RECURSE so the inner
      // literal adopts the union-field shape and records ITS node type; without the
      // descent the lambda body built the self-inferred `{f: i32}` layout while the sig
      // keyed the union-field struct (INVALID-WASM at the return; fuzz-nightly run
      // 29808029476, seed 78530533 d5 `(i32) => {f: {f: i32 | string}}`).
      if fv < 0 { return false }
      let fvIn = fv
      let fvDone = false
      while !fvDone {
        const fvp = P.nodes[fvIn]
        if fvp is Paren { fvIn = fvp.parInner } else { fvDone = true }
      }
      const fvNode = P.nodes[fvIn]
      // The recursion targets a NESTED-STRUCT dest only: an ObjLit value against a UNION
      // field (`{f: {f: h0}}` against `{f: {f:{[string]:string}} | boolean}` — the literal
      // is a MEMBER of the union, an ARM, not a field-wise widening target) descends into
      // `!(d is TyObj)` and refuted the WHOLE adoption — so nothing recorded, no
      // `synthRetAnnots` pin, and the emitter's self-derivation keyed the outer literal
      // onto the same-field-name-set MAP-field twin (INVALID-WASM at the `struct.new`;
      // fuzz frontier seed 658239060 d5). Route a non-TyObj dest through the plain
      // member-flow check below, recording the union field type so the emitter boxes.
      let dtyIsObj = false
      const dtyT = T.tys[dty]
      if dtyT is TyObj { dtyIsObj = true }
      if fvNode is ObjLit && dtyIsObj {
        if !objLitWidenFields(fvIn, sty, dty, recNodes, recTys) { return false }
        recNodes.push(fvIn)
        recTys.push(dty)
      } else {
        if !assignableExpr(fv, sty, dty) { return false }
        recNodes.push(fv)
        recTys.push(dty)
      }
    } else if tyIsLitUnion(dty) {
      // LITUNION field (`f: "8"` against `f: K0 = "xz" | "8"`): the body value is a bare
      // string literal that is a MEMBER of the expected literal-union. It infers the
      // softened `string`, but re-encodes as the litunion's i32 ATOM — the field dual of
      // the scalar litunion-return arm (`(i32) => K = (x) => "b"`). Adopt when the value is
      // a member literal; record the litunion field type so `anonFieldCode` interns the
      // atom slot (it would else code the string). The named-function VALUE spelling of the
      // same struct-with-litunion-field return already lowers to this rep.
      if fv < 0 { return false }
      if !assignableExpr(fv, sty, dty) { return false }
      recNodes.push(fv)
      recTys.push(dty)
    } else {
      // A non-widening field must match exactly (mutual assignability) — a shape
      // difference beyond numeric widening is not an adoption, it is a mismatch.
      if !assignable(sty, dty) { return false }
      if !assignable(dty, sty) { return false }
    }
    i = i + 1
  }
  true
}

function objRetWidenAdopt(bodyIx: i32, inferredTy: i32, expRetTy: i32) {
  if inferredTy < 0 || expRetTy < 0 { return false }
  let u = lambdaBodyTail(bodyIx)
  if u < 0 { return false }
  let done = false
  while !done {
    const pn = P.nodes[u]
    if pn is Paren { u = pn.parInner } else { done = true }
  }
  const lit = P.nodes[u]
  if !(lit is ObjLit) { return false }
  const s = T.tys[inferredTy]
  // A NULLABLE expected result (`() => {f: K0} | null` — spelled directly, or through the
  // nullable-closure wrapper `(() => {f: K0} | null) | null`): adopt against the INNER
  // struct. The caller still adopts the FULL nullable expected, so the lambda's `$fnsig`
  // result keys the nullable struct exactly as the annotation-side consumer does. Without
  // the unwrap a litunion field never adopted and the two sides keyed DIFFERENT structs
  // (`{f: string}` vs `{f: K0}` — a cast-failure TRAP at the narrowed nullable-closure
  // call; fuzz frontier seed 679748579 d5 --branching --multiobs).
  let expInnerTy = expRetTy
  const dn = T.tys[expRetTy]
  if dn is TyNullable { expInnerTy = dn.nInner }
  const d = T.tys[expInnerTy]
  if s is TyObj {
    if d is TyObj {
      const recNodes: i32[] = []
      const recTys: i32[] = []
      if !objLitWidenFields(u, inferredTy, expInnerTy, recNodes, recTys) {
        return false
      }
      if recNodes.length == 0 { return false }
      if !inferQuiet {
        let r = 0
        while r < recNodes.length {
          const rn = recNodes[r]
          while nodeTyIx.length <= rn { nodeTyIx.push(-1) }
          nodeTyIx[rn] = recTys[r]
          r = r + 1
        }
      }
      return true
    }
  }
  false
}

// Propagate an EXPECTED type into an expression, recording per-lambda param expectations. A
// lambda at a function-typed position is seeded directly — its params from the expected param
// types AND its body recursively against the expected RESULT type (so a CURRIED `(a) => (b) => …`
// types its inner lambda from a nested function type). A composite LITERAL (array / object)
// recurses into its elements / fields. So a lambda nested anywhere in the expected shape — under
// arrows, arrays, or object fields, at any depth — is reached by ONE recursive mechanism. Any
// other shape is a no-op.
// The union member index of `u`'s FUNCTION arm whose parameter arity is `arity` (`(() => i64) |
// {w:i32}` with a 0-arg lambda → the `() => i64` member), or -1 when no function arm matches. Lets
// `seedExpected` adopt a bare LAMBDA into a union's closure arm (the emit already boxes a closure
// arm — this is the checker seam that widens `f: () => 5` to the `() => i64` member). The FIRST
// matching arm wins (a union with two same-arity func arms is not a supported shape).
function unionFuncArmForArity(u: TyUnion, arity: i32) {
  const members = u.uMembers
  let i = 0
  while i < members.length {
    const m = members[i]
    const mt = T.tys[m]
    if mt is TyFunc {
      if mt.fnParamTypes.length == arity { return m }
    }
    i = i + 1
  }
  -1
}
// True if the union OBJECT arm `tyIx` can be BOTH boxed into the union's `{tag, value}` rep AND
// have its narrowed fields read back with valid wasm — the safety gate for seeding a struct literal
// into this arm. A field that is a scalar / string (`TyPrim`), a nested struct (`TyObj`, recursively
// safe), or a closure (`TyFunc`) has a sound variant-struct rep: construction boxes it, and a
// narrowed read of it either lowers (`v.a`, `v.f.g`) or FAILS LOUD (`v.f(1)` on a closure field is a
// clean "callee is not a function name" reject) — never invalid wasm. A field that is an ARRAY,
// a union, or a nullable has NO sound narrowed-read rep yet (`v.f[0](1)` over a reflist-of-closures
// field emits a type-mismatched read — INVALID WASM), so an arm carrying one is NOT seed-safe:
// leaving it unseeded keeps the un-annotated field lambda a clean "cannot infer" reject instead of
// letting the checker accept a shape the emitter mis-lowers. (A stricter sibling of `unionArmBoxSafe`,
// which the widening-adoption path uses — that one also excludes closures; this one admits them
// because a closure FIELD boxes + reads soundly, only its narrowed CALL is a loud gap.)
function unionArmSeedSafe(tyIx: i32) {
  const t = T.tys[tyIx]
  if !(t is TyObj) { return false }
  const ftys = t.objFieldTypes
  let i = 0
  while i < ftys.length {
    const ft = T.tys[ftys[i]]
    if ft is TyPrim {
      // scalar / string / boolean field — boxes + reads cleanly
    } else if ft is TyFunc {
      // a closure field — boxes into the variant struct; a narrowed call is a loud reject
    } else if ft is TyObj {
      if !unionArmSeedSafe(ftys[i]) { return false }
    } else if ft is TyArray {
      // a CLOSURE-ARRAY field (`f: ((i32) => K0)[]`) — the reflist field boxes into the
      // variant struct and a narrowed indexed call reads back the closure element; the
      // seed is what lets the element lambdas infer their params/result from the arm.
      // Every other element rep keeps the un-seeded clean reject.
      if ft.aElem < 0 { return false }
      const aet = T.tys[ft.aElem]
      if !(aet is TyFunc) { return false }
    } else {
      return false // other array / union / nullable field — no sound narrowed-read rep yet
    }
    i = i + 1
  }
  true
}
// The union member index of `u`'s OBJECT arm whose shape covers the object literal `objIx` (every
// literal field name is a field of the arm) AND whose fields are seed-safe (`unionArmSeedSafe`), or
// -1. The object dual of `unionFuncArmForArity`: lets `seedExpected` descend a struct LITERAL flowing
// into a union (`{f: (i32) => i32, …} | boolean`) into its matching struct arm, so a bare field lambda
// (`f: (q) => …`) infers its params from that arm's field types instead of failing "cannot infer a
// type for parameter". Seeding only supplies the contextual param types — the whole literal is still
// gated by the normal assignability check against the union, so a mis-matched arm cannot be silently
// accepted; the seed-safety gate additionally keeps a shape the emitter cannot yet lower (an array /
// union / nullable field) a clean reject rather than an INVALID-WASM acceptance. FIRST match wins.
function unionObjArmForLit(u: TyUnion, objIx: i32) {
  const on = P.nodes[objIx]
  if on is ObjLit {
    const members = u.uMembers
    let i = 0
    while i < members.length {
      const m = members[i]
      const mt = T.tys[m]
      if mt is TyObj && unionArmSeedSafe(m) {
        let ok = true
        let j = 0
        while j < on.objFields.length {
          const fnode = P.nodes[on.objFields[j]]
          if fnode is FieldInit {
            if objFieldType(mt, fnode.fiName) < 0 { ok = false }
          }
          j = j + 1
        }
        if ok { return m }
      }
      i = i + 1
    }
  }
  -1
}
// The union member index of `u`'s CLOSURE-ARRAY arm (`((i32) => f32)[]` — a `TyArray` whose
// element is a `TyFunc`) whose element arity matches the array literal `arrIx`'s element lambdas,
// or -1. Lets `seedExpected` descend an array LITERAL flowing into a union into that arm so a bare
// element lambda infers its params/result from the arm's element function type. Gated to a
// CLOSURE element: a scalar/string/struct array arm needs no contextual seed (its elements infer
// standalone), and admitting only the closure-array arm keeps the seed off shapes the emitter has
// no sound narrowed read for. FIRST match wins.
function unionClosureArrayArmForLit(u: TyUnion, arrIx: i32) {
  const an = P.nodes[arrIx]
  if an is ArrayLit {
    const members = u.uMembers
    let i = 0
    while i < members.length {
      const m = members[i]
      const mt = T.tys[m]
      if mt is TyArray {
        const aet = T.tys[mt.aElem]
        if aet is TyFunc { return m }
      }
      i = i + 1
    }
  }
  -1
}
function seedExpected(exprIx: i32, expectedTy: i32) {
  if exprIx < 0 || expectedTy < 0 { return 0 }
  let u = exprIx
  let done = false
  while !done {
    const node = P.nodes[u]
    if node is Paren { u = node.parInner } else { done = true }
  }
  const en = P.nodes[u]
  const et = T.tys[expectedTy]
  // A nullable expected type (`(i32) => i32 | null` — e.g. a map VALUE slot, which is
  // `V | null`) seeds its inner: the RHS lambda / literal still wants the non-null shape.
  if et is TyNullable { return seedExpected(u, et.nInner) }
  if en is FuncDecl {
    if en.fnName == "" {
      if et is TyFunc {
        recordCbExpected(u, et.fnParamTypes)
        recordCbExpectedRet(u, et.fnRet)
        // RECURSE into the lambda's BODY against the expected RESULT type — the dual of the
        // array/object recursion below. A curried `(a) => (b) => …` against `(i32) => ((i32) =>
        // i32)` then types its inner lambda's params from the result function type, at any depth.
        seedExpected(lambdaBodyTail(en.fnBody), et.fnRet)
      } else if et is TyUnion {
        // A lambda flowing into a UNION with a bare-closure arm (`f: (() => i64) | {w:i32}`):
        // seed it against the arity-matching function arm, so `() => 5` widens to `() => i64`
        // and adopts the union (the emit boxes the closure arm into the `{tag, value}` rep).
        // Without this the lambda infers its own bare `() => i32` and the union assignment is a
        // loud type error — the checker seam the emit layers depend on. Arity-matched so a
        // non-function arm (or a wrong-arity closure) is left to the normal assignability check.
        const arm = unionFuncArmForArity(et, en.fnParams.length)
        if arm >= 0 { seedExpected(u, arm) }
      }
    }
  } else if en is ArrayLit {
    if et is TyArray {
      let i = 0
      while i < en.arrElems.length {
        seedExpected(en.arrElems[i], et.aElem)
        i = i + 1
      }
    } else if et is TyUnion {
      // An array LITERAL flowing into a union with a CLOSURE-ARRAY arm (`[(q) => …]` into
      // `((i32) => f32)[] | i32`): descend into the matching array arm so a bare element
      // lambda infers its params/result from that arm's element function type (the array
      // dual of the closure-arm and struct-arm seeding above). Without this seed the element
      // lambda has no context and fails "cannot infer a type for parameter". Re-entering with
      // the arm's `TyArray` reuses the element-recursion branch; assignability still gates the
      // whole literal against the union, so a wrong arm cannot be silently adopted.
      const arm = unionClosureArrayArmForLit(et, u)
      if arm >= 0 { seedExpected(u, arm) }
    }
  } else if en is ObjLit {
    if et is TyObj {
      const fields = en.objFields
      let i = 0
      while i < fields.length {
        const fnode = P.nodes[fields[i]]
        if fnode is FieldInit {
          const fty = objFieldType(et, fnode.fiName)
          if fty >= 0 { seedExpected(fnode.fiValue, fty) }
        }
        i = i + 1
      }
    } else if et is TyUnion {
      // A struct LITERAL flowing into a union (`{f: (i32) => i32, …} | boolean`): descend into the
      // matching struct ARM so a bare field lambda infers its params from that arm's field types
      // (the object dual of the closure-arm seeding above). Without this an un-annotated field
      // lambda has no contextual seed and fails "cannot infer a type for parameter". Re-entering
      // with the arm's `TyObj` reuses the field-recursion branch; assignability still gates the
      // whole literal against the union, so a wrong arm cannot be silently adopted.
      const arm = unionObjArmForLit(et, u)
      if arm >= 0 { seedExpected(u, arm) }
    }
  }
  0
}

// Reset all checker module state, then intern the well-known primitives and the
// global scope. Call once before checking.
export function initChecker() {
  redunReset()
  cbExpNode = []
  cbExpOff = []
  cbExpLen = []
  cbExpPool = []
  cbExpRetNode = []
  cbExpRetTy = []
  valBindLambda = []
  T.tys = []
  T.scopes = []
  T.diags = []
  T.curRet = -1
  cUserTypes = Map()
  // The arena is re-minted for this program: advance BOTH generations so no
  // emit-side memo stamped under a previous program can be consulted on a
  // shared instance (advance, never reset — a reset could collide with a stamp
  // an earlier program left behind).
  tyMutEpoch = tyMutEpoch + 1
  cUserTypesVer = cUserTypesVer + 1
  gaNames = []
  gaParamLists = []
  gaDeclIxs = []
  annotNameMemo = Map()
  annotNameMemoNegVer = Map()
  tpEnvNames = []
  tpEnvTys = []
  bgSrcStack = []
  bgDstStack = []
  stSeenStack = []
  holeShapeNames = []
  holeShapeTys = []
  holeArrayDemand = []
  binCstrLt = []
  binCstrOp = []
  binCstrRt = []
  argCstrAt = []
  argCstrExp = []
  argCstrWho = []
  fnDeclIx = Map()
  moduleGlobals = Map()
  topUnannotFns = []
  gRootStmts = []
  inferRetFn = []
  inferRetTy = []
  inferRetIdx = Map()
  inferLetIx = []
  inferLetTy = []
  inferLetNulStrIx = []
  inferLetNulBoolIx = []
  bodyChecked = Map()
  nodeTyIx = []
  cFuncPinTyIx = -1
  cObjPinTyIx = -1
  inferQuiet = false
  cycleBreakCount = 0
  inferTentative = []
  unresolvedFns = []
  fnSawValueRet = false
  retNatural = -1
  retNaturalErr = false
  daClear()
  daWriteTarget = -1
  inferStack = []
  inferObserved = -1
  inferSawErr = false
  TY_I32 = mkPrim("i32")
  TY_I64 = mkPrim("i64")
  TY_F64 = mkPrim("f64")
  TY_F32 = mkPrim("f32")
  TY_BOOL = mkPrim("boolean")
  TY_STR = mkPrim("string")
  TY_VOID = mkPrim("void")
  TY_ERR = mkErrTy()
  TY_NULL = mkPrim("null")
  TY_NEVER = mkPrim("never")
  T.scopes.push(Map())
  constScopes = []
  constScopes.push(Map())
  pendNames = []
  pendTys = []
  pendAts = []
  pendDepths = []
  npKeys = []
  npTys = []
  npFrames = []
  asgSrcStack = []
  asgDstStack = []
  tyToStrDepth = 0
  pgKeys = []
  pgFrames = []
  guardNames = []
  guardParamIdxs = []
  guardThens = []
  // LSP symbol-table data — cleared every check (the `symEnabled` mode flag is the
  // driver's to set, so it is NOT reset here). The global scope's decl frame is
  // seeded to parallel the global type scope `T.scopes` already pushed below.
  symOccTok = []
  symOccDecl = []
  symOccIsDecl = []
  // Token-membership set mirroring `symOccTok` — reset in lockstep (see `symOccHasTok`).
  symOccTokSet = Map()
  symDeclScope = []
  symBindNode = []
  symBindType = []
  symBindKind = []
  symMemNode = []
  symMemTy = []
  symMemLine = []
  symMemCol = []
  symMemEndCol = []
  symVisName = []
  symVisNode = []
  symVisKind = []
  symVisSL = []
  symVisSC = []
  symVisEL = []
  symVisEC = []
  scopeSL = []
  scopeSC = []
  scopeEL = []
  scopeEC = []
  scopeResName = []
  scopeResKind = []
  scopeResType = []
  if symEnabled != 0 {
    symDeclScope.push(Map())
    // The global scope spans the whole file (looser than any nested scope).
    scopeSL.push(1)
    scopeSC.push(0)
    scopeEL.push(SCOPE_EOF)
    scopeEC.push(0)
  }
  // Memory intrinsics (host `defaultScope`): raw linear-memory stores/loads and
  // the `__log__` host hook used by low-level corpus programs.
  declare("__store_i32__", mkFuncTy([TY_I32, TY_I32], TY_VOID))
  declare("__store_i64__", mkFuncTy([TY_I32, TY_I64], TY_VOID))
  declare("__store_f32__", mkFuncTy([TY_I32, TY_F32], TY_VOID))
  declare("__store_f64__", mkFuncTy([TY_I32, TY_F64], TY_VOID))
  declare("__load_i32__", mkFuncTy([TY_I32], TY_I32))
  declare("__store_string__", mkFuncTy([TY_I32, TY_STR], TY_I32))
  declare("__log_string__", mkFuncTy([TY_I32, TY_I32], TY_VOID))
  declare("__log__", mkFuncTy([TY_I32, TY_I32], TY_VOID))
  declare("__memory_grow__", mkFuncTy([TY_I32], TY_I32))
  const noParams: i32[] = []
  declare("__memory_size__", mkFuncTy(noParams, TY_I32))
  0
}

// ── scope chain ──────────────────────────────────────────────────────────────

// ── flow narrowing (condition collectors) ────────────────────────────────────
// The canonical narrowing key for a "place" — a bare name (`x`) or a property
// path rooted at one (`o.v`, `o.v.w`) — or "" for anything else (a call, an
// index, a literal: not a stable place to narrow). Mirrors the host's
// `placeKey`; `x?.y` keys the same place as `x.y`, so a guard written with
// `?.` refines the regular `x.y` reads in the branch body.
function placeKeyOf(ix: i32) {
  const n = P.nodes[ix]
  if n is Ident { return n.identName }
  if n is Member {
    const base = placeKeyOf(n.memObj)
    if base == "" { return "" }
    return base + "." + n.memProp
  }
  if n is OptMember {
    const base = placeKeyOf(n.omObj)
    if base == "" { return "" }
    return base + "." + n.omProp
  }
  ""
}

// The innermost narrowed-path overlay entry for `key`, or -1 (not narrowed).
function narrowedPathTy(key: string) {
  let i = npKeys.length - 1
  while i >= 0 {
    if npKeys[i] == key { return npTys[i] }
    i = i - 1
  }
  -1
}

// The node index of the place compared against `null` in a `x == null` /
// `x != null` / `null == x` comparison, or -1 (not a null compare).
function nullCmpPlace(condIx: i32) {
  const cond = P.nodes[condIx]
  if cond is BinExpr {
    const lhs = P.nodes[cond.binLeft]
    const rhs = P.nodes[cond.binRight]
    if rhs is NullLit { return cond.binLeft }
    if lhs is NullLit { return cond.binRight }
  }
  -1
}

// Whether `ty` is the `null` primitive (compared structurally — `null` may be
// interned more than once across annotations).
function isNullTy(ty: i32) {
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyPrim { return t.primName == "null" }
  false
}

// Whether `ty` is the `void` primitive (compared STRUCTURALLY — like `null`, `void` may
// be interned at more than one arena index, so `== TY_VOID` is not reliable).
function isVoidTy(ty: i32) {
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyPrim { return t.primName == "void" }
  false
}

// Whether `ty` is exactly `string | null` — a `TyNullable` wrapping the `string`
// primitive. Cheap (no `tyToStr`); used to record an inferred niche if-binding.
function isNulStringTy(ty: i32) {
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyNullable {
    const inr = t.nInner
    if inr < 0 { return false }
    const it = T.tys[inr]
    if it is TyPrim { return it.primName == "string" }
  }
  false
}

// Whether `ty` ADMITS null — a `TyNullable`, the bare `null` prim, or a union with a
// `null` member. Gates the completion coercion: an object literal may OMIT a field whose
// declared type admits null (it is materialized as `null` at construction).
function tyAdmitsNull(ty: i32) {
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyNullable { return true }
  if t is TyPrim { return t.primName == "null" }
  if t is TyUnion {
    const ms = t.uMembers
    let i = 0
    while i < ms.length {
      if isNullTy(ms[i]) { return true }
      i = i + 1
    }
  }
  false
}

// Whether `ty` is a union whose every member is a structural OBJECT (`Cat | Dog`) — the
// variant-boxed struct-union rep the emitter lowers via its expression-based `exprUnion`
// fallback. An inferred return of this shape no longer floors (the annotated form already
// lowers + `is`-narrows). A MIXED union (a struct mixed with a scalar/string) is NOT this
// — it has no single rep, so it stays floored.
function isStructUnionTy(ty: i32) {
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyUnion {
    const members = t.uMembers
    if members.length < 2 { return false }
    let i = 0
    while i < members.length {
      const m = T.tys[members[i]]
      if !(m is TyObj) { return false }
      i = i + 1
    }
    return true
  }
  false
}

// Whether `ty` is exactly `boolean | null` — a `TyNullable` wrapping the `boolean`
// primitive (the niche scalar nullable: an i32 0/1 with sentinel 2 = null). Cheap
// (no `tyToStr`); used to record an inferred niche if-binding.
function isNulBoolTy(ty: i32) {
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyNullable {
    const inr = t.nInner
    if inr < 0 { return false }
    const it = T.tys[inr]
    // The canonical boolean prim interns as `mkPrim("boolean")` (`TY_BOOL`); an annotation
    // may also name it "boolean" — accept both, like the inferred-return niche path.
    if it is TyPrim { return it.primName == "boolean" }
  }
  false
}

// The non-null part of `ty` (the host's `nonNullable`): a nullable peels to
// its inner type; anything else is already non-null. -1 propagates.
function nonNullTy(ty: i32) {
  if ty < 0 { return -1 }
  const t = T.tys[ty]
  if t is TyNullable { return t.nInner }
  ty
}

// A place's CURRENT type during fact collection: facts already collected into
// `names`/`tys` (innermost-last wins) override the path overlay, which
// overrides the scope/field lookup — so successive narrowings compose
// (`o != null && o.y is i32` resolves `o.y` against the non-null `o`).
// Read-only: collection must never raise a diagnostic.
function placeCurTy(ix: i32, names: string[], tys: i32[]) {
  const key = placeKeyOf(ix)
  if key != "" {
    let i = names.length - 1
    while i >= 0 {
      if names[i] == key { return tys[i] }
      i = i - 1
    }
    const ov = narrowedPathTy(key)
    if ov >= 0 { return ov }
  }
  const n = P.nodes[ix]
  if n is Ident { return lookup(n.identName) }
  if n is Member {
    return placeFieldTy(placeCurTy(n.memObj, names, tys), n.memProp, false)
  }
  if n is OptMember {
    return placeFieldTy(placeCurTy(n.omObj, names, tys), n.omProp, true)
  }
  -1
}

// The type of field `prop` read off `baseTy` for narrowing purposes (no
// diagnostics): an OPTIONAL hop peels a nullable receiver and re-wraps the
// result nullable; the field resolves off a struct, or as a shared union
// field. -1 when unresolvable (no narrowing is recorded then).
function placeFieldTy(baseTy: i32, prop: string, optional: boolean) {
  if baseTy < 0 { return -1 }
  const bt = T.tys[baseTy]
  let wasNullable = false
  let core = baseTy
  if bt is TyNullable {
    if !optional { return -1 }
    wasNullable = true
    core = bt.nInner
  }
  if core < 0 { return -1 }
  const ct = T.tys[core]
  let ft = -1
  if ct is TyObj { ft = objFieldType(ct, prop) }
  else if ct is TyUnion { ft = sharedUnionFieldTy(ct, prop) }
  if ft < 0 { return -1 }
  if wasNullable { return mkNullableTy(ft) }
  ft
}

// SHARED-FIELD ACCESS over a struct union (the host's `sharedUnionField`): a
// field present on EVERY member with a mutually-assignable type is readable on
// the union directly, without narrowing — `(A | B).tag`. -1 when any member
// lacks the field, disagrees on its type, or isn't a struct.
function sharedUnionFieldTy(u: TyUnion, prop: string) {
  const members = u.uMembers
  if members.length < 1 { return -1 }
  let shared = -1
  let i = 0
  while i < members.length {
    const mIx = members[i]
    if mIx < 0 { return -1 }
    const m = T.tys[mIx]
    if m is TyObj {
      const ft = objFieldType(m, prop)
      if ft < 0 { return -1 }
      if shared < 0 { shared = ft }
      else if !assignable(shared, ft) || !assignable(ft, shared) { return -1 }
    } else {
      return -1
    }
    i = i + 1
  }
  shared
}

// Flatten a union/nullable into its variant list (`null` becomes the null
// type), mirroring the host's `flattenVariants`.
function flattenVariantsInto(ty: i32, out: i32[]) {
  if ty < 0 {
    out.push(ty)
    return 0
  }
  const t = T.tys[ty]
  if t is TyUnion {
    const members = t.uMembers
    let i = 0
    while i < members.length {
      flattenVariantsInto(members[i], out)
      i = i + 1
    }
    return 0
  }
  if t is TyNullable {
    flattenVariantsInto(t.nInner, out)
    out.push(TY_NULL)
    return 0
  }
  out.push(ty)
  0
}

// Two arena types denoting the same variant (mutually assignable). A generic
// type variable is never "the same variant" as anything — the host's hole
// guard (`isHole`) — so narrowing never pins an un-instantiated parameter.
function sameVariantTy(a: i32, b: i32) {
  if a < 0 || b < 0 { return false }
  const ta = T.tys[a]
  if ta is TyVar { return false }
  const tb = T.tys[b]
  if tb is TyVar { return false }
  // Named variants resolve to one canonical arena entry (`cUserTypes`), so
  // the common same-variant case is index equality — skip both traversals.
  if a == b { return true }
  if !assignable(a, b) { return false }
  assignable(b, a)
}

// Litunion alias-PROVENANCE stamp (Stage B b1, see `cLitUnionCopyTyIxs`):
// record that freshly-minted union `res` is a COPY of the declared litunion
// alias `src` derives from. `src` is the operation's INPUT type (a nullable
// wrapper unwraps to its inner — `K | null` narrowing subtracts from the
// nullable). Records only when
//   · `res` is itself a litunion at an index with no alias identity yet, and
//   · `src` resolves to a declared alias (directly, via its own recorded
//     provenance — copies chain — or through a `| null` wrapper), and
//   · every member of `res` is a member of that alias (the subset gate:
//     narrowing/subtraction/dedup only ever KEEP members, so a copy is always
//     contained; a join that widened past the alias is NOT the alias).
// A miss records nothing — the index simply stays alias-less, exactly the
// pre-provenance state. Never consulted on the checking hot path (the rep
// layers read it at emit); the copy list stays small (one entry per litunion
// re-mint).
function litUnionProvSrcAlias(src: i32): i32 {
  if src < 0 { return -1 }
  const t = T.tys[src]
  if t is TyNullable { return litUnionProvSrcAlias(t.nInner) }
  tyLitUnionAliasIx(src)
}

function noteLitUnionCopy(res: i32, src: i32) {
  if res < 0 { return 0 }
  if !tyIsLitUnion(res) { return 0 }
  if tyLitUnionAliasIx(res) >= 0 { return 0 }
  const alias = litUnionProvSrcAlias(src)
  if alias < 0 { return 0 }
  const rt = T.tys[res]
  const at = T.tys[alias]
  if rt is TyUnion {
    if at is TyUnion {
      let i = 0
      while i < rt.uMembers.length {
        let hit = false
        let j = 0
        while j < at.uMembers.length {
          if sameVariantTy(rt.uMembers[i], at.uMembers[j]) { hit = true }
          j = j + 1
        }
        if !hit { return 0 }
        i = i + 1
      }
      cLitUnionCopyTyIxs.push(res)
      cLitUnionCopyAliasIxs.push(alias)
    }
  }
  0
}

// Remove a variant from a union/nullable, returning the residual type (the
// host's `subtractType`) — backs else-branch narrowing: in `if x is A { … }
// else { … }`, `x` is `U − A` in the else branch. Returns -1 both when nothing
// concrete is removed (open-world negation isn't tracked) and when nothing
// remains (a dead branch — the host skips overlaying a `Never`).
function subtractTy(ty: i32, removed: i32) {
  if ty < 0 || removed < 0 { return -1 }
  const drop: i32[] = []
  flattenVariantsInto(removed, drop)
  const vars: i32[] = []
  flattenVariantsInto(ty, vars)
  const kept: i32[] = []
  let i = 0
  while i < vars.length {
    const v = vars[i]
    let hit = false
    let j = 0
    while j < drop.length {
      if sameVariantTy(v, drop[j]) { hit = true }
      j = j + 1
    }
    if !hit { kept.push(v) }
    i = i + 1
  }
  if kept.length == vars.length { return -1 }
  if kept.length == 0 { return -1 }
  // Reassemble the residual: a surviving `null` folds back into a nullable.
  let hasNull = false
  const core: i32[] = []
  let k = 0
  while k < kept.length {
    if isNullTy(kept[k]) { hasNull = true } else { core.push(kept[k]) }
    k = k + 1
  }
  if core.length == 0 { return TY_NULL }
  let res = core[0]
  if core.length > 1 {
    res = mkUnionTy(core)
    // A narrowed litunion alias (`K` minus some members, `K | null` minus the
    // null) is a fresh COPY of the alias — stamp its provenance (b1).
    noteLitUnionCopy(res, ty)
  }
  if hasNull { return mkNullableTy(res) }
  res
}

// Whether `ix` is the `never` primitive (the empty type).
function isNeverTy(ix: i32) {
  if ix < 0 { return false }
  const t = T.tys[ix]
  if t is TyPrim { return t.primName == "never" }
  // An empty union (no surviving members — e.g. a degenerate `type D = D` or an
  // empty intersection `A & B`) is uninhabited, i.e. `never`. The declaration
  // already reported it; treating it as `never` keeps use sites from cascading.
  if t is TyUnion { return t.uMembers.length == 0 }
  false
}

// A prose description of a type's underlying SHAPE, for explaining why two
// intersection operands can't overlap (`A & B` → "an object and a string
// literal"). Mirrors the TS host's `operandKind`. A single-member union (a
// `type B = "foo"` alias) peels to its member so it reads "a string literal",
// not "a union".
function operandKind(ix: i32) {
  if ix < 0 { return "a type" }
  const t = T.tys[ix]
  if t is TyUnion {
    if t.uMembers.length == 1 { return operandKind(t.uMembers[0]) }
    return "a union"
  }
  if t is TyLit {
    if t.litKind == "str" { return "a string literal" }
    return "a number literal"
  }
  if t is TyObj { return "an object" }
  if t is TyFunc { return "a function" }
  if t is TyPrim { return "the type `" + t.primName + "`" }
  if t is TyArray { return "an array" }
  if t is TyMap { return "a map" }
  "a type"
}

// Split a synthetic intersection name (`A&B`, `{a:i32}&B`) into its TOP-LEVEL
// operands (depth-aware, so a nested `{…}`/`[…]`/`(…)` `&` doesn't split). One
// element when there is no top-level `&`.
function splitTopAmp(name: string) {
  const parts: string[] = []
  let depth = 0
  let start = 0
  let i = 0
  while i < name.length {
    const c = name[i]
    if c == '{' || c == '[' || c == '(' {
      depth = depth + 1
    } else if c == '}' || c == ']' || c == ')' {
      depth = depth - 1
    } else if c == '&' && depth == 0 {
      parts.push(name.slice(start, i))
      start = i + 1
    }
    i = i + 1
  }
  parts.push(name.slice(start, name.length))
  parts
}

// The base scalar a literal type SOFTENS to (host: `StringLiteral` → string,
// `IntegerLiteral` → its magnitude-defaulted integer type, `RealLiteral` →
// f64). An integer literal past the i32 range softens to i64 (the host's
// `defaultIntegerType` magnitude rule), so the literal-aware assignability
// path never sneaks an out-of-range literal into an i32 slot.
function litBaseTy(t: TyLit) {
  if t.litKind == "str" { return TY_STR }
  if t.litKind == "flt" { return TY_F64 }
  if intLexemeFitsI32(t.litText) { return TY_I32 }
  TY_I64
}

// Whether `ty` carries LITERAL members (a literal type, or a union/nullable
// with a literal member) — the "closed set" types whose membership rules the
// literal-union checks enforce.
function isLitBearing(ty: i32) {
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyLit { return true }
  if t is TyNullable { return isLitBearing(t.nInner) }
  if t is TyUnion {
    const members = t.uMembers
    let i = 0
    while i < members.length {
      if isLitBearing(members[i]) { return true }
      i = i + 1
    }
  }
  false
}

// Soften a literal / all-literal union operand to its base scalar (host: a
// numeric-literal union is its base type for ARITHMETIC and ordering — the
// union constrains what may be ASSIGNED, not what may be computed). A mixed
// union (different bases, or any non-literal member) is left alone.
function softenLitTy(ty: i32) {
  if ty < 0 { return ty }
  const t = T.tys[ty]
  if t is TyLit { return litBaseTy(t) }
  if t is TyUnion {
    const members = t.uMembers
    let base = -1
    let i = 0
    while i < members.length {
      const m = members[i]
      if m < 0 { return ty }
      const mt = T.tys[m]
      if mt is TyLit {
        const b = litBaseTy(mt)
        if base < 0 { base = b }
        else if base != b { return ty }
      } else {
        return ty
      }
      i = i + 1
    }
    if base >= 0 { return base }
  }
  ty
}

// The LITERAL type of a literal EXPRESSION (host: a string/number literal
// carries its own `StringLiteral`/`IntegerLiteral`/`RealLiteral` type), or -1
// when the expression isn't a bare literal. Peels parens. The string text is
// the RAW lexeme between the quotes — the same characters a literal-type
// annotation keeps — so membership compares consistently.
function litTyOfExpr(ix: i32) {
  if ix < 0 { return -1 }
  const e = P.nodes[ix]
  if e is Paren { return litTyOfExpr(e.parInner) }
  if e is StrLit {
    const raw = e.strText
    return mkLitTy("str", raw.slice(1, raw.length - 1))
  }
  if e is NumLit {
    if hasDot(e.numText) { return mkLitTy("flt", e.numText) }
    return mkLitTy("int", e.numText)
  }
  -1
}

// `A & !B` (host `subtractType` under an intersection fold): drop B's variants
// from A. Differs from the narrowing `subtractTy` in its EDGES: nothing
// concrete dropped → A unchanged (open-world negation, e.g. `i32 & !2`);
// everything dropped → `never` (host: an empty intersection).
function isectSubtract(ty: i32, removed: i32) {
  if ty < 0 || removed < 0 { return -1 }
  const drop: i32[] = []
  flattenVariantsInto(removed, drop)
  const vars: i32[] = []
  flattenVariantsInto(ty, vars)
  const kept: i32[] = []
  let i = 0
  while i < vars.length {
    const v = vars[i]
    let hit = false
    let j = 0
    while j < drop.length {
      if sameVariantTy(v, drop[j]) { hit = true }
      j = j + 1
    }
    if !hit { kept.push(v) }
    i = i + 1
  }
  if kept.length == vars.length { return ty }
  if kept.length == 0 { return TY_NEVER }
  let hasNull = false
  const core: i32[] = []
  let k = 0
  while k < kept.length {
    if isNullTy(kept[k]) { hasNull = true } else { core.push(kept[k]) }
    k = k + 1
  }
  if core.length == 0 { return TY_NULL }
  let res = core[0]
  if core.length > 1 {
    res = mkUnionTy(core)
    // `K & !"a"` — an intersection-subtracted litunion alias is a COPY (b1).
    noteLitUnionCopy(res, ty)
  }
  if hasNull { return mkNullableTy(res) }
  res
}

// Fold `A & B` (host `intersectType`): a negation operand SUBTRACTS, a union
// operand DISTRIBUTES (`(0|1|2) & !2` → `0 | 1`), two object types MERGE
// field-wise (A3: `{a} & {b}` is `{a, b}`, a shared field refines to the meet),
// a subtype pair keeps the NARROWER side, and a disjoint concrete pair folds to
// `never` (no common values). -1 (unresolved) poisons the fold.
function intersectTy(a: i32, b: i32) {
  if a < 0 || b < 0 { return -1 }
  const tb = T.tys[b]
  if tb is TyNeg { return isectSubtract(a, tb.negTy) }
  const ta = T.tys[a]
  if ta is TyNeg { return isectSubtract(b, ta.negTy) }
  if ta is TyUnion {
    const du = isectDistribute(ta.uMembers, b)
    // A distributed litunion alias (`K & <lit>`) re-mints a subset COPY (b1).
    noteLitUnionCopy(du, a)
    return du
  }
  if tb is TyUnion {
    const du2 = isectDistribute(tb.uMembers, a)
    noteLitUnionCopy(du2, b)
    return du2
  }
  if ta is TyObj {
    if tb is TyObj {
      // Structural field-wise merge: the value that is BOTH carries every
      // field of each side; a shared field is the meet of the two sides.
      const mnames: string[] = []
      const mtys: i32[] = []
      const anames = ta.objFieldNames
      const atys = ta.objFieldTypes
      let ai = 0
      while ai < anames.length {
        mnames.push(anames[ai])
        mtys.push(atys[ai])
        ai = ai + 1
      }
      const bnames = tb.objFieldNames
      const btys = tb.objFieldTypes
      let bi = 0
      while bi < bnames.length {
        let at2 = -1
        let mi = 0
        while mi < mnames.length {
          if mnames[mi] == bnames[bi] { at2 = mi }
          mi = mi + 1
        }
        if at2 >= 0 {
          mtys[at2] = intersectTy(mtys[at2], btys[bi])
        } else {
          mnames.push(bnames[bi])
          mtys.push(btys[bi])
        }
        bi = bi + 1
      }
      return mkObjTy(mnames, mtys)
    }
  }
  if assignable(a, b) { return a }
  if assignable(b, a) { return b }
  TY_NEVER
}

// Distribute an intersection over a union operand: `(A | B) & C` is
// `(A & C) | (B & C)`, dropping members that fold to `never`.
function isectDistribute(members: i32[], other: i32) {
  const kept: i32[] = []
  let i = 0
  while i < members.length {
    const r = intersectTy(members[i], other)
    if r >= 0 && !isNeverTy(r) {
      let dup = false
      let j = 0
      while j < kept.length {
        if sameVariantTy(r, kept[j]) { dup = true }
        j = j + 1
      }
      if !dup { kept.push(r) }
    }
    i = i + 1
  }
  if kept.length == 0 { return TY_NEVER }
  if kept.length == 1 { return kept[0] }
  mkUnionTy(kept)
}

// Append one narrowing fact (place key → type) when the place is stable and
// the narrowed type resolved (-1 means "no fact" and is skipped).
function pushNarrowFact(placeIx: i32, ty: i32, names: string[], tys: i32[]) {
  if ty < 0 { return 0 }
  const key = placeKeyOf(placeIx)
  if key == "" { return 0 }
  names.push(key)
  tys.push(ty)
  0
}

// Whether the place runs through a `?.` hop — its negation is then not a sound
// else-branch refinement (the chain may be null because a RECEIVER was).
function placeHasOptionalHop(ix: i32) {
  const n = P.nodes[ix]
  if n is OptMember { return true }
  if n is Member { return placeHasOptionalHop(n.memObj) }
  false
}

// For a guard on an optional chain (`x?.y is T`), the truthy branch also
// implies every `?.` receiver is non-null — push those facts innermost-first
// (each resolves against an already-narrowed receiver), so the body's regular
// `x.y` reads resolve. THEN branch only (the host's `optionalChainThenFacts`).
function pushOptChainThenFacts(placeIx: i32, names: string[], tys: i32[]) {
  const n = P.nodes[placeIx]
  if n is Member {
    pushOptChainThenFacts(n.memObj, names, tys)
    return 0
  }
  if n is OptMember {
    pushOptChainThenFacts(n.omObj, names, tys)
    const cur = placeCurTy(n.omObj, names, tys)
    const inner = nonNullTy(cur)
    if inner >= 0 && inner != cur { pushNarrowFact(n.omObj, inner, names, tys) }
    return 0
  }
  0
}

// The argument PLACE a guard call narrows in the branch where its non-null
// side is `wantThen` (1: THEN, 0: ELSE), or -1: not a registered guard call /
// wrong direction / no stable argument. Handles the inline form
// (`present(v)`) and the UFCS form (`v.present()` — the receiver fills the
// guard's `self` param 0).
function guardCallPlace(cond: Call, wantThen: i32) {
  const cfn = P.nodes[cond.callFn]
  let gname = ""
  let gRecv = -1
  if cfn is Ident {
    gname = cfn.identName
  } else if cfn is Member {
    gname = cfn.memProp
    gRecv = cfn.memObj
  }
  if gname == "" { return -1 }
  const gi = guardIndexOf(gname)
  if gi < 0 { return -1 }
  if guardThens[gi] != wantThen { return -1 }
  const pIdx = guardParamIdxs[gi]
  const cargs = cond.callArgs
  if gRecv >= 0 {
    if pIdx == 0 { return gRecv }
    if pIdx - 1 < cargs.length { return cargs[pIdx - 1] }
    return -1
  }
  if pIdx < cargs.length { return cargs[pIdx] }
  -1
}

// Collect the narrowings that hold when `cond` is TRUE into the parallel
// `names`/`tys` arrays (keys are place paths — see `placeKeyOf`): `x != null`
// strips x's null, `x is T` pins x to T (`is null` pins to the null type),
// `a && b` contributes BOTH conjuncts, `!(e)` contributes e's FALSE
// narrowings, and parens recurse. A guard over an optional chain also narrows
// each `?.` receiver non-null (host `optionalChainThenFacts`).
function collectThenNarrows(condIx: i32, names: string[], tys: i32[]) {
  const cond = P.nodes[condIx]
  if cond is Paren { return collectThenNarrows(cond.parInner, names, tys) }
  if cond is Unary {
    if cond.unOp == "!" { return collectElseNarrows(cond.unArg, names, tys) }
    return 0
  }
  if cond is IsExpr {
    pushOptChainThenFacts(cond.isObj, names, tys)
    if cond.isVariant == "null" {
      pushNarrowFact(cond.isObj, TY_NULL, names, tys)
    } else {
      const tIdx = nameToTy(cond.isVariant)
      if tIdx >= 0 { pushNarrowFact(cond.isObj, tIdx, names, tys) }
    }
    return 0
  }
  if cond is BinExpr {
    if cond.binOp == "&&" {
      collectThenNarrows(cond.binLeft, names, tys)
      collectThenNarrows(cond.binRight, names, tys)
      return 0
    }
    if cond.binOp == "!=" {
      const placeIx = nullCmpPlace(condIx)
      if placeIx >= 0 {
        pushOptChainThenFacts(placeIx, names, tys)
        const cur = placeCurTy(placeIx, names, tys)
        const inner = nonNullTy(cur)
        if inner >= 0 && inner != cur {
          pushNarrowFact(placeIx, inner, names, tys)
        }
      }
    }
    return 0
  }
  // Inferred type-guard call (A6b): `if present(v)` narrows `v` the way the
  // guard's body narrows its parameter — non-null here when the guard's
  // non-null branch is THEN.
  if cond is Call {
    const gArg = guardCallPlace(cond, 1)
    if gArg >= 0 {
      pushOptChainThenFacts(gArg, names, tys)
      const gCur = placeCurTy(gArg, names, tys)
      const gInner = nonNullTy(gCur)
      if gInner >= 0 && gInner != gCur {
        pushNarrowFact(gArg, gInner, names, tys)
      }
    }
    return 0
  }
  0
}

// Collect the narrowings that hold when `cond` is FALSE: `x == null` strips
// the null in the else-branch, `x is null` false means non-null, `x is T`
// false leaves the union COMPLEMENT `U − T` (host `subtractType`), `a || b`
// contributes BOTH disjuncts (De Morgan: neither held), `!(e)` contributes
// e's TRUE narrowings, and parens recurse. A place behind a `?.` hop is never
// else-narrowed (the chain may be null because a receiver was).
function collectElseNarrows(condIx: i32, names: string[], tys: i32[]) {
  const cond = P.nodes[condIx]
  if cond is Paren { return collectElseNarrows(cond.parInner, names, tys) }
  if cond is Unary {
    if cond.unOp == "!" { return collectThenNarrows(cond.unArg, names, tys) }
    return 0
  }
  if cond is IsExpr {
    if placeHasOptionalHop(cond.isObj) { return 0 }
    const cur = placeCurTy(cond.isObj, names, tys)
    if cond.isVariant == "null" {
      const inner = nonNullTy(cur)
      if inner >= 0 && inner != cur {
        pushNarrowFact(cond.isObj, inner, names, tys)
      }
    } else {
      const tIdx = nameToTy(cond.isVariant)
      if tIdx >= 0 {
        pushNarrowFact(cond.isObj, subtractTy(cur, tIdx), names, tys)
      }
    }
    return 0
  }
  if cond is BinExpr {
    if cond.binOp == "||" {
      collectElseNarrows(cond.binLeft, names, tys)
      collectElseNarrows(cond.binRight, names, tys)
      return 0
    }
    if cond.binOp == "==" {
      const placeIx = nullCmpPlace(condIx)
      if placeIx >= 0 {
        if !placeHasOptionalHop(placeIx) {
          const cur = placeCurTy(placeIx, names, tys)
          const inner = nonNullTy(cur)
          if inner >= 0 && inner != cur {
            pushNarrowFact(placeIx, inner, names, tys)
          }
        }
      }
    }
    return 0
  }
  // Inferred type-guard call (A6b): `if absent(p) { … } else { /* p!=null */ }`
  // — non-null in the ELSE branch when the guard's non-null branch is ELSE.
  if cond is Call {
    const gArg = guardCallPlace(cond, 0)
    if gArg >= 0 {
      if !placeHasOptionalHop(gArg) {
        const gCur = placeCurTy(gArg, names, tys)
        const gInner = nonNullTy(gCur)
        if gInner >= 0 && gInner != gCur {
          pushNarrowFact(gArg, gInner, names, tys)
        }
      }
    }
    return 0
  }
  0
}

// Whether a narrowing key is a property PATH (`o.v`) rather than a bare name.
function isPathKey(s: string) {
  let i = 0
  while i < s.length {
    if s[i] == 46 {
      return true // '.'
    }
    i = i + 1
  }
  false
}

// Apply collected narrowings around a branch: a bare name shadows via the
// scope chain (the caller pushes a scope first), a property path rides the
// `npKeys`/`npTys` overlay — whose entries the matching `popScope` unwinds.
function applyNarrows(names: string[], tys: i32[]) {
  let i = 0
  while i < names.length {
    if isPathKey(names[i]) {
      npKeys.push(names[i])
      npTys.push(tys[i])
    } else {
      declare(names[i], tys[i])
    }
    i = i + 1
  }
  0
}

// The START char offset of a SCOPE-OWNING node (the `{`/`for` token), or `-1`.
// Only the node kinds that open a lexical scope are handled (block bodies, the
// two `for` forms); other owners fall back to "no start" → a full-file sentinel.
function scopeStartOff(owner: i32) {
  if owner < 0 || owner >= P.nodes.length { return -1 }
  const n = P.nodes[owner]
  if n is Block { return n.pos }
  if n is ForRange { return n.pos }
  if n is ForIn { return n.pos }
  if n is FuncDecl { return n.pos }
  -1
}

// The token index whose START offset is exactly `off`, or `-1`. A scope owner's
// `pos` is a token boundary (`{`/`for`), so this recovers its line/col.
function tokIxAtStart(off: i32) {
  if off < 0 { return -1 }
  // The lexer appends tokens in scan order, so `start` offsets are strictly
  // increasing — binary search (this runs per scope push in LSP mode, and a
  // linear scan over all tokens made scope collection quadratic).
  let lo = 0
  let hi = P.toks.length - 1
  while lo <= hi {
    const mid = lo + (hi - lo) / 2
    const s = P.toks[mid].start
    if s == off { return mid }
    if s < off { lo = mid + 1 } else { hi = mid - 1 }
  }
  -1
}

// Push the open-scope span for `owner` (the scope-owning node), in lockstep with
// the decl-scope map. The END is the owner's anchor (last) token — the closing
// `}` for a block; the START its first token. `owner < 0` (a narrowing-only
// scope, which never holds a binding) pushes a full-file sentinel.
function pushScopeSpan(owner: i32) {
  let startL = 1
  let startC = 0
  let endL = SCOPE_EOF
  let endC = 0
  if owner >= 0 {
    const so = scopeStartOff(owner)
    const stk = tokIxAtStart(so)
    if stk >= 0 {
      const st = P.toks[stk]
      startL = st.line
      startC = st.col
    }
    if owner < nodeToks.length {
      const etk = nodeToks[owner]
      if etk >= 0 && etk < P.toks.length {
        const et = P.toks[etk]
        endL = et.line
        endC = et.col + et.text.length
      }
    }
  }
  scopeSL.push(startL)
  scopeSC.push(startC)
  scopeEL.push(endL)
  scopeEC.push(endC)
  0
}

// Enter a new lexical scope (push a fresh name→type map). Marks the current
// narrowed-path overlay depth so `popScope` unwinds entries pushed inside.
// `owner` is the scope-owning node (its source span bounds visibility for the
// LSP scope query); `-1` for a narrowing-only overlay that holds no binding.
function pushScope(owner: i32) {
  T.scopes.push(Map())
  constScopes.push(Map())
  npFrames.push(npKeys.length)
  pgFrames.push(pgKeys.length)
  if symEnabled != 0 {
    symDeclScope.push(Map())
    pushScopeSpan(owner)
  }
  0
}

// Leave the innermost scope. (`.pop()` in statement position drops its return
// value correctly now — the old PR #4 wasm-validation gap is fixed and pinned by
// `tests/cases/lists/struct-field-pop-statement.vl`.)
function popScope() {
  flushUninferred(T.scopes.length - 1)
  T.scopes.pop()
  constScopes.pop()
  if npFrames.length > 0 {
    const base = npFrames[npFrames.length - 1]
    npFrames.pop()
    while npKeys.length > base {
      npKeys.pop()
      npTys.pop()
    }
  }
  if pgFrames.length > 0 {
    const pbase = pgFrames[pgFrames.length - 1]
    pgFrames.pop()
    while pgKeys.length > pbase { pgKeys.pop() }
  }
  if symEnabled != 0 {
    if symDeclScope.length > 0 { symDeclScope.pop() }
    if scopeSL.length > 0 {
      scopeSL.pop()
      scopeSC.pop()
      scopeEL.pop()
      scopeEC.pop()
    }
  }
  0
}

// ── LSP symbol-table recording (no-ops when `symEnabled == 0`) ────────────────
// A binding's type-arena index, retained by `bindingId` (its decl node index)
// so hover can render it after the scope closed. The last write for a node wins
// (a re-check during demand-inference overwrites with the resolved type).
function symRetainType(declNode: i32, ty: i32, kind: i32) {
  let i = 0
  while i < symBindNode.length {
    if symBindNode[i] == declNode {
      symBindType[i] = ty
      symBindKind[i] = kind
      return 0
    }
    i = i + 1
  }
  symBindNode.push(declNode)
  symBindType.push(ty)
  symBindKind.push(kind)
  0
}

// Stamp a binding's VISIBILITY scope for the position query, from open-scope span
// `spanIx` (a `scope*` stack index). Skipped when the index is out of range.
// FIRST stamp per binding (`declNode`) wins: a top-level function name is stamped
// in pass 1 with its (correct, global) scope BEFORE pass 2, so a later
// demand-inference re-entry — which runs the body from an artificially deep stack
// and would mis-pick the enclosing-scope span — cannot clobber it. A local/param's
// span is derived from its scope-owning node, so it is correct on first stamp
// regardless of stack depth.
function symStampVis(name: string, declNode: i32, kind: i32, spanIx: i32) {
  if spanIx < 0 || spanIx >= scopeSL.length { return 0 }
  let k = 0
  while k < symVisNode.length {
    if symVisNode[k] == declNode { return 0 }
    k = k + 1
  }
  symVisName.push(name)
  symVisNode.push(declNode)
  symVisKind.push(kind)
  symVisSL.push(scopeSL[spanIx])
  symVisSC.push(scopeSC[spanIx])
  symVisEL.push(scopeEL[spanIx])
  symVisEC.push(scopeEC[spanIx])
  0
}

// Record a DECLARATION: bind `name → declNode` in the innermost decl scope, emit
// the declaration's own occurrence (anchored at its NAME token), and retain its
// type. `declNode` is the bindingId; `nameTok` its identifier token (from the
// parser's `declNameTok` side table — falls back to the node anchor when unset).
function symDecl(name: string, declNode: i32, ty: i32, kind: i32) {
  if symEnabled == 0 { return 0 }
  if symDeclScope.length > 0 {
    const top = symDeclScope.length - 1
    symDeclScope[top][name] = declNode
  }
  symRetainType(declNode, ty, kind)
  // Visibility for completion: a binding is visible across its OWN (innermost)
  // scope. Stamped before the occurrence dedup so a demand-inference re-check
  // refreshes the span (see `symStampVis`).
  symStampVis(name, declNode, kind, scopeSL.length - 1)
  let tok = declNameTokOf(declNode)
  if tok < 0 {
    if declNode >= 0 && declNode < nodeToks.length { tok = nodeToks[declNode] }
  }
  // Idempotent by token: a function body re-checked during demand-inference would
  // otherwise stamp the same source identifier twice.
  if symOccHasTok(tok) { return 0 }
  symOccTok.push(tok)
  symOccRecordTok(tok)
  symOccDecl.push(declNode)
  symOccIsDecl.push(1)
  0
}

// Token-keyed membership set mirroring `symOccTok`, so the dedup guard is O(1)
// instead of a linear scan over every prior occurrence (which made recording the
// occurrence list O(n²)). Reset in lockstep with `symOccTok` (see the check
// preamble) and inserted into at every occurrence append (`symOccRecordTok`).
let symOccTokSet: {[string]: boolean} = Map()

// Record token `tok` into the membership set (mirrors a `symOccTok.push(tok)`).
// Negative tokens are never deduped, matching `symOccHasTok`, so they are skipped.
function symOccRecordTok(tok: i32) {
  if tok < 0 { return 0 }
  symOccTokSet[i32ToStr(tok)] = true
  0
}

// Whether an occurrence at token `tok` is already recorded (the dedup guard).
// O(1) via `symOccTokSet`, kept in sync with `symOccTok` at every append/reset.
function symOccHasTok(tok: i32) {
  if tok < 0 { return false }
  // A member-call cannot be a bare tail expression (the emitter rejects it as a
  // statement) — bind the `.has` result first (see `sliceNode` in format.vl).
  const present = symOccTokSet.has(i32ToStr(tok))
  present
}

// Like `symDecl`, but binds into the ENCLOSING decl scope (one level out from the
// innermost). A function name lives in the scope surrounding its body, yet its
// body scope is already pushed when the params/name are processed — so its
// binding must land one frame up to resolve recursive and sibling references.
function symDeclInOuter(name: string, declNode: i32, ty: i32, kind: i32) {
  if symEnabled == 0 { return 0 }
  const outer = symDeclScope.length - 2
  if outer >= 0 {
    symDeclScope[outer][name] = declNode
  } else if symDeclScope.length > 0 {
    symDeclScope[symDeclScope.length - 1][name] = declNode
  }
  symRetainType(declNode, ty, kind)
  // A function name is visible in the ENCLOSING scope (where it binds), not its
  // body — the decl-scope frame is one out, so its span is one below the top.
  // Stamped before the occurrence dedup (see `symDecl`).
  let outerSpan = scopeSL.length - 2
  if outerSpan < 0 { outerSpan = scopeSL.length - 1 }
  symStampVis(name, declNode, kind, outerSpan)
  let tok = declNameTokOf(declNode)
  if tok < 0 {
    if declNode >= 0 && declNode < nodeToks.length { tok = nodeToks[declNode] }
  }
  if symOccHasTok(tok) { return 0 }
  symOccTok.push(tok)
  symOccRecordTok(tok)
  symOccDecl.push(declNode)
  symOccIsDecl.push(1)
  0
}

// Resolve `name` to its binding's decl node through the decl-scope chain
// (innermost first — mirrors `lookup`), or `-1` if it is not a tracked binding
// (a builtin/intrinsic, or an import seeded with no decl node).
function symResolve(name: string) {
  let i = symDeclScope.length - 1
  while i >= 0 {
    if symDeclScope[i].has(name) { return symDeclScope[i][name] ?? (-1) }
    i = i - 1
  }
  -1
}

// Record a USE occurrence of the identifier node `useNode` (its anchor token IS
// the identifier). Resolves to its binding through the decl-scope chain; a name
// with no tracked binding records nothing (no go-to-def target).
function symUse(useNode: i32, name: string) {
  if symEnabled == 0 { return 0 }
  const decl = symResolve(name)
  if decl < 0 { return 0 }
  let tok = -1
  if useNode >= 0 && useNode < nodeToks.length { tok = nodeToks[useNode] }
  if symOccHasTok(tok) { return 0 }
  symOccTok.push(tok)
  symOccRecordTok(tok)
  symOccDecl.push(decl)
  symOccIsDecl.push(0)
  0
}

// Whether `ty` is an unresolved hole the host's `isHole` would skip (an
// `Infer`/`Unknown` analogue): a generic type variable or an error placeholder.
export function inlayHole(ty: i32) {
  if ty < 0 { return true }
  const t = T.tys[ty]
  if t is TyVar { return true }
  if t is TyErr { return true }
  false
}

// A multi-module compile merges every module's AST, so
// `modOfTok` resolves which file a finding is in; the
// cli keeps only the entry module's (driver wrapper
// `redunModuleAt`).

function redunReset() {
  redunSLine = []
  redunSCol = []
  redunELine = []
  redunECol = []
  redunName = []
  redunType = []
  redunTok = []
  0
}

// Record `let <name>: T = init` as redundant when init's own type == the annotation.
// `declIx` is the LetDecl node (for its name token); `n` carries letName/letInit.
function recordRedundantAnnot(
  n: LetDecl,
  declIx: i32,
  initTy: i32,
  annot: i32,
) {
  // Only a CONCRETE init type that renders identically to the annotation. A hole
  // (empty `[]`/`Map()`, a lone `null`), an error, or `never` is never redundant.
  if inlayHole(initTy) { return 0 }
  if isNeverTy(initTy) { return 0 }
  if annot == TY_ERR { return 0 }
  if !tyEq(initTy, annot) { return 0 }
  const nameTok = declNameTokOf(declIx)
  if nameTok < 0 { return 0 }
  // The fix deletes the annotation, so the span runs from just after the NAME to
  // the assignment `=`. Find that `=` by scanning the tokens between (the
  // annotation can be multi-token — `{[string]: i32}[]`, a function type — so the
  // init node's anchor token is unreliable). It is the first `EQUAL` at bracket
  // depth 0 that is NOT part of `=>` (an `EQUAL` immediately followed by `>`).
  let eqTok = -1
  let depth = 0
  let t = nameTok + 1
  while t < P.toks.length {
    if eqTok < 0 {
      const kd = P.toks[t].kind
      if kd == "LPAREN" || kd == "LBRACK" || kd == "LBRACE" {
        depth = depth + 1
      } else if kd == "RPAREN" || kd == "RBRACK" || kd == "RBRACE" {
        depth = depth - 1
      } else if depth == 0 && kd == "EQUAL" {
        let isArrow = false
        if t + 1 < P.toks.length {
          if P.toks[t + 1].kind == "GT" { isArrow = true }
        }
        if !isArrow { eqTok = t }
      }
    }
    t = t + 1
  }
  if eqTok < 0 { return 0 }
  // Span start = the `:` token (always `nameTok + 1` for an annotated decl). Using
  // the colon's own position — not `nameTok.col + name.length` — is robust to the
  // module merge mangling the binding NAME (`local$m0`), which would otherwise push
  // the start past the `:` into the type.
  const colonTok = nameTok + 1
  if colonTok >= P.toks.length { return 0 }
  redunSLine.push(P.toks[colonTok].line)
  redunSCol.push(P.toks[colonTok].col)
  redunELine.push(P.toks[eqTok].line)
  redunECol.push(P.toks[eqTok].col)
  redunName.push(demangleName(n.letName))
  redunType.push(tyToStr(initTy))
  redunTok.push(nameTok)
  0
}

// Does a return EXPRESSION's type get pinned by the return ANNOTATION (rather than
// inferred on its own)? An empty `[]`/`{}`/`Map()`/`Set()` or a bare `null` resolves
// from the declared return via `T.curRet`, so the annotation is LOAD-BEARING.
function retInfluencedByAnnot(ix: i32) {
  if ix < 0 { return false }
  const nd = P.nodes[ix]
  if nd is ArrayLit { return nd.arrElems.length == 0 }
  if nd is ObjLit { return nd.objFields.length == 0 }
  if nd is NullLit { return true }
  if nd is Call {
    const cn = P.nodes[nd.callFn]
    if cn is Ident {
      if cn.identName == "Map" || cn.identName == "Set" {
        return nd.callArgs.length == 0
      }
    }
  }
  false
}

// Record a redundant RETURN-type annotation (`function f(): T { … }` whose body's
// inferred return already IS T) into the same finding stream the `let` rule uses. The
// fix deletes the `: T` between the params `)` and the body `{`. Both span ends are
// TOKEN-INDEX scans (robust in a merged multi-module compile): the colon is the first
// `COLON` at bracket depth 0 scanning from the function NAME; the body `{` is the
// token at the block's source offset, scanned FORWARD from the colon. An OBJECT return
// is excluded — a named/structural struct emits as a WasmGC ref whose inferred type
// can be tyToStr-equal yet not emit-identical (`peekTok(): Tok`).
function recordRedundantRet(n: FuncDecl, fnIx: i32, ret: i32) {
  // Only SCALAR/STRING returns — the categories the emitter default + `A20` classify
  // for an un-annotated function. Object / array / union / nullable returns can
  // mis-lower (the emitter re-derives them from the return expression), so keep those.
  const rnm = tyToStr(ret)
  if !isClassifiableRetName(rnm) { return 0 }
  // Skip GENERIC functions (an un-annotated param is a per-call-site hole; `A20` does
  // not elaborate them, so a removed string return could mis-lower).
  let gi = 0
  while gi < n.fnParams.length {
    const gpn = P.nodes[n.fnParams[gi]]
    if gpn is Param {
      if gpn.parType < 0 { return 0 }
    }
    gi = gi + 1
  }
  const nameTok = declNameTokOf(fnIx)
  if nameTok < 0 { return 0 }
  let colonTok = -1
  let depth = 0
  let ci = nameTok + 1
  while ci < P.toks.length && colonTok < 0 {
    const kd = P.toks[ci].kind
    if kd == "LPAREN" || kd == "LBRACK" || kd == "LBRACE" {
      depth = depth + 1
    } else if kd == "RPAREN" || kd == "RBRACK" || kd == "RBRACE" {
      depth = depth - 1
    } else if depth == 0 && kd == "COLON" {
      colonTok = ci
    }
    ci = ci + 1
  }
  if colonTok < 0 { return 0 }
  const bn = P.nodes[n.fnBody]
  if !(bn is Block) { return 0 }
  if bn.pos < 0 { return 0 }
  let braceTok = -1
  let bi = colonTok + 1
  while bi < P.toks.length && braceTok < 0 {
    if P.toks[bi].start == bn.pos { braceTok = bi }
    bi = bi + 1
  }
  if braceTok < 0 { return 0 }
  redunSLine.push(P.toks[colonTok].line)
  redunSCol.push(P.toks[colonTok].col)
  redunELine.push(P.toks[braceTok].line)
  redunECol.push(P.toks[braceTok].col)
  redunName.push(demangleName(n.fnName))
  redunType.push(tyToStr(ret))
  redunTok.push(nameTok)
  0
}

// Record a member-access node's resolved type + its property-name span, keyed by
// the node (last write wins — a re-check during demand-inference overwrites the
// hole with the pinned type). A no-op unless `symEnabled` and the type resolved.
// Returns `ty` so it can wrap a member arm's return: `return symMem(ix, ft)`.
function symMem(ix: i32, ty: i32) {
  if symEnabled == 0 { return ty }
  if ty < 0 { return ty }
  if ix < 0 || ix >= nodeToks.length { return ty }
  const tk = nodeToks[ix]
  if tk < 0 || tk >= P.toks.length { return ty }
  const t = P.toks[tk]
  // Property-name length, to bound the span the cursor must fall within.
  let pl = 0
  const nd = P.nodes[ix]
  if nd is Member { pl = nd.memProp.length }
  else if nd is OptMember { pl = nd.omProp.length }
  let i = 0
  while i < symMemNode.length {
    if symMemNode[i] == ix {
      symMemTy[i] = ty
      return ty
    }
    i = i + 1
  }
  symMemNode.push(ix)
  symMemTy.push(ty)
  symMemLine.push(t.line)
  symMemCol.push(t.col)
  symMemEndCol.push(t.col + pl)
  ty
}

// Record a method-CALL callee member name (`xs.push`, `m.set`, `s.slice`) for
// semantic tokens. A method call's callee never flows through the member-read
// arm (the builtin arms type and return it directly), so `symMem` never sees it;
// this records its property-name span, classified as a `method`. A later `symMem`
// for the same node (a struct field holding a function, resolved via the call's
// fall-through) overwrites the type so member hover still works for that case.
function symMemMethod(ix: i32) {
  if symEnabled == 0 { return ix }
  if ix < 0 || ix >= nodeToks.length { return ix }
  const tk = nodeToks[ix]
  if tk < 0 || tk >= P.toks.length { return ix }
  const t = P.toks[tk]
  let pl = 0
  const nd = P.nodes[ix]
  if nd is Member { pl = nd.memProp.length }
  else if nd is OptMember { pl = nd.omProp.length }
  let i = 0
  while i < symMemNode.length {
    if symMemNode[i] == ix { return ix }
    i = i + 1
  }
  symMemNode.push(ix)
  symMemTy.push(SYM_MEM_METHOD)
  symMemLine.push(t.line)
  symMemCol.push(t.col)
  symMemEndCol.push(t.col + pl)
  ix
}

// Strip a module-merge mangling suffix (`add$m1` → `add`) so an imported name
// shows under its SOURCE name in completion. The merge appends `$m<N>` (N = the
// module table index) to every cross-module name; `$` is not a legal identifier
// char (the lexer forbids it), so the first `$` marks the suffix. A name without
// a `$` (every single-file / same-module binding) is returned unchanged.
export function demangleName(nm: string) {
  let i = 0
  while i < nm.length {
    if nm[i] == '$' { return nm.slice(0, i) }
    i = i + 1
  }
  nm
}

// Strip every `$m<digits>` MODULE-MERGE mangle suffix from a free-form diagnostic MESSAGE
// — the merge renames a module's declarations `name` → `name$mN` (N = its table index),
// an internal name that must not surface to the user. `$` is not a valid source identifier
// char (the lexer), so the pattern is unambiguous. The message analogue of `demangleName`
// (which strips a BARE name): a message embeds the name mid-text, and `tyToStr` can embed a
// mangled TYPE name too (`Box$m1<i32>`), so both are cleaned by one pass over the text.
export function demangleMsg(s: string) {
  const out: i32[] = []
  let i = 0
  while i < s.length {
    if (
      s[i] == '$' &&
      i + 2 < s.length &&
      s[i + 1] == 'm' &&
      s[i + 2] >= '0' &&
      s[i + 2] <= '9'
    ) {
      i = i + 2
      while i < s.length && s[i] >= '0' && s[i] <= '9' { i = i + 1 }
    } else {
      out.push(s[i])
      i = i + 1
    }
  }
  fromCodePoints(out)
}

// Bind `name` to type-arena index `ty` in the innermost scope.
export function declare(name: string, ty: i32) {
  const top = T.scopes.length - 1
  T.scopes[top][name] = ty
  0
}

// Look `name` up through the scope chain, innermost first. Returns its type-arena
// index, or `-1` if undeclared (innermost-wins, so shadowing works).
export function lookup(name: string) {
  let i = T.scopes.length - 1
  while i >= 0 {
    if T.scopes[i].has(name) { return T.scopes[i][name] ?? -1 }
    i = i - 1
  }
  -1
}

// Raise a diagnostic at AST node `at`, resolving its source position (the
// node's anchor token via the `nodeToks` side table) eagerly so the driver can
// render `line:col: message`. Every lookup is BOUNDS-CHECKED: a harness that
// builds `P.nodes` by hand (or resets it without resetting `nodeToks`) yields
// an out-of-range index, which degrades to "no position" (`tline == 0`), never
// a trap.
export function tErr(msg: string, at: i32) { tErrCoded(msg, at, "") }

// The EMITTER-CAPABILITY channel: raise an error for a construct the type
// system ACCEPTS but codegen cannot lower yet, under the stable
// `unsupported-lowering` category code. Keeps codegen maturity out of the type
// system's verdict vocabulary: a `tErr` says "this program is type-invalid", a
// `tErrUnsupported` says "this program is type-valid but cannot build". Both
// are errors (an unbuildable program must not pass), but tooling can tell them
// apart by code. Message convention: name the type-valid construct, then the
// workaround after an em dash.
function tErrUnsupported(msg: string, at: i32) {
  tErrCoded(msg, at, CODE_UNSUPPORTED_LOWERING)
}

function tErrCoded(msg: string, at: i32, code: string) {
  let ln = 0
  let co = 0
  if at >= 0 && at < nodeToks.length {
    const tk = nodeToks[at]
    if tk >= 0 && tk < P.toks.length {
      const t = P.toks[tk]
      ln = t.line
      co = t.col
    }
  }
  // An EXACT repeat (same message, same anchor) is noise, not information — two
  // passes can resolve the same annotation (the pass-1.5 hoist and the real pass
  // both report a generic-alias arity/bare-use error, identically positioned).
  // Drop the repeat; the diagnostic count stays small, so the scan is cheap.
  let di = 0
  while di < T.diags.length {
    const d = T.diags[di]
    if d.tat == at && d.tmsg == msg { return 0 }
    di = di + 1
  }
  T.diags.push({ tmsg: msg, tat: at, tline: ln, tcol: co, tcode: code })
  0
}

// ── small numeric / string helpers (no union narrowing) ──────────────────────

// Is type-arena index `ix` the `string` primitive?
function isStringTy(ix: i32) {
  if ix < 0 { return false }
  const t = T.tys[ix]
  if t is TyPrim { return t.primName == "string" }
  false
}

// Is type-arena index `ix` a numeric primitive (i32/i64/f32/f64)? A `TyErr` or
// `TyVar` placeholder also counts, so a checking failure or unresolved hole
// doesn't cascade a spurious "not a number" error.
function isNumeric(ix: i32) {
  if ix < 0 { return false }
  const t = T.tys[ix]
  if t is TyErr { return true }
  if t is TyVar { return true }
  if t is TyPrim {
    return t.primName == "i32" ||
      t.primName == "i64" ||
      t.primName == "f64" ||
      t.primName == "f32"
  }
  false
}

// The bare primitive name of type-arena index `ix`, or "" if it is not a primitive.
function primNameOf(ix: i32) {
  if ix < 0 { return "" }
  const t = T.tys[ix]
  if t is TyPrim { return t.primName }
  ""
}

// Numeric WIDENING lattice (B2): may a value of primitive type `sn` implicitly
// flow into a `dn`-typed slot? Only the LOSSLESS edges are permitted:
//   i32 → i64,  i32 → f64,  f32 → f64
// (plus every type to itself). Each preserves the value exactly. Codegen inserts
// the matching wasm convert at the boundary. Keyed on bare names so it is a pure
// value-lattice query independent of arena identity.
//
// REJECTED — needing an explicit conversion VL has no syntax for yet:
//   i32 → f32  (above 2^24 the i32 rounds to the nearest f32 — lossy)
//   i64 → f64  (above 2^53 the i64 rounds to the nearest f64 — lossy)
// plus every narrowing (i64→i32, f64→f32, …) and any float→integer (truncation).
function numWidensName(sn: string, dn: string) {
  if sn == dn { return false }
  if sn == "i32" {
    if dn == "i64" || dn == "f64" { return true }
  }
  if sn == "f32" {
    if dn == "f64" { return true }
  }
  false
}

// True when `src`→`dst` is an implicit numeric widening (see `numWidensName` —
// the lossless edges only; i32→f32 / i64→f64 are rejected as lossy).
function numWidens(src: i32, dst: i32) {
  numWidensName(primNameOf(src), primNameOf(dst))
}

// Are `a` and `b` two numeric operands of DIFFERENT but compatible types, so a mixed
// arithmetic/comparison widens the narrower side to the wider one? True exactly when
// one operand widens to the other (either direction). The shared op type
// is then the WIDER of the two (`widerNumeric`).
function mixesNumeric(a: i32, b: i32) {
  if numWidens(a, b) { return true }
  if numWidens(b, a) { return true }
  false
}

// The WIDER of two mixed numeric operands (the result/op type): whichever the other
// widens INTO. Caller guarantees `mixesNumeric(a, b)`.
function widerNumeric(a: i32, b: i32) {
  if numWidens(a, b) { return b }
  a
}

// Do two numeric type indices denote the SAME numeric type?
export function sameNumeric(a: i32, b: i32) {
  const ta = T.tys[a]
  const tb = T.tys[b]
  if ta is TyErr { return true }
  if tb is TyErr { return true }
  if ta is TyVar { return true }
  if tb is TyVar { return true }
  if ta is TyPrim {
    if tb is TyPrim { return ta.primName == tb.primName }
  }
  false
}

// Is the EXPRESSION at `ix` (peeling parens) a float `.` NUMBER literal? A float
// literal is polymorphic across the float types: it types f64 by default but
// re-encodes EXACTLY into an f32 slot, so a float literal flowing into an `f32`
// binding/operand is accepted (the demote that a general f64 value would need is
// never performed — the literal is encoded at f32 directly). Integer literals are
// NOT covered here (they ride the i32→{i64,f32,f64} widening lattice).
function isFloatLitExpr(ix: i32) {
  if ix < 0 { return false }
  const e = P.nodes[ix]
  if e is Paren { return isFloatLitExpr(e.parInner) }
  // A unary-minus over a float literal (`-1.5`) is still a float LITERAL — it
  // re-encodes exactly at f32 (negation is exact in IEEE-754), so it flows into any
  // f32 position the positive literal would (`f32 = -1.5`, `f32[] = [-1.5]`, an f32
  // map value / union atom / field). Without this a leading `-` made the value a
  // plain f64 expression, rejected as a lossy demote.
  if e is Unary {
    if e.unOp == "-" { return isFloatLitExpr(e.unArg) }
  }
  // A literal whose magnitude overflows f32 does NOT re-encode at f32 (it would
  // encode ±infinity), so it gets no f32 grant — it takes the normal
  // f64-value-into-f32 lossy-demote rejection at the flow site.
  if e is NumLit {
    if !hasDot(e.numText) { return false }
    return !f32LitOverflows(e.numText)
  }
  false
}

// The least upper bound used by `??` (host: `flatten(Union(nonNull(l), r))`):
// mutually-assignable types collapse to the wider; otherwise a two-member union.
function joinTys(a: i32, b: i32) {
  if a < 0 { return b }
  if b < 0 { return a }
  if assignable(b, a) { return a }
  if assignable(a, b) { return b }
  // Distinct variants: a FLATTENED, deduped union (nullability folds back
  // into a `?` wrapper) — mirrors the host's `flattenType(Union(...))`.
  const vars: i32[] = []
  flattenVariantsInto(a, vars)
  flattenVariantsInto(b, vars)
  const kept: i32[] = []
  let hasNull = false
  let i = 0
  while i < vars.length {
    const v = vars[i]
    if isNullTy(v) {
      hasNull = true
    } else {
      let dup = false
      let j = 0
      while j < kept.length {
        if kept[j] == v { dup = true }
        if sameVariantTy(kept[j], v) { dup = true }
        j = j + 1
      }
      if !dup { kept.push(v) }
    }
    i = i + 1
  }
  if kept.length == 0 { return TY_NULL }
  let res = kept[0]
  if kept.length > 1 {
    res = mkUnionTy(kept)
    // A joined litunion alias (`if c then k1 else k2`, `k ?? "a"` — both sides
    // the same alias / a member of it) re-mints the alias as a COPY; the
    // subset gate inside the stamp rejects a join that widened PAST it (b1).
    noteLitUnionCopy(res, a)
    noteLitUnionCopy(res, b)
  }
  if hasNull { return mkNullableTy(res) }
  res
}

// Whether the expression is a bare `true`/`false` literal (through parens) —
// excluded from the A7 boolean→i32 value coercion (a literal in an i32 slot is
// more likely a mistake; write `1`/`0`).
function isBoolLitExpr(ix: i32) {
  if ix < 0 { return false }
  const e = P.nodes[ix]
  if e is Paren { return isBoolLitExpr(e.parInner) }
  if e is BoolLit { return true }
  false
}

// True if `dstTy` has an f32 POSITION a float literal can re-encode into: a bare `f32`, a
// nullable `f32?` (the inner), or any f32 member of a union (recursively).
function dstAdmitsF32(dstTy: i32) {
  if dstTy < 0 { return false }
  if primNameOf(dstTy) == "f32" { return true }
  const t = T.tys[dstTy]
  if t is TyNullable { return dstAdmitsF32(t.nInner) }
  if t is TyUnion {
    let i = 0
    while i < t.uMembers.length {
      if dstAdmitsF32(t.uMembers[i]) { return true }
      i = i + 1
    }
    return false
  }
  false
}

// Does function type `tyIx` carry an inference HOLE — a `TyVar` param or return? Such a type is a
// GENERIC (capability-bounded) function value (`(a, b) => a + b`), not a concrete signature.
function fnTyHasHole(tyIx: i32) {
  const t = T.tys[tyIx]
  if t is TyFunc {
    const ps = t.fnParamTypes
    let i = 0
    while i < ps.length {
      if tyIsHole(ps[i]) { return true }
      i = i + 1
    }
    return tyIsHole(t.fnRet)
  }
  false
}

// Do every deferred binary-op constraint THIS binding resolves hold (the capability check, as a
// pure boolean — `validateBinCstrs` is the diagnostic-emitting twin)? A constraint still touching
// an unbound hole defers (true here).
function binCstrsHold(bNames: string[], bTys: i32[]) {
  let ci = 0
  while ci < binCstrOp.length {
    const clt = substTyDeep(binCstrLt[ci], bNames, bTys)
    const crt = substTyDeep(binCstrRt[ci], bNames, bTys)
    if !tyIsHole(clt) {
      if !tyIsHole(crt) {
        if !binOpDefinedFor(binCstrOp[ci], clt, crt) { return false }
      }
    }
    ci = ci + 1
  }
  true
}

// Is a GENERIC function value of type `srcTy` (hole params/return) assignable to the CONCRETE
// function type `dstTy`? Instantiate it at `dstTy`'s param types (bind the holes), require the
// body's capability to hold there and the substituted return to match `dstTy`'s return — exactly
// the per-call-site instantiation, but driven by the target type. This governs every typed boundary
// a generic function value meets (an annotated binding/param/return/element); the emitter then
// materializes that instance (`monoInstanceFor`). The permissive structural `assignable` (which a
// hole passes unconditionally) would wrongly accept a return/capability mismatch that cannot lower.
function genericFnAssignable(srcTy: i32, dstTy: i32) {
  const s = T.tys[srcTy]
  const d = T.tys[dstTy]
  if s is TyFunc {
    if d is TyFunc {
      const sp = s.fnParamTypes
      const dp = d.fnParamTypes
      if sp.length != dp.length { return false }
      const bNames: string[] = []
      const bTys: i32[] = []
      let i = 0
      while i < sp.length {
        bindGenWalk(sp[i], dp[i], bNames, bTys)
        if !assignable(dp[i], sp[i]) { return false }
        i = i + 1
      }
      if !binCstrsHold(bNames, bTys) { return false }
      if !argCstrsHold(bNames, bTys) { return false }
      return assignable(substTyDeep(s.fnRet, bNames, bTys), d.fnRet)
    }
  }
  false
}

// Whether a struct type is SOUND to box into a value union via a WIDENING struct
// literal (`{f: 97.5}` into `{f: f32} | {w: i32}` — the checker adopts the arm,
// the emitter boxes the plain struct into the union rep). Restricted to structs
// whose every field is a primitive scalar / string / boolean, or a nested plain
// struct: the emitter boxes exactly those into a union today. A field that is
// itself a LITUNION (or any other composite needing its own boxed rep) has no
// such union-boxed rep yet — adopting it would emit INVALID wasm — so those arms
// stay a loud reject (the emit-rep work is the sibling agents' territory).
function unionArmBoxSafe(tyIx: i32) {
  const t = T.tys[tyIx]
  if !(t is TyObj) { return false }
  const ftys = t.objFieldTypes
  let i = 0
  while i < ftys.length {
    const ft = T.tys[ftys[i]]
    if ft is TyPrim {
      // scalar / string / boolean field — boxes cleanly
    } else if ft is TyObj {
      if !unionArmBoxSafe(ftys[i]) { return false }
    } else if tyIsLitUnion(ftys[i]) {
      // A literal-union field (`f: K0`) boxes as its interned i32 ATOM: the variant
      // tables record the union name (`uFieldElemName`, the `sFieldElemName` twin) and
      // the variant construct path lowers a member literal as its atom id — the same
      // rep the plain struct field carries.
    } else if T.tys[ftys[i]] is TyFunc {
      // A bare FUNCTION-typed field (`f: (i32) => K0`) boxes as the closure fat-pointer
      // (code 14) — the variant construct passes the lambda through, and the narrowed
      // member call routes to `call_ref` (`exprIsClosure`'s variant-member arm). A
      // NULLABLE closure field stays out (its arm rep is not yet proven here).
    } else if ft is TyNullable {
      // A NULLABLE-litunion field (`f: K0 | null`, the code-30 i32 niche with the -1
      // sentinel) and a nullable-f32 field (`f: f32 | null`, the code-16 value box the
      // plain struct field already carries) both box: the variant construct path
      // threads the same per-code arms the plain struct-literal path uses. Other
      // nullable field types keep their loud reject (their variant rep is unproven).
      const nfi = ft.nInner
      if nfi < 0 { return false }
      if !(tyIsLitUnion(nfi) || primNameOf(nfi) == "f32") { return false }
    } else {
      return false
    }
    i = i + 1
  }
  true
}
// Literal-aware assignability for a numeric binding/argument/return: the normal
// `assignable` lattice, PLUS the float-literal→f32 exception (`isFloatLitExpr`). Used
// where the SOURCE EXPRESSION node is in hand (so the literal can be recognized);
// type-only sites keep using `assignable`.
// Record the destination ARRAY type on an ArrayLit source whose element target is a
// NICHE-nullable scalar (`K | null` / `boolean | null` / `string | null`), peeling a
// nullable destination wrapper (`(K|null)[] | null`) and grouping parens. Runs BEFORE
// `assignableExpr`'s plain-assignable short-circuit: `[null]` infers `null[]`, which IS
// covariantly assignable, so the literal-aware adoption block (where the litunion-array
// recording lives) is never reached for it — yet the recorded type is the emitter's ONLY
// classification signal for a literal with no rep-classifying element (all-`null`, or a
// string-first `["x", null]` that would else claim the plain string list).
function recordNicheNulElemArrayLit(srcExpr: i32, dstTy: i32) {
  if inferQuiet || srcExpr < 0 || dstTy < 0 { return 0 }
  let dtix = dstTy
  const dN = T.tys[dtix]
  if dN is TyNullable { dtix = dN.nInner }
  // An UNFILLED A-infer-null hole (`let x = null`) peels to no inner — nothing to record
  // (indexing the arena at -1 traps the compiler).
  if dtix < 0 { return 0 }
  const d = T.tys[dtix]
  if d is TyArray {
    if tyIsNicheNulScalarElem(d.aElem) {
      const e = P.nodes[srcExpr]
      if e is Paren {
        // Record on the WRAPPING Paren too, not only the inner literal: the emitter's
        // typed-IR fast paths (`exprStringArray` and siblings) consult whichever node a
        // consumer holds — a Paren keeping its stale pre-adoption record (`string[]`)
        // would re-claim the wrong rep at the closure-result classification.
        if recordNicheNulElemArrayLit(e.parInner, dtix) == 1 {
          while nodeTyIx.length <= srcExpr { nodeTyIx.push(-1) }
          nodeTyIx[srcExpr] = dtix
          return 1
        }
        return 0
      }
      if e is ArrayLit {
        while nodeTyIx.length <= srcExpr { nodeTyIx.push(-1) }
        nodeTyIx[srcExpr] = dtix
        return 1
      }
    }
  }
  0
}
export function assignableExpr(srcExpr: i32, srcTy: i32, dstTy: i32) {
  // (A GENERIC function value meeting a CONCRETE function type is decided by instantiation inside
  // `assignable`'s `TyFunc` case — `genericFnAssignable` — so it governs nested positions like an
  // array element too, not just this expression-level entry.)
  recordNicheNulElemArrayLit(srcExpr, dstTy)
  if assignable(srcTy, dstTy) { return true }
  // A float literal re-encodes EXACTLY at f32, so it flows into any destination whose f32
  // position it fits: a bare `f32`, a nullable `f32?` (a map value / niche), or an f32 MEMBER
  // of a union (`f32 | string`). An arbitrary f64 VALUE is NOT covered (that is a lossy demote).
  if isFloatLitExpr(srcExpr) {
    if dstAdmitsF32(dstTy) { return true }
  }
  // (A float-literal array → `f32[]`, and any literal array adapting element-wise, is handled by
  // the `ArrayLit` recursion in the literal-aware block below — the array dual of the ObjLit case.)
  // `boolean`-where-`i32`-expected coercion (A7): a boolean-typed VALUE flows
  // into an i32 slot as 1/0 (a no-op in codegen — boolean rides in an i32).
  // One-directional, and a bare `true`/`false` LITERAL is excluded.
  if primNameOf(dstTy) == "i32" {
    if primNameOf(srcTy) == "boolean" && !isBoolLitExpr(srcExpr) { return true }
  }
  // LITERAL-typed destination (host: a literal expression carries its own
  // literal type): a bare literal flows wherever its LITERAL type is a member
  // (`"a"` into `"a" | "b"`), even though its softened base (`string`) does not.
  if srcExpr >= 0 {
    const lTy = litTyOfExpr(srcExpr)
    if lTy >= 0 {
      if assignable(lTy, dstTy) { return true }
    }
    // An OBJECT LITERAL checks field-wise against a literal-bearing object
    // target, so a field's bare literal can match a literal-union field
    // (`{tag: "circle", r: 5}` against `{tag: "circle" | "square", r: i32}`).
    const e = P.nodes[srcExpr]
    if e is Paren { return assignableExpr(e.parInner, srcTy, dstTy) }
    if e is ObjLit {
      const s = T.tys[srcTy]
      if s is TyObj {
        // A nullable struct target (`S | null` / a `V?` map value) peels its wrapper so an object
        // literal still adapts field-wise into the inner struct — the ObjLit dual of the ArrayLit
        // nullable peel below (without it a float-literal `f32` field, a litunion field, or an
        // omitted-nullable field fails to coerce through the `| null`). The peel ITERATES: a
        // nullable-VALUE map slot (`{[string]: S | null}` — the stored `V?` over `S | null`)
        // stacks two wrappers, and a single unwrap left the literal against `S | null`.
        let dtix = dstTy
        let dPeel = true
        while dPeel {
          const dNW = T.tys[dtix]
          if dNW is TyNullable { dtix = dNW.nInner } else { dPeel = false }
        }
        const d = T.tys[dtix]
        if d is TyObj {
          const dnames = d.objFieldNames
          const dtys = d.objFieldTypes
          let i = 0
          let ok = true
          while i < dnames.length {
            const sft = objFieldType(s, dnames[i])
            if sft < 0 {
              // COMPLETION COERCION: an object literal may OMIT a field whose declared
              // type ADMITS null — the field is materialized as `null` at construction
              // (`let cat: Cat = { meow: 7 }` with `foo: i32 | null`). A non-nullable
              // omitted field is still required. Scoped to this EXPRESSION-aware path (an
              // object LITERAL against a known target), NOT general structural
              // assignability — so it never widens through a container / variance.
              if !tyAdmitsNull(dtys[i]) { ok = false }
            } else {
              // The field's VALUE expression, for the literal-aware recursion.
              let fexpr = -1
              const fl = e.objFields
              let fi = 0
              while fi < fl.length {
                const fn = P.nodes[fl[fi]]
                if fn is FieldInit {
                  if fn.fiName == dnames[i] { fexpr = fn.fiValue }
                }
                fi = fi + 1
              }
              if !assignableExpr(fexpr, sft, dtys[i]) { ok = false }
            }
            i = i + 1
          }
          return ok
        }
        // A struct literal flowing into a UNION adopts the FIRST struct arm it adapts
        // into field-wise (`{f: 97.5}` into `{f: f32} | {w: i32}`, `{a: 3.5, f: "x", …}`
        // into `{a: f32, f: K, …} | string`). The emitter already boxes a struct literal
        // into a union slot at a direct binding (the i32-field spelling lowers today); this
        // is the checker seam that lets a WIDENING field (a float-literal `f32`, a litunion
        // member) reach that same rep. Record the concrete arm on the literal node so the
        // shape interner / field encoder sees the arm's field types, not the inferred ones.
        if d is TyUnion {
          const members = d.uMembers
          let mi = 0
          while mi < members.length {
            const mt = T.tys[members[mi]]
            if mt is TyObj && unionArmBoxSafe(members[mi]) {
              if assignableExpr(srcExpr, srcTy, members[mi]) {
                if !inferQuiet {
                  while nodeTyIx.length <= srcExpr { nodeTyIx.push(-1) }
                  nodeTyIx[srcExpr] = members[mi]
                }
                return true
              }
            }
            mi = mi + 1
          }
        }
      }
    }
    // An array LITERAL checks element-wise against the target's element type, so a bare element
    // adapts exactly as it would at a binding — the array analogue of the ObjLit recursion above.
    // This SUBSUMES the scalar float-literal → `f32[]` rule and generalizes it to ANY element
    // type and ANY nesting depth: a float-literal element fits `f32[]`, an object-literal element
    // with an `f32` field fits `{x: f32}[]`, and a nested literal recurses (`[[1.5]]` → `f32[][]`).
    // An empty `[]` fits any element type (the loop does not run). An arbitrary non-literal value
    // element is NOT widened — the per-element `assignableExpr` still rejects a lossy f64 demote.
    if e is ArrayLit {
      // A map value / niche slot is `V?` (`{[string]: f32[]}` seeds `f32[]?`) — peel the nullable
      // wrapper(s) so a literal array still adapts into the inner element type (a nullable-VALUE
      // map slot stacks two wrappers; iterate like the ObjLit peel above).
      let dtix = dstTy
      let dPeel = true
      while dPeel {
        const dNW = T.tys[dtix]
        if dNW is TyNullable { dtix = dNW.nInner } else { dPeel = false }
      }
      const d = T.tys[dtix]
      if d is TyArray {
        let i = 0
        let ok = true
        while i < e.arrElems.length {
          if (
            !assignableExpr(e.arrElems[i], nodeTyIxOf(e.arrElems[i]), d.aElem)
          ) {
            ok = false
          }
          i = i + 1
        }
        // CONTEXT ADOPTION (atom lists): a literal array accepted by a literal-union
        // element target IS that atom list (`const ks: VK[] = ["aa", "bb"]`) — record the
        // destination array type on the literal node so the emitter classifies it as the
        // i32 atom-id list (`nodeArrayElemIsLitUnion`). Its member elements are string
        // exprs syntactically, so the literal's own recorded type is `string[]`, which
        // would else claim the string-list rep at every seam (slot, collect, construct).
        // The NICHE-nullable scalar elements (`K | null` / `boolean | null` / `string |
        // null`) record the same way: an all-`null` `[null]` self-infers as `null[]` (no
        // classifying element exists), so the recorded type is the ONLY signal the
        // emitter's element probes (`nodeArrayElemIsNulLitUnion` / `…NulBool` /
        // `…NulStr`) have at a position with no threaded annotation (a lambda body, an
        // argument) — one signal, every position.
        if (
          ok &&
          !inferQuiet &&
          (tyIsLitUnion(d.aElem) || tyIsNicheNulScalarElem(d.aElem))
        ) {
          if srcExpr < nodeTyIx.length { nodeTyIx[srcExpr] = dtix }
        }
        return ok
      }
      // An array literal flowing into a UNION adopts the FIRST array arm it adapts into
      // element-wise (`["a"]` into `K0[] | {w: i32}`, `[1.5]` into `f32[] | i64`) — the
      // array dual of the ObjLit union-arm adoption above. The concrete arm is RECORDED
      // on the literal node so the emitter classifies the list with the arm's element
      // rep (an atom-id list, an f32 list), not the literal's softened one (`string[]` /
      // `f64[]`), and the union box tags the arm the checker picked.
      if d is TyUnion {
        const members = d.uMembers
        let mi = 0
        while mi < members.length {
          const mt = T.tys[members[mi]]
          if mt is TyArray {
            // An `f32[]` arm adopts like any other list arm: the f32-list value atom
            // (kind 12) gives the box a real rep, and the emitter's coerce re-encodes
            // the literal's f64-classified elements at f32 (`coerceListKind` 7).
            if assignableExpr(srcExpr, srcTy, members[mi]) {
              if !inferQuiet {
                while nodeTyIx.length <= srcExpr { nodeTyIx.push(-1) }
                nodeTyIx[srcExpr] = members[mi]
              }
              return true
            }
          }
          mi = mi + 1
        }
      }
    }
  }
  false
}

// Does `s` contain a "." (so a number literal is a float)? Indexing a string
// yields the i32 char CODE, so the comparison is against the char literal `'.'`.
function hasDot(s: string) {
  let i = 0
  while i < s.length {
    if s[i] == '.' { return true }
    i = i + 1
  }
  false
}

// Does the non-negative integer LEXEME `t` (decimal / `0x` hex / `0b` binary /
// `0o` octal, `_` separators skipped) fit the i32 range [0, 2147483647]? Ports
// the host's `defaultIntegerType` magnitude rule (typecheck.ts): an un-annotated
// integer literal defaults to i32 when its value fits, else widens to i64 —
// defaulting an out-of-range literal to i32 would silently wrap (0xDEAD_BEEF).
// A `NumLit` lexeme never carries a sign (unary minus is a separate node), so
// only the positive bound is checked. Digits fold with a pre-multiply overflow
// guard (`v > (max - d) / base`) instead of 64-bit arithmetic.
export function intLexemeFitsI32(t: string) {
  let v = 0
  let i = 0
  let base = 10
  if t.length >= 2 && t[0] == '0' {
    const p = t[1]
    if p == 'x' || p == 'X' {
      base = 16
      i = 2
    } else if p == 'b' || p == 'B' {
      base = 2
      i = 2
    } else if p == 'o' || p == 'O' {
      base = 8
      i = 2
    }
  }
  while i < t.length {
    const c = t[i]
    if c == '_' {
      i = i + 1
    } else {
      let d = 0
      if c >= '0' && c <= '9' { d = c - '0' }
      else if c >= 'a' && c <= 'f' { d = c - 'a' + 10 }
      else { d = c - 'A' + 10 }
      if v > (2147483647 - d) / base { return false }
      v = v * base + d
      i = i + 1
    }
  }
  true
}

// Is the integer LEXEME's magnitude EXACTLY 2^31 (2147483648)? The host PARSER
// folds a negated literal into a signed literal before defaulting (`-${text}`,
// parser.ts), so `-2147483648` / `-0x8000_0000` sits AT I32_MIN and defaults to
// i32 — even though the bare magnitude is one past I32_MAX. The unary `-` arm
// uses this for parity. Compares the significant digits (base prefix, `_`
// separators and leading zeros stripped) against 2^31 written in the lexeme's
// base; hex letters never match a decimal digit char, so no case folding needed.
export function intLexemeIs2Pow31(t: string) {
  let digits = "2147483648"
  let i = 0
  if t.length >= 2 && t[0] == '0' {
    const p = t[1]
    if p == 'x' || p == 'X' {
      digits = "80000000"
      i = 2
    } else if p == 'b' || p == 'B' {
      digits = "10000000000000000000000000000000"
      i = 2
    } else if p == 'o' || p == 'O' {
      digits = "20000000000"
      i = 2
    }
  }
  let started = false
  let j = 0
  while i < t.length {
    const c = t[i]
    if c == '_' {
      i = i + 1
    } else if !started && c == '0' {
      i = i + 1
    } else {
      started = true
      if j >= digits.length { return false }
      if c != digits[j] { return false }
      i = i + 1
      j = j + 1
    }
  }
  j == digits.length
}

// Is the EXPRESSION at `ix` (peeling parens) an INTEGER literal of magnitude
// exactly 2^31 — the one operand whose NEGATION fits i32 while the bare literal
// does not? Companion of `intLexemeIs2Pow31` for the unary `-` arm.
function isNegI32MinLit(ix: i32) {
  if ix < 0 { return false }
  const e = P.nodes[ix]
  if e is Paren { return isNegI32MinLit(e.parInner) }
  if e is NumLit {
    if hasDot(e.numText) { return false }
    return intLexemeIs2Pow31(e.numText)
  }
  false
}

// Map a written type NAME to its type-arena index (a primitive, or TY_ERR for an
// unknown name). Takes the bare NAME — NOT a `Node` index — so it never narrows
// the `Node` union (see Finding 2). The single caller (`checkNode`) extracts the
// `TypeRef`'s name inline before calling this.
// Skip a QUOTED string-literal segment inside a synthetic type name (the
// cursor is ON the opening `"`): returns the index just past the closing
// quote. A `\` escape skips the next char, so an escaped quote stays inside.
// Every depth-aware name scanner calls this so a literal member's characters
// (`"a|b"`) never count as separators or depth.
function skipQuotedName(name: string, start: i32) {
  let i = start + 1
  while i < name.length {
    const c = name[i]
    if c == '\\' { i = i + 2 }
    else if c == '"' { return i + 1 }
    else { i = i + 1 }
  }
  i
}

// True if the type name contains the TOP-LEVEL separator `sep` (`|` for an
// inline-union synthetic name `A|B|null`, `&` for an intersection `A&B`).
// Depth-aware: a separator inside `{…}`/`[…]`/`(…)` (an inline-object field's
// own union type, a map value, a parenthesized group) or inside a quoted
// literal member does NOT make the whole name a union/intersection.
function nameHasSep(name: string, sep: i32) {
  let depth = 0
  let i = 0
  while i < name.length {
    const c = name[i]
    if c == '"' {
      i = skipQuotedName(name, i)
    } else {
      if c == '{' || c == '[' || c == '(' { depth = depth + 1 }
      else if c == '}' || c == ']' || c == ')' { depth = depth - 1 }
      else if c == sep && depth == 0 { return true }
      i = i + 1
    }
  }
  false
}

function nameHasPipe(name: string) { nameHasSep(name, '|') }

// The index of a TOP-LEVEL `=>` (`=` at depth 0, followed by `>`) in `name`, or -1 — the
// FUNCTION-TYPE marker the parser emits for `(params) => ret`. Depth/quote-aware, so an
// arrow nested in a param/return group (`((i32) => i32) => void`) is NOT the top one.
function topLevelArrowIndex(name: string) {
  let depth = 0
  let i = 0
  while i < name.length {
    const c = name[i]
    if c == '"' {
      i = skipQuotedName(name, i)
    } else {
      if c == '{' || c == '[' || c == '(' {
        depth = depth + 1
      } else if c == '}' || c == ']' || c == ')' {
        depth = depth - 1
      } else if (
        depth == 0 &&
        c == '=' &&
        i + 1 < name.length &&
        name[i + 1] == '>'
      ) {
        return i
      }
      i = i + 1
    }
  }
  -1
}

// True if `name` is a top-level FUNCTION TYPE `(params)=>ret` — a top-level `=>` with the
// leading `(...)` param group closing right before it. The `=>` binds LOOSER than `|`/`&`,
// so `(i32) => A | B` is `(i32) => (A | B)` (a function returning a union), NOT
// `((i32) => A) | B`; this guards the union/intersection splits from grabbing a `|`/`&`
// that belongs to the return. A genuine `((i32) => i32) | string` has its arrow nested in
// parens (depth 1), so `topLevelArrowIndex` returns -1 and it still splits as a union.
function isTopLevelFuncTypeName(name: string) {
  const arrowAt = topLevelArrowIndex(name)
  if arrowAt < 1 { return false }
  if name[0] != '(' { return false }
  if name[arrowAt - 1] != ')' { return false }
  true
}

// Split `name` on its TOP-LEVEL occurrences of `sep` (depth-aware, quoted
// literal members skipped) into `out`. Shared by the union (`|`) and
// intersection (`&`) arms of `nameToTy`.
function splitTypeName(name: string, sep: i32, out: string[]) {
  let depth = 0
  let start = 0
  let i = 0
  while i <= name.length {
    let atSplit = i == name.length
    let step = 1
    if !atSplit {
      const c = name[i]
      if c == '"' { step = skipQuotedName(name, i) - i }
      else if c == '{' || c == '[' || c == '(' { depth = depth + 1 }
      else if c == '}' || c == ']' || c == ')' { depth = depth - 1 }
      else if c == sep && depth == 0 { atSplit = true }
    }
    if atSplit {
      out.push(name.slice(start, i))
      start = i + 1
    }
    i = i + step
  }
  0
}

// The registry slot of a generic alias base name ("Box"), or -1.
function gaIndexOf(name: string) {
  let i = 0
  while i < gaNames.length {
    if gaNames[i] == name { return i }
    i = i + 1
  }
  -1
}

// Split a generic-application argument list ("i32,string", "Pair<i32,i32>,T")
// at its TOP-LEVEL commas — `<>`/`{}`/`[]`/`()` nest, quoted literal-type names
// skip whole. (The general `splitTypeName` doesn't track `<>` depth, so the
// application form gets its own splitter.) Empty parts drop (a tolerated
// trailing comma).
function splitGenArgs(s: string, out: string[]) {
  let depth = 0
  let start = 0
  let i = 0
  while i <= s.length {
    const isEnd = i == s.length
    let step = 1
    let split = isEnd
    if !isEnd {
      const c = s[i]
      if c == '"' { step = skipQuotedName(s, i) - i }
      else if c == '<' || c == '{' || c == '[' || c == '(' { depth = depth + 1 }
      else if c == '>' || c == '}' || c == ']' || c == ')' { depth = depth - 1 }
      else if c == ',' && depth == 0 { split = true }
    }
    if split {
      const part = s.slice(start, i)
      if part.length > 0 { out.push(part) }
      start = i + 1
    }
    i = i + step
  }
  0
}

// The AST node (a TypeRef / annotation child) that diagnostics raised INSIDE
// name resolution anchor to — the generic-alias ARITY error (`applyGenAlias`)
// and the BARE-generic-use error (`nameToTy`). Resolution is name-keyed (no
// node flows through it), so the positioned entry points (let / param / return
// / field annotation resolution) bank their TypeRef node here via
// `nameToTyAt` / `resolveAnnotAt`; -1 (no position) outside them (e.g. the
// emitter's re-resolution calls, which re-raise errors the checker already
// reported positioned).
let annotDiagAt = -1

// Resolve annotation NAME with resolution diagnostics anchored at node `at`.
function nameToTyAt(name: string, at: i32) {
  const saved = annotDiagAt
  annotDiagAt = at
  const r = nameToTy(name)
  annotDiagAt = saved
  r
}

// Apply a generic alias (`Box<i32>`, `Pair<i32,string>`, `Box<T>` under a live
// type-param env): resolve the arguments in the CURRENT environment, check the
// arity, bind the declared parameter names to the argument types, and resolve
// the declaration's fields under those bindings — the host's `instantiateAlias`
// substitution. The result memoizes into `cUserTypes` under a RESOLVED key
// (`Box<#2>` — the head + the argument arena indices, NOT the spelled name:
// a `Box<T>` spelled under two different `T` bindings must not collide),
// REGISTERED as an empty placeholder before the fields resolve so a recursive
// application (`type A<T> = { next: A<T> | null }`) lands on its own (cyclic)
// arena index instead of recursing forever. Returns -1 for an unknown
// base/argument (the caller reports "unknown type"); a wrong ARITY reports
// here (the full name is otherwise well-formed, anchored at `annotDiagAt`)
// and yields the error type.
export function applyGenAlias(head: string, inner: string) {
  const gi = gaIndexOf(head)
  if gi < 0 { return -1 }
  const pnames: string[] = []
  splitGenArgs(gaParamLists[gi], pnames)
  const argNames: string[] = []
  splitGenArgs(inner, argNames)
  const argTys: i32[] = []
  let ai = 0
  while ai < argNames.length {
    const a = nameToTy(argNames[ai])
    if a < 0 { return -1 }
    argTys.push(a)
    ai = ai + 1
  }
  if argTys.length != pnames.length {
    tErr(
      "`" +
        head +
        "` expects " +
        i32ToStr(pnames.length) +
        " type arguments but got " +
        i32ToStr(argTys.length),
      annotDiagAt,
    )
    return TY_ERR
  }
  let memoKey = head + "<#"
  let mi = 0
  while mi < argTys.length {
    memoKey = memoKey + i32ToStr(argTys[mi]) + ","
    mi = mi + 1
  }
  if cUserTypes.has(memoKey) { return cUserTypes[memoKey] ?? -1 }
  const fnames: string[] = []
  const ftys: i32[] = []
  const resIx = mkObjTy(fnames, ftys)
  cUserTypes[memoKey] = resIx
  cUserTypesVer = cUserTypesVer + 1 // new declared-name resolution registered
  let bi = 0
  while bi < pnames.length {
    tpEnvNames.push(pnames[bi])
    tpEnvTys.push(argTys[bi])
    bi = bi + 1
  }
  const decl = P.nodes[gaDeclIxs[gi]]
  if decl is TypeDecl {
    const dfields = decl.tdFields
    let fi = 0
    while fi < dfields.length {
      const fd = P.nodes[dfields[fi]]
      if fd is FieldDef {
        fnames.push(fd.fdName)
        let fty = TY_ERR
        if fd.fdType >= 0 {
          const ftn = P.nodes[fd.fdType]
          if ftn is TypeRef {
            const r = nameToTy(ftn.tyName)
            if r >= 0 {
              fty = r
              // Record the resolved type on the field's TYPE-ANNOTATION node so the emitter
              // classifies a field type structurally from the `Ty` arena, not a re-parsed name (C1).
              if !inferQuiet && fd.fdType < nodeTyIx.length {
                nodeTyIx[fd.fdType] = r
              }
            } else {
              tErr(
                "unknown type '" + ftn.tyName + "' for field '" + fd.fdName + "'",
                dfields[fi],
              )
            }
          }
        }
        ftys.push(fty)
      }
      fi = fi + 1
    }
  }
  // The placeholder registered above was just FILLED in place (its field arrays
  // are `fnames`/`ftys`) — an existing arena entry changed shape.
  tyMutEpoch = tyMutEpoch + 1
  let pj = 0
  while pj < pnames.length {
    tpEnvNames.pop()
    tpEnvTys.pop()
    pj = pj + 1
  }
  resIx
}

function nameToTy(name: string) {
  // An inline UNION `A | B | null` — the parser joins the members with `|` into one
  // synthetic name. Split on TOP-LEVEL `|`s (depth-aware), resolve each member, and
  // build the union (a `null` member makes it NULLABLE). Checked FIRST so a member's
  // `[]`/map shape isn't read as a suffix of the whole union name. Duplicate
  // members COLLAPSE (host `flattenType` dedup: `"a" | "a" | "b"` is `"a" | "b"`).
  if nameHasPipe(name) && !isTopLevelFuncTypeName(name) {
    const parts: string[] = []
    splitTypeName(name, '|', parts)
    const members: i32[] = []
    let hasNull = false
    let pi = 0
    while pi < parts.length {
      const part = parts[pi]
      if part == "null" {
        hasNull = true
      } else if part.length > 0 {
        // An UNRESOLVED member poisons the whole union (-1, "unknown type") —
        // like the array-suffix arm below. Pushing the -1 would leak the
        // sentinel into the member list, and `assignable` treats a negative
        // side as "accept anything", so `Bogus | i32` would silently accept
        // every source.
        const m = nameToTy(part)
        if m < 0 { return -1 }
        let dup = false
        let dj = 0
        while dj < members.length {
          if sameVariantTy(m, members[dj]) { dup = true }
          dj = dj + 1
        }
        if !dup { members.push(m) }
      }
      pi = pi + 1
    }
    let inner = TY_ERR
    if members.length == 1 { inner = members[0] }
    else if members.length > 1 { inner = mkUnionTy(members) }
    if hasNull { return mkNullableTy(inner) }
    return inner
  }
  // An INTERSECTION `A & B` (A3) — fold the operands through `intersectTy` so a
  // finite annotation simplifies to a concrete type (`(0|1|2) & !2` → `0 | 1`).
  // An unresolvable operand poisons the whole name (-1, "unknown type").
  if nameHasSep(name, '&') && !isTopLevelFuncTypeName(name) {
    const iparts: string[] = []
    splitTypeName(name, '&', iparts)
    let acc = -1
    let ii = 0
    while ii < iparts.length {
      const operand = nameToTy(iparts[ii])
      if operand < 0 { return -1 }
      if ii == 0 { acc = operand } else { acc = intersectTy(acc, operand) }
      ii = ii + 1
    }
    return acc
  }
  if name.length > 0 {
    // A prefix NEGATION `!A` (A4): "anything but A" — almost always consumed by
    // the `&` fold above (`A & !B` subtracts B's variants from A).
    if name[0] == '!' {
      const negd = nameToTy(name.slice(1, name.length))
      if negd < 0 { return -1 }
      return mkNegTy(negd)
    }
    // A PARENTHESIZED group `(A | B)` — strip when the outer parens enclose the
    // whole name (depth never returns to 0 before the final `)`).
    if name[0] == '(' && name[name.length - 1] == ')' {
      let pdepth = 0
      let pj = 0
      let wraps = true
      while pj < name.length {
        const pc = name[pj]
        if pc == '"' {
          pj = skipQuotedName(name, pj)
        } else {
          if pc == '{' || pc == '[' || pc == '(' {
            pdepth = pdepth + 1
          } else if pc == '}' || pc == ']' || pc == ')' {
            pdepth = pdepth - 1
            if pdepth == 0 && pj < name.length - 1 { wraps = false }
          }
          pj = pj + 1
        }
      }
      if wraps { return nameToTy(name.slice(1, name.length - 1)) }
    }
    // A FUNCTION TYPE `(params)=>ret` (the parser's synthetic name for `(i32) => i32`):
    // the leading `(...)` is the param list, then `=>`, then the return atom. Build a
    // `TyFunc` so a function-typed binding/param/field type-checks (call arity + types).
    const arrowAt = topLevelArrowIndex(name)
    if arrowAt >= 1 && name[0] == '(' && name[arrowAt - 1] == ')' {
      const paramsStr = name.slice(1, arrowAt - 1)
      const retStr = name.slice(arrowAt + 2, name.length)
      const ptys: i32[] = []
      if paramsStr.length > 0 {
        const pparts: string[] = []
        splitTypeName(paramsStr, ',', pparts)
        let pk = 0
        while pk < pparts.length {
          const pt = nameToTy(pparts[pk])
          if pt < 0 { return -1 }
          ptys.push(pt)
          pk = pk + 1
        }
      }
      const rty = nameToTy(retStr)
      if rty < 0 { return -1 }
      return mkFuncTy(ptys, rty)
    }
    // A STRING-LITERAL type `"a"` — the quoted lexeme is the member; keep the
    // RAW inner text (the literal expression side keeps its raw lexeme too, so
    // membership compares the same characters).
    if name[0] == '"' { return mkLitTy("str", name.slice(1, name.length - 1)) }
    // A NUMERIC-LITERAL type (`0`, `1.5`): int vs float by the `.`.
    if name[0] >= '0' && name[0] <= '9' {
      if hasDot(name) { return mkLitTy("flt", name) }
      return mkLitTy("int", name)
    }
  }
  if name == "i32" { return TY_I32 }
  if name == "i64" { return TY_I64 }
  if name == "f64" { return TY_F64 }
  if name == "f32" { return TY_F32 }
  if name == "boolean" { return TY_BOOL }
  if name == "string" { return TY_STR }
  if name == "void" { return TY_VOID }
  // The `null` type itself — the check type of `x is null` (host: an Alias
  // named "null"); union members spell it through the `|`-split above.
  if name == "null" { return TY_NULL }
  // An array type `T[]`: the parser appends a literal `[]` per array suffix to the
  // type NAME (`i32[]`, `Tok[]`, `i32[][]`). Strip one suffix and wrap the element.
  const nlen = name.length
  if nlen >= 2 {
    if name[nlen - 2] == '[' && name[nlen - 1] == ']' {
      // An UNRESOLVED element name poisons the whole array annotation (-1,
      // "unknown type 'Bad[]'"). Building `mkArrayTy(-1)` here instead would
      // leak the `-1` ELEMENT HOLE (the empty-`[]` sentinel) as the type of
      // every `xs[i]` read — and a member access on that hole indexes the
      // type arena at -1, a checker CRASH (generics/type-alias-nested.vl).
      const aeTy = nameToTy(name.slice(0, nlen - 2))
      if aeTy < 0 { return -1 }
      return mkArrayTy(aeTy)
    }
  }
  // A string-keyed MAP `{[K]:V}` (the parser's synthetic index-signature name).
  // Split at the FIRST "]:" — the key (between "{[" and "]:") cannot contain `]`,
  // so a nested-map VALUE (`{[string]:{[string]:i32}}`) splits correctly. Only
  // string keys are supported (the host's map rep); a non-string key resolves to
  // -1 so the caller reports "unknown type".
  if nlen >= 5 {
    if name[0] == '{' && name[1] == '[' && name[nlen - 1] == '}' {
      let mi = 2
      while mi < nlen - 1 {
        if name[mi] == ']' && name[mi + 1] == ':' {
          const mk = nameToTy(name.slice(2, mi))
          if mk != TY_STR { return -1 }
          return mkMapTy(mk, nameToTy(name.slice(mi + 2, nlen - 1)), 0)
        }
        mi = mi + 1
      }
    }
  }
  // An INLINE OBJECT type `{x:T,y:U}` (the parser's synthetic anonymous-struct
  // name — starts `{` but not `{[`). Split the TOP-LEVEL commas (depth-aware: a
  // field's own map/object/array commas don't split), then each field at its first
  // top-level `:`, and build the structural TyObj.
  if nlen >= 2 {
    if name[0] == '{' && name[nlen - 1] == '}' {
      const fnames: string[] = []
      const ftys: i32[] = []
      let fdepth = 0
      let fstart = 1
      let fi = 1
      while fi <= nlen - 1 {
        let fSplit = fi == nlen - 1
        let fstep = 1
        if !fSplit {
          const fc = name[fi]
          if fc == '"' { fstep = skipQuotedName(name, fi) - fi }
          else if fc == '{' || fc == '[' || fc == '(' { fdepth = fdepth + 1 }
          else if fc == '}' || fc == ']' || fc == ')' { fdepth = fdepth - 1 }
          else if fc == ',' && fdepth == 0 { fSplit = true }
        }
        if fSplit {
          const field = name.slice(fstart, fi)
          if field.length > 0 {
            // split `fname:ftype` at the first top-level `:`
            let cdepth = 0
            let ci = 0
            let colonAt = -1
            while ci < field.length {
              const cc = field[ci]
              if cc == '"' {
                ci = skipQuotedName(field, ci) - 1
              } else if cc == '{' || cc == '[' || cc == '(' {
                cdepth = cdepth + 1
              } else if cc == '}' || cc == ']' || cc == ')' {
                cdepth = cdepth - 1
              } else if cc == ':' && cdepth == 0 && colonAt < 0 {
                colonAt = ci
              }
              ci = ci + 1
            }
            if colonAt > 0 {
              fnames.push(field.slice(0, colonAt))
              ftys.push(nameToTy(field.slice(colonAt + 1, field.length)))
            }
          }
          fstart = fi + 1
        }
        fi = fi + fstep
      }
      return mkObjTy(fnames, ftys)
    }
  }
  // A live type-parameter BINDING (a generic function's `<T>` while its
  // annotations resolve via `resolveAnnot`, or a generic alias application's
  // params while its body resolves via `applyGenAlias`) — innermost wins.
  let tpi = tpEnvNames.length - 1
  while tpi >= 0 {
    if tpEnvNames[tpi] == name { return tpEnvTys[tpi] }
    tpi = tpi - 1
  }
  // A generic alias APPLICATION `Box<i32>` / `Pair<i32,string>` — the parser
  // folds the arguments into the synthetic name; substitute them into the
  // declared body (A10 stage 3).
  if nlen >= 3 {
    if name[nlen - 1] == '>' {
      let ltAt = -1
      let gj = 0
      let ggoing = gj < nlen
      while ggoing {
        if name[gj] == '<' {
          ltAt = gj
          ggoing = false
        } else {
          gj = gj + 1
          ggoing = gj < nlen
        }
      }
      if ltAt > 0 {
        return applyGenAlias(
          name.slice(0, ltAt),
          name.slice(ltAt + 1, nlen - 1),
        )
      }
    }
  }
  // A declared struct/union type (registered by the program's pre-pass). A SINGLE-MEMBER union
  // alias (`type Id = i32`, `type Name = string`, `type MyCat = Cat`) is TRANSPARENT — it denotes
  // its member, not a one-variant union box. The parser accepts a bare `type N = A` as a one-member
  // union, but a union of one is just that one type, so resolve to the member (`x: Id` is a plain
  // `i32`, usable with `+`; before this it was the box → "operator + not defined" / invalid wasm).
  if cUserTypes.has(name) {
    const ut = cUserTypes[name] ?? -1
    if ut >= 0 {
      const utt = T.tys[ut]
      if utt is TyUnion {
        // Collapse only a PRIMITIVE-scalar single member (the soundness hole). A struct / object /
        // intersection single-member alias keeps its named union ty — the emitter resolves it through
        // its named-struct path, and collapsing it would diverge the two sides (see
        // `singleMemberAliasName`).
        if utt.uMembers.length == 1 {
          const m0 = T.tys[utt.uMembers[0]]
          if m0 is TyPrim { return utt.uMembers[0] }
        }
      }
    }
    return ut
  }
  // A BARE reference to a generic alias has no concrete type — its parameters
  // were never supplied (host: `Generic type … was used without any`).
  if gaIndexOf(name) >= 0 {
    tErr(
      "Generic type `" +
        name +
        "` expects type arguments but was used without any",
      annotDiagAt,
    )
    return TY_ERR
  }
  -1
}

// If `name` is a synthetic map shape `{[K]:V}` (the parser's index-signature
// name), return the KEY type name `K`; otherwise "". Used to give an actionable
// diagnostic for an unsupported (non-`string`) map key instead of a bare
// "unknown type '{[i32]:i32}'".
function mapShapeKeyName(name: string) {
  const nlen = name.length
  if nlen < 5 { return "" }
  if name[0] != '{' || name[1] != '[' { return "" }
  let mi = 2
  while mi < nlen - 1 {
    if name[mi] == ']' && name[mi + 1] == ':' { return name.slice(2, mi) }
    mi = mi + 1
  }
  return ""
}

// The collection FLAVOR of a binding initializer: "Set" when the init is a
// `Set()` call, else "Map" (a `Map()` call or any other shape). Lets the
// i32-keyed diagnostic name the right constructor (`Map`/`Set`).
function initMapCtorName(initIx: i32) {
  if initIx < 0 { return "Map" }
  const inode = P.nodes[initIx]
  if inode is Call {
    const cn = P.nodes[inode.callFn]
    if cn is Ident {
      if cn.identName == "Set" { return "Set" }
    }
  }
  return "Map"
}

// ── type → string (for diagnostics) ──────────────────────────────────────────
// Renders a type-arena index as a readable type name. Recurses through the arena
// for object/function/union/nullable. Narrows the `Ty` union only — never `Node`.
export function tyToStr(ix: i32) {
  if ix < 0 { return "<none>" }
  if tyToStrDepth > 8 { return "…" }
  tyToStrDepth = tyToStrDepth + 1
  const s = tyToStrGo(ix)
  tyToStrDepth = tyToStrDepth - 1
  s
}

function tyToStrGo(ix: i32) {
  const t = T.tys[ix]
  if t is TyPrim {
    return t.primName
  } else if t is TyErr {
    return "<error>"
  } else if t is TyObj {
    // GAP: `.length`/index chained directly on an array field of an `is`-narrowed
    // value miscompiles, so the array fields are bound to locals first (PR #3).
    const names = t.objFieldNames
    const ftys = t.objFieldTypes
    let s = "{"
    let i = 0
    while i < names.length {
      if i > 0 { s = s + ", " }
      s = s + names[i] + ": " + tyToStr(ftys[i])
      i = i + 1
    }
    return s + "}"
  } else if t is TyFunc {
    const ptys = t.fnParamTypes
    let s = "("
    let i = 0
    while i < ptys.length {
      if i > 0 { s = s + ", " }
      s = s + tyToStr(ptys[i])
      i = i + 1
    }
    return s + ") -> " + tyToStr(t.fnRet)
  } else if t is TyUnion {
    const members = t.uMembers
    let s = ""
    let i = 0
    while i < members.length {
      if i > 0 { s = s + " | " }
      s = s + tyToStr(members[i])
      i = i + 1
    }
    return s
  } else if t is TyNullable {
    return tyToStr(t.nInner) + "?"
  } else if t is TyArray {
    return tyToStr(t.aElem) + "[]"
  } else if t is TyMap {
    return "{[" + tyToStr(t.mKey) + "]: " + tyToStr(t.mVal) + "}"
  } else if t is TyVar {
    // An inference hole (`?fn.N`) — an un-annotated, still-polymorphic param — is
    // an internal name, so render it as `any` (host parity: Unknown → "any"). A
    // declared type param (`T`) carries a real source name and keeps it.
    if t.tvName[0] == '?' { return "any" }
    return t.tvName
  } else if t is TyLit {
    // A literal type renders as its member text — quoted for a string literal
    // (host `stringifyType`: `expected "a" | "b", got "c"`).
    if t.litKind == "str" { return "\"" + t.litText + "\"" }
    return t.litText
  } else if t is TyNeg {
    return "!" + tyToStr(t.negTy)
  }
  "<?>"
}

// ── structural type equality ─────────────────────────────────────────────────
// Whether two arena types RENDER identically (`tyToStr(a) == tyToStr(b)`),
// decided structurally without building the strings. Powers the "redundant
// annotation" hints, whose meaning is literally "the annotation spells what
// inference already prints" — so this mirrors the RENDERING rules rather than
// plain shape equality:
//   - union LAYERS flatten in the render and a one-member union prints as its
//     member, so members compare through `unionMembersInto`;
//   - every internal inference hole prints "any", so two holes compare equal;
//   - object field ORDER is significant (the render is ordered).
// Mutual assignability is NOT equality (width subtyping accepts extra fields);
// `sameVariantTy` keeps its two-way `assignable` check.
const tyEqAStack: i32[] = []
const tyEqBStack: i32[] = []

function tyEq(a: i32, b: i32) {
  if a == b { return true }
  if a < 0 || b < 0 { return false }
  // A pair already being compared higher in the recursion is assumed equal —
  // the cycle guard for recursive named types, like `assignable`'s.
  let gi = tyEqAStack.length - 1
  while gi >= 0 {
    if tyEqAStack[gi] == a && tyEqBStack[gi] == b { return true }
    gi = gi - 1
  }
  tyEqAStack.push(a)
  tyEqBStack.push(b)
  const ok = tyEqGo(a, b)
  tyEqAStack.pop()
  tyEqBStack.pop()
  ok
}

// Flatten nested union LAYERS only — a nullable renders `T?`, not `T | null`,
// so (unlike `flattenVariantsInto`) a nullable stays opaque here.
function unionMembersInto(ty: i32, out: i32[]) {
  if ty >= 0 {
    const t = T.tys[ty]
    if t is TyUnion {
      const ms = t.uMembers
      let i = 0
      while i < ms.length {
        unionMembersInto(ms[i], out)
        i = i + 1
      }
      return 0
    }
  }
  out.push(ty)
  0
}

// Union render-equality: the flattened member sequences match pairwise.
function unionEq(a: i32, b: i32) {
  const av: i32[] = []
  unionMembersInto(a, av)
  const bv: i32[] = []
  unionMembersInto(b, bv)
  if av.length != bv.length { return false }
  let i = 0
  while i < av.length {
    if !tyEq(av[i], bv[i]) { return false }
    i = i + 1
  }
  true
}

function tyEqGo(a: i32, b: i32) {
  const ta = T.tys[a]
  const tb = T.tys[b]
  if ta is TyUnion { return unionEq(a, b) }
  if tb is TyUnion { return unionEq(a, b) }
  if ta is TyPrim {
    if tb is TyPrim { return ta.primName == tb.primName }
    return false
  }
  if ta is TyErr {
    if tb is TyErr { return true }
    return false
  }
  if ta is TyVar {
    if tb is TyVar {
      // An inference hole renders "any" regardless of its internal name.
      if ta.tvName[0] == '?' { return tb.tvName[0] == '?' }
      return ta.tvName == tb.tvName
    }
    return false
  }
  if ta is TyLit {
    if tb is TyLit {
      return ta.litKind == tb.litKind && ta.litText == tb.litText
    }
    return false
  }
  if ta is TyNullable {
    if tb is TyNullable { return tyEq(ta.nInner, tb.nInner) }
    return false
  }
  if ta is TyArray {
    if tb is TyArray { return tyEq(ta.aElem, tb.aElem) }
    return false
  }
  if ta is TyMap {
    if tb is TyMap {
      if ta.mSet != tb.mSet { return false }
      return tyEq(ta.mKey, tb.mKey) && tyEq(ta.mVal, tb.mVal)
    }
    return false
  }
  if ta is TyFunc {
    if tb is TyFunc {
      const ap = ta.fnParamTypes
      const bp = tb.fnParamTypes
      if ap.length != bp.length { return false }
      if !tyEq(ta.fnRet, tb.fnRet) { return false }
      let i = 0
      while i < ap.length {
        if !tyEq(ap[i], bp[i]) { return false }
        i = i + 1
      }
      return true
    }
    return false
  }
  if ta is TyObj {
    if tb is TyObj {
      const an = ta.objFieldNames
      const bn = tb.objFieldNames
      if an.length != bn.length { return false }
      const aty = ta.objFieldTypes
      const bty = tb.objFieldTypes
      let i = 0
      while i < an.length {
        if an[i] != bn[i] { return false }
        if !tyEq(aty[i], bty[i]) { return false }
        i = i + 1
      }
      return true
    }
    return false
  }
  if ta is TyNeg {
    if tb is TyNeg { return tyEq(ta.negTy, tb.negTy) }
    return false
  }
  false
}

// The type-arena index of object `o`'s field `name`, or `-1` if absent. Takes a
// concrete `TyObj` (already narrowed by the caller) — `Ty`-union only.
function objFieldType(o: TyObj, name: string) {
  const names = o.objFieldNames
  const ftys = o.objFieldTypes
  let i = 0
  while i < names.length {
    if names[i] == name { return ftys[i] }
    i = i + 1
  }
  -1
}

// ── emit-name canonicalization ────────────────────────────────────────────────
// The native emitter classifies annotations by their synthetic NAME, and the
// literal/intersection algebra above is purely a CHECKER notion — at runtime a
// same-base literal union IS its base scalar (`"a" | "b"` rides a string,
// `0 | 1` an i32, `1.5 | 2.5` an f64) and a folded intersection IS its fold
// (`(0|1|2) & !2` an i32, `{a} & {b}` the merged shape). So at the end of
// `checkProgram`, `canonEmitTypeNames` rewrites every annotation name into the
// emitter's vocabulary; a name with no literal/intersection construct passes
// through BYTE-IDENTICAL (the membership rules were already enforced above —
// the emitter only needs the representation).

// Whether `name` contains a construct the emitter can't classify: a quoted
// string-literal member, an `&` intersection, a `!` negation, a parenthesized
// group, or a numeric-literal member (a digit at a member-START position —
// after `|` / `:` / `,` or at the very start; a digit INSIDE an identifier
// like `i32` never starts a member).
function nameNeedsCanon(name: string) {
  let i = 0
  while i < name.length {
    const c = name[i]
    if c == '"' || c == '&' || c == '!' || c == '(' { return true }
    // A composite form (`Id[]`, `{[string]: Id}`, `{x: Id}`) may embed a single-member alias in its
    // element / value / field, which `canonEmitName`'s array/map/object recursion resolves — so it
    // must run even when no other canon trigger is present. Idempotent for an already-canon composite
    // (a non-alias element rewrites to itself), so this only broadens WHICH names recurse, not the
    // result of any name that already canon'd.
    if c == '[' || c == '{' { return true }
    // A top-level union (`AB | null`) must be processed so a union-ALIAS member expands to
    // its flattened members (the inline `(A|B)|null` already trips the `(` test above). The
    // member-canon loop is idempotent for an already-flat union, so this is a no-op there.
    if c == '|' { return true }
    if c >= '0' && c <= '9' {
      if i == 0 { return true }
      const p = name[i - 1]
      if p == '|' || p == ':' || p == ',' { return true }
    }
    i = i + 1
  }
  false
}

// The base-scalar emit name of one LITERAL member lexeme (`"a"` → string,
// `0` → i32, `1.5` → f64, an i32-overflowing integer → i64 — the same
// magnitude rule as `litBaseTy`).
function litBaseName(part: string) {
  if part[0] == '"' { return "string" }
  if hasDot(part) { return "f64" }
  if intLexemeFitsI32(part) { return "i32" }
  "i64"
}

// Render a RESOLVED arena type as an emitter-classifiable synthetic name, or
// "" when it has none (a TyVar, a residual negation, err/never). Only the
// `&`-fold arm of `canonEmitName` consults this — every other arm rewrites the
// name STRUCTURALLY without resolving it, so a NAMED struct keeps its name.
function tyToEmitName(ix: i32) {
  if ix < 0 { return "" }
  const t = T.tys[ix]
  if t is TyPrim {
    if t.primName == "never" { return "" }
    return t.primName
  }
  if t is TyLit {
    if t.litKind == "str" { return "string" }
    if t.litKind == "flt" { return "f64" }
    if intLexemeFitsI32(t.litText) { return "i32" }
    return "i64"
  }
  if t is TyUnion {
    const members = t.uMembers
    // FLATTENED-alias regroup: a litunion-ALIAS member's literals flatten into sibling
    // TyLit members (`flattenVariantsInto`: `K0 | i64` → ["64","bjtvb","tt", i64]), so
    // the per-member alias lookup below never sees the alias and each lit softened to
    // `string` — the widened spelling minted TWIN field/slot rows beside the
    // annotation-spelled ones (divergent structs/mv slots — INVALID-WASM; fuzz-nightly
    // seed 658239060 d5). In a MIXED union (at least one non-TyLit member) regroup the
    // str-lit members into their exactly-matching registered alias, rendered at the
    // FIRST lit's position. A PURE litunion keeps the historical `string` softening
    // (the `canonEmitTypeNames` invariant), and a lit set matching no alias keeps the
    // per-member path unchanged.
    let rgAlias = ""
    const rgTexts: string[] = []
    let rgNonLit = false
    let rg = 0
    while rg < members.length {
      const rm = T.tys[members[rg]]
      if rm is TyLit {
        if rm.litKind == "str" { rgTexts.push(rm.litText) }
      } else {
        let rmNull = false
        if rm is TyPrim {
          if rm.primName == "null" { rmNull = true }
        }
        if !rmNull { rgNonLit = true }
      }
      rg = rg + 1
    }
    if rgNonLit && rgTexts.length >= 2 {
      rgAlias = litUnionAliasOfLitTexts(rgTexts)
    }
    const parts: string[] = []
    let rgDone = false
    let i = 0
    while i < members.length {
      // A MEMBER that is a registered litunion ALIAS (`K0 | i64`) keeps its alias name
      // rather than softening to `string` — the alias arm reps as the i32 atom in the
      // union box, and every `$fnsig`/slot key derived from this render must agree with
      // the annotation side's `(K0|i64)` spelling. Without it a closure returning
      // `(K0 | i64)[]` keyed `(string|i64)[]` while the value call keyed the alias —
      // divergent functypes, a cast-failure TRAP (fuzz-nightly run 29808029476, seed
      // 78530533 d5). The union-member sibling of the TyFunc-result / TyObj-field
      // alias preservation above and below.
      const rgm = T.tys[members[i]]
      if rgAlias != "" && rgm is TyLit {
        if !rgDone {
          rgDone = true
          parts.push(rgAlias)
        }
        i = i + 1
        continue
      }
      let s = litUnionAliasNameOfTy(members[i])
      if s == "" { s = tyToEmitName(members[i]) }
      if s == "" { return "" }
      // A FUNCTION-TYPE member renders PARENTHESIZED (`(()=>f32|null)|{w:i32}`) — the
      // annotation's atom spelling. Bare, the closure's result arms swallow the union's
      // sibling members (`()=>f32|null|{w:i32}`), so `annSigKey` read a top-level arrow
      // and keyed the whole result `>c` while the pinned lambda interned `>u` — a
      // divergent `ref.cast` functype at the value call (INVALID-WASM; fuzz-nightly
      // seed 556796311 d6).
      if rgm is TyFunc { s = "(" + s + ")" }
      let dup = false
      let j = 0
      while j < parts.length {
        if parts[j] == s { dup = true }
        j = j + 1
      }
      if !dup { parts.push(s) }
      i = i + 1
    }
    if parts.length == 0 { return "" }
    let out = parts[0]
    let k = 1
    while k < parts.length {
      out = out + "|" + parts[k]
      k = k + 1
    }
    return out
  }
  if t is TyNullable {
    const inner = tyToEmitName(t.nInner)
    if inner == "" { return "" }
    // A NULLABLE FUNCTION type keeps the kind-19 grouping parens (`((i32)=>string)|null`)
    // — bare, the render spells a closure RETURNING `string|null` instead (the `|null`
    // binds to the result), the same swallowed-arm ambiguity as the union-member case.
    const nfn = T.tys[t.nInner]
    if nfn is TyFunc { return "(" + inner + ")|null" }
    return inner + "|null"
  }
  if t is TyObj {
    const names = t.objFieldNames
    const ftys = t.objFieldTypes
    let out = "{"
    let fi = 0
    while fi < names.length {
      // A FIELD preserves a literal-union ALIAS (`{f: K0}`, `{f: K0 | null}`) rather
      // than the softened `string` — so a rendered shape resolves the SAME struct index
      // the annotation side interned (`{f:K0}`, the i32-atom field layout), not the
      // string-field twin. Without it a nullable-struct closure-result pin
      // (`nullableRetName`'s TyObj arm) keyed `>n` on `{f:string}` while the annotated
      // value call keyed `>n` on `{f:K0}` — divergent `$fnsig` entries: a cast-failure
      // TRAP at the narrowed nullable-closure call (fuzz frontier seed 679748579 d5).
      // The field dual of the TyFunc-result alias preservation below.
      let fs = ""
      const ftn = T.tys[ftys[fi]]
      if ftn is TyNullable {
        const fal = litUnionAliasNameOfTy(ftn.nInner)
        if fal != "" { fs = fal + "|null" }
      }
      if fs == "" {
        const fbal = litUnionAliasNameOfTy(ftys[fi])
        if fbal != "" { fs = fbal }
      }
      if fs == "" { fs = tyToEmitName(ftys[fi]) }
      if fs == "" { return "" }
      if fi > 0 { out = out + "," }
      out = out + names[fi] + ":" + fs
      fi = fi + 1
    }
    return out + "}"
  }
  if t is TyArray {
    // A litunion-ALIAS element (`K0[]`) keeps its alias name rather than softening to
    // `string[]` — the two spell DIFFERENT reps (the alias array is the interned-i32
    // ATOM list; `string[]` is the string-ref list), so a widened render minted a TWIN
    // mv slot beside the annotation-spelled one and the narrowed map read resolved the
    // other twin's struct (INVALID-WASM; fuzz-nightly seed 210853359 d6). The array
    // sibling of the TyUnion-member / TyObj-field / TyMap-value alias preservation.
    let el = litUnionAliasNameOfTy(t.aElem)
    if el == "" { el = tyToEmitName(t.aElem) }
    if el == "" { return "" }
    if nameHasPipe(el) { return "(" + el + ")[]" }
    return el + "[]"
  }
  if t is TyMap {
    const mk = tyToEmitName(t.mKey)
    // A litunion-ALIAS map VALUE (`{[string]: K0}`) keeps its alias name rather than
    // softening to `string` — an atom-valued map is the MONO i32 map, and every
    // `$fnsig`/mv-slot key derived from this render must agree with the annotation
    // side's `{[string]:K0}` spelling. Widened, a never-constructed inner closure's
    // synthesized `>m` sig keyed the STRING-valued map struct while the narrowed
    // call's map read resolved the mono atom map — INVALID-WASM at the result store
    // (fuzz seed 113148886 d6). The map-value sibling of the TyUnion-member /
    // TyObj-field / TyFunc-result alias preservation around it.
    let mv = litUnionAliasNameOfTy(t.mVal)
    if mv == "" { mv = tyToEmitName(t.mVal) }
    if mk == "" || mv == "" { return "" }
    return "{[" + mk + "]:" + mv + "}"
  }
  // A FUNCTION type renders the emitter's closure-annotation form `(p1, p2) => ret` — so an
  // inferred closure VALUE (`const g = f(4)`) recovers an annotation-shaped name the closure
  // `$fnsig` producers (`annSigKey`) can key. "" if any param / the result is unrenderable.
  if t is TyFunc {
    const ps = t.fnParamTypes
    let out = "("
    let i = 0
    while i < ps.length {
      const ps1 = tyToEmitName(ps[i])
      if ps1 == "" { return "" }
      if i > 0 { out = out + "," }
      out = out + ps1
      i = i + 1
    }
    // A function RESULT preserves a literal-union ALIAS (`() => K0`, `() => K0 | null`)
    // rather than `tyToEmitName`'s softened `string` — so an INFERRED closure value (a
    // `??`-defaulted map-value closure, a call result) keys the litunion's i32-atom token
    // (`>i`, via `annRetKind`), byte-matching the constructed lambda's `$fnsig`. Without it
    // the inferred name widened to `string|null`, whose `nulstr` `(ref array)` result clashed
    // with the litunion-atom call (INVALID-WASM at the value call's `local.set`). Mirrors the
    // return-position `nulLitUnionRetName` / `nullableRetName` alias preservation.
    let rs = ""
    const rtn = T.tys[t.fnRet]
    if rtn is TyNullable {
      const nal = litUnionAliasNameOfTy(rtn.nInner)
      if nal != "" { rs = nal + "|null" }
    }
    if rs == "" {
      const bal = litUnionAliasNameOfTy(t.fnRet)
      if bal != "" { rs = bal }
    }
    if rs == "" { rs = tyToEmitName(t.fnRet) }
    if rs == "" { return "" }
    // A function-type RESULT keeps grouping parens so the outer `$fnsig` producers see a
    // single result token (`(i32)=>((i32)=>i32)`), matching the source-annotation form.
    const rt = T.tys[t.fnRet]
    if rt is TyFunc { rs = "(" + rs + ")" }
    return out + ")=>" + rs
  }
  ""
}

// Canonicalize one inline `{…}` shape name (an object `{f:T,…}` or a map
// `{[K]:V}`): each field/key/value type recurses through `canonEmitName`, the
// surrounding structure is rebuilt with the parser's exact conventions (no
// spaces), so a shape with no literal field is reproduced byte-identical.
function canonShapeName(name: string) {
  const inner = name.slice(1, name.length - 1)
  if inner.length > 0 && inner[0] == '[' {
    // A map `{[K]:V}` — the key ends at its matching `]` (depth-aware).
    let depth = 0
    let i = 0
    while i < inner.length {
      const c = inner[i]
      if c == '"' {
        i = skipQuotedName(inner, i)
      } else {
        if c == '[' || c == '{' || c == '(' { depth = depth + 1 }
        if c == ']' || c == '}' || c == ')' {
          depth = depth - 1
          if depth == 0 {
            const key = inner.slice(1, i)
            const val = inner.slice(i + 2, inner.length)
            return "{[" + canonEmitName(key) + "]:" + canonEmitName(val) + "}"
          }
        }
        i = i + 1
      }
    }
    return name
  }
  // An object shape `{f:T,…}`: split fields at depth 0 (quoted literal members
  // skipped), canon each field's type past its first depth-0 `:`.
  let out = "{"
  let depth = 0
  let start = 0
  let i = 0
  while i <= inner.length {
    let atSplit = i == inner.length
    let step = 1
    if !atSplit {
      const c = inner[i]
      if c == '"' { step = skipQuotedName(inner, i) - i }
      else if c == '{' || c == '[' || c == '(' { depth = depth + 1 }
      else if c == '}' || c == ']' || c == ')' { depth = depth - 1 }
      else if c == ',' && depth == 0 { atSplit = true }
    }
    if atSplit {
      const field = inner.slice(start, i)
      // The field's type starts past its first depth-0 `:` (quote-aware).
      let cdepth = 0
      let colonAt = -1
      let ci = 0
      while ci < field.length {
        const cc = field[ci]
        if cc == '"' { ci = skipQuotedName(field, ci) - 1 }
        else if cc == '{' || cc == '[' || cc == '(' { cdepth = cdepth + 1 }
        else if cc == '}' || cc == ']' || cc == ')' { cdepth = cdepth - 1 }
        else if cc == ':' && cdepth == 0 && colonAt < 0 { colonAt = ci }
        ci = ci + 1
      }
      if start > 0 { out = out + "," }
      if colonAt >= 0 {
        out = out +
          field.slice(0, colonAt + 1) +
          canonEmitName(field.slice(colonAt + 1, field.length))
      } else {
        out = out + field
      }
      start = i + 1
    }
    i = i + step
  }
  out + "}"
}

// Rewrite one synthetic annotation name into the emitter's vocabulary (see the
// block comment above). Structure-preserving: only literal members, `&` folds
// and whole-name parens change; any name without those constructs is returned
// byte-identical (the `nameNeedsCanon` fast path).
// If `name` is a declared UNION ALIAS (`type AB = A | B`), its flattened member-set emit name
// (`"A|B"`); "" for a struct alias / primitive / generic / unknown (which keep their own name).
// `canonEmitName` uses this to FLATTEN a union-alias member of an OUTER union — `AB | null`
// canonicalizes to `A | B | null`, the same name the inline `(A | B) | null` produces, which
// the emitter's union machinery recognizes (an un-expanded alias name is not a union name, so
// `AB | null` otherwise fell through to the i32-local default — "only i32 locals are supported").
function unionAliasMembers(name: string) {
  const ix = cUserTypes[name] ?? -1
  if ix < 0 { return "" }
  const t = T.tys[ix]
  if t is TyUnion { return tyToEmitName(ix) }
  ""
}

// The single member's EMIT name of a declared one-member union ALIAS (`type Id = i32` → "i32",
// `type Name = string` → "string", `type MyCat = Cat` → "Cat"), or "" if `name` is not a declared
// single-member union. Such an alias is TRANSPARENT — it denotes its member, so the emitter resolves
// it to the member's own vocabulary rather than registering a one-variant union box.
function singleMemberAliasName(name: string) {
  if !cUserTypes.has(name) { return "" }
  const ti = cUserTypes[name] ?? -1
  if ti < 0 { return "" }
  const t = T.tys[ti]
  if t is TyUnion {
    if t.uMembers.length == 1 {
      // Only a PRIMITIVE-SCALAR member is resolved here (the documented soundness hole — `type Id =
      // i32` / `type Name = string` miscompiling as a one-variant box). A struct / object / inline-
      // intersection member (`type MyCat = Cat`, `type AB = {a}&{b}`) is left as its alias NAME, which
      // the emitter already resolves through its named-struct / `unionStructAliasShape` path —
      // expanding it to an inline shape here would lose that registration (a struct param then reads
      // as an unrecognized inline-object annotation).
      const mt = T.tys[t.uMembers[0]]
      if mt is TyPrim { return tyToEmitName(t.uMembers[0]) }
    }
  }
  ""
}

// A NULLABLE LITERAL-UNION's preserved canonical name, or "" if `parts` (the top-level `|`-split
// members of a union annotation) are not one. `K | null` / `"a" | "b" | null` must keep the litunion
// members intact — the generic union soften below collapses each quoted literal to `string`, erasing
// the litunion identity and mis-routing the type to the `string | null` ref box (kind 16) instead of
// the i32 ATOM NICHE (`-1` = null). Reconstructs as `<litunion-core>|null` (alias preserved, literals
// kept quoted), which `nameIsNulLitUnion` recognizes and `vtKindOfType` maps to the i32 kind 0.
function nulLitUnionPreserve(parts: string[]) {
  let hasNull = false
  const rest: string[] = []
  let i = 0
  while i < parts.length {
    if parts[i] == "null" { hasNull = true } else { rest.push(parts[i]) }
    i = i + 1
  }
  if !hasNull { return "" }
  if rest.length == 0 { return "" }
  let core = rest[0]
  let j = 1
  while j < rest.length {
    core = core + "|" + rest[j]
    j = j + 1
  }
  if nameIsLitUnionType(core) { return core + "|null" }
  ""
}

export function canonEmitName(name: string) {
  if name.length == 0 { return name }
  // A single-member union alias is transparent — resolve it to its member's emit name FIRST (before
  // the `nameNeedsCanon` early-out, which would otherwise return a bare alias name unchanged). The
  // member is itself canon'd, so `type Id = i32` → "i32" and `type Ids = Id[]`-style nesting resolves.
  const sma = singleMemberAliasName(name)
  if sma != "" { return canonEmitName(sma) }
  if !nameNeedsCanon(name) { return name }
  // A top-level UNION: canon each member and collapse duplicates (`"a" | "b"`
  // both soften to string → the bare scalar; a mixed-base union keeps each
  // softened member — `"a" | 1` stays the boxed `string|i32`). A top-level FUNCTION
  // type is NOT a union (its `=>` binds looser than `|`, the #516 rule applied to
  // `nameToTy`) — `(i32) => A | B` is a function returning a union, so it is left for
  // the function-type pass-through below, NOT split here.
  if nameHasPipe(name) && !isTopLevelFuncTypeName(name) {
    const parts: string[] = []
    splitTypeName(name, '|', parts)
    // A nullable literal-union (`K | null`) keeps its litunion members — see `nulLitUnionPreserve`.
    const nlu = nulLitUnionPreserve(parts)
    if nlu != "" { return nlu }
    const kept: string[] = []
    let i = 0
    while i < parts.length {
      let c = canonEmitName(parts[i])
      // A union-ALIAS member flattens into this outer union (`AB | null` → `A | B | null`):
      // a union of unions is one union, so expand the alias to its members — matching the
      // inline `(A | B) | null` form the emitter recognizes. (A bare `AB` annotation has no
      // top-level `|`, so it never reaches here and stays its alias name.)
      const exp = unionAliasMembers(c)
      if exp != "" { c = exp }
      // A FUNCTION-type member keeps grouping parens (`((i32) => i32) | null` — a NULLABLE
      // function), so the rejoined name stays distinct from `(i32) => i32 | null` (a
      // function returning a nullable). `canonEmitName` strips a member's own wrapping
      // parens (the bare `(i32) => i32`, a top-level function type), so re-add them.
      if isTopLevelFuncTypeName(c) { c = "(" + c + ")" }
      let dup = false
      let j = 0
      while j < kept.length {
        if kept[j] == c { dup = true }
        j = j + 1
      }
      if !dup { kept.push(c) }
      i = i + 1
    }
    let out = kept[0]
    let k = 1
    while k < kept.length {
      out = out + "|" + kept[k]
      k = k + 1
    }
    return out
  }
  // A top-level INTERSECTION: fold through the checker algebra (`nameToTy`
  // runs `intersectTy`), then render the fold. An unrenderable fold leaves the
  // name unchanged — the emitter reports its own coverage gap.
  if (nameHasSep(name, '&')) {
    const folded = nameToTy(name)
    if folded >= 0 {
      const r = tyToEmitName(folded)
      if r != "" { return r }
    }
    return name
  }
  // A trailing `[]`: canon the ELEMENT (no top-level `|`/`&` here, so the
  // suffix binds the whole core); a union element keeps its grouping parens. NOT for a
  // TOP-LEVEL function type (`(i32) => i32[]`) — there the `[]` binds the RETURN type
  // (`i32[]`), not the whole function, so it is a function returning a list, handled by
  // the function-type pass-through below — NOT an array of functions.
  if (
    name.length > 2 &&
    name[name.length - 2] == '[' &&
    name[name.length - 1] == ']' &&
    !isTopLevelFuncTypeName(name)
  ) {
    const core = canonEmitName(name.slice(0, name.length - 2))
    if nameHasPipe(core) { return "(" + core + ")[]" }
    // A FUNCTION-type element keeps grouping parens (`((i32) => i32)[]` — an ARRAY OF
    // functions), so the name stays distinct from `(i32) => i32[]` (a function RETURNING
    // a list). `canonEmitName` strips the element's own wrapping parens (the bare
    // top-level `(i32) => i32`), so re-add them — mirroring the union-member rule above.
    if isTopLevelFuncTypeName(core) { return "(" + core + ")[]" }
    return core + "[]"
  }
  // A parenthesized group wrapping the whole (no top-level `|`/`&`/`[]` left):
  // strip and canon the inside. NOT for a TOP-LEVEL function type whose RETURN is
  // parenthesized (`(i32) => ((i32) => i32)` — a curried/closure-returning function): its
  // leading `(` wraps only the PARAM list, so a blind first/last strip corrupts it to
  // `i32)=>((i32)=>i32`. Such a name keeps its top-level arrow (handled below).
  if (
    name[0] == '(' &&
    name[name.length - 1] == ')' &&
    !isTopLevelFuncTypeName(name)
  ) {
    return canonEmitName(name.slice(1, name.length - 1))
  }
  // A TOP-LEVEL function type with a parenthesized result (`(i32) => ((i32) => i32)`): canon
  // the param list and the (paren-stripped) result, re-render with the result's grouping
  // parens. A simple `(i32) => i32` ends in its return type (not `)`), so it never reached the
  // strip above and falls through unchanged — this only re-canonicalizes the nested form.
  if isTopLevelFuncTypeName(name) && name[name.length - 1] == ')' {
    const fa = topLevelArrowIndex(name)
    const psStr = name.slice(1, fa - 1)
    let out = "("
    if psStr.length > 0 {
      const parts: string[] = []
      splitTypeName(psStr, ',', parts)
      let pi = 0
      while pi < parts.length {
        if pi > 0 { out = out + "," }
        out = out + canonEmitName(parts[pi])
        pi = pi + 1
      }
    }
    let rc = canonEmitName(name.slice(fa + 2, name.length))
    if isTopLevelFuncTypeName(rc) { rc = "(" + rc + ")" }
    return out + ")=>" + rc
  }
  // A literal member → its base scalar.
  if name[0] == '"' { return "string" }
  if name[0] >= '0' && name[0] <= '9' { return litBaseName(name) }
  // A residual negation (only meaningful under `&`) — leave for the emitter.
  if name[0] == '!' { return name }
  // An inline `{…}` shape: canon its field/value types.
  if name[0] == '{' && name[name.length - 1] == '}' {
    return canonShapeName(name)
  }
  name
}

// The post-check sweep: rewrite every `TypeRef` annotation and every
// `UnionDecl` variant name in the arena. Runs once at the end of
// `checkProgram` — `compileSrc` hands this SAME arena to `emitProgram`, so the
// emitter only ever sees its own vocabulary.
export function canonEmitTypeNames() {
  let i = 0
  while i < P.nodes.length {
    const n = P.nodes[i]
    if n is TypeRef {
      const c = canonEmitName(n.tyName)
      if c != n.tyName { n.tyName = c }
    } else if n is UnionDecl {
      const vs = n.udVariants
      let vi = 0
      while vi < vs.length {
        const c2 = canonEmitName(vs[vi])
        if c2 != vs[vi] { vs[vi] = c2 }
        vi = vi + 1
      }
    }
    i = i + 1
  }
  0
}

// ── value-comparability: may `ty` be compared with the default structural `==`? ─
// SOUNDNESS (mirrors the host's `isEquatable`): `==`/`!=` on a plain data object
// falls back to structural equality, which is sound only when EVERY component is
// itself value-comparable. Primitives and strings compare natively; a FUNCTION
// field compares by reference (same table index + captured env), so it does NOT
// make its object non-equatable; an array is equatable iff its element type is; an
// object iff all its fields are. A non-discriminated UNION (or NULLABLE, or a map)
// field is NOT value-comparable — discriminating the variant would be required
// first — so its enclosing object needs an explicit `==`. `seen` guards a cyclic
// (recursive) object shape: a type already on the stack is treated as equatable
// (its fields decide), matching the host's cycle guard.
function isEquatable(ty: i32, seen: i32[]) {
  if ty < 0 { return true }
  const t = T.tys[ty]
  if t is TyPrim {
    // Every scalar primitive (incl. string, bool) is value-comparable; `void`/`null`
    // never reach a structural compare (a nullness test short-circuits earlier).
    return true
  }
  if t is TyErr { return true }
  if t is TyVar { return true }
  if t is TyFunc { return true }
  if t is TyArray { return isEquatable(t.aElem, seen) }
  if t is TyObj {
    let si = 0
    while si < seen.length {
      if seen[si] == ty { return true }
      si = si + 1
    }
    seen.push(ty)
    const ftys = t.objFieldTypes
    let i = 0
    let ok = true
    while i < ftys.length {
      if !isEquatable(ftys[i], seen) { ok = false }
      i = i + 1
    }
    seen.pop()
    return ok
  }
  // TyUnion / TyNullable / TyMap: not structurally value-comparable.
  false
}

// ── structural assignability: is `src` assignable to `dst`? ──────────────────
// Both are type-arena indices. The error type is assignable in both directions
// (so one failure doesn't cascade). Primitives match by name. An object is
// assignable to another when it has (at least) every target field, each field
// assignable (width + depth subtyping — the structural rule). A function matches
// on arity then parameter/return assignability (parameters contravariant). A
// value is assignable to a nullable when it is assignable to the inner type (or
// is itself nullable). A union source is assignable when EVERY member is; a union
// target accepts a source assignable to ANY member. Narrows `Ty` only.
// A param/return SLOT of a function type: numeric prims are INVARIANT here. The numeric
// widening lattice (`numWidensName`) holds for a VALUE flowing into a wider slot — codegen
// converts at the boundary — but a function VALUE's wasm functype fixes each param/result
// rep and no adapter thunk exists, so `() => i32` must not flow into a `() => i64` slot
// (accepted, it emits an i32-result functype every i64-expecting call site mistrusts —
// invalid wasm). A lambda LITERAL in that position still works: the checker seeds the
// expected return (`recordCbExpectedRet`) and the body ADOPTS it, widening at its return
// seam, so the lambda reaches this comparison already at the wider type.
function fnSlotAssignable(src: i32, dst: i32) {
  if numWidens(src, dst) { return false }
  if objNumWidens(src, dst) { return false }
  assignable(src, dst)
}

// A struct type with a numerically-WIDER field on the destination side (`{f: i32}` vs
// `{f: i64}`): assignable as a VALUE (construction converts at the field store) but NOT
// as a function-type slot — a function value's functype fixes the field rep, so the
// covariant accept emitted an i32-field shape every call site mistrusts (invalid wasm).
// The object dual of the scalar invariance in `fnSlotAssignable`; recursion covers a
// nested struct field. A lambda LITERAL in that position still works: the checker adopts
// the expected shape when the widening fields are literals (`objRetWidenAdopt`), so it
// reaches the comparison already at the wider type.
function objNumWidens(src: i32, dst: i32) {
  if src < 0 || dst < 0 { return false }
  const s = T.tys[src]
  const d = T.tys[dst]
  if s is TyObj {
    if d is TyObj {
      let i = 0
      while i < d.objFieldNames.length {
        const sf = objFieldType(s, d.objFieldNames[i])
        if sf >= 0 {
          if numWidens(sf, d.objFieldTypes[i]) { return true }
          if objNumWidens(sf, d.objFieldTypes[i]) { return true }
        }
        i = i + 1
      }
    }
  }
  false
}

function assignable(src: i32, dst: i32) {
  if src < 0 || dst < 0 { return true }
  if src == dst { return true }
  let gi = asgSrcStack.length - 1
  while gi >= 0 {
    if asgSrcStack[gi] == src && asgDstStack[gi] == dst { return true }
    gi = gi - 1
  }
  asgSrcStack.push(src)
  asgDstStack.push(dst)
  const ok = assignableGo(src, dst)
  asgSrcStack.pop()
  asgDstStack.pop()
  ok
}

function assignableGo(src: i32, dst: i32) {
  const s = T.tys[src]
  const d = T.tys[dst]
  if s is TyErr { return true }
  if d is TyErr { return true }
  if s is TyVar { return true }
  if d is TyVar { return true }
  // `never` (the empty type) is the BOTTOM type: assignable anywhere. (As a
  // TARGET it accepts nothing — no concrete source reaches `s.primName ==
  // d.primName` with "never" on only one side.)
  if s is TyPrim {
    if s.primName == "never" { return true }
  }
  // Nullable target: accepts `null` itself, the inner, or another nullable's inner.
  if d is TyNullable {
    if src == TY_NULL { return true }
    if s is TyNullable { return assignable(s.nInner, d.nInner) }
    return assignable(src, d.nInner)
  }
  // A nullable source is not assignable to a non-nullable target.
  if s is TyNullable { return false }
  // Union source: every member must be assignable to the target.
  if s is TyUnion {
    const members = s.uMembers
    let i = 0
    let ok = true
    while i < members.length {
      if !assignable(members[i], dst) { ok = false }
      i = i + 1
    }
    return ok
  }
  // Union target: the source must be assignable to some member.
  if d is TyUnion {
    const members = d.uMembers
    let i = 0
    let ok = false
    while i < members.length {
      if assignable(src, members[i]) { ok = true }
      i = i + 1
    }
    return ok
  }
  // LITERAL types (host `StringLiteral`/`IntegerLiteral`/`RealLiteral`): a
  // literal source is assignable to the SAME literal (a closed set's member —
  // the union-target case above already tried each member), or anywhere its
  // base scalar flows (`0` → i32, `"a"` → string). A non-literal source is
  // NEVER assignable to a literal target — `string` does not flow into
  // `"a" | "b"` (the union is a closed set, not an open string type).
  if s is TyLit {
    if d is TyLit { return s.litKind == d.litKind && s.litText == d.litText }
    return assignable(litBaseTy(s), dst)
  }
  if d is TyLit { return false }
  // A NEGATION target `!T` (A4, residual — usually folded away by
  // `intersectTy`): accepts a source NOT assignable to the negated type.
  if d is TyNeg { return !assignable(src, d.negTy) }
  if s is TyNeg { return false }
  if s is TyPrim {
    if d is TyPrim {
      // Lossless numeric WIDENING (B2): a narrower numeric value flows into a wider
      // slot — annotation, argument, return — along the lattice i32→{i64,f32,f64},
      // i64→f64, f32→f64. The reverse (any narrowing, e.g. i64→i32, f64→f32, f64→i32)
      // is NOT assignable: it is lossy and must be made explicit. Codegen inserts the
      // matching wasm convert at the boundary. f32 literals reach an f32 slot via the
      // float-literal exception at the binding/arg/return sites (a float literal types
      // f64 by default but re-encodes exactly at f32). The binding takes the WIDER type.
      if numWidensName(s.primName, d.primName) { return true }
      return s.primName == d.primName
    }
    return false
  }
  if s is TyObj {
    if d is TyObj {
      const dnames = d.objFieldNames
      const dtys = d.objFieldTypes
      let i = 0
      let ok = true
      while i < dnames.length {
        const srcIx = objFieldType(s, dnames[i])
        if srcIx < 0 { ok = false }
        else if !assignable(srcIx, dtys[i]) { ok = false }
        i = i + 1
      }
      return ok
    }
    return false
  }
  if s is TyArray {
    if d is TyArray {
      // An empty `[]` (element `-1`) is assignable to any array; otherwise the
      // element types must be assignable.
      return assignable(s.aElem, d.aElem)
    }
    return false
  }
  if s is TyMap {
    if d is TyMap {
      // A bare `Map()`/`Set()` (key/value holes, `-1`) is assignable to any map.
      return assignable(s.mKey, d.mKey) && assignable(s.mVal, d.mVal)
    }
    return false
  }
  if s is TyFunc {
    if d is TyFunc {
      // A GENERIC function value (hole params/return) is assignable to a CONCRETE function type only
      // by INSTANTIATION — its body's capability must hold at the target's param types and yield the
      // target's return — NOT the structural rule below, which a hole passes unconditionally. This
      // type-level check reaches every nested position (an ARRAY element, a field) that the
      // expression-level `assignableExpr` interception does not.
      if fnTyHasHole(src) { return genericFnAssignable(src, dst) }
      const sp = s.fnParamTypes
      const dp = d.fnParamTypes
      if sp.length != dp.length { return false }
      let i = 0
      let ok = fnSlotAssignable(s.fnRet, d.fnRet)
      while i < sp.length {
        if !fnSlotAssignable(dp[i], sp[i]) { ok = false }
        i = i + 1
      }
      return ok
    }
    return false
  }
  false
}

// ── per-kind helpers (take a NARROWED variant; recurse back through checkNode) ──
// These helpers receive an already-narrowed `Node` variant as a STRUCT PARAMETER,
// narrow further `Node` children themselves, and call back into `checkNode` — the
// exact shape "Finding 2" historically prohibited. The miscompile is fixed in the
// host (pinned by `tests/cases/types/union-two-visitors.vl` and
// `union-narrowed-helper-recursion.vl`), so the visitor can be factored naturally.

// Look up a generic binding by type-param name in the parallel bind arrays.
function bindOf(bNames: string[], bTys: i32[], name: string) {
  let i = 0
  while i < bNames.length {
    if bNames[i] == name { return bTys[i] }
    i = i + 1
  }
  -1
}

// The demanded shape (TyObj arena index) of hole `name`, or -1.
function holeShapeOf(name: string) {
  let i = 0
  while i < holeShapeNames.length {
    if holeShapeNames[i] == name { return holeShapeTys[i] }
    i = i + 1
  }
  -1
}

// Record that hole `name` was indexed (so it demands an array). Idempotent.
function noteArrayDemand(name: string) {
  let i = 0
  while i < holeArrayDemand.length {
    if holeArrayDemand[i] == name { return 0 }
    i = i + 1
  }
  holeArrayDemand.push(name)
  0
}

// The array BUILTIN methods that constrain an un-annotated-param hole RECEIVER to an array
// (rather than growing a `{method: any}` struct shape). Element-bearing and array-specific —
// a map exposes `set`/`add`/`has`/`delete`/`keys`/`values`, never these — so recognizing them
// on a hole can't hijack a genuine map/struct use.
function holeArrMethod(name: string) {
  name == "map" || name == "filter" || name == "push" || name == "pop"
}

function holeIsArrayDemanded(name: string) {
  let i = 0
  while i < holeArrayDemand.length {
    if holeArrayDemand[i] == name { return true }
    i = i + 1
  }
  false
}

// A type that is still an inference HOLE (`TyVar`): an un-annotated param, or a derived hole.
function tyIsHole(tyIx: i32) {
  if tyIx < 0 { return false }
  const t = T.tys[tyIx]
  if t is TyVar { return true }
  false
}

// Record a deferred binary-op constraint when either operand is a hole — the body can't yet decide
// the operator's form, so the generic call-site validates it under substitution.
function noteBinCstr(lt: i32, op: string, rt: i32) {
  if tyIsHole(lt) || tyIsHole(rt) {
    let k = 0
    while k < binCstrOp.length {
      if binCstrLt[k] == lt && binCstrOp[k] == op && binCstrRt[k] == rt {
        return 0
      }
      k = k + 1
    }
    binCstrLt.push(lt)
    binCstrOp.push(op)
    binCstrRt.push(rt)
  }
  0
}

// Whether the EMITTER can lower `lt op rt` for two CONCRETE operand types — the soundness criterion
// the generic call-site checks after substituting a hole to its argument type. A still-unresolved
// operand (`TyVar`, a nested generic) DEFERS (true — the outer call validates it). Mirrors
// `checkBinary`'s accepted forms; an operator OVERLOAD (`opSelfFnTy`) would also satisfy it but does
// not yet lower, so it stays a clean reject. Operators not modelled here return true (no false
// reject — they keep today's behaviour).
function binOpDefinedFor(op: string, lt0: i32, rt0: i32) {
  const lt = softenLitTy(lt0)
  const rt = softenLitTy(rt0)
  if tyIsHole(lt) || tyIsHole(rt) { return true }
  if op == "==" || op == "!=" { return true }
  const lArr = T.tys[lt]
  const rArr = T.tys[rt]
  if op == "+" {
    if isStringTy(lt) && isStringTy(rt) {
      return true // string concat
    }
    if lArr is TyArray {
      if rArr is TyArray {
        return true // list concat (element agreement checked in the body)
      }
    }
    return isNumeric(lt) && isNumeric(rt)
  }
  if op == "-" || op == "*" || op == "/" || op == "%" {
    return isNumeric(lt) && isNumeric(rt)
  }
  if op == "<" || op == ">" || op == "<=" || op == ">=" {
    if isStringTy(lt) && isStringTy(rt) { return true }
    return isNumeric(lt) && isNumeric(rt)
  }
  true
}

// Record a deferred call-argument constraint: hole-typed argument `at` flowed into the
// CONCRETE param type `exp` of callee `who`. Idempotent per (at, exp) pair. An `exp` that
// still carries a hole is NOT recorded — after `bindGenWalk`+`substTyDeep` at the inner
// call it could only be one of the enclosing body's own holes, and that hole's demands
// surface through its own bindings instead.
function noteArgCstr(at: i32, exp: i32, who: string) {
  let k = 0
  while k < argCstrAt.length {
    if argCstrAt[k] == at && argCstrExp[k] == exp { return 0 }
    k = k + 1
  }
  argCstrAt.push(at)
  argCstrExp.push(exp)
  argCstrWho.push(who)
  0
}

// Re-validate every deferred call-argument constraint that THIS call resolves: substitute
// the hole to the call's concrete argument type and check it against the recorded param
// type. A constraint still touching an unresolved hole (not bound by this call, or a
// nested generic) defers — `validateBinCstrs` for argument flow.
function validateArgCstrs(bNames: string[], bTys: i32[], ix: i32) {
  let ci = 0
  while ci < argCstrAt.length {
    const rat = substTyDeep(argCstrAt[ci], bNames, bTys)
    const rexp = substTyDeep(argCstrExp[ci], bNames, bTys)
    if !tyIsHole(rat) {
      if !tyIsHole(rexp) {
        if !assignable(rat, rexp) {
          let who = argCstrWho[ci]
          if who == "" { who = "a call" } else { who = "`" + who + "`" }
          tErr(
            "argument of type " +
              tyToStr(rat) +
              " flows into " +
              who +
              " expecting " +
              tyToStr(rexp) +
              " (the call's argument types)",
            ix,
          )
        }
      }
    }
    ci = ci + 1
  }
  0
}

// Do every deferred call-argument constraint THIS binding resolves hold (the pure-boolean
// twin of `validateArgCstrs`, for `genericFnAssignable`)? An unresolved hole defers.
function argCstrsHold(bNames: string[], bTys: i32[]) {
  let ci = 0
  while ci < argCstrAt.length {
    const rat = substTyDeep(argCstrAt[ci], bNames, bTys)
    const rexp = substTyDeep(argCstrExp[ci], bNames, bTys)
    if !tyIsHole(rat) {
      if !tyIsHole(rexp) {
        if !assignable(rat, rexp) { return false }
      }
    }
    ci = ci + 1
  }
  true
}

// Re-validate every deferred binary-op constraint that THIS call resolves: substitute the holes to
// the call's concrete argument types and check the operator is defined for them. A constraint still
// touching an unresolved hole (not bound by this call, or a nested generic) defers. The general
// capability check — numeric / string / relational all fall out of one rule.
function validateBinCstrs(bNames: string[], bTys: i32[], ix: i32) {
  let ci = 0
  while ci < binCstrOp.length {
    const clt = substTyDeep(binCstrLt[ci], bNames, bTys)
    const crt = substTyDeep(binCstrRt[ci], bNames, bTys)
    if !tyIsHole(clt) {
      if !tyIsHole(crt) {
        if !binOpDefinedFor(binCstrOp[ci], clt, crt) {
          tErr(
            "operator '" +
              binCstrOp[ci] +
              "' is not defined for " +
              tyToStr(clt) +
              " and " +
              tyToStr(crt) +
              " (the call's argument types)",
            ix,
          )
        }
      }
    }
    ci = ci + 1
  }
  0
}

// A type that definitively CANNOT be indexed `[i]`: a scalar primitive (i32 / f64 / i64 /
// f32 / boolean / null / …) — anything but a `string`. An array / string / struct (may carry
// a `"[]"` trap) / map / hole / error is NOT rejected here (it resolves or defers).
function tyIsNonIndexableScalar(tyIx: i32) {
  if tyIx < 0 { return false }
  const t = T.tys[tyIx]
  if t is TyPrim { return t.primName != "string" }
  false
}

// Member access on an inference hole (host `getChildType` on `Infer<Unknown>`):
// record the field on the hole's demanded shape — creating the shape on first
// access, the field on first read — and return the field's DERIVED hole.
function holeMemberTy(holeName: string, prop: string) {
  let shape = holeShapeOf(holeName)
  if shape < 0 {
    const fnames: string[] = []
    const ftys: i32[] = []
    shape = mkObjTy(fnames, ftys)
    holeShapeNames.push(holeName)
    holeShapeTys.push(shape)
  }
  const st = T.tys[shape]
  if st is TyObj {
    const f = objFieldType(st, prop)
    if f >= 0 { return f }
    const d = mkTyVar("?fld." + prop + "." + holeName)
    st.objFieldNames.push(prop)
    st.objFieldTypes.push(d)
    tyMutEpoch = tyMutEpoch + 1 // hole shape gained a field in place
    return d
  }
  TY_ERR
}

// Resolve a (possibly DERIVED) hole NAME against a call's bindings: a direct
// binding wins; `?ret.<h>` collapses to the pinned function's return (the
// host's instantiate-and-collapse — keeps `inferred-return-soundness`
// rejecting); `?fld.<prop>.<h>` to the pinned object's field (the structural
// A13 read `self.x` concretized per call site). -1 = unresolved.
function substHoleByName(name: string, bNames: string[], bTys: i32[]) {
  const b = bindOf(bNames, bTys, name)
  if b >= 0 { return b }
  if name.length > 5 {
    if name.slice(0, 5) == "?ret." {
      const inner = substHoleByName(name.slice(5, name.length), bNames, bTys)
      if inner >= 0 {
        const it = T.tys[inner]
        if it is TyFunc { return it.fnRet }
      }
      return -1
    }
    // `?elem.<hole>` — the element of an indexed hole (`self[i]`): resolve the hole to its
    // pinned argument; an array yields its element, a string an i32 code point. Mirrors the
    // `?fld.` field read for indexing.
    if name.slice(0, 6) == "?elem." {
      const innerE = substHoleByName(name.slice(6, name.length), bNames, bTys)
      if innerE >= 0 {
        const itE = T.tys[innerE]
        if itE is TyArray { return itE.aElem }
        if itE is TyPrim {
          if itE.primName == "string" { return TY_I32 }
        }
      }
      return -1
    }
    if name.slice(0, 5) == "?fld." {
      const rest = name.slice(5, name.length)
      let dot = -1
      let i = 0
      let going = i < rest.length
      while going {
        if rest[i] == '.' {
          dot = i
          going = false
        } else {
          i = i + 1
          going = i < rest.length
        }
      }
      if dot > 0 {
        const inner2 = substHoleByName(
          rest.slice(dot + 1, rest.length),
          bNames,
          bTys,
        )
        if inner2 >= 0 {
          const it2 = T.tys[inner2]
          if it2 is TyObj {
            const f = objFieldType(it2, rest.slice(0, dot))
            if f >= 0 { return f }
          }
        }
      }
      return -1
    }
  }
  -1
}

// Generic CALL-SITE binding, deep (host `instantiateFunctionType`): walk an
// expected parameter type against the argument's actual type and bind every
// TyVar leaf — a declared type param (`T`) or an inference hole (`?f.N`) — on
// FIRST use. Later uses are checked by the caller against the SUBSTITUTED
// expected type (`substTyDeep`), so disagreeing uses still error
// (generics/return-correlation). Nested positions bind too: a `Box<T>` param
// (`{value: T}`) pins `T` from the argument's field, a callback param's
// signature from the argument function. Recursion over a cyclic arena (a
// recursive named type) is cut by the visited-pair stack.
function bindGenWalk(expIx: i32, atIx: i32, bNames: string[], bTys: i32[]) {
  if expIx < 0 || atIx < 0 { return 0 }
  const e = T.tys[expIx]
  if e is TyVar {
    if bindOf(bNames, bTys, e.tvName) < 0 {
      bNames.push(e.tvName)
      bTys.push(atIx)
    }
    return 0
  }
  let gi = bgSrcStack.length - 1
  while gi >= 0 {
    if bgSrcStack[gi] == expIx && bgDstStack[gi] == atIx { return 0 }
    gi = gi - 1
  }
  bgSrcStack.push(expIx)
  bgDstStack.push(atIx)
  const a = T.tys[atIx]
  if e is TyArray {
    if a is TyArray { bindGenWalk(e.aElem, a.aElem, bNames, bTys) }
  } else if e is TyNullable {
    if a is TyNullable { bindGenWalk(e.nInner, a.nInner, bNames, bTys) }
    else if atIx != TY_NULL { bindGenWalk(e.nInner, atIx, bNames, bTys) }
  } else if e is TyObj {
    if a is TyObj {
      const enames = e.objFieldNames
      const etys = e.objFieldTypes
      let i = 0
      while i < enames.length {
        const sf = objFieldType(a, enames[i])
        if sf >= 0 { bindGenWalk(etys[i], sf, bNames, bTys) }
        i = i + 1
      }
    }
  } else if e is TyFunc {
    if a is TyFunc {
      const ep = e.fnParamTypes
      const ap = a.fnParamTypes
      let i = 0
      while i < ep.length {
        if i < ap.length { bindGenWalk(ep[i], ap[i], bNames, bTys) }
        i = i + 1
      }
      bindGenWalk(e.fnRet, a.fnRet, bNames, bTys)
    }
  } else if e is TyMap {
    // A map/set param (`{[string]: T}`) pins `T` from the argument's value
    // type (the key position walks too, for symmetry).
    if a is TyMap {
      bindGenWalk(e.mKey, a.mKey, bNames, bTys)
      bindGenWalk(e.mVal, a.mVal, bNames, bTys)
    }
  }
  bgSrcStack.pop()
  bgDstStack.pop()
  0
}

// Deep substitution of a call's bindings into a type (host: instantiate-and-
// collapse): a bound TyVar becomes its binding; a DERIVED return hole
// `?ret.<calleeHole>` collapses to the pinned function's return (the body
// called a hole param — `function apply(fn, a, b) fn(a, b)`); composites
// rebuild ONLY when a child actually changed, so a concrete type keeps its
// arena identity (and the in-place pinning semantics that ride on it).
// Cyclic arenas (recursive named types) return themselves unchanged.
function substTyDeep(tyIx: i32, bNames: string[], bTys: i32[]) {
  if tyIx < 0 || bNames.length == 0 { return tyIx }
  const t = T.tys[tyIx]
  if t is TyVar {
    const b = substHoleByName(t.tvName, bNames, bTys)
    if b >= 0 { return b }
    return tyIx
  }
  let si = stSeenStack.length - 1
  while si >= 0 {
    if stSeenStack[si] == tyIx { return tyIx }
    si = si - 1
  }
  stSeenStack.push(tyIx)
  let res = tyIx
  if t is TyArray {
    const e2 = substTyDeep(t.aElem, bNames, bTys)
    if e2 != t.aElem { res = mkArrayTy(e2) }
  } else if t is TyNullable {
    const n2 = substTyDeep(t.nInner, bNames, bTys)
    if n2 != t.nInner { res = mkNullableTy(n2) }
  } else if t is TyObj {
    const onames = t.objFieldNames
    const otys = t.objFieldTypes
    const out: i32[] = []
    let changed = false
    let i = 0
    while i < otys.length {
      const f2 = substTyDeep(otys[i], bNames, bTys)
      if f2 != otys[i] { changed = true }
      out.push(f2)
      i = i + 1
    }
    if changed {
      const nn: string[] = []
      let j = 0
      while j < onames.length {
        nn.push(onames[j])
        j = j + 1
      }
      res = mkObjTy(nn, out)
    }
  } else if t is TyFunc {
    const ps = t.fnParamTypes
    const out2: i32[] = []
    let changed2 = false
    let k = 0
    while k < ps.length {
      const p2 = substTyDeep(ps[k], bNames, bTys)
      if p2 != ps[k] { changed2 = true }
      out2.push(p2)
      k = k + 1
    }
    const r2 = substTyDeep(t.fnRet, bNames, bTys)
    if r2 != t.fnRet { changed2 = true }
    if changed2 { res = mkFuncTy(out2, r2) }
  } else if t is TyUnion {
    const ms = t.uMembers
    const out3: i32[] = []
    let changed3 = false
    let u = 0
    while u < ms.length {
      const m2 = substTyDeep(ms[u], bNames, bTys)
      if m2 != ms[u] { changed3 = true }
      out3.push(m2)
      u = u + 1
    }
    if changed3 { res = mkUnionTy(out3) }
  } else if t is TyMap {
    const k2 = substTyDeep(t.mKey, bNames, bTys)
    const v2 = substTyDeep(t.mVal, bNames, bTys)
    if k2 != t.mKey || v2 != t.mVal { res = mkMapTy(k2, v2, t.mSet) }
  } else if t is TyNeg {
    const g2 = substTyDeep(t.negTy, bNames, bTys)
    if g2 != t.negTy { res = mkNegTy(g2) }
  }
  stSeenStack.pop()
  res
}

// Operator dispatch `a op b` over a STRUCT left operand through the free
// `self`-function named for the operator (`function +(self, b)` — host parser
// B13+B14): the function must exist, take exactly (self, right), and its FIRST
// param must be NAMED `self` (the pollution rule). Binds the operands into the
// function's holes like any call (the operator "monomorphizes per call") and
// substitutes the return. -1 = no such function fits (the caller falls through
// to the operator-FIELD lookup / the native numeric paths).
function opSelfFnTy(op: string, lt: i32, rt: i32, rightIx: i32, ix: i32) {
  const fnTy = lookup(op)
  if fnTy < 0 { return -1 }
  const preFt = T.tys[fnTy]
  if preFt is TyFunc {
    if preFt.fnRet == -2 {
      if !onInferStack(op) {
        const dIx = fnDeclIx[op] ?? -1
        if dIx >= 0 { checkNode(dIx) }
      }
    }
  } else {
    return -1
  }
  const dIx2 = fnDeclIx[op] ?? -1
  if dIx2 < 0 { return -1 }
  const d = P.nodes[dIx2]
  let selfOk = false
  if d is FuncDecl {
    if d.fnParams.length == 2 {
      const p0 = P.nodes[d.fnParams[0]]
      if p0 is Param {
        if p0.parName == "self" { selfOk = true }
      }
    }
  }
  if !selfOk { return -1 }
  const ft = T.tys[fnTy]
  if ft is TyFunc {
    let retTy = ft.fnRet
    if retTy == -2 { retTy = TY_ERR }
    const params = ft.fnParamTypes
    if params.length != 2 { return -1 }
    if !assignable(lt, params[0]) { return -1 }
    const bNames: string[] = []
    const bTys: i32[] = []
    const p0t = T.tys[params[0]]
    if p0t is TyVar {
      const hs0 = holeShapeOf(p0t.tvName)
      if hs0 >= 0 {
        if !assignable(lt, hs0) { return -1 }
      }
    }
    bindGenWalk(params[0], lt, bNames, bTys)
    bindGenWalk(params[1], rt, bNames, bTys)
    const expected = substTyDeep(params[1], bNames, bTys)
    const p1t = T.tys[params[1]]
    if p1t is TyVar {
      const hs1 = holeShapeOf(p1t.tvName)
      if hs1 >= 0 {
        if !assignableExpr(rightIx, rt, hs1) {
          tErr(
            "operator '" +
              op +
              "': expected " +
              tyToStr(hs1) +
              ", got " +
              tyToStr(rt),
            ix,
          )
        }
      }
    }
    if !assignableExpr(rightIx, rt, expected) {
      tErr(
        "operator '" +
          op +
          "': expected " +
          tyToStr(expected) +
          ", got " +
          tyToStr(rt),
        ix,
      )
    }
    if bNames.length > 0 { retTy = substTyDeep(retTy, bNames, bTys) }
    return retTy
  }
  -1
}

// The declared parameter NAMES of the top-level function `name` (via its
// `FuncDecl` in `fnDeclIx`), or an empty list when no declaration is known (an
// undeclared name, or a closure-valued binding — `TyFunc` carries no parameter
// names, so NAMED arguments resolve only against a declared function).
function fnParamNamesOf(name: string) {
  const out: string[] = []
  const dIx = fnDeclIx[name] ?? -1
  if dIx >= 0 {
    const d = P.nodes[dIx]
    if d is FuncDecl {
      const ps = d.fnParams
      let i = 0
      while i < ps.length {
        const p = P.nodes[ps[i]]
        if p is Param { out.push(p.parName) }
        i = i + 1
      }
    }
  }
  out
}

// Bind a call's arguments into PARAMETER order when any is NAMED (`f(b: 1,
// a: 2)`), mirroring the host's `orderArgumentsByParameters`: named args fill
// their parameter's slot, positionals fill the remaining slots in order.
// Returns the VALUE-node indices in parameter order, or an empty list on a
// binding failure (an unknown/duplicate name — diagnosed here). `paramNames`
// must align 1:1 with the checked parameter types (the UFCS path passes the
// names AFTER `self`, since the receiver fills slot 0 separately).
function orderNamedCallArgs(
  paramNames: string[],
  args: i32[],
  argNames: string[],
  ix: i32,
) {
  const bad: i32[] = []
  if paramNames.length != args.length {
    // Arity is diagnosed by the caller; just refuse to reorder.
    tErr("named arguments require a declared function with matching arity", ix)
    return bad
  }
  const ordered = orderArgsByParamNames(paramNames, args, argNames)
  if ordered.length != paramNames.length {
    tErr("named argument does not match a parameter", ix)
    return bad
  }
  let i = 0
  while i < ordered.length {
    if ordered[i] < 0 {
      tErr("named argument does not match a parameter", ix)
      return bad
    }
    i = i + 1
  }
  ordered
}

function ufcsCallTy(plainName: string, recvTy: i32, n: Call, ix: i32) {
  // A UFCS callee names a free `self`-function by its SOURCE name. The module
  // merge mangles such functions (`shout` → `shout$m1`) but leaves the call's
  // property string plain so field precedence still resolves from the receiver
  // type; `ufcsAliasOf` maps the plain name to the mangled function here, where
  // the field check has already been passed. Single-file builds have no merge,
  // so the alias is identity.
  const name = ufcsAliasOf(plainName)
  const fnTy = lookup(name)
  if fnTy < 0 { return -1 }
  const preFt = T.tys[fnTy]
  if preFt is TyFunc {
    if preFt.fnRet == -2 {
      if !onInferStack(name) {
        const dIx = fnDeclIx[name] ?? -1
        if dIx >= 0 { checkNode(dIx) }
      }
    }
  } else {
    return -1
  }
  const ft = T.tys[fnTy]
  if ft is TyFunc {
    let retTy = ft.fnRet
    if retTy == -2 { retTy = TY_ERR }
    const params = ft.fnParamTypes
    let args = n.callArgs
    if params.length != args.length + 1 { return -1 }
    if !assignable(recvTy, params[0]) { return -1 }
    // NAMED arguments (`5.scale(plus: 1, by: 2)`): the receiver is an unnamed
    // slot-0 positional, so the explicit args bind against the parameter names
    // AFTER `self`, in PARAMETER order (host: `orderArgumentsByParameters` over
    // the full list with the injected receiver unnamed).
    if hasNamedArgs(n.callArgNames) {
      const uNames = fnParamNamesOf(name)
      if uNames.length != params.length {
        tErr("named arguments require a declared function", ix)
        return TY_ERR
      }
      const restNames: string[] = []
      let rn = 1
      while rn < uNames.length {
        restNames.push(uNames[rn])
        rn = rn + 1
      }
      args = orderNamedCallArgs(restNames, args, n.callArgNames, ix)
      if args.length != restNames.length { return TY_ERR }
    }
    // Generic dispatch (host: UFCS reuses the call machinery, so `self`
    // monomorphizes to the receiver's shape): bind the receiver into the
    // `self` param's holes — when the body DEMANDED fields, a receiver
    // missing one is NOT this method (fall through to the caller's error) —
    // then bind/check the explicit args and substitute the return.
    const bNames: string[] = []
    const bTys: i32[] = []
    const p0 = T.tys[params[0]]
    if p0 is TyVar {
      const hShape0 = holeShapeOf(p0.tvName)
      if hShape0 >= 0 {
        if !assignable(recvTy, hShape0) { return -1 }
      }
    }
    bindGenWalk(params[0], recvTy, bNames, bTys)
    let i = 0
    while i < args.length {
      const at = checkNode(args[i])
      bindGenWalk(params[i + 1], at, bNames, bTys)
      const expected = substTyDeep(params[i + 1], bNames, bTys)
      const pHole = T.tys[params[i + 1]]
      if pHole is TyVar {
        const hShape = holeShapeOf(pHole.tvName)
        if hShape >= 0 {
          if !assignableExpr(args[i], at, hShape) {
            tErr(
              "argument " +
                i32ToStr(i + 1) +
                ": expected " +
                tyToStr(hShape) +
                ", got " +
                tyToStr(at),
              ix,
            )
          }
        }
        if holeIsArrayDemanded(pHole.tvName) {
          if tyIsNonIndexableScalar(at) {
            tErr(
              "argument " +
                i32ToStr(i + 1) +
                ": expected an array, got " +
                tyToStr(at),
              ix,
            )
          }
        }
      }
      constrainEmpty(at, expected)
      if !assignableExpr(args[i], at, expected) {
        tErr(
          "argument " +
            i32ToStr(i + 1) +
            ": expected " +
            tyToStr(expected) +
            ", got " +
            tyToStr(at),
          ix,
        )
      }
      i = i + 1
    }
    if bNames.length > 0 { retTy = substTyDeep(retTy, bNames, bTys) }
    return retTy
  }
  -1
}

// The innermost guard registration for `name`, or -1 (not a guard).
function guardIndexOf(name: string) {
  let i = guardNames.length - 1
  while i >= 0 {
    if guardNames[i] == name { return i }
    i = i - 1
  }
  -1
}

// The A6b guard fact of a function body's result expression over the params:
// the index of the param whose NULL-ness it tests, or -1 (not a guard shape).
// Sets nothing itself — the caller reads the branch direction from the shape:
// the encoded result is `paramIndex * 2 + 1` when the non-null branch is THEN
// (`x != null`, `x is T`), `paramIndex * 2` when it is ELSE (`x == null`,
// `x is null`). Mirrors the host's `conditionNarrowing` over a bare param.
function guardFactOf(exprIx: i32, paramNames: string[]) {
  const e = P.nodes[exprIx]
  if e is Paren { return guardFactOf(e.parInner, paramNames) }
  if e is IsExpr {
    const obj = P.nodes[e.isObj]
    if obj is Ident {
      let gi = 0
      while gi < paramNames.length {
        if paramNames[gi] == obj.identName {
          if e.isVariant == "null" { return gi * 2 }
          return gi * 2 + 1
        }
        gi = gi + 1
      }
    }
    return -1
  }
  if e is BinExpr {
    if e.binOp == "==" || e.binOp == "!=" {
      const placeIx = nullCmpPlace(exprIx)
      if placeIx >= 0 {
        const p = P.nodes[placeIx]
        if p is Ident {
          let gj = 0
          while gj < paramNames.length {
            if paramNames[gj] == p.identName {
              if e.binOp == "!=" { return gj * 2 + 1 }
              return gj * 2
            }
            gj = gj + 1
          }
        }
      }
    }
  }
  -1
}

// A call expression: array-method builtins (`xs.push`), string-method builtins
// (`.slice`/`.indexOf`/`.includes`/`.charCodeAt`), the `print`/`fromCodePoint`
// builtins, then the generic function-call path (arity + per-arg assignability).
// UFCS `self`-method dispatch (host parser: `o.f(args)` → `f(o, args)` for a
// free function whose first parameter accepts the receiver). Returns the
// call's type, or -1 when no matching function exists (the caller reports its
// own "no method"/"no field" error). Mirrors the general call path's pending-
// return demand-inference; generic (TyVar) self-functions are not dispatched.
function checkCallNode(n: Call, ix: i32) {
  // Array method call `xs.push(e)`: when the callee is a member access whose
  // receiver is an array, type it as a builtin (NOT a struct field). Only fires for
  // an array receiver, so a plain `f(…)` / non-array method falls through.
  const cfn = P.nodes[n.callFn]
  if cfn is Member {
    // A member-access callee is, by definition, function-typed — the `method`
    // classification for semantic tokens. The builtin method arms below type and
    // return it directly (never via the member-read arm), so record its name here;
    // a struct field holding a function falls through to `checkNode(n.callFn)` and
    // `symMem` overwrites the type for hover.
    symMemMethod(n.callFn)
    let recvTy = checkNode(cfn.memObj)
    let rt = T.tys[recvTy]
    // An un-annotated-param HOLE receiving an ARRAY method (`self.map`/`.filter`/`.push`/
    // `.pop`) is constrained to an array — the method analogue of `self[i]` / `self.length`.
    // Synthesize an array over a DERIVED element hole (`?elem.<hole>`) and fall into the
    // array-method arm below; `noteArrayDemand` makes a non-array argument a call-site error
    // and pins the param to the concrete array per call shape (the emitter then monomorphizes
    // the method on the concrete element, exactly like an annotated array param). Without this
    // the hole would grow a `{map: any}` STRUCT shape no array argument can satisfy.
    if rt is TyVar {
      if holeArrMethod(cfn.memProp) {
        noteArrayDemand(rt.tvName)
        recvTy = mkArrayTy(mkTyVar("?elem." + rt.tvName))
      }
    }
    rt = T.tys[recvTy]
    if rt is TyArray {
      const margs = n.callArgs
      if cfn.memProp == "push" {
        if margs.length != 1 {
          tErr("push expects 1 argument, got " + i32ToStr(margs.length), ix)
        } else {
          // Contextual param inference for a pushed callback: `fs.push((n) => n + 1)` over a
          // `((i32) => i32)[]` seeds the lambda's param from the element function type, so an
          // un-annotated lambda infers `n` instead of erroring (mirrors the `.map`/`.filter`
          // seeding). A non-function element / non-lambda arg is left untouched by `seedExpected`.
          if rt.aElem >= 0 { seedExpected(margs[0], rt.aElem) }
          const pat = checkNode(margs[0])
          // The first `.push(v)` on a bare empty `[]` (element hole `-1`) PINS its
          // element type to `typeof v` in place — this is the usage-driven inference
          // that resolves an un-annotated `const xs = []` (see `infer-empty-push.vl`),
          // and clears the uninferred-binding floor. A later conflicting push is then
          // a clean type error.
          if rt.aElem < 0 {
            rt.aElem = pat
            tyMutEpoch = tyMutEpoch + 1 // `.push` pinned the element in place
          } else if !assignableExpr(margs[0], pat, rt.aElem) {
            // `assignableExpr` (not bare `assignable`) so a float-literal argument re-encodes into
            // an `f32` element (`xs.push(2.5)` over `f32[]`), exactly as it does at a binding.
            tErr(
              "push: cannot add " + tyToStr(pat) + " to " + tyToStr(recvTy),
              ix,
            )
          }
        }
        return TY_I32
      }
      // `.map(fn)` / `.filter(pred)`: the callback is a 1-arg function over the
      // element type; map yields an array of the callback's return, filter the
      // same array type (its predicate must yield bool).
      if cfn.memProp == "map" || cfn.memProp == "filter" {
        const cargs = n.callArgs
        if cargs.length != 1 {
          tErr(
            cfn.memProp + " expects 1 argument, got " + i32ToStr(cargs.length),
            ix,
          )
          return TY_ERR
        }
        // Contextual param inference: the callback is `(elem) -> ?` over the
        // receiver's element type. Stash that expected param type so an
        // UN-annotated function-literal arg (`function(n) …`) infers `n` from the
        // receiver instead of erroring — matching the host. Only meaningful when
        // the arg is an anonymous function literal AND the element type is known
        // (not the `-1` hole of a never-pinned `[]`); otherwise it is left
        // pending and cleared below so it can't leak.
        const cbArg = P.nodes[cargs[0]]
        if cbArg is FuncDecl {
          if cbArg.fnName == "" && rt.aElem >= 0 {
            recordCbExpected(cargs[0], [rt.aElem])
          }
        }
        const cbTy = checkNode(cargs[0])
        const cb = T.tys[cbTy]
        if cb is TyFunc {
          const cbParams = cb.fnParamTypes
          if cbParams.length != 1 {
            tErr(
              cfn.memProp +
                " callback expects 1 parameter, got " +
                i32ToStr(cbParams.length),
              ix,
            )
          } else if !assignable(rt.aElem, cbParams[0]) {
            tErr(
              cfn.memProp +
                " callback: parameter expects " +
                tyToStr(cbParams[0]) +
                ", got " +
                tyToStr(rt.aElem),
              ix,
            )
          }
          if cfn.memProp == "filter" {
            if !assignable(cb.fnRet, TY_BOOL) {
              tErr(
                "filter predicate must yield boolean, got " + tyToStr(cb.fnRet),
                ix,
              )
            }
            return recvTy
          }
          return mkArrayTy(cb.fnRet)
        }
        tErr(cfn.memProp + " expects a function, got " + tyToStr(cbTy), ix)
        return TY_ERR
      }
      // `.pop()` / `.get(i)` yield `T | null` (an empty pop / out-of-range get is
      // normal absence); `.clear()` empties in place and yields nothing.
      if cfn.memProp == "pop" {
        if margs.length != 0 {
          tErr("pop expects 0 arguments, got " + i32ToStr(margs.length), ix)
        }
        return mkNullableTy(rt.aElem)
      }
      if cfn.memProp == "get" {
        if margs.length != 1 {
          tErr("get expects 1 argument, got " + i32ToStr(margs.length), ix)
        } else {
          const gat = checkNode(margs[0])
          if !assignable(gat, TY_I32) {
            tErr("get: index must be i32, got " + tyToStr(gat), ix)
          }
        }
        return mkNullableTy(rt.aElem)
      }
      if cfn.memProp == "clear" {
        if margs.length != 0 {
          tErr("clear expects 0 arguments, got " + i32ToStr(margs.length), ix)
        }
        return TY_VOID
      }
      // `.slice(start, end?)` yields a NEW array of the SAME element type — the bounds
      // are i32 (a missing `end` defaults to the length; negatives count from the end).
      if cfn.memProp == "slice" {
        if margs.length != 1 && margs.length != 2 {
          tErr(
            "slice expects 1 or 2 arguments, got " + i32ToStr(margs.length),
            ix,
          )
        } else {
          let si = 0
          while si < margs.length {
            const sat = checkNode(margs[si])
            if !assignable(sat, TY_I32) {
              tErr("slice: bound must be i32, got " + tyToStr(sat), ix)
            }
            si = si + 1
          }
        }
        return recvTy
      }
      // UFCS `self`-method on an array receiver (`parts.join(sep)`): an array
      // carries no user FIELD, so a matching free `self`-function resolves
      // directly — the array dual of the string/struct/union UFCS paths.
      const au = ufcsCallTy(cfn.memProp, recvTy, n, ix)
      if au >= 0 { return au }
      tErr("no method '." + cfn.memProp + "' on array " + tyToStr(recvTy), ix)
      return TY_ERR
    }
    // Map/Set methods over the `{[K]: V}` rep, gated by FLAVOR: a map exposes
    // `.set`/`.get`/`.has`/`.delete`/`.keys()`/`.values()`; a SET exposes only
    // `.add`/`.has`/`.delete`/`.values()` (the Map surface must not leak — `.set`
    // on a set / `.add` on a map is an unknown-property error). The first
    // `.set`/`.add` on a bare `Map()`/`Set()` PINS its key/value holes in place,
    // so a later conflicting use is a clean type error.
    if rt is TyMap {
      const mp = cfn.memProp
      const margs2 = n.callArgs
      if mp == "set" && rt.mSet == 0 {
        if margs2.length != 2 {
          tErr("set expects 2 arguments, got " + i32ToStr(margs2.length), ix)
        } else {
          const k0 = checkNode(margs2[0])
          const v0 = checkNode(margs2[1])
          if rt.mKey < 0 {
            rt.mKey = k0
            tyMutEpoch = tyMutEpoch + 1 // `.set` pinned the key in place
          } else if !assignable(k0, rt.mKey) {
            tErr(
              "set: expected " + tyToStr(rt.mKey) + ", got " + tyToStr(k0),
              ix,
            )
          }
          if rt.mVal < 0 {
            rt.mVal = v0
            tyMutEpoch = tyMutEpoch + 1 // `.set` pinned the value in place
          } else if !assignable(v0, rt.mVal) {
            tErr(
              "set: expected " + tyToStr(rt.mVal) + ", got " + tyToStr(v0),
              ix,
            )
          }
        }
        return TY_VOID
      }
      if mp == "get" && rt.mSet == 0 {
        if margs2.length != 1 {
          tErr("get expects 1 argument, got " + i32ToStr(margs2.length), ix)
        } else {
          const k1 = checkNode(margs2[0])
          if !assignable(k1, rt.mKey) {
            tErr(
              "get: key must be " + tyToStr(rt.mKey) + ", got " + tyToStr(k1),
              ix,
            )
          }
        }
        return mkNullableTy(rt.mVal)
      }
      if mp == "add" && rt.mSet == 1 {
        if margs2.length != 1 {
          tErr("add expects 1 argument, got " + i32ToStr(margs2.length), ix)
        } else {
          const ka = checkNode(margs2[0])
          if rt.mKey < 0 {
            rt.mKey = ka
            tyMutEpoch = tyMutEpoch + 1 // `.add` pinned the Set key in place
          } else if !assignable(ka, rt.mKey) {
            tErr(
              "add: expected " + tyToStr(rt.mKey) + ", got " + tyToStr(ka),
              ix,
            )
          }
        }
        return TY_VOID
      }
      if mp == "has" || mp == "delete" {
        if margs2.length != 1 {
          tErr(mp + " expects 1 argument, got " + i32ToStr(margs2.length), ix)
        } else {
          const k2 = checkNode(margs2[0])
          if !assignable(k2, rt.mKey) {
            tErr(
              mp + ": key must be " + tyToStr(rt.mKey) + ", got " + tyToStr(k2),
              ix,
            )
          }
        }
        return TY_BOOL
      }
      if mp == "keys" && rt.mSet == 0 {
        if margs2.length != 0 { tErr("keys expects no arguments", ix) }
        return mkArrayTy(rt.mKey)
      }
      if mp == "values" {
        if margs2.length != 0 { tErr("values expects no arguments", ix) }
        // A set's `.values()` yields its ELEMENTS (the keys); a map's its values.
        if rt.mSet == 1 { return mkArrayTy(rt.mKey) }
        return mkArrayTy(rt.mVal)
      }
      tErr("unknown property `" + mp + "` on " + tyToStr(recvTy), ix)
      return TY_ERR
    }
    // String methods: `.slice(i32,i32)->string`, `.indexOf(string)->i32`,
    // `.includes(string)->bool`, `.charCodeAt(i32)->i32`. (`.length` is a Member,
    // handled there; `s[i]` is an Index.) Element types are checked.
    if rt is TyPrim {
      if rt.primName == "string" {
        const sp = cfn.memProp
        const sargs = n.callArgs
        if sp == "slice" {
          if sargs.length != 2 {
            tErr("slice expects 2 arguments, got " + i32ToStr(sargs.length), ix)
          } else {
            const s0 = checkNode(sargs[0])
            const s1 = checkNode(sargs[1])
            if !assignable(s0, TY_I32) || !assignable(s1, TY_I32) {
              tErr(
                "slice expects i32 bounds, got " +
                  tyToStr(s0) +
                  " and " +
                  tyToStr(s1),
                ix,
              )
            }
          }
          return TY_STR
        }
        if sp == "indexOf" {
          if sargs.length != 1 {
            tErr(
              "indexOf expects 1 argument, got " + i32ToStr(sargs.length),
              ix,
            )
          } else {
            const a0 = checkNode(sargs[0])
            if !assignable(a0, TY_STR) {
              tErr("indexOf expects a string, got " + tyToStr(a0), ix)
            }
          }
          return TY_I32
        }
        if sp == "includes" {
          if sargs.length != 1 {
            tErr(
              "includes expects 1 argument, got " + i32ToStr(sargs.length),
              ix,
            )
          } else {
            const a0 = checkNode(sargs[0])
            if !assignable(a0, TY_STR) {
              tErr("includes expects a string, got " + tyToStr(a0), ix)
            }
          }
          return TY_BOOL
        }
        if sp == "charCodeAt" {
          if sargs.length != 1 {
            tErr(
              "charCodeAt expects 1 argument, got " + i32ToStr(sargs.length),
              ix,
            )
          } else {
            const a0 = checkNode(sargs[0])
            if !assignable(a0, TY_I32) {
              tErr("charCodeAt expects an i32 index, got " + tyToStr(a0), ix)
            }
          }
          return TY_I32
        }
        // UFCS `self`-method on a string receiver (`"hello".first()`).
        const su = ufcsCallTy(sp, recvTy, n, ix)
        if su >= 0 { return su }
        tErr("no method '." + sp + "' on string", ix)
        return TY_ERR
      }
    }
    // UFCS `self`-method on any other receiver (struct / nullable / union):
    // `o.f(args)` lowers to `f(o, args)` when the receiver carries no such
    // FIELD (a callable field keeps precedence) and a matching free function
    // exists; otherwise fall through to the normal member-call path/error.
    let ufcsHasField = false
    const urt = T.tys[recvTy]
    if urt is TyObj {
      if objFieldType(urt, cfn.memProp) >= 0 { ufcsHasField = true }
    }
    if !ufcsHasField {
      const uu = ufcsCallTy(cfn.memProp, recvTy, n, ix)
      if uu >= 0 { return uu }
    }
  }
  // `print(x)` is a compiler builtin (no module/import system yet): it accepts a
  // single value of any printable type and yields void. Special-cased so a program
  // that prints does not trip "undeclared identifier 'print'". Each argument is
  // still checked so a type error inside it surfaces.
  if cfn is Ident {
    if cfn.identName == "print" {
      const pargs = n.callArgs
      let pj = 0
      while pj < pargs.length {
        const pt = checkNode(pargs[pj])
        // `print` renders ONE scalar/string rep at runtime; a BOXED value-union (`i32 |
        // string` — `≥2` distinct value atoms) has no fixed rep, so emit cannot lower
        // `print(<union>)` (it produced invalid wasm). An emitter-capability rejection,
        // not a type error — the union must be narrowed with `is` first.
        // `valueUnionRetName` is the exact boxing gate: it stays "" for a same-rep
        // literal union (`0 | 1` is plain i32) and for `never` (empty), so those still
        // print.
        if valueUnionRetName(pt) != "" {
          tErrUnsupported(
            "print of a union value (" +
              tyToStr(pt) +
              ") is type-valid but not yet supported by codegen — narrow it first, e.g. `if v is i32 { print(v) }`",
            pargs[pj],
          )
        }
        pj = pj + 1
      }
      return TY_VOID
    }
    // `Map()` / `Set()` construct an empty string-keyed map: key/value HOLES (-1)
    // assignable to any map annotation (`const m: {[string]: i32} = Map()`).
    if cfn.identName == "Map" || cfn.identName == "Set" {
      if n.callArgs.length != 0 {
        tErr(cfn.identName + " expects no arguments", ix)
      }
      if cfn.identName == "Set" {
        // A set's VALUE type is the membership boolean; the element (key) is a
        // hole pinned by the annotation or the first `.add`.
        return mkMapTy(-1, TY_BOOL, 1)
      }
      return mkMapTy(-1, -1, 0)
    }
    // `toString(x)` is a builtin: an i32 (decimal digits) or boolean ("true" /
    // "false") renders as a string.
    if cfn.identName == "toString" {
      const targs = n.callArgs
      if targs.length != 1 {
        tErr("toString expects 1 argument, got " + i32ToStr(targs.length), ix)
      } else {
        const t0 = checkNode(targs[0])
        if !assignable(t0, TY_I32) && !assignable(t0, TY_BOOL) {
          tErr("toString expects an i32 or boolean, got " + tyToStr(t0), ix)
        }
      }
      return TY_STR
    }
    // `fromCodePoints(xs)` is a builtin: an `i32[]` of code points -> a string,
    // in one bulk copy (the amortized alternative to per-char concat).
    if cfn.identName == "fromCodePoints" {
      const pargs = n.callArgs
      if pargs.length != 1 {
        tErr(
          "fromCodePoints expects 1 argument, got " + i32ToStr(pargs.length),
          ix,
        )
      } else {
        const p0 = checkNode(pargs[0])
        const p0t = T.tys[p0]
        let pOk = false
        if p0t is TyArray {
          // An empty `[]` literal's element hole (-1) pins to i32 here.
          if p0t.aElem < 0 || assignable(p0t.aElem, TY_I32) { pOk = true }
        }
        if p0t is TyErr { pOk = true }
        if !pOk {
          tErr("fromCodePoints expects an i32[], got " + tyToStr(p0), ix)
        }
      }
      return TY_STR
    }
    // `fromCodePoint(code)` is a builtin: an i32 code point -> a length-1 string.
    if cfn.identName == "fromCodePoint" {
      const fargs = n.callArgs
      if fargs.length != 1 {
        tErr(
          "fromCodePoint expects 1 argument, got " + i32ToStr(fargs.length),
          ix,
        )
      } else {
        const f0 = checkNode(fargs[0])
        if !assignable(f0, TY_I32) {
          tErr("fromCodePoint expects an i32, got " + tyToStr(f0), ix)
        }
      }
      return TY_STR
    }
    // The array-intrinsic floor (std-design D1 / collections-design §LS.2),
    // host parity: `defaultScope.ts`. `__array_new__(n, fill)` allocates `n`
    // slots each set to `fill`, typing as `T[]` with `T` = the fill's type.
    if cfn.identName == "__array_new__" {
      const anArgs = n.callArgs
      if anArgs.length != 2 {
        tErr(
          "__array_new__ expects 2 arguments, got " + i32ToStr(anArgs.length),
          ix,
        )
        return mkArrayTy(-1)
      }
      const anLen = checkNode(anArgs[0])
      if !assignable(anLen, TY_I32) {
        tErr("__array_new__ expects an i32 length, got " + tyToStr(anLen), ix)
      }
      return mkArrayTy(checkNode(anArgs[1]))
    }
    // `__array_new_default__(n)`: `n` zeroed/default slots. The element type is
    // a HOLE (-1) pinned by the annotation — the empty-`[]` mechanism (host: the
    // fresh element hole returned by `typeFromExpression`).
    if cfn.identName == "__array_new_default__" {
      const adArgs = n.callArgs
      if adArgs.length != 1 {
        tErr(
          "__array_new_default__ expects 1 argument, got " +
            i32ToStr(adArgs.length),
          ix,
        )
      } else {
        const adLen = checkNode(adArgs[0])
        if !assignable(adLen, TY_I32) {
          tErr(
            "__array_new_default__ expects an i32 length, got " + tyToStr(adLen),
            ix,
          )
        }
      }
      return mkArrayTy(-1)
    }
    // `__array_copy__(dst, dstAt, src, srcAt, count)`: bulk-move `count`
    // elements from `src[srcAt..]` into `dst[dstAt..]`; void. dst/src must be
    // arrays; the dst↔src ELEMENT correlation is deliberately NOT enforced —
    // host parity: generic param↔param correlation is lenient there too (a
    // mismatched pair fails loudly at the emit stage in both compilers).
    if cfn.identName == "__array_copy__" {
      const acArgs = n.callArgs
      if acArgs.length != 5 {
        tErr(
          "__array_copy__ expects 5 arguments, got " + i32ToStr(acArgs.length),
          ix,
        )
        return TY_VOID
      }
      let acI = 0
      while acI < 5 {
        const acT = checkNode(acArgs[acI])
        if acI == 0 || acI == 2 {
          const acTy = T.tys[acT]
          let acOk = false
          if acTy is TyArray { acOk = true }
          if acTy is TyErr { acOk = true }
          if !acOk {
            tErr("__array_copy__ expects a T[], got " + tyToStr(acT), ix)
          }
        } else {
          if !assignable(acT, TY_I32) {
            tErr("__array_copy__ expects an i32, got " + tyToStr(acT), ix)
          }
        }
        acI = acI + 1
      }
      return TY_VOID
    }
    // `__trap__()`: the deliberate abort primitive — lowered to `unreachable`.
    // `__trap__("reason")`: an OPTIONAL single string message, printed to the
    // host boundary (the print-of-string path) before the abort — so the trap
    // carries a human-readable reason. Either form still "never returns".
    if cfn.identName == "__trap__" {
      if n.callArgs.length > 1 {
        tErr("__trap__ takes an optional string message", ix)
      } else if n.callArgs.length == 1 {
        const trapMsgTy = checkNode(n.callArgs[0])
        if !assignable(trapMsgTy, TY_STR) {
          tErr(
            "__trap__ takes an optional string message, got " + tyToStr(trapMsgTy),
            ix,
          )
        }
      }
      return TY_VOID
    }
  }
  const fnTy = checkNode(n.callFn)
  let args = n.callArgs
  const ft = T.tys[fnTy]
  if ft is TyFunc {
    // PENDING return (-2): the un-annotated callee hasn't been inferred yet (a
    // forward call). Demand-infer it now — check its FuncDecl, which patches this
    // very TyFunc in place — unless it is already on the in-progress stack (an
    // in-cycle call: contribute TY_ERR so the cycle can be detected at the root).
    if ft.fnRet == -2 {
      if cfn is Ident {
        if !onInferStack(cfn.identName) {
          const dIx = fnDeclIx[cfn.identName] ?? -1
          if dIx >= 0 { checkNode(dIx) }
        }
      }
    }
    let retTy = ft.fnRet
    if retTy == -2 {
      retTy = TY_ERR
      // A DIRECT self-recursive call (`fib(n-1)` inside `fib`) — the callee is the very
      // function being inferred (the inference-stack top) — resolves to that body's
      // PROVISIONAL type: the concrete base-case returns accumulated so far
      // (`inferObserved`). Without this it is `TY_ERR`, and since `assignable(TY_ERR,
      // string)` is vacuously true, a `+` over the call (`fib(n-1) + fib(n-2)`) takes the
      // string-concat form and pollutes the inferred return to `i32 | string`. The base
      // case is checked before the recursive tail, so `inferObserved` already holds it.
      // MUTUAL recursion (callee != the accumulating function) keeps `TY_ERR` and is
      // settled by the binding-group fixpoint; a recursive call seen before any base case
      // (`inferObserved < 0`) also stays `TY_ERR`.
      if cfn is Ident {
        if inferStack.length > 0 {
          if inferStack[inferStack.length - 1] == cfn.identName {
            if inferObserved >= 0 { retTy = inferObserved }
          }
        }
      }
    }
    const params = ft.fnParamTypes
    if args.length != params.length {
      tErr(
        "wrong number of arguments: expected " +
          i32ToStr(params.length) +
          ", got " +
          i32ToStr(args.length),
        ix,
      )
      return retTy
    }
    // NAMED arguments bind to parameters by NAME, then positionally — source
    // order is irrelevant for named args (host: `ensureParameters` /
    // `orderArgumentsByParameters`). `TyFunc` carries no parameter names, so
    // the names resolve against the callee's `FuncDecl`; a closure-valued
    // callee (no declaration) cannot take named arguments.
    if hasNamedArgs(n.callArgNames) {
      let cNames: string[] = []
      if cfn is Ident { cNames = fnParamNamesOf(cfn.identName) }
      if cNames.length != params.length {
        tErr("named arguments require a declared function", ix)
        return retTy
      }
      args = orderNamedCallArgs(cNames, args, n.callArgNames, ix)
      if args.length != params.length { return retTy }
    }
    // Generic CALL-SITE inference: a TyVar param (or `T[]`) BINDS its type-param to
    // the argument's type (first use wins; later uses must agree), and the return
    // type substitutes through the binding — so `id("s")` is `string`, and
    // `let n: i32 = id("s")` is a genuine type error downstream.
    const bNames: string[] = []
    const bTys: i32[] = []
    let i = 0
    while i < args.length {
      // Contextual param inference for a function-VALUE argument: propagate the expected
      // param type into the argument so an un-annotated literal param infers from the
      // signature (the general HOF case, matching `.map`/`.filter`) — including a lambda
      // nested in a composite argument (`apply([(x) => …], …)`). SUBSTITUTE the type-param
      // bindings accumulated from EARLIER args first, so a generic HOF's callback infers its
      // param from the already-bound type param: `mapArr(xs: T[], f: (T) => R)` called
      // `mapArr([1,2,3], (x) => …)` binds `T = i32` from `xs`, then seeds `f`'s `(x)` as `i32`
      // (without this `x` stays a `TyVar` and the monomorphizer can't concretize the lambda).
      seedExpected(args[i], substTyDeep(params[i], bNames, bTys))
      const at = checkNode(args[i])
      // Bind every TyVar reachable in the expected param position from the
      // argument's shape (first use wins), then check the argument against the
      // SUBSTITUTED expected type — a later disagreeing use errors here.
      bindGenWalk(params[i], at, bNames, bTys)
      const expected = substTyDeep(params[i], bNames, bTys)
      // A HOLE argument meeting a CONCRETE param can't be judged here — a hole is
      // permissively assignable both ways, so the check below passes vacuously.
      // Record the demand; the generic call site that pins the hole re-validates
      // it under the substituted argument types (the deferred binary-op-constraint
      // pattern), so `function f(x) { g(x) }` with `g(n: i32)` rejects `f("s")`.
      if tyIsHole(at) {
        if !tyIsHole(expected) {
          let ccWho = ""
          if cfn is Ident { ccWho = cfn.identName }
          noteArgCstr(at, expected, ccWho)
        }
      }
      // A hole param whose body DEMANDED fields (member access on the hole)
      // checks the argument against the demanded shape, so `getx(5)` rejects
      // when the body read `o.x` (host: the grown `Infer<{x,…}>` pin).
      const pHole = T.tys[params[i]]
      if pHole is TyVar {
        const hShape = holeShapeOf(pHole.tvName)
        if hShape >= 0 {
          if !assignableExpr(args[i], at, hShape) {
            tErr(
              "argument " +
                i32ToStr(i + 1) +
                ": expected " +
                tyToStr(hShape) +
                ", got " +
                tyToStr(at),
              ix,
            )
          }
        }
        // A hole the body INDEXED (`self[i]`) demands an array — a scalar argument can't be
        // indexed, so reject it here (`head(5)`) instead of deferring to an emit failure.
        if holeIsArrayDemanded(pHole.tvName) {
          if tyIsNonIndexableScalar(at) {
            tErr(
              "argument " +
                i32ToStr(i + 1) +
                ": expected an array, got " +
                tyToStr(at),
              ix,
            )
          }
        }
      }
      // Passing an empty-collection argument into a concrete `T[]` / map param pins
      // its element type from the param (`len(empty)` resolves `empty` to `i32[]`),
      // clearing its uninferred floor — pure downstream-usage inference, no push.
      constrainEmpty(at, expected)
      if !assignableExpr(args[i], at, expected) {
        tErr(
          "argument " +
            i32ToStr(i + 1) +
            ": expected " +
            tyToStr(expected) +
            ", got " +
            tyToStr(at),
          ix,
        )
      }
      i = i + 1
    }
    // Substitute the binding into a generic return type — deep, so a
    // structural return (`{first: B, second: A}`, a generic alias body, a
    // function-typed field) concretizes per call site; a DERIVED `?ret.` hole
    // collapses to the pinned callee's return (see `substTyDeep`, which keeps
    // `functions/inferred-return-soundness.vl` rejecting).
    if bNames.length > 0 {
      validateBinCstrs(bNames, bTys, ix)
      validateArgCstrs(bNames, bTys, ix)
      retTy = substTyDeep(retTy, bNames, bTys)
    }
    return retTy
  }
  if ft is TyErr { return TY_ERR }
  if ft is TyVar {
    // Calling an INFERENCE-HOLE value — an un-annotated parameter used as a
    // function inside its own (generic) body: `function apply(fn, a, b)
    // fn(a, b)`. Host parity: the hole pins to a function shape per
    // monomorphized call site, so here the arguments are checked on their own
    // and the call yields a fresh hole (resolved when an outer call binds the
    // generic signature; the emitter compiles each instance concretely).
    const hargs = n.callArgs
    let hj = 0
    while hj < hargs.length {
      checkNode(hargs[hj])
      hj = hj + 1
    }
    return mkTyVar("?ret." + ft.tvName)
  }
  tErr("called value is not a function (" + tyToStr(fnTy) + ")", ix)
  TY_ERR
}

// Resolve a written annotation NAME in the context of generic type-parameter
// names: the type params bind to their TyVars in the type-param ENVIRONMENT
// consulted by `nameToTy`, so a bare `T`, a `T[]` suffix, a structural
// `{first: B, second: A}`, and a generic alias application `Box<T>` all
// resolve through the one name grammar with the params substituted.
// MEMOIZED for the env-free case (no typarams, no live type-param environment):
// `nameToTy` MINTS fresh arena types per call for an inline spelling, so the
// emitter's per-probe resolutions (`repNameCanonKey`'s dedup keys, the compat
// probes' nested-name checks) re-minted the SAME structural types thousands of
// times — on a deep same-fieldset composite the arena grew past 300K types and a
// table allocation crossed the engine limit: a compiler CRASH ("allocation size
// too large"; fuzz seed 459979688 d6 bm). One index per spelling per program is
// also semantically TIGHTER: probes now compare against the one memoized
// structure. Only SUCCESSFUL resolutions memoize (a name unresolvable early may
// resolve once later declarations register); a live tpEnv (an enclosing generic
// body / applyGenAlias substitution) bypasses — the same spelling means
// different types under different bindings. Reset per program (`initChecker`).
let annotNameMemo: {[string]: i32} = Map()
// FAILED resolutions memoize too — under the version that failed (`cUserTypesVer`):
// a name unresolvable NOW may resolve once later declarations register, so the
// negative hit is honored only while no new declared-name resolution landed.
// (`nameToTy` mints PARTIAL types before failing, so un-memoized failures re-probed
// in a loop still grow the arena — the same runaway the positive memo closes.)
let annotNameMemoNegVer: {[string]: i32} = Map()
export function resolveAnnot(name: string, typarams: string[]) {
  if typarams.length == 0 {
    if tpEnvNames.length == 0 {
      const hit = annotNameMemo[name] ?? -2
      if hit != -2 { return hit }
      const negVer = annotNameMemoNegVer[name] ?? -1
      if negVer == cUserTypesVer { return -1 }
      const r = nameToTy(name)
      if r >= 0 {
        annotNameMemo[name] = r
      } else {
        annotNameMemoNegVer[name] = cUserTypesVer
      }
      return r
    }
    return nameToTy(name)
  }
  let i = 0
  while i < typarams.length {
    tpEnvNames.push(typarams[i])
    tpEnvTys.push(mkTyVar(typarams[i]))
    i = i + 1
  }
  const r = nameToTy(name)
  let j = 0
  while j < typarams.length {
    tpEnvNames.pop()
    tpEnvTys.pop()
    j = j + 1
  }
  r
}

// `resolveAnnot` with resolution diagnostics anchored at node `at` (the
// annotation's TypeRef) — see `annotDiagAt`.
function resolveAnnotAt(name: string, typarams: string[], at: i32) {
  const saved = annotDiagAt
  annotDiagAt = at
  const r = resolveAnnot(name, typarams)
  annotDiagAt = saved
  r
}

// Is `name` currently being inferred (on the in-progress stack)?
function onInferStack(name: string) {
  let i = 0
  while i < inferStack.length {
    if inferStack[i] == name { return true }
    i = i + 1
  }
  false
}

// Record a type a PENDING body produced (a `return e` or the trailing expression):
// the first CONCRETE type wins; an error type only notes that something err-ish
// flowed back (an in-cycle call), which distinguishes "void body" from "no basis".
function noteInferredRet(t: i32) {
  if t < 0 { return 0 }
  const tt = T.tys[t]
  if tt is TyErr {
    inferSawErr = true
    return 0
  }
  if tt is TyPrim {
    if tt.primName == "void" { return 0 }
  }
  // JOIN every non-void return, not just the first: a function whose returns
  // disagree (`return 5` … `return null`, or `return 5` … `return "hi"`) infers the
  // flattened UNION/nullable of them (`joinTys` mirrors the host's
  // `flattenType(Union(...))`), so the caller sees the true type. First-wins silently
  // dropped later branches — the checker then mis-typed a `!= null` compare or let a
  // string flow through an i32 result and crash codegen.
  if inferObserved < 0 {
    inferObserved = t
  } else {
    inferObserved = joinTys(inferObserved, t)
  }
  0
}

// The natural-return accumulator for the redundant-return rule (annotated funcs):
// the FIRST non-void/non-error return observed, mirroring noteInferredRet so the
// captured type IS what an unannotated version would infer.
function noteNaturalRet(t: i32) {
  if t < 0 { return 0 }
  const tt = T.tys[t]
  if tt is TyErr {
    retNaturalErr = true
    return 0
  }
  if tt is TyPrim {
    if tt.primName == "void" { return 0 }
  }
  // JOIN, mirroring noteInferredRet (above) so the captured "natural" return IS what
  // an unannotated version would infer — a multi-return function joins to a union.
  if retNatural < 0 {
    retNatural = t
  } else {
    retNatural = joinTys(retNatural, t)
  }
  0
}

function listHasStr(xs: string[], v: string) {
  let i = 0
  while i < xs.length {
    if xs[i] == v { return true }
    i = i + 1
  }
  false
}

// Is `ix` a STATEMENT node (not a value-producing expression)? A function whose
// body's last node / `return` arg is a value expression has a value return POSITION;
// one whose body ends in a bare statement (a recursive `if`/`while` with no trailing
// value) is genuinely void. The redundant-return fixpoint defers ONLY value-return
// functions poisoned by a cycle, so genuine void recursion is never mis-flagged.
function isStmtNode(ix: i32) {
  const nd = P.nodes[ix]
  if nd is LetDecl { return true }
  if nd is IfStmt { return true }
  if nd is WhileStmt { return true }
  if nd is BreakStmt { return true }
  if nd is ContinueStmt { return true }
  if nd is RetStmt { return true }
  if nd is ForRange { return true }
  if nd is ForIn { return true }
  false
}

function resetReturnPending(name: string) {
  const h = lookup(name)
  if h >= 0 {
    const ht = T.tys[h]
    if ht is TyFunc {
      ht.fnRet = -2
      tyMutEpoch = tyMutEpoch + 1 // return-inference fixpoint reset in place
    }
  }
  0
}

// Demand-infer one top-level function's return, but only if still pending (the
// memoization guard already short-circuits a resolved one; the fixpoint resets to
// pending first to force a fresh re-inference once neighbours have settled).
function preInferOne(dIx: i32) {
  const dn = P.nodes[dIx]
  if dn is FuncDecl {
    const h = lookup(dn.fnName)
    let pending = true
    if h >= 0 {
      const ht = T.tys[h]
      if ht is TyFunc {
        if ht.fnRet != -2 { pending = false }
      }
    }
    if pending { checkFuncDeclNode(dn, dIx) }
  }
  0
}

// The return-inference PRE-PASS: resolve every un-annotated return with diagnostics,
// symbol recording and the redundant-type stream SUPPRESSED, so the real check pass
// runs against final return types. Non-cycle functions resolve in the first demand
// sweep (dependency order); cycle-poisoned ones iterate to a fixpoint — each round
// resets the still-tentative set to pending and re-infers, until the set stops
// shrinking. What remains is genuinely base-case-less (recorded for the real pass).
function inferReturnsPrePass() {
  if topUnannotFns.length == 0 { return 0 }
  inferQuiet = true
  const savedDiag = T.diags.length
  const savedSym = symEnabled
  const savedRedun = redunName.length
  symEnabled = 0
  let i = 0
  while i < topUnannotFns.length {
    preInferOne(topUnannotFns[i])
    i = i + 1
  }
  let shrinking = true
  let rounds = 0
  while shrinking && rounds < 2000 {
    rounds = rounds + 1
    const work = inferTentative
    inferTentative = []
    let r = 0
    while r < work.length {
      resetReturnPending(work[r])
      r = r + 1
    }
    let q = 0
    while q < work.length {
      const dIx = fnDeclIx[work[q]] ?? -1
      if dIx >= 0 { preInferOne(dIx) }
      q = q + 1
    }
    if inferTentative.length >= work.length { shrinking = false }
  }
  unresolvedFns = []
  let u = 0
  while u < inferTentative.length {
    unresolvedFns.push(inferTentative[u])
    u = u + 1
  }
  symEnabled = savedSym
  while T.diags.length > savedDiag { T.diags.pop() }
  redunTruncate(savedRedun)
  inferQuiet = false
  0
}

function redunTruncate(n: i32) {
  while redunSLine.length > n { redunSLine.pop() }
  while redunSCol.length > n { redunSCol.pop() }
  while redunELine.length > n { redunELine.pop() }
  while redunECol.length > n { redunECol.pop() }
  while redunName.length > n { redunName.pop() }
  while redunType.length > n { redunType.pop() }
  while redunTok.length > n { redunTok.pop() }
  0
}

// The UNCOVERED union members of the last non-exhaustive `is`-chain
// `ifChainExhausts` analyzed (rendered, comma-joined), so the diagnostic can
// NAME what is missing — the `match` exhaustiveness error's sibling. "" when
// the chain was exhaustive, or when it was non-exhaustive for a reason other
// than member coverage (a non-coverable arm shape, an uncovered `null` path):
// there is no member list to name, so the caller keeps its generic wording.
let chainMissing = ""

// SOUNDNESS — exhaustiveness of an else-less `is`-chain. Does the flat
// `if p is A {…} else if p is B {…}` chain rooted at `ifIx` (no final `else`)
// COVER every variant of `p`'s union type? If so its fall-through is unreachable
// and the chain needs no `else`; if not, a value falls off the end (the host
// types that as `| null`). Mirrors the host's `conditionsExhaust`, but over the
// discriminated place's declared union MEMBERS (VL has no union-subtraction /
// `Never` machinery): collect the per-arm tested types, require every arm to test
// the SAME single place, then check each union member is covered by some arm.
// Conservative — any arm that isn't a bare `place is T` (a compound `&&`/`||`, a
// different place, a null test) makes the chain non-exhaustive (returns false),
// never wrongly exhaustive.
function ifChainExhausts(ifIx: i32) {
  chainMissing = ""
  let havePlace = false
  let placeName = "?"
  const testedTys: i32[] = []
  // `allIsArms` stays true only while every arm seen is a bare `<sameIdent> is T`
  // (the only shape we can prove exhaustive by union-member coverage).
  let allIsArms = true
  let node = P.nodes[ifIx]
  let walking = true
  while walking {
    if node is IfStmt {
      // Classify this arm's condition. Only a single `<ident> is T` (not null)
      // contributes to coverage; anything else makes the chain non-coverable.
      // A parenthesized arm (`else if (p is B)`) classifies like the bare one.
      const cond = P.nodes[condUnderParens(node.ifCond)]
      if cond is IsExpr {
        if cond.isVariant == "null" {
          allIsArms = false
        } else {
          const obj = P.nodes[cond.isObj]
          if obj is Ident {
            if !havePlace {
              placeName = obj.identName
              havePlace = true
            } else if placeName != obj.identName {
              allIsArms = false
            }
            const tIx = nameToTy(cond.isVariant)
            if tIx < 0 { allIsArms = false } else { testedTys.push(tIx) }
          } else {
            allIsArms = false
          }
        }
      } else if cond is BinExpr {
        // A literal-equality arm `place == <lit>` discriminates a literal
        // union the same way an `is` arm does (host: literal narrowing via
        // `atomFact` + `subtractType`) — contribute the tested literal type.
        let armLit = -1
        let armObj = -1
        if cond.binOp == "==" {
          armLit = litTyOfExpr(cond.binRight)
          armObj = cond.binLeft
          if armLit < 0 {
            armLit = litTyOfExpr(cond.binLeft)
            armObj = cond.binRight
          }
        }
        if armLit >= 0 {
          const eobj = P.nodes[armObj]
          if eobj is Ident {
            if !havePlace {
              placeName = eobj.identName
              havePlace = true
            } else if placeName != eobj.identName {
              allIsArms = false
            }
            testedTys.push(armLit)
          } else {
            allIsArms = false
          }
        } else {
          allIsArms = false
        }
      } else {
        allIsArms = false
      }
      if node.ifElse < 0 {
        // No `else`: the chain ends here — decide by coverage below.
        walking = false
      } else {
        const nxt = P.nodes[node.ifElse]
        if nxt is IfStmt {
          node = nxt
        } else {
          // A real (block) `else` covers the fall-through outright — exhaustive
          // regardless of the arm shapes.
          return true
        }
      }
    } else {
      return false
    }
  }
  // No `else`. Only a pure `is`-chain over one place can be exhaustive by member
  // coverage; any other shape genuinely falls through.
  if !allIsArms { return false }
  // No place was discriminated (shouldn't happen) — not exhaustive.
  if !havePlace { return false }
  // Look up the place's union members; cover each against the tested set.
  const pty = lookup(placeName)
  if pty < 0 { return false }
  const pt = T.tys[pty]
  if pt is TyNullable {
    // A nullable place needs an explicit `is null` (or `else`) arm to be covered;
    // an else-less `is`-chain over the inner variants always leaves the null path.
    return false
  }
  if pt is TyUnion {
    // Cover each union member against the tested set; collect the uncovered
    // ones (rendered) so the diagnostic can name exactly what is missing.
    const members = pt.uMembers
    let mi = 0
    let allCovered = true
    while mi < members.length {
      let covered = false
      let ti = 0
      while ti < testedTys.length {
        if assignable(members[mi], testedTys[ti]) { covered = true }
        ti = ti + 1
      }
      if !covered {
        allCovered = false
        if chainMissing != "" { chainMissing = chainMissing + ", " }
        chainMissing = chainMissing + tyToStr(members[mi])
      }
      mi = mi + 1
    }
    return allCovered
  }
  // A non-union place: an `is`-chain over it is degenerate; treat as covered
  // (a single concrete type is "exhausted" by any always-true branch).
  true
}

// A function declaration: resolve param/return annotations (narrowing the Param/
// TypeRef children), bind the signature, and check the body in a fresh scope.
// An UN-ANNOTATED return type is INFERRED from the body — its `return`s and
// trailing expression accumulate via `noteInferredRet` (under the `-2` pending
// `curRet`), and the result is PATCHED into the hoisted TyFunc in place, so every
// caller (incl. ones that demand-inferred this function early) sees it. A
// base-case-less cycle (`ping(){return pong()}` / `pong(){return ping()}`) has
// nothing concrete to latch onto and reports "cannot infer a return type".
function checkFuncDeclNode(n: FuncDecl, fnIx: i32) {
  const inferring = n.fnRet < 0
  // The infer-stack KEY: a named function uses its name (so self-recursion is detected); an
  // ANONYMOUS lambda has no name, so key it by NODE INDEX — else two nested anonymous lambdas
  // (`(a) => (b) => …`) both key on "" and the inner falsely trips the recursive-cycle guard
  // below, breaking with a provisional `void` (its return then mis-infers `void`, so a curried
  // lambda `f(4)` reads as a void result).
  let inferKey = n.fnName
  if inferKey == "" { inferKey = "#L" + i32ToStr(fnIx) }
  // Already inferred on demand (a forward call checked this body before pass 2
  // reached it)? Skip the re-check so diagnostics aren't duplicated.
  if inferring {
    // Recursive cycle: this function is already on the inference stack. Break with a
    // provisional `void` (the binding-group fixpoint re-infers it once the cycle's
    // resolvable members settle), and COUNT the break so the completion below knows
    // the result is tentative rather than final.
    if onInferStack(inferKey) {
      cycleBreakCount = cycleBreakCount + 1
      return TY_VOID
    }
    if inferQuiet {
      // Suppressed pre-pass: memoize a resolved return (a `-2` reset by the fixpoint
      // forces a fresh re-inference).
      const hoisted = lookup(n.fnName)
      if hoisted >= 0 {
        if (fnDeclIx[n.fnName] ?? -1) >= 0 {
          const ht = T.tys[hoisted]
          if ht is TyFunc {
            if ht.fnRet != -2 { return TY_VOID }
          }
        }
      }
    } else {
      // Real check pass: returns are already resolved by the pre-pass, so skip ONLY a
      // TOP-LEVEL body already diagnostic-checked (a forward call reached it before
      // pass 2 did). Gated on `fnIx` matching the registered top-level decl, so a
      // NESTED function sharing a name (e.g. two `add` closures) is never skipped.
      if (fnDeclIx[n.fnName] ?? -1) == fnIx {
        if bodyChecked[n.fnName] ?? false { return TY_VOID }
      }
    }
  }
  const params = n.fnParams
  // The contextual expected param types recorded for THIS lambda node (`seedExpected` at a
  // call arg, a `.map`/`.filter` receiver, or an annotated let/return/field/element). Keyed by
  // node index, so a composite's many lambdas each read their own — no single-shot leak.
  const cbExpect = cbExpectedFor(fnIx)
  const cbExpectUsable = cbExpect.length == params.length
  const paramTys: i32[] = []
  let paramUninferable = false
  let pi = 0
  while pi < params.length {
    const pNode = P.nodes[params[pi]]
    let pt = TY_ERR
    if pNode is Param {
      if pNode.parType >= 0 {
        const ptn = P.nodes[pNode.parType]
        if ptn is TypeRef {
          pt = resolveAnnotAt(ptn.tyName, n.fnTyParams, pNode.parType)
          if pt < 0 {
            tErr("unknown type '" + ptn.tyName + "'", pNode.parType)
            pt = TY_ERR
          }
          // Record the resolved type on the param's TYPE-ANNOTATION node too (not just the
          // param node), so the emitter can classify a param annotation STRUCTURALLY from the
          // `Ty` arena instead of re-parsing its synthetic name (`tyNameOf`) — C1.
          if !inferQuiet && pt >= 0 {
            if pNode.parType < nodeTyIx.length { nodeTyIx[pNode.parType] = pt }
          }
        }
      } else if cbExpectUsable && cbExpect[pi] >= 0 {
        // Contextual inference: the expected callback type pins this un-annotated
        // param (e.g. `xs.map(function(n) …)` over `i32[]` ⇒ `n: i32`), matching
        // the host's receiver-driven inference.
        pt = cbExpect[pi]
      } else if n.fnName != "" {
        // HOST PARITY (`Infer<Unknown>` param holes): a NAMED function's
        // un-annotated parameter is a fresh inference HOLE — a synthetic TyVar
        // (one per param, named by declaration + position so the hoisted
        // signature and the body bind the same hole). Each CALL SITE pins it
        // independently through the existing generic TyVar binding (the
        // per-call `bNames`/`bTys`), mirroring the host's per-callsite
        // `instantiateFunctionType`; the emitter then monomorphizes one wasm
        // instance per distinct shape. Inside the body the hole is opaque
        // (assignable both ways), exactly like an explicit `<T>` param.
        pt = mkTyVar("?" + n.fnName + "." + i32ToStr(pi))
      } else if isValBindLambda(fnIx) {
        // A lambda bound to an UN-annotated `const`/`let` (`const add = (a, b) => a + b`): its
        // un-annotated param is a fresh inference HOLE, exactly like a named function's — the
        // emitter value-flow-monomorphizes one instance per call shape (env and all). Keyed by NODE
        // index (the lambda is anonymous), the dual of the named branch above.
        pt = mkTyVar("?#L" + i32ToStr(fnIx) + "." + i32ToStr(pi))
      } else {
        // An ANONYMOUS literal with no annotation and no contextual type is genuinely uninferable —
        // its value-typed binding demands a concrete signature NOW (host parity).
        tErr(
          "cannot infer a type for parameter `" + pNode.parName + "`",
          params[pi],
        )
        // The body can't be typed once a param is unknown — don't also cascade a "cannot infer a
        // return type" from the resulting error-only return.
        paramUninferable = true
      }
    }
    // TYPED-IR: record the param node's resolved type so the emitter can recover a
    // contextually-inferred callback param's type (`xs.map((x) => …)` over `f64[]` ⇒ x: f64)
    // and synthesize its annotation, instead of defaulting an un-annotated param to i32.
    // Gated on the real pass (`!inferQuiet`); a generic hole stays a `TyVar` and is excluded
    // by the emitter's reader (`nodeTyName`).
    if !inferQuiet && pt >= 0 {
      if params[pi] < nodeTyIx.length { nodeTyIx[params[pi]] = pt }
    }
    paramTys.push(pt)
    pi = pi + 1
  }
  // Resolve the return-type annotation (or the pending sentinel when inferring).
  let ret = -2
  if !inferring {
    ret = TY_VOID
    const rtn = P.nodes[n.fnRet]
    if rtn is TypeRef {
      ret = resolveAnnotAt(rtn.tyName, n.fnTyParams, n.fnRet)
      if ret < 0 {
        tErr("unknown type '" + rtn.tyName + "'", n.fnRet)
        ret = TY_ERR
      }
      // Record the resolved return type on the RETURN-ANNOTATION node so the emitter can
      // classify it structurally from the `Ty` arena rather than re-parsing `tyNameOf` — C1.
      if !inferQuiet && ret >= 0 {
        if n.fnRet < nodeTyIx.length { nodeTyIx[n.fnRet] = ret }
      }
    }
    // `f` is hoisted in the outer scope (checkProgram pre-pass), but re-declaring
    // it here covers nested function decls and is an idempotent rebind otherwise.
    // (An anonymous function EXPRESSION has no name to bind.)
    if n.fnName != "" { declare(n.fnName, mkFuncTy(paramTys, ret)) }
  }
  // Save the inference accumulators (a demand-inference can nest inside another
  // function's body check) and the enclosing return type.
  const savedObserved = inferObserved
  const savedSawErr = inferSawErr
  const cbBefore = cycleBreakCount
  const savedValueRet = fnSawValueRet
  const savedRetNatural = retNatural
  const savedRetNaturalErr = retNaturalErr
  retNatural = -1
  retNaturalErr = false
  if inferring {
    inferStack.push(inferKey)
    inferObserved = -1
    inferSawErr = false
    fnSawValueRet = false
  }
  // Check the body in a fresh scope sharing the parameters.
  pushScope(n.fnBody)
  // Keep the function's TYPE PARAMETERS in scope for the WHOLE body, so a body
  // annotation that names one — a local `const out: T[]`, `const x: T` — resolves it
  // (to an opaque `TyVar`, like the param signatures) instead of failing "unknown type
  // 'T'". `resolveAnnot` only scopes typarams around a single param/return annotation.
  // The emitter substitutes the concrete type per monomorphized instance (`monoCloneBody`
  // rewrites the body's annotations), so the annotation lowers correctly.
  let tpBody = 0
  while tpBody < n.fnTyParams.length {
    tpEnvNames.push(n.fnTyParams[tpBody])
    tpEnvTys.push(mkTyVar(n.fnTyParams[tpBody]))
    tpBody = tpBody + 1
  }
  // Definite-assignment: a function body is its OWN flow context — it runs at
  // call time, not at the declaration site, so a NESTED function that captures an
  // outer still-unassigned `let x` must not be flagged (the call may happen after
  // `x` is written). Save and clear the live unassigned set for the body, then
  // restore the enclosing path.
  const daSavedUnassigned = daSnapshot()
  daClear()
  const savedRet = T.curRet
  T.curRet = ret
  // LSP: the function name binds in the OUTER scope (decl-scope chain), but its
  // body — params + statements — is checked under this pushed scope. Record the
  // name occurrence against the enclosing decl scope before descending.
  if symEnabled != 0 {
    if n.fnName != "" && fnIx >= 0 {
      symDeclInOuter(n.fnName, fnIx, mkFuncTy(paramTys, ret), 2)
    }
  }
  let dj = 0
  while dj < params.length {
    const pNode2 = P.nodes[params[dj]]
    if pNode2 is Param {
      declare(pNode2.parName, paramTys[dj])
      if symEnabled != 0 {
        symDecl(pNode2.parName, params[dj], paramTys[dj], 1)
      }
    }
    dj = dj + 1
  }
  const body = P.nodes[n.fnBody]
  if body is Block {
    const stmts = body.blkStmts
    let s = 0
    while s < stmts.length {
      // The LAST statement's value is this function's implicit return. Under inference,
      // mark it as the return-tail position so a tail `if`/`else`'s base-case branch
      // seeds `inferObserved` before a recursive sibling branch is checked.
      const savedRTPbody = retTailPos
      if s == stmts.length - 1 && inferring {
        retTailPos = true
      } else {
        retTailPos = false
      }
      const stTy = checkNode(stmts[s])
      retTailPos = savedRTPbody
      // The trailing expression is the implicit return; under inference it is a
      // return-type witness. With a CONCRETE annotated return, a trailing empty
      // collection (`mk(): i32[] { … inner }`) pins its element from the return
      // type here — before the body scope is popped (and `inner`'s floor checked).
      if s == stmts.length - 1 {
        if inferring {
          // A value-producing trailing expression is a value return POSITION (vs a
          // bare trailing statement); the redundant-return fixpoint defers only these.
          if !isStmtNode(stmts[s]) { fnSawValueRet = true }
          noteInferredRet(stTy)
        } else {
          // Redundant-return rule: witness the trailing expression's NATURAL type
          // (before constrainEmpty pins a hole); an annotation-influenced trailing
          // (empty `[]`/`Map()`, `null`) disqualifies the function.
          if retInfluencedByAnnot(stmts[s]) { retNaturalErr = true }
          noteNaturalRet(stTy)
          constrainEmpty(stTy, ret)
          // SOUNDNESS — missing-return / non-exhaustive fall-through. When the
          // body's LAST statement is an else-less `is`-chain that does NOT cover
          // every variant of its discriminated union, a value falls off the end
          // (the host types this as `branches | null`). For a non-void declared
          // return that is a soundness hole: "you forgot a case". An `if` WITH a
          // final `else`, or an EXHAUSTIVE chain, is unreachable past its end and
          // is fine; any other trailing statement is a normal value/return and is
          // left to the per-`return` and trailing-expression checks above. Skip
          // when the return type is itself nullable (a `| null` fall-through is
          // assignable) or the error type (don't cascade).
          const lastN = P.nodes[stmts[s]]
          if lastN is IfStmt {
            // Only a DISCRIMINATING chain is subject to this exhaustiveness
            // rule — a trailing `if` over `is` arms, or a literal-equality
            // chain (`n == 0` / `else if n == 1 …`) over a LITERAL-UNION place
            // (host: the un-covered member leaves a `| null` fall-through,
            // `exhaustive-missing-literal-case`). Plain `if cond {…}` shapes
            // over non-literal places keep the existing per-branch checks.
            const firstCond = P.nodes[condUnderParens(lastN.ifCond)]
            let isChain = false
            if firstCond is IsExpr {
              isChain = true
            } else if firstCond is BinExpr {
              if firstCond.binOp == "==" {
                let eqPlace = -1
                if litTyOfExpr(firstCond.binRight) >= 0 {
                  eqPlace = firstCond.binLeft
                } else if litTyOfExpr(firstCond.binLeft) >= 0 {
                  eqPlace = firstCond.binRight
                }
                if eqPlace >= 0 {
                  const eqObj = P.nodes[eqPlace]
                  if eqObj is Ident {
                    if isLitBearing(lookup(eqObj.identName)) { isChain = true }
                  }
                }
              }
            }
            const retT = T.tys[ret]
            let retNullable = false
            if retT is TyNullable { retNullable = true }
            if isChain && !isVoidTy(ret) && ret != TY_ERR && !retNullable {
              if !ifChainExhausts(stmts[s]) {
                // Name the uncovered variants when member coverage computed
                // them (the `match` sibling's courtesy); a chain that is
                // non-exhaustive for a SHAPE reason (a non-coverable arm, an
                // uncovered `null` path) has no member list, so stay generic.
                let chainFix = "add the missing variant(s) or an `else` (expected " +
                  tyToStr(ret) +
                  ")"
                if chainMissing != "" {
                  chainFix = "missing " +
                    chainMissing +
                    " (add the arm(s) or an `else`; expected " +
                    tyToStr(ret) +
                    ")"
                }
                tErr(
                  "non-exhaustive `is`-chain falls through with no `else` — " +
                    chainFix,
                  stmts[s],
                )
              }
            }
          }
        }
      }
      s = s + 1
    }
  }
  // Capture body TOTALITY (missing-return soundness) while the body scope is still LIVE
  // — `ifCondIsDiscriminating` looks up a discriminated param/local's type, which the
  // `popScope` below would drop. The flag is consumed after `ret` is finalized.
  const bodyTotalForRet = nodeIsTotal(n.fnBody)
  T.curRet = savedRet
  daRestore(daSavedUnassigned)
  let tpPop = 0
  while tpPop < n.fnTyParams.length {
    tpEnvNames.pop()
    tpEnvTys.pop()
    tpPop = tpPop + 1
  }
  popScope()
  if !inferQuiet {
    // Mark only the registered TOP-LEVEL decl (not a nested/shadowing namesake).
    if n.fnName != "" && (fnDeclIx[n.fnName] ?? -1) == fnIx {
      bodyChecked[n.fnName] = true
    }
  }
  if inferring {
    inferStack.pop()
    let inferred = TY_VOID
    // Set when the OBJECT-shaped contextual adoption fires (`objRetWidenAdopt` below):
    // gates the plain-struct CANON record — a lambda whose self-inference already
    // matches its context keeps the established un-pinned route (pinning EVERY
    // plain-struct lambda regressed `.map`-collapse / factory / generic-HOF cases).
    let objRetAdopted = false
    const sawCycle = cycleBreakCount > cbBefore
    if inferObserved >= 0 {
      inferred = inferObserved
    } else if sawCycle && fnSawValueRet {
      // A value return position resolved to `void` ONLY because a recursive-cycle
      // member was still pending. Defer: the binding-group fixpoint re-infers this
      // once the cycle's resolvable members settle (a genuinely base-case-less cycle
      // stays tentative and is reported by the real pass). Genuine void recursion has
      // no value return position (`fnSawValueRet` is false), so it is never deferred.
      if !listHasStr(inferTentative, n.fnName) { inferTentative.push(n.fnName) }
      inferred = TY_VOID
    } else if inferSawErr {
      // Only err-ish types flowed back: no basis. A param that was itself uninferable
      // already reported the root cause, so suppress the redundant message.
      if !paramUninferable {
        tErr(
          "cannot infer a return type for '" +
            n.fnName +
            "' — annotate a return type",
          n.fnBody,
        )
      }
      inferred = TY_ERR
    }
    // CONTEXTUAL RETURN ADOPTION: an anonymous lambda whose body infers a NARROWER numeric
    // than the contextual expected return (`const v: () => i64 = () => (5)`, an arg to a
    // `p: () => i64` param, a `{f: () => i64}` field) takes the EXPECTED return as its own,
    // so the widening lands at the lambda's return seam — where codegen inserts the convert
    // (`emitReturnValue`) — and its emitted functype result matches every call site. Numeric
    // widening through function-type VARIANCE is rejected instead (`fnSlotAssignable`): a
    // function VALUE's rep is fixed, so the body is the only place the value can widen.
    if n.fnName == "" && inferred >= 0 {
      const expRet = cbExpectedRetFor(fnIx)
      if expRet >= 0 {
        if numWidens(inferred, expRet) { inferred = expRet }
        // FLOAT-LITERAL → f32 dual of the numeric widen: a float-literal-bodied lambda
        // whose contextual return is f32 (`(i32) => f32 = (x) => 5.5`) infers f64 (a float
        // literal's default), but the literal re-encodes EXACTLY at f32 — the same grant
        // `isFloatLitExpr`/`assignableExpr` make at a direct `const v: f32 = 5.5` binding.
        // Adopt f32 so the lambda's functype result is f32 and `emitReturnValue` encodes the
        // literal at f32 in the body (the named-function-value spelling `= mk` already lowers).
        if inferred != expRet && primNameOf(expRet) == "f32" {
          if isFloatLitExpr(lambdaBodyTail(n.fnBody)) { inferred = expRet }
        }
        // Object-shaped dual: `() => ({f: 5})` against `() => {f: i64}` — adopt the
        // expected shape when every widening field is a re-encodable literal
        // (`objRetWidenAdopt` also records the field types for the emitter's interner).
        if objRetWidenAdopt(n.fnBody, inferred, expRet) {
          inferred = expRet
          objRetAdopted = true
        }
        // LITERAL-UNION dual: a bare string-literal body that is a MEMBER of the expected
        // literal-union (`(i32) => K = (x) => "b"`) adopts the litunion. Its inferred type is
        // the softened `string`; the direct `const k: K = "b"` binding grants the member flow
        // via `assignableExpr`/`litTyOfExpr`, but the lambda-return path only had the
        // numeric/object arms. Adopting makes the lambda's functype result the litunion (an i32
        // atom), and the member literal encodes as its atom id at the return seam.
        if inferred != expRet && tyIsLitUnion(expRet) {
          const luTail = lambdaBodyTail(n.fnBody)
          if luTail >= 0 && assignableExpr(luTail, inferred, expRet) {
            inferred = expRet
          }
        }
        // NULLABLE-STRING result: a lambda whose body infers a bare `string` member of an expected
        // `string | null` closure result (`(i32) => string | null = (x) => "hey"`) adopts the
        // nullable — its functype result is the string-ref `ref.null` NICHE (position-independent),
        // and `emitReturnValue` niches the value, exactly as the named-function VALUE (`= mk`) lowers.
        // Recorded by the `nullableRetName` arm below + pinned by `synthRetAnnots`. This arm
        // covers the string/boolean NICHES only: a nullable numeric SCALAR (`i32 | null`,
        // `f32 | null`) is the value-union BOX and adopts through the `valueUnionRetName` arm
        // below (its `$fnsig` keys `>u` on both producers — `annRetKind`'s nullable-scalar arm).
        // `TyNullable`-inner-`string` is checked directly (`valueUnionRetName` also claims
        // `T | null`, so the niche must be recognized before it).
        if inferred != expRet {
          const etU = T.tys[expRet]
          if etU is TyNullable {
            const etInner = tyToStr(etU.nInner)
            // The BOOLEAN-niche dual of the string niche: a lambda whose body infers a bare
            // `boolean` / `null` member of an expected `boolean | null` (`() => boolean | null =
            // () => null`) adopts the niche — its functype result is the i32 sentinel (2 = null),
            // exactly as the annotated `: boolean | null` return and the named-function VALUE lower.
            // Recorded by `nullableRetName` + pinned by `synthRetAnnots` (`nullablePartOf` non-empty).
            if etInner == "string" || etInner == "boolean" {
              const nsTail = lambdaBodyTail(n.fnBody)
              if nsTail >= 0 && assignableExpr(nsTail, inferred, expRet) {
                inferred = expRet
              }
            }
            // The NULLABLE-LIST dual (`() => boolean[] | null = () => ([false])`): a lambda
            // whose body infers the bare i32-backed LIST member of an expected `T[] | null`
            // adopts the niche — its functype result is the nullable i32-list wrapper
            // (`(ref null $lTypeIdx)`, the `>o` result token), exactly as the annotated
            // `: boolean[] | null` named-function return lowers. Recorded by
            // `nullableRetName`'s i32-backed-list arm + pinned by `synthRetAnnots`.
            // The distinct-backing leaves (`i64[] | null`, …) are NOT adopted (outside
            // the value-call ABI — they stay loud checker rejects).
            if inferred != expRet && tyIsNulI32BackedListInner(etU.nInner) {
              const nlTail = lambdaBodyTail(n.fnBody)
              if nlTail >= 0 && assignableExpr(nlTail, inferred, expRet) {
                inferred = expRet
              }
            }
            // The NULLABLE-CLOSURE dual (`(i32) => ((i32) => K0) | null = (q0) => (null)`): a
            // lambda whose body infers `null` (or a closure) against an expected nullable-closure
            // result adopts the niche — its functype result is `(ref null $cloStruct)`, and
            // `emitReturnValue`'s `retNulClosure` arm niches a `return null` as `ref.null
            // $cloStruct`. Recorded by `nullableRetName`'s `TyFunc`-inner arm + pinned by
            // `synthRetAnnots`. Position-independent, exactly as the annotated `: ((i32)=>K0)|null`
            // return already lowers (the pin only removes the annotation).
            const etInnerTy = T.tys[etU.nInner]
            if etInnerTy is TyFunc {
              const ncTail = lambdaBodyTail(n.fnBody)
              if ncTail >= 0 && assignableExpr(ncTail, inferred, expRet) {
                inferred = expRet
              }
            }
            // The NULLABLE-STRUCT dual (`() => {a, f, z} | null = () => ({…})`, also
            // `(i32) => {f: i64} | null = (q) => ({f: 7})`): a lambda whose body infers the
            // bare struct member (or `null`) of an expected `S | null` closure result adopts
            // the nullable — its functype result is the `(ref null $S)` niche (`>n`,
            // byte-matching the value call's `annRetKind`), exactly as the annotated
            // named-function VALUE spelling already lowers. Recorded by `nullableRetName`'s
            // TyObj arm + pinned by `synthRetAnnots`.
            if etInnerTy is TyObj {
              const nsoTail = lambdaBodyTail(n.fnBody)
              if nsoTail >= 0 && assignableExpr(nsoTail, inferred, expRet) {
                inferred = expRet
              }
            }
            // The NULLABLE-LITUNION dual (`() => K0 | null = () => ("42")`): a lambda whose body
            // infers a bare `string` MEMBER of the expected `K | null` litunion adopts the niche —
            // its functype result is the i32 atom (the `-1` sentinel = null), and `emitReturnValue`'s
            // `retNulLitUnion` arm encodes the member literal as its atom id / a `return null` as
            // `-1`. Recorded by `nulLitUnionRetName` + pinned by `synthRetAnnots` (`nullablePartOf`
            // non-empty). Exposed already by the annotated `: () => K | null` form.
            if tyIsLitUnion(etU.nInner) {
              const nluTail = lambdaBodyTail(n.fnBody)
              if nluTail >= 0 && assignableExpr(nluTail, inferred, expRet) {
                inferred = expRet
              }
            }
          }
        }
        // VALUE-UNION result (C1, `() => i64 | boolean`): a lambda whose body infers a bare
        // SCALAR arm of the expected value-union box result adopts the union, so the widening
        // lands at the return seam — `emitReturnValue` boxes the scalar into the `{tag, value}`
        // rep and the lambda's functype result IS the box (`synthRetAnnots` pins `fnRet` to the
        // recorded union name; the `"union"` return kind then drives the union result valtype). Without this the
        // body returned a raw scalar into a union-box functype result (INVALID-WASM at the call
        // site's box-typed local). The scalar-arm boxing is position-independent, so this is the
        // closure-return dual of the array-element boxing. Checked AFTER the niche arms (a
        // `T | null` niche must not be swallowed as a value union).
        if inferred != expRet && valueUnionRetName(expRet) != "" {
          const vuTail = lambdaBodyTail(n.fnBody)
          if vuTail >= 0 && assignableExpr(vuTail, inferred, expRet) {
            inferred = expRet
          }
        }
        // CLOSURE-ARM value-union result (`(i32) => (() => string) | i64`): a lambda whose
        // body infers ONE arm (a closure or a scalar) of the expected closure-arm value union
        // adopts the union, so the boxing lands at the return seam — `emitReturnValue` boxes
        // the arm (a closure member is the kind-11 REF atom, riding the box's anyref value)
        // and the lambda's functype result IS the box (`synthRetAnnots` pins `fnRet` via its
        // `isValueUnionName` arm; the `$fnsig` keys `>u`, matching the value call's
        // `annRetKind`). The annotated named-function-VALUE spelling of the same union result
        // already lowers this box soundly, so the pin only removes the annotation.
        if inferred != expRet && cloArmValueUnionRetName(expRet) != "" {
          const cvTail = lambdaBodyTail(n.fnBody)
          if cvTail >= 0 && assignableExpr(cvTail, inferred, expRet) {
            inferred = expRet
          }
        }
        // MAP-MEMBER-UNION result (`() => {[string]:f32} | {w:i32}`): a lambda whose body infers
        // one struct arm of the expected map-member-union box result adopts the union, so the
        // widening lands at the return seam — `emitReturnValue` boxes the struct/map arm into the
        // #865/#868 map-union box and the lambda's functype result IS the box (`synthRetAnnots` pins
        // `fnRet` to the recorded union name). Without this the body returned a bare struct into a
        // union-box functype result (a `ref valtype with no interned shape` crash). Position-
        // independent, like the value-union arm: the annotated `: {[string]:f32}|{w:i32}` return
        // exposes this rep already, so the lambda pin adds no invalid wasm.
        if inferred != expRet && mapUnionRetName(expRet) != "" {
          const muTail = lambdaBodyTail(n.fnBody)
          if muTail >= 0 && assignableExpr(muTail, inferred, expRet) {
            inferred = expRet
          }
        }
        // REF-ARM value-union result (`(i32) => T[] | {w: i32}`, repOf item (d)): a lambda whose
        // body infers ONE arm (`(q0) => ([{f: true}])` infers `T[]`) of the expected ref-arm
        // union adopts the union, so the boxing lands at the return seam — `emitReturnValue`
        // boxes the reflist/struct arm into the `{tag, value}` rep and the lambda's functype
        // result IS the box (`synthRetAnnots` pins `fnRet` to the recorded name; its `$fnsig`
        // keys `>u`, matching the call site's `annSigKey`). Without the pin the lambda's
        // functype result was the RAW reflist while the narrowed call site `ref.cast` the
        // funcref to the `>u` sig — a guaranteed runtime cast TRAP (annotated spelling) or,
        // with the consumer gate also missing, INVALID-WASM (the #911 finding). The annotated
        // named-function spelling (`mk(): T[] | {w: i32}`) already lowers this box soundly, so
        // the pin only removes the annotation. NOMINAL-gated (`refArmUnionRetName` declines an
        // anonymous-element array arm), so the #911 declared-twin-gated shapes stay loud.
        if inferred != expRet && refArmUnionRetName(expRet, gRootStmts) != "" {
          const raTail = lambdaBodyTail(n.fnBody)
          if raTail >= 0 && assignableExpr(raTail, inferred, expRet) {
            inferred = expRet
          }
        }
        // VARIANT-BOX union result with an INLINE-struct arm (`(i32) => i32 | {w: i32}`,
        // `() => {f: i32} | f64` — the R2 closure-result `$fnsig` seam): a lambda whose body
        // infers ONE arm of the expected union adopts the whole union, so the boxing lands at
        // the return seam (`emitReturnValue` boxes the arm) and the lambda's functype result IS
        // the box — its `$fnsig` keys `>u`, byte-matching the value call's `annSigKey`. The
        // annotated named-function spelling of every such union already lowers this box soundly
        // (the value call reads it back through `is`), so the pin only removes the annotation.
        // AFTER `refArmUnionRetName` (ref-array arms carry a slot render this arm declines).
        if inferred != expRet && variantBoxUnionRetName(expRet) != "" {
          const vbTail = lambdaBodyTail(n.fnBody)
          if vbTail >= 0 && assignableExpr(vbTail, inferred, expRet) {
            inferred = expRet
          }
        }
        // ELEMENT-NULLABLE LIST result (`() => (f64|null)[]`): a lambda whose body is an
        // array literal assignable to the expected value-union-box list adopts it, so
        // `emitReturnValue` seeds each nullable element (`[null]`) through the SAME rep the
        // annotated `(f64|null)[]` return / named-function form already lowers soundly
        // (`synthRetAnnots` pins `fnRet`). Position-independent: the annotated spelling
        // exposes this rep everywhere already, so the lambda pin cannot add invalid wasm.
        if inferred != expRet && nulElemListRetName(expRet) != "" {
          const elTail = lambdaBodyTail(n.fnBody)
          if elTail >= 0 && assignableExpr(elTail, inferred, expRet) {
            inferred = expRet
          }
        }
        // ELEMENT-VALUE-UNION LIST result (`() => (i64|boolean)[]`): a lambda whose body array
        // literal is assignable to the expected value-union-box list adopts it, so `emitReturnValue`
        // boxes each element (`[7]`) through the SAME element-kind-2 rep the annotated
        // `(i64|boolean)[]` return / named-function-value form already lowers soundly (`synthRetAnnots`
        // pins `fnRet`). The value-union sibling of the element-nullable arm above.
        if inferred != expRet && elemValueUnionListRetName(expRet) != "" {
          const evTail = lambdaBodyTail(n.fnBody)
          if evTail >= 0 && assignableExpr(evTail, inferred, expRet) {
            inferred = expRet
          }
        }
        // ELEMENT-VARIANT-BOX-UNION LIST result (`(i32) => ({a,f,z} | i64)[]`): a lambda
        // whose body array literal is assignable to the expected variant-box-element list
        // adopts it, so `emitReturnValue` boxes each element through the SAME element-kind-2
        // rep the annotated return / named-function-VALUE form already lowers
        // (`synthRetAnnots` pins `fnRet` via its `parenUnionArrElemName` arm). The
        // variant-box sibling of the element-value-union arm above.
        if inferred != expRet && elemVariantBoxListRetName(expRet) != "" {
          const vbeTail = lambdaBodyTail(n.fnBody)
          if vbeTail >= 0 && assignableExpr(vbeTail, inferred, expRet) {
            inferred = expRet
          }
        }
        // UNION-FIELD-STRUCT-element LIST result (`() => {f: {f: f64} | boolean}[]`): a
        // lambda whose body array literal is assignable to the expected list of
        // boxed-field structs adopts it, so each element literal builds the boxed field
        // slot exactly as the annotated `(): {f:…|boolean}[]` spelling lowers
        // (`synthRetAnnots` pins `fnRet` via the element's `nameIsStructWithUnionField`).
        // The element-list sibling of the `structFieldBoxRetName` struct arm.
        if inferred != expRet && structFieldBoxElemListRetName(expRet) != "" {
          const sfeTail = lambdaBodyTail(n.fnBody)
          if sfeTail >= 0 && assignableExpr(sfeTail, inferred, expRet) {
            inferred = expRet
          }
        }
        // NULLABLE-CLOSURE-element LIST result (`() => ((() => i64) | null)[] = () =>
        // ([null])`): a lambda whose body array literal is assignable to the expected
        // kind-5 niche list adopts it, so `emitReturnValue` seeds each element (a `null`
        // → `ref.null $cloStruct`) through the SAME rep the annotated return /
        // named-function form already lowers soundly (`synthRetAnnots` pins `fnRet`).
        // The closure-niche sibling of the element-nullable arm above.
        if inferred != expRet && nulClosureElemListRetName(expRet) != "" {
          const nceTail = lambdaBodyTail(n.fnBody)
          if nceTail >= 0 && assignableExpr(nceTail, inferred, expRet) {
            inferred = expRet
          }
        }
        // NESTED-LIST result (`() => i64[][] = () => ([[100]])`): a lambda whose body array
        // literal is assignable to the expected nested scalar-leaf array adopts it, so the
        // body literal builds under the pinned RETURN's threading (`synthRetAnnots` pins
        // `fnRet`; the leaf widens at the store like a named function's return) and the
        // `$fnsig` result keys the arm's reflist slot on BOTH producers. Unlike the 1-D
        // scalar-list note below, the pinned `fnRet` TypeRef IS scanned by `collectA`'s
        // ref-array branch (`ensureRefElem` + the leaf-pair forcing), so the call-result
        // index finds its list types collected. (R4.)
        if inferred != expRet && nestedLeafListRetName(expRet) != "" {
          const nlTail = lambdaBodyTail(n.fnBody)
          if nlTail >= 0 && assignableExpr(nlTail, inferred, expRet) {
            inferred = expRet
          }
        }
        // SCALAR-LEAF LIST result (`(i32) => f32[] = (q0) => ([97.5])`, `() => i64[] =
        // () => ([5])`): a lambda whose body array literal is assignable to the expected
        // distinct-backing scalar-leaf list adopts it — the elements re-encode at the leaf
        // (`assignableExpr`'s ArrayLit arm, the same grant a direct `const xs: f32[] = [1.5]`
        // binding makes), the adopted name is recorded (`isScalarListRetName`) and
        // `synthRetAnnots` pins `fnRet` to it, so the body literal builds the leaf's wrapper
        // under the RETURN-position seed and the value-call index read finds its list types
        // collected — the SAME sound path the annotated named-function spelling
        // (`mk(q0: i32): f32[]`) already lowers.
        if inferred != expRet && scalarLeafListRetName(expRet) != "" {
          const slTail = lambdaBodyTail(n.fnBody)
          if slTail >= 0 && assignableExpr(slTail, inferred, expRet) {
            inferred = expRet
          }
        }
        // LITUNION-ELEMENT LIST result (`(i32) => K0[] = (q0) => (["4664"])`): a lambda
        // whose body array literal's elements are MEMBERS of the expected litunion-element
        // list adopts it — `assignableExpr`'s ArrayLit arm records the destination array
        // type on the literal (the atom-array contextual adoption a direct
        // `const ks: K0[] = ["4664"]` binding makes), so the body builds the i32 atom
        // list; the lambda's `>a` result token already byte-matches the annotation side
        // (a litunion array shares the i32-list backing), so no pin is needed. The
        // named-function spelling (`mk(q0: i32): K0[]`) lowers this already.
        if inferred != expRet && litUnionElemListRetName(expRet) != "" {
          const lulTail = lambdaBodyTail(n.fnBody)
          if lulTail >= 0 && assignableExpr(lulTail, inferred, expRet) {
            inferred = expRet
          }
        }
        // STRUCT-ELEMENT LIST result (`(i32) => {f: f32}[]`, `(i32) => {a: f32, f: K0,
        // z: i64}[]`): a lambda whose body array literal's element structs coerce FIELD-WISE
        // into the expected element shape adopts the expected list — `assignableExpr`'s
        // per-element ObjLit coercion RECORDS the coerced field types (a float-literal f32
        // field, a small-int i64/f64 field, a litunion member) for the emitter's interner,
        // exactly as a direct `const xs: {f: f32}[] = [{f: 1.5}]` binding does. Gated on
        // plainly-lowerable element fields (`structElemListRetName`: scalar / string /
        // litunion) so a map / union / nullable-field element stays a loud reject.
        if inferred != expRet && structElemListRetName(expRet) != "" {
          const seTail = lambdaBodyTail(n.fnBody)
          if seTail >= 0 && assignableExpr(seTail, inferred, expRet) {
            inferred = expRet
            objRetAdopted = true
          }
        }
      }
    }
    // PERMISSIVE FALL-THROUGH (totality): an un-annotated function that can fall off the
    // end on some path implicitly yields `null` there, so its inferred return widens to
    // `T | null` (host byline: "types hidden by aggressive inference"). A box-able value
    // type (`i32`/`i64`/`f64`/`f32` and their unions) lowers un-annotated via the
    // `uBoxIdx` box; a NICHE (`boolean`/`string`) widens too but stays floored just below
    // ("annotate the return type") until A20 carries the niche seed. A void/error
    // inferred return (no value return at all) never falls into a value position, so it
    // is exempt. Mirrors the annotated rule below: fall-through `null` must be part of the
    // return type, here by widening rather than by an explicit annotation.
    if (
      !bodyTotalForRet &&
      inferred >= 0 &&
      !isVoidTy(inferred) &&
      inferred != TY_ERR
    ) {
      const inT = T.tys[inferred]
      if !(inT is TyNullable) { inferred = mkNullableTy(inferred) }
    }
    // Robustness floor (host parity with the empty-`[]` "cannot infer — annotate"
    // floor): an un-annotated function whose returns JOIN to a union/nullable now
    // infers the CORRECT type, but the emitter cannot yet lower an un-annotated
    // union/nullable return — the `A20` return classifier carries scalar/string/array,
    // not the union box / nullable-struct seed, so a bare `return null` / a string
    // through an i32 result crashes codegen ("bare null needs a struct-typed context").
    // Require an explicit annotation here, which DOES lower (the annotated path seeds
    // the return). Codegen elaboration that removes this requirement — inferred
    // union/nullable returns end-to-end — is the documented follow-up.
    // A VALUE union/nullable (`i32 | string`, `i32 | null`) now lowers un-annotated via
    // the `uBoxIdx` box (valueUnionRetName != "" — exported above, emitted like the
    // annotated path), so it does NOT floor. Only a union/nullable the emitter still
    // can't box un-annotated — struct-ref unions, `boolean | null` / `string | null`
    // niches — hits the floor.
    if (
      !inferQuiet &&
      n.fnName != "" &&
      inferred >= 0 &&
      valueUnionRetName(inferred) == ""
    ) {
      const itt = T.tys[inferred]
      if itt is TyUnion {
        // A pure STRUCT-union whose every member maps to a NAMED type (`Cat | Dog`) lowers
        // un-annotated via the variant-boxed rep, exactly like the annotated form — so it
        // does NOT floor. The export uses the SAME `structUnionRetName` predicate, so the
        // floor accepts EXACTLY what the emitter can register/lower; a union mixing a
        // scalar/string, or one with an anonymous/un-named-shape member, still floors.
        if structUnionRetName(inferred, gRootStmts) == "" {
          tErrUnsupported(
            "'" +
              n.fnName +
              "' infers the union return type " +
              tyToStr(inferred) +
              " — type-valid, but an inferred return of this shape is not yet supported by codegen; annotate the return type",
            n.fnBody,
          )
        }
      } else if itt is TyNullable {
        // The NICHE nullables (`boolean | null` / `string | null`) now lower un-annotated
        // — the A20 table carries their inferred name and the emitter seeds the niche
        // (sentinel `2` / `ref.null $array`) from it — so they do NOT floor. Only a
        // nullable the emitter still can't box/niche un-annotated (a nullable STRUCT ref)
        // hits the floor.
        const innerNm = tyToStr(itt.nInner)
        if innerNm != "boolean" && innerNm != "string" {
          tErrUnsupported(
            "'" +
              n.fnName +
              "' infers the nullable return type " +
              tyToStr(inferred) +
              " — type-valid, but an inferred return of this shape is not yet supported by codegen; annotate the return type",
            n.fnBody,
          )
        }
      }
    }
    ret = inferred
    // Patch the hoisted TyFunc IN PLACE so existing references see the result;
    // a nested (un-hoisted) NAMED function declares fresh; an anonymous lambda
    // just carries its type as the expression value.
    if n.fnName != "" {
      const bound = lookup(n.fnName)
      let patched = false
      if bound >= 0 {
        const bt = T.tys[bound]
        if bt is TyFunc {
          bt.fnRet = inferred
          tyMutEpoch = tyMutEpoch + 1 // inferred return patched in place
          patched = true
        }
      }
      if !patched { declare(n.fnName, mkFuncTy(paramTys, inferred)) }
      // Re-retain the SYMBOL-TABLE type with the inferred return: the entry
      // stamped while checking the signature (`symDeclInOuter`, above) carried the
      // `-2` infer-later sentinel, and the in-place patch above only touches the
      // scope-bound copy (a distinct arena entry). Without this, hover / inlay on
      // an unannotated function render `-> <none>`. `symRetainType` overwrites the
      // existing `fnIx` entry in place.
      if symEnabled != 0 {
        symRetainType(fnIx, mkFuncTy(paramTys, inferred), 2)
      }
    } else if !inferQuiet {
      // An ANONYMOUS lambda is lifted to a top-level function by the emitter under a
      // synthesized `__lambda_N` name the checker never saw, so the name-keyed
      // inferred-return table can't reach it (the emitter's `inferRetNameOf("__lambda_N")`
      // misses, and the return mis-classifies as i32). Record the inferred SCALAR/STRING/
      // LIST return under a node-index sentinel key (`#<nodeIx>` — `#` can't appear in a
      // real name, so no collision), read back by `inferRetNameByNode`. This is the lambda
      // analogue of the named loop in `checkProgram`; without it a non-i32 return reached
      // through a VARIABLE (`(n) => { const x: i64 = …; return x }`) — which the emitter's
      // expression-based fallback misses — emits invalid wasm.
      const anm = tyToStr(inferred)
      // A STRUCT-with-BOXED-FIELD contextual return (`{f: boolean | {w: i32}}`, `{f: i64 |
      // string}` — a struct whose field is a union/nullable) the checker adopted at the lambda
      // boundary (`objRetWidenAdopt`'s boxing-widen arm). Recorded under the CANONICAL emit name
      // (`tyToEmitName`, spaceless — the `sNames` / `structIndexByName` key), NOT the spaced
      // `tyToStr` render, so `synthRetAnnots`'s pin + `internShapeDeep`'s inline-shape intern
      // resolve. Takes precedence over `recordable` (which would else record the spaced `anm`,
      // an un-interned key). Empty unless the inferred struct genuinely carries a boxed field.
      const sfbNm = structFieldBoxRetName(inferred)
      // A MAP-carrying STRUCT return (`{a: string, f: {f: {[string]: {f: i64}}}, z: f32}`):
      // recorded under the CANONICAL emit name too — the spaced `recordable` render never
      // pins, and the un-pinned body literal's nested `{f: h0}` resolved the map's own
      // value struct `{f: i64}` by field-name set, minting a wrong-layout outer twin
      // (INVALID-WASM; fuzz-nightly seed 184510897 d6). AFTER `sfbNm` (a boxed-field
      // struct keeps its established pin).
      let smfNm = ""
      if sfbNm == "" { smfNm = structMapFieldRetName(inferred) }
      // A PLAIN struct return (`{f: f32}`, `{a: i64, f: f64, z: {…}}` — scalar /
      // litunion / nested-plain fields only): recorded CANONICALLY too. The spaced
      // `recordable` render never pins, and an un-pinned lambda's body literal
      // fieldset-matches — a program with a same-fieldset TWIN row in scope resolved
      // the WRONG row (`{f: 4.5}` took the `{f: f64}` twin where the context declared
      // `{f: f32}` — INVALID-WASM, fuzz sweep3 multiobs leg, seed 784841544
      // case_00222; the third same-fieldset pin-miss this arc after #969's map-field
      // and case_00290's element-list). Composite fields (map / union / closure /
      // list) keep their own recorder arms below.
      let spfNm = ""
      if sfbNm == "" && smfNm == "" && objRetAdopted {
        spfNm = structPlainRetName(inferred)
      }
      // A single STRUCT-shape (`{meow: i32}`) inferred return is recorded too — a lambda
      // that COLLAPSES to one union variant (`(a) => if a is Cat { a } else { catShape }`)
      // types as that variant's shape; the emitter resolves it to the concrete variant
      // (`variantIndexOfTypeName`) so a `.map` result is the variant ref list, not the box.
      const recordable = sfbNm == "" &&
        smfNm == "" &&
        spfNm == "" &&
        (isClassifiableRetName(anm) ||
        isObjShapeName(anm) ||
        isScalarListRetName(anm))
      // A UNION inferred/contextual return (`i32 | string`, `Cat | Dog`) — export its emitter-format
      // name (value-union or struct-union) under the same node sentinel, mirroring the named-function
      // A20 loop. This is the CONTEXTUAL return the checker proved for the lambda at ITS boundary
      // (binding / return / field / array / arg), so the emitter pins a union-returning closure value
      // POSITION-INDEPENDENTLY (`synthRetAnnots`), instead of re-deriving it per boundary.
      let unm = ""
      if !recordable {
        unm = sfbNm
        if unm == "" { unm = smfNm }
        if unm == "" { unm = spfNm }
        if unm == "" { unm = valueUnionRetName(inferred) }
        if unm == "" { unm = structUnionRetName(inferred, gRootStmts) }
        // A NULLABLE-ref contextual return (`P | null`, `string | null`) — recorded under the same
        // node sentinel so `synthRetAnnots` pins a nullable-returning closure value position-
        // independently (the nullable dual of the union pin).
        if unm == "" { unm = nullableRetName(inferred, gRootStmts) }
        // A NULLABLE-LITUNION contextual return (`() => K0 | null`, adopted just above) — record
        // the alias name so `synthRetAnnots` pins the lambda's `fnRet` as the nullable litunion
        // (an i32 atom with `-1` = null), whose member-encoding `emitReturnValue` already performs.
        if unm == "" { unm = nulLitUnionRetName(inferred) }
        // An ELEMENT-NULLABLE list contextual return (`() => (f64|null)[]`, adopted just
        // above) — record its emitter name so `synthRetAnnots` pins the lambda's `fnRet` as
        // the value-union-box list, whose `[null]` element seeding `emitReturnValue` already
        // performs for the annotated form.
        if unm == "" { unm = nulElemListRetName(inferred) }
        // An ELEMENT-VALUE-UNION list contextual return (`() => (i64|boolean)[]`, adopted just
        // above) — record its emitter name so `synthRetAnnots` pins the lambda's `fnRet` as the
        // value-union-box list, whose element boxing `emitReturnValue` already performs.
        if unm == "" { unm = elemValueUnionListRetName(inferred) }
        // An ELEMENT-VARIANT-BOX-UNION list contextual return (`(i32) => ({a,f,z}|i64)[]`,
        // adopted just above) — record its emitter name so `synthRetAnnots` pins the lambda's
        // `fnRet` as the variant-box-element list, whose element boxing `emitReturnValue`
        // already performs for the annotated form.
        if unm == "" { unm = elemVariantBoxListRetName(inferred) }
        // A UNION-FIELD-STRUCT-element list contextual return (`() => {f: {f:f64}|boolean}[]`,
        // adopted just above) — record its emitter name so `synthRetAnnots` pins the lambda's
        // `fnRet` as the boxed-field-element list, whose element boxing the annotated
        // spelling already performs.
        if unm == "" { unm = structFieldBoxElemListRetName(inferred) }
        // A PLAIN-STRUCT-element list return (`() => {a: i64, f: f64, z: {…}}[]`) — record
        // its canonical name so `synthRetAnnots` pins the lambda and the element literals
        // build under the annotated threading instead of fieldset-matching (a same-fieldset
        // TWIN row in scope matched the wrong row — INVALID-WASM, fuzz sweep3 multiobs leg,
        // seed 369283890 case_00290). ADOPTION-GATED like the plain-struct record above:
        // a lambda whose self-inference already matched keeps the un-pinned route
        // (un-gated, this record regressed the closure-value ref-list ABI suite cases).
        if unm == "" && objRetAdopted { unm = structElemListRetName(inferred) }

        // A NULLABLE-CLOSURE-element list contextual return (`() => ((() => i64) | null)[]`,
        // adopted just above) — record its emitter name so `synthRetAnnots` pins the lambda's
        // `fnRet` (its `parenUnionArrElemName` arm): the pinned TypeRef collects the kind-5
        // ref-list slot + element `$fnsig`, and `emitReturnValue` threads the `[null]` seed.
        if unm == "" { unm = nulClosureElemListRetName(inferred) }
        // A CLOSURE-ARM value-union contextual return (`(i32) => (() => string) | i64`,
        // adopted just above) — record its emitter name so `collectU`'s inferred-return loop
        // REGISTERS the union and `synthRetAnnots` pins the lambda's `fnRet` to it; the
        // `$fnsig` result then keys `>u`, matching the value call.
        if unm == "" { unm = cloArmValueUnionRetName(inferred) }
        // A MAP-MEMBER-UNION contextual return (`() => {[string]:f32} | {w:i32}`, adopted just above)
        // — record its emitter name so `synthRetAnnots` pins the lambda's `fnRet` as the map-union box
        // (#865/#868), whose arm boxing `emitReturnValue` already performs for the annotated form.
        if unm == "" { unm = mapUnionRetName(inferred) }
        // A REF-ARM value-union contextual return (`(i32) => T[] | {w: i32}`, adopted just
        // above; repOf item (d)) — record its nominal render so `collectU`'s inferred-return
        // loop REGISTERS the union and `synthRetAnnots`'s `isUName` arm pins the lambda's
        // `fnRet` to the same spelling `nodeUnionName` hands the emitter's binding resolution.
        if unm == "" { unm = refArmUnionRetName(inferred, gRootStmts) }
        // A VARIANT-BOX union contextual return with an INLINE-struct arm (`(i32) => i32 |
        // {w: i32}`, adopted just above) — record its emitter name so `collectU`'s inferred-
        // return loop REGISTERS the union and `synthRetAnnots`'s `isUName` arm pins the
        // lambda's `fnRet` to it; the `$fnsig` result then keys `>u`, matching the value call.
        if unm == "" { unm = variantBoxUnionRetName(inferred) }
        // A NESTED-LIST contextual return (`() => i64[][]`, adopted just above) — record its
        // emitter name so `synthRetAnnots` pins the lambda's `fnRet` as the nested array, whose
        // return-position literal threading + `$fnsig` reflist-slot keying the annotated form
        // already performs (the pinned TypeRef collects its own list types). (R4.)
        if unm == "" { unm = nestedLeafListRetName(inferred) }
        // A MAP-ELEMENT list contextual return (`(i32) => {[string]: f32}[]`) — record its
        // emitter name so `synthRetAnnots` pins the lambda's `fnRet` as the map-element
        // array, whose kind-3 slot keying the annotated named-function form already performs.
        if unm == "" { unm = mapElemListRetName(inferred) }
        // A LITUNION-ALIAS-element list contextual return (`(i32) => K0[]`, adopted just
        // above) — record the `K0[]` name so `synthRetAnnots` pins the lambda's `fnRet`
        // and the body member literals build the i32 ATOM list the annotated return does.
        if unm == "" { unm = litUnionElemListRetName(inferred) }
        // A LITERAL-UNION contextual return (`(i32) => K = (x) => "b"`, adopted just above) — record
        // the ALIAS name so `synthRetAnnots` pins the lambda's `fnRet` as the litunion, whose functype
        // result reps as an i32 atom (`vtKindOfType`): the `$fnsig` result keys `>i` to match the value
        // call, and `emitReturnValue` encodes the member literal as its atom id (`retLitUnion`).
        if unm == "" { unm = litUnionAliasNameOfTy(inferred) }
      }
      if recordable || unm != "" {
        const nodeKey = "#" + i32ToStr(fnIx)
        if inferRetNameOf(nodeKey) == "" {
          let rty = unm
          if recordable { rty = anm }
          recordInferRet(nodeKey, rty)
        }
      }
    }
    inferObserved = savedObserved
    inferSawErr = savedSawErr
    fnSawValueRet = savedValueRet
  }
  // SOUNDNESS — missing return: a function whose body can fall off the end without
  // yielding a value on some path implicitly produces `null` there. That is sound ONLY
  // when `null` is part of the return type — a NULLABLE return (declared `: T | null`,
  // or an inferred return widened to `T | null` just above) lowers the fall-through as
  // `null` (the emitter pads it; see `emitNullForRet`). A NON-nullable value return with
  // a reachable fall-through has nowhere to put the `null`, so it is rejected (the TS
  // `noImplicitReturns` case: annotated `: i32` that falls through). Suppressed in the
  // pre-pass (`inferQuiet`) and on a void/error return (no cascade).
  let retNullableNow = false
  if ret >= 0 {
    const rtn = T.tys[ret]
    if rtn is TyNullable { retNullableNow = true }
  }
  if (
    !inferQuiet &&
    !isVoidTy(ret) &&
    ret != TY_ERR &&
    !bodyTotalForRet &&
    !retNullableNow
  ) {
    tErr(
      "not all code paths return a value in '" +
        n.fnName +
        "' — add a `return`, or annotate the return type `| null` to fall through",
      n.fnBody,
    )
  }
  // Redundant RETURN annotation: the body's NATURAL inferred return already equals the
  // explicit `: T`, so removing it yields the identical type. Conservative: a single
  // concrete observed return rendering identically to `ret`; a hole / error / `never`
  // / an annotation-influenced return is skipped. Annotated functions are checked only
  // in the real pass, so this never fires under the suppressed pre-pass.
  if (
    !inferring &&
    !inferQuiet &&
    n.fnRet >= 0 &&
    retNatural >= 0 &&
    !retNaturalErr
  ) {
    if !inlayHole(retNatural) && !isNeverTy(retNatural) && ret != TY_ERR {
      if tyEq(retNatural, ret) { recordRedundantRet(n, fnIx, ret) }
    }
  }
  retNatural = savedRetNatural
  retNaturalErr = savedRetNaturalErr
  // Inferred type guard (A6b, host parity — degenerate case): a NAMED function
  // whose body's RESULT is exactly a null-test on one of its params registers
  // as a guard, so calling it in a condition narrows the argument (inline,
  // UFCS, and the guard-clause form).
  if n.fnName != "" {
    const gBody = P.nodes[n.fnBody]
    if gBody is Block {
      const gStmts = gBody.blkStmts
      if gStmts.length > 0 {
        const gLastIx = gStmts[gStmts.length - 1]
        const gLast = P.nodes[gLastIx]
        let gResIx = gLastIx
        if gLast is RetStmt { gResIx = gLast.retArg }
        if gResIx >= 0 {
          const gParamNames: string[] = []
          let gp = 0
          while gp < params.length {
            const gpn = P.nodes[params[gp]]
            if gpn is Param {
              gParamNames.push(gpn.parName)
            } else {
              gParamNames.push("")
            }
            gp = gp + 1
          }
          const gFact = guardFactOf(gResIx, gParamNames)
          if gFact >= 0 {
            const gThen = gFact - gFact / 2 * 2
            guardNames.push(n.fnName)
            guardParamIdxs.push(gFact / 2)
            guardThens.push(gThen)
          }
        }
      }
    }
  }
  // The function's own type — a FuncDecl in EXPRESSION position (a lambda, or a
  // named function referenced as a value) evaluates to it.
  mkFuncTy(paramTys, ret)
}

// The program root: pass 0 registers `type` declarations (structs, then unions over
// them), pass 1 hoists function signatures (call-before-decl + mutual recursion),
// pass 2 checks every top-level statement.
function checkProgramNode(n: Program) {
  const stmts = n.progStmts
  cStructTyIxs = []
  cVariantMemberTyIxs = []
  cUnionTyIxs = []
  cUnionNames = []
  cLitUnionCopyTyIxs = []
  cLitUnionCopyAliasIxs = []
  // Pass 0: register top-level struct `type` declarations BEFORE anything else, so
  // a struct name in a param/return/let annotation (pass 1/2) or in a later struct's
  // field resolves via `nameToTy`. Types register in source order, so a field may
  // reference an EARLIER struct; a forward reference to a later struct reports
  // "unknown type" (deferred).
  // Pass 0a: pre-register EVERY top-level `type` name with an EMPTY placeholder
  // (struct or union) so SELF- and FORWARD-references inside field annotations
  // and union variants resolve (host A11: a recursive alias is a lazy
  // self-referential leaf; here the placeholder's arrays are filled in pass 0b,
  // so the reference lands on the FINAL arena index — the arena shape is cyclic
  // for a recursive type, which `assignable`/`tyToStr` guard against).
  let t0 = 0
  while t0 < stmts.length {
    const sd0 = P.nodes[stmts[t0]]
    if sd0 is TypeDecl {
      // A GENERIC alias (`type Box<T> = …` — the parser folds the params into
      // the declared name "Box<T>") registers in the generic-alias registry,
      // NOT in `cUserTypes`: it has no concrete type until applied. Pass 0b
      // skips it (its `cUserTypes` lookup misses); each application resolves
      // its fields under the param→argument bindings (`applyGenAlias`).
      const gname = sd0.tdName
      let gLt = -1
      let gk = 0
      let gGoing = gk < gname.length
      while gGoing {
        if gname[gk] == '<' {
          gLt = gk
          gGoing = false
        } else {
          gk = gk + 1
          gGoing = gk < gname.length
        }
      }
      if gLt > 0 {
        gaNames.push(gname.slice(0, gLt))
        gaParamLists.push(gname.slice(gLt + 1, gname.length - 1))
        gaDeclIxs.push(stmts[t0])
      } else {
        // A bodyless alias (parser sentinel `tdFields == [-1]`) registers as the
        // error type — the parser already reported it, and the error type
        // suppresses use-site cascades. A real (possibly empty `{}`) body builds
        // an object placeholder that pass 0b fills.
        const df0 = sd0.tdFields
        const bodyless0 = df0.length == 1 && df0[0] == (-1)
        if bodyless0 {
          cUserTypes[sd0.tdName] = TY_ERR
          cUserTypesVer = cUserTypesVer + 1
        } else {
          const fnames0: string[] = []
          const ftys0: i32[] = []
          const sIx0 = mkObjTy(fnames0, ftys0)
          cUserTypes[sd0.tdName] = sIx0
          cUserTypesVer = cUserTypesVer + 1
          cStructTyIxs.push(sIx0)
        }
      }
    } else if sd0 is UnionDecl {
      const members0: i32[] = []
      const uIx0 = mkUnionTy(members0)
      cUserTypes[sd0.udName] = uIx0
      cUserTypesVer = cUserTypesVer + 1
      cUnionTyIxs.push(uIx0)
      cUnionNames.push(sd0.udName)
    }
    t0 = t0 + 1
  }
  // Pass 0b: resolve each declaration's fields/variants and fill them into the
  // placeholder (pushing into the SAME arrays its arena entry holds). A name
  // redeclared later overwrote the map in 0a, so both decls resolve into the
  // LAST placeholder; `tdDone` keeps each arena entry filled exactly once.
  const tdDone: i32[] = []
  let ti = 0
  while ti < stmts.length {
    const sd = P.nodes[stmts[ti]]
    if sd is TypeDecl {
      const declIx = cUserTypes[sd.tdName] ?? -1
      let dseen = false
      let dj = 0
      while dj < tdDone.length {
        if tdDone[dj] == declIx { dseen = true }
        dj = dj + 1
      }
      if declIx >= 0 && !dseen {
        tdDone.push(declIx)
        const pt = T.tys[declIx]
        if pt is TyObj {
          const fnames = pt.objFieldNames
          const ftys = pt.objFieldTypes
          const dfields = sd.tdFields
          let fi = 0
          while fi < dfields.length {
            const fd = P.nodes[dfields[fi]]
            if fd is FieldDef {
              fnames.push(fd.fdName)
              let fty = TY_ERR
              if fd.fdType >= 0 {
                const ftn = P.nodes[fd.fdType]
                if ftn is TypeRef {
                  const r = nameToTyAt(ftn.tyName, dfields[fi])
                  if r >= 0 {
                    fty = r
                    // Record the resolved type on the field's annotation node so the emitter
                    // classifies a struct field structurally from the arena, not the name (C1).
                    if !inferQuiet && fd.fdType < nodeTyIx.length {
                      nodeTyIx[fd.fdType] = r
                    }
                  } else {
                    tErr(
                      "unknown type '" +
                        ftn.tyName +
                        "' for field '" +
                        fd.fdName +
                        "'",
                      dfields[fi],
                    )
                  }
                }
              }
              ftys.push(fty)
            }
            fi = fi + 1
          }
          // The 0a placeholder was just FILLED in place (its field arrays are
          // the ones pushed above) — an existing arena entry changed shape.
          tyMutEpoch = tyMutEpoch + 1
        }
      }
    } else if sd is UnionDecl {
      // A union's variants are type NAMES; resolve each into the member
      // type-arena indices (forward references hit the 0a placeholders).
      const declIx = cUserTypes[sd.udName] ?? -1
      let useen = false
      let uj = 0
      while uj < tdDone.length {
        if tdDone[uj] == declIx { useen = true }
        uj = uj + 1
      }
      if declIx >= 0 && !useen {
        tdDone.push(declIx)
        const pt = T.tys[declIx]
        if pt is TyUnion {
          const members = pt.uMembers
          const variants = sd.udVariants
          // A DEGENERATE self-cycle — `type D = D`, a body that is nothing but
          // the alias itself — has no base case, so nothing can inhabit it.
          // Reported at the DECLARATION (host parser parity), so an UNUSED
          // `type D = D` still flags; the members stay empty (host: `Never`).
          if variants.length == 1 && variants[0] == sd.udName {
            tErr(
              "Type `" +
                sd.udName +
                "` is defined in terms of itself " +
                "with no base type, so it can never have a value",
              stmts[ti],
            )
          } else {
            let vi = 0
            let resolvedAny = false
            const declMemberIxs: i32[] = []
            while vi < variants.length {
              const m = nameToTy(variants[vi])
              if m >= 0 {
                declMemberIxs.push(m)
                resolvedAny = true
                // A member that folds to `never` (an empty intersection —
                // `A & B` over disjoint operands) DROPS from the union
                // (`0 | (1 & !1)` is `0`); a declaration with NO surviving
                // member is the never-value HARD ERROR below (host PR #189:
                // errors at the declaration even when unused).
                if !isNeverTy(m) { members.push(m) }
              } else {
                tErr(
                  "unknown type '" +
                    variants[vi] +
                    "' in union '" +
                    sd.udName +
                    "'",
                  stmts[ti],
                )
              }
              vi = vi + 1
            }
            // Variant-member registration is ARITY-AWARE (Stage B b1, latent
            // irregularity (a) from the #920 shadow report): only a REAL
            // (2+ surviving member) union registers its members as variants.
            // The emitter lowers a single-member union as the member ITSELF
            // (a `{a} & {b}` struct alias, a transparent `type Id = i32`),
            // never as a variant box — the old arity-blind push made such a
            // member's index classify "variant" through the flat TyObj arm
            // while the union's own index classified "struct".
            if members.length >= 2 {
              let ri = 0
              while ri < declMemberIxs.length {
                cVariantMemberTyIxs.push(declMemberIxs[ri])
                ri = ri + 1
              }
            }
            // The 0a placeholder union was just FILLED in place (`members` is
            // its `uMembers` array) — an existing arena entry changed shape.
            tyMutEpoch = tyMutEpoch + 1
            if resolvedAny && members.length == 0 {
              // Explain the empty intersection in SOURCE terms (matching the TS
              // host): name the two operands and their kinds (`A & B`, an object
              // and a string literal), or call out a self-reference
              // (`type E = A & E`). Falls back to the generic wording for a
              // non-binary / non-intersection never (e.g. `type C = NeverAlias`).
              const ops = splitTopAmp(variants[0])
              let didDetail = false
              if variants.length == 1 && ops.length == 2 {
                const expr = ops[0] + " & " + ops[1]
                const selfRef = ops[0] == sd.udName || ops[1] == sd.udName
                if selfRef {
                  tErr(
                    "Type `" +
                      sd.udName +
                      "` refers to itself inside an intersection (`" +
                      expr +
                      "`), so it reduces to `never`",
                    stmts[ti],
                  )
                } else {
                  tErr(
                    "Type `" +
                      sd.udName +
                      "` is `never` (an empty type — `" +
                      expr +
                      "`, " +
                      operandKind(nameToTy(ops[0])) +
                      " and " +
                      operandKind(nameToTy(ops[1])) +
                      ", have no common values), so it has no values",
                    stmts[ti],
                  )
                }
                didDetail = true
              }
              if !didDetail {
                tErr(
                  "Type `" +
                    sd.udName +
                    "` is `never` (an empty type — " +
                    "its operands have no common values), so it has no values",
                  stmts[ti],
                )
              }
            }
          }
        }
      }
    }
    ti = ti + 1
  }
  // Pass 1: hoist top-level function signatures so call-before-decl and mutual
  // recursion type-check.
  let hi = 0
  while hi < stmts.length {
    const s = P.nodes[stmts[hi]]
    if s is FuncDecl {
      // A SECOND top-level `function` of the same name is a redeclaration error,
      // exactly like a duplicate `let`/`const` (B16). Without this the later
      // hoist silently overwrites the earlier one and the last body wins.
      if (fnDeclIx[s.fnName] ?? -1) >= 0 {
        tErr("redeclared " + s.fnName, stmts[hi])
      }
      const hp = s.fnParams
      const hpt: i32[] = []
      let k = 0
      while k < hp.length {
        const hpn = P.nodes[hp[k]]
        let t = TY_ERR
        if hpn is Param {
          if hpn.parType >= 0 {
            const hptn = P.nodes[hpn.parType]
            if hptn is TypeRef {
              const r = resolveAnnotAt(hptn.tyName, s.fnTyParams, hpn.parType)
              if r >= 0 { t = r }
            }
          } else {
            // An un-annotated param hoists as its inference HOLE (the same
            // declaration+position name `checkFuncDeclNode` mints, so a
            // forward call site binds the identical hole by name).
            t = mkTyVar("?" + s.fnName + "." + i32ToStr(k))
          }
        }
        hpt.push(t)
        k = k + 1
      }
      // An UN-ANNOTATED return hoists as the PENDING sentinel (-2): the real type
      // is inferred from the body in pass 2 (or on demand at a forward call site),
      // then PATCHED into this same TyFunc in place.
      let hret = -2
      if s.fnRet >= 0 {
        const hrtn = P.nodes[s.fnRet]
        if hrtn is TypeRef {
          const r = resolveAnnotAt(hrtn.tyName, s.fnTyParams, s.fnRet)
          if r >= 0 { hret = r } else { hret = TY_VOID }
        }
      }
      declare(s.fnName, mkFuncTy(hpt, hret))
      fnDeclIx[s.fnName] = stmts[hi]
      // Collect un-annotated returns (hoisted as the `-2` pending sentinel) for the
      // return-inference pre-pass.
      if hret == (-2) { topUnannotFns.push(stmts[hi]) }
      // Completion visibility: a top-level function is global. Stamped here (only
      // the global scope is open) so it wins over any later demand-inference
      // re-entry, which would run the body from a deeper stack (see `symStampVis`).
      if symEnabled != 0 {
        symStampVis(s.fnName, stmts[hi], 2, scopeSL.length - 1)
      }
    }
    hi = hi + 1
  }
  // Pass 1.5: hoist top-level VALUE bindings (`let`/`const`) — names + types — so a
  // function body sees every module-level value regardless of source order, exactly
  // as pass 1 makes every top-level function visible. This makes the module scope
  // order-independent; the annotation a forward-referenced/demand-inferred function
  // used to NEED (so its body could resolve a later global) becomes genuinely
  // redundant.
  //
  // Initialization order still matters for STRAIGHT-LINE top-level code: each global
  // joins the definite-assignment dead-zone here (`daAdd`) and is marked assigned
  // only when pass 2 reaches its initializer, so reading one before its `let` is a
  // "used before initialization" (TDZ) error. A function body runs at CALL time, not
  // at the declaration site — `checkFuncDeclNode` clears the dead-zone for the body
  // (`daSnapshot`/`daClear`) — so a deferred read from inside a function is correctly
  // NOT flagged. The annotation type is registered now for forward references; pass 2
  // overwrites the binding with the final (identical, for annotated) type.
  let mi = 0
  while mi < stmts.length {
    const sm = P.nodes[stmts[mi]]
    if sm is LetDecl {
      if moduleGlobals[sm.letName] ?? false {
        // A genuine top-level redeclaration — reported here (pass 2 skips its own
        // redeclare check for module globals, since the hoist owns the declaration).
        tErr("redeclared " + sm.letName, stmts[mi])
      } else {
        let mty = TY_ERR
        if sm.letType >= 0 {
          const mtn = P.nodes[sm.letType]
          if mtn is TypeRef {
            const r = nameToTyAt(mtn.tyName, sm.letType)
            if r >= 0 { mty = r }
          }
        } else if sm.letInit >= 0 {
          // Un-annotated: peek ONLY at a LITERAL initializer — side-effect free. A
          // `checkNode` here would prematurely demand-infer callees and PATCH their
          // hoisted return types (corrupting the real pass-2 result), so a non-literal
          // init stays an error placeholder that pass 2 overwrites with its real type.
          // (A forward reference to an un-annotated NON-literal global is the one case
          // still order-dependent — it carries no manifest type to hoist.)
          const initN = P.nodes[sm.letInit]
          if initN is NumLit {
            if hasDot(initN.numText) { mty = TY_F64 }
            else if intLexemeFitsI32(initN.numText) { mty = TY_I32 }
            else { mty = TY_I64 }
          } else if initN is StrLit {
            mty = TY_STR
          } else if initN is CharLit {
            mty = TY_I32
          } else if initN is BoolLit {
            mty = TY_BOOL
          }
        }
        declare(sm.letName, mty)
        moduleGlobals[sm.letName] = true
        // TDZ: in the dead-zone until pass 2 reaches the initializer.
        daAdd(sm.letName)
      }
    }
    mi = mi + 1
  }
  // Pass 1.7: return-inference pre-pass — resolve every un-annotated return (cycles
  // included, via the binding-group fixpoint) BEFORE checking bodies, so pass 2 sees
  // final return types and a recursive function needs no return annotation.
  inferReturnsPrePass()
  // Pass 2: check every top-level statement (bodies included).
  let j = 0
  while j < stmts.length {
    checkNode(stmts[j])
    j = j + 1
  }
  // A function whose return never resolved (a genuinely base-case-less recursive
  // cycle) — the fixpoint found no concrete basis. Reported here, after the real
  // pass (the pre-pass suppressed it).
  let uf = 0
  while uf < unresolvedFns.length {
    const ufIx = fnDeclIx[unresolvedFns[uf]] ?? -1
    if ufIx >= 0 {
      const ufn = P.nodes[ufIx]
      if ufn is FuncDecl {
        tErr(
          "cannot infer a return type for '" +
            unresolvedFns[uf] +
            "' — annotate a return type",
          ufn.fnBody,
        )
      }
    }
    uf = uf + 1
  }
  TY_VOID
}

// ── the Node visitor (dispatch; per-kind helpers above take narrowed variants) ──
// `checkNode` dispatches EVERY node kind — expressions AND statements — and
// returns the node's type-arena index (statements yield `TY_VOID`). Every
// per-variant body is INLINED here, including the nested `TypeRef`/`Param`/`Block`
// narrowing, because no other function may narrow `Node` (Finding 2). It is the
// direct analogue of the parser_harness's single `walk`. On a type error it
// raises a diagnostic and returns `TY_ERR` so checking continues.
// Thin recording wrapper around the real per-variant checker: on the real (non-quiet)
// pass, store each node's resolved type-arena index into the typed-IR table. Recording the
// arena INDEX (not a snapshot) means a hole pinned later in place — an empty `[]` element
// fixed by a downstream `.push` — is reflected when the emitter reads it back. Last write
// wins, so a re-checked node settles on its final type.
// Wrap a match arm body as a Block (a bare-expression body becomes a one-statement block).
function matchBlockOf(bodyIx: i32) {
  const b = P.nodes[bodyIx]
  if b is Block { return bodyIx }
  const one: i32[] = []
  one.push(bodyIx)
  mkBlock(one, -1)
}

// `scrut == p0 [|| scrut == p1 …]` over match arm `k`'s OR-patterns.
function matchArmCond(
  scrut: i32,
  pats: i32[],
  armStart: i32[],
  armCount: i32[],
  k: i32,
  pos: i32,
) {
  let cond = -1
  let pj = 0
  while pj < armCount[k] {
    const pat = pats[armStart[k] + pj]
    const eq = mkBinary("==", scrut, pat, pos)
    if cond < 0 { cond = eq } else { cond = mkBinary("||", cond, eq, pos) }
    pj = pj + 1
  }
  cond
}

// Lower the checked, exhaustive `MatchExpr` at `ix` to an if/else chain, OVERWRITING the arena slot
// in place — so lint AND emit see only if-chains (no per-node `match` handling needed in either).
// The wildcard arm (or, if none, the LAST arm — exhaustive, the only case left) becomes the bare
// `else`. Runs in the REAL check pass only.
function desugarMatchAt(ix: i32) {
  const n = P.nodes[ix]
  if n is MatchExpr {
    const scrut = n.matchScrut
    const pats = n.matchPats
    const armStart = n.matchArmStart
    const armCount = n.matchArmCount
    const bodies = n.matchBodies
    const mpos = n.pos
    const nArms = armStart.length
    let wildArm = -1
    let ai = 0
    while ai < nArms {
      let pj = 0
      while pj < armCount[ai] {
        const p = P.nodes[pats[armStart[ai] + pj]]
        if p is Ident { wildArm = ai }
        pj = pj + 1
      }
      ai = ai + 1
    }
    let elseArm = wildArm
    if elseArm < 0 { elseArm = nArms - 1 }
    let chain = matchBlockOf(bodies[elseArm])
    let k = nArms - 1
    while k >= 0 {
      if k != elseArm {
        const cond = matchArmCond(scrut, pats, armStart, armCount, k, mpos)
        const thenB = matchBlockOf(bodies[k])
        chain = mkIf(cond, thenB, chain, mpos)
      }
      k = k - 1
    }
    P.nodes[ix] = P.nodes[chain]
  }
  0
}

function checkNode(ix: i32) {
  const t = checkNodeReal(ix)
  if !inferQuiet {
    if ix >= 0 {
      if ix < nodeTyIx.length { nodeTyIx[ix] = t }
    }
  }
  t
}

function checkNodeReal(ix: i32) {
  if ix < 0 { return TY_ERR }
  const n = P.nodes[ix]

  // ── literals & identifiers ────────────────────────────────────────────────
  if n is NumLit {
    // A literal with a "." is f64. An integer literal defaults to the NARROWEST
    // type that holds it exactly — i32 if its magnitude fits, else i64 — the
    // host's `defaultIntegerType` rule (`intLexemeFitsI32`).
    if hasDot(n.numText) {
      // A literal whose magnitude rounds past the largest finite double names a
      // value f64 cannot represent — and VL has no infinity spelling to encode
      // it honestly, so it is an ERROR (silent ±inf would be a lossy implicit
      // conversion). The judgement is the ENCODER's own rounding
      // (`f64LitOverflows`), exact at the boundary. Runtime arithmetic still
      // yields ±inf per IEEE-754 — this rejects only literal text.
      if f64LitOverflows(n.numText) { tErr("float literal overflows f64", ix) }
      return TY_F64
    }
    if intLexemeFitsI32(n.numText) { return TY_I32 }
    return TY_I64
  } else if n is StrLit {
    return TY_STR
  } else if n is CharLit {
    // A char literal `'x'` is its i32 CODE POINT (composes with arithmetic / `==` /
    // string indexing exactly like a bare int literal), NOT a string.
    return TY_I32
  } else if n is BoolLit {
    return TY_BOOL
  } else if n is NullLit {
    return TY_NULL
  } else if n is Ident {
    const ty = lookup(n.identName)
    if ty < 0 {
      tErr("undeclared identifier '" + n.identName + "'", ix)
      return TY_ERR
    }
    if symEnabled != 0 { symUse(ix, n.identName) }
    // Definite-assignment read gate: a bare-name READ of a still-unassigned
    // binding is "used before assigned". The LHS of a plain `=` is a WRITE, not a
    // read (the `BinExpr` `=` arm marks it as `daWriteTarget` before evaluating
    // the target), so it is skipped here; a compound `x += …` desugars to
    // `x = x + (…)` whose RHS reads `x` and DOES reach this gate.
    if ix != daWriteTarget { daCheckRead(n.identName, ix) }
    return ty
  } else if n is Paren {
    return checkNode(n.parInner)
    // ── explicit numeric cast `x as T` ──────────────────────────────────────────
  } else if n is AsExpr {
    return checkCastNode(n, ix)
    // ── unary ─────────────────────────────────────────────────────────────────
  } else if n is Unary {
    return checkUnaryNode(n, ix)
  } else if n is BinExpr {
    return checkBinExprNode(n, ix)
  } else if n is Call {
    return checkCallNode(n, ix)
    // ── member access ───────────────────────────────────────────────────────────
  } else if n is Member {
    return checkMemberNode(n, ix)
  } else if n is ArrayLit {
    return checkArrayLitNode(n, ix)
  } else if n is Index {
    return checkIndexNode(n, ix)
  } else if n is ObjLit {
    return checkObjLitNode(n, ix)
  } else if n is IsExpr {
    return checkIsExprNode(n, ix)
  } else if n is OptMember {
    return checkOptMemberNode(n, ix)
  } else if n is ErrExpr {
    return TY_ERR
    // ── let / const ─────────────────────────────────────────────────────────────
  } else if n is LetDecl {
    return checkLetDeclNode(n, ix)
  } else if n is FuncDecl {
    return checkFuncDeclNode(n, ix)
    // ── while ─────────────────────────────────────────────────────────────────
  } else if n is WhileStmt {
    return checkWhileStmtNode(n, ix)
    // Accepted unconditionally: valid only inside a loop, but loop-nesting is
    // not tracked yet (a misplaced `break`/`continue` is a parser concern).
  } else if n is BreakStmt {
    return TY_VOID
  } else if n is ContinueStmt {
    return TY_VOID
    // ── for v in A to B [step S] ────────────────────────────────────────────────
    // A numeric range loop: the bounds (and step, if present) must be i32; the loop
    // variable is i32 in the body's scope.
  } else if n is ForRange {
    return checkForRangeNode(n, ix)
  } else if n is ForIn {
    return checkForInNode(n, ix)
  } else if n is MatchExpr {
    return checkMatchExprNode(n, ix)
  } else if n is IfStmt {
    return checkIfStmtNode(n, ix)
  } else if n is RetStmt {
    return checkRetStmtNode(n, ix)
  } else if n is Block {
    return checkBlockNode(n, ix)
  } else if n is Program {
    return checkProgramNode(n)
  } else if n is Param {
    return TY_VOID
  } else if n is TypeRef {
    return TY_VOID
  } else if n is TypeDecl {
    // Registered by the Program pass-0 pre-pass; nothing to do when visited.
    return TY_VOID
  } else if n is UnionDecl {
    // Registered by the Program pass-0 pre-pass; nothing to do when visited.
    return TY_VOID
  } else if n is ImportDecl {
    // A tooling node (the lint tier reads it): import binding/resolution
    // happened in the module front end (the driver's token-level `modScan` +
    // merge), so the checker has nothing to verify here.
    return TY_VOID
  }
  TY_ERR
}

// Flatten a (possibly nested) union/nullable type into its leaf atom NAMES, pushing
// each into `out` ("null" for the nullable slot). joinTys can nest a nullable around a
// union (`mkNullableTy(mkUnionTy(...))`), so recurse; a scalar leaf renders no-space
// via tyToStr. Used to build the emitter-format `a|b|null` union name for an inferred
// return (the emitter's `splitUnionAtoms` splits on a bare `|`, NOT tyToStr's ` | `).
function collectRetAtoms(er: i32, out: string[]) {
  if er < 0 { return 0 }
  const t = T.tys[er]
  if t is TyUnion {
    let i = 0
    while i < t.uMembers.length {
      collectRetAtoms(t.uMembers[i], out)
      i = i + 1
    }
  } else if t is TyNullable {
    collectRetAtoms(t.nInner, out)
    out.push("null")
  } else {
    out.push(tyToStr(er))
  }
  0
}

// The CANONICAL emitter NAME (`{f:boolean|{w:i32}}`, `{f:i64|string}`) for an inferred return
// `er` IF it is a bare STRUCT whose every field is emit-nameable AND at least one field is a
// UNION or NULLABLE (a boxed / niche field slot), else "". A struct whose composite field a
// closure result BODY literal built from bare-scalar/struct literals does NOT naturally box —
// the lambda self-infers the plain field shape — so the value call mis-recovered the boxed field
// (a MISMATCH: `t0(1).f is boolean` read the wrong tag; or INVALID-WASM: an i64 field read where
// an i32 was stored). `synthRetAnnots` pins the lambda's `fnRet` to this canonical name so its
// `$fnsig` result is the union-FIELD struct and `emitReturnValue` boxes the body ObjLit, exactly
// as the annotated `: {f: …}` named-function form lowers. Canonical (`tyToEmitName`), spaceless —
// the `structIndexByName` / `internShapeDeep` key (`tyToStr`'s spaced render would not resolve).
// The struct-field dual of `valueUnionRetName` / `mapUnionRetName`.
function structFieldBoxRetName(er: i32) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if !(t is TyObj) { return "" }
  let hasBox = false
  let i = 0
  while i < t.objFieldTypes.length {
    const ft = T.tys[t.objFieldTypes[i]]
    if ft is TyUnion {
      // Every member must be a SCALAR / string-literal / OBJECT (a boxable value or struct-mixed
      // union — `i64 | string`, `boolean | {w: i32}`). A CLOSURE / MAP / LIST / nullable member is
      // NOT lowerable as a boxed struct-field slot (`((i32) => K0) | f64`, `{[string]: V} | X`) — the
      // annotated form itself rejects those, so pinning would turn a working shape into a NEW loud
      // reject. Decline the whole struct then (its unlowerable shape stays a clean reject, unchanged).
      let m = 0
      while m < ft.uMembers.length {
        const mt = T.tys[ft.uMembers[m]]
        if !(mt is TyPrim) && !(mt is TyLit) && !(mt is TyObj) {
          // A LITUNION-ALIAS member kept NESTED in the arena (`K0 | boolean` = TyUnion
          // [TyUnion[lits], bool] — `tyToStr` flattens it for display, the entry does
          // not): it rides the box as the i32 atom / string ref, `tyToEmitName` renders
          // the alias (`K0`), and the annotated spelling lowers — admit it. Without
          // this the whole struct declined, the closure-field lambda recorded the
          // SPACED self render instead of the canonical pin, and its `$fnsig` result
          // kept the twin plain row while the value call keyed the boxed-field struct
          // — INVALID-WASM (fuzz sweep3 declared leg, seed 128787380 case_00189).
          if !tyIsLitUnion(ft.uMembers[m]) { return "" }
        }
        m = m + 1
      }
      hasBox = true
    } else if ft is TyNullable {
      // A NULLABLE struct field (`{f: f64 | null}`, `{f: S | null}`) — a niche slot the
      // ANNOTATED form already lowers. Record it as box-bearing (so the pin fires) when the
      // inner is a prim/literal/object; an unlowerable inner (closure/map/list) declines the
      // whole struct as before. The old blanket decline left the lambda UN-pinned — for a
      // shape whose outer and nested structs share a field-name set (`{a: f32, f: {a: f64,
      // f: {f: f64 | null}}}`), the un-pinned return resolution collapsed onto the WRONG
      // same-name-set struct and emitted the outer f32 field as f64 — INVALID-WASM (fuzz
      // seed 103465585 d6). Pinned, the lambda takes the annotated-form path (proven).
      const nin = T.tys[ft.nInner]
      if !(nin is TyPrim) && !(nin is TyLit) && !(nin is TyObj) {
        // A NULLABLE STRUCT-ELEMENT LIST field (`{f: {f: string}[] | null}` — the
        // code-28 nul-ref-list slot the annotated form already lowers): admit it so
        // the lambda pins to the canonical render. Declined, the recorder kept the
        // `?`-spelled `tyToStr` shape no pin arm matches — the un-pinned body
        // literal then resolved the OUTER `{f: …}` onto the same-field-name INNER
        // `{f: string}` row and built one level short: INVALID-WASM (fuzz sweep3
        // branching leg, seed 46882632 case_00050). Other inners (closure / map /
        // scalar-backed lists) keep the decline — their nullable field slots are
        // not all lowerable, and an unsupported shape must stay a loud reject.
        let nulListOk = false
        if nin is TyArray {
          if nin.aElem >= 0 {
            const nel = T.tys[nin.aElem]
            if nel is TyObj { nulListOk = true }
          }
        }
        if !nulListOk { return "" }
      }
      hasBox = true
    } else if ft is TyObj {
      // A NESTED struct field (`{f: {f: i32 | string}}`): the boxed slot may sit one level
      // down — RECURSE so the pin fires for a lambda whose NESTED literal field adopted a
      // union-field shape (`objLitWidenFields`' descent). Without it the lambda's `$fnsig`
      // kept the self-inferred plain layout while the value call keyed the boxed-field
      // struct — INVALID-WASM (fuzz-nightly run 29808029476, seed 78530533 d5,
      // `(i32) => {f: {f: i32 | string}}`). A nested shape with no box contributes
      // nothing (the "" is a plain no-box, not a decline — its own unlowerable unions
      // still fail loudly at the field-coding gate).
      if structFieldBoxRetName(t.objFieldTypes[i]) != "" { hasBox = true }
    }
    i = i + 1
  }
  if !hasBox { return "" }
  tyToEmitName(er)
}

// The CANONICAL emitter NAME (`{a:string,f:{f:{[string]:{f:i64}}},z:f32}`) for an inferred
// return `er` IF it is a bare STRUCT carrying a MAP field anywhere in its (recursively
// nested-struct) field tree, else "". A map-carrying struct a lambda BODY literal builds
// has NO field-set anchor for its nested literals — the un-pinned inner `{f: h0}` resolved
// by first-field-name-set match to the map's own VALUE struct `{f: i64}` (interned first),
// the map ref took the i64 field widen, and the outer literal minted a WRONG-layout twin
// row beside the annotation's — INVALID-WASM (`i64.extend_i32_s` on a map ref; fuzz-nightly
// run 29893544685, seed 184510897 d6, `() => {a: string, f: {f: {[string]: {f: i64}}},
// z: f32}`). `synthRetAnnots` pins the lambda's `fnRet` to this canonical name so the body
// ObjLit threads the SAME per-field struct indices the annotated named-function spelling
// (which lowers already) seeds. Canonical (`tyToEmitName`), spaceless — the
// `structIndexByName` / `internShapeDeep` key. The map-field sibling of
// `structFieldBoxRetName`; checked AFTER it in the recorder (a boxed-field struct keeps
// its own pin).
function structMapFieldRetName(er: i32) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if !(t is TyObj) { return "" }
  if !tyObjHasMapField(er) { return "" }
  tyToEmitName(er)
}

// True if struct-arena entry `er` (a `TyObj`) carries a `TyMap` field directly or inside a
// nested `TyObj` field (any depth). The `structMapFieldRetName` gate.
function tyObjHasMapField(er: i32) {
  const t = T.tys[er]
  if t is TyObj {
    let i = 0
    while i < t.objFieldTypes.length {
      const ft = T.tys[t.objFieldTypes[i]]
      if ft is TyMap { return true }
      if ft is TyObj {
        if tyObjHasMapField(t.objFieldTypes[i]) { return true }
      }
      i = i + 1
    }
  }
  false
}

// The CANONICAL emitter NAME (`{f:{f:f64}|boolean}[]`) for an inferred return `er` IF it is a
// LIST whose ELEMENT is a `structFieldBoxRetName` struct (a struct with a boxed union/nullable
// field slot), else "". The element-list sibling of `structFieldBoxRetName`: a closure-result
// array literal of such structs self-infers the plain element shape (`{f:{f:f64}}[]` — no box),
// so un-pinned the binding's element rep and the annotation-side consumer keyed DIFFERENT
// layouts — INVALID-WASM at the element construct (`expected i32, found ref`; fuzz-nightly run
// 29874629450, seed 214588500 d6, `() => {f: {f: f64} | boolean}[]`). `synthRetAnnots` pins the
// lambda's `fnRet` to this name so the body array literal builds boxed-field elements exactly
// as the annotated `(): {f:…|boolean}[]` spelling (which lowers already) does.
function structFieldBoxElemListRetName(er: i32) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if !(t is TyArray) { return "" }
  if t.aElem < 0 { return "" }
  if structFieldBoxRetName(t.aElem) == "" { return "" }
  tyToEmitName(er)
}

// True when every LEAF atom of the (possibly nested) union/nullable type `er` renders
// to a SHORT name `valueAtomKind` could admit — a prim/literal/type-var leaf, or a
// prim-element list (`i32[]`). A composite leaf (struct, map, closure, negation,
// nested list) always renders to a `-1`-kind atom, so the whole union declines and the
// render was wasted — and for a RECURSIVE struct the waste is CATASTROPHIC: `tyToStr`
// expands `{child: S | null, kids: S[]}` DOUBLY per depth level (≈4–6 K chars at the
// depth-8 cap), and `splitUnionAtoms`'s per-atom accumulation walks that name again —
// re-run per narrowing consult of one `const p = f()` binding of type `S | null`, this
// took ~14 s of compile for a 30-line program (#912's fuzzgen: 66 s vs master's 4.5 s).
// The gate decides structurally, BEFORE `collectRetAtoms` renders anything. (The same
// pre-gate shape as `nodeUnionName`'s allValue scan — the third recurrence of the
// render-before-checking quadratic class; see also #494.)
function retAtomsCheap(er: i32) {
  if er < 0 { return true }
  const t = T.tys[er]
  if t is TyUnion {
    let i = 0
    while i < t.uMembers.length {
      if !retAtomsCheap(t.uMembers[i]) { return false }
      i = i + 1
    }
    return true
  }
  if t is TyNullable { return retAtomsCheap(t.nInner) }
  if t is TyPrim { return true }
  if t is TyLit { return true }
  if t is TyVar { return true }
  if t is TyErr { return true }
  if t is TyArray {
    // Only a prim-element list renders short AND can classify (`i32[]`, `string[]`);
    // a composite-element list (`S[]`, `i32[][]`) renders big and always declines.
    if t.aElem < 0 { return true }
    const et = T.tys[t.aElem]
    return et is TyPrim
  }
  false
}

// The emitter-format union NAME (`i32|string`, `i32|null`) for an inferred return type
// `er` IF it is a VALUE union the emitter can box (the `uBoxIdx` rep: ≥2 non-null value
// atoms, or one numeric scalar + null — `isValueUnionName`, the same gate the annotated
// path uses), else "". This is what lets an UN-annotated union/nullable return lower:
// the name drives `registerValueUnionName` (type interning), the `"union"` return kind (the result
// valtype), and `emitUnionCoerce` at the return site — exactly the annotated path.
function valueUnionRetName(er: i32) {
  if er < 0 { return "" }
  // Decline a union with any composite leaf WITHOUT rendering it (`retAtomsCheap`) —
  // `isValueUnionName` would reject its atom anyway, and the render of a recursive
  // struct leaf is exponential in the `tyToStr` depth cap.
  if !retAtomsCheap(er) { return "" }
  const atoms: string[] = []
  collectRetAtoms(er, atoms)
  let nm = ""
  let i = 0
  while i < atoms.length {
    if i > 0 { nm = nm + "|" }
    nm = nm + atoms[i]
    i = i + 1
  }
  if isValueUnionName(nm) { return nm }
  ""
}

// The user-type NAME whose declared shape structurally equals object type `obj`, found
// by scanning the program's `TypeDecl`s (`cUserTypes` is a `Map` the compiler subset
// cannot iterate). Structural equality is bidirectional assignability — so a 1-field
// `{meow}` does NOT match a 2-field `Cat = {meow, foo}` (the missing field breaks one
// direction). "" if no named type matches.
function nominalNameOfObj(obj: i32, stmts: i32[]) {
  let i = 0
  while i < stmts.length {
    const s = P.nodes[stmts[i]]
    if s is TypeDecl {
      const nm = s.tdName
      if cUserTypes.has(nm) {
        const ti = cUserTypes[nm] ?? (-1)
        if ti >= 0 {
          const tt = T.tys[ti]
          if tt is TyObj {
            if assignable(obj, ti) && assignable(ti, obj) { return nm }
          }
        }
      }
    }
    i = i + 1
  }
  ""
}

// The emitter-format NAME of an inferred STRUCT-union return `er` — `Cat|Dog`, each
// member reverse-mapped (`nominalNameOfObj`) to the user-type name whose shape it
// equals. The emitter's union machinery is keyed on these NOMINAL names — the structural
// `{meow: i32}` render `tyToStr` produces does NOT resolve through `registerInlineUnion`
// / `structIndexByName`, so the reverse map is required. "" unless `er` is an all-object
// union of ≥2 members AND every member resolves to a named type (else it declines, so the
// emitter never sees an unregisterable name).
function structUnionRetName(er: i32, stmts: i32[]) {
  if er < 0 { return "" }
  if !isStructUnionTy(er) { return "" }
  const t = T.tys[er]
  if t is TyUnion {
    const members = t.uMembers
    let name = ""
    let i = 0
    while i < members.length {
      const nm = nominalNameOfObj(members[i], stmts)
      if nm == "" { return "" }
      if i > 0 { name = name + "|" }
      name = name + nm
      i = i + 1
    }
    return name
  }
  ""
}

// The emitter-format NAME of an inferred NULLABLE-ref return `er` — `P | null` (the struct inner
// reverse-mapped to its user-type name, exactly as `structUnionRetName` does for a union member) or
// `string | null`. The emitter pins a nullable-returning closure VALUE from this (`synthRetAnnots`) so
// its `$fnsig` result keys the nullable token (`>n<idx>;` / `>N`) and the value call's `ref.cast`
// resolves — without it the lambda's return collapses to the bare non-null kind (`>s<idx>;`) and the
// call's nullable key is un-interned. "" unless `er` is a nullable whose inner the emitter lowers (a
// NAMED struct — niche `(ref null $struct)` — or string — niche `ref.null $array`).
// Whether nullable-INNER type `it` is an ARRAY of a PRIM i32/boolean element — the
// `T[] | null` subset that reps as the `nullist` niche (`(ref null $lTypeIdx)`) and
// carries the `>o` value-call result token. The distinct-backing leaves (i64/f64/f32/
// string elements) are NOT this — their nullable lists stay outside the value-call ABI.
// A LITUNION element (`K0[] | null`) shares the i32 backing too but its lambda
// adoption still mis-keys the sig producers (the named-function VALUE spelling works;
// the lambda stays a clean checker reject until that seam is audited), so it is
// deliberately excluded here.
function tyIsNulI32BackedListInner(itIx: i32) {
  if itIx < 0 { return false }
  const it = T.tys[itIx]
  if it is TyArray {
    if it.aElem < 0 { return false }
    const el = T.tys[it.aElem]
    if el is TyPrim { return el.primName == "i32" || el.primName == "boolean" }
  }
  false
}

function nullableRetName(er: i32, stmts: i32[]) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if t is TyNullable {
    const it = T.tys[t.nInner]
    if it is TyObj {
      const nm = nominalNameOfObj(t.nInner, stmts)
      // NON-spaced (`P|null`) — the emitter's internal name convention (`nullablePartOf`,
      // `structUnionRetName`'s `Cat|Dog`), not the spaced `tyToStr` render.
      if nm != "" { return nm + "|null" }
      // An INLINE shape with no matching TypeDecl (`{a: boolean, f: {f: f64}, z: i32}`,
      // the anonymous `(i32) => {f: i64} | null` spelling): render the emitter-format shape
      // text — `structIndexOfTypeName` resolves it by FIELD-SET to the same struct index the
      // annotation side keys, so the two `$fnsig` producers agree on `>n<idx>;`. A map (`{[`)
      // is excluded (no struct rep); an un-internable shape leaves the sig unresolved
      // downstream — a loud reject, exactly as before the pin.
      const inm = tyToEmitName(t.nInner)
      if inm.length >= 2 && inm[0] == '{' && inm[1] != '[' {
        return inm + "|null"
      }
    } else if it is TyFunc {
      // A NULLABLE-CLOSURE contextual return (`((i32) => K0) | null`, kind 19): the closure
      // fat-pointer made nullable (`(ref null $cloStruct)` — the niche). Render the inner
      // function type in the emitter's NON-spaced `=>` form, PARENTHESIZED and NON-spaced around
      // the bar (`((i32)=>K0)|null`) — the form `nameIsNulClosure` / `nullablePartOf` recognize
      // (`tyToStr`'s spaced `->` render does not). The RESULT preserves a literal-union ALIAS
      // (`litUnionAliasNameOfTy`) rather than `tyToEmitName`'s softened `string`, so the inner
      // value-call (`t0(1)`) and the interned inner `$fnsig` agree on the litunion's i32-atom
      // token (`>i`, via `annRetKind`) — NOT the string `>S`, whose `(ref array)` result would
      // clash with the litunion-atom `print`. `synthRetAnnots` pins the lambda's `fnRet` to this,
      // and `emitReturnValue`'s `retNulClosure` arm niches a `return null` as `ref.null
      // $cloStruct`. (Closure dual of the nullable-struct pin; the lambda's `$fnsig` result keys `>C`.)
      let ips = ""
      const pts = it.fnParamTypes
      let pj = 0
      while pj < pts.length {
        const pn = tyToEmitName(pts[pj])
        if pn == "" { return "" }
        if pj > 0 { ips = ips + "," }
        ips = ips + pn
        pj = pj + 1
      }
      let irs = litUnionAliasNameOfTy(it.fnRet)
      if irs == "" { irs = tyToEmitName(it.fnRet) }
      if irs != "" { return "((" + ips + ")=>" + irs + ")|null" }
    } else if tyIsNulI32BackedListInner(t.nInner) {
      // The nullable i32-BACKED list (`boolean[] | null`, `i32[] | null`, a litunion
      // `K0[] | null` — kind 15): the shared i32-list wrapper made nullable
      // (`(ref null $lTypeIdx)`). Rendered NON-spaced (`boolean[]|null`) so
      // `nullablePartOf` recognizes it; `synthRetAnnots` pins the lambda's `fnRet` to it
      // and the annotated nullable-list return machinery (`retNulListFlag`) lowers the
      // body — the lambda's `$fnsig` result keys `>o`, matching the value call's
      // `annRetKind`. The distinct-backing leaves (`i64[] | null`, …) are NOT rendered
      // (outside the value-call ABI — they stay loud rejects).
      return tyToEmitName(t.nInner) + "|null"
    } else if tyToStr(t.nInner) == "string" {
      return "string|null"
    } else if tyToStr(t.nInner) == "boolean" {
      // The boolean niche (`boolean | null`): the i32 sentinel rep (2 = null). Pinned by
      // `synthRetAnnots` (`nullablePartOf` non-empty) so `emitReturnValue`'s `tyIsNulBool`
      // arm niches a `return null` / `return <bool>`, matching the annotated form.
      return "boolean|null"
    }
  }
  ""
}

// The emitter-format NAME of an inferred NULLABLE-LITUNION return `er` (`() => K0 | null`): a
// `TyNullable` (or a `TyUnion` with a `null` atom) whose non-null part is a LITERAL union. The
// emitter niches it as the i32 atom with `-1` = null (`nodeTyIsNulLitUnion` → `retNulLitUnion`),
// so the pin (`synthRetAnnots`, via `nullablePartOf` non-empty) routes the anonymous lambda
// through the SAME sound rep the annotated `: () => K | null` return already lowers. Renders the
// litunion by its ALIAS (`K0|null`); an inline `("a"|"b")|null` litunion has no alias and stays
// "" (a clean reject — the fuzzer's shapes alias the union). "" for any non-nullable-litunion.
function nulLitUnionRetName(er: i32) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if t is TyNullable {
    const alias = litUnionAliasNameOfTy(t.nInner)
    if alias != "" { return alias + "|null" }
  }
  ""
}

// The emitter-format NAME of an inferred ELEMENT-NULLABLE list return `er` — `(f64|null)[]`,
// `(i32|null)[]`, `(i64|null)[]`, `(f32|null)[]`: a `TyArray` whose element is a `TyNullable`
// over a numeric scalar. Its elements are the value-union `{tag, payload}` boxes (element kind
// 2, the SAME rep the annotated `(f64|null)[]` return uses), so the emitter pins a lambda to it
// (`synthRetAnnots`) and routes through that existing sound path. The parser renders the union
// with NO spaces (`f64|null`), matching `parenUnionArrElemName` / `isValueUnionName`. "" unless
// `er` is such an array (a struct / string / boolean element uses a distinct or absent rep).
function nulElemListRetName(er: i32) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if t is TyArray {
    const et = T.tys[t.aElem]
    if et is TyNullable {
      const inner = tyToStr(et.nInner)
      if inner == "f64" || inner == "i32" || inner == "i64" || inner == "f32" {
        return "(" + inner + "|null)[]"
      }
      // The NICHE leaves: `(boolean|null)[]` (i32 sentinel-2 list), `(string|null)[]`
      // (string-ref list with `ref.null` elements), `(K|null)[]` (i32 atom list with the
      // `-1` sentinel, rendered by its ALIAS). Each rides an existing non-box list rep the
      // annotated return already lowers; the pin routes the anonymous lambda through it.
      if inner == "boolean" || inner == "string" {
        return "(" + inner + "|null)[]"
      }
      const alias = litUnionAliasNameOfTy(et.nInner)
      if alias != "" { return "(" + alias + "|null)[]" }
    }
  }
  ""
}

// The emitter-format NAME of a NULLABLE-CLOSURE-element list return `er` —
// `(((i32)=>K0)|null)[]`, `((()=>i64)|null)[]`: a `TyArray` whose element is a `TyNullable`
// over a function type. Its elements are the kind-5 NICHE over the shared closure
// fat-pointer (`(ref null $cloStruct)`, the `rlElemNullable` bit — the SAME rep the
// annotated spelling lowers), rendered through `nullableRetName`'s TyFunc arm so a litunion
// RESULT keeps its ALIAS (`K0`, the i32-atom token) and the whole name byte-matches the
// parser's canonical annotation. `synthRetAnnots` pins a lambda's `fnRet` to it (its
// `parenUnionArrElemName` arm) so an all-`null` body literal (`() => ([null])`) builds
// under the RETURN-position kind-5 seed and the pinned TypeRef collects the ref-list slot
// + the element's `$fnsig` — the path the annotated named-function form already lowers.
// "" otherwise.
function nulClosureElemListRetName(er: i32) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if t is TyArray {
    if t.aElem < 0 { return "" }
    const et = T.tys[t.aElem]
    if et is TyNullable {
      const it = T.tys[et.nInner]
      if it is TyFunc {
        const en = nullableRetName(t.aElem, gRootStmts)
        if en != "" { return "(" + en + ")[]" }
      }
    }
  }
  ""
}

// The emitter-format NAME of a DISTINCT-BACKING SCALAR-LEAF list return `er` — `i64[]`,
// `f64[]`, `f32[]`: a `TyArray` whose element is one of the scalar leaves with its OWN list
// backing. The name is in `isScalarListRetName`'s recordable set, and `synthRetAnnots` pins a
// lambda's `fnRet` to it so the body literal builds the leaf's wrapper and the value-call
// index read finds its list types collected — the SAME sound path the annotated
// named-function return already lowers. An `i32[]`/`boolean[]`/`string[]`/litunion `K[]`
// element is EXCLUDED: those self-classify identically to the annotation (a shared backing),
// so no adoption is ever needed there. "" otherwise.
function scalarLeafListRetName(er: i32) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if t is TyArray {
    if t.aElem < 0 { return "" }
    const et = T.tys[t.aElem]
    if et is TyPrim {
      const pn = et.primName
      if pn == "i64" || pn == "f64" || pn == "f32" { return pn + "[]" }
    }
  }
  ""
}

// The emitter-format NAME of a LITUNION-ALIAS-element list return `er` — `K0[]`: the
// adoption gate + recorded name for a member-literal-bodied lambda
// (`(i32) => K0[] = (q0) => (["4664"])`). `synthRetAnnots` pins the lambda's `fnRet` to
// it so the body literal builds the i32 ATOM list under the annotated return's threading
// (un-pinned, the member literals self-classify a STRING list into the i32-list functype
// result — invalid wasm); the named-function spelling (`mk(q0: i32): K0[]`) lowers this
// already. An alias-less INLINE litunion element declines ("" — no pinnable name).
function litUnionElemListRetName(er: i32) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if t is TyArray {
    if t.aElem < 0 { return "" }
    if tyIsLitUnion(t.aElem) {
      const an = litUnionAliasNameOfTy(t.aElem)
      if an != "" { return an + "[]" }
    }
  }
  ""
}

// The emitter-format NAME of a STRUCT-ELEMENT list return `er` (`{f: f32}[]`,
// `{a: f32, f: K0, z: i64}[]`) whose element fields are all PLAINLY LOWERABLE (a scalar /
// string / boolean prim, or a litunion alias) — the element shapes the named-function
// spelling (`mk(q0: i32): {f: f32}[]`) already round-trips through the value-call ABI, so a
// lambda may adopt them. A map / union / nullable / list / closure / nested-struct field is
// NOT this (those composition seams stay loud rejects). "" otherwise.
function structElemListRetName(er: i32) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if t is TyArray {
    if t.aElem < 0 { return "" }
    const et = T.tys[t.aElem]
    if et is TyObj {
      if !structElemFieldsPlain(t.aElem, 4) { return "" }
      return tyToEmitName(er)
    }
  }
  ""
}

// The CANONICAL emitter NAME for a PLAIN struct inferred return (`{f: f32}`) whose
// fields all pass `structElemFieldsPlain` — the bare-struct sibling of
// `structElemListRetName`, feeding the recorder's `spfNm` canon record so
// `synthRetAnnots`' whole-span-shape arm pins the lambda.
function structPlainRetName(er: i32) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if !(t is TyObj) { return "" }
  if !structElemFieldsPlain(er, 4) { return "" }
  tyToEmitName(er)
}

// The field gate of `structElemListRetName`: every field a scalar / string / boolean
// prim, a litunion alias, or (recursively) a NESTED plain struct. The nested-struct
// admission is load-bearing: an UN-pinned lambda returning a list of such structs
// self-resolves each element literal by field-name set, and a program with
// same-fieldset TWIN rows in scope matched the WRONG row and boxed the element as a
// union-box list — INVALID-WASM (fuzz sweep3 multiobs leg, seed 369283890
// case_00290). The named-fn spelling lowers nested-struct fields already (code 15).
// Map / union / nullable / list / closure fields stay declined (their composition
// seams keep the loud rejects).
function structElemFieldsPlain(objTy: i32, depth: i32): boolean {
  if depth <= 0 { return false }
  const et = T.tys[objTy]
  if !(et is TyObj) { return false }
  let i = 0
  while i < et.objFieldTypes.length {
    const fty = et.objFieldTypes[i]
    if fty < 0 { return false }
    const ft = T.tys[fty]
    let ok = false
    if ft is TyPrim { ok = true }
    if tyIsLitUnion(fty) { ok = true }
    if ft is TyObj {
      if structElemFieldsPlain(fty, depth - 1) { ok = true }
    }
    if !ok { return false }
    i = i + 1
  }
  true
}

// The emitter-format NAME of a MAP-ELEMENT list return `er` — `{[string]: f32}[]`: a
// `TyArray` whose element is a string-keyed map. `synthRetAnnots` pins a lambda's `fnRet`
// to it so its `$fnsig` result keys the SAME kind-3 map-element ref-list slot the
// annotation-side value call resolves (the named-function spelling lowers this already);
// un-pinned, the literal-side element spelling diverges and the call finds no interned
// signature. A map value type the emitter cannot lower keeps rejecting loudly on the
// annotated path itself. "" otherwise.
function mapElemListRetName(er: i32) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if t is TyArray {
    if t.aElem < 0 { return "" }
    const et = T.tys[t.aElem]
    if et is TyMap { return tyToEmitName(er) }
  }
  ""
}

// The emitter-format NAME of an inferred ELEMENT-VALUE-UNION list return `er` — `(i64|boolean)[]`,
// `(i64|string)[]`, `(i32|f64)[]`: a `TyArray` whose element is a VALUE union the emitter boxes
// (`isValueUnionName`). Its elements are the value-union `{tag, payload}` boxes (element kind 2, the
// SAME rep the annotated `(i64|boolean)[]` return / named-function-value form lowers), so the emitter
// pins a lambda to it (`synthRetAnnots`) and routes through that existing sound path. `tyToEmitName`
// renders the parens-wrapped, space-free name `(i64|boolean)[]` matching `parenUnionArrElemName`. The
// value-union sibling of `nulElemListRetName` (which owns the `(scalar|null)[]` niche). "" otherwise.
function elemValueUnionListRetName(er: i32) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if t is TyArray {
    const en = tyToEmitName(t.aElem)
    if en != "" && isValueUnionName(en) { return tyToEmitName(er) }
  }
  ""
}

// The emitter-format NAME of an inferred ELEMENT-VARIANT-BOX-UNION list return `er` —
// `({a:boolean,f:boolean,z:i32}|i64)[]`, `(i32|{w:i32})[]`: a `TyArray` whose element is a
// union `variantBoxUnionRetName` renders (an inline-struct arm + scalar/string/litunion-alias
// siblings). Its elements are the `{tag, payload}` boxes (element kind 2 — the SAME rep the
// annotated return / named-function-VALUE spelling already lowers), so the emitter pins a
// lambda to it (`synthRetAnnots`) and routes through that existing sound path. The member
// render is `variantBoxUnionRetName`'s (a litunion arm keeps its ALIAS — `rlSlotByName`'s
// primary key), parens-wrapped to match `parenUnionArrElemName`. The variant-box sibling of
// `elemValueUnionListRetName`. "" otherwise.
function elemVariantBoxListRetName(er: i32) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if t is TyArray {
    if t.aElem < 0 { return "" }
    const en = variantBoxUnionRetName(t.aElem)
    if en != "" { return "(" + en + ")[]" }
  }
  ""
}

// The emitter-format NAME of a CLOSURE-ARM value union return `er` (`(()=>string)|i64`,
// `((i32)=>f64)|boolean`): a ≥2-member union mixing at least one FUNCTION-TYPE member with
// scalar prims. A closure member is the kind-11 REF atom (`valueAtomKind` — the fat-pointer
// rides the box's anyref value), rendered in the emitter's non-spaced, parens-grouped form
// (`nullableRetName`'s TyFunc render); the RESULT preserves a litunion ALIAS so the inner
// value call and interned inner `$fnsig` agree on the atom token. Gated through
// `isValueUnionName` (the same gate the annotated path uses), so the pin routes the
// anonymous lambda through the SAME sound box the annotated named-function-VALUE spelling
// already lowers. "" for any other shape (map / array / object members stay on their paths).
function cloArmValueUnionRetName(er: i32) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if t is TyUnion {
    const members = t.uMembers
    if members.length < 2 { return "" }
    let hasClo = false
    let name = ""
    let i = 0
    while i < members.length {
      const m = T.tys[members[i]]
      let mn = ""
      if m is TyFunc {
        let ips = ""
        const pts = m.fnParamTypes
        let pj = 0
        while pj < pts.length {
          const pn = tyToEmitName(pts[pj])
          if pn == "" { return "" }
          if pj > 0 { ips = ips + "," }
          ips = ips + pn
          pj = pj + 1
        }
        let irs = litUnionAliasNameOfTy(m.fnRet)
        if irs == "" { irs = tyToEmitName(m.fnRet) }
        if irs == "" { return "" }
        mn = "((" + ips + ")=>" + irs + ")"
        hasClo = true
      } else if m is TyPrim {
        mn = m.primName
      } else {
        return ""
      }
      if i > 0 { name = name + "|" }
      name = name + mn
      i = i + 1
    }
    if !hasClo { return "" }
    if isValueUnionName(name) { return name }
  }
  ""
}

// The emitter-format NAME of an inferred/contextual NESTED LIST return `er` with a
// SCALAR/STRING LEAF — `i64[][]`, `f64[][]`, `string[][]`, `f32[][]`, or a deeper
// recursion over those (`i64[][][]`): a `TyArray` whose element is itself a `TyArray`,
// bottoming out at a scalar/string/boolean prim. Pinning a lambda's `fnRet` to this
// (`synthRetAnnots`) makes the body literal build under the RETURN-position seed —
// `() => ([[100]])` against `() => i64[][]` builds i64 INNER lists (the leaf widens at
// the store), instead of the self-classified i32 default whose sig/wrapper diverge —
// and the `$fnsig` result keys the SAME reflist slot the annotation side resolves. An
// `i32[][]`/`boolean[][]` leaf is EXCLUDED: the self-classified build already agrees
// with the annotation there (one i32[] backing), so no pin is needed — recording it
// would only churn working programs. A struct/union/closure/map leaf is NOT this (the
// R6/R3/R1 composition seams stay loud). "" otherwise.
function nestedLeafListRetName(er: i32) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if t is TyArray {
    if t.aElem < 0 { return "" }
    const et = T.tys[t.aElem]
    if et is TyArray {
      if et.aElem < 0 { return "" }
      const lt = T.tys[et.aElem]
      if lt is TyPrim {
        const pn = lt.primName
        if pn == "i64" || pn == "f64" || pn == "f32" || pn == "string" {
          return tyToEmitName(er)
        }
        return ""
      }
      if lt is TyArray {
        // Deeper nesting: the leaf decides — recurse on the INNER array.
        if nestedLeafListRetName(t.aElem) != "" { return tyToEmitName(er) }
      }
    }
  }
  ""
}

// The emitter-format NAME of an inferred MAP-MEMBER-UNION return `er` (`{[string]:f32}|{w:i32}`):
// a ≥2-member union whose FIRST member is a MAP and whose every member is a map or object shape.
// `tyToEmitName` renders it in the emitter's non-spaced vocabulary, MAP-FIRST (so the name matches
// `nameIsMap`, the shape the emitter's `registerInlineUnion` map-member-union box path — #865/#868 —
// keys on). Pinning a lambda's `fnRet` to this (`synthRetAnnots`) routes the anonymous lambda through
// the SAME sound rep the annotated `: {[string]:f32}|{w:i32}` return lowers (verified: the annotated
// spelling interns + prints; the pin only removes the annotation). "" for a non-union, a map-SECOND
// union (the emitter's classifiers assume map-first — left a LOUD reject, never invalid wasm), or a
// union with a non-map/non-object member (an unrepresentable arm the box path rejects downstream).
function mapUnionRetName(er: i32) {
  if er < 0 { return "" }
  // A NULLABLE map-member union (`{[string]: boolean} | i32 | null`) normalizes to
  // TyNullable over the union — unwrap it for the member gate; the render keeps the
  // full `…|null` spelling (`tyToEmitName(er)`), which `synthRetAnnots`'s nullable
  // pin arm accepts and the annotated form already lowers. Un-recorded, the lambda's
  // `$fnsig` result keyed the raw scalar arm (`>i`) while the binding local held the
  // union box — INVALID-WASM at the call-result store (fuzz seed 103465585 d6).
  let uIx = er
  const tn = T.tys[er]
  if tn is TyNullable { uIx = tn.nInner }
  const t = T.tys[uIx]
  if t is TyUnion {
    const members = t.uMembers
    if members.length < 2 { return "" }
    // At least one MAP member, and every member a map, an object shape, or a
    // scalar/string prim (`{[string]: string} | boolean` — the prim rides the box
    // as its value atom, exactly as in the variant-box unions). A litunion /
    // array / closure / nullable member declines — those stay on their own paths.
    let hasMap = false
    let i = 0
    while i < members.length {
      const m = T.tys[members[i]]
      if m is TyMap {
        hasMap = true
      } else if !(m is TyObj) {
        if !(m is TyPrim) { return "" }
      }
      i = i + 1
    }
    if !hasMap { return "" }
    return tyToEmitName(er)
  }
  ""
}

// The emitter-format NAME of a REF-ARM value union `er` (`T[] | {w: i32}` — a ≥2-member
// union with at least one REF-ARRAY member and every member an object shape or an array
// of object shapes; repOf item (d)'s shape class). Members render NOMINALLY when a
// declared type matches (`nominalNameOfObj` — the emitter's narrow-atom compare is
// name-keyed, and the program's `is T[]` spelling is nominal), falling back to the
// structural `tyToEmitName` render for an anonymous arm (`{w:i32}`). The rendered name
// is registered by `collectU`'s inferred-return loop, pinned onto the lambda by
// `synthRetAnnots` (its `isUName` arm — same spelling), and returned to the emitter's
// union-binding resolution by `nodeUnionName` — ONE renderer, so all three byte-match.
// An ARRAY member whose element has no nominal name declines ("" — the #911
// declared-twin gate keeps anonymous-element reflists a loud reject; rendering them
// would only trade that reject for a deeper one). "" for any other shape (scalar /
// string / map / closure / null members stay on their existing paths).
function refArmUnionRetName(er: i32, stmts: i32[]) {
  if er < 0 { return "" }
  const t = T.tys[er]
  if t is TyUnion {
    const members = t.uMembers
    if members.length < 2 { return "" }
    // Structural pre-gate BEFORE any render (the #494 discipline): every member an
    // object or an array-of-object, at least one array.
    let hasList = false
    let gi = 0
    while gi < members.length {
      const m = T.tys[members[gi]]
      if m is TyArray {
        const et = T.tys[m.aElem]
        if !(et is TyObj) { return "" }
        hasList = true
      } else if !(m is TyObj) {
        return ""
      }
      gi = gi + 1
    }
    if !hasList { return "" }
    let name = ""
    let i = 0
    while i < members.length {
      const m = T.tys[members[i]]
      let mn = ""
      if m is TyArray {
        const en = nominalNameOfObj(m.aElem, stmts)
        if en == "" { return "" }
        mn = en + "[]"
      } else {
        mn = nominalNameOfObj(members[i], stmts)
        if mn == "" { mn = tyToEmitName(members[i]) }
        if mn == "" { return "" }
      }
      if i > 0 { name = name + "|" }
      name = name + mn
      i = i + 1
    }
    return name
  }
  ""
}

// The emitter-format NAME of a VARIANT-BOX union `er` with an INLINE-struct arm and a
// scalar/string sibling (`i32 | {w: i32}`, `{f: string} | {w: i32}`, `{f: i32} | f64`,
// `{a: i32, f: i32, z: f64} | boolean`): a ≥2-member union whose every member is an
// object shape or a scalar/string prim, with at least one object member. This is the
// closure-RESULT unlock for the R2 `$fnsig` seam: the annotated named-function spelling
// (`mk(x: i32): i32 | {w: i32}` bound to a `(i32) => i32 | {w: i32}` value) already
// interns `>u` and its value call round-trips, so pinning a lambda's `fnRet` to this
// name (`synthRetAnnots`'s `isUName` arm — the render is registered by `collectU`'s
// inferred-return loop) routes the anonymous lambda through the SAME sound box.
// `tyToEmitName` renders the emitter's non-spaced vocabulary, byte-matching the
// `registerInlineUnion` / `splitUnionAtoms` name shape. Declines ("") when:
//  · any member is a map / array / nullable (those shapes are owned by
//    `mapUnionRetName` / `refArmUnionRetName` / the nullable arms — or stay loud),
//  · a closure member appears WITHOUT a struct sibling (closure + scalar mixes are
//    `cloArmValueUnionRetName`'s), or a second closure member appears (one kind-11
//    ref atom per box — two closures would tag identically),
//  · any member is a literal type (`TyLit` — a litunion member renders softened to
//    `string`, divorcing the pinned name from the annotation's atom rep),
//  · any member renders "" (an unrepresentable leaf), or no object member exists
//    (a pure-scalar union is `valueUnionRetName`'s), or every member is a NOMINAL
//    object (`structUnionRetName` owns the nominal render — checked by the caller
//    running that arm first).
function variantBoxUnionRetName(er: i32) {
  if er < 0 { return "" }
  const t = T.tys[er]
  // A NULLABLE variant-box union (`{a,f,z} | i32 | null` — canon wraps the null into a
  // `TyNullable` over the 2+-member union): the box already carries a null member atom
  // (`valueAtomKind("null")`), so the rep IS the same `>u` box — render the inner union
  // and append the `|null` atom, which `registerInlineUnion`'s variant-box path admits
  // (a `null` atom rides the tag, no variant slot) and `annRetKind` keys `>u` for.
  if t is TyNullable {
    const inner = variantBoxUnionRetName(t.nInner)
    if inner != "" { return inner + "|null" }
    return ""
  }
  if t is TyUnion {
    const members = t.uMembers
    if members.length < 2 { return "" }
    // A litunion-ALIAS member's literals FLATTEN into sibling TyLit members
    // (`flattenVariantsInto`: `K0 | {w: i32} | f64` -> ["pd", "42", {w:i32}, f64]),
    // so no single member names the alias. Regroup: collect the str-lit members and
    // resolve them as ONE registered alias by exact member-set match, rendered at
    // the FIRST lit's position (preserving the annotation's member order so the
    // pinned name byte-matches the annotation spelling). No exact alias match (or a
    // non-str lit) declines the whole union, keeping the loud reject.
    const litTexts: string[] = []
    let i0 = 0
    while i0 < members.length {
      const m0 = T.tys[members[i0]]
      if m0 is TyLit {
        if m0.litKind != "str" { return "" }
        litTexts.push(m0.litText)
      }
      i0 = i0 + 1
    }
    let litAlias = ""
    if litTexts.length > 0 {
      litAlias = litUnionAliasOfLitTexts(litTexts)
      if litAlias == "" { return "" }
    }
    let hasComposite = litAlias != ""
    let hasClo = false
    let hasObj = false
    let name = ""
    let litDone = false
    let i = 0
    while i < members.length {
      const m = T.tys[members[i]]
      let mn = ""
      if m is TyLit {
        if litDone {
          i = i + 1
          continue
        }
        litDone = true
        mn = litAlias
      } else if m is TyFunc {
        // A CLOSURE arm beside a STRUCT arm (`(() => f32|null) | {w: i32}`): the closure
        // rides the box anyref as the kind-11 REF atom (`isVariantBoxUnion` admits it), and
        // the annotated spelling of such a union already lowers soundly — so render the
        // parenthesized functype atom, byte-matching the annotation's `((…)=>…)` member.
        // ONE closure arm at most (two would share the kind-11 tag — indiscriminable), and
        // the struct-sibling requirement below keeps closure + scalar/list mixes on their
        // existing owners (`cloArmValueUnionRetName`) / loud paths. Without this the outer
        // lambda of a `(i32) => (() => f32|null) | {w:i32}` value never adopted the union —
        // its `$fnsig` interned the raw-closure result while the value call cast to the
        // `>u` sig (INVALID-WASM; fuzz-nightly seed 556796311 d6).
        if hasClo { return "" }
        const cn = tyToEmitName(members[i])
        if cn == "" { return "" }
        mn = "(" + cn + ")"
        hasClo = true
        hasComposite = true
      } else {
        mn = vbUnionMemberName(members[i])
        if mn == "" { return "" }
        if m is TyObj { hasObj = true }
        if mn != "i32" && mn != "i64" && mn != "f64" && mn != "f32" {
          if mn != "boolean" && mn != "string" { hasComposite = true }
        }
      }
      if name != "" { name = name + "|" }
      name = name + mn
      i = i + 1
    }
    if hasClo && !hasObj { return "" }
    if !hasComposite { return "" }
    return name
  }
  ""
}

// One member's render for `variantBoxUnionRetName`: a scalar/string prim by name, a
// literal-union ALIAS by its alias (`K0` — the i32-atom rep; `tyToEmitName` would soften
// it to `string`, divorcing the pinned name from the annotation's atom member), and an
// object shape field-wise (each field a prim or a litunion alias). "" for anything else
// (map / array / closure / nullable / inline-litunion members stay on their own paths).
function vbUnionMemberName(mIx: i32): string {
  const alias = litUnionAliasNameOfTy(mIx)
  if alias != "" { return alias }
  const m = T.tys[mIx]
  if m is TyPrim { return m.primName }
  // A SCALAR-LEAF array member (`i64[] | boolean`, `i64[][] | boolean` — a value-atom
  // list or a nested scalar-leaf array): its rep is a plain wrapper ref riding the box
  // (the value-atom / kind-9 nested-list rule), and the annotated named-fn spelling of
  // such a union lowers fully (both arms round-trip, `is i64[][]` narrows) — so the
  // rendered name pins a contextual lambda through the same sound path. An
  // OBJECT-element array member stays declined (its arm-narrow registration and
  // element-literal widening are the deferred repOf seams).
  if m is TyArray {
    let leaf = m.aElem
    let vguard = 0
    let scalarLeaf = false
    while vguard < 8 {
      vguard = vguard + 1
      if leaf < 0 { break }
      const lt = T.tys[leaf]
      if lt is TyArray {
        leaf = lt.aElem
      } else {
        let leafPrim = leaf
        // A NULLABLE-scalar element leaf (`(i64 | null)[]` — the value-union-box
        // element list) admits too: the annotated named-fn spelling of a union
        // carrying such an arm lowers fully (both arms round-trip, the `!= null`
        // element narrow included), so the pin routes the lambda the same way.
        if lt is TyNullable { leafPrim = lt.nInner }
        const lp = T.tys[leafPrim]
        if lp is TyPrim {
          const pn = lp.primName
          if (
            pn == "i32" ||
            pn == "i64" ||
            pn == "f64" ||
            pn == "f32" ||
            pn == "boolean" ||
            pn == "string"
          ) {
            scalarLeaf = true
          }
        }
        break
      }
    }
    if scalarLeaf {
      const en = tyToEmitName(mIx)
      if en != "" { return en }
    }
    return ""
  }
  if m is TyObj {
    const names = m.objFieldNames
    const ftys = m.objFieldTypes
    let out = "{"
    let fi = 0
    while fi < names.length {
      let fs = litUnionAliasNameOfTy(ftys[fi])
      if fs == "" {
        const ft = T.tys[ftys[fi]]
        if ft is TyPrim {
          fs = ft.primName
        } else if ft is TyMap {
          // A MAP field (`{f: {[string]: string}} | boolean`): the annotated named-fn
          // spelling of a union carrying such an arm lowers fully (the arm narrow and
          // the `t.f[k]` read round-trip), so render the field canonically and pin the
          // lambda through the same sound path. Without it the pin declined, the
          // RETURN-position lambdas of an annotated closure-array literal emitted raw
          // arm-typed `$fnsig`s while the value call cast to the `>u` box sig — a
          // cast-failure TRAP (fuzz sweep2 multiobs seed 655720167 case_00209).
          fs = tyToEmitName(ftys[fi])
          if fs == "" { return "" }
        } else {
          return ""
        }
      }
      if fi > 0 { out = out + "," }
      out = out + names[fi] + ":" + fs
      fi = fi + 1
    }
    return out + "}"
  }
  ""
}

// True if node `ix`'s recorded type is a PURE literal union (every member a `TyLit` —
// an aliased or inline litunion): it reps as the i32 ATOM (alias) or the string ref
// (inline), NEVER the value-union box, so the emitter's union-box classifiers must not
// claim it. Gates `exprUnion`'s checker-typed Call fallback: without it a call whose
// result is a litunion (`const r = pick(ks)`, `pick(p: K[]): K`) classified as a box
// and the atom-valued store mismatched the ref cell.
export function nodeTyIsPureLitUnion(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyUnion {
    if t.uMembers.length < 2 { return false }
    let i = 0
    while i < t.uMembers.length {
      if !(T.tys[t.uMembers[i]] is TyLit) { return false }
      i = i + 1
    }
    return true
  }
  false
}

// True when at least one member of the union member list is NOT an object shape — the
// cheap NO-RENDER pre-gate for `nodeUnionName`'s variant-box fallback arm. A mixed
// union (`f64 | {w: i32}`, `K0 | boolean`) boxes value-union style and its narrowed
// read needs the NAME to unbox; a pure-object union (`{f: string} | {w: i32}`, the
// huge `Node`) narrows via the variant alone, so declining here keeps the costly
// member renders off that path.
function mixedVariantBoxGate(members: i32[]): boolean {
  let i = 0
  while i < members.length {
    if !(T.tys[members[i]] is TyObj) { return true }
    i = i + 1
  }
  false
}

// The public entry point: check the program rooted at node `rootIx`, returning
// the number of diagnostics raised (diagnostics also accumulate on `T.diags`).
// (The old PR #5 gap — a discarded/`let`-bound call return mis-lowering at module
// scale, which forced callers into expression position — is fixed and pinned by
// `tests/cases/statements/discarded-call-return.vl`; the discarded `checkNode`
// below exercises it in this very module.)
export function checkProgram(rootIx: i32) {
  const rootN0 = P.nodes[rootIx]
  if rootN0 is Program { gRootStmts = rootN0.progStmts }
  // Size the typed-IR table to the (now fully parsed) node arena, all holes (-1).
  nodeTyIx = []
  cFuncPinTyIx = -1
  cObjPinTyIx = -1
  let ntz = 0
  while ntz < P.nodes.length {
    nodeTyIx.push(-1)
    ntz = ntz + 1
  }
  checkNode(rootIx)
  // The global scope (depth 0) is never popped, so flush its un-annotated
  // empty-collection bindings here: any still-open hole is genuinely uninferable.
  flushUninferred(0)
  // Rewrite literal/intersection annotation names into the emitter's
  // vocabulary (membership was enforced above; the emitter needs only the
  // runtime representation). Names without those constructs are untouched.
  canonEmitTypeNames()
  // A20: record each un-annotated function's INFERRED concrete return name for the
  // emitter (never the AST, so `fmt` stays oblivious).
  let ei = 0
  while ei < topUnannotFns.length {
    const efn = P.nodes[topUnannotFns[ei]]
    if efn is FuncDecl {
      const eft = lookup(efn.fnName)
      if eft >= 0 {
        const eftt = T.tys[eft]
        if eftt is TyFunc {
          const er = eftt.fnRet
          // Skip GENERIC functions (a `self` marker or any un-annotated param is a
          // `TyVar` hole): their return is per-call-site, so the definition-time
          // inferred type is a placeholder that renders to a misleading name (e.g.
          // `sumsq(self)` → `string`). Only a fully concrete signature is elaborated.
          let generic = false
          const ert0 = T.tys[er]
          if ert0 is TyVar { generic = true }
          let gp = 0
          while gp < eftt.fnParamTypes.length {
            const pt = T.tys[eftt.fnParamTypes[gp]]
            if pt is TyVar { generic = true }
            gp = gp + 1
          }
          if !generic && er >= 0 && er != TY_VOID && er != TY_ERR {
            // Only SCALAR/STRING returns — names that unambiguously round-trip through
            // the emitter's classifier. A structural object / union / array name
            // (`{x: i32}`, `A | B`, `Tok[]`) can mis-classify, and the emitter's
            // expression-based fallback already handles those, so leave them be.
            const enm = tyToStr(er)
            if isClassifiableRetName(enm) {
              recordInferRet(efn.fnName, enm)
            } else {
              // A VALUE union/nullable inferred return (`i32 | string`, `i32 | null`)
              // lowers through the same `uBoxIdx` machinery as an annotation — export
              // its emitter-format name so `buildFnMap`/`registerValueUnionName`/the
              // return site pick it up.
              const un = valueUnionRetName(er)
              if un != "" {
                recordInferRet(efn.fnName, un)
              } else if structUnionRetName(er, gRootStmts) != "" {
                // A STRUCT-union (`Cat | Dog`) lowers un-annotated via the variant-boxed
                // rep — the SAME machinery as an annotated `: Cat | Dog`. Export its
                // nominal name so the emitter registers the union + classifies the
                // binding (`registerInlineUnion` / `unionNameOfExpr`).
                recordInferRet(efn.fnName, structUnionRetName(er, gRootStmts))
              } else {
                // A NICHE nullable (`boolean | null` / `string | null`) lowers via its
                // sentinel / `ref.null $array` rep, not the box, so `valueUnionRetName`
                // declines it. Export the canonical niche name (no spaces, matching the
                // emitter's classifier) so the return-site seeding / functype result
                // valtype pick it up. A non-niche nullable (struct ref) stays floored.
                const ert = T.tys[er]
                if ert is TyNullable {
                  const innerNm = tyToStr(ert.nInner)
                  if innerNm == "boolean" {
                    recordInferRet(efn.fnName, "boolean|null")
                  } else if innerNm == "string" {
                    recordInferRet(efn.fnName, "string|null")
                  }
                }
              }
            }
          }
        }
      }
    }
    ei = ei + 1
  }
  T.diags.length
}

// A20: the emitter reads this to classify an un-annotated function's return from its
// inferred TYPE name rather than re-deriving from the return expression.
// Record an inferred-return entry: push the parallel arrays AND the by-name map (first-wins).
// Every `inferRetFn`/`inferRetTy` push goes through here so the map stays in sync.
function recordInferRet(name: string, ty: string) {
  if !inferRetIdx.has(name) { inferRetIdx[name] = inferRetFn.length }
  inferRetFn.push(name)
  inferRetTy.push(ty)
  0
}

export function inferRetNameOf(name: string) {
  if inferRetIdx.has(name) {
    const i = inferRetIdx[name] ?? -1
    if i >= 0 { return inferRetTy[i] }
  }
  ""
}

// The inferred-return name of an ANONYMOUS lambda, keyed by its FuncDecl NODE INDEX (the
// emitter passes `fnStmts[i]`). Anonymous lambdas are recorded under a `#<nodeIx>` sentinel
// key (they have no real name); the emitter consults this when the name-keyed lookup misses.
export function inferRetNameByNode(nodeIx: i32) {
  return inferRetNameOf("#" + i32ToStr(nodeIx))
}

// Whether an inferred return TYPE name is one the emitter's A20 classifier carries directly
// (a scalar / string / simple list) — the set the inferred-return table records. Shared by
// the named-function recording loop and the anonymous-lambda recording in `checkFuncDeclNode`.
function isClassifiableRetName(nm: string) {
  return nm == "i32" ||
    nm == "i64" ||
    nm == "f32" ||
    nm == "f64" ||
    nm == "boolean" ||
    nm == "string" ||
    nm == "i32[]" ||
    nm == "string[]"
}

// A scalar-list inferred-return name the emitter's closure-result classifier carries
// (the `"f64list"`/`"i64list"`/`"f32list"` kinds) but which `isClassifiableRetName` deliberately omits
// (those array names must not reach the redundant-return lint). Recorded for an anonymous
// lambda so its `$fnsig` result resolves position-independently — the checker's per-node
// f32[] typing is unreliable (a float literal types f64), so the syntactic classifier alone
// can miss an f32-list lambda return.
function isScalarListRetName(nm: string) {
  return nm == "i64[]" || nm == "f32[]" || nm == "f64[]"
}

// Whether a rendered type name is a single object SHAPE (`{meow: i32}`) — `tyToStr` of a
// `TyObj`. The emitter resolves it to a concrete union variant (a collapsed `.map` callback
// return) via field-set match. A nullable `{…}?` / union `{…} | {…}` is NOT a single shape.
function isObjShapeName(nm: string) {
  if nm.length < 2 { return false }
  if nm[0] != '{' || nm[nm.length - 1] != '}' { return false }
  // Reject a brace that is actually part of a larger composite (`{…} | {…}`, `{…}?`): a
  // single shape has balanced braces only at the outer ends with no top-level `|`.
  let depth = 0
  let i = 0
  while i < nm.length {
    const c = nm[i]
    if c == '{' { depth = depth + 1 }
    else if c == '}' { depth = depth - 1 }
    else if c == '|' && depth == 0 { return false }
    i = i + 1
  }
  true
}

// Iteration over the inferred-return table (the emitter's `collectU` registers any
// VALUE-union names here so their box/value-box reps are interned even when an inferred
// return is the program's only value union). `inferRetTyAt` is the rendered type name.
export function inferRetCount() { inferRetFn.length }
export function inferRetTyAt(i: i32) { inferRetTy[i] }

// The emitter reads this to classify an un-annotated binding (`const x = if c then v
// else null`) from its inferred value-union TYPE name (keyed by LetDecl node index),
// rather than re-deriving it from the initializer expression. "" when the binding is
// not an inferred value union. Iteration mirrors the inferred-return table so the
// emitter's `collectU` interns every inferred binding union's box reps too.
export function inferLetNameOf(letIx: i32) {
  let i = 0
  while i < inferLetIx.length {
    if inferLetIx[i] == letIx { return inferLetTy[i] }
    i = i + 1
  }
  ""
}
export function inferLetCount() { inferLetIx.length }
export function inferLetIxAt(i: i32) { inferLetIx[i] }
// TYPED-IR FOUNDATION: the resolved type-arena index the checker recorded for AST node
// `ix`, or -1 if none (an emitter-synthesized node, or a node never checked). The emitter
// reads the `Ty` at this index (`T.tys[...]`) to lower the node by its checked type rather
// than re-deriving it syntactically.
export function nodeTyIxOf(ix: i32) {
  if ix >= 0 {
    if ix < nodeTyIx.length { return nodeTyIx[ix] }
  }
  -1
}
// EMIT-TIME typed-IR coverage (C1 endgame): the monomorphizer CLONES a generic instance's body,
// creating fresh annotation nodes whose type-param names are substituted to CONCRETE names — these
// nodes fall PAST the checker-sized `nodeTyIx` (so a structural classifier reads -1 and falls back to
// the name). Resolve the concrete substituted `name` and record it on the new node so the emitter's
// arena-reading classifiers cover monomorphized instances too. `name` is already concrete (no TyVar),
// so `nameToTy` resolves it under the empty type-param env. Idempotent; grows the flat table as needed.
// EMIT-TIME typed-IR coverage (C1 endgame): copy the type the checker already recorded on `srcNode`
// onto a SYNTHESIZED annotation node `destNode`. Used where the synthesis name is an emitter-internal
// form `nameToTy` can't resolve (an interned anonymous shape `#anonN`), but the source param/expr node
// carries the real arena type. Grows the flat table as needed.
export function recordNodeTyFrom(destNode: i32, srcNode: i32) {
  if destNode < 0 { return 0 }
  const ty = nodeTyIxOf(srcNode)
  while nodeTyIx.length <= destNode { nodeTyIx.push(-1) }
  nodeTyIx[destNode] = ty
  0
}
// The lazily-built placeholder `TyFunc` for closure pins — only its `is TyFunc`-ness is read (via
// `nodeTyIsFunc`); the real signature rides the `=>sigkey` NAME elsewhere. Reset per program.
function funcPinTyIx() {
  if cFuncPinTyIx < 0 {
    const ps: i32[] = []
    cFuncPinTyIx = mkFuncTy(ps, -1)
  }
  cFuncPinTyIx
}
// The lazily-built placeholder `TyObj` for interned anonymous shapes — only its `is TyObj`-ness is
// read (`nodeTyIsStruct`); the real layout rides the `#anonN` NAME (the emitter's `sNames` table).
function objPinTyIx() {
  if cObjPinTyIx < 0 {
    const ns: string[] = []
    const ts: i32[] = []
    cObjPinTyIx = mkObjTy(ns, ts)
  }
  cObjPinTyIx
}
export function recordClonedNodeTy(nodeIx: i32, name: string) {
  if nodeIx < 0 { return 0 }
  let ty = nameToTy(name)
  if ty < 0 {
    // A monomorphizer closure-pin `=>sigkey` (an emitter sig encoding `nameToTy` can't parse) IS a
    // function type — record a placeholder `TyFunc` so `nodeTyIsFunc` classifies the pin structurally.
    if name.length >= 2 && name[0] == '=' && name[1] == '>' {
      ty = funcPinTyIx()
    } else if (
      name.length >= 5 &&
      name[0] == '#' &&
      name[1] == 'a' &&
      name[2] == 'n' &&
      name[3] == 'o' &&
      name[4] == 'n'
    ) {
      // An interned anonymous-shape `#anonN` (`nameToTy` can't resolve the synthetic name) is a
      // struct-shaped object — a placeholder `TyObj` so `nodeTyIsStruct` classifies it structurally.
      ty = objPinTyIx()
    }
  }
  while nodeTyIx.length <= nodeIx { nodeTyIx.push(-1) }
  nodeTyIx[nodeIx] = ty
  0
}
// The primitive-type NAME the checker recorded for node `ix` — `T.tys[nodeTyIx[ix]]`'s
// `primName` when it resolved to a `TyPrim` (`i32`/`i64`/`f64`/`f32`/`boolean`/…), else "".
// A STRUCTURAL query over the `Ty` arena — the emitter's scalar classifiers read this
// instead of string-testing the parser's synthetic annotation name (`tyNameOf`), so a
// scalar rep is decided from the checked type, not a re-parsed name (C1).
export function nodeTyPrimName(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return "" }
  const t = T.tys[ty]
  if t is TyPrim { return t.primName }
  ""
}
// STRUCTURAL: node `ix`'s recorded type is a FUNCTION type (`TyFunc`). The emitter's closure
// classifier reads this instead of a depth-aware `=>` arrow test on the name — a `TyFunc` is a
// bare function value, while a func ARRAY (`((i32)=>i32)[]`) is a `TyArray` and a nullable
// closure (`((i32)=>i32)|null`) a `TyNullable`, so the structure excludes those for free (C1).
export function nodeTyIsFunc(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyFunc { return true }
  false
}
// STRUCTURAL: the wasm ELEMENT-REP name of the array type the checker recorded for node `ix`,
// normalized to the emitter's list-rep vocabulary — "i32" (an `i32[]`, a `boolean[]`, or a
// literal-union `K[]`: all share the i32 atom backing), "f64"/"f32"/"i64" (scalar-elem lists),
// "string" (a `string[]`), or "" when the node isn't a recorded array (or its element is a ref
// / nested list). The emitter's `ret*ArrFlag` classifiers read this instead of `nameIsX[]`
// string tests on the synthetic name (C1). Mirrors `nameIsI32Array`/`nameIsF64Array`/… exactly.
export function nodeTyArrayElemRepName(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return "" }
  const t = T.tys[ty]
  if t is TyArray {
    const e = t.aElem
    if e >= 0 {
      const et = T.tys[e]
      if et is TyPrim {
        if et.primName == "boolean" { return "i32" }
        return et.primName
      }
      // A `(boolean | null)[]` element — the boolean SENTINEL niche — shares the i32
      // backing (0/1, spare 2 = null), so its list reps as an i32 list. Only the
      // `null → 2` element coercion + sentinel read/print differ.
      if et is TyNullable {
        const en = T.tys[et.nInner]
        if en is TyPrim {
          if en.primName == "boolean" { return "i32" }
          // A `(string | null)[]` element — the string ref made nullable. A `string[]`
          // element is ALREADY `(ref null $aTypeIdx)` at the wasm level, so the nullable
          // element shares the EXACT strlist backing; only `null → ref.null` construct +
          // the element READ (kept `(ref null)`, narrowed) differ. Reps as a string list.
          if en.primName == "string" { return "string" }
        }
      }
      if tyIsLitUnion(e) { return "i32" }
      // A `(K | null)[]` element — the litunion atom NICHE — shares the i32 backing (member ids ≥ 0,
      // spare `-1` = null), so its list reps as an i32 list, exactly like the non-null `K[]` above.
      // Both the ADOPTED `TyNullable`-inner form and the INFERRED `"a" | null` expanded-union form
      // classify (`tyIsNullableLitUnion`). Only the `null → -1` element coercion + the sentinel read
      // differ. Without this the element rep fell through to "" and the list defaulted to a string ref
      // list, mismatching the i32 construct/read.
      if tyIsNullableLitUnion(e) { return "i32" }
    }
  }
  ""
}
// STRUCTURAL: the WIDENED scalar rep of node `ix`'s type — like `nodeTyPrimName`, but a string
// literal union (`"a"|"b"`) reports "string" (it widens one-way to `string`; at an annotation-rep
// site it classifies as string exactly as its canon-collapsed name does). "" for a non-prim /
// non-litunion. Lets the `string` classifier read the arena without misclassifying a litunion. C1.
export function nodeTyWidenedRepName(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return "" }
  const t = T.tys[ty]
  if t is TyPrim { return t.primName }
  if tyIsLitUnion(ty) { return "string" }
  ""
}
// STRUCTURAL: node `ix`'s type is `string | null` (kind 16 nullable raw-array ref) — a
// `TyNullable` whose inner is the `string` prim. A `K | null` litunion niche is NOT this (its
// inner is a `TyUnion`), matching `nullablePartOf(name) == "string"`. C1.
export function nodeTyIsNulString(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyNullable {
    const inner = T.tys[t.nInner]
    if inner is TyPrim { return inner.primName == "string" }
  }
  false
}
// STRUCTURAL: node `ix`'s type is `boolean | null` (the i32 sentinel-2 niche) — a
// `TyNullable` whose inner is the `boolean` prim. Lets `exprNulBool` recover the niche
// from the checker's recorded type for an expression whose syntactic form it can't trace
// (a `(boolean | null)[]` element read `p[i]`, an inferred `const t = p[i]`), so the
// `!= null` / `?? d` / print routes to the sentinel compare. Mirrors `nodeTyIsNulString`.
export function nodeTyIsNulBool(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyNullable {
    const inner = T.tys[t.nInner]
    if inner is TyPrim { return inner.primName == "boolean" }
  }
  false
}
// STRUCTURAL: node `ix`'s type is a nullable NUMERIC scalar (`i32 | null`, `i64 | null`,
// `f64 | null`, `f32 | null`) — a `TyNullable` whose inner numeric prim has no spare value to
// niche into, so the value reps as the value-union {tag, value} BOX (`repOfNullable`'s scalar
// arm). The niche nullables (`string | null`, `boolean | null`, litunion/struct/closure/list
// `| null`) are structurally excluded — they are NOT box values and must not classify union.
export function nodeTyIsNulScalarBox(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyNullable {
    const inner = T.tys[t.nInner]
    if inner is TyPrim {
      return (inner.primName == "i32" ||
        inner.primName == "i64" ||
        inner.primName == "f64" ||
        inner.primName == "f32")
    }
  }
  false
}
// STRUCTURAL: node `ix`'s type is `((…) => …) | null` (kind 19 nullable closure) — a `TyNullable`
// whose inner is a `TyFunc`. Mirrors `nameIsNulClosure`; the structure excludes a nullable
// non-closure for free. C1.
// STRUCTURAL: node `ix`'s type is `i32[] | null` / `boolean[] | null` (kind 15, nullable i32-list) —
// a `TyNullable` whose inner is an array of the `i32`/`boolean` prim (both i32-repped). A litunion
// array is EXCLUDED, matching `nameIsNulI32List` (which tests `"i32[]"`/`"boolean[]"` only). C1.
export function nodeTyIsNulI32List(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyNullable {
    const it = T.tys[t.nInner]
    if it is TyArray {
      const e = it.aElem
      if e >= 0 {
        const et = T.tys[e]
        if et is TyPrim {
          return et.primName == "i32" || et.primName == "boolean"
        }
        // A literal-union element (`K[] | null`, `("a"|"b")[] | null`) — its atoms are
        // interned i32 ids, sharing the i32-list backing/rep exactly like `i32[]` (the arena
        // dual of `nameIsI32Array`'s litunion arm). A scalar-elem / ref-elem list is not this.
        if tyIsLitUnion(e) { return true }
        // A NICHE-nullable i32-backed element (`(K | null)[] | null`, `(boolean | null)[] |
        // null`): the element's null rides IN the i32 (`-1` / 2 sentinel), so the list is the
        // SAME i32 backing and the outer `| null` is the same `(ref null $lTypeIdx)` niche —
        // the arena dual of `nameIsI32Array`'s nul-litunion/nul-boolean arms.
        if tyIsNullableLitUnion(e) { return true }
        if et is TyNullable {
          const ei = T.tys[et.nInner]
          if ei is TyPrim { return ei.primName == "boolean" }
        }
      }
    }
  }
  false
}
// STRUCTURAL: node `ix`'s type is an ARRAY OF FUNCTIONS (`((i32)=>i32)[]`) — a `TyArray` whose
// element is a `TyFunc` (a closure-element ref list, kind 5). Mirrors `nameIsClosureArray`. C1.
export function nodeTyIsClosureArray(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyArray {
    const e = t.aElem
    if e >= 0 {
      const et = T.tys[e]
      if et is TyFunc { return true }
    }
  }
  false
}
// Linear membership over a small nominal-index set (a handful of struct/variant decls per program).
function cTyIxListHas(xs: i32[], v: i32) {
  let i = 0
  while i < xs.length {
    if xs[i] == v { return true }
    i = i + 1
  }
  false
}
// STRUCTURAL (C1): node `ix`'s recorded type IS a declared struct and NOT a union-variant member —
// the nominal analogue of the emitter's `isSName(tyNameOf(ix))`, read from the checker's arena-index
// sets instead of an O(nodes) `nameIsStructDecl` AST scan. Under-approximates (a struct not covered by
// `nodeTyIx`, or a UnionDecl struct-alias, reads false) so callers keep the name test as the fallback.
export function nodeTyIsStruct(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  if cTyIxListHas(cVariantMemberTyIxs, ty) { return false }
  if cTyIxListHas(cStructTyIxs, ty) { return true }
  const t = T.tys[ty]
  if t is TyObj { return true }
  if t is TyUnion {
    // A struct-alias union — a canonicalized `{a} & {b}` object intersection wraps its single merged
    // object shape in a one-member union; the emitter interns it as a struct (`isSName`), so match it.
    if t.uMembers.length == 1 {
      const m = T.tys[t.uMembers[0]]
      if m is TyObj { return true }
    }
  }
  false
}
// STRUCTURAL (C1): node `ix`'s recorded type IS an OBJECT union-variant member — the nominal analogue
// of `variantIndexOf(tyNameOf(ix)) >= 0`, read from the checker's variant-member arena-index set. The
// `is TyObj` guard excludes a TRANSPARENT single-member PRIMITIVE alias (`type Id = i32`, a one-member
// union whose member `i32` lands in the set but denotes the scalar, not a variant box). Confirms only.
export function nodeTyIsVariant(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  if !cTyIxListHas(cVariantMemberTyIxs, ty) { return false }
  const t = T.tys[ty]
  if t is TyObj { return true }
  false
}
// STRUCTURAL (C1): node `ix`'s recorded type is a NULLABLE declared struct (`S | null`) — a
// `TyNullable` whose inner is a declared struct (never a variant member, never `string | null`,
// which its `TyPrim` inner already excludes). The nominal analogue of `retNulRefFlag`'s name path.
export function nodeTyIsNulStruct(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyNullable {
    const inner = t.nInner
    if inner < 0 { return false }
    if cTyIxListHas(cVariantMemberTyIxs, inner) { return false }
    if cTyIxListHas(cStructTyIxs, inner) { return true }
    const it = T.tys[inner]
    if it is TyObj { return true }
    return false
  }
  false
}
// STRUCTURAL (C1): node `ix`'s recorded type is an ARRAY of a declared struct (`S[]`) — the clean
// base case of the emitter's recursive `nameIsRefArray`. Confirms ONLY the plain struct-element list
// (element in `cStructTyIxs`, not a variant member); nested / union / value-union / closure / nullable
// ref arrays fall to the name path. So a caller stays byte-identical (confirm-only + name fallback).
export function nodeTyIsStructArray(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyArray {
    const e = t.aElem
    if e < 0 { return false }
    if cTyIxListHas(cVariantMemberTyIxs, e) { return false }
    if cTyIxListHas(cStructTyIxs, e) { return true }
    const et = T.tys[e]
    if et is TyObj { return true }
    return false
  }
  false
}
// STRUCTURAL (C1): node `ix`'s recorded type is a DECLARED value-union alias box (`type T = A | B`) —
// the nominal analogue of the emitter's `isUName`. Confirms only a declared union (`cUnionTyIxs`) with
// 2+ members that is NOT a string litunion (`tyIsLitUnion`, which boxes as an i32 atom, not a union) —
// so a single-member struct-alias union and a litunion both fall to the name path.
// STRUCTURAL (C1): node `ix`'s type is a DECLARED litunion ALIAS (`type K = "a" | "b"`) — its arena
// index is a registered union alias (`cUnionTyIxs`) that is a litunion. Matches `nameIsLitUnionType` at
// emit time: `canonEmitTypeNames` softens an INLINE `"a" | "b"` annotation to `string` (string rep), but
// an alias keeps its name (atom rep), so only aliases classify as litunions here.
// STRUCTURAL (C1): node `ix`'s type is a nullable litunion (`K | null` / `"a" | "b" | null`) — a
// `TyNullable` whose inner is a litunion. Matches `nameIsNulLitUnion`: `canonEmitTypeNames` PRESERVES a
// nullable litunion's members (`nulLitUnionPreserve`), so BOTH inline and aliased forms classify here.
export function nodeTyIsNulLitUnion(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyNullable { return tyIsLitUnion(t.nInner) }
  false
}

// The declared ALIAS NAME of litunion TYPE index `ty` (`type K = "a" | "b"` → "K"), or "" when
// `ty` is not a registered litunion alias. Reverse of `cUserTypes` via the parallel
// `cUnionTyIxs`/`cUnionNames` arrays — used to pin an anonymous lambda's adopted litunion return
// as its alias (the alias reps as an i32 atom; the inline member spelling would rep as a string).
export function litUnionAliasNameOfTy(ty: i32) {
  if ty < 0 { return "" }
  if !tyIsLitUnion(ty) { return "" }
  let i = 0
  while i < cUnionTyIxs.length {
    if cUnionTyIxs[i] == ty { return cUnionNames[i] }
    i = i + 1
  }
  // STRUCTURAL fallback: an annotation position may REBUILD the alias's member union
  // at a fresh arena index, so the index compare misses and the member was
  // unnameable. An all-str-lit TyUnion in the arena is alias-derived
  // (`canonEmitTypeNames` softens INLINE litunion spellings to `string` — string
  // rep, never a lit-member TyUnion), so matching a registered litunion alias by
  // member-literal SET is exact, not a guess.
  const tu = T.tys[ty]
  if tu is TyUnion {
    const texts: string[] = []
    let m0 = 0
    while m0 < tu.uMembers.length {
      const mt = T.tys[tu.uMembers[m0]]
      if mt is TyLit { texts.push(mt.litText) }
      m0 = m0 + 1
    }
    return litUnionAliasOfLitTexts(texts)
  }
  ""
}

// The registered litunion ALIAS whose member-literal set is EXACTLY `texts` (`["pd",
// "42"]` -> "K0"), or "" — shared by the structural fallback above and the
// flattened-member regroup in `variantBoxUnionRetName`.
export function litUnionAliasOfLitTexts(texts: string[]): string {
  if texts.length == 0 { return "" }
  let a = 0
  while a < cUnionTyIxs.length {
    if tyIsLitUnion(cUnionTyIxs[a]) {
      const rt = T.tys[cUnionTyIxs[a]]
      if rt is TyUnion {
        if rt.uMembers.length == texts.length {
          let all = true
          let m = 0
          while m < texts.length {
            let found = false
            let r = 0
            while r < rt.uMembers.length {
              const rm = T.tys[rt.uMembers[r]]
              if rm is TyLit {
                if rm.litText == texts[m] { found = true }
              }
              r = r + 1
            }
            if !found { all = false }
            m = m + 1
          }
          if all { return cUnionNames[a] }
        }
      }
    }
    a = a + 1
  }
  ""
}
export function nodeTyIsLitUnionAlias(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  if !cTyIxListHas(cUnionTyIxs, ty) { return false }
  tyIsLitUnion(ty)
}
export function nodeTyIsUnionAlias(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  // A value/struct union box (`i32 | string`, `Cat | Dog`) — inline OR declared; the emitter registers
  // both in `unNames` (`isUName`). Excluded: a nullable niche (a `TyNullable`, not a `TyUnion`), and a
  // LITERAL union — string OR numeric (`0 | 1 | 2` canon-names `i32`), whose members are all `TyLit`
  // and which reps as an interned atom, not a `{tag, value}` box. A struct-alias is single-member.
  if isValueUnionBox(ty) { return true }
  // A SAME-SHAPE union (`A | B` with A, B structurally IDENTICAL) collapses to a single `TyObj` in the
  // arena — structural equality dedups the members — losing its union-ness, though the emitter keeps the
  // union box for tag discrimination (`isUName`). The arena can't represent this, so recover it locally
  // from the annotation node: a `TypeRef` whose name has a TOP-LEVEL `|` yet resolved to a struct.
  if t is TyObj {
    const nd = P.nodes[ix]
    if nd is TypeRef {
      const parts: string[] = []
      splitTypeName(nd.tyName, '|', parts)
      if parts.length >= 2 { return true }
    }
  }
  if t is TyNullable {
    const inner = t.nInner
    if inner >= 0 {
      const it = T.tys[inner]
      if it is TyPrim {
        const pn = it.primName
        if pn == "i32" || pn == "f64" || pn == "i64" || pn == "f32" {
          return true
        }
      }
      if isValueUnionBox(inner) { return true }
    }
  }
  false
}
// A `{tag, value}` value/struct union box: `TyUnion`, 2+ members, NOT a pure literal union.
function isValueUnionBox(tyix: i32) {
  if tyix < 0 { return false }
  const t = T.tys[tyix]
  if t is TyUnion {
    if t.uMembers.length < 2 { return false }
    // A HOMOGENEOUS literal union (all members `TyLit` of the SAME `litKind`) is an interned atom,
    // NOT a box: all-`str` (`"a"|"b"`) or all-numeric (`0|1|2`). A MIXED-kind literal union (`"x"|7`,
    // a string lit + a numeric lit) can't share one atom rep, so it boxes as a value union.
    let allSameLit = true
    let litKind = ""
    let i = 0
    while i < t.uMembers.length {
      const m = T.tys[t.uMembers[i]]
      if m is TyLit {
        if litKind == "" { litKind = m.litKind }
        else if litKind != m.litKind { allSameLit = false }
      } else {
        allSameLit = false
      }
      i = i + 1
    }
    return !allSameLit
  }
  false
}
export function nodeTyIsNulClosure(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyNullable {
    const inner = T.tys[t.nInner]
    if inner is TyFunc { return true }
  }
  false
}
// ── Arena-level (Ty-index-keyed) nominal queries ──────────────────────────────
// The emitter's `repOf` descriptor derivation (`emit_rep.vl`) classifies TYPES —
// `Ty`-arena indices — where the `nodeTy*` twins above classify a NODE's recorded
// type. The purely structural arms live in `emit_rep`; these expose only the
// checker-PRIVATE nominal-identity metadata (the sidecar index sets) that a
// structural walk cannot re-derive (the arena's `TyObj`/`TyUnion` carry no name).
export function tyIxIsStructDecl(ty: i32) {
  if ty < 0 { return false }
  cTyIxListHas(cStructTyIxs, ty)
}
export function tyIxIsVariantMember(ty: i32) {
  if ty < 0 { return false }
  cTyIxListHas(cVariantMemberTyIxs, ty)
}
export function tyIxIsUnionAliasDecl(ty: i32) {
  if ty < 0 { return false }
  cTyIxListHas(cUnionTyIxs, ty)
}
// The declared litunion ALIAS a litunion arena index denotes, or -1: the index
// itself when it IS a declared alias (`type K = "a" | "b"`), else the recorded
// source alias when it is a checker-minted COPY of one (alias PROVENANCE — see
// `cLitUnionCopyTyIxs`), else -1 (a genuinely-inline litunion, whose rep stays
// position-decided by the canon pass: string bare, atom under `| null`). The
// rep layers read this instead of the copy-blind `tyIxIsUnionAliasDecl` where
// the question is "does this index carry a declared alias's atom identity".
export function tyLitUnionAliasIx(ty: i32): i32 {
  if ty < 0 { return -1 }
  if !tyIsLitUnion(ty) { return -1 }
  if cTyIxListHas(cUnionTyIxs, ty) { return ty }
  let i = 0
  while i < cLitUnionCopyTyIxs.length {
    if cLitUnionCopyTyIxs[i] == ty { return cLitUnionCopyAliasIxs[i] }
    i = i + 1
  }
  -1
}
// A `{tag, value}` value/struct union BOX at arena level — `isValueUnionBox`,
// exposed under the `ty*` naming for the emitter's descriptor arms.
export function tyIsValueUnionBox(ty: i32) { isValueUnionBox(ty) }
// TYPED-IR query: the element type NAME of the array the checker recorded for node `ix`
// (e.g. "f64", "string", an inline `{v: i32}` shape), or "" when `ix` has no recorded
// concrete array type. A GENERIC element (a `TyVar`) returns "" — a generic build's
// annotation is substituted by the monomorphizer per instance, NOT synthesized here (a
// shared instance body would otherwise stamp a bogus `T[]`). The emitter synthesizes an
// `<elem>[]` annotation from this so an un-annotated empty `[]` reuses the annotated path.
export function nodeArrayElemName(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return "" }
  const t = T.tys[ty]
  if t is TyArray {
    if t.aElem >= 0 {
      const el = T.tys[t.aElem]
      if el is TyVar { return "" }
      if el is TyPrim { return tyToStr(t.aElem) }
      // A STRUCT element renders its inline shape name (`{v: i32}`), which
      // `structIndexOfTypeName` matches to the interned struct by field-set.
      if el is TyObj { return tyToStr(t.aElem) }
      // A FUNCTION element (`((i32,i32)=>i32)[]`) renders the closure-element table key — the
      // emit-form function type WRAPPED in grouping parens, matching `refArrElemName`'s form for an
      // annotated closure array — so an UN-annotated literal of function values (`[add, mul]`)
      // recovers the same kind-5 slot. "" when a param/return is generic (a `TyVar` → unpinned).
      if el is TyFunc {
        const fn = tyToEmitName(t.aElem)
        if fn == "" { return "" }
        return "(" + fn + ")"
      }
      // A NULLABLE-CLOSURE element (`(((i32) => K0) | null)[]` — the kind-5 niche over the
      // shared closure fat-pointer): renders the full `(<fn>)|null` table key via
      // `nullableRetName`'s nullable-closure arm — the SAME form `refArrElemName` yields for
      // the annotated spelling, with a litunion RESULT kept as its ALIAS (`K0`, the i32-atom
      // rep) — so a literal like `[() => 7, null]` typed only through a LAMBDA's contextual
      // result (no direct binding annotation) still interns/resolves the niche slot and the
      // element `$fnsig` key the annotation side derives.
      if el is TyNullable {
        const ni = T.tys[el.nInner]
        if ni is TyFunc {
          const stmts: i32[] = []
          return nullableRetName(t.aElem, stmts)
        }
      }
    }
  }
  ""
}
export function inferLetTyAt(i: i32) { inferLetTy[i] }

// The CANONICAL emit render of node `ix`'s recorded STRUCT type (`tyToEmitName` —
// spaceless, litunion-ALIAS preserving), or "" when the node's type is not a TyObj or
// has an unrepresentable leaf. The struct-resolution consumers (`structIndexOfExpr`'s
// closure-call fallback) try this BEFORE `nodeTyName`'s spaced `tyToStr` render: the
// spaced render FLATTENS an alias field (`{a: K0 | boolean}` spells its literal
// members), and the flattened field text classifies as NO field code —
// `structIndexOfTypeName`'s scan then matched the shape LENIENTLY onto the plain
// same-name-set twin row, so a boxed-field closure-call result read took the plain
// row's layout: INVALID-WASM (fuzz sweep3 declared leg, seed 128787380 case_00189).
// Scoped to the resolution site (not folded into `nodeTyName`) so the annotation-
// synthesis consumers keep the spaced spelling they were built against.
export function nodeTyCanonObjName(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return "" }
  const t = T.tys[ty]
  if t is TyObj { return tyToEmitName(ty) }
  ""
}

// TYPED-IR query: the rendered NAME of the scalar/string type the checker recorded for node
// `ix` (`"f64"`, `"string"`, `"i32"`, …), or "" when none / generic (a `TyVar`) / a composite
// type. The emitter reads this for an un-annotated callback PARAM (`xs.map((x) => …)`) to
// synthesize its annotation, so the param's valtype follows the contextually-inferred element
// instead of defaulting to i32. Only PRIM/string types are surfaced — a struct/array/union
// callback param is out of scope here (those route through their own per-rep paths).
export function nodeTyName(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return "" }
  const t = T.tys[ty]
  if t is TyPrim {
    if t.primName == "void" { return "" }
    return tyToStr(ty)
  }
  // A STRUCT type renders its inline shape (`{x: i32}`); the emitter's `synthParamAnnots`
  // resolves that to the declared struct's NOMINAL name (`structIndexOfTypeName` matches by
  // field-set), so an un-annotated struct-element callback param (`ps.map((p) => p.x)`) gets
  // the same `p: P` annotation the explicit form would.
  if t is TyObj { return tyToStr(ty) }
  // A FUNCTION type renders its closure-annotation name (`(i32) => i32`) so an un-annotated
  // closure VALUE from a call result (`const g = f(4)`) recovers a sig-keyable name.
  if t is TyFunc { return tyToEmitName(ty) }
  // A REF-LIST type renders its recursive emit name (`{v:i32}[]`, `((i32) => i32)[]`) so an
  // un-annotated ref-list callback param (`(S[]) => i32 = (xs) => …`) recovers a name
  // `synthParamAnnots` resolves to the nominal element (`S[]`). Without it the param fell through
  // to "" and defaulted to i32 — a missing-type silently lowered as the wrong type.
  if t is TyArray { return tyToEmitName(ty) }
  ""
}

// True if the node at `ix` has a recorded type that is a VALUE union (`Cat | Dog`) — a
// `TyUnion` with 2+ members. Lets the emitter's `synthParamAnnots` give an un-annotated
// union-element callback param (`xs.filter((a) => a is Cat)`) a union annotation, so its
// `is`-narrowing and closure `$fnsig` param token resolve. A nullable (`T | null`) is a
// `TyNullable`, not a `TyUnion`, so it is excluded here (its own slice).
export function nodeTyIsUnion(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyUnion { return t.uMembers.length >= 2 }
  false
}

// True if type-arena entry `ty` is a union whose members are ALL string-LITERAL types (`"a" | "b"`) — a
// "literal union", which the emitter lowers as an interned i32 ATOM (one id per distinct member string).
export function tyIsLitUnion(ty: i32) {
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyUnion {
    if t.uMembers.length < 1 { return false }
    let i = 0
    while i < t.uMembers.length {
      const m = T.tys[t.uMembers[i]]
      if m is TyLit {
        if m.litKind != "str" { return false }
      } else {
        return false
      }
      i = i + 1
    }
    return true
  }
  false
}

// True if the NAMED type `name` (a `type K = "a" | "b"` alias) is a literal union — the emitter's
// annotation-side query (the checker preserves the literal members even though the emit-side `udVariants`
// are widened to `"string"`).
export function nameIsLitUnionType(name: string) {
  if cUserTypes.has(name) {
    const ti = cUserTypes[name] ?? -1
    const r = tyIsLitUnion(ti)
    return r
  }
  // An INLINE (un-aliased) literal union — the synthetic annotation name `"a"|"b"` carries the
  // members directly (no `cUserTypes` entry). It is a literal union iff it has 2+ top-level members
  // and every one is a QUOTED string literal (`"…"`), matching `tyIsLitUnion` over the named alias.
  const inl = nameIsInlineLitUnion(name)
  inl
}

// True if the synthetic type name `name` is an INLINE literal union: 2+ top-level `|`-separated
// members, each a quoted string literal. A mixed member (`"a" | i32`, `"a" | null`) or a single
// literal fails — those are value unions / nullables / single-literal types, not atom unions.
function nameIsInlineLitUnion(name: string) {
  // Cheap O(1) reject before the allocating split: an inline literal-union name always begins with
  // a quoted member (`"a"|…`). This skips every ordinary name (`i32`, `string`, struct/union names,
  // map/array shapes) — the overwhelming majority of `nameIsLitUnionType` calls — without allocating.
  if name.length < 1 { return false }
  if name[0] != '"' { return false }
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  if atoms.length < 2 { return false }
  let i = 0
  while i < atoms.length {
    const a = atoms[i]
    if a.length < 2 { return false }
    if a[0] != '"' { return false }
    i = i + 1
  }
  true
}

// True if the program uses ANY literal-union type — a single `P.nodes` pass for the emitter to
// run ONCE, so its per-node atom detectors can early-out when no literal union exists. Every
// literal-union usage surfaces as a `TypeRef` annotation (a `type K = …` RHS, a `: K` / `: "a"|"b"`
// binding/param/return), so one TypeRef scan via `nameIsLitUnionType` covers named + inline.
export function anyLitUnionUsed() {
  let i = 0
  while i < P.nodes.length {
    const n = P.nodes[i]
    if n is TypeRef {
      if nodeTyIsLitUnion(i) { return true }
      // A `K | null` annotation USES the litunion K too — without this, a program whose ONLY litunion
      // mention is nullable (`K | null` everywhere, no bare `K`) leaves `gLitUnionUsed` at 0 and the
      // emitter's atom-widening (`exprIsLitAtom`) short-circuits, printing the raw id instead of the member.
      if nodeTyIsNulLitUnion(i) { return true }
    }
    // A litunion used ONLY as an ARRAY element (`K[]`, no bare `K` annotation anywhere) — or any
    // EXPRESSION the checker typed as a litunion (a `K[]` element read `xs[i]`, a `for k in xs` var) —
    // also counts. A direct Ty check over the recorded node type (not the annotation name, which for
    // `K[]` is not a bare litunion name). Without it `gLitUnionUsed` stays 0 and atom detection is off,
    // so `const sk = xs[i]` lowers as a `string` ref — the i32 atom into a `(ref $array)` cell.
    if nodeTyIsLitUnion(i) { return true }
    if nodeArrayElemIsLitUnion(i) { return true }
    i = i + 1
  }
  false
}

// True if node `ix` has a recorded ARRAY type whose ELEMENT is a literal union (`K[]`). The
// emitter seeds atom construction for such an array literal's elements (they lower as ids, not
// strings). A direct Ty check — no name round-trip (a rendered `"a" | "b"` would not re-parse).
export function nodeArrayElemIsLitUnion(ix: i32) {
  const pty = nodeArrayElemPeelTy(ix)
  if pty < 0 { return false }
  const t = T.tys[pty]
  if t is TyArray {
    const r = tyIsLitUnion(t.aElem)
    return r
  }
  false
}

// The recorded type of node `ix` with ONE nullable wrapper peeled — a NULLABLE-list
// receiver (`(K | null)[] | null`) indexed in its checker-proved non-null branch still
// RECORDS the nullable type on the receiver node, so the element probes below must see
// through the wrapper to classify the element. -1 (out-of-arena) when unrecorded.
function nodeArrayElemPeelTy(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return -1 }
  const t = T.tys[ty]
  if t is TyNullable { return t.nInner }
  ty
}

// True if node `ix` has a recorded ARRAY type whose ELEMENT is `boolean | null` (a
// `(boolean | null)[]` literal). The emitter seeds `pendingNulBool` for such a literal's
// elements so a `null` element lowers as the sentinel 2 (a `true`/`false` element rides
// its i32 0/1 untouched) — the list analogue of the scalar `boolean | null` niche.
export function nodeArrayElemIsNulBool(ix: i32) {
  const pty = nodeArrayElemPeelTy(ix)
  if pty < 0 { return false }
  const t = T.tys[pty]
  if t is TyArray {
    const e = t.aElem
    if e >= 0 {
      const et = T.tys[e]
      if et is TyNullable {
        const en = T.tys[et.nInner]
        if en is TyPrim { return en.primName == "boolean" }
      }
    }
  }
  false
}

// True if node `ix` has a recorded ARRAY type whose ELEMENT is `string | null` (a `(string | null)[]`).
// The read side of the string-ref niche list: the element is stored `(ref null $aTypeIdx)`, so an
// element read `p[i]` STAYS nullable (a `nulstr` the caller narrows with `!= null`) rather than
// recovering non-null the way a plain `string[]` element does. Mirrors `nodeArrayElemIsNulBool`.
export function nodeArrayElemIsNulStr(ix: i32) {
  const pty = nodeArrayElemPeelTy(ix)
  if pty < 0 { return false }
  const t = T.tys[pty]
  if t is TyArray {
    const e = t.aElem
    if e >= 0 {
      const et = T.tys[e]
      if et is TyNullable {
        const en = T.tys[et.nInner]
        if en is TyPrim { return en.primName == "string" }
      }
    }
  }
  false
}

// True if node `ix` has a recorded ARRAY type whose ELEMENT is `K | null` (a `(K | null)[]` — a
// literal union made nullable). The emitter seeds `pendingLitUnion` (member literals lower as their
// interned ids) AND `pendingNulLitUnion` (a `null` element lowers as the sentinel `-1`) for such a
// literal's elements — the atom-niche analogue of `nodeArrayElemIsNulBool`. Mirrors that probe with
// `tyIsLitUnion` on the nullable's inner instead of a `boolean` primitive test.
export function nodeArrayElemIsNulLitUnion(ix: i32) {
  const pty = nodeArrayElemPeelTy(ix)
  if pty < 0 { return false }
  const t = T.tys[pty]
  if t is TyArray { return tyIsNullableLitUnion(t.aElem) }
  false
}
// True if type `ty` is a NULLABLE literal union — either the two-part form `K | null` (a `TyNullable`
// whose inner is a litunion) OR the expanded member form `"a" | "b" | null` (a `TyUnion` with a null
// member and every OTHER member a quoted string literal). Matches `nameIsNulLitUnion`'s dual handling
// at the name level: a `(K | null)[]` literal's ADOPTED annotation gives the `TyNullable` form, while
// its INFERRED element type (`["a", null]` → the union of the elements' types) gives the expanded
// `TyUnion` form — both must classify as the atom niche so the literal takes the i32-list path.
export function tyIsNullableLitUnion(ty: i32): boolean {
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyNullable { return tyIsLitUnion(t.nInner) }
  if t is TyUnion {
    if t.uMembers.length < 2 { return false }
    let sawNull = false
    let sawLit = false
    let i = 0
    while i < t.uMembers.length {
      const m = T.tys[t.uMembers[i]]
      if m is TyPrim {
        if m.primName != "null" { return false }
        sawNull = true
      } else if m is TyLit {
        if m.litKind != "str" { return false }
        sawLit = true
      } else {
        return false
      }
      i = i + 1
    }
    return sawNull && sawLit
  }
  false
}
// The emitter's per-node query: node `ix` has a recorded literal-union type.
export function nodeTyIsLitUnion(ix: i32) {
  const r = tyIsLitUnion(nodeTyIxOf(ix))
  return r
}

// True if array-ELEMENT type `ty` is a NICHE-nullable scalar the emitter reps without a
// box — `K | null` (litunion atom, i32 sentinel `-1`), `boolean | null` (i32 sentinel 2),
// `string | null` (`(ref null $aTypeIdx)` element). Gates the ArrayLit context-adoption
// recording: a literal accepted by such an element target IS the niche list, and the
// recorded destination type is what the emitter's element probes key on.
function tyIsNicheNulScalarElem(ty: i32): boolean {
  if tyIsNullableLitUnion(ty) { return true }
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyNullable {
    const inn = T.tys[t.nInner]
    if inn is TyPrim {
      return inn.primName == "boolean" || inn.primName == "string"
    }
  }
  false
}

// True if node `ix`'s recorded type is a string-keyed MAP whose VALUE type is a literal
// union (`{[string]: K}`, `K = "a" | "b"`) — the atom-valued MONO map (each value is the
// interned atom id, a plain i32). The emitter's map store / `??`-default sites read this
// off the RECEIVER to seed the atom context, so a member literal lowers as its id, not a
// string ref.
export function nodeTyMapValIsLitUnion(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyMap { return tyIsLitUnion(t.mVal) }
  false
}

// True if node `ix`'s recorded type is a string-keyed MAP whose VALUE is a NULLABLE literal
// union (`{[string]: K | null}`): each value is the interned atom id with the `-1` null
// sentinel — still the MONO i32 map. The store/`??`-default sites read this to admit a bare
// `null` (lowered as `-1`) alongside the member literals.
export function nodeTyMapValIsNulLitUnion(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyMap { return tyIsNullableLitUnion(t.mVal) }
  false
}

// The member literal TEXTS (raw inner lexeme, no quotes) of the VALUE literal union of node
// `ix`'s recorded map type — the atom-map dual of `nodeLitUnionMemberTexts`. Empty if `ix`
// is not an atom-valued map. The emitter's `??`-default gate checks the default literal is
// a MEMBER (a non-member would mint a fresh atom id under a `string`-typed result).
export function nodeTyMapValLitUnionTexts(ix: i32) {
  const out: string[] = []
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return out }
  const t = T.tys[ty]
  if t is TyMap {
    if !tyIsLitUnion(t.mVal) && !tyIsNullableLitUnion(t.mVal) { return out }
    let mv = t.mVal
    const mvN = T.tys[mv]
    if mvN is TyNullable { mv = mvN.nInner }
    const v = T.tys[mv]
    if v is TyUnion {
      let i = 0
      while i < v.uMembers.length {
        const m = T.tys[v.uMembers[i]]
        if m is TyLit {
          if m.litKind == "str" { out.push(m.litText) }
        }
        i = i + 1
      }
    }
  }
  out
}

// The member literal TEXTS (raw inner lexeme, no quotes) of node `ix`'s literal-union type, in source
// order — used by the emitter to widen an atom to its member `string` (`print(k)` etc.). Empty if `ix`
// is not a literal union.
export function nodeLitUnionMemberTexts(ix: i32) {
  const out: string[] = []
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return out }
  const t = T.tys[ty]
  if t is TyUnion {
    let i = 0
    while i < t.uMembers.length {
      const m = T.tys[t.uMembers[i]]
      if m is TyLit {
        if m.litKind == "str" { out.push(m.litText) }
      }
      i = i + 1
    }
  }
  out
}

// True if node `ix` has a recorded OBJECT (struct) type — a cheap, NO-RENDER variant-tag check. Gates
// the emitter's `nodeTyName`-rendering struct fallback (`structIndexOfExpr`) so the costly `tyToStr`
// runs only on a confirmed struct receiver the syntactic cases missed (a struct-returning closure value
// call — `arr[i](x).field`), never on the hot path.
export function nodeTyIsObj(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  t is TyObj
}

// True if node `ix` has a recorded MAP type (`{[K]: V}`) — a cheap NO-RENDER variant-tag check, the
// map dual of `nodeTyIsObj`. Gates the emitter's map classifiers (`exprMap` / `mapShapeOfExpr`) so a
// map-returning closure VALUE call whose callee they miss (a closure local `v()`, an indexed closure
// `arr[i]()`) still routes through the map lowering, exactly as a named `fnRetMap` factory does.
export function nodeTyIsMap(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  t is TyMap
}

// The emitter-format VALUE type-name of node `ix`'s recorded map type (`string` for `{[string]: string}`,
// `f32` for `{[string]: f32}`), or "" if `ix` is not a map. RENDERS the value type (`tyToEmitName`), so
// the emitter calls it only as a map-SHAPE fallback (`mapShapeOfExpr`) for a map-returning closure value
// call — never on the hot path. The value name resolves to the map's mv slot via `mvSlotOfMapValNameOrMono`.
export function nodeTyMapValName(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return "" }
  const t = T.tys[ty]
  if t is TyMap { return tyToEmitName(t.mVal) }
  ""
}

// True if node `ix` has a recorded NULLABLE-STRUCT type (`P | null`) — a cheap NO-RENDER check (a
// `TyNullable` wrapping a `TyObj`). The nullable dual of `nodeTyIsObj`: gates the emitter's nullable
// consumer classifiers (`exprNullableStruct`) so a nullable-struct-returning closure value call whose
// callee they miss (an indexed closure-array element `arr[i](x)`) still classifies kind-9.
export function nodeTyIsNullableStruct(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyNullable {
    const it = T.tys[t.nInner]
    return it is TyObj
  }
  false
}

// True if node `ix` has a recorded `string | null` type — the niche-string (kind 16) dual of
// `nodeTyIsNullableStruct`. Gates `exprNullableString`'s fallback so a `string | null`-returning
// closure value call whose callee it misses (an indexed closure-array element) classifies kind-16.
// A nullable LITUNION (`K0 | null`) is EXCLUDED first: `tyToEmitName` renders each string-literal
// member as `string` (then dedups), so the render alone can't tell `K0 | null` from `string | null`
// — but the litunion niche reps as an i32 (atom id / `-1` sentinel), not a string ref, and claiming
// it kind-16 stored the callee's i32 result into a `(ref null $array)` local (INVALID-WASM).
export function nodeTyIsNullableString(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return false }
  const t = T.tys[ty]
  if t is TyNullable {
    if tyIsLitUnion(t.nInner) { return false }
    return tyToEmitName(t.nInner) == "string"
  }
  false
}

// The emitter-format shape NAME of a nullable-struct node `ix`'s INNER struct (`{x:i32}` for a
// `P | null`), or "" otherwise. RENDERS (`tyToEmitName`), so the emitter calls it only as a struct-index
// FALLBACK (`structIndexOfExpr`) for a nullable-returning closure value call — never on the hot path.
// The nullable sibling of `nodeTyName`, resolving to the inner struct's layout index via
// `structIndexOfTypeName`.
export function nodeNulStructInnerName(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return "" }
  const t = T.tys[ty]
  if t is TyNullable {
    const it = T.tys[t.nInner]
    if it is TyObj { return tyToEmitName(t.nInner) }
  }
  ""
}

// The emitter-format union NAME of node `ix` (a value union "i32|string" or a struct union "Cat|Dog"),
// or "" if its recorded type is not a 2+-member union. RENDERS the union (`tyToStr`, the #494-costly
// op), so the emitter calls it only as a FALLBACK — for a union-valued CALL result whose callee its
// syntactic resolution misses (an indexed closure-array call `arr[i](x)`) — never on the hot path
// (declared / param / binding unions resolve from the cheap annotation string). The name-typed sibling
// of `nodeTyIsUnion`, needed for the value-union UNBOX (the struct case narrows via the variant alone).
export function nodeUnionName(ix: i32) {
  const ty = nodeTyIxOf(ix)
  if ty < 0 { return "" }
  const t = T.tys[ty]
  if t is TyUnion {
    if t.uMembers.length >= 2 {
      // CHEAPLY gate to a VALUE union (all members scalar/literal atoms) BEFORE rendering: a STRUCT
      // union (e.g. the huge `Node`) has object members, and `valueUnionRetName`/`structUnionRetName`
      // would RENDER it (`tyToStr` — the #494 ~4× self-compile cost) only to decline / for the
      // variant path that doesn't need the name. The value-union UNBOX (the sole caller's need) is the
      // only case that requires a name here; a struct-union narrow resolves via the variant alone.
      let allValue = true
      let i = 0
      while i < t.uMembers.length {
        const mt = T.tys[t.uMembers[i]]
        if !(mt is TyPrim) {
          if !(mt is TyLit) { allValue = false }
        }
        i = i + 1
      }
      if allValue { return valueUnionRetName(ty) }
      // A REF-ARM value union (`T[] | {w: i32}` — repOf item (d)): a binding INFERRED from a
      // closure-value call of this result type narrows (`t1 is T[]`) but its unbox gated on
      // `unionNameOfIdent`, which reached this fallback and got "" — the raw box leaked into
      // the indexed read (INVALID-WASM nominal / a TRAP annotated, the #911 finding). Render
      // the union's NOMINAL name (the same spelling the recording arm registers and
      // `synthRetAnnots` pins), so the narrowed read unboxes like any other union binding.
      // Declines ("") for an anonymous-element array arm — the #911 declared-twin-gated
      // shapes stay a loud reject. Reached only on the Call fallback (never the hot path),
      // and `refArmUnionRetName` structurally pre-gates before rendering (#494 discipline).
      const ran = refArmUnionRetName(ty, gRootStmts)
      if ran != "" { return ran }
      // A MAP-member union (`{[string]: i32} | boolean`): a binding INFERRED from a
      // closure-value call of this result type (a narrowed nullable-closure rebind
      // `t0()`) holds the box, and its narrowed MAP-arm read must unbox — which keys
      // on this name. Render the same spelling `mapUnionRetName` pins on an adopted
      // lambda (the registered union name), so the unbox resolves exactly like the
      // annotated-binding path.
      const mun = mapUnionRetName(ty)
      if mun != "" { return mun }
      // A MIXED variant-box union (`f64 | {w: i32}`, `K0 | boolean` — ≥1 non-object arm):
      // a binding INFERRED from a closure-value call of this result type (an indexed
      // closure-array element `v[0](1)`, a narrowed nullable-closure rebind `t0()`) holds
      // the box, and its narrowed read must UNBOX — which keys on this name. Render the
      // same spelling `variantBoxUnionRetName` pins on the adopted lambda (the registered
      // union name), so the unbox resolves exactly like the annotated-binding path. A
      // pure-OBJECT union (`{f: string} | {w: i32}`, the huge `Node`) stays "" — its
      // narrow resolves via the variant alone and the render is the #494-costly op the
      // hot path must avoid (`mixedVariantBoxGate` declines before any member renders).
      if mixedVariantBoxGate(t.uMembers) {
        const vbn = variantBoxUnionRetName(ty)
        if vbn != "" { return vbn }
        // A CLOSURE-ARM value union (`(()=>string) | i64`): a binding INFERRED from a
        // closure-value call of this result type (an indexed closure-array element
        // `v[0](1)`) holds the box, and its narrowed read must UNBOX — which keys on
        // this name. Render the same spelling `cloArmValueUnionRetName` pins on the
        // adopted lambda (the registered union name), so the unbox resolves exactly
        // like the annotated-binding path.
        const can = cloArmValueUnionRetName(ty)
        if can != "" { return can }
      }
    }
  }
  // A nullable value SCALAR (`i32 | null`) is a `TyNullable`, NOT a `TyUnion`, yet reps as the
  // value-union {tag,value} BOX — so a value call whose result is `i32 | null` (a `??`-derived
  // closure `t0(1)` with no lifted fe / annotation) resolves its box name here for the binding's
  // union unbox / narrow, mirroring the annotated-closure path. `valueUnionRetName` gates through
  // `isValueUnionName`, which admits ONLY the numeric-scalar nullables that box (`i32|null`, …) and
  // declines the `boolean|null` / `string|null` NICHES, so those stay "" (their niche rep handles).
  if t is TyNullable {
    const nvn = valueUnionRetName(ty)
    if nvn != "" { return nvn }
    // A NULLABLE variant-box union (`{a,f,z} | i32 | null`): a binding inferred from a
    // closure-value call of this result type holds the `>u` box (the null is a member
    // atom) — render the same spelling `variantBoxUnionRetName` pins on the adopted
    // lambda, so the narrowed read unboxes and `!= null` tag-tests like the annotated
    // path. `mixedVariantBoxGate` pre-gates before any member renders (#494 discipline).
    const nit = T.tys[t.nInner]
    if nit is TyUnion {
      if mixedVariantBoxGate(nit.uMembers) {
        const nvb = variantBoxUnionRetName(ty)
        if nvb != "" { return nvb }
      }
    }
    return ""
  }
  ""
}

// MONOMORPHIC BODY INFERENCE — lift the element-hole ceiling for an un-annotated param.
// The shared definition body of a function is type-checked ONCE with each un-annotated
// parameter bound to an OPAQUE inference hole, so an inferred empty-list local built from a
// pass-through (`out.push(self[i])`) pins its element (the indexed param's element name), but
// one built from a NON-TRIVIAL expression over the element (`out.push(self[i] * 2)`) cannot —
// the hole isn't known to be numeric. This re-checks the body for ONE concrete call shape:
// each parameter is bound to its pinned type (`paramTyNames`, aligned with the decl's params),
// so the SAME existing list-element inference resolves the local concretely. Returns the
// inferred LIST type-name of `localName` (`"i32[]"`, `"f64[]"`), or "" when it is not an
// inferred list or stays generic — in which case the emitter keeps its prior behavior.
//
// Runs fully ISOLATED at emit time (after the real check pass): `nodeTyIx` recording and
// symbols are suppressed via `inferQuiet`, and every diagnostic / inference table the body
// check appends to is truncated back to its saved length, so the global checker state the
// emitter still reads is byte-identical afterwards. Mirrors `inferReturnsPrePass`'s discipline.
export function monoInferListElem(
  declIx: i32,
  paramTyNames: string[],
  localName: string,
) {
  if declIx < 0 { return "" }
  const dn = P.nodes[declIx]
  if !(dn is FuncDecl) { return "" }
  const body = P.nodes[dn.fnBody]
  if !(body is Block) { return "" }
  // Snapshot the suppression flags and every append-only inference/diagnostic table.
  const sQuiet = inferQuiet
  const sSym = symEnabled
  const sDiag = T.diags.length
  const sHoleN = holeShapeNames.length
  const sHoleT = holeShapeTys.length
  const sHoleArr = holeArrayDemand.length
  const sBinC = binCstrOp.length
  const sILet = inferLetIx.length
  const sINulS = inferLetNulStrIx.length
  const sINulB = inferLetNulBoolIx.length
  const sIRet = inferRetFn.length
  const sStack = inferStack.length
  const sTent = inferTentative.length
  const sRedun = redunName.length
  inferQuiet = true
  symEnabled = 0
  // Bind the parameters concretely in a fresh scope, then check the body STATEMENTS in
  // that scope directly (not `checkNode(dn.fnBody)`, whose Block arm would push+pop its own
  // scope and drop the local before we can read it). The list element hole resolves through
  // the pushes; a `return`'s check against a stale `T.curRet` only yields a truncated diag.
  pushScope(dn.fnBody)
  const params = dn.fnParams
  let pi = 0
  while pi < params.length {
    const p = P.nodes[params[pi]]
    if p is Param {
      let pty = TY_ERR
      if pi < paramTyNames.length {
        if paramTyNames[pi] != "" { pty = nameToTy(paramTyNames[pi]) }
      }
      declare(p.parName, pty)
    }
    pi = pi + 1
  }
  const stmts = body.blkStmts
  let s = 0
  while s < stmts.length {
    checkNode(stmts[s])
    s = s + 1
  }
  // Read the resolved local: a fully-pinned `T[]` (element no longer a `TyVar`) renders its
  // list type name; anything else (not a list, or still generic) yields "".
  let listName = ""
  const lt = lookup(localName)
  if lt >= 0 {
    const ltt = T.tys[lt]
    if ltt is TyArray {
      if ltt.aElem >= 0 {
        const el = T.tys[ltt.aElem]
        if !(el is TyVar) { listName = tyToStr(lt) }
      }
    }
  }
  popScope()
  // Restore: truncate every table back, then the flags + diagnostic stream.
  while holeShapeNames.length > sHoleN { holeShapeNames.pop() }
  while holeShapeTys.length > sHoleT { holeShapeTys.pop() }
  while holeArrayDemand.length > sHoleArr { holeArrayDemand.pop() }
  while binCstrOp.length > sBinC {
    binCstrOp.pop()
    binCstrLt.pop()
    binCstrRt.pop()
  }
  while inferLetIx.length > sILet { inferLetIx.pop() }
  while inferLetTy.length > sILet { inferLetTy.pop() }
  while inferLetNulStrIx.length > sINulS { inferLetNulStrIx.pop() }
  while inferLetNulBoolIx.length > sINulB { inferLetNulBoolIx.pop() }
  while inferRetFn.length > sIRet { inferRetFn.pop() }
  while inferRetTy.length > sIRet { inferRetTy.pop() }
  while inferStack.length > sStack { inferStack.pop() }
  while inferTentative.length > sTent { inferTentative.pop() }
  redunTruncate(sRedun)
  while T.diags.length > sDiag { T.diags.pop() }
  symEnabled = sSym
  inferQuiet = sQuiet
  listName
}

// The SCALAR sibling of `monoInferListElem`: re-check the body of `declIx` with its params
// pinned to `paramTyNames` and read the resolved type of the LOCAL `localName`, returning its
// prim NAME when it settles on a concrete NON-i32 scalar (`string` / `f64` / `i64` / `f32`),
// else "". This lets the monomorphizer type an un-annotated `return <local>` whose local is a
// scalar ELEMENT of a hole-pinned param (`const t = self[i]; return t`, or a `let acc = "";
// acc = acc + self[i]; return acc` fold) — the emitter's return-kind inference runs BEFORE
// locals are collected and the checker's typed-IR is stale for a hole-derived node, so without
// this the instance's functype result defaults to i32 and clashes with the string/f64 ref the
// body returns. i32 / boolean (both i32 valtype) and any still-generic local yield "" so the
// existing inferred-return path is left byte-identical. The save/restore mirrors
// `monoInferListElem` exactly (every append-only inference/diagnostic table is truncated back).
export function monoInferLocalScalar(
  declIx: i32,
  paramTyNames: string[],
  localName: string,
) {
  if declIx < 0 { return "" }
  const dn = P.nodes[declIx]
  if !(dn is FuncDecl) { return "" }
  const body = P.nodes[dn.fnBody]
  if !(body is Block) { return "" }
  const sQuiet = inferQuiet
  const sSym = symEnabled
  const sDiag = T.diags.length
  const sHoleN = holeShapeNames.length
  const sHoleT = holeShapeTys.length
  const sHoleArr = holeArrayDemand.length
  const sBinC = binCstrOp.length
  const sILet = inferLetIx.length
  const sINulS = inferLetNulStrIx.length
  const sINulB = inferLetNulBoolIx.length
  const sIRet = inferRetFn.length
  const sStack = inferStack.length
  const sTent = inferTentative.length
  const sRedun = redunName.length
  inferQuiet = true
  symEnabled = 0
  pushScope(dn.fnBody)
  const params = dn.fnParams
  let pi = 0
  while pi < params.length {
    const p = P.nodes[params[pi]]
    if p is Param {
      let pty = TY_ERR
      if pi < paramTyNames.length {
        if paramTyNames[pi] != "" { pty = nameToTy(paramTyNames[pi]) }
      }
      declare(p.parName, pty)
    }
    pi = pi + 1
  }
  const stmts = body.blkStmts
  let s = 0
  while s < stmts.length {
    checkNode(stmts[s])
    s = s + 1
  }
  // Read the resolved local: a concrete NON-i32 scalar prim renders its name; anything else
  // (i32 / boolean / non-scalar / still-generic) yields "" → the inferred-return path is left
  // untouched.
  let scalarName = ""
  const lt = lookup(localName)
  if lt >= 0 {
    const ltt = T.tys[lt]
    if ltt is TyPrim {
      const pn = ltt.primName
      if pn == "string" || pn == "f64" || pn == "i64" || pn == "f32" {
        scalarName = pn
      }
    }
  }
  popScope()
  while holeShapeNames.length > sHoleN { holeShapeNames.pop() }
  while holeShapeTys.length > sHoleT { holeShapeTys.pop() }
  while holeArrayDemand.length > sHoleArr { holeArrayDemand.pop() }
  while binCstrOp.length > sBinC {
    binCstrOp.pop()
    binCstrLt.pop()
    binCstrRt.pop()
  }
  while inferLetIx.length > sILet { inferLetIx.pop() }
  while inferLetTy.length > sILet { inferLetTy.pop() }
  while inferLetNulStrIx.length > sINulS { inferLetNulStrIx.pop() }
  while inferLetNulBoolIx.length > sINulB { inferLetNulBoolIx.pop() }
  while inferRetFn.length > sIRet { inferRetFn.pop() }
  while inferRetTy.length > sIRet { inferRetTy.pop() }
  while inferStack.length > sStack { inferStack.pop() }
  while inferTentative.length > sTent { inferTentative.pop() }
  redunTruncate(sRedun)
  while T.diags.length > sDiag { T.diags.pop() }
  symEnabled = sSym
  inferQuiet = sQuiet
  scalarName
}

// Whether the LetDecl at `letIx` was recorded as an inferred `string | null` niche
// if-binding (the niche analogue of `inferLetNameOf`). The emitter's `letIsNulString`
// consults this so the slot classifies as kind 16 and reuses the annotated lowering.
export function isInferLetNulStr(letIx: i32) {
  let i = 0
  while i < inferLetNulStrIx.length {
    if inferLetNulStrIx[i] == letIx { return true }
    i = i + 1
  }
  false
}

// The `boolean | null` companion of `isInferLetNulStr`: whether the LetDecl at `letIx`
// was recorded as an inferred `boolean | null` niche if-binding. The emitter's
// `letNulBool` consults this so the slot classifies as the niche i32 rep.
export function isInferLetNulBool(letIx: i32) {
  let i = 0
  while i < inferLetNulBoolIx.length {
    if inferLetNulBoolIx[i] == letIx { return true }
    i = i + 1
  }
  false
}

// ── value-union NAME classification (moved from wasmEmit to break the
// typecheck→emitter import cycle; pure string/atom logic the checker needs too) ──
// ── inline union annotations (`v: A | B`) ─────────────────────────────────────
// An INLINE union annotation parses to a `TypeRef` whose synthetic name is the
// pipe-joined member list (`"A|B"`, mirroring the `i32[]` / `{[K]:V}` synthetic
// names — see `parser.vl`'s `parseTypeName`). A NAMED alias `type N = A | B` is a
// `UnionDecl` whose name `"N"` is registered in `unNames`; an inline annotation has
// no such name, so none of the name-keyed union machinery (`isUName`, valtype
// interning, narrowing) recognizes it. To make an inline `A | B` behave IDENTICALLY
// to a named alias, we register the synthetic name itself as a union alias — the
// same tables, the same heap-type interning, the same tags — so every downstream
// lookup keyed on the type-name string just works.
//
// Append the member atoms of the synthetic union name `name` to `out`, split on its
// TOP-LEVEL `|` separators (depth tracked so a nested `{…}` / `[…]` member is not
// split inside). A bare name with no `|` appends one atom. The flat `out` accumulator
// (vs returning a fresh `string[]`) keeps this off the self-host emitter's
// empty-ref-array-literal return path.
export function splitUnionAtoms(name: string, out: string[]) {
  // Atoms are VERBATIM substrings of `name` between top-level `|` separators, so each
  // is one `slice` from the last separator (`start`) — never a per-code-point
  // accumulation, whose repeated copy-on-concat walked the whole atom AGAIN per char:
  // O(len²) per call, ~14 s of compile for one 30-line program over a recursive
  // struct's ~5 K-char render (the third recurrence of the per-code-point-concat
  // quadratic class — see `retAtomsCheap`, which now also gates that render away).
  //
  // `pdepth` counts ALL groupers — braces, brackets, AND parens — and gates BOTH the `|`
  // splitting and the top-level-`=>` detection. Paren-aware splitting keeps a paren-GROUPED
  // arm whole: `(i32 | string)[] | {w: i32}` splits to `(i32 | string)[]` + `{w: i32}` (the
  // legacy brace/bracket-only depth mis-split it into the garbage atoms `(i32` + `string)[]`,
  // so the WHOLE union mis-classified — the binding silently dropped its union rep and every
  // `is` against the list arm const-folded FALSE, a live miscompile). A paren-grouped closure
  // member (`((i32) => A | B) | f64`) needs no special casing anymore: its return's `|` sits
  // at `pdepth >= 1`. Quoted litunion members are skipped verbatim (`inStr`) so a grouper or
  // `|` INSIDE a string-literal atom (`"(a" | "b"`) neither splits nor derails the depth.
  let start = 0
  let pdepth = 0
  let inStr = false
  let i = 0
  while i < name.length {
    const c = name[i]
    if inStr {
      if c == '"' { inStr = false }
    } else if c == '"' {
      inStr = true
    } else if c == '{' || c == '[' || c == '(' {
      pdepth = pdepth + 1
    } else if c == '}' || c == ']' || c == ')' {
      pdepth = pdepth - 1
    } else if (c == '=' && i + 1 < name.length && name[i + 1] == '>') {
      if pdepth == 0 {
        // A top-level function arrow: the whole name is a single function-type member — absorb
        // the return verbatim (a `|` inside it belongs to the return union, split separately),
        // i.e. stop scanning; the final push below takes everything from `start`.
        i = name.length
      }
    } else if pdepth == 0 && c == '|' {
      out.push(name.slice(start, i))
      start = i + 1
    }
    i = i + 1
  }
  out.push(name.slice(start, name.length))
  0
}

// The number of TOP-LEVEL `|`-separated members in the synthetic name `name` (1 for a
// bare name). Counts separators without materializing the atom strings.
export function unionMemberCount(name: string) {
  let n = 1
  // All-grouper depth + quoted-atom skipping, the counting dual of `splitUnionAtoms`
  // (paren-aware, so a paren-GROUPED arm's inner `|` is not a separator).
  let pdepth = 0
  let inStr = false
  let i = 0
  while i < name.length {
    const c = name[i]
    if inStr {
      if c == '"' { inStr = false }
    } else if c == '"' {
      inStr = true
    } else if c == '{' || c == '[' || c == '(' {
      pdepth = pdepth + 1
    } else if c == '}' || c == ']' || c == ')' {
      pdepth = pdepth - 1
    } else if (c == '=' && i + 1 < name.length && name[i + 1] == '>') {
      if pdepth == 0 {
        // A top-level `=>` — the rest is the function RETURN (one member); stop counting so
        // `(i32) => i32 | string` is ONE function type, not a 2-member union.
        return n
      }
    } else if pdepth == 0 && c == '|' {
      n = n + 1
    }
    i = i + 1
  }
  n
}

// True if the type-name `name` is a FUNCTION type (`() => i64`, `(i32) => i32`) — a
// TOP-LEVEL `=>` (parens/braces/brackets balanced). A value-union member that is a
// closure rides the box's anyref `value` as the closure fat-pointer struct (a
// `structref` subtype), exactly as a string/list member rides its wrapper ref — so it
// is a REF atom (kind 11), with no per-rep scalar value box. Local to typecheck (the
// emitter's `annArrowAt` lives in `emit_base`, which imports THIS module).
export function nameIsFuncTypeAtom(nameIn: string) {
  // A union member keeps its GROUPING parens (`(() => i64) | i64` splits to the atom
  // `(() => i64)`), so peel every fully-enclosing balanced paren layer before the
  // top-level `=>` scan — otherwise the arrow reads as nested (depth 1) and misses.
  let name = nameIn
  while (
    name.length >= 2 &&
    name[0] == '(' &&
    name[name.length - 1] == ')' &&
    parenEnclosesWhole(name)
  ) {
    name = name.slice(1, name.length - 1)
  }
  let depth = 0
  let i = 0
  while i < name.length {
    const c = name[i]
    if c == '(' || c == '{' || c == '[' {
      depth = depth + 1
    } else if c == ')' || c == '}' || c == ']' {
      depth = depth - 1
    } else if (
      depth == 0 &&
      c == '=' &&
      i + 1 < name.length &&
      name[i + 1] == '>'
    ) {
      return true
    }
    i = i + 1
  }
  false
}

// True when the LEADING `(` of `name` closes only at the FINAL char — i.e. the outer
// parens enclose the whole string (`(()=>i64)` yes; `(i32)=>(i32)` no, the first `)`
// closes mid-string). Lets `nameIsFuncTypeAtom` strip only genuine grouping parens.
export function parenEnclosesWhole(name: string) {
  let depth = 0
  let i = 0
  while i < name.length {
    const c = name[i]
    if c == '(' || c == '{' || c == '[' {
      depth = depth + 1
    } else if c == ')' || c == '}' || c == ']' {
      depth = depth - 1
      if depth == 0 { return i == name.length - 1 }
    }
    i = i + 1
  }
  false
}

// The value-atom kind of a NICHE-nullable scalar-element LIST member name —
// `(boolean | null)[]` / `(K | null)[]` share the i32-list backing (kind 7),
// `(string | null)[]` the string-list backing (kind 9); -1 otherwise. The element's
// null encodes INSIDE the element rep (sentinel 2 / `-1` / `ref.null $a`), so the
// outer list carries no extra structure beyond its leaf backing's list.
function nulElemListAtomKind(name: string) {
  const n = name.length
  if n < 5 { return -1 }
  if name[n - 2] != '[' || name[n - 1] != ']' { return -1 }
  let elem = name.slice(0, n - 2)
  if elem.length > 1 {
    if elem[0] == '(' && elem[elem.length - 1] == ')' {
      elem = elem.slice(1, elem.length - 1)
    }
  }
  const atoms: string[] = []
  splitUnionAtoms(elem, atoms)
  if atoms.length < 2 { return -1 }
  let sawNull = false
  const rest: string[] = []
  let i = 0
  while i < atoms.length {
    if atoms[i] == "null" { sawNull = true } else { rest.push(atoms[i]) }
    i = i + 1
  }
  if !sawNull { return -1 }
  if rest.length == 0 { return -1 }
  if rest.length == 1 {
    if rest[0] == "boolean" { return 7 }
    if rest[0] == "string" { return 9 }
    if nameIsLitUnionType(rest[0]) { return 7 }
    return -1
  }
  // The expanded inline litunion form (`("a" | "b" | null)[]`).
  let core = rest[0]
  let j = 1
  while j < rest.length {
    core = core + "|" + rest[j]
    j = j + 1
  }
  if nameIsLitUnionType(core) { return 7 }
  -1
}

// True if `name` is a VALUE union carrying a literal-union ALIAS arm (`K0 | i64`,
// `K0 | f64`): ≥2 top-level atoms, every atom a value atom / `null` / a declared
// litunion alias, at least one alias arm and ≥2 non-null arms. Such a union boxes
// like a value union — the litunion arm rides the box as its member-string atom
// (tag `string`), so a closure result pinned to this name lowers exactly like the
// annotated named-function spelling. The alias arm makes `isValueUnionName`
// decline (its `valueAtomKind` is -1), hence this dedicated predicate.
export function nameIsLitUnionArmValueUnion(name: string) {
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  if atoms.length < 2 { return false }
  let hasAlias = false
  let nonNull = 0
  let i = 0
  while i < atoms.length {
    const a = atoms[i]
    if a != "null" {
      nonNull = nonNull + 1
      if nameIsLitUnionType(a) { hasAlias = true }
      else if valueAtomKind(a) < 0 { return false }
    }
    i = i + 1
  }
  hasAlias && nonNull >= 2
}

// ── value-union atom classification ───────────────────────────────────────────
// The atom KIND of a value-union member type name: 0 i32, 1 boolean, 2 string,
// 3 i64, 4 f64, 5 f32, 6 null, 11 closure (a function type — a REF atom riding the
// box anyref), 7-10/12 scalar-element lists — or -1 for anything else (a struct
// name, an inline shape, a ref-element array).
// The kind doubles as the atom's tag offset (`scalarTagOf`).
// The literal-union ELEMENT name of a `K[]` / `("a"|"b")[]` array type-name, or "" when
// `name` is not a litunion array. The checker-side twin of the emitter's
// `nameIsLitUnionArray` (which typecheck cannot import): strip the trailing `[]`, peel
// one grouping-paren layer, and require a litunion (`nameIsLitUnionType` — a named alias
// or an inline all-quoted member set). Cheap-rejects any name not ending in `[]`.
export function litUnionArrayElemOf(name: string) {
  const n = name.length
  if n < 3 { return "" }
  if name[n - 2] != '[' || name[n - 1] != ']' { return "" }
  let elem = name.slice(0, n - 2)
  if elem.length > 1 {
    if elem[0] == '(' {
      if elem[elem.length - 1] == ')' { elem = elem.slice(1, elem.length - 1) }
    }
  }
  if nameIsLitUnionType(elem) { return elem }
  ""
}

export function valueAtomKind(name: string) {
  if name == "i32" { return 0 }
  if name == "boolean" { return 1 }
  if name == "string" { return 2 }
  if name == "i64" { return 3 }
  if name == "f64" { return 4 }
  if name == "f32" { return 5 }
  if name == "null" { return 6 }
  // A LIST member of a value union (`i32[] | string`) is a REF atom — the union box's
  // `value` field holds the list WRAPPER ref directly (like a string), no scalar box. Each
  // list type gets a distinct code so it tags distinctly (`boolean[]` shares the i32 list).
  if name == "i32[]" || name == "boolean[]" { return 7 }
  // A literal-union ARRAY (`K[]` over `type K = "a" | "b"`, or an inline `("a"|"b")[]`): its
  // elements are interned i32 ATOM ids, so the list shares the exact `i32[]` backing and rides
  // the SAME kind-7 atom (`boolean[]`'s pattern — the construct seeds the atom-element context,
  // a narrowed read yields the atom list). A real `i32[]`/`boolean[]` member cannot coexist with
  // it in one union (same backing, one tag), so the shared tag never mis-discriminates.
  if litUnionArrayElemOf(name) != "" { return 7 }
  if name == "f64[]" { return 8 }
  if name == "string[]" { return 9 }
  if name == "i64[]" { return 10 }
  // The f32 list rides its own atom (the `$fa32`/`$fl32` backing — distinct from the
  // f64 list's kind 8, so `f32[] | i64` tags/unboxes the f32 wrapper). Code 12 sits
  // ABOVE the closure kind 11: the codes are append-only (each doubles as a tag offset).
  if name == "f32[]" { return 12 }
  // A NICHE-nullable scalar-element LIST member (`(boolean | null)[]`, `(K | null)[]`,
  // `(string | null)[]`): the element's null rides IN the element rep (an i32 sentinel /
  // `ref.null` string), so the list IS its leaf backing's atom — the i32 list (7) or the
  // string list (9). One kind per backing keeps the `is`-compare tag consistent with
  // `emitUnionCoerce`'s carrier classification ("i32[]" / "string[]").
  const nk = nulElemListAtomKind(name)
  if nk >= 0 { return nk }
  // A CLOSURE member (`(() => i64) | i64`) is a REF atom (kind 11) — the closure
  // fat-pointer struct rides the box's anyref `value` directly (a `structref`
  // subtype), no per-rep scalar value box. Checked LAST so a concrete scalar/list
  // name (none of which carry a top-level `=>`) never reaches it.
  if nameIsFuncTypeAtom(name) { return 11 }
  -1
}

// True if `name` is a VALUE union this emitter boxes: 2+ top-level atoms, every
// atom a scalar/string/null name, and either (a) 2+ non-null atoms, or (b) exactly
// one non-null NUMERIC atom plus `null` (`i32 | null` — a scalar has no spare null
// niche, so it boxes; `boolean | null` keeps its existing sentinel NICHE encoding,
// and a single REF member + null (`S | null`, `string | null`) stays a niche
// nullable ref — neither is a box).
export function isValueUnionName(name: string) {
  if unionMemberCount(name) < 2 { return false }
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  let nonNull = 0
  let hasNull = false
  let soloKind = -1
  let i = 0
  while i < atoms.length {
    const k = valueAtomKind(atoms[i])
    if k < 0 { return false }
    if k == 6 {
      hasNull = true
    } else {
      nonNull = nonNull + 1
      soloKind = k
    }
    i = i + 1
  }
  if nonNull >= 2 { return true }
  if nonNull == 1 && hasNull {
    // Only a NUMERIC scalar boxes with null; boolean|null / string|null are niches.
    return soloKind == 0 || soloKind == 3 || soloKind == 4 || soloKind == 5
  }
  false
}

// Extracted from `checkNodeReal`'s `BinExpr` arm (C3: thin the dispatcher).
function checkBinExprNode(n: BinExpr, ix: i32) {
  const op = n.binOp
  // `a && b` / `a || b`: the LEFT side's narrowings hold while CHECKING the
  // right (`p != null && p.x > 0` checks `p.x` under a non-null `p`; for `||`
  // the right is reached only when the left was FALSE, so its else-narrowings
  // hold — `p == null || p.x > 0`).
  if op == "&&" || op == "||" {
    const clt = checkNode(n.binLeft)
    const cnames: string[] = []
    const ctys: i32[] = []
    if op == "&&" {
      collectThenNarrows(n.binLeft, cnames, ctys)
    } else {
      collectElseNarrows(n.binLeft, cnames, ctys)
    }
    let cpushed = 0
    if cnames.length > 0 {
      pushScope(-1)
      applyNarrows(cnames, ctys)
      cpushed = 1
    }
    const crt = checkNode(n.binRight)
    if cpushed == 1 { popScope() }
    if !assignable(clt, TY_BOOL) || !assignable(crt, TY_BOOL) {
      tErr("operator '" + op + "' expects boolean operands", ix)
    }
    return TY_BOOL
  }
  // Definite-assignment: the LHS of a plain `=` with a bare-name target is a
  // pure WRITE — flag the target node so the `Ident` arm does not trip
  // use-before-assign on it (the assignment is what assigns it). A compound
  // `x += …` is desugared to `x = x + (…)`: the inner `x` in the RHS is NOT the
  // write target, so its read is still gated. Cleared after the target is
  // checked. Saved/restored so a nested `=` (e.g. `a = (b = c)`) is exact.
  const savedWriteTarget = daWriteTarget
  if op == "=" {
    const wtgt = P.nodes[n.binLeft]
    if wtgt is Ident { daWriteTarget = n.binLeft }
  }
  let lt = checkNode(n.binLeft)
  daWriteTarget = savedWriteTarget
  // Contextual typing for an assignment RHS (`m[k] = (x) => …` over a `{[…]: (i32)=>i32}`
  // map, `xs[i] = (n) => …`, `f = (n) => …`): seed the LHS type so an un-annotated lambda
  // param infers from the target (the let-init / arg / return positions already seed).
  if op == "=" { seedExpected(n.binRight, lt) }
  // Contextual typing for a `??` DEFAULT (`v["k"] ?? (q2) => (12121)` over a `{[string]: (i32) =>
  // i32 | null}` map): seed the default operand with the LHS type so an un-annotated default-lambda
  // param infers from the non-null LHS closure type (`seedExpected` unwraps the `TyNullable` map
  // read to `(i32) => i32 | null`, then seeds `q2: i32`). Without it the bare `(q2) => …` default is
  // an uninferable-param reject. Mirrors the `=` seeding; the LHS non-null shape drives the lambda.
  if op == "??" { seedExpected(n.binRight, lt) }
  let rt = checkNode(n.binRight)
  // A binary op with a HOLE operand can't decide its form until the hole is bound at the call —
  // record the deferred constraint (skipping assignment / logical, handled by their own arms).
  if op != "=" && op != "&&" && op != "||" { noteBinCstr(lt, op, rt) }
  // Assignment: RHS must be assignable to the LHS's (already-bound) type.
  if op == "=" {
    // A `const` NAME cannot be rebound (`x = …`, and the `x++`/`x += …`
    // desugarings). Data behind it stays mutable (a Member/Index target).
    const tgt = P.nodes[n.binLeft]
    if tgt is Ident {
      if isConstName(tgt.identName) {
        tErr("cannot reassign `const` " + tgt.identName, ix)
      }
      // This write makes the binding definitely assigned on the current path.
      daMarkAssigned(tgt.identName)
    }
    // An index-set into an empty `[]` (`xs[i] = v`) pins its element type to
    // `typeof v` in place — usage-driven inference (`infer-empty-index-set.vl`),
    // clearing the uninferred floor. `lt` is the (open `-1`) element type, so
    // every assignment succeeds against it until it is pinned.
    if tgt is Index {
      // The whole left-hand side (receiver included) was already checked as
      // `lt` above — READ the recorded type instead of re-checking, so a
      // diagnostic inside the receiver subtree isn't reported twice. The
      // fallback re-check only fires for a node the table doesn't cover.
      let arrTy0 = nodeTyIxOf(tgt.idxArr)
      if arrTy0 < 0 { arrTy0 = checkNode(tgt.idxArr) }
      const arrT0 = T.tys[arrTy0]
      if arrT0 is TyArray {
        if arrT0.aElem < 0 {
          arrT0.aElem = rt
          tyMutEpoch = tyMutEpoch + 1 // index-write pinned the element in place
        }
      }
      // Index WRITE trap (B13, host `indexTrap` "[]="): `o[k] = v` on an
      // object that declares `"[]="` checks the value against the method's
      // VALUE parameter (index/wrong-value-type.vl rejects); an object with
      // only a READ trap rejects the write (host: the missing-method error).
      if arrT0 is TyObj {
        const wtrap = objFieldType(arrT0, "[]=")
        if wtrap >= 0 {
          const wt = T.tys[wtrap]
          if wt is TyFunc {
            if wt.fnParamTypes.length == 2 {
              if !assignableExpr(n.binRight, rt, wt.fnParamTypes[1]) {
                tErr(
                  "index write: expected " +
                    tyToStr(wt.fnParamTypes[1]) +
                    ", got " +
                    tyToStr(rt),
                  ix,
                )
              }
              return rt
            }
          }
        } else if objFieldType(arrT0, "[]") >= 0 {
          tErr(
            "no \"[]=\" method for index assignment on " + tyToStr(arrTy0),
            ix,
          )
          return TY_ERR
        }
      }
    }
    if !assignableExpr(n.binRight, rt, lt) {
      tErr("cannot assign " + tyToStr(rt) + " to " + tyToStr(lt), ix)
    }
    // A-infer-null: a nullable binding's open inner HOLE (`let x = null`)
    // fills from the first non-null assignment (in place, so the binding
    // becomes `T | null` everywhere); and a straight-line non-null `x = e`
    // narrows `x` for the REST of the enclosing block (host
    // `assignmentNarrowing` — an assignment inside a branch unwinds with the
    // branch's scope, so it never leaks past the join).
    const asgTgt = P.nodes[n.binLeft]
    if asgTgt is Ident {
      const asgCur = lookup(asgTgt.identName)
      if asgCur >= 0 {
        const asgCt = T.tys[asgCur]
        if asgCt is TyNullable {
          const rtT = T.tys[rt]
          let rhsNullable = false
          if rtT is TyNullable { rhsNullable = true }
          if !rhsNullable && !isNullTy(rt) && rt >= 0 {
            if asgCt.nInner < 0 {
              asgCt.nInner = rt
              tyMutEpoch = tyMutEpoch + 1 // nullable inner pinned in place
            }
            declare(asgTgt.identName, nonNullTy(asgCur))
          }
        }
      }
    }
    // Assignment is an expression yielding its RIGHT-HAND SIDE (host parity;
    // DECISIONS: assignment-as-expression).
    return rt
  }
  // Nullish coalescing: `a ?? d` — the result is `a`'s NON-NULL part unioned
  // with `d`'s type (host `NullCoalesce`: `a ?? b` with a nullable `b` stays
  // nullable; a non-null default collapses to the inner type). A non-nullable
  // LHS just yields itself.
  if op == "??" {
    const lt2 = T.tys[lt]
    if lt2 is TyNullable {
      // A float-literal default re-encodes at an inner `f32`, so keep the result f32 — else
      // `joinTys` widens `f32 + f64` to f64 and a downstream `f32` slot rejects the demote.
      if primNameOf(lt2.nInner) == "f32" && isFloatLitExpr(n.binRight) {
        return lt2.nInner
      }
      // A literal-union inner with a MEMBER-LITERAL default stays the union (`m[k] ?? "aa"`
      // over a `{[string]: K}` map is a `K`, an i32 atom) — else the bare literal types
      // `string` and `joinTys` widens the whole result to `string`, divorcing the checked
      // type from the atom rep the read produces.
      if isLitBearing(lt2.nInner) {
        const dl = litTyOfExpr(n.binRight)
        if dl >= 0 {
          if assignable(dl, lt2.nInner) { return lt2.nInner }
        }
        // An ATOM-VALUED MAP get's default must itself be an atom — a member literal
        // (accepted above) or a value of the same literal union. The fused read's rep is
        // the bare i32 atom id, so a `string`-typed default (or a NON-member literal,
        // which would mint a fresh id) cannot lower: type-valid (`joinTys` widens to
        // `string`) but unbuildable — the emitter-capability channel.
        const mgl = P.nodes[n.binLeft]
        if mgl is Index {
          if nodeTyMapValIsLitUnion(mgl.idxArr) {
            if !assignable(rt, lt2.nInner) {
              tErrUnsupported(
                "`??` over an atom-valued map needs a member-literal (or atom) default",
                ix,
              )
            }
          }
        }
      }
      // When the DEFAULT fits the non-null LHS type (with contextual coercion — an inline
      // object literal `{f: "aa"}` field-wise coerces to a `{f: K}` litunion field, #851),
      // the `??` result IS that LHS type — NOT the `joinTys` LUB, which WIDENS a litunion
      // struct field (`{f: K}`) to `string` when the default's field types bare `string`.
      // That widening divorced the checked type from the i32-atom rep the map-value struct
      // field read produces: `print((m[k] ?? {f:"aa"}).f)` rendered the RAW ATOM ID (the
      // read's node type carried no litunion members to widen). The variable-default spelling
      // (`m[k] ?? d`, `d: {f: K}`) already returned the union — `joinTys` of two identical
      // types — so only the inline-literal default was wrong; this extends the same result to
      // it. `assignableExpr` (not `assignable`) so the object literal coerces field-wise.
      if assignableExpr(n.binRight, rt, lt2.nInner) { return lt2.nInner }
      return joinTys(lt2.nInner, rt)
    }
    return lt
  }
  // Equality: result bool; requires mutual compatibility.
  if op == "==" || op == "!=" {
    // CLOSED SET (literal unions): comparing a literal-union place against a
    // literal OUTSIDE its set can never be true — reject rather than compile
    // an always-false test (host: discrimination is total over the union;
    // `literal-union-reject-compare`). Only fires when one side's TYPE
    // carries literal members and the OTHER side is a bare literal.
    if isLitBearing(lt) {
      const eqR = litTyOfExpr(n.binRight)
      if eqR >= 0 {
        if !assignable(eqR, lt) {
          tErr(
            "cannot compare " +
              tyToStr(lt) +
              " with " +
              tyToStr(eqR) +
              " — not a member of the union",
            ix,
          )
        }
        // A MEMBER compare is always a valid discrimination (`v == 7` over
        // `"x" | 7` — the mixed union's softened sides aren't mutually
        // assignable, so it must not fall through to the general rule).
        return TY_BOOL
      }
    } else if isLitBearing(rt) {
      const eqL = litTyOfExpr(n.binLeft)
      if eqL >= 0 {
        if !assignable(eqL, rt) {
          tErr(
            "cannot compare " +
              tyToStr(eqL) +
              " with " +
              tyToStr(rt) +
              " — not a member of the union",
            ix,
          )
        }
        return TY_BOOL
      }
    }
    if !assignable(lt, rt) && !assignable(rt, lt) {
      tErr("cannot compare " + tyToStr(lt) + " with " + tyToStr(rt), ix)
    } else {
      // SOUNDNESS: a STRUCTURAL `==`/`!=` on a plain object (or array) defaults
      // to field-by-field equality, which is sound only when every field is
      // itself value-comparable. A non-discriminated union/nullable/map field is
      // not — so reject the default structural compare and ask for an explicit
      // `==`. (Unions/nullables compared DIRECTLY — value-union equality, `==
      // null` nullness tests — never reach here: only an object/array operand is
      // tested, matching the host's anonymous-object structural fallback.)
      const lT = T.tys[lt]
      let structural = false
      if lT is TyObj { structural = true }
      else if lT is TyArray { structural = true }
      if structural {
        const seen: i32[] = []
        if !isEquatable(lt, seen) {
          tErr(
            tyToStr(lt) +
              " isn't equatable (a field is not value-comparable) — define a `==` operator for it",
            ix,
          )
        }
      }
    }
    return TY_BOOL
  }
  // OPERATOR DISPATCH on a user object (B13 + B14): `a op b` with a STRUCT
  // left operand resolves through a free `self`-function named for the
  // operator (host parser dispatch — checked FIRST, host order), else
  // through an operator closure FIELD (`"*": function(s) …` — host
  // `opFunc`). Equality/logicals/`=`/`??` returned above, so only the
  // arithmetic/comparison operators reach here.
  if op != "&&" && op != "||" {
    const odsp = T.tys[lt]
    if odsp is TyObj {
      const osf = opSelfFnTy(op, lt, rt, n.binRight, ix)
      if osf >= 0 { return osf }
      const ofld = objFieldType(odsp, op)
      if ofld >= 0 {
        const oft = T.tys[ofld]
        if oft is TyFunc {
          if oft.fnParamTypes.length == 1 {
            if !assignableExpr(n.binRight, rt, oft.fnParamTypes[0]) {
              tErr(
                "operator '" +
                  op +
                  "': expected " +
                  tyToStr(oft.fnParamTypes[0]) +
                  ", got " +
                  tyToStr(rt),
                ix,
              )
            }
            return oft.fnRet
          }
        }
      }
    }
  }
  // Ordering comparison: result bool; requires matching numeric types. A
  // literal / literal-union operand is its base scalar here (`n < 2` over
  // `0 | 1 | 2` compares as i32 — host: a numeric-literal union softens).
  if op == "<" || op == ">" || op == "<=" || op == ">=" {
    const olt = softenLitTy(lt)
    const ort = softenLitTy(rt)
    // String ordering: a lexicographic compare of two strings yields a bool.
    if isStringTy(olt) && isStringTy(ort) { return TY_BOOL }
    // A hole operand reaching a numeric comparison is USED numerically — record the demand.
    if !isNumeric(olt) || !isNumeric(ort) {
      tErr(
        "comparison expects numeric operands, got " +
          tyToStr(olt) +
          " and " +
          tyToStr(ort),
        ix,
      )
    } else if !sameNumeric(olt, ort) && !mixesNumeric(olt, ort) {
      // Mixed numerics may be compared when one side widens to the other
      // (i32/i64, i32/f64, f32/f64, …); the narrower side widens. Other mixes error.
      tErr("comparison mixes " + tyToStr(olt) + " and " + tyToStr(ort), ix)
    }
    return TY_BOOL
  }
  // `+` also concatenates strings.
  if op == "+" {
    // String concat requires an operand that ACTUALLY is a string. A hole (un-annotated
    // param) is permissively `assignable` to string, so the bare `assignable(_, STR)` test
    // collapsed `a + b` over two holes to `string` — wrong: that op is instantiation-dependent
    // (i32+i32→i32, f64→f64, string→string) and must DEFER its result to the operand hole
    // (resolved per call site through `substTyDeep`, so `const x: i32 = add(3, 4)` types and
    // `const x: string = add(3, 4)` is rejected). A hole paired with a REAL string (`s + "!"`)
    // still concatenates. With one concrete-string operand present, fall back to the
    // assignability test (so the other side may be a hole that pins to string).
    if isStringTy(lt) || isStringTy(rt) {
      if assignable(lt, TY_STR) && assignable(rt, TY_STR) { return TY_STR }
    }
    // List concat `a + b` → a new `T[]` (collections-design §VL.4); the two
    // element types must agree (an empty `[]` adopts the other side's).
    const lta = T.tys[lt]
    if lta is TyArray {
      const rta = T.tys[rt]
      if rta is TyArray {
        constrainEmpty(rt, lt)
        constrainEmpty(lt, rt)
        if assignable(rt, lt) { return lt }
        if assignable(lt, rt) { return rt }
        tErr("cannot concat " + tyToStr(lt) + " and " + tyToStr(rt), ix)
        return TY_ERR
      }
    }
  }
  // Remaining arithmetic: numeric-only, both the SAME numeric type (no implicit
  // i32 ↔ f64). A literal / all-literal-union operand SOFTENS to its base
  // scalar first (host: `n + 10` over `1 | 2 | 3` computes — and yields — a
  // plain i32; the union constrains assignment, not arithmetic).
  lt = softenLitTy(lt)
  rt = softenLitTy(rt)
  // A hole operand reaching arithmetic is USED numerically — record the demand so the call-arg
  // check enforces a numeric (or operator-overloaded) argument (`isNumeric(TyVar)` passes below).
  if !isNumeric(lt) || !isNumeric(rt) {
    // Reached only AFTER string-concat and array-concat are ruled out above, so
    // this is a genuine operand-type mismatch — `+` does have string/array forms,
    // so don't claim it is "numeric-only"; just report no form fits these types.
    tErr(
      "operator '" +
        op +
        "' is not defined for " +
        tyToStr(lt) +
        " and " +
        tyToStr(rt),
      ix,
    )
    return TY_ERR
  }
  // BITWISE / SHIFT operators are INTEGER-ONLY: a float operand (i32↔f64 mixing or
  // even same-type f64) has no bitwise form. Reject before the numeric-widening rules
  // so `1.0 & 2` errors (the float-widening lattice must not make it pass). Arithmetic
  // (`+ - * /`), `%`, and comparisons are unaffected.
  if (
    op == "&" ||
    op == "|" ||
    op == "^" ||
    op == "<<" ||
    op == ">>" ||
    op == ">>>"
  ) {
    if (
      primNameOf(lt) == "f64" ||
      primNameOf(lt) == "f32" ||
      primNameOf(rt) == "f64" ||
      primNameOf(rt) == "f32"
    ) {
      tErr(
        "operator '" +
          op +
          "' is integer-only, got " +
          tyToStr(lt) +
          " and " +
          tyToStr(rt),
        ix,
      )
      return TY_ERR
    }
  }
  // A FLOAT LITERAL operand adopts the OTHER side's f32 type (the literal re-encodes
  // exactly at f32, so `x + 4.0` with `x: f32` stays f32 — the `4.0` is NOT demoted
  // f64). Checked before the general mixed rule so the result is f32, not the wider
  // f64. (One side is the f32 variable; the other the float literal typed f64.)
  if primNameOf(lt) == "f32" && isFloatLitExpr(n.binRight) { return lt }
  if primNameOf(rt) == "f32" && isFloatLitExpr(n.binLeft) { return rt }
  // A mixed-numeric op widens the narrower operand to the wider one and yields the
  // wider type (`i32 op i64`→i64, `f64 op i32`→f64, `f32 op f64`→f64, …). Done BEFORE
  // the same-type check so a compatible mixed pair is accepted (B2). i32-only programs
  // never reach here (they are `sameNumeric` and fall through to `return lt`).
  if mixesNumeric(lt, rt) { return widerNumeric(lt, rt) }
  if !sameNumeric(lt, rt) {
    tErr(
      "operator '" + op + "' mixes " + tyToStr(lt) + " and " + tyToStr(rt),
      ix,
    )
    return TY_ERR
  }
  return lt
}
// ── let declaration ────────────────────────────────────────────────────────

// Extracted from `checkNodeReal`'s `LetDecl` arm (C3: thin the dispatcher).
function checkLetDeclNode(n: LetDecl, ix: i32) {
  // Resolve the annotation (if any) by reading the TypeRef child INLINE.
  let annot = -1
  if n.letType >= 0 {
    const tn = P.nodes[n.letType]
    if tn is TypeRef {
      annot = nameToTyAt(tn.tyName, n.letType)
      if annot < 0 {
        // An i32-keyed map shape (`{[i32]: V}`) is the native list/array path,
        // not the string-keyed hash map — report that directly (with the fix)
        // instead of a bare "unknown type", naming the constructor in play.
        // An emitter/runtime-capability rejection (the map rep is string-keyed),
        // not a type error — the unsupported-lowering channel.
        if mapShapeKeyName(tn.tyName) == "i32" {
          tErrUnsupported(
            "An i32-keyed " +
              initMapCtorName(n.letInit) +
              " isn't supported yet — i32 keys use a list/array (`T[]`); " +
              "`Map`/`Set` keys must be `string` for now",
            n.letType,
          )
        } else {
          tErr("unknown type '" + tn.tyName + "'", n.letType)
        }
        annot = TY_ERR
      }
      // Record the resolved type on the `let`'s TYPE-ANNOTATION node so the emitter can
      // classify it structurally from the `Ty` arena rather than re-parsing `tyNameOf` — C1.
      if !inferQuiet && annot >= 0 {
        if n.letType < nodeTyIx.length { nodeTyIx[n.letType] = annot }
      }
    }
  }
  let initTy = -1
  // Bidirectional: a `const f: (i32) => i32 = (x) => …` (or a composite of such — an
  // annotated array/object of lambdas) infers each un-annotated lambda param from the
  // annotation BEFORE the initializer is checked.
  if n.letInit >= 0 && annot >= 0 { seedExpected(n.letInit, annot) }
  // An UN-annotated binding to a bare lambda (`const add = (a, b) => …`): mark the lambda so its
  // un-annotated params type as inference holes (a value-flow-monomorphized generic function)
  // rather than being rejected as uninferable. Annotated bindings seed a concrete type above.
  if annot < 0 && n.letInit >= 0 {
    const liN = P.nodes[n.letInit]
    if liN is FuncDecl {
      if liN.fnName == "" { noteValBindLambda(n.letInit) }
    }
  }
  if n.letInit >= 0 { initTy = checkNode(n.letInit) }
  // A `void` initializer (`const x = f()` over a void function) has NO value to bind.
  // The assignment path (`x = f()`) already rejects it; the BINDING path did not — an
  // un-annotated binding had no assignability check, and `assignableExpr(void, T)` is
  // lenient — so a void binding slipped past `vl check` and CRASHED codegen. Reject it
  // here with a clear, source-located message, poisoning `initTy` to suppress cascades.
  if n.letInit >= 0 && isVoidTy(initTy) {
    // EXCEPT an if-EXPRESSION init (`const x = if c then 5`): a statement-if is
    // context-free `void`, but the if-binding inference below resolves it to `T | null`
    // (the else-less false path is the implicit `null`) — that path owns it.
    let vini = n.letInit
    const vip = P.nodes[vini]
    if vip is Paren { vini = vip.parInner }
    const viNode = P.nodes[vini]
    let voidOk = false
    if viNode is IfStmt { voidOk = true }
    if !voidOk {
      tErr(
        "cannot bind the void result of '" +
          n.letName +
          "' — a void function returns no value",
        ix,
      )
      initTy = TY_ERR
    }
  }
  // Redundant explicit annotation: the initializer's CONTEXT-FREE type (checked
  // just above, before the annotation is consulted) already IS the annotation, so
  // `: T` adds nothing. Recorded BEFORE `constrainEmpty` runs, so an empty-
  // collection hole the annotation legitimately pins is naturally excluded.
  if annot >= 0 && initTy >= 0 && n.letInit >= 0 {
    recordRedundantAnnot(n, ix, initTy, annot)
  }
  let bound = TY_ERR
  if annot >= 0 {
    bound = annot
    if initTy >= 0 {
      // An annotated assignment of an empty-collection initializer pins the
      // SOURCE binding's open holes from the annotation (`const ys: i32[] = zs`
      // resolves `zs`'s element) — clearing its uninferred floor in place.
      constrainEmpty(initTy, annot)
      // A `never`-typed annotation (a degenerate/empty-intersection alias) was
      // ALREADY reported at its declaration; don't also cascade a "cannot assign
      // … of type <empty>" at every use site.
      const neverAnnot = isNeverTy(annot)
      if !neverAnnot && !assignableExpr(n.letInit, initTy, annot) {
        // An object literal (`{}` / `{x: 1}`) assigned to a map type is a
        // category error, not a width mismatch — point at the fix (`Map()`)
        // rather than the opaque "cannot assign {} to … of type {[string]: …}".
        const annT = T.tys[annot]
        const initN = P.nodes[n.letInit]
        let objToMap = false
        if annT is TyMap {
          if initN is ObjLit { objToMap = true }
        }
        if objToMap {
          tErr(
            "An object literal isn't a map value — construct a map with " +
              "`Map()` (or a set with `Set()`), e.g. `let m: {[string]: i32} = Map()`",
            ix,
          )
        } else if isNumeric(initTy) && isNumeric(annot) {
          // Both sides numeric but not assignable ⇒ a lossy/narrowing edge the
          // lossless-only implicit-widening rule (#298) won't take silently.
          // Explain the lossiness rather than the opaque "cannot assign i32 to f32".
          tErr(
            tyToStr(initTy) +
              " doesn't fit in " +
              tyToStr(annot) +
              " — the conversion is lossy and must be made explicit with `as` " +
              "(write `x as " +
              tyToStr(annot) +
              "`)",
            ix,
          )
        } else {
          tErr(
            "cannot assign " +
              tyToStr(initTy) +
              " to '" +
              n.letName +
              "' of type " +
              tyToStr(annot),
            ix,
          )
        }
      }
      // A `Set()` initializer keeps its SET flavor even under a map-shaped
      // annotation (`let s: {[string]: boolean} = Set()`): the binding exposes
      // the Set surface (`.add`, no `.set`/`.get`/`.keys`), with the
      // annotation's key/value types.
      const it2 = T.tys[initTy]
      if it2 is TyMap {
        if it2.mSet == 1 {
          const an2 = T.tys[annot]
          if an2 is TyMap { bound = mkMapTy(an2.mKey, an2.mVal, 1) }
        }
      }
    }
  } else if initTy >= 0 {
    bound = initTy
    // USAGE-DRIVEN NULLABLE HOLE (A-infer-null): an un-annotated `let x =
    // null` is NOT pinned to the exact `null` type — `null` is hole-bearing
    // (it inhabits every `T | null`). Bind a nullable with an OPEN inner
    // hole; the first non-null assignment fills `T` in place (see the `=`
    // arm), so `x` becomes `T | null`. A COMPLETE initializer still pins.
    if isNullTy(initTy) { bound = mkNullableTy(-1) }
    // UN-INFERRED EMPTY-COLLECTION FLOOR: an un-annotated `[]` / `Map()` / `Set()`
    // whose hole is still open here may yet be pinned by a downstream
    // `.push`/`.set`/`.add` (those mutate the shared arena entry in place), so we
    // can't decide now. Record it for the scope-close re-check; if the hole stays
    // open it is genuinely uninferable and `flushUninferred` reports it.
    if unresolvedHole(bound) { notePending(n.letName, bound, ix) }
    // Export an un-annotated IF-EXPRESSION binding's INFERRED value-union type (by
    // node index) for the emitter, so it lowers like an annotated nullable/value-union
    // binding even when an arm is one the emitter can't statically classify (an ident
    // `if c then v else null`). Niches/non-unions render "" and are skipped — the
    // emitter's existing paths handle those. Mirrors the inferred-RETURN export.
    //
    // GATED to an if-expression init: the emitter's SOLE consumer is `nliInferIfLet`
    // (if-expr bindings), and `valueUnionRetName` renders the bound type via `tyToStr`
    // — cheap for a small union, but ruinous on the huge AST-node union that every
    // `const e = P.nodes[i]` binds. Restricting to if-expr inits keeps the render off
    // that hot path (the cause of the #494 ~4× self-compile regression).
    let initIf = n.letInit
    if initIf >= 0 {
      const ini0 = P.nodes[initIf]
      if ini0 is Paren { initIf = ini0.parInner }
    }
    let isIfInit = false
    if initIf >= 0 {
      const ini1 = P.nodes[initIf]
      if ini1 is IfStmt { isIfInit = true }
    }
    if isIfInit {
      const lvn = valueUnionRetName(bound)
      if lvn != "" {
        inferLetIx.push(ix)
        inferLetTy.push(lvn)
      } else if isNulStringTy(bound) {
        // `string | null` is a NICHE (not a value-union box) so `valueUnionRetName`
        // renders "" — record it separately for the kind-16 slot classification.
        inferLetNulStrIx.push(ix)
      } else if isNulBoolTy(bound) {
        // `boolean | null` is the OTHER niche (the i32 sentinel-2 rep) — same story,
        // recorded for the niche slot classification (`isInferLetNulBool`).
        inferLetNulBoolIx.push(ix)
      }
    }
  } else {
    tErr("'" + n.letName + "' needs a type annotation or initializer", ix)
  }
  // Same-scope redeclaration (B16): a second `let`/`const` of a name already
  // bound in the INNERMOST scope frame is an error — `let a = 1; let a = 2` in
  // one block silently overwrites otherwise. Only the same frame is rejected;
  // shadowing a name from an OUTER scope in a nested block is legal (the scope
  // chain is innermost-wins), so we check `T.scopes[top].has` — the current
  // frame only — not the full `lookup` chain.
  const dtop = T.scopes.length - 1
  // A module global is pre-declared by the pass-1.5 hoist, so its own pass-2
  // declaration would falsely trip the same-frame redeclare check — skip it there
  // (genuine top-level dups are caught in the hoist). Nested `let`s are unaffected.
  const preHoisted = dtop == 0 && (moduleGlobals[n.letName] ?? false)
  if !preHoisted && T.scopes[dtop].has(n.letName) {
    tErr("redeclared " + n.letName, ix)
  }
  declare(n.letName, bound)
  if symEnabled != 0 { symDecl(n.letName, ix, bound, 0) }
  if n.letKw == "const" {
    const ctop = constScopes.length - 1
    if ctop >= 0 { constScopes[ctop][n.letName] = true }
  }
  // Definite-assignment: an uninitialized `let x` / `let x: T` (no initializer)
  // starts UNASSIGNED; a later read before it is written is an error. An
  // initialized `let x = …` (and every `const`, which must have a value) is
  // assigned from the start, so it is never tracked. A re-declaration that
  // shadows clears any prior assigned/unassigned record under that name.
  daMarkAssigned(n.letName)
  if n.letInit < 0 { daAdd(n.letName) }
  return TY_VOID
}
// ── match ──────────────────────────────────────────────────────────────────

// Extracted from `checkNodeReal`'s `MatchExpr` arm (C3: thin the dispatcher).
function checkMatchExprNode(n: MatchExpr, ix: i32) {
  // `match scrut { pat => body … }` — exhaustive dispatch over a LITERAL UNION (phase 1).
  // Type the scrutinee, check every pattern is a member, enforce EXHAUSTIVENESS (all members
  // covered, or a `_` wildcard) and reject REDUNDANT arms, then join the arm VALUE types so a
  // value-position `match` (`const x = match …`) and a return-tail `match` both type.
  // The scrutinee and the arm bodies are NOT in return-tail position; RESTORE the flag on
  // every exit (mirroring `checkIfStmtNode`) so a `match` subexpression is transparent to a
  // SIBLING in the same statement — a stale `false` re-typed a following else-less tail-`if`
  // as void instead of `then | null`.
  const mTail = retTailPos
  retTailPos = false
  const st = checkNode(n.matchScrut)
  if !tyIsLitUnion(st) {
    tErr("match scrutinee must be a literal union, got " + tyToStr(st), ix)
    retTailPos = mTail
    return TY_ERR
  }
  // The member texts (inner, no quotes), and a parallel covered-flag.
  const members: string[] = []
  const sty = T.tys[st]
  if sty is TyUnion {
    let mi = 0
    while mi < sty.uMembers.length {
      const mm = T.tys[sty.uMembers[mi]]
      if mm is TyLit { members.push(mm.litText) }
      mi = mi + 1
    }
  }
  const covered: i32[] = []
  let ci = 0
  while ci < members.length {
    covered.push(0)
    ci = ci + 1
  }
  let hasWild = false
  // A pattern that is neither a member STRING literal nor the `_` wildcard covers
  // nothing — report it AT THE PATTERN (silently skipping it surfaced later as a
  // misattributed "non-exhaustive match", or as a phantom wildcard for a non-`_`
  // identifier) and suppress the exhaustiveness error below (the bad pattern is
  // the root cause; don't cascade).
  let sawBadPat = false
  // -1 is the "unset" join seed (`joinTys` returns the other operand); the positive TY_ERR
  // sentinel would POISON the join (every arm joins back to error), so never seed with it.
  let matchTy = -1
  let ai = 0
  while ai < n.matchArmStart.length {
    // Patterns of arm `ai`.
    let pj = 0
    while pj < n.matchArmCount[ai] {
      const patIx = n.matchPats[n.matchArmStart[ai] + pj]
      const pn = P.nodes[patIx]
      if pn is Ident {
        // Only `_` is the wildcard; any other identifier is not a pattern VL
        // supports (patterns don't bind) and must not silently cover every member.
        if pn.identName == "_" {
          hasWild = true
        } else {
          sawBadPat = true
          tErr(
            "invalid match pattern `" +
              pn.identName +
              "` — a pattern is a member string literal or the `_` wildcard",
            patIx,
          )
        }
      } else if pn is StrLit {
        // The member name is the pattern's inner text (strip the surrounding quotes).
        const raw = pn.strText
        let inner = raw
        if raw.length >= 2 { inner = raw.slice(1, raw.length - 1) }
        let found = -1
        let fi = 0
        while fi < members.length {
          if members[fi] == inner { found = fi }
          fi = fi + 1
        }
        if found < 0 {
          tErr(
            "match pattern \"" + inner + "\" is not a member of " + tyToStr(st),
            patIx,
          )
        } else if covered[found] == 1 {
          tErr(
            "redundant match arm: \"" + inner + "\" is already covered",
            patIx,
          )
        } else {
          covered[found] = 1
        }
      } else {
        // Any other node kind (a parse-recovered pattern, a future literal form):
        // same story — it covers nothing, so name it rather than mis-blame coverage.
        sawBadPat = true
        tErr(
          "invalid match pattern — a pattern is a member string literal or the `_` wildcard",
          patIx,
        )
      }
      pj = pj + 1
    }
    // Body value type. (Arm bodies are NOT checked in return-tail position; the match's joined
    // value seeds the function return once, below — avoids a per-arm void/err mis-seed.)
    const body = n.matchBodies[ai]
    const bt = checkNode(body)
    let armTy = bt
    const bn = P.nodes[body]
    if bn is Block {
      armTy = blockTailTy
      // A statement-tail block has `blockTailTy == -1` ("no value") — that is VOID, not the
      // sentinel TY_ERR (both are -1), so a void-arm `match` must not be mistaken for an error.
      if armTy < 0 { armTy = TY_VOID }
    }
    matchTy = joinTys(matchTy, armTy)
    ai = ai + 1
  }
  // A void-armed match leaves the join unset (-1) or void; normalize to VOID so the function-
  // body-tail seeding (`noteInferredRet`) does not mistake it for the error sentinel.
  if matchTy < 0 { matchTy = TY_VOID }
  // Exhaustiveness: every member covered, or a wildcard. Skipped after an invalid
  // pattern — that arm covers nothing, so a missing-member report would mis-blame
  // coverage for what the pattern diagnostic already explained.
  if !hasWild && !sawBadPat {
    let missing = ""
    let mk = 0
    while mk < members.length {
      if covered[mk] == 0 {
        if missing != "" { missing = missing + ", " }
        missing = missing + "\"" + members[mk] + "\""
      }
      mk = mk + 1
    }
    if missing != "" {
      tErr(
        "non-exhaustive match — missing " + missing + " (add the arm or a `_`)",
        ix,
      )
    }
  }
  // Lower to an if/else chain in place (real pass only) so lint + emit see only if-chains.
  if !inferQuiet { desugarMatchAt(ix) }
  retTailPos = mTail
  return matchTy
}

// Extracted from `checkNodeReal`'s `IfStmt` arm (C3: thin the dispatcher).
function checkIfStmtNode(n: IfStmt, ix: i32) {
  // An `if`/`else` in VALUE position is an EXPRESSION whose value is the join of its
  // branch tail values (`if c { 1 } else { 2 }` is `i32`). Capture whether THIS `if`
  // sits in the function's return-tail position; the condition itself never does.
  const ifTail = retTailPos
  retTailPos = false
  const condTy = checkNode(n.ifCond)
  if !assignable(condTy, TY_BOOL) {
    tErr("if-condition must be boolean, got " + tyToStr(condTy), ix)
  }
  // Narrowing over a simple identifier:
  //  - `if x is T { … }` refines `x` to the variant `T` in the THEN branch.
  //  - `if x != null { … }` refines a nullable `x` to its inner type in the THEN.
  //  - `if x == null { … } else { … }` refines `x` to inner in the ELSE; and when
  //    the THEN always exits (a guard clause), `x` is inner AFTER the `if` too.
  // Branch narrowing rides a pushed scope that shadows `x`. (Union-complement
  // narrowing after `is T` was tried and REVERTED — it made VL miss real errors;
  // null-stripping is the well-defined core and is what the corpus leans on.)
  // The condition's TRUE narrowings hold in the THEN branch, its FALSE
  // narrowings in the ELSE (and, for a diverging then — a guard clause — for
  // the rest of the enclosing block). The collectors handle `is` / null
  // compares / `&&`-`||` chains / `!(…)` / parens.
  const tnNames: string[] = []
  const tnTys: i32[] = []
  collectThenNarrows(n.ifCond, tnNames, tnTys)
  const enNames: string[] = []
  const enTys: i32[] = []
  collectElseNarrows(n.ifCond, enNames, enTys)
  // Definite-assignment fork/join: each branch is a separate path forked off
  // the if-entry state; after the chain they JOIN. A binding is assigned after
  // the `if` only if assigned on EVERY surviving (non-diverging) path. With no
  // `else`, the implicit fall-through (condition false) is a surviving path
  // that assigns nothing — so a write only inside `if c { x = 1 }` does NOT
  // make `x` assigned afterwards. A branch that always exits (`return`/`break`/
  // `continue`) contributes nothing to the merge (its end is unreachable).
  const daEntry = daSnapshot()
  const daThenDiverges = daBranchDiverges(n.ifThen)
  if tnNames.length > 0 {
    pushScope(-1)
    applyNarrows(tnNames, tnTys)
  }
  retTailPos = ifTail
  checkNode(n.ifThen)
  retTailPos = false
  const thenTy = blockTailTy
  if tnNames.length > 0 { popScope() }
  // SEED the inferred return from the then-branch value BEFORE the else is checked, so
  // a recursive call in the else (`fib(n-1)+fib(n-2)`) resolves against the base-case
  // type (`return n` → i32) instead of an unresolved hole (the #487 mechanism, now
  // reached through an implicit-return branch value, not just an explicit `return`).
  // Seed only from a genuine value-`if` (one WITH an `else` — a no-else `if` is a
  // statement, not a value expression) and only a CONCRETE branch value: a TY_VOID
  // (a statement-tail branch, e.g. a void procedure's recursive tail call) or a still-
  // unresolved TY_ERR (a recursive call with no base case seeded yet) must not be
  // mistaken for the return type, or a void procedure infers a spurious value/error.
  if ifTail && n.ifElse >= 0 {
    if thenTy != TY_VOID && thenTy != TY_ERR { noteInferredRet(thenTy) }
  }
  // Surviving paths' end-states, each as an unassigned snapshot. Seed with the
  // then-branch end if it survived.
  const daThenEnd = daSnapshot()
  daRestore(daEntry)
  let daElseDiverges = false
  let daElseEnd = daEntry
  let elseTy = TY_VOID
  const daHasElse = n.ifElse >= 0
  if daHasElse {
    daElseDiverges = daBranchDiverges(n.ifElse)
    if enNames.length > 0 {
      pushScope(-1)
      applyNarrows(enNames, enTys)
    }
    retTailPos = ifTail
    const elseRes = checkNode(n.ifElse)
    retTailPos = false
    elseTy = blockTailTy
    // An `else if` CHAIN: the else node is an IfStmt whose VALUE is its own branch
    // join (the checkNode result). `blockTailTy` holds only the INNERMOST block's
    // tail, which under-joins a mixed chain (`if a then k else if b then "cc" else
    // k2` joined to the litunion, dropping the string arm — the emitted string ref
    // then flowed into an i32 join).
    const enElse = P.nodes[n.ifElse]
    if enElse is IfStmt { elseTy = elseRes }
    if enNames.length > 0 { popScope() }
    if ifTail {
      if elseTy != TY_VOID && elseTy != TY_ERR { noteInferredRet(elseTy) }
    }
    daElseEnd = daSnapshot()
  }
  // Join the surviving paths. Start from the empty set and fold in every
  // surviving path's unassigned set (the union = "unassigned on some surviving
  // path"). The else path (or, with no `else`, the entry fall-through) always
  // counts unless it diverges.
  daClear()
  if !daThenDiverges { daJoinInto(daThenEnd) }
  if daHasElse {
    if !daElseDiverges { daJoinInto(daElseEnd) }
  } else {
    daJoinInto(daEntry)
  }
  // GUARD CLAUSE: a THEN that always exits applies the FALSE narrowings to
  // the rest of the enclosing block (`if x == null { return } … x.f …`).
  // Host `postGuardNarrowings` parity: only a SINGLE-arm `if` with NO `else`
  // (an `else`/`else if` chain does not post-narrow the fall-through), and
  // only ONE union SUBTRACTION per place per block — the host checker accepts
  // a twice-subtracted residual but both codegens reject it
  // (xfail-seq-guard-residual-codegen), so the front end keeps rejecting the
  // second subtraction. Null-STRIPS always apply (guard sequences rely on
  // them). Path-keyed entries unwind at the ENCLOSING scope's `popScope`.
  if enNames.length > 0 && !daHasElse {
    const tn2 = P.nodes[n.ifThen]
    if tn2 is Block {
      const tst = tn2.blkStmts
      if tst.length > 0 {
        const last = P.nodes[tst[tst.length - 1]]
        let diverges = false
        if last is RetStmt { diverges = true }
        else if last is BreakStmt { diverges = true }
        else if last is ContinueStmt { diverges = true }
        if diverges {
          let gi2 = 0
          while gi2 < enNames.length {
            const gKey = enNames[gi2]
            const gTy = enTys[gi2]
            if isPathKey(gKey) {
              npKeys.push(gKey)
              npTys.push(gTy)
            } else if gTy == nonNullTy(lookup(gKey)) {
              declare(gKey, gTy)
            } else {
              let gSeen = false
              let gj = 0
              while gj < pgKeys.length {
                if pgKeys[gj] == gKey { gSeen = true }
                gj = gj + 1
              }
              if !gSeen {
                pgKeys.push(gKey)
                declare(gKey, gTy)
              }
            }
            gi2 = gi2 + 1
          }
        }
      }
    }
  }
  retTailPos = ifTail
  // The `if`-expression's VALUE type: the join of the two branch tail values. With no
  // `else` the `if` may not yield a value (the fall-through has none), so it is valueless
  // (TY_VOID) — a value-position use without `else` stays as before. A statement `if`
  // (void branches) joins to TY_VOID, unchanged.
  if daHasElse { return joinTys(thenTy, elseTy) }
  // An else-less `if` in RETURN-TAIL position: the false fall-through yields no value —
  // that path is `null` (exactly the #484 function fall-through), so the function's
  // return is `thenTy | null`. The emitter routes this to `emitIfTail` (the then-arm
  // returns the value; the false path falls through to the function-end null padding,
  // `emitNullForRet`). Outside tail position (an inline `const x = if c then 5`) the
  // emitter can't yet leave a nullable value on the stack, so it stays TY_VOID — a clean
  // "cannot assign void" at the use site, pending a typed-blocktype if-expression.
  if ifTail && thenTy != TY_VOID && thenTy != TY_ERR {
    return mkNullableTy(thenTy)
  }
  return TY_VOID
}
// ── explicit numeric cast `x as T` ──────────────────────────────────────────

// `x as T` (B2) is an explicit, CHECKED numeric conversion. Unlike the implicit
// lossless-widening rule (`numWidensName`, which permits only i32→i64, i32→f64,
// f32→f64), `as` permits EVERY numeric-scalar direction: those widenings PLUS the
// lossy widenings (i64→f64, i32→f32, i64→f32), the narrowings (i64→i32 wrap,
// f64→f32 demote) and int↔float conversions — that explicitness is the whole
// point. The float→int forms trap at runtime on NaN / out-of-range (see emit).
// `as` is numeric-only for now: a non-numeric operand OR target is a type error.
// The cast expression's type is exactly `T`.
function checkCastNode(n: AsExpr, ix: i32) {
  const arg = checkNode(n.asObj)
  const target = nameToTyAt(n.asTy, ix)
  if target < 0 {
    tErr("unknown type `" + n.asTy + "` in `as` cast", ix)
    return TY_ERR
  }
  // The TARGET must be a concrete numeric scalar (strict — `primNameOf` skips
  // arrays/objects/unions/type-vars). The OPERAND uses the tolerant `isNumeric`
  // (true for `TyErr`), so an already-errored operand does not pile on a second
  // diagnostic here.
  const tn = primNameOf(target)
  const targetIsScalar = tn == "i32" ||
    tn == "i64" ||
    tn == "f32" ||
    tn == "f64"
  if !isNumeric(arg) || !targetIsScalar {
    tErr("`as` supports numeric conversions only", ix)
    return TY_ERR
  }
  target
}

// ── unary ──────────────────────────────────────────────────────────────────

// Extracted from `checkNodeReal`'s `Unary` arm (C3: thin the dispatcher).
function checkUnaryNode(n: Unary, ix: i32) {
  const arg = checkNode(n.unArg)
  if n.unOp == "!" {
    if !assignable(arg, TY_BOOL) {
      tErr("operator '!' expects boolean, got " + tyToStr(arg), ix)
    }
    return TY_BOOL
  }
  // Postfix `x++` / `x--` (`"p+"`/`"p-"`): `unArg` is the `x = x ± 1` assignment,
  // already fully checked by `checkNode` above (const-reassign, numeric arithmetic,
  // assignability). The postfix expression's type is that of the operand.
  if n.unOp == "p+" || n.unOp == "p-" {
    if !isNumeric(arg) {
      tErr("'++'/'--' expects a numeric variable, got " + tyToStr(arg), ix)
      return TY_ERR
    }
    return arg
  }
  // "-"
  if !isNumeric(arg) {
    tErr("unary '-' expects a numeric type, got " + tyToStr(arg), ix)
    return TY_ERR
  }
  // Host parity: the host folds `-lit` into a signed literal BEFORE defaulting,
  // so `-2147483648` (magnitude 2^31, one past I32_MAX) sits at I32_MIN and is
  // i32 — even though the bare operand literal alone types i64.
  if n.unOp == "-" {
    if isNegI32MinLit(n.unArg) { return TY_I32 }
  }
  return arg
}
// ── member `o.field` ───────────────────────────────────────────────────────

// Extracted from `checkNodeReal`'s `Member` arm (C3: thin the dispatcher).
function checkMemberNode(n: Member, ix: i32) {
  // A flow-narrowed property path (`if o.v is T { … }`) overrides the stored
  // field type within the branch (the host's `narrowedPaths` overlay).
  const mKey = placeKeyOf(ix)
  if mKey != "" {
    const mOv = narrowedPathTy(mKey)
    if mOv >= 0 { return symMem(ix, mOv) }
  }
  const objTy = checkNode(n.memObj)
  // A NEGATIVE receiver type is an unpinned inference hole (the `-1` element
  // of a never-pinned empty `[]` read back through `xs[i]`), not an arena
  // index — indexing `T.tys` with it would CRASH. The hole itself is already
  // reported (`flushUninferred` / the unknown-annotation path), so don't
  // cascade.
  if objTy < 0 { return TY_ERR }
  const ot = T.tys[objTy]
  if ot is TyObj {
    const ft = objFieldType(ot, n.memProp)
    if ft < 0 {
      tErr("no field '" + n.memProp + "' on " + tyToStr(objTy), ix)
      return TY_ERR
    }
    return symMem(ix, ft)
  }
  if ot is TyErr { return TY_ERR }
  // SHARED-FIELD ACCESS over a struct union — `(A | B).tag` when every
  // member carries the field at the same type (the host's
  // `sharedUnionField`); an unshared field still needs an `is` narrowing.
  if ot is TyUnion {
    const sf = sharedUnionFieldTy(ot, n.memProp)
    if sf >= 0 { return symMem(ix, sf) }
    // The field is on SOME but not all members of the union — reading it is
    // unsafe until the value is narrowed (`is`) to a member that has it.
    // (NOT "non-object": the members ARE objects; the field just isn't shared.)
    tErr(
      "field '" +
        n.memProp +
        "' is not on every member of " +
        tyToStr(objTy) +
        " — narrow with `is` first",
      ix,
    )
    return TY_ERR
  }
  // `.length` on an array, a map, or a string is an i32.
  if ot is TyArray {
    if n.memProp == "length" { return symMem(ix, TY_I32) }
    tErr("no field '" + n.memProp + "' on array " + tyToStr(objTy), ix)
    return TY_ERR
  }
  if ot is TyMap {
    // `.length` and `.size` are both the live-entry count (an i32) — `.size` is the
    // JS Map/Set name, `.length` the list-consistent alias; both read the same field.
    if n.memProp == "length" { return symMem(ix, TY_I32) }
    if n.memProp == "size" { return symMem(ix, TY_I32) }
    tErr("no field '" + n.memProp + "' on map " + tyToStr(objTy), ix)
    return TY_ERR
  }
  if ot is TyPrim {
    if ot.primName == "string" {
      if n.memProp == "length" { return symMem(ix, TY_I32) }
      tErr("no field '" + n.memProp + "' on string", ix)
      return TY_ERR
    }
  }
  // Member access on an INFERENCE HOLE (`self.x` where `self` is the
  // un-annotated param hole `?add.0` — host: `getChildType` pins the
  // `Infer<Unknown>` to a growing object shape): record the demanded field
  // and yield its derived hole; the call site pins both (A13).
  if ot is TyVar {
    if ot.tvName.length > 0 {
      if ot.tvName[0] == '?' {
        // `.length` is the i32 length an array / string / map exposes — treat it as that
        // (not a struct field) so an un-annotated param used as a collection (`self[i]` +
        // `self.length`) infers without growing a bogus `{length}` shape that an array
        // argument can't satisfy. A NON-length field still grows the hole's struct shape.
        if n.memProp == "length" { return symMem(ix, TY_I32) }
        return symMem(ix, holeMemberTy(ot.tvName, n.memProp))
      }
    }
  }
  tErr("member access '." + n.memProp + "' on non-object " + tyToStr(objTy), ix)
  return TY_ERR
}
// ── array literal ───────────────────────────────────────────────────────────
// `[e, e, …]` types as `T[]` where `T` is the first element's type (the rest must
// be assignable to it). An empty `[]` is `T[]` with an unknown element (`-1`),
// assignable to any array — its concrete element is pinned by the binding's
// annotation (`let a: i32[] = []`).

// Extracted from `checkNodeReal`'s `ArrayLit` arm (C3: thin the dispatcher).
function checkArrayLitNode(n: ArrayLit, _ix: i32) {
  const elems = n.arrElems
  if elems.length < 1 { return mkArrayTy(-1) }
  let elemTy = checkNode(elems[0])
  let ei = 1
  while ei < elems.length {
    const et = checkNode(elems[ei])
    // Host parity: the element type is the UNION of every element's type
    // (flattened/deduped) — `[a, b, c]` over mixed struct variants types as
    // `(A | B | C)[]`; an annotation then checks each member structurally.
    elemTy = joinTys(elemTy, et)
    ei = ei + 1
  }
  return mkArrayTy(elemTy)
}
// ── index `a[i]` ────────────────────────────────────────────────────────────

// Extracted from `checkNodeReal`'s `Index` arm (C3: thin the dispatcher).
function checkIndexNode(n: Index, ix: i32) {
  const arrTy = checkNode(n.idxArr)
  const idxTy = checkNode(n.idxIndex)
  // Guard the unpinned-hole receiver (`-1` — see the Member-arm note).
  if arrTy < 0 { return TY_ERR }
  const at = T.tys[arrTy]
  // A MAP index `m[k]`: the key must match the map's key type; a READ yields the
  // NULLABLE value (`V | null` — the key may be absent; default with `??`), and an
  // assignment target `m[k] = v` accepts a plain `V` (assignable to `V | null`).
  if at is TyMap {
    if !assignable(idxTy, at.mKey) {
      tErr(
        "map key must be " + tyToStr(at.mKey) + ", got " + tyToStr(idxTy),
        ix,
      )
    }
    return mkNullableTy(at.mVal)
  }
  // Indexing an un-annotated-param HOLE (`self[i]`) constrains it to an array: demand an
  // i32 index and return the element as a DERIVED hole (`?elem.<hole>`), resolved per call
  // site against the pinned array's element (`substHoleByName`). Mirrors `holeMemberTy`
  // for `self.x`, so an un-annotated `function head(self) { return self[0] }` infers.
  if at is TyVar {
    if !assignable(idxTy, TY_I32) {
      tErr("array index must be i32, got " + tyToStr(idxTy), ix)
    }
    noteArrayDemand(at.tvName)
    return mkTyVar("?elem." + at.tvName)
  }
  // Index TRAP (B13, host parser `indexTrap`): a user object that declares a
  // `"[]"` method handles `o[k]` itself — the key checks against the
  // method's parameter (so an i32-keyed trap indexed with a string REJECTS,
  // index/wrong-key-type.vl), the result is its return. Checked BEFORE the
  // native i32-index rule (a trap key may be any type); a struct with no
  // `"[]"` falls through to the cannot-index error. Write traps (`o[k] = v`)
  // check in the assignment arm against `"[]="`.
  if at is TyObj {
    const trap = objFieldType(at, "[]")
    if trap >= 0 {
      const tt = T.tys[trap]
      if tt is TyFunc {
        if tt.fnParamTypes.length == 1 {
          if !assignableExpr(n.idxIndex, idxTy, tt.fnParamTypes[0]) {
            tErr(
              "index: expected " +
                tyToStr(tt.fnParamTypes[0]) +
                ", got " +
                tyToStr(idxTy),
              ix,
            )
          }
          return tt.fnRet
        }
      }
    }
    tErr("cannot index non-array " + tyToStr(arrTy), ix)
    return TY_ERR
  }
  if !assignable(idxTy, TY_I32) {
    tErr("array index must be i32, got " + tyToStr(idxTy), ix)
  }
  if at is TyArray { return at.aElem }
  if at is TyErr { return TY_ERR }
  // Indexing a string yields the i32 code point at that position.
  if at is TyPrim {
    if at.primName == "string" { return TY_I32 }
  }
  tErr("cannot index non-array " + tyToStr(arrTy), ix)
  return TY_ERR
}
// ── object literal ──────────────────────────────────────────────────────────
// `{ x: e, y: e }` types as a structural `TyObj` whose fields carry each value's
// checked type. Assignability against an annotation/param/return then matches it
// to a declared struct by structure (`assignable`), so field ORDER need not match
// the declaration. Reads each FieldInit child INLINE (Finding 2).

// Extracted from `checkNodeReal`'s `ObjLit` arm (C3: thin the dispatcher).
function checkObjLitNode(n: ObjLit, _ix: i32) {
  const fields = n.objFields
  const fnames: string[] = []
  const ftys: i32[] = []
  let i = 0
  while i < fields.length {
    const fnode = P.nodes[fields[i]]
    if fnode is FieldInit {
      fnames.push(fnode.fiName)
      ftys.push(checkNode(fnode.fiValue))
    }
    i = i + 1
  }
  return mkObjTy(fnames, ftys)
}
// ── type guard `x is T` ─────────────────────────────────────────────────────
// Always a `bool`. Checks the operand and that `T` names a known type. The actual
// narrowing of `x` to `T` happens in the THEN branch of an enclosing `if` (see the
// IfStmt case); used elsewhere it is just a boolean test.

// Extracted from `checkNodeReal`'s `IsExpr` arm (C3: thin the dispatcher).
function checkIsExprNode(n: IsExpr, ix: i32) {
  const objTy = checkNode(n.isObj)
  const chkTy = nameToTy(n.isVariant)
  if chkTy < 0 {
    tErr("unknown type '" + n.isVariant + "' in 'is'", ix)
  } else if n.isVariant != "null" {
    // SOUNDNESS: `x is T` is meaningful only when `T` is one of the value's
    // possible variants (or `null`). When the value's type is a union/nullable,
    // the check type must be assignable to its non-null part — otherwise the
    // test can never hold (e.g. `(string | i32) is boolean`, or a struct outside
    // the union), so reject it rather than compile an always-false branch. Only
    // a union/nullable value is "testable"; a plain (incl. generic/inferred)
    // operand is left alone, matching the host.
    const ot = T.tys[objTy]
    let testable = false
    let baseTy = objTy
    if ot is TyUnion {
      testable = true
    } else if ot is TyNullable {
      testable = true
      baseTy = ot.nInner
    }
    if testable {
      if !assignable(chkTy, baseTy) {
        tErr(
          "`is` check type '" +
            n.isVariant +
            "' is not a variant of " +
            tyToStr(objTy),
          ix,
        )
      }
    }
  }
  return TY_BOOL
}
// ── optional member `o?.field` ─────────────────────────────────────────────
// Null-safe access: a NULLABLE receiver reads the field off its inner type and
// re-wraps the result nullable (`{x: i32} | null` ?. x → `i32 | null`); a
// non-null receiver behaves like a plain member read.

// Extracted from `checkNodeReal`'s `OptMember` arm (C3: thin the dispatcher).
function checkOptMemberNode(n: OptMember, ix: i32) {
  // `x?.y` keys the same narrowed place as `x.y` (host `placeKey`).
  const omKey = placeKeyOf(ix)
  if omKey != "" {
    const omOv = narrowedPathTy(omKey)
    if omOv >= 0 { return symMem(ix, omOv) }
  }
  const recv = checkNode(n.omObj)
  // Guard the unpinned-hole receiver (`-1` — see the Member-arm note).
  if recv < 0 { return TY_ERR }
  const rcv = T.tys[recv]
  let wasNullable = false
  let baseTy = recv
  if rcv is TyNullable {
    wasNullable = true
    baseTy = rcv.nInner
    // Peel a SECOND nullable layer too: the host's `flattenType` collapses
    // `T??` to `T?`, so a doubly-nullable receiver (`m[k]?.v` off a nullable
    // map read) still reads its field with one `?.`.
    if baseTy >= 0 {
      const rcv2 = T.tys[baseTy]
      if rcv2 is TyNullable { baseTy = rcv2.nInner }
    }
  }
  if baseTy < 0 { return TY_ERR }
  const bt = T.tys[baseTy]
  if bt is TyObj {
    const oft = objFieldType(bt, n.omProp)
    if oft < 0 {
      tErr("no field '" + n.omProp + "' on " + tyToStr(baseTy), ix)
      return TY_ERR
    }
    if wasNullable { return symMem(ix, mkNullableTy(oft)) }
    return symMem(ix, oft)
  }
  if bt is TyErr { return TY_ERR }
  // Shared union field through `?.` — same rule as the plain member read.
  if bt is TyUnion {
    const osf = sharedUnionFieldTy(bt, n.omProp)
    if osf >= 0 {
      if wasNullable { return symMem(ix, mkNullableTy(osf)) }
      return symMem(ix, osf)
    }
  }
  tErr("member access '?." + n.omProp + "' on non-object " + tyToStr(recv), ix)
  return TY_ERR
}

// Extracted from `checkNodeReal`'s `WhileStmt` arm (C3: thin the dispatcher).
function checkWhileStmtNode(n: WhileStmt, ix: i32) {
  const wc = checkNode(n.whileCond)
  if !assignable(wc, TY_BOOL) {
    tErr("while-condition must be boolean, got " + tyToStr(wc), ix)
  }
  // Definite-assignment: a loop body may run ZERO times, so an assignment
  // inside it is NOT guaranteed to reach code after the loop. Check the body
  // with the live state (so a read AFTER an in-body assignment is fine), then
  // RESTORE the pre-loop state for the fall-through.
  const daLoopEntry = daSnapshot()
  checkNode(n.whileBody)
  daRestore(daLoopEntry)
  return TY_VOID
}
// ── for range ──────────────────────────────────────────────────────────────
// Extracted from `checkNodeReal`'s `ForRange` arm (C3: thin the dispatcher).
function checkForRangeNode(n: ForRange, ix: i32) {
  const frFrom = checkNode(n.frFrom)
  const frTo = checkNode(n.frTo)
  if !assignable(frFrom, TY_I32) || !assignable(frTo, TY_I32) {
    tErr(
      "for-range bounds must be i32, got " +
        tyToStr(frFrom) +
        " and " +
        tyToStr(frTo),
      ix,
    )
  }
  if n.frStep >= 0 {
    const frStep = checkNode(n.frStep)
    if !assignable(frStep, TY_I32) {
      tErr("for-range step must be i32, got " + tyToStr(frStep), ix)
    }
    // A range `for` with a LITERAL `step 0` never advances its loop variable —
    // a degenerate / infinite loop. Catch only a literal integer 0 (a negative
    // step parses as a Unary wrapping the NumLit, and a runtime-0 step is not
    // statically known, so neither is matched here).
    const stepNode = P.nodes[n.frStep]
    if stepNode is NumLit {
      if stepNode.numText == "0" { tErr("`for` step is 0", n.frStep) }
    }
  }
  pushScope(ix)
  declare(n.frVar, TY_I32)
  if symEnabled != 0 { symDecl(n.frVar, ix, TY_I32, 0) }
  // Loop body may run zero times — see `WhileStmt` (A-definite-assign).
  const daFrEntry = daSnapshot()
  // The loop variable is always assigned in the body; clear it from the dead-zone
  // so a body read isn't flagged when the loop var SHADOWS a still-uninitialized
  // module global of the same name (the `daRestore` below preserves that global's
  // TDZ for any post-loop read).
  daMarkAssigned(n.frVar)
  checkNode(n.frBody)
  daRestore(daFrEntry)
  popScope()
  return TY_VOID
}
// ── for v in iterable ───────────────────────────────────────────────────────
// A for-in loop over an array: the loop variable binds to the element type.

// Extracted from `checkNodeReal`'s `ForIn` arm (C3: thin the dispatcher).
function checkForInNode(n: ForIn, ix: i32) {
  const iterTy = checkNode(n.fiIter)
  let elemTy = TY_ERR
  const it = T.tys[iterTy]
  if it is TyArray {
    elemTy = it.aElem
  } else if it is TyMap {
    // `for k in m` over a map / set iterates its KEYS (the key type) — like
    // `for k in m.keys()`.
    elemTy = it.mKey
  } else if isStringTy(iterTy) {
    // `for ch in s` iterates a STRING's code units — each an i32, exactly as `s[i]`
    // reads one. A string IS the raw i32 array at the wasm level, so this rides the
    // same element-iteration machinery as an `i32[]`.
    elemTy = TY_I32
  } else if it is TyErr {
    elemTy = TY_ERR
  } else {
    tErr("for-in expects an array or map, got " + tyToStr(iterTy), ix)
  }
  pushScope(ix)
  declare(n.fiVar, elemTy)
  if symEnabled != 0 { symDecl(n.fiVar, ix, elemTy, 0) }
  // Loop body may run zero times — see `WhileStmt` (A-definite-assign).
  const daFiEntry = daSnapshot()
  // See ForRange: clear the loop var from the dead-zone for the body so it can't
  // collide with a shadowed, still-uninitialized module global of the same name.
  daMarkAssigned(n.fiVar)
  checkNode(n.fiBody)
  daRestore(daFiEntry)
  popScope()
  return TY_VOID
}
// ── return ─────────────────────────────────────────────────────────────────

// Extracted from `checkNodeReal`'s `RetStmt` arm (C3: thin the dispatcher).
function checkRetStmtNode(n: RetStmt, ix: i32) {
  const want = T.curRet
  if n.retArg < 0 {
    if want >= 0 && !assignable(TY_VOID, want) {
      tErr("return needs a value of type " + tyToStr(want), ix)
    }
    return TY_VOID
  }
  // Under a PENDING return type (-2: this function's return is being inferred),
  // record the returned type as a witness instead of checking a mismatch.
  if want == -2 {
    // `return <expr>` is always a value return position.
    fnSawValueRet = true
    noteInferredRet(checkNode(n.retArg))
    return TY_VOID
  }
  // Bidirectional: `function mk(): (i32) => i32 { return (x) => … }` infers the returned
  // lambda's param from the declared return type (also through a composite return shape).
  if want >= 0 { seedExpected(n.retArg, want) }
  const got = checkNode(n.retArg)
  // Redundant-return rule: witness the explicit return's NATURAL type (before
  // constrainEmpty); an annotation-influenced return disqualifies the function.
  if retInfluencedByAnnot(n.retArg) { retNaturalErr = true }
  noteNaturalRet(got)
  // An explicit `return inner` of an empty collection pins its element from the
  // declared return type — usage-driven inference clearing the floor.
  constrainEmpty(got, want)
  if want >= 0 && !assignableExpr(n.retArg, got, want) {
    tErr(
      "return type mismatch: expected " + tyToStr(want) + ", got " + tyToStr(got),
      ix,
    )
  }
  return TY_VOID
}
// ── block ─────────────────────────────────────────────────────────────────

// Extracted from `checkNodeReal`'s `Block` arm (C3: thin the dispatcher).
function checkBlockNode(n: Block, ix: i32) {
  pushScope(ix)
  const stmts = n.blkStmts
  const savedRTP = retTailPos
  let tailTy = TY_VOID
  let i = 0
  while i < stmts.length {
    // Only the LAST statement is the block's value (and inherits tail position); the
    // rest are not the block's value, so they never carry the return tail.
    if i == stmts.length - 1 {
      retTailPos = savedRTP
    } else {
      retTailPos = false
    }
    const sty = checkNode(stmts[i])
    if i == stmts.length - 1 {
      // A value-producing trailing expression is the block's value; a trailing
      // STATEMENT (return / let / assignment / loop) leaves the block valueless.
      if !isStmtNode(stmts[i]) {
        tailTy = sty
      } else {
        // An if-EXPRESSION tail (`{ … if c { v1 } else { v2 } }`) IS the block's value, even
        // though an `IfStmt` is otherwise a statement node — `checkNode` already returned the
        // arms' join (`joinTys`). Non-void only for a genuine value-`if` WITH an else (a
        // statement-`if`/else-less tail stays valueless), so a nested if-expression as an
        // if-expression ARM (`if c { if d { 1 } else { 2 } } else { 3 }`) types as a value.
        const lastN2 = P.nodes[stmts[i]]
        if lastN2 is IfStmt {
          if lastN2.ifElse >= 0 {
            if sty != TY_VOID && sty != TY_ERR { tailTy = sty }
          }
        }
      }
    }
    i = i + 1
  }
  retTailPos = savedRTP
  popScope()
  blockTailTy = tailTy
  return TY_VOID
}
