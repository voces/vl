// A type-checker for a meaningful subset of VL, written in VL
// (Track H / H3 self-hosting — the compiler stage after the lexer and parser).
//
// Side-by-side with `compiler/typecheck.ts`, whose SHAPE it follows (a type
// algebra, a scope chain, inference from initializers, structural assignability,
// a diagnostics channel) but reimplemented idiomatically for VL — it is NOT a
// transliteration. VL has no module system yet, so the TS driver
// (`tests/selfhost_typecheck_test.ts`) concatenates `compiler/ast.vl`,
// `compiler/parser.vl`, this file, then a `.vl` harness before compiling, so the
// AST types/constructors, the global parser state `P`, the parse entry points,
// and `i32ToStr` are already in scope. The checker consumes the REAL parser's
// node arena (`P.nodes`): it lexes nothing and parses nothing itself, it walks
// the union AST the parser built.
//
// ── Finding 1 — the type algebra is a TYPE ARENA ─────────────────────────────
// VL's `compiler/typecheck.ts` represents types as a RECURSIVE union `VLType`
// whose members nest more `VLType`s (an `Object` property's type is a `VLType`, a
// `Function`'s return is a `VLType`). That encoding is NOT expressible in VL: a
// `type` union alias cannot self- or forward-reference its own members (the same
// limitation that forced the AST to use arena indices for child nodes — see
// `ast.vl`). So types live in their OWN flat arena `T.tys: Ty[]` and every place
// a type would nest another type holds an `i32` INDEX into that arena instead:
//   - `TyObj.objFieldTypes : i32[]`  (a field's type is a type-arena index)
//   - `TyFunc.fnParamTypes : i32[]`, `TyFunc.fnRet : i32`
//   - `TyUnion.uMembers : i32[]`, `TyNullable.nInner : i32`
// This is the same workaround the AST node arena uses, applied to the type
// algebra — the predicted gap, now confirmed (PR gap inventory #1).
//
// ── Finding 2 (RESOLVED) — the mono-visitor constraint is lifted ─────────────
// Historically, two distinct functions that `is`-narrowed the SAME union and were
// mutually recursive through it MISCOMPILED ("Object has no field …"), which forced
// every per-variant body to be INLINED into the single `checkNode` mega-function.
// That host bug is FIXED — pinned by `tests/cases/types/union-two-visitors.vl` and
// `union-narrowed-helper-recursion.vl` — so the visitor is now factored naturally:
// per-kind helpers (`checkCallNode`, `checkFuncDeclNode`, `checkProgramNode`) take
// the NARROWED variant as a struct parameter, narrow further `Node` children
// themselves, and recurse back through `checkNode`. Remaining small arms stay
// inline in `checkNode` for readability, not out of necessity.
//
// Checker state lives in the global `T` (a `Checker` struct), like the parser's
// `P` — a style choice for call-site brevity. (The old struct-param-into-recursive-
// group miscompile is also fixed, pinned by
// `tests/cases/functions/struct-param-mutual-recursion-global.vl`.)

// The AST data layer (`compiler/ast.vl`): the global parser state `P` (whose
// `P.nodes` arena the checker walks), the int→string helper, and every `Node`
// variant type the single `checkNode` visitor `is`-narrows. The checker's own
// `Ty` type algebra stays PRIVATE to this module.
import { P, i32ToStr } from "./ast"
import {
  NumLit,
  StrLit,
  CharLit,
  BoolLit,
  NullLit,
  Ident,
  Unary,
  BinExpr,
  Call,
  Member,
  OptMember,
  Paren,
  ErrExpr,
  LetDecl,
  Param,
  TypeRef,
  FuncDecl,
  IfStmt,
  RetStmt,
  Block,
  Program,
  TypeDecl,
  FieldDef,
  ObjLit,
  FieldInit,
  UnionDecl,
  IsExpr,
  ArrayLit,
  Index,
  WhileStmt,
  BreakStmt,
  ContinueStmt,
  ForRange,
  ForIn,
} from "./ast"

// ── Type-arena variants ──────────────────────────────────────────────────────
// One struct per type KIND, prefixed field names so `is` discriminates the union
// (the AST's convention). A nested type is always an `i32` index into `T.tys`.

// A primitive: `primName` is one of "i32" | "f64" | "bool" | "string" | "void".
type TyPrim = { primName: string }
// The error/unknown type — produced on a type failure so checking continues
// without cascading (akin to TS `Never`/`Unknown`); assignable to/from anything.
type TyErr = { errKind: string }
// A structural object: parallel arrays of field names and their type-arena
// indices. (Constructed by the harness to seed object-typed bindings; the parser
// subset has no object-type literal syntax yet, so it is not built from source.)
type TyObj = { objFieldNames: string[], objFieldTypes: i32[] }
// A function: parameter type indices and a return type index.
type TyFunc = { fnParamTypes: i32[], fnRet: i32 }
// A union `A | B | …`: member type-arena indices.
type TyUnion = { uMembers: i32[] }
// A nullable `T?` / `T | null`: the inner type-arena index.
type TyNullable = { nInner: i32 }
// A growable array `T[]`: the element type-arena index (`-1` for an empty `[]`
// whose element is not yet known — assignable to any array, like a hole).
type TyArray = { aElem: i32 }
// A string-keyed map `{[K]: V}` or a Set over it: key and value type-arena
// indices (`-1` for the holes of a bare `Map()`/`Set()`, pinned by the binding
// annotation or the first `.set`/`.add`). `mSet` is 1 for the SET flavor — a set
// is internally a boolean-valued map but exposes ONLY `.add`/`.has`/`.delete`/
// `.length`/`.values()` (the Map surface — `.set`/`.get`/`.keys` — must not leak).
type TyMap = { mKey: i32, mVal: i32, mSet: i32 }
// A generic TYPE PARAMETER (`T` in `function id<T>(x: T): T`): opaque inside the
// generic body (assignable both ways, like the err hole); at a CALL site each
// TyVar param BINDS to its argument's type and the return substitutes through.
type TyVar = { tvName: string }

// The unified type. Declared after its members (a union alias can't forward-
// reference). Discriminated with `is`, exactly like the AST `Node`.
type Ty = TyPrim |
  TyErr |
  TyObj |
  TyFunc |
  TyUnion |
  TyNullable |
  TyArray |
  TyMap |
  TyVar

// A type diagnostic: a message plus the AST node index it was raised at. VL has
// no exceptions, so errors are accumulated on `T.diags`, not thrown.
type TDiag = { tmsg: string, tat: i32 }

// ── Checker state (one struct, held in the global `T`) ───────────────────────
// `tys`     — the type arena (every type is an index into it).
// `scopes`  — the scope chain: an array of `name → type-index` maps. Index 0 is
//             the global scope; entering a block/function pushes a fresh map,
//             leaving pops it. Shadowing is innermost-wins lookup.
// `diags`   — accumulated diagnostics.
// `curRet`  — the type-arena index of the enclosing function's return type while
//             checking its body (`-1` outside any function), so `return e` can be
//             checked against it.
type Checker = {
  tys: Ty[],
  scopes: {[string]: i32}[],
  diags: TDiag[],
  curRet: i32,
}

// The single checker instance. The harness calls `initChecker()` then the entry
// point `checkProgram(root)` and reads `T.diags`.
export let T: Checker = { tys: [], scopes: [], diags: [], curRet: -1 }

// `cUserTypes` — declared struct/union types: a `name → type-arena index` map built
// in a pre-pass over the program's `type` declarations (so a struct name in a
// param/return/let annotation, or in a later struct's field, resolves). A MODULE
// GLOBAL rather than a `Checker` field: the emitter handles a bare-map global but not
// a bare-map struct field, and there is exactly one checker instance, so this is
// equivalent (and keeps the full compiler self-emittable). Reset by `initChecker`.
let cUserTypes: {[string]: i32} = Map()

// The const-binding chain, PARALLEL to `T.scopes`: each frame records which of
// its names were bound `const` (immutable NAME, not immutable data — a field
// write through a const stays legal). Kept module-level (not a `Checker` field)
// so the exported struct shape is unchanged.
let constScopes: {[string]: boolean}[] = []

// UN-INFERRED EMPTY-COLLECTION FLOOR (mirrors the host's `reportUninferredBinding`
// in `compiler/typecheck.ts`): an un-annotated empty `[]` / `Map()` / `Set()` whose
// element/key/value hole is never pinned — by an annotation or a downstream
// `.push`/`.set`/`.add` — has a genuinely unknown type. We can't decide that at the
// declaration (a later use may still pin it), so each such binding is RECORDED here
// (its name, its type-arena index, the decl node) and re-examined at scope close /
// program end: if the hole is STILL open (`aElem < 0`, or `mKey`/`mVal < 0`), it
// "cannot be inferred" and an annotation is required. Three parallel arrays + a
// per-record scope-depth, flushed by `flushUninferred(depth)` (avoids a nested
// `Pending[][]`). An ANNOTATED empty collection never lands here (the binding takes
// the annotation's element type), so the compiler's own annotated `let x: T[] = []`
// / `Map()` / `Set()` bindings are untouched.
let pendNames: string[] = []
let pendTys: i32[] = []
let pendAts: i32[] = []
let pendDepths: i32[] = []

// Record an un-annotated empty-collection binding for the deferred scope-close check.
function notePending(name: string, ty: i32, at: i32): i32 {
  pendNames.push(name)
  pendTys.push(ty)
  pendAts.push(at)
  pendDepths.push(T.scopes.length - 1)
  0
}

// Does type-arena index `ty` still reach an UNRESOLVED collection hole — an empty
// `[]` element (`aElem < 0`) or a bare `Map()`/`Set()` key/value (`mKey`/`mVal < 0`)
// that no annotation or downstream use ever pinned? Mirrors the host's
// `containsUnresolvedHole`, but over the arena's `-1` hole sentinel.
function unresolvedHole(ty: i32): boolean {
  if ty < 0 {
    return false
  }
  let t = T.tys[ty]
  if t is TyArray {
    return t.aElem < 0
  }
  if t is TyMap {
    return t.mKey < 0 || t.mVal < 0
  }
  false
}

// USAGE-DRIVEN INFERENCE through a TYPED context: when an empty `[]` / bare
// `Map()`/`Set()` (open holes) flows into a slot with a concrete shape — a `T[]`
// param at a call site, an annotated assignment (`const ys: i32[] = zs`), or a
// `T[]`-returning tail — PIN the source's open holes to the destination's, in place,
// so the binding is no longer uninferable. Mirrors the host's `constrainElementHole`.
// A no-op unless the source is an array/map with an open hole and the destination
// supplies the matching shape; recurses into element types so a nested empty pins too.
function constrainEmpty(srcTy: i32, dstTy: i32): i32 {
  if srcTy < 0 || dstTy < 0 {
    return 0
  }
  let s = T.tys[srcTy]
  let d = T.tys[dstTy]
  if s is TyArray {
    if d is TyArray {
      if s.aElem < 0 {
        s.aElem = d.aElem
      } else {
        constrainEmpty(s.aElem, d.aElem)
      }
    }
    return 0
  }
  if s is TyMap {
    if d is TyMap {
      if s.mKey < 0 {
        s.mKey = d.mKey
      }
      if s.mVal < 0 {
        s.mVal = d.mVal
      }
    }
    return 0
  }
  0
}

// Flush every pending binding recorded at scope `depth` (called just before the
// scope is popped, and for the global scope at program end). A binding whose hole is
// still open at this point will never be pinned, so report the unified
// "cannot infer a type" diagnostic — the same wording the host raises.
function flushUninferred(depth: i32): i32 {
  let keepN: string[] = []
  let keepT: i32[] = []
  let keepA: i32[] = []
  let keepD: i32[] = []
  let i = 0
  while i < pendNames.length {
    if pendDepths[i] == depth {
      if unresolvedHole(pendTys[i]) {
        tErr("cannot infer a type for '" + pendNames[i] +
          "' — add a type annotation", pendAts[i])
      }
    } else {
      keepN.push(pendNames[i])
      keepT.push(pendTys[i])
      keepA.push(pendAts[i])
      keepD.push(pendDepths[i])
    }
    i = i + 1
  }
  pendNames = keepN
  pendTys = keepT
  pendAts = keepA
  pendDepths = keepD
  0
}

// ── definite-assignment flow (A-definite-assign) ─────────────────────────────
// Mirrors `compiler/typecheck.ts`'s host analysis (which lives in `parser.ts`):
// an uninitialized `let x: T` (no initializer) starts UNASSIGNED and is non-null,
// so a READ before it is provably written on every preceding path is a "used
// before it is assigned" error — closing the silent-`0` soundness gap
// (`let x: i32; return x` used to compile and return a fabricated 0). The
// declaration is fine; only the read is gated.
//
// `daUnassigned` is the live set of binding NAMES still un-written on the CURRENT
// path (a plain list — the set is tiny, only uninitialized lets in scope). A
// `let x: T` with no initializer adds its name; `x = …` removes it; a read of a
// still-present name errors (and drops it, so the same hole doesn't re-fire on
// every later read). The host keys by `Binding` identity for exact shadowing; VL
// keys by name (innermost-wins like `lookup`/`isConstName`) — sound for the
// subset since the compiler's own source has NO uninitialized lets and no source
// shadows an uninitialized let. Fork/join for `if`/`else` and loops is explicit
// (snapshot/restore/join), modelled on the host. `daWriteTarget` is the node
// index of a plain-`=` LHS Ident currently being evaluated as a WRITE (not a
// read) so the `Ident` arm does not trip use-before-assign on it; a compound
// `x += …` desugars to `x = x + (…)` whose RHS reads `x` and IS checked.
let daUnassigned: string[] = []
let daWriteTarget: i32 = -1

// True if `name` is currently in the live unassigned set.
function daIsUnassigned(name: string): boolean {
  let i = 0
  while i < daUnassigned.length {
    if daUnassigned[i] == name {
      return true
    }
    i = i + 1
  }
  false
}

// Mark `name` unassigned on the current path (a `let x: T` with no initializer).
function daAdd(name: string): i32 {
  if !daIsUnassigned(name) {
    daUnassigned.push(name)
  }
  0
}

// Mark `name` assigned on the current path (a write or a checked read), removing
// it from the live set. Rebuilds the survivors into a temp, then refills the
// global IN PLACE (`.clear()` + push) — the global array reference is never
// reassigned (mirrors the host's `unassigned.delete`, and keeps the self-emitter
// on its supported in-place-mutation path).
function daMarkAssigned(name: string): i32 {
  let keep: string[] = []
  let i = 0
  while i < daUnassigned.length {
    if daUnassigned[i] != name {
      keep.push(daUnassigned[i])
    }
    i = i + 1
  }
  daClear()
  let j = 0
  while j < keep.length {
    daUnassigned.push(keep[j])
    j = j + 1
  }
  0
}

// Empty the live set IN PLACE (never reassigns the global reference).
function daClear(): i32 {
  // The self-host emitter lowers `.pop()` (and `.length`) as statements but not
  // `.clear()`, so empty the array in place by popping until empty.
  while daUnassigned.length > 0 {
    daUnassigned.pop()
  }
  0
}

// Check a READ of `name`: if still unassigned on this path, report it and drop it
// so the same hole doesn't re-fire on every later read.
function daCheckRead(name: string, at: i32): i32 {
  if daIsUnassigned(name) {
    daMarkAssigned(name)
    tErr("`" + name + "` is used before it is assigned", at)
  }
  0
}

// Snapshot the live unassigned set (a copy), for forking and joining paths.
function daSnapshot(): string[] {
  let snap: string[] = []
  let i = 0
  while i < daUnassigned.length {
    snap.push(daUnassigned[i])
    i = i + 1
  }
  snap
}

// Restore the live set from a snapshot (in place — never reassigns the global).
function daRestore(snap: string[]): i32 {
  daClear()
  let i = 0
  while i < snap.length {
    daUnassigned.push(snap[i])
    i = i + 1
  }
  0
}

// Join two surviving paths into the live set: a name is assigned-after-the-merge
// only if it is assigned on BOTH — equivalently it is STILL unassigned if it is
// unassigned on EITHER. So the joined live set is the UNION of the two paths'
// unassigned sets. (`a` is taken as the current live set; `b` is folded in.)
function daJoinInto(b: string[]): i32 {
  let i = 0
  while i < b.length {
    daAdd(b[i])
    i = i + 1
  }
  0
}

// True if the statement at node `ix` ALWAYS exits its enclosing path (so its end
// is unreachable and it contributes nothing to a definite-assignment join). A
// `return`/`break`/`continue` diverges; a `Block` diverges if its last statement
// does; an `if … else …` diverges only if BOTH arms diverge (a chain recurses
// through its `ifElse`). Mirrors the host's `divergesStatement` for the subset.
function daBranchDiverges(ix: i32): boolean {
  if ix < 0 {
    return false
  }
  let s = P.nodes[ix]
  if s is RetStmt {
    return true
  } else if s is BreakStmt {
    return true
  } else if s is ContinueStmt {
    return true
  } else if s is Block {
    let st = s.blkStmts
    if st.length > 0 {
      return daBranchDiverges(st[st.length - 1])
    }
    return false
  } else if s is IfStmt {
    if s.ifElse < 0 {
      return false
    }
    return daBranchDiverges(s.ifThen) && daBranchDiverges(s.ifElse)
  }
  false
}
// True if `name` resolves (innermost-first) to a `const` binding.
function isConstName(name: string): boolean {
  let i = T.scopes.length - 1
  while i >= 0 {
    if T.scopes[i].has(name) {
      if i < constScopes.length {
        return constScopes[i].has(name)
      }
      return false
    }
    i = i - 1
  }
  false
}


// Well-known primitive type-arena indices, pinned by `initChecker` so the hot
// primitives are interned once (not re-pushed per use). `-1` until initialized.
export let TY_I32: i32 = -1
let TY_I64: i32 = -1
let TY_F64: i32 = -1
let TY_F32: i32 = -1
let TY_BOOL: i32 = -1
let TY_STR: i32 = -1
let TY_VOID: i32 = -1
let TY_ERR: i32 = -1
let TY_NULL: i32 = -1

// ── type-arena constructors ──────────────────────────────────────────────────
// Each appends a variant to `T.tys` and returns its index. (The same shape as the
// AST's `mk*` constructors, for the parallel arena.)

function addTy(t: Ty): i32 {
  T.tys.push(t)
  T.tys.length - 1
}

function mkPrim(name: string): i32 {
  let t: Ty = { primName: name }
  addTy(t)
}

function mkErrTy(): i32 {
  let t: Ty = { errKind: "error" }
  addTy(t)
}

export function mkObjTy(names: string[], typeIxs: i32[]): i32 {
  let t: Ty = { objFieldNames: names, objFieldTypes: typeIxs }
  addTy(t)
}

function mkFuncTy(params: i32[], ret: i32): i32 {
  let t: Ty = { fnParamTypes: params, fnRet: ret }
  addTy(t)
}

function mkUnionTy(members: i32[]): i32 {
  let t: Ty = { uMembers: members }
  addTy(t)
}

function mkNullableTy(inner: i32): i32 {
  let t: Ty = { nInner: inner }
  addTy(t)
}

function mkArrayTy(elem: i32): i32 {
  let t: Ty = { aElem: elem }
  addTy(t)
}

function mkMapTy(key: i32, val: i32, isSet: i32): i32 {
  let t: Ty = { mKey: key, mVal: val, mSet: isSet }
  addTy(t)
}

function mkTyVar(name: string): i32 {
  let t: Ty = { tvName: name }
  addTy(t)
}

// Intern the well-known primitives and the global scope. Call once before
// checking.
// ── return-type inference state (module globals, reset by initChecker) ────────
// An un-annotated function's hoisted return type is the PENDING sentinel `-2`
// until its body is checked. `fnDeclIx` maps a top-level function name to its
// FuncDecl arena index so a forward call can infer the callee ON DEMAND;
// `inferStack` is the in-progress set (cycle detection); `inferObserved` /
// `inferSawErr` accumulate what a pending body's `return`s / trailing expression
// yielded (first concrete type wins; an in-cycle call contributes only "err").
let fnDeclIx: {[string]: i32} = Map()
let inferStack: string[] = []
let inferObserved: i32 = -1
let inferSawErr: boolean = false

export function initChecker(): i32 {
  T.tys = []
  T.scopes = []
  T.diags = []
  T.curRet = -1
  cUserTypes = Map()
  fnDeclIx = Map()
  daClear()
  daWriteTarget = -1
  inferStack = []
  inferObserved = -1
  inferSawErr = false
  TY_I32 = mkPrim("i32")
  TY_I64 = mkPrim("i64")
  TY_F64 = mkPrim("f64")
  TY_F32 = mkPrim("f32")
  TY_BOOL = mkPrim("bool")
  TY_STR = mkPrim("string")
  TY_VOID = mkPrim("void")
  TY_ERR = mkErrTy()
  TY_NULL = mkPrim("null")
  T.scopes.push(Map())
  constScopes = []
  constScopes.push(Map())
  pendNames = []
  pendTys = []
  pendAts = []
  pendDepths = []
  0
}

// ── scope chain ──────────────────────────────────────────────────────────────

// ── flow narrowing (condition collectors) ────────────────────────────────────
// The Ident name of a `x == null` / `x != null` / `null == x` comparison, "" else.
function nullCmpName(condIx: i32): string {
  let cond = P.nodes[condIx]
  if cond is BinExpr {
    let lhs = P.nodes[cond.binLeft]
    let rhs = P.nodes[cond.binRight]
    if rhs is NullLit {
      if lhs is Ident { return lhs.identName }
    }
    if lhs is NullLit {
      if rhs is Ident { return rhs.identName }
    }
  }
  ""
}

// The non-null INNER type of the nullable binding `name`, or -1 (not nullable /
// not bound).
function nullableInnerOf(name: string): i32 {
  let curTy = lookup(name)
  if curTy >= 0 {
    let ct = T.tys[curTy]
    if ct is TyNullable { return ct.nInner }
  }
  0 - 1
}

// Collect the narrowings that hold when `cond` is TRUE into the parallel
// `names`/`tys` arrays: `x != null` strips x's null, `x is T` pins x to T
// (`is null` pins to the null type), `a && b` contributes BOTH conjuncts,
// `!(e)` contributes e's FALSE narrowings, and parens recurse. Union-COMPLEMENT
// narrowing (x is NOT T → drop T) stays out — tried and reverted (it made VL
// miss real errors); null-stripping is the well-defined core.
function collectThenNarrows(condIx: i32, names: string[], tys: i32[]): i32 {
  let cond = P.nodes[condIx]
  if cond is Paren {
    return collectThenNarrows(cond.parInner, names, tys)
  }
  if cond is Unary {
    if cond.unOp == "!" { return collectElseNarrows(cond.unArg, names, tys) }
    return 0
  }
  if cond is IsExpr {
    let obj = P.nodes[cond.isObj]
    if obj is Ident {
      if cond.isVariant == "null" {
        names.push(obj.identName)
        tys.push(TY_NULL)
      } else {
        let tIdx = nameToTy(cond.isVariant)
        if tIdx >= 0 {
          names.push(obj.identName)
          tys.push(tIdx)
        }
      }
    }
    return 0
  }
  if cond is BinExpr {
    if cond.binOp == "&&" {
      collectThenNarrows(cond.binLeft, names, tys)
      collectThenNarrows(cond.binRight, names, tys)
      return 0
    }
    if cond.binOp == "!=" {
      let nm = nullCmpName(condIx)
      if nm != "" {
        let inner = nullableInnerOf(nm)
        if inner >= 0 {
          names.push(nm)
          tys.push(inner)
        }
      }
    }
    return 0
  }
  0
}

// Collect the narrowings that hold when `cond` is FALSE: `x == null` strips the
// null in the else-branch, `x is null` false means non-null, `a || b`
// contributes BOTH disjuncts (De Morgan: neither held), `!(e)` contributes e's
// TRUE narrowings, and parens recurse.
function collectElseNarrows(condIx: i32, names: string[], tys: i32[]): i32 {
  let cond = P.nodes[condIx]
  if cond is Paren {
    return collectElseNarrows(cond.parInner, names, tys)
  }
  if cond is Unary {
    if cond.unOp == "!" { return collectThenNarrows(cond.unArg, names, tys) }
    return 0
  }
  if cond is IsExpr {
    let obj = P.nodes[cond.isObj]
    if obj is Ident {
      if cond.isVariant == "null" {
        let inner = nullableInnerOf(obj.identName)
        if inner >= 0 {
          names.push(obj.identName)
          tys.push(inner)
        }
      }
    }
    return 0
  }
  if cond is BinExpr {
    if cond.binOp == "||" {
      collectElseNarrows(cond.binLeft, names, tys)
      collectElseNarrows(cond.binRight, names, tys)
      return 0
    }
    if cond.binOp == "==" {
      let nm = nullCmpName(condIx)
      if nm != "" {
        let inner = nullableInnerOf(nm)
        if inner >= 0 {
          names.push(nm)
          tys.push(inner)
        }
      }
    }
    return 0
  }
  0
}

// Enter a new lexical scope (push a fresh name→type map).
function pushScope(): i32 {
  T.scopes.push(Map())
  constScopes.push(Map())
  0
}

// Leave the innermost scope. (`.pop()` in statement position drops its return
// value correctly now — the old PR #4 wasm-validation gap is fixed and pinned by
// `tests/cases/lists/struct-field-pop-statement.vl`.)
function popScope(): i32 {
  flushUninferred(T.scopes.length - 1)
  T.scopes.pop()
  constScopes.pop()
  0
}

// Bind `name` to type-arena index `ty` in the innermost scope.
export function declare(name: string, ty: i32): i32 {
  let top = T.scopes.length - 1
  T.scopes[top][name] = ty
  0
}

// Look `name` up through the scope chain, innermost first. Returns its type-arena
// index, or `-1` if undeclared (innermost-wins, so shadowing works).
function lookup(name: string): i32 {
  let i = T.scopes.length - 1
  while i >= 0 {
    if T.scopes[i].has(name) {
      return T.scopes[i][name] ?? -1
    }
    i = i - 1
  }
  -1
}

// Raise a diagnostic at AST node `at`.
function tErr(msg: string, at: i32): i32 {
  T.diags.push({ tmsg: msg, tat: at })
  0
}

// ── small numeric / string helpers (no union narrowing) ──────────────────────

// Is type-arena index `ix` a numeric primitive (i32 or f64)?
function isNumeric(ix: i32): boolean {
  if ix < 0 {
    return false
  }
  let t = T.tys[ix]
  if t is TyErr {
    return true
  }
  if t is TyVar {
    return true
  }
  if t is TyPrim {
    return t.primName == "i32" || t.primName == "i64" || t.primName == "f64" ||
      t.primName == "f32"
  }
  false
}

// Is type-arena index `ix` exactly the i64 primitive?
function isI64Ty(ix: i32): boolean {
  if ix < 0 {
    return false
  }
  let t = T.tys[ix]
  if t is TyPrim {
    return t.primName == "i64"
  }
  false
}

// Is type-arena index `ix` exactly the i32 primitive?
function isI32Ty(ix: i32): boolean {
  if ix < 0 {
    return false
  }
  let t = T.tys[ix]
  if t is TyPrim {
    return t.primName == "i32"
  }
  false
}

// Are `a` and `b` two INTEGER operands that mix i32 and i64 (so the op widens the
// i32 side to i64 and yields i64)? `i64 op i64`, `i32 op i64`, `i64 op i32`.
function mixesI64(a: i32, b: i32): boolean {
  let aI64 = isI64Ty(a)
  let bI64 = isI64Ty(b)
  if aI64 && bI64 { return true }
  if aI64 && isI32Ty(b) { return true }
  if bI64 && isI32Ty(a) { return true }
  false
}

// The bare primitive name of type-arena index `ix`, or "" if it is not a primitive.
function primNameOf(ix: i32): string {
  if ix < 0 { return "" }
  let t = T.tys[ix]
  if t is TyPrim {
    return t.primName
  }
  ""
}

// Numeric WIDENING lattice (B2): may a value of primitive type `sn` implicitly
// flow into a `dn`-typed slot? Only the LOSSLESS edges are permitted:
//   i32 → i64,  i32 → f64,  f32 → f64
// (plus every type to itself). Each preserves the value exactly. Codegen inserts
// the matching wasm convert at the boundary. Keyed on bare names so it is a pure
// value-lattice query independent of arena identity.
//
// REJECTED — needing an explicit conversion VL has no syntax for yet:
//   i32 → f32  (above 2^24 the i32 rounds to the nearest f32 — lossy)
//   i64 → f64  (above 2^53 the i64 rounds to the nearest f64 — lossy)
// plus every narrowing (i64→i32, f64→f32, …) and any float→integer (truncation).
function numWidensName(sn: string, dn: string): boolean {
  if sn == dn { return false }
  if sn == "i32" {
    if dn == "i64" || dn == "f64" { return true }
  }
  if sn == "f32" {
    if dn == "f64" { return true }
  }
  false
}

// True when `src`→`dst` is an implicit numeric widening (see `numWidensName` —
// the lossless edges only; i32→f32 / i64→f64 are rejected as lossy).
function numWidens(src: i32, dst: i32): boolean {
  numWidensName(primNameOf(src), primNameOf(dst))
}

// Are `a` and `b` two numeric operands of DIFFERENT but compatible types, so a mixed
// arithmetic/comparison widens the narrower side to the wider one? True exactly when
// one operand widens to the other (either direction). The shared op type
// is then the WIDER of the two (`widerNumeric`).
function mixesNumeric(a: i32, b: i32): boolean {
  if numWidens(a, b) { return true }
  if numWidens(b, a) { return true }
  false
}

// The WIDER of two mixed numeric operands (the result/op type): whichever the other
// widens INTO. Caller guarantees `mixesNumeric(a, b)`.
function widerNumeric(a: i32, b: i32): i32 {
  if numWidens(a, b) { return b }
  a
}

// Do two numeric type indices denote the SAME numeric type?
function sameNumeric(a: i32, b: i32): boolean {
  let ta = T.tys[a]
  let tb = T.tys[b]
  if ta is TyErr {
    return true
  }
  if tb is TyErr {
    return true
  }
  if ta is TyVar {
    return true
  }
  if tb is TyVar {
    return true
  }
  if ta is TyPrim {
    if tb is TyPrim {
      return ta.primName == tb.primName
    }
  }
  false
}

// Is the EXPRESSION at `ix` (peeling parens) a float `.` NUMBER literal? A float
// literal is polymorphic across the float types: it types f64 by default but
// re-encodes EXACTLY into an f32 slot, so a float literal flowing into an `f32`
// binding/operand is accepted (the demote that a general f64 value would need is
// never performed — the literal is encoded at f32 directly). Integer literals are
// NOT covered here (they ride the i32→{i64,f32,f64} widening lattice).
function isFloatLitExpr(ix: i32): boolean {
  if ix < 0 { return false }
  let e = P.nodes[ix]
  if e is Paren { return isFloatLitExpr(e.parInner) }
  if e is NumLit { return hasDot(e.numText) }
  false
}

// Literal-aware assignability for a numeric binding/argument/return: the normal
// `assignable` lattice, PLUS the float-literal→f32 exception (`isFloatLitExpr`). Used
// where the SOURCE EXPRESSION node is in hand (so the literal can be recognized);
// type-only sites keep using `assignable`.
function assignableExpr(srcExpr: i32, srcTy: i32, dstTy: i32): boolean {
  if assignable(srcTy, dstTy) { return true }
  if primNameOf(dstTy) == "f32" {
    if isFloatLitExpr(srcExpr) { return true }
  }
  false
}

// Does `s` contain a "." (so a number literal is a float)? Indexing a string
// yields the i32 char CODE, so the comparison is against the char literal `'.'`.
function hasDot(s: string): boolean {
  let i = 0
  while i < s.length {
    if s[i] == '.' {
      return true
    }
    i = i + 1
  }
  false
}

// Map a written type NAME to its type-arena index (a primitive, or TY_ERR for an
// unknown name). Takes the bare NAME — NOT a `Node` index — so it never narrows
// the `Node` union (see Finding 2). The single caller (`checkNode`) extracts the
// `TypeRef`'s name inline before calling this.
// True if the type name contains a TOP-LEVEL `|` (an inline-union synthetic name
// `A|B|null`). Depth-aware: a `|` inside `{…}`/`[…]` (an inline-object field's own
// union type, a map value) does NOT make the whole name a union.
function nameHasPipe(name: string): boolean {
  let depth = 0
  let i = 0
  while i < name.length {
    let c = name[i]
    if c == '{' || c == '[' {
      depth = depth + 1
    } else if c == '}' || c == ']' {
      depth = depth - 1
    } else if c == '|' && depth == 0 {
      return true
    }
    i = i + 1
  }
  false
}

function nameToTy(name: string): i32 {
  // An inline UNION `A | B | null` — the parser joins the members with `|` into one
  // synthetic name. Split on TOP-LEVEL `|`s (depth-aware), resolve each member, and
  // build the union (a `null` member makes it NULLABLE). Checked FIRST so a member's
  // `[]`/map shape isn't read as a suffix of the whole union name.
  if nameHasPipe(name) {
    let members: i32[] = []
    let hasNull = false
    let depth = 0
    let start = 0
    let i = 0
    while i <= name.length {
      let atSplit = i == name.length
      if !atSplit {
        let c = name[i]
        if c == '{' || c == '[' {
          depth = depth + 1
        } else if c == '}' || c == ']' {
          depth = depth - 1
        } else if c == '|' && depth == 0 {
          atSplit = true
        }
      }
      if atSplit {
        let part = name.slice(start, i)
        if part == "null" {
          hasNull = true
        } else if part.length > 0 {
          members.push(nameToTy(part))
        }
        start = i + 1
      }
      i = i + 1
    }
    let inner = TY_ERR
    if members.length == 1 {
      inner = members[0]
    } else if members.length > 1 {
      inner = mkUnionTy(members)
    }
    if hasNull {
      return mkNullableTy(inner)
    }
    return inner
  }
  if name == "i32" {
    return TY_I32
  }
  if name == "i64" {
    return TY_I64
  }
  if name == "f64" {
    return TY_F64
  }
  if name == "f32" {
    return TY_F32
  }
  if name == "bool" || name == "boolean" {
    return TY_BOOL
  }
  if name == "string" {
    return TY_STR
  }
  if name == "void" {
    return TY_VOID
  }
  // An array type `T[]`: the parser appends a literal `[]` per array suffix to the
  // type NAME (`i32[]`, `Tok[]`, `i32[][]`). Strip one suffix and wrap the element.
  let nlen = name.length
  if nlen >= 2 {
    if name[nlen - 2] == '[' && name[nlen - 1] == ']' {
      return mkArrayTy(nameToTy(name.slice(0, nlen - 2)))
    }
  }
  // A string-keyed MAP `{[K]:V}` (the parser's synthetic index-signature name).
  // Split at the FIRST "]:" — the key (between "{[" and "]:") cannot contain `]`,
  // so a nested-map VALUE (`{[string]:{[string]:i32}}`) splits correctly. Only
  // string keys are supported (the host's map rep); a non-string key resolves to
  // -1 so the caller reports "unknown type".
  if nlen >= 5 {
    if name[0] == '{' && name[1] == '[' && name[nlen - 1] == '}' {
      let mi = 2
      while mi < nlen - 1 {
        if name[mi] == ']' && name[mi + 1] == ':' {
          let mk = nameToTy(name.slice(2, mi))
          if mk != TY_STR {
            return -1
          }
          return mkMapTy(mk, nameToTy(name.slice(mi + 2, nlen - 1)), 0)
        }
        mi = mi + 1
      }
    }
  }
  // An INLINE OBJECT type `{x:T,y:U}` (the parser's synthetic anonymous-struct
  // name — starts `{` but not `{[`). Split the TOP-LEVEL commas (depth-aware: a
  // field's own map/object/array commas don't split), then each field at its first
  // top-level `:`, and build the structural TyObj.
  if nlen >= 2 {
    if name[0] == '{' && name[nlen - 1] == '}' {
      let fnames: string[] = []
      let ftys: i32[] = []
      let fdepth = 0
      let fstart = 1
      let fi = 1
      while fi <= nlen - 1 {
        let fSplit = fi == nlen - 1
        if !fSplit {
          let fc = name[fi]
          if fc == '{' || fc == '[' {
            fdepth = fdepth + 1
          } else if fc == '}' || fc == ']' {
            fdepth = fdepth - 1
          } else if fc == ',' && fdepth == 0 {
            fSplit = true
          }
        }
        if fSplit {
          let field = name.slice(fstart, fi)
          if field.length > 0 {
            // split `fname:ftype` at the first top-level `:`
            let cdepth = 0
            let ci = 0
            let colonAt = 0 - 1
            while ci < field.length {
              let cc = field[ci]
              if cc == '{' || cc == '[' {
                cdepth = cdepth + 1
              } else if cc == '}' || cc == ']' {
                cdepth = cdepth - 1
              } else if cc == ':' && cdepth == 0 && colonAt < 0 {
                colonAt = ci
              }
              ci = ci + 1
            }
            if colonAt > 0 {
              fnames.push(field.slice(0, colonAt))
              ftys.push(nameToTy(field.slice(colonAt + 1, field.length)))
            }
          }
          fstart = fi + 1
        }
        fi = fi + 1
      }
      return mkObjTy(fnames, ftys)
    }
  }
  // A declared struct/union type (registered by the program's pre-pass).
  if cUserTypes.has(name) {
    return cUserTypes[name] ?? -1
  }
  -1
}

// ── type → string (for diagnostics) ──────────────────────────────────────────
// Renders a type-arena index as a readable type name. Recurses through the arena
// for object/function/union/nullable. Narrows the `Ty` union only — never `Node`.
function tyToStr(ix: i32): string {
  if ix < 0 {
    return "<none>"
  }
  let t = T.tys[ix]
  if t is TyPrim {
    return t.primName
  } else if t is TyErr {
    return "<error>"
  } else if t is TyObj {
    // GAP: `.length`/index chained directly on an array field of an `is`-narrowed
    // value miscompiles, so the array fields are bound to locals first (PR #3).
    let names = t.objFieldNames
    let ftys = t.objFieldTypes
    let s = "{"
    let i = 0
    while i < names.length {
      if i > 0 {
        s = s + ", "
      }
      s = s + names[i] + ": " + tyToStr(ftys[i])
      i = i + 1
    }
    return s + "}"
  } else if t is TyFunc {
    let ptys = t.fnParamTypes
    let s = "("
    let i = 0
    while i < ptys.length {
      if i > 0 {
        s = s + ", "
      }
      s = s + tyToStr(ptys[i])
      i = i + 1
    }
    return s + ") -> " + tyToStr(t.fnRet)
  } else if t is TyUnion {
    let members = t.uMembers
    let s = ""
    let i = 0
    while i < members.length {
      if i > 0 {
        s = s + " | "
      }
      s = s + tyToStr(members[i])
      i = i + 1
    }
    return s
  } else if t is TyNullable {
    return tyToStr(t.nInner) + "?"
  } else if t is TyArray {
    return tyToStr(t.aElem) + "[]"
  } else if t is TyMap {
    return "{[" + tyToStr(t.mKey) + "]: " + tyToStr(t.mVal) + "}"
  } else if t is TyVar {
    return t.tvName
  }
  "<?>"
}

// The type-arena index of object `o`'s field `name`, or `-1` if absent. Takes a
// concrete `TyObj` (already narrowed by the caller) — `Ty`-union only.
function objFieldType(o: TyObj, name: string): i32 {
  let names = o.objFieldNames
  let ftys = o.objFieldTypes
  let i = 0
  while i < names.length {
    if names[i] == name {
      return ftys[i]
    }
    i = i + 1
  }
  -1
}

// ── value-comparability: may `ty` be compared with the default structural `==`? ─
// SOUNDNESS (mirrors the host's `isEquatable`): `==`/`!=` on a plain data object
// falls back to structural equality, which is sound only when EVERY component is
// itself value-comparable. Primitives and strings compare natively; a FUNCTION
// field compares by reference (same table index + captured env), so it does NOT
// make its object non-equatable; an array is equatable iff its element type is; an
// object iff all its fields are. A non-discriminated UNION (or NULLABLE, or a map)
// field is NOT value-comparable — discriminating the variant would be required
// first — so its enclosing object needs an explicit `==`. `seen` guards a cyclic
// (recursive) object shape: a type already on the stack is treated as equatable
// (its fields decide), matching the host's cycle guard.
function isEquatable(ty: i32, seen: i32[]): boolean {
  if ty < 0 {
    return true
  }
  let t = T.tys[ty]
  if t is TyPrim {
    // Every scalar primitive (incl. string, bool) is value-comparable; `void`/`null`
    // never reach a structural compare (a nullness test short-circuits earlier).
    return true
  }
  if t is TyErr {
    return true
  }
  if t is TyVar {
    return true
  }
  if t is TyFunc {
    return true
  }
  if t is TyArray {
    return isEquatable(t.aElem, seen)
  }
  if t is TyObj {
    let si = 0
    while si < seen.length {
      if seen[si] == ty {
        return true
      }
      si = si + 1
    }
    seen.push(ty)
    let ftys = t.objFieldTypes
    let i = 0
    let ok = true
    while i < ftys.length {
      if !isEquatable(ftys[i], seen) {
        ok = false
      }
      i = i + 1
    }
    seen.pop()
    return ok
  }
  // TyUnion / TyNullable / TyMap: not structurally value-comparable.
  false
}

// ── structural assignability: is `src` assignable to `dst`? ──────────────────
// Both are type-arena indices. The error type is assignable in both directions
// (so one failure doesn't cascade). Primitives match by name. An object is
// assignable to another when it has (at least) every target field, each field
// assignable (width + depth subtyping — the structural rule). A function matches
// on arity then parameter/return assignability (parameters contravariant). A
// value is assignable to a nullable when it is assignable to the inner type (or
// is itself nullable). A union source is assignable when EVERY member is; a union
// target accepts a source assignable to ANY member. Narrows `Ty` only.
function assignable(src: i32, dst: i32): boolean {
  if src < 0 || dst < 0 {
    return true
  }
  if src == dst {
    return true
  }
  let s = T.tys[src]
  let d = T.tys[dst]
  if s is TyErr {
    return true
  }
  if d is TyErr {
    return true
  }
  if s is TyVar {
    return true
  }
  if d is TyVar {
    return true
  }
  // Nullable target: accepts `null` itself, the inner, or another nullable's inner.
  if d is TyNullable {
    if src == TY_NULL {
      return true
    }
    if s is TyNullable {
      return assignable(s.nInner, d.nInner)
    }
    return assignable(src, d.nInner)
  }
  // A nullable source is not assignable to a non-nullable target.
  if s is TyNullable {
    return false
  }
  // Union source: every member must be assignable to the target.
  if s is TyUnion {
    let members = s.uMembers
    let i = 0
    let ok = true
    while i < members.length {
      if !assignable(members[i], dst) {
        ok = false
      }
      i = i + 1
    }
    return ok
  }
  // Union target: the source must be assignable to some member.
  if d is TyUnion {
    let members = d.uMembers
    let i = 0
    let ok = false
    while i < members.length {
      if assignable(src, members[i]) {
        ok = true
      }
      i = i + 1
    }
    return ok
  }
  if s is TyPrim {
    if d is TyPrim {
      // Lossless numeric WIDENING (B2): a narrower numeric value flows into a wider
      // slot — annotation, argument, return — along the lattice i32→{i64,f32,f64},
      // i64→f64, f32→f64. The reverse (any narrowing, e.g. i64→i32, f64→f32, f64→i32)
      // is NOT assignable: it is lossy and must be made explicit. Codegen inserts the
      // matching wasm convert at the boundary. f32 literals reach an f32 slot via the
      // float-literal exception at the binding/arg/return sites (a float literal types
      // f64 by default but re-encodes exactly at f32). The binding takes the WIDER type.
      if numWidensName(s.primName, d.primName) {
        return true
      }
      return s.primName == d.primName
    }
    return false
  }
  if s is TyObj {
    if d is TyObj {
      let dnames = d.objFieldNames
      let dtys = d.objFieldTypes
      let i = 0
      let ok = true
      while i < dnames.length {
        let srcIx = objFieldType(s, dnames[i])
        if srcIx < 0 {
          ok = false
        } else if !assignable(srcIx, dtys[i]) {
          ok = false
        }
        i = i + 1
      }
      return ok
    }
    return false
  }
  if s is TyArray {
    if d is TyArray {
      // An empty `[]` (element `-1`) is assignable to any array; otherwise the
      // element types must be assignable.
      return assignable(s.aElem, d.aElem)
    }
    return false
  }
  if s is TyMap {
    if d is TyMap {
      // A bare `Map()`/`Set()` (key/value holes, `-1`) is assignable to any map.
      return assignable(s.mKey, d.mKey) && assignable(s.mVal, d.mVal)
    }
    return false
  }
  if s is TyFunc {
    if d is TyFunc {
      let sp = s.fnParamTypes
      let dp = d.fnParamTypes
      if sp.length != dp.length {
        return false
      }
      let i = 0
      let ok = assignable(s.fnRet, d.fnRet)
      while i < sp.length {
        if !assignable(dp[i], sp[i]) {
          ok = false
        }
        i = i + 1
      }
      return ok
    }
    return false
  }
  false
}

// ── per-kind helpers (take a NARROWED variant; recurse back through checkNode) ──
// These helpers receive an already-narrowed `Node` variant as a STRUCT PARAMETER,
// narrow further `Node` children themselves, and call back into `checkNode` — the
// exact shape "Finding 2" historically prohibited. The miscompile is fixed in the
// host (pinned by `tests/cases/types/union-two-visitors.vl` and
// `union-narrowed-helper-recursion.vl`), so the visitor can be factored naturally.

// Look up a generic binding by type-param name in the parallel bind arrays.
function bindOf(bNames: string[], bTys: i32[], name: string): i32 {
  let i = 0
  while i < bNames.length {
    if bNames[i] == name {
      return bTys[i]
    }
    i = i + 1
  }
  -1
}

// A call expression: array-method builtins (`xs.push`), string-method builtins
// (`.slice`/`.indexOf`/`.includes`/`.charCodeAt`), the `print`/`fromCodePoint`
// builtins, then the generic function-call path (arity + per-arg assignability).
function checkCallNode(n: Call, ix: i32): i32 {
  // Array method call `xs.push(e)`: when the callee is a member access whose
  // receiver is an array, type it as a builtin (NOT a struct field). Only fires for
  // an array receiver, so a plain `f(…)` / non-array method falls through.
  let cfn = P.nodes[n.callFn]
  if cfn is Member {
    let recvTy = checkNode(cfn.memObj)
    let rt = T.tys[recvTy]
    if rt is TyArray {
      let margs = n.callArgs
      if cfn.memProp == "push" {
        if margs.length != 1 {
          tErr("push expects 1 argument, got " + i32ToStr(margs.length), ix)
        } else {
          let pat = checkNode(margs[0])
          // The first `.push(v)` on a bare empty `[]` (element hole `-1`) PINS its
          // element type to `typeof v` in place — this is the usage-driven inference
          // that resolves an un-annotated `const xs = []` (see `infer-empty-push.vl`),
          // and clears the uninferred-binding floor. A later conflicting push is then
          // a clean type error.
          if rt.aElem < 0 {
            rt.aElem = pat
          } else if !assignable(pat, rt.aElem) {
            tErr("push: cannot add " + tyToStr(pat) + " to " + tyToStr(recvTy), ix)
          }
        }
        return TY_I32
      }
      // `.map(fn)` / `.filter(pred)`: the callback is a 1-arg function over the
      // element type; map yields an array of the callback's return, filter the
      // same array type (its predicate must yield bool).
      if cfn.memProp == "map" || cfn.memProp == "filter" {
        let cargs = n.callArgs
        if cargs.length != 1 {
          tErr(cfn.memProp + " expects 1 argument, got " + i32ToStr(cargs.length), ix)
          return TY_ERR
        }
        let cbTy = checkNode(cargs[0])
        let cb = T.tys[cbTy]
        if cb is TyFunc {
          let cbParams = cb.fnParamTypes
          if cbParams.length != 1 {
            tErr(cfn.memProp + " callback expects 1 parameter, got " +
              i32ToStr(cbParams.length), ix)
          } else if !assignable(rt.aElem, cbParams[0]) {
            tErr(cfn.memProp + " callback: parameter expects " +
              tyToStr(cbParams[0]) + ", got " + tyToStr(rt.aElem), ix)
          }
          if cfn.memProp == "filter" {
            if !assignable(cb.fnRet, TY_BOOL) {
              tErr("filter predicate must yield bool, got " + tyToStr(cb.fnRet), ix)
            }
            return recvTy
          }
          return mkArrayTy(cb.fnRet)
        }
        tErr(cfn.memProp + " expects a function, got " + tyToStr(cbTy), ix)
        return TY_ERR
      }
      // `.pop()` / `.get(i)` yield `T | null` (an empty pop / out-of-range get is
      // normal absence); `.clear()` empties in place and yields nothing.
      if cfn.memProp == "pop" {
        if margs.length != 0 {
          tErr("pop expects 0 arguments, got " + i32ToStr(margs.length), ix)
        }
        return mkNullableTy(rt.aElem)
      }
      if cfn.memProp == "get" {
        if margs.length != 1 {
          tErr("get expects 1 argument, got " + i32ToStr(margs.length), ix)
        } else {
          let gat = checkNode(margs[0])
          if !assignable(gat, TY_I32) {
            tErr("get: index must be i32, got " + tyToStr(gat), ix)
          }
        }
        return mkNullableTy(rt.aElem)
      }
      if cfn.memProp == "clear" {
        if margs.length != 0 {
          tErr("clear expects 0 arguments, got " + i32ToStr(margs.length), ix)
        }
        return TY_VOID
      }
      tErr("no method '." + cfn.memProp + "' on array " + tyToStr(recvTy), ix)
      return TY_ERR
    }
    // Map/Set methods over the `{[K]: V}` rep, gated by FLAVOR: a map exposes
    // `.set`/`.get`/`.has`/`.delete`/`.keys()`/`.values()`; a SET exposes only
    // `.add`/`.has`/`.delete`/`.values()` (the Map surface must not leak — `.set`
    // on a set / `.add` on a map is an unknown-property error). The first
    // `.set`/`.add` on a bare `Map()`/`Set()` PINS its key/value holes in place,
    // so a later conflicting use is a clean type error.
    if rt is TyMap {
      let mp = cfn.memProp
      let margs2 = n.callArgs
      if mp == "set" && rt.mSet == 0 {
        if margs2.length != 2 {
          tErr("set expects 2 arguments, got " + i32ToStr(margs2.length), ix)
        } else {
          let k0 = checkNode(margs2[0])
          let v0 = checkNode(margs2[1])
          if rt.mKey < 0 {
            rt.mKey = k0
          } else if !assignable(k0, rt.mKey) {
            tErr("set: expected " + tyToStr(rt.mKey) + ", got " + tyToStr(k0), ix)
          }
          if rt.mVal < 0 {
            rt.mVal = v0
          } else if !assignable(v0, rt.mVal) {
            tErr("set: expected " + tyToStr(rt.mVal) + ", got " + tyToStr(v0), ix)
          }
        }
        return TY_VOID
      }
      if mp == "get" && rt.mSet == 0 {
        if margs2.length != 1 {
          tErr("get expects 1 argument, got " + i32ToStr(margs2.length), ix)
        } else {
          let k1 = checkNode(margs2[0])
          if !assignable(k1, rt.mKey) {
            tErr("get: key must be " + tyToStr(rt.mKey) + ", got " + tyToStr(k1), ix)
          }
        }
        return mkNullableTy(rt.mVal)
      }
      if mp == "add" && rt.mSet == 1 {
        if margs2.length != 1 {
          tErr("add expects 1 argument, got " + i32ToStr(margs2.length), ix)
        } else {
          let ka = checkNode(margs2[0])
          if rt.mKey < 0 {
            rt.mKey = ka
          } else if !assignable(ka, rt.mKey) {
            tErr("add: expected " + tyToStr(rt.mKey) + ", got " + tyToStr(ka), ix)
          }
        }
        return TY_VOID
      }
      if mp == "has" || mp == "delete" {
        if margs2.length != 1 {
          tErr(mp + " expects 1 argument, got " + i32ToStr(margs2.length), ix)
        } else {
          let k2 = checkNode(margs2[0])
          if !assignable(k2, rt.mKey) {
            tErr(mp + ": key must be " + tyToStr(rt.mKey) + ", got " + tyToStr(k2), ix)
          }
        }
        return TY_BOOL
      }
      if mp == "keys" && rt.mSet == 0 {
        if margs2.length != 0 {
          tErr("keys expects no arguments", ix)
        }
        return mkArrayTy(rt.mKey)
      }
      if mp == "values" {
        if margs2.length != 0 {
          tErr("values expects no arguments", ix)
        }
        // A set's `.values()` yields its ELEMENTS (the keys); a map's its values.
        if rt.mSet == 1 {
          return mkArrayTy(rt.mKey)
        }
        return mkArrayTy(rt.mVal)
      }
      tErr("unknown property `" + mp + "` on " + tyToStr(recvTy), ix)
      return TY_ERR
    }
    // String methods: `.slice(i32,i32)->string`, `.indexOf(string)->i32`,
    // `.includes(string)->bool`, `.charCodeAt(i32)->i32`. (`.length` is a Member,
    // handled there; `s[i]` is an Index.) Element types are checked.
    if rt is TyPrim {
      if rt.primName == "string" {
        let sp = cfn.memProp
        let sargs = n.callArgs
        if sp == "slice" {
          if sargs.length != 2 {
            tErr("slice expects 2 arguments, got " + i32ToStr(sargs.length), ix)
          } else {
            let s0 = checkNode(sargs[0])
            let s1 = checkNode(sargs[1])
            if !assignable(s0, TY_I32) || !assignable(s1, TY_I32) {
              tErr("slice expects i32 bounds, got " + tyToStr(s0) + " and " + tyToStr(s1), ix)
            }
          }
          return TY_STR
        }
        if sp == "indexOf" {
          if sargs.length != 1 {
            tErr("indexOf expects 1 argument, got " + i32ToStr(sargs.length), ix)
          } else {
            let a0 = checkNode(sargs[0])
            if !assignable(a0, TY_STR) {
              tErr("indexOf expects a string, got " + tyToStr(a0), ix)
            }
          }
          return TY_I32
        }
        if sp == "includes" {
          if sargs.length != 1 {
            tErr("includes expects 1 argument, got " + i32ToStr(sargs.length), ix)
          } else {
            let a0 = checkNode(sargs[0])
            if !assignable(a0, TY_STR) {
              tErr("includes expects a string, got " + tyToStr(a0), ix)
            }
          }
          return TY_BOOL
        }
        if sp == "charCodeAt" {
          if sargs.length != 1 {
            tErr("charCodeAt expects 1 argument, got " + i32ToStr(sargs.length), ix)
          } else {
            let a0 = checkNode(sargs[0])
            if !assignable(a0, TY_I32) {
              tErr("charCodeAt expects an i32 index, got " + tyToStr(a0), ix)
            }
          }
          return TY_I32
        }
        tErr("no method '." + sp + "' on string", ix)
        return TY_ERR
      }
    }
  }
  // `print(x)` is a compiler builtin (no module/import system yet): it accepts a
  // single value of any printable type and yields void. Special-cased so a program
  // that prints does not trip "undeclared identifier 'print'". Each argument is
  // still checked so a type error inside it surfaces.
  if cfn is Ident {
    if cfn.identName == "print" {
      let pargs = n.callArgs
      let pj = 0
      while pj < pargs.length {
        checkNode(pargs[pj])
        pj = pj + 1
      }
      return TY_VOID
    }
    // `Map()` / `Set()` construct an empty string-keyed map: key/value HOLES (-1)
    // assignable to any map annotation (`const m: {[string]: i32} = Map()`).
    if cfn.identName == "Map" || cfn.identName == "Set" {
      if n.callArgs.length != 0 {
        tErr(cfn.identName + " expects no arguments", ix)
      }
      if cfn.identName == "Set" {
        // A set's VALUE type is the membership boolean; the element (key) is a
        // hole pinned by the annotation or the first `.add`.
        return mkMapTy(0 - 1, TY_BOOL, 1)
      }
      return mkMapTy(0 - 1, 0 - 1, 0)
    }
    // `toString(x)` is a builtin: an i32 (decimal digits) or boolean ("true" /
    // "false") renders as a string.
    if cfn.identName == "toString" {
      let targs = n.callArgs
      if targs.length != 1 {
        tErr("toString expects 1 argument, got " + i32ToStr(targs.length), ix)
      } else {
        let t0 = checkNode(targs[0])
        if !assignable(t0, TY_I32) && !assignable(t0, TY_BOOL) {
          tErr("toString expects an i32 or boolean, got " + tyToStr(t0), ix)
        }
      }
      return TY_STR
    }
    // `fromCodePoints(xs)` is a builtin: an `i32[]` of code points -> a string,
    // in one bulk copy (the amortized alternative to per-char concat).
    if cfn.identName == "fromCodePoints" {
      let pargs = n.callArgs
      if pargs.length != 1 {
        tErr("fromCodePoints expects 1 argument, got " + i32ToStr(pargs.length), ix)
      } else {
        let p0 = checkNode(pargs[0])
        let p0t = T.tys[p0]
        let pOk = false
        if p0t is TyArray {
          // An empty `[]` literal's element hole (-1) pins to i32 here.
          if p0t.aElem < 0 || assignable(p0t.aElem, TY_I32) { pOk = true }
        }
        if p0t is TyErr { pOk = true }
        if !pOk {
          tErr("fromCodePoints expects an i32[], got " + tyToStr(p0), ix)
        }
      }
      return TY_STR
    }
    // `fromCodePoint(code)` is a builtin: an i32 code point -> a length-1 string.
    if cfn.identName == "fromCodePoint" {
      let fargs = n.callArgs
      if fargs.length != 1 {
        tErr("fromCodePoint expects 1 argument, got " + i32ToStr(fargs.length), ix)
      } else {
        let f0 = checkNode(fargs[0])
        if !assignable(f0, TY_I32) {
          tErr("fromCodePoint expects an i32, got " + tyToStr(f0), ix)
        }
      }
      return TY_STR
    }
  }
  let fnTy = checkNode(n.callFn)
  let args = n.callArgs
  let ft = T.tys[fnTy]
  if ft is TyFunc {
    // PENDING return (-2): the un-annotated callee hasn't been inferred yet (a
    // forward call). Demand-infer it now — check its FuncDecl, which patches this
    // very TyFunc in place — unless it is already on the in-progress stack (an
    // in-cycle call: contribute TY_ERR so the cycle can be detected at the root).
    if ft.fnRet == 0 - 2 {
      if cfn is Ident {
        if !onInferStack(cfn.identName) {
          let dIx = fnDeclIx[cfn.identName] ?? -1
          if dIx >= 0 {
            checkNode(dIx)
          }
        }
      }
    }
    let retTy = ft.fnRet
    if retTy == 0 - 2 {
      retTy = TY_ERR
    }
    let params = ft.fnParamTypes
    if args.length != params.length {
      tErr("wrong number of arguments: expected " +
        i32ToStr(params.length) + ", got " + i32ToStr(args.length), ix)
      return retTy
    }
    // Generic CALL-SITE inference: a TyVar param (or `T[]`) BINDS its type-param to
    // the argument's type (first use wins; later uses must agree), and the return
    // type substitutes through the binding — so `id("s")` is `string`, and
    // `let n: i32 = id("s")` is a genuine type error downstream.
    let bNames: string[] = []
    let bTys: i32[] = []
    let i = 0
    while i < args.length {
      let at = checkNode(args[i])
      let expected = params[i]
      let pt2 = T.tys[expected]
      if pt2 is TyVar {
        let b0 = bindOf(bNames, bTys, pt2.tvName)
        if b0 >= 0 {
          expected = b0
        } else {
          bNames.push(pt2.tvName)
          bTys.push(at)
          expected = at
        }
      } else if pt2 is TyArray {
        let elemIx = pt2.aElem
        if elemIx >= 0 {
          let et2 = T.tys[elemIx]
          if et2 is TyVar {
            let at2 = T.tys[at]
            if at2 is TyArray {
              let b1 = bindOf(bNames, bTys, et2.tvName)
              if b1 >= 0 {
                expected = mkArrayTy(b1)
              } else {
                bNames.push(et2.tvName)
                bTys.push(at2.aElem)
                expected = at
              }
            }
          }
        }
      }
      // Passing an empty-collection argument into a concrete `T[]` / map param pins
      // its element type from the param (`len(empty)` resolves `empty` to `i32[]`),
      // clearing its uninferred floor — pure downstream-usage inference, no push.
      constrainEmpty(at, expected)
      if !assignable(at, expected) {
        tErr("argument " + i32ToStr(i + 1) + ": expected " +
          tyToStr(expected) + ", got " + tyToStr(at), ix)
      }
      i = i + 1
    }
    // Substitute the binding into a generic return type.
    if bNames.length > 0 {
      let rt3 = T.tys[retTy]
      if rt3 is TyVar {
        let rb = bindOf(bNames, bTys, rt3.tvName)
        if rb >= 0 {
          retTy = rb
        }
      } else if rt3 is TyArray {
        let re = rt3.aElem
        if re >= 0 {
          let re2 = T.tys[re]
          if re2 is TyVar {
            let rb2 = bindOf(bNames, bTys, re2.tvName)
            if rb2 >= 0 {
              retTy = mkArrayTy(rb2)
            }
          }
        }
      }
    }
    return retTy
  }
  if ft is TyErr {
    return TY_ERR
  }
  tErr("called value is not a function (" + tyToStr(fnTy) + ")", ix)
  TY_ERR
}

// Resolve a written annotation NAME in the context of generic type-parameter
// names: a bare type-param resolves to its TyVar, `T[]` to an array of it; any
// other name falls through to `nameToTy`.
function resolveAnnot(name: string, typarams: string[]): i32 {
  let i = 0
  while i < typarams.length {
    if typarams[i] == name {
      return mkTyVar(name)
    }
    i = i + 1
  }
  let nlen = name.length
  if nlen >= 2 {
    if name[nlen - 2] == '[' && name[nlen - 1] == ']' {
      let base = name.slice(0, nlen - 2)
      let j = 0
      while j < typarams.length {
        if typarams[j] == base {
          return mkArrayTy(mkTyVar(base))
        }
        j = j + 1
      }
    }
  }
  nameToTy(name)
}

// Is `name` currently being inferred (on the in-progress stack)?
function onInferStack(name: string): boolean {
  let i = 0
  while i < inferStack.length {
    if inferStack[i] == name {
      return true
    }
    i = i + 1
  }
  false
}

// Record a type a PENDING body produced (a `return e` or the trailing expression):
// the first CONCRETE type wins; an error type only notes that something err-ish
// flowed back (an in-cycle call), which distinguishes "void body" from "no basis".
function noteInferredRet(t: i32): i32 {
  if t < 0 {
    return 0
  }
  let tt = T.tys[t]
  if tt is TyErr {
    inferSawErr = true
    return 0
  }
  if tt is TyPrim {
    if tt.primName == "void" {
      return 0
    }
  }
  if inferObserved < 0 {
    inferObserved = t
  }
  0
}

// SOUNDNESS — exhaustiveness of an else-less `is`-chain. Does the flat
// `if p is A {…} else if p is B {…}` chain rooted at `ifIx` (no final `else`)
// COVER every variant of `p`'s union type? If so its fall-through is unreachable
// and the chain needs no `else`; if not, a value falls off the end (the host
// types that as `| null`). Mirrors the host's `conditionsExhaust`, but over the
// discriminated place's declared union MEMBERS (VL has no union-subtraction /
// `Never` machinery): collect the per-arm tested types, require every arm to test
// the SAME single place, then check each union member is covered by some arm.
// Conservative — any arm that isn't a bare `place is T` (a compound `&&`/`||`, a
// different place, a null test) makes the chain non-exhaustive (returns false),
// never wrongly exhaustive.
function ifChainExhausts(ifIx: i32): boolean {
  let havePlace = false
  let placeName = "?"
  let testedTys: i32[] = []
  // `allIsArms` stays true only while every arm seen is a bare `<sameIdent> is T`
  // (the only shape we can prove exhaustive by union-member coverage).
  let allIsArms = true
  let node = P.nodes[ifIx]
  let walking = true
  while walking {
    if node is IfStmt {
      // Classify this arm's condition. Only a single `<ident> is T` (not null)
      // contributes to coverage; anything else makes the chain non-coverable.
      let cond = P.nodes[node.ifCond]
      if cond is IsExpr {
        if cond.isVariant == "null" {
          allIsArms = false
        } else {
          let obj = P.nodes[cond.isObj]
          if obj is Ident {
            if !havePlace {
              placeName = obj.identName
              havePlace = true
            } else if placeName != obj.identName {
              allIsArms = false
            }
            let tIx = nameToTy(cond.isVariant)
            if tIx < 0 {
              allIsArms = false
            } else {
              testedTys.push(tIx)
            }
          } else {
            allIsArms = false
          }
        }
      } else {
        allIsArms = false
      }
      if node.ifElse < 0 {
        // No `else`: the chain ends here — decide by coverage below.
        walking = false
      } else {
        let nxt = P.nodes[node.ifElse]
        if nxt is IfStmt {
          node = nxt
        } else {
          // A real (block) `else` covers the fall-through outright — exhaustive
          // regardless of the arm shapes.
          return true
        }
      }
    } else {
      return false
    }
  }
  // No `else`. Only a pure `is`-chain over one place can be exhaustive by member
  // coverage; any other shape genuinely falls through.
  if !allIsArms {
    return false
  }
  // No place was discriminated (shouldn't happen) — not exhaustive.
  if !havePlace {
    return false
  }
  // Look up the place's union members; cover each against the tested set.
  let pty = lookup(placeName)
  if pty < 0 {
    return false
  }
  let pt = T.tys[pty]
  if pt is TyNullable {
    // A nullable place needs an explicit `is null` (or `else`) arm to be covered;
    // an else-less `is`-chain over the inner variants always leaves the null path.
    return false
  }
  if pt is TyUnion {
    // Cover each union member against the tested set.
    let members = pt.uMembers
    let mi = 0
    let allCovered = true
    while mi < members.length {
      let covered = false
      let ti = 0
      while ti < testedTys.length {
        if assignable(members[mi], testedTys[ti]) {
          covered = true
        }
        ti = ti + 1
      }
      if !covered {
        allCovered = false
      }
      mi = mi + 1
    }
    return allCovered
  }
  // A non-union place: an `is`-chain over it is degenerate; treat as covered
  // (a single concrete type is "exhausted" by any always-true branch).
  true
}

// A function declaration: resolve param/return annotations (narrowing the Param/
// TypeRef children), bind the signature, and check the body in a fresh scope.
// An UN-ANNOTATED return type is INFERRED from the body — its `return`s and
// trailing expression accumulate via `noteInferredRet` (under the `-2` pending
// `curRet`), and the result is PATCHED into the hoisted TyFunc in place, so every
// caller (incl. ones that demand-inferred this function early) sees it. A
// base-case-less cycle (`ping(){return pong()}` / `pong(){return ping()}`) has
// nothing concrete to latch onto and reports "cannot infer a return type".
function checkFuncDeclNode(n: FuncDecl): i32 {
  let inferring = n.fnRet < 0
  // Already inferred on demand (a forward call checked this body before pass 2
  // reached it)? Skip the re-check so diagnostics aren't duplicated.
  if inferring {
    if onInferStack(n.fnName) {
      return TY_VOID
    }
    let hoisted = lookup(n.fnName)
    if hoisted >= 0 {
      if (fnDeclIx[n.fnName] ?? -1) >= 0 {
        let ht = T.tys[hoisted]
        if ht is TyFunc {
          if ht.fnRet != 0 - 2 {
            return TY_VOID
          }
        }
      }
    }
  }
  let params = n.fnParams
  let paramTys: i32[] = []
  let pi = 0
  while pi < params.length {
    let pNode = P.nodes[params[pi]]
    let pt = TY_ERR
    if pNode is Param {
      if pNode.parType >= 0 {
        let ptn = P.nodes[pNode.parType]
        if ptn is TypeRef {
          pt = resolveAnnot(ptn.tyName, n.fnTyParams)
          if pt < 0 {
            tErr("unknown type '" + ptn.tyName + "'", pNode.parType)
            pt = TY_ERR
          }
        }
      } else {
        tErr("parameter needs a type annotation", params[pi])
      }
    }
    paramTys.push(pt)
    pi = pi + 1
  }
  // Resolve the return-type annotation (or the pending sentinel when inferring).
  let ret = 0 - 2
  if !inferring {
    ret = TY_VOID
    let rtn = P.nodes[n.fnRet]
    if rtn is TypeRef {
      ret = resolveAnnot(rtn.tyName, n.fnTyParams)
      if ret < 0 {
        tErr("unknown type '" + rtn.tyName + "'", n.fnRet)
        ret = TY_ERR
      }
    }
    // `f` is hoisted in the outer scope (checkProgram pre-pass), but re-declaring
    // it here covers nested function decls and is an idempotent rebind otherwise.
    // (An anonymous function EXPRESSION has no name to bind.)
    if n.fnName != "" {
      declare(n.fnName, mkFuncTy(paramTys, ret))
    }
  }
  // Save the inference accumulators (a demand-inference can nest inside another
  // function's body check) and the enclosing return type.
  let savedObserved = inferObserved
  let savedSawErr = inferSawErr
  if inferring {
    inferStack.push(n.fnName)
    inferObserved = -1
    inferSawErr = false
  }
  // Check the body in a fresh scope sharing the parameters.
  pushScope()
  // Definite-assignment: a function body is its OWN flow context — it runs at
  // call time, not at the declaration site, so a NESTED function that captures an
  // outer still-unassigned `let x` must not be flagged (the call may happen after
  // `x` is written). Save and clear the live unassigned set for the body, then
  // restore the enclosing path.
  let daSavedUnassigned: string[] = daSnapshot()
  daClear()
  let savedRet = T.curRet
  T.curRet = ret
  let dj = 0
  while dj < params.length {
    let pNode2 = P.nodes[params[dj]]
    if pNode2 is Param {
      declare(pNode2.parName, paramTys[dj])
    }
    dj = dj + 1
  }
  let body = P.nodes[n.fnBody]
  if body is Block {
    let stmts = body.blkStmts
    let s = 0
    while s < stmts.length {
      let stTy = checkNode(stmts[s])
      // The trailing expression is the implicit return; under inference it is a
      // return-type witness. With a CONCRETE annotated return, a trailing empty
      // collection (`mk(): i32[] { … inner }`) pins its element from the return
      // type here — before the body scope is popped (and `inner`'s floor checked).
      if s == stmts.length - 1 {
        if inferring {
          noteInferredRet(stTy)
        } else {
          constrainEmpty(stTy, ret)
          // SOUNDNESS — missing-return / non-exhaustive fall-through. When the
          // body's LAST statement is an else-less `is`-chain that does NOT cover
          // every variant of its discriminated union, a value falls off the end
          // (the host types this as `branches | null`). For a non-void declared
          // return that is a soundness hole: "you forgot a case". An `if` WITH a
          // final `else`, or an EXHAUSTIVE chain, is unreachable past its end and
          // is fine; any other trailing statement is a normal value/return and is
          // left to the per-`return` and trailing-expression checks above. Skip
          // when the return type is itself nullable (a `| null` fall-through is
          // assignable) or the error type (don't cascade).
          let lastN = P.nodes[stmts[s]]
          if lastN is IfStmt {
            // Only an `is`-chain (the trailing `if` discriminates with `is`) is
            // subject to this exhaustiveness rule — leave plain `if cond {…}`
            // shapes to the existing per-branch checks.
            let firstCond = P.nodes[lastN.ifCond]
            let isChain = false
            if firstCond is IsExpr {
              isChain = true
            }
            let retT = T.tys[ret]
            let retNullable = false
            if retT is TyNullable {
              retNullable = true
            }
            if isChain && ret != TY_VOID && ret != TY_ERR && !retNullable {
              if !ifChainExhausts(stmts[s]) {
                tErr("non-exhaustive `is`-chain falls through with no `else`" +
                  " — add the missing variant(s) or an `else` (expected " +
                  tyToStr(ret) + ")", stmts[s])
              }
            }
          }
        }
      }
      s = s + 1
    }
  }
  T.curRet = savedRet
  daRestore(daSavedUnassigned)
  popScope()
  if inferring {
    inferStack.pop()
    let inferred = TY_VOID
    if inferObserved >= 0 {
      inferred = inferObserved
    } else if inferSawErr {
      // Only err-ish types flowed back (a base-case-less cycle): no basis.
      tErr("cannot infer a return type for '" + n.fnName +
        "' — annotate a return type", n.fnBody)
      inferred = TY_ERR
    }
    ret = inferred
    // Patch the hoisted TyFunc IN PLACE so existing references see the result;
    // a nested (un-hoisted) NAMED function declares fresh; an anonymous lambda
    // just carries its type as the expression value.
    if n.fnName != "" {
      let bound = lookup(n.fnName)
      let patched = false
      if bound >= 0 {
        let bt = T.tys[bound]
        if bt is TyFunc {
          bt.fnRet = inferred
          patched = true
        }
      }
      if !patched {
        declare(n.fnName, mkFuncTy(paramTys, inferred))
      }
    }
    inferObserved = savedObserved
    inferSawErr = savedSawErr
  }
  // The function's own type — a FuncDecl in EXPRESSION position (a lambda, or a
  // named function referenced as a value) evaluates to it.
  mkFuncTy(paramTys, ret)
}

// The program root: pass 0 registers `type` declarations (structs, then unions over
// them), pass 1 hoists function signatures (call-before-decl + mutual recursion),
// pass 2 checks every top-level statement.
function checkProgramNode(n: Program): i32 {
  let stmts = n.progStmts
  // Pass 0: register top-level struct `type` declarations BEFORE anything else, so
  // a struct name in a param/return/let annotation (pass 1/2) or in a later struct's
  // field resolves via `nameToTy`. Types register in source order, so a field may
  // reference an EARLIER struct; a forward reference to a later struct reports
  // "unknown type" (deferred).
  let ti = 0
  while ti < stmts.length {
    let sd = P.nodes[stmts[ti]]
    if sd is TypeDecl {
      let dfields = sd.tdFields
      let fnames: string[] = []
      let ftys: i32[] = []
      let fi = 0
      while fi < dfields.length {
        let fd = P.nodes[dfields[fi]]
        if fd is FieldDef {
          fnames.push(fd.fdName)
          let fty = TY_ERR
          if fd.fdType >= 0 {
            let ftn = P.nodes[fd.fdType]
            if ftn is TypeRef {
              let r = nameToTy(ftn.tyName)
              if r >= 0 {
                fty = r
              } else {
                tErr("unknown type '" + ftn.tyName + "' for field '" +
                  fd.fdName + "'", dfields[fi])
              }
            }
          }
          ftys.push(fty)
        }
        fi = fi + 1
      }
      cUserTypes[sd.tdName] = mkObjTy(fnames, ftys)
    } else if sd is UnionDecl {
      // A union's variants are type NAMES; resolve each (its variant structs
      // register earlier in source order) into the member type-arena indices.
      let variants = sd.udVariants
      let members: i32[] = []
      let vi = 0
      while vi < variants.length {
        let m = nameToTy(variants[vi])
        if m >= 0 {
          members.push(m)
        } else {
          tErr("unknown type '" + variants[vi] + "' in union '" +
            sd.udName + "'", stmts[ti])
        }
        vi = vi + 1
      }
      cUserTypes[sd.udName] = mkUnionTy(members)
    }
    ti = ti + 1
  }
  // Pass 1: hoist top-level function signatures so call-before-decl and mutual
  // recursion type-check.
  let hi = 0
  while hi < stmts.length {
    let s = P.nodes[stmts[hi]]
    if s is FuncDecl {
      let hp = s.fnParams
      let hpt: i32[] = []
      let k = 0
      while k < hp.length {
        let hpn = P.nodes[hp[k]]
        let t = TY_ERR
        if hpn is Param {
          if hpn.parType >= 0 {
            let hptn = P.nodes[hpn.parType]
            if hptn is TypeRef {
              let r = resolveAnnot(hptn.tyName, s.fnTyParams)
              if r >= 0 {
                t = r
              }
            }
          }
        }
        hpt.push(t)
        k = k + 1
      }
      // An UN-ANNOTATED return hoists as the PENDING sentinel (-2): the real type
      // is inferred from the body in pass 2 (or on demand at a forward call site),
      // then PATCHED into this same TyFunc in place.
      let hret = 0 - 2
      if s.fnRet >= 0 {
        let hrtn = P.nodes[s.fnRet]
        if hrtn is TypeRef {
          let r = resolveAnnot(hrtn.tyName, s.fnTyParams)
          if r >= 0 {
            hret = r
          } else {
            hret = TY_VOID
          }
        }
      }
      declare(s.fnName, mkFuncTy(hpt, hret))
      fnDeclIx[s.fnName] = stmts[hi]
    }
    hi = hi + 1
  }
  // Pass 2: check every top-level statement (bodies included).
  let j = 0
  while j < stmts.length {
    checkNode(stmts[j])
    j = j + 1
  }
  TY_VOID
}

// ── the Node visitor (dispatch; per-kind helpers above take narrowed variants) ──
// `checkNode` dispatches EVERY node kind — expressions AND statements — and
// returns the node's type-arena index (statements yield `TY_VOID`). Every
// per-variant body is INLINED here, including the nested `TypeRef`/`Param`/`Block`
// narrowing, because no other function may narrow `Node` (Finding 2). It is the
// direct analogue of the parser_harness's single `walk`. On a type error it
// raises a diagnostic and returns `TY_ERR` so checking continues.
function checkNode(ix: i32): i32 {
  if ix < 0 {
    return TY_ERR
  }
  let n = P.nodes[ix]

  // ── literals & identifiers ────────────────────────────────────────────────
  if n is NumLit {
    // A literal with a "." is f64, else i32 (a deliberately simple rule for the
    // subset — VL's real checker tracks literal types and softens; see PR note).
    if hasDot(n.numText) {
      return TY_F64
    }
    return TY_I32
  } else if n is StrLit {
    return TY_STR
  } else if n is CharLit {
    // A char literal `'x'` is its i32 CODE POINT (composes with arithmetic / `==` /
    // string indexing exactly like a bare int literal), NOT a string.
    return TY_I32
  } else if n is BoolLit {
    return TY_BOOL
  } else if n is NullLit {
    return TY_NULL
  } else if n is Ident {
    let ty = lookup(n.identName)
    if ty < 0 {
      tErr("undeclared identifier '" + n.identName + "'", ix)
      return TY_ERR
    }
    // Definite-assignment read gate: a bare-name READ of a still-unassigned
    // binding is "used before assigned". The LHS of a plain `=` is a WRITE, not a
    // read (the `BinExpr` `=` arm marks it as `daWriteTarget` before evaluating
    // the target), so it is skipped here; a compound `x += …` desugars to
    // `x = x + (…)` whose RHS reads `x` and DOES reach this gate.
    if ix != daWriteTarget {
      daCheckRead(n.identName, ix)
    }
    return ty
  } else if n is Paren {
    return checkNode(n.parInner)

  // ── unary ─────────────────────────────────────────────────────────────────
  } else if n is Unary {
    let arg = checkNode(n.unArg)
    if n.unOp == "!" {
      if !assignable(arg, TY_BOOL) {
        tErr("operator '!' expects bool, got " + tyToStr(arg), ix)
      }
      return TY_BOOL
    }
    // Postfix `x++` / `x--` (`"p+"`/`"p-"`): `unArg` is the `x = x ± 1` assignment,
    // already fully checked by `checkNode` above (const-reassign, numeric arithmetic,
    // assignability). The postfix expression's type is that of the operand.
    if n.unOp == "p+" || n.unOp == "p-" {
      if !isNumeric(arg) {
        tErr("'++'/'--' expects a numeric variable, got " + tyToStr(arg), ix)
        return TY_ERR
      }
      return arg
    }
    // "-"
    if !isNumeric(arg) {
      tErr("unary '-' expects a numeric type, got " + tyToStr(arg), ix)
      return TY_ERR
    }
    return arg

  // ── binary ────────────────────────────────────────────────────────────────
  } else if n is BinExpr {
    let op = n.binOp
    // `a && b` / `a || b`: the LEFT side's narrowings hold while CHECKING the
    // right (`p != null && p.x > 0` checks `p.x` under a non-null `p`; for `||`
    // the right is reached only when the left was FALSE, so its else-narrowings
    // hold — `p == null || p.x > 0`).
    if op == "&&" || op == "||" {
      let clt = checkNode(n.binLeft)
      let cnames: string[] = []
      let ctys: i32[] = []
      if op == "&&" {
        collectThenNarrows(n.binLeft, cnames, ctys)
      } else {
        collectElseNarrows(n.binLeft, cnames, ctys)
      }
      let cpushed = 0
      if cnames.length > 0 {
        pushScope()
        let cni = 0
        while cni < cnames.length {
          declare(cnames[cni], ctys[cni])
          cni = cni + 1
        }
        cpushed = 1
      }
      let crt = checkNode(n.binRight)
      if cpushed == 1 { popScope() }
      if !assignable(clt, TY_BOOL) || !assignable(crt, TY_BOOL) {
        tErr("operator '" + op + "' expects bool operands", ix)
      }
      return TY_BOOL
    }
    // Definite-assignment: the LHS of a plain `=` with a bare-name target is a
    // pure WRITE — flag the target node so the `Ident` arm does not trip
    // use-before-assign on it (the assignment is what assigns it). A compound
    // `x += …` is desugared to `x = x + (…)`: the inner `x` in the RHS is NOT the
    // write target, so its read is still gated. Cleared after the target is
    // checked. Saved/restored so a nested `=` (e.g. `a = (b = c)`) is exact.
    let savedWriteTarget = daWriteTarget
    if op == "=" {
      let wtgt = P.nodes[n.binLeft]
      if wtgt is Ident {
        daWriteTarget = n.binLeft
      }
    }
    let lt = checkNode(n.binLeft)
    daWriteTarget = savedWriteTarget
    let rt = checkNode(n.binRight)
    // Assignment: RHS must be assignable to the LHS's (already-bound) type.
    if op == "=" {
      // A `const` NAME cannot be rebound (`x = …`, and the `x++`/`x += …`
      // desugarings). Data behind it stays mutable (a Member/Index target).
      let tgt = P.nodes[n.binLeft]
      if tgt is Ident {
        if isConstName(tgt.identName) {
          tErr("cannot reassign `const` " + tgt.identName, ix)
        }
        // This write makes the binding definitely assigned on the current path.
        daMarkAssigned(tgt.identName)
      }
      // An index-set into an empty `[]` (`xs[i] = v`) pins its element type to
      // `typeof v` in place — usage-driven inference (`infer-empty-index-set.vl`),
      // clearing the uninferred floor. `lt` is the (open `-1`) element type, so
      // every assignment succeeds against it until it is pinned.
      if tgt is Index {
        let arrTy0 = checkNode(tgt.idxArr)
        let arrT0 = T.tys[arrTy0]
        if arrT0 is TyArray {
          if arrT0.aElem < 0 {
            arrT0.aElem = rt
          }
        }
      }
      if !assignable(rt, lt) {
        tErr("cannot assign " + tyToStr(rt) + " to " + tyToStr(lt), ix)
      }
      // Assignment is an expression yielding its RIGHT-HAND SIDE (host parity;
      // DECISIONS: assignment-as-expression).
      return rt
    }
    // Nullish coalescing: `a ?? d` strips `a`'s nullability; the default must be
    // assignable to the inner type. A non-nullable LHS just yields itself.
    if op == "??" {
      let lt2 = T.tys[lt]
      if lt2 is TyNullable {
        let inner = lt2.nInner
        if !assignable(rt, inner) {
          tErr("?? default: expected " + tyToStr(inner) + ", got " + tyToStr(rt), ix)
        }
        return inner
      }
      return lt
    }
    // Equality: result bool; requires mutual compatibility.
    if op == "==" || op == "!=" {
      if !assignable(lt, rt) && !assignable(rt, lt) {
        tErr("cannot compare " + tyToStr(lt) + " with " + tyToStr(rt), ix)
      } else {
        // SOUNDNESS: a STRUCTURAL `==`/`!=` on a plain object (or array) defaults
        // to field-by-field equality, which is sound only when every field is
        // itself value-comparable. A non-discriminated union/nullable/map field is
        // not — so reject the default structural compare and ask for an explicit
        // `==`. (Unions/nullables compared DIRECTLY — value-union equality, `==
        // null` nullness tests — never reach here: only an object/array operand is
        // tested, matching the host's anonymous-object structural fallback.)
        let lT = T.tys[lt]
        let structural = false
        if lT is TyObj {
          structural = true
        } else if lT is TyArray {
          structural = true
        }
        if structural {
          let seen: i32[] = []
          if !isEquatable(lt, seen) {
            tErr(tyToStr(lt) +
              " isn't equatable (a field is not value-comparable) — define a `==` operator for it",
              ix)
          }
        }
      }
      return TY_BOOL
    }
    // Ordering comparison: result bool; requires matching numeric types.
    if op == "<" || op == ">" || op == "<=" || op == ">=" {
      if !isNumeric(lt) || !isNumeric(rt) {
        tErr("comparison expects numeric operands, got " +
          tyToStr(lt) + " and " + tyToStr(rt), ix)
      } else if !sameNumeric(lt, rt) && !mixesNumeric(lt, rt) {
        // Mixed numerics may be compared when one side widens to the other
        // (i32/i64, i32/f64, f32/f64, …); the narrower side widens. Other mixes error.
        tErr("comparison mixes " + tyToStr(lt) + " and " + tyToStr(rt), ix)
      }
      return TY_BOOL
    }
    // `+` also concatenates strings.
    if op == "+" {
      if assignable(lt, TY_STR) && assignable(rt, TY_STR) {
        return TY_STR
      }
    }
    // Remaining arithmetic: numeric-only, both the SAME numeric type (no implicit
    // i32 ↔ f64).
    if !isNumeric(lt) || !isNumeric(rt) {
      tErr("operator '" + op + "' expects numeric operands, got " +
        tyToStr(lt) + " and " + tyToStr(rt), ix)
      return TY_ERR
    }
    // BITWISE / SHIFT operators are INTEGER-ONLY: a float operand (i32↔f64 mixing or
    // even same-type f64) has no bitwise form. Reject before the numeric-widening rules
    // so `1.0 & 2` errors (the float-widening lattice must not make it pass). Arithmetic
    // (`+ - * /`), `%`, and comparisons are unaffected.
    if op == "&" || op == "|" || op == "^" || op == "<<" || op == ">>" || op == ">>>" {
      if primNameOf(lt) == "f64" || primNameOf(lt) == "f32" ||
         primNameOf(rt) == "f64" || primNameOf(rt) == "f32" {
        tErr("operator '" + op + "' is integer-only, got " +
          tyToStr(lt) + " and " + tyToStr(rt), ix)
        return TY_ERR
      }
    }
    // A FLOAT LITERAL operand adopts the OTHER side's f32 type (the literal re-encodes
    // exactly at f32, so `x + 4.0` with `x: f32` stays f32 — the `4.0` is NOT demoted
    // f64). Checked before the general mixed rule so the result is f32, not the wider
    // f64. (One side is the f32 variable; the other the float literal typed f64.)
    if primNameOf(lt) == "f32" && isFloatLitExpr(n.binRight) { return lt }
    if primNameOf(rt) == "f32" && isFloatLitExpr(n.binLeft) { return rt }
    // A mixed-numeric op widens the narrower operand to the wider one and yields the
    // wider type (`i32 op i64`→i64, `f64 op i32`→f64, `f32 op f64`→f64, …). Done BEFORE
    // the same-type check so a compatible mixed pair is accepted (B2). i32-only programs
    // never reach here (they are `sameNumeric` and fall through to `return lt`).
    if mixesNumeric(lt, rt) {
      return widerNumeric(lt, rt)
    }
    if !sameNumeric(lt, rt) {
      tErr("operator '" + op + "' mixes " + tyToStr(lt) + " and " +
        tyToStr(rt), ix)
      return TY_ERR
    }
    return lt

  // ── call ──────────────────────────────────────────────────────────────────
  } else if n is Call {
    return checkCallNode(n, ix)

  // ── member access ───────────────────────────────────────────────────────────
  } else if n is Member {
    let objTy = checkNode(n.memObj)
    let ot = T.tys[objTy]
    if ot is TyObj {
      let ft = objFieldType(ot, n.memProp)
      if ft < 0 {
        tErr("no field '" + n.memProp + "' on " + tyToStr(objTy), ix)
        return TY_ERR
      }
      return ft
    }
    if ot is TyErr {
      return TY_ERR
    }
    // `.length` on an array, a map, or a string is an i32.
    if ot is TyArray {
      if n.memProp == "length" {
        return TY_I32
      }
      tErr("no field '" + n.memProp + "' on array " + tyToStr(objTy), ix)
      return TY_ERR
    }
    if ot is TyMap {
      if n.memProp == "length" {
        return TY_I32
      }
      tErr("no field '" + n.memProp + "' on map " + tyToStr(objTy), ix)
      return TY_ERR
    }
    if ot is TyPrim {
      if ot.primName == "string" {
        if n.memProp == "length" {
          return TY_I32
        }
        tErr("no field '" + n.memProp + "' on string", ix)
        return TY_ERR
      }
    }
    tErr("member access '." + n.memProp + "' on non-object " +
      tyToStr(objTy), ix)
    return TY_ERR

  // ── array literal ───────────────────────────────────────────────────────────
  // `[e, e, …]` types as `T[]` where `T` is the first element's type (the rest must
  // be assignable to it). An empty `[]` is `T[]` with an unknown element (`-1`),
  // assignable to any array — its concrete element is pinned by the binding's
  // annotation (`let a: i32[] = []`).
  } else if n is ArrayLit {
    let elems = n.arrElems
    if elems.length < 1 {
      return mkArrayTy(0 - 1)
    }
    let elemTy = checkNode(elems[0])
    let ei = 1
    while ei < elems.length {
      let et = checkNode(elems[ei])
      if !assignable(et, elemTy) {
        tErr("array element " + i32ToStr(ei) + " is " + tyToStr(et) +
          ", expected " + tyToStr(elemTy), ix)
      }
      ei = ei + 1
    }
    return mkArrayTy(elemTy)

  // ── index `a[i]` ────────────────────────────────────────────────────────────
  } else if n is Index {
    let arrTy = checkNode(n.idxArr)
    let idxTy = checkNode(n.idxIndex)
    let at = T.tys[arrTy]
    // A MAP index `m[k]`: the key must match the map's key type; a READ yields the
    // NULLABLE value (`V | null` — the key may be absent; default with `??`), and an
    // assignment target `m[k] = v` accepts a plain `V` (assignable to `V | null`).
    if at is TyMap {
      if !assignable(idxTy, at.mKey) {
        tErr("map key must be " + tyToStr(at.mKey) + ", got " + tyToStr(idxTy), ix)
      }
      return mkNullableTy(at.mVal)
    }
    if !assignable(idxTy, TY_I32) {
      tErr("array index must be i32, got " + tyToStr(idxTy), ix)
    }
    if at is TyArray {
      return at.aElem
    }
    if at is TyErr {
      return TY_ERR
    }
    // Indexing a string yields the i32 code point at that position.
    if at is TyPrim {
      if at.primName == "string" {
        return TY_I32
      }
    }
    tErr("cannot index non-array " + tyToStr(arrTy), ix)
    return TY_ERR

  // ── object literal ──────────────────────────────────────────────────────────
  // `{ x: e, y: e }` types as a structural `TyObj` whose fields carry each value's
  // checked type. Assignability against an annotation/param/return then matches it
  // to a declared struct by structure (`assignable`), so field ORDER need not match
  // the declaration. Reads each FieldInit child INLINE (Finding 2).
  } else if n is ObjLit {
    let fields = n.objFields
    let fnames: string[] = []
    let ftys: i32[] = []
    let i = 0
    while i < fields.length {
      let fnode = P.nodes[fields[i]]
      if fnode is FieldInit {
        fnames.push(fnode.fiName)
        ftys.push(checkNode(fnode.fiValue))
      }
      i = i + 1
    }
    return mkObjTy(fnames, ftys)

  // ── type guard `x is T` ─────────────────────────────────────────────────────
  // Always a `bool`. Checks the operand and that `T` names a known type. The actual
  // narrowing of `x` to `T` happens in the THEN branch of an enclosing `if` (see the
  // IfStmt case); used elsewhere it is just a boolean test.
  } else if n is IsExpr {
    let objTy = checkNode(n.isObj)
    let chkTy = nameToTy(n.isVariant)
    if chkTy < 0 {
      tErr("unknown type '" + n.isVariant + "' in 'is'", ix)
    } else if n.isVariant != "null" {
      // SOUNDNESS: `x is T` is meaningful only when `T` is one of the value's
      // possible variants (or `null`). When the value's type is a union/nullable,
      // the check type must be assignable to its non-null part — otherwise the
      // test can never hold (e.g. `(string | i32) is boolean`, or a struct outside
      // the union), so reject it rather than compile an always-false branch. Only
      // a union/nullable value is "testable"; a plain (incl. generic/inferred)
      // operand is left alone, matching the host.
      let ot = T.tys[objTy]
      let testable = false
      let baseTy = objTy
      if ot is TyUnion {
        testable = true
      } else if ot is TyNullable {
        testable = true
        baseTy = ot.nInner
      }
      if testable {
        if !assignable(chkTy, baseTy) {
          tErr("`is` check type '" + n.isVariant +
            "' is not a variant of " + tyToStr(objTy), ix)
        }
      }
    }
    return TY_BOOL

  // ── optional member `o?.field` ─────────────────────────────────────────────
  // Null-safe access: a NULLABLE receiver reads the field off its inner type and
  // re-wraps the result nullable (`{x: i32} | null` ?. x → `i32 | null`); a
  // non-null receiver behaves like a plain member read.
  } else if n is OptMember {
    let recv = checkNode(n.omObj)
    let rcv = T.tys[recv]
    let wasNullable = false
    let baseTy = recv
    if rcv is TyNullable {
      wasNullable = true
      baseTy = rcv.nInner
    }
    if baseTy < 0 {
      return TY_ERR
    }
    let bt = T.tys[baseTy]
    if bt is TyObj {
      let oft = objFieldType(bt, n.omProp)
      if oft < 0 {
        tErr("no field '" + n.omProp + "' on " + tyToStr(baseTy), ix)
        return TY_ERR
      }
      if wasNullable {
        return mkNullableTy(oft)
      }
      return oft
    }
    if bt is TyErr {
      return TY_ERR
    }
    tErr("member access '?." + n.omProp + "' on non-object " + tyToStr(recv), ix)
    return TY_ERR

  } else if n is ErrExpr {
    return TY_ERR

  // ── let / const ─────────────────────────────────────────────────────────────
  } else if n is LetDecl {
    // Resolve the annotation (if any) by reading the TypeRef child INLINE.
    let annot = -1
    if n.letType >= 0 {
      let tn = P.nodes[n.letType]
      if tn is TypeRef {
        annot = nameToTy(tn.tyName)
        if annot < 0 {
          tErr("unknown type '" + tn.tyName + "'", n.letType)
          annot = TY_ERR
        }
      }
    }
    let initTy = -1
    if n.letInit >= 0 {
      initTy = checkNode(n.letInit)
    }
    let bound = TY_ERR
    if annot >= 0 {
      bound = annot
      if initTy >= 0 {
        // An annotated assignment of an empty-collection initializer pins the
        // SOURCE binding's open holes from the annotation (`const ys: i32[] = zs`
        // resolves `zs`'s element) — clearing its uninferred floor in place.
        constrainEmpty(initTy, annot)
        if !assignableExpr(n.letInit, initTy, annot) {
          tErr("cannot assign " + tyToStr(initTy) + " to '" + n.letName +
            "' of type " + tyToStr(annot), ix)
        }
        // A `Set()` initializer keeps its SET flavor even under a map-shaped
        // annotation (`let s: {[string]: boolean} = Set()`): the binding exposes
        // the Set surface (`.add`, no `.set`/`.get`/`.keys`), with the
        // annotation's key/value types.
        let it2 = T.tys[initTy]
        if it2 is TyMap {
          if it2.mSet == 1 {
            let an2 = T.tys[annot]
            if an2 is TyMap {
              bound = mkMapTy(an2.mKey, an2.mVal, 1)
            }
          }
        }
      }
    } else if initTy >= 0 {
      bound = initTy
      // UN-INFERRED EMPTY-COLLECTION FLOOR: an un-annotated `[]` / `Map()` / `Set()`
      // whose hole is still open here may yet be pinned by a downstream
      // `.push`/`.set`/`.add` (those mutate the shared arena entry in place), so we
      // can't decide now. Record it for the scope-close re-check; if the hole stays
      // open it is genuinely uninferable and `flushUninferred` reports it.
      if unresolvedHole(bound) {
        notePending(n.letName, bound, ix)
      }
    } else {
      tErr("'" + n.letName + "' needs a type annotation or initializer", ix)
    }
    declare(n.letName, bound)
    if n.letKw == "const" {
      let ctop = constScopes.length - 1
      if ctop >= 0 {
        constScopes[ctop][n.letName] = true
      }
    }
    // Definite-assignment: an uninitialized `let x` / `let x: T` (no initializer)
    // starts UNASSIGNED; a later read before it is written is an error. An
    // initialized `let x = …` (and every `const`, which must have a value) is
    // assigned from the start, so it is never tracked. A re-declaration that
    // shadows clears any prior assigned/unassigned record under that name.
    daMarkAssigned(n.letName)
    if n.letInit < 0 {
      daAdd(n.letName)
    }
    return TY_VOID

  // ── function declaration ─────────────────────────────────────────────────────
  } else if n is FuncDecl {
    return checkFuncDeclNode(n)

  // ── while ─────────────────────────────────────────────────────────────────
  } else if n is WhileStmt {
    let wc = checkNode(n.whileCond)
    if !assignable(wc, TY_BOOL) {
      tErr("while-condition must be bool, got " + tyToStr(wc), ix)
    }
    // Definite-assignment: a loop body may run ZERO times, so an assignment
    // inside it is NOT guaranteed to reach code after the loop. Check the body
    // with the live state (so a read AFTER an in-body assignment is fine), then
    // RESTORE the pre-loop state for the fall-through.
    let daLoopEntry: string[] = daSnapshot()
    checkNode(n.whileBody)
    daRestore(daLoopEntry)
    return TY_VOID

  // ── break / continue ────────────────────────────────────────────────────────
  // Valid only inside a loop, but loop-nesting is not tracked yet, so they are
  // accepted unconditionally (a misplaced `break`/`continue` is a parser concern).
  } else if n is BreakStmt {
    return TY_VOID
  } else if n is ContinueStmt {
    return TY_VOID

  // ── for v in A to B [step S] ────────────────────────────────────────────────
  // A numeric range loop: the bounds (and step, if present) must be i32; the loop
  // variable is i32 in the body's scope.
  } else if n is ForRange {
    let frFrom = checkNode(n.frFrom)
    let frTo = checkNode(n.frTo)
    if !assignable(frFrom, TY_I32) || !assignable(frTo, TY_I32) {
      tErr("for-range bounds must be i32, got " + tyToStr(frFrom) + " and " +
        tyToStr(frTo), ix)
    }
    if n.frStep >= 0 {
      let frStep = checkNode(n.frStep)
      if !assignable(frStep, TY_I32) {
        tErr("for-range step must be i32, got " + tyToStr(frStep), ix)
      }
    }
    pushScope()
    declare(n.frVar, TY_I32)
    // Loop body may run zero times — see `WhileStmt` (A-definite-assign).
    let daFrEntry: string[] = daSnapshot()
    checkNode(n.frBody)
    daRestore(daFrEntry)
    popScope()
    return TY_VOID

  // ── for v in iterable ───────────────────────────────────────────────────────
  // A for-in loop over an array: the loop variable binds to the element type.
  } else if n is ForIn {
    let iterTy = checkNode(n.fiIter)
    let elemTy = TY_ERR
    let it = T.tys[iterTy]
    if it is TyArray {
      elemTy = it.aElem
    } else if it is TyErr {
      elemTy = TY_ERR
    } else {
      tErr("for-in expects an array, got " + tyToStr(iterTy), ix)
    }
    pushScope()
    declare(n.fiVar, elemTy)
    // Loop body may run zero times — see `WhileStmt` (A-definite-assign).
    let daFiEntry: string[] = daSnapshot()
    checkNode(n.fiBody)
    daRestore(daFiEntry)
    popScope()
    return TY_VOID

  // ── if / else ─────────────────────────────────────────────────────────────
  } else if n is IfStmt {
    let condTy = checkNode(n.ifCond)
    if !assignable(condTy, TY_BOOL) {
      tErr("if-condition must be bool, got " + tyToStr(condTy), ix)
    }
    // Narrowing over a simple identifier:
    //  - `if x is T { … }` refines `x` to the variant `T` in the THEN branch.
    //  - `if x != null { … }` refines a nullable `x` to its inner type in the THEN.
    //  - `if x == null { … } else { … }` refines `x` to inner in the ELSE; and when
    //    the THEN always exits (a guard clause), `x` is inner AFTER the `if` too.
    // Branch narrowing rides a pushed scope that shadows `x`. (Union-complement
    // narrowing after `is T` was tried and REVERTED — it made VL miss real errors;
    // null-stripping is the well-defined core and is what the corpus leans on.)
    // The condition's TRUE narrowings hold in the THEN branch, its FALSE
    // narrowings in the ELSE (and, for a diverging then — a guard clause — for
    // the rest of the enclosing block). The collectors handle `is` / null
    // compares / `&&`-`||` chains / `!(…)` / parens.
    let tnNames: string[] = []
    let tnTys: i32[] = []
    collectThenNarrows(n.ifCond, tnNames, tnTys)
    let enNames: string[] = []
    let enTys: i32[] = []
    collectElseNarrows(n.ifCond, enNames, enTys)
    // Definite-assignment fork/join: each branch is a separate path forked off
    // the if-entry state; after the chain they JOIN. A binding is assigned after
    // the `if` only if assigned on EVERY surviving (non-diverging) path. With no
    // `else`, the implicit fall-through (condition false) is a surviving path
    // that assigns nothing — so a write only inside `if c { x = 1 }` does NOT
    // make `x` assigned afterwards. A branch that always exits (`return`/`break`/
    // `continue`) contributes nothing to the merge (its end is unreachable).
    let daEntry: string[] = daSnapshot()
    let daThenDiverges = daBranchDiverges(n.ifThen)
    if tnNames.length > 0 {
      pushScope()
      let ti = 0
      while ti < tnNames.length {
        declare(tnNames[ti], tnTys[ti])
        ti = ti + 1
      }
    }
    checkNode(n.ifThen)
    if tnNames.length > 0 {
      popScope()
    }
    // Surviving paths' end-states, each as an unassigned snapshot. Seed with the
    // then-branch end if it survived.
    let daThenEnd: string[] = daSnapshot()
    daRestore(daEntry)
    let daElseDiverges = false
    let daElseEnd: string[] = daEntry
    let daHasElse = n.ifElse >= 0
    if daHasElse {
      daElseDiverges = daBranchDiverges(n.ifElse)
      if enNames.length > 0 {
        pushScope()
        let ei = 0
        while ei < enNames.length {
          declare(enNames[ei], enTys[ei])
          ei = ei + 1
        }
      }
      checkNode(n.ifElse)
      if enNames.length > 0 {
        popScope()
      }
      daElseEnd = daSnapshot()
    }
    // Join the surviving paths. Start from the empty set and fold in every
    // surviving path's unassigned set (the union = "unassigned on some surviving
    // path"). The else path (or, with no `else`, the entry fall-through) always
    // counts unless it diverges.
    daClear()
    if !daThenDiverges {
      daJoinInto(daThenEnd)
    }
    if daHasElse {
      if !daElseDiverges {
        daJoinInto(daElseEnd)
      }
    } else {
      daJoinInto(daEntry)
    }
    // GUARD CLAUSE: a THEN that always exits applies the FALSE narrowings to
    // the rest of the enclosing block (`if x == null { return } … x.f …`).
    if enNames.length > 0 {
      let tn2 = P.nodes[n.ifThen]
      if tn2 is Block {
        let tst = tn2.blkStmts
        if tst.length > 0 {
          let last = P.nodes[tst[tst.length - 1]]
          let diverges = false
          if last is RetStmt {
            diverges = true
          } else if last is BreakStmt {
            diverges = true
          } else if last is ContinueStmt {
            diverges = true
          }
          if diverges {
            let gi2 = 0
            while gi2 < enNames.length {
              declare(enNames[gi2], enTys[gi2])
              gi2 = gi2 + 1
            }
          }
        }
      }
    }
    return TY_VOID

  // ── return ────────────────────────────────────────────────────────────────
  } else if n is RetStmt {
    let want = T.curRet
    if n.retArg < 0 {
      if want >= 0 && !assignable(TY_VOID, want) {
        tErr("return needs a value of type " + tyToStr(want), ix)
      }
      return TY_VOID
    }
    // Under a PENDING return type (-2: this function's return is being inferred),
    // record the returned type as a witness instead of checking a mismatch.
    if want == 0 - 2 {
      noteInferredRet(checkNode(n.retArg))
      return TY_VOID
    }
    let got = checkNode(n.retArg)
    // An explicit `return inner` of an empty collection pins its element from the
    // declared return type — usage-driven inference clearing the floor.
    constrainEmpty(got, want)
    if want >= 0 && !assignable(got, want) {
      tErr("return type mismatch: expected " + tyToStr(want) + ", got " +
        tyToStr(got), ix)
    }
    return TY_VOID

  // ── block ─────────────────────────────────────────────────────────────────
  } else if n is Block {
    pushScope()
    let stmts = n.blkStmts
    let i = 0
    while i < stmts.length {
      checkNode(stmts[i])
      i = i + 1
    }
    popScope()
    return TY_VOID

  // ── program ───────────────────────────────────────────────────────────────
  } else if n is Program {
    return checkProgramNode(n)

  } else if n is Param {
    return TY_VOID
  } else if n is TypeRef {
    return TY_VOID
  } else if n is TypeDecl {
    // Registered by the Program pass-0 pre-pass; nothing to do when visited.
    return TY_VOID
  } else if n is UnionDecl {
    // Registered by the Program pass-0 pre-pass; nothing to do when visited.
    return TY_VOID
  }
  TY_ERR
}

// The public entry point: check the program rooted at node `rootIx`, returning
// the number of diagnostics raised (diagnostics also accumulate on `T.diags`).
// (The old PR #5 gap — a discarded/`let`-bound call return mis-lowering at module
// scale, which forced callers into expression position — is fixed and pinned by
// `tests/cases/statements/discarded-call-return.vl`; the discarded `checkNode`
// below exercises it in this very module.)
export function checkProgram(rootIx: i32): i32 {
  checkNode(rootIx)
  // The global scope (depth 0) is never popped, so flush its un-annotated
  // empty-collection bindings here: any still-open hole is genuinely uninferable.
  flushUninferred(0)
  T.diags.length
}
