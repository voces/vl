// `emit_bignum.vl` â€” arbitrary-precision integer math + numeric-literal helpers,
// extracted from the emitter. A `bignum` is a little-endian `i32[]` of base-2^16
// limbs powering the i64 / `2^31` literal range checks. A self-contained LEAF â€” no
// emitter state beyond its own `gDivRemNonzero` flag, no cross-module calls, no
// cycle. Split out to shrink `wasmEmit.vl`.

// Scratch out-param for `bigDivmod`: set to `true` when the division left a NONZERO
// remainder (the IEEE-754 "sticky" bit). The decimalâ†’double encoder reads it after the
// final divide to decide round-to-nearest-ties-to-even. (Slice 3.)
export let gDivRemNonzero = false

// Does the non-negative integer LEXEME `t` (a `NumLit.numText`: decimal / hex /
// binary / octal, `_` separators skipped) fit the i32 range [0, 2147483647]?
// Mirrors the checker's `intLexemeFitsI32` (the host `defaultIntegerType`
// magnitude rule): a literal past the bound is TYPED i64, so it must lower as
// `i64.const` â€” `i32.const` would silently wrap (0xDEAD_BEEF). The lexeme never
// carries a sign (unary minus is a separate node). Digits fold with a
// pre-multiply overflow guard (`v > (max - d) / base`), no 64-bit arithmetic.
export function numLexFitsI32(t: string) {
  let v = 0
  let i = 0
  let base = 10
  if t.length >= 2 && t[0] == '0' {
    const p = t[1]
    if p == 'x' || p == 'X' {
      base = 16
      i = 2
    } else if p == 'b' || p == 'B' {
      base = 2
      i = 2
    } else if p == 'o' || p == 'O' {
      base = 8
      i = 2
    }
  }
  while i < t.length {
    let c = t[i]
    if c == '_' {
      i = i + 1
    } else {
      let d = 0
      if c >= '0' && c <= '9' { d = c - '0' }
      else if c >= 'a' && c <= 'f' { d = c - 'a' + 10 }
      else { d = c - 'A' + 10 }
      if v > (2147483647 - d) / base { return false }
      v = v * base + d
      i = i + 1
    }
  }
  true
}
// Is the integer LEXEME's magnitude EXACTLY 2^31 (2147483648)? Mirrors the
// checker's `intLexemeIs2Pow31`: the host folds a negated literal into a signed
// literal before defaulting, so `-2147483648` is i32 (it sits AT I32_MIN) even
// though the bare magnitude is one past I32_MAX. Used by the unary `-` arms.
// Compares the significant digits (base prefix, `_` separators and leading
// zeros stripped) against 2^31 written in the lexeme's base.
export function numLexIs2Pow31(t: string) {
  let digits = "2147483648"
  let i = 0
  if t.length >= 2 && t[0] == '0' {
    const p = t[1]
    if p == 'x' || p == 'X' {
      digits = "80000000"
      i = 2
    } else if p == 'b' || p == 'B' {
      digits = "10000000000000000000000000000000"
      i = 2
    } else if p == 'o' || p == 'O' {
      digits = "20000000000"
      i = 2
    }
  }
  let started = false
  let j = 0
  while i < t.length {
    let c = t[i]
    if c == '_' {
      i = i + 1
    } else if !started && c == '0' {
      i = i + 1
    } else {
      started = true
      if j >= digits.length { return false }
      if c != digits[j] { return false }
      i = i + 1
      j = j + 1
    }
  }
  j == digits.length
}
// Fold a non-negative integer LEXEME (a `NumLit.numText`, possibly past the i32
// range) into a 64-bit (hi, lo) i32 PAIR, returned as `[hi, lo]`. Mirrors
// `parseI32`'s base detection (hex `0x`/binary `0b`/octal `0o`, else decimal,
// with `_` separators skipped) but accumulates into the pair via 64-bit
// multiply-add so values like `0xFFFFFFFFFF` survive intact. Each step computes
// `pair = pair * base + digit` using `mulAdd64`.
export function parseI64Pair(text: string) {
  let hi = 0
  let lo = 0
  let i = 0
  let base = 10
  if text.length >= 2 && text[0] == '0' {
    const p = text[1]
    if p == 'x' || p == 'X' {
      base = 16
      i = 2
    } else if p == 'b' || p == 'B' {
      base = 2
      i = 2
    } else if p == 'o' || p == 'O' {
      base = 8
      i = 2
    }
  }
  while i < text.length {
    let c = text[i]
    if c == '_' {
      i = i + 1
    } else {
      let d = 0
      if c >= '0' && c <= '9' { d = c - '0' }
      else if c >= 'a' && c <= 'f' { d = c - 'a' + 10 }
      else { d = c - 'A' + 10 }
      let r = mulAdd64(hi, lo, base, d)
      hi = r[0]
      lo = r[1]
      i = i + 1
    }
  }
  let out: i32[] = []
  out.push(hi)
  out.push(lo)
  out
}
// 64-bit `(hi, lo) * m + add`, returned as `[hi, lo]`. `m`/`add` are small
// (base â‰¤ 16, digit â‰¤ 15) so the multiply fits without a full 64Ă—64. The low
// lane is split into two 16-bit halves so each partial product stays within i32;
// carries propagate into the high lane. All lanes are treated as UNSIGNED 32-bit.
export function mulAdd64(hi: i32, lo: i32, m: i32, add: i32) {
  const loLow = lo & 0xffff
  const loHigh = (lo >>> 16) & 0xffff
  const p0 = loLow * m + add
  const p1 = loHigh * m + (p0 >>> 16)
  const newLo = (p0 & 0xffff) | ((p1 & 0xffff) << 16)
  let carry = p1 >>> 16
  // High lane: hi * m + carry, low 32 bits kept (overflow past 64 bits is dropped,
  // as the host's `i64.const` wraps mod 2^64).
  const hiLow = hi & 0xffff
  const hiHigh = (hi >>> 16) & 0xffff
  const q0 = hiLow * m + carry
  const q1 = hiHigh * m + (q0 >>> 16)
  const newHi = (q0 & 0xffff) | ((q1 & 0xffff) << 16)
  let out: i32[] = []
  out.push(newHi)
  out.push(newLo)
  out
}
// Drop leading-zero limbs (keep at least one). A bignum is always >= 1 limb.
export function bigTrim(a: i32[]) {
  while a.length > 1 && a[a.length - 1] == 0 { a.pop() }
  a
}
// True when the bignum is exactly zero.
export function bigIsZero(a: i32[]) { a.length == 1 && a[0] == 0 }
// `a * m` for a small (<= 0xffff) multiplier. Each limbĂ—m fits in i32; carry rolls up.
export function bigMulSmall(a: i32[], m: i32) {
  let out: i32[] = []
  let carry = 0
  let i = 0
  while i < a.length {
    const p = a[i] * m + carry
    out.push(p & 0xffff)
    carry = (p >>> 16) & 0xffff
    i = i + 1
  }
  while carry != 0 {
    out.push(carry & 0xffff)
    carry = (carry >>> 16) & 0xffff
  }
  if out.length == 0 { out.push(0) }
  bigTrim(out)
}
// `a + v` for a small (<= 0xffff) addend.
export function bigAddSmall(a: i32[], v: i32) {
  let out: i32[] = []
  let i = 0
  while i < a.length {
    out.push(a[i])
    i = i + 1
  }
  let carry = v
  let j = 0
  while carry != 0 {
    if j >= out.length { out.push(0) }
    let s = out[j] + carry
    out[j] = s & 0xffff
    carry = (s >>> 16) & 0xffff
    j = j + 1
  }
  bigTrim(out)
}
// Compare two bignums: -1 if a<b, 0 if equal, 1 if a>b.
export function bigCmp(a: i32[], b: i32[]) {
  if a.length != b.length {
    if a.length < b.length { return -1 }
    return 1
  }
  let i = a.length - 1
  while i >= 0 {
    if a[i] != b[i] {
      if a[i] < b[i] { return -1 }
      return 1
    }
    i = i - 1
  }
  0
}
// `a - b`, requiring a >= b (caller guarantees). Borrow-propagating limb subtract.
export function bigSub(a: i32[], b: i32[]) {
  let out: i32[] = []
  let borrow = 0
  let i = 0
  while i < a.length {
    let bv = 0
    if i < b.length { bv = b[i] }
    let d = a[i] - bv - borrow
    if d < 0 {
      d = d + 0x10000
      borrow = 1
    } else {
      borrow = 0
    }
    out.push(d)
    i = i + 1
  }
  bigTrim(out)
}
// `a * 2` (left shift by one bit).
export function bigShl1(a: i32[]) {
  let out: i32[] = []
  let carry = 0
  let i = 0
  while i < a.length {
    let v = (a[i] << 1) | carry
    out.push(v & 0xffff)
    carry = (v >>> 16) & 1
    i = i + 1
  }
  if carry != 0 { out.push(1) }
  bigTrim(out)
}
// `a >> 1` (floor divide by two). Walk limbs highâ†’low, threading the dropped bit.
export function bigShr1(a: i32[]) {
  let out: i32[] = []
  let i = 0
  while i < a.length {
    out.push(0)
    i = i + 1
  }
  let carry = 0
  let k = a.length - 1
  while k >= 0 {
    let v = a[k] | (carry << 16)
    out[k] = (v >>> 1) & 0xffff
    carry = v & 1
    k = k - 1
  }
  bigTrim(out)
}
// `a << bits` (multiply by 2^bits), applied bit-by-bit (`bits` is small here).
export function bigShlK(a: i32[], bits: i32) {
  let r = a
  let i = 0
  while i < bits {
    r = bigShl1(r)
    i = i + 1
  }
  r
}
// Number of significant bits in `a` (0 for zero).
export function bigBitLen(a: i32[]) {
  if bigIsZero(a) { return 0 }
  let top = a[a.length - 1]
  let bits = (a.length - 1) * 16
  while top != 0 {
    bits = bits + 1
    top = top >>> 1
  }
  bits
}
// Bit `idx` (0 = least significant) of `a`.
export function bigGetBit(a: i32[], idx: i32) {
  const limb = idx >>> 4
  const off = idx & 15
  if limb >= a.length { return 0 }
  (a[limb] >>> off) & 1
}
// floor(n / d) by bitwise long division. The REMAINDER's nonzero-ness (the sticky
// bit) is returned via the `gDivRemNonzero` module global â€” that is all the encoder
// needs from the remainder, so no second array is returned.
export function bigDivmod(n: i32[], d: i32[]) {
  const nb = bigBitLen(n)
  let rem: i32[] = []
  rem.push(0)
  const qbits: i32[] = []
  let b = nb - 1
  while b >= 0 {
    rem = bigShl1(rem)
    if bigGetBit(n, b) == 1 { rem = bigAddSmall(rem, 1) }
    if bigCmp(rem, d) >= 0 {
      rem = bigSub(rem, d)
      qbits.push(1)
    } else {
      qbits.push(0)
    }
    b = b - 1
  }
  // qbits are MSB-first; fold into a bignum.
  let q: i32[] = []
  q.push(0)
  let i = 0
  while i < qbits.length {
    q = bigShl1(q)
    if qbits[i] == 1 { q = bigAddSmall(q, 1) }
    i = i + 1
  }
  gDivRemNonzero = !bigIsZero(rem)
  bigTrim(q)
}
// Parse a non-negative integer lexeme (a `NumLit.numText`) into its i32 value.
// The lexer stores the RAW source lexeme: a plain decimal digit run, OR a `0x`/
// `0X` hex run, OR a `0b`/`0B` binary run (it mirrors the host's base set, but
// keeps the lexeme un-normalized â€” so the base is folded here, at value time).
// The prefix is detected from the first two chars; otherwise base-10 is assumed.
// Each digit char's value is its char code minus the appropriate base offset.
export function parseI32(text: string) {
  let v = 0
  let i = 0
  // Hex `0xâ€¦` / binary `0bâ€¦` / octal `0oâ€¦` â€” skip the two-char prefix, then fold
  // base 16 / 2 / 8. A `_` digit separator (legal in every base) is skipped.
  if text.length >= 2 && text[0] == '0' {
    const p = text[1]
    if p == 'x' || p == 'X' {
      i = 2
      while i < text.length {
        let c = text[i]
        if c == '_' {
          i = i + 1
        } else {
          let d = 0
          if c >= '0' && c <= '9' { d = c - '0' }
          else if c >= 'a' && c <= 'f' { d = c - 'a' + 10 }
          else { d = c - 'A' + 10 }
          v = v * 16 + d
          i = i + 1
        }
      }
      return v
    }
    if p == 'b' || p == 'B' {
      i = 2
      while i < text.length {
        if text[i] == '_' {
          i = i + 1
        } else {
          v = v * 2 + (text[i] - '0')
          i = i + 1
        }
      }
      return v
    }
    if p == 'o' || p == 'O' {
      i = 2
      while i < text.length {
        if text[i] == '_' {
          i = i + 1
        } else {
          v = v * 8 + (text[i] - '0')
          i = i + 1
        }
      }
      return v
    }
  }
  while i < text.length {
    if text[i] == '_' {
      i = i + 1
    } else {
      v = v * 10 + (text[i] - '0')
      i = i + 1
    }
  }
  v
}

// Set by `ieeeBytes` when the literal's magnitude rounds AT or PAST the format's
// all-ones exponent â€” the value f64/f32 cannot represent finitely. The checker's
// `f64LitOverflows`/`f32LitOverflows` and the emitter's `fbF64Const`/`fbF32Const`
// backstop read it, so the overflow judgement has ONE implementation (the same
// alignment + rounding that encodes the bytes) and cannot drift.
export let gIeeeOverflow = false
// Encode the decimal literal `text` as its little-endian IEEE-754 bytes (i32[]). Shared by
// `f64Bytes`/`f32Bytes`, parameterized over the format: `sigBits` significand bits (53 / 24),
// `bias` exponent bias (1023 / 127), `nbytes` output width (8 / 4). The subtle, error-prone
// core â€” sign/mantissa parse, num/den build, align to `sigBits + 1`, divmod, round-to-nearest-
// ties-to-even down to `sigBits` bits â€” lives ONCE here; only the final byte PACKING (the two
// formats lay their fraction/exponent/sign bits out differently) branches on width. Rounding is
// a SINGLE round on the exact decimal value, never decimalâ†’f64â†’f32, so it never double-rounds.
// The same bignum helpers (`bigShlK`/`bigDivmod`/`bigShr1`/â€¦) drive both widths.
function ieeeBytes(text: string, sigBits: i32, bias: i32, nbytes: i32) {
  gIeeeOverflow = false
  let neg = false
  let i = 0
  if text.length > 0 {
    if text[0] == '-' {
      neg = true
      i = 1
    } else if text[0] == '+' {
      i = 1
    }
  }
  // Parse mantissa digits (ignoring `.` and `_`), counting fractional digits.
  let mant: i32[] = []
  mant.push(0)
  let frac = 0
  let dot = false
  while i < text.length {
    let c = text[i]
    if c == '_' {
      i = i + 1
    } else if c == '.' {
      dot = true
      i = i + 1
    } else {
      mant = bigMulSmall(mant, 10)
      mant = bigAddSmall(mant, c - '0')
      if dot { frac = frac + 1 }
      i = i + 1
    }
  }
  if bigIsZero(mant) {
    // +/- zero: all bytes 0 except the sign in the top bit of the high byte.
    const z: i32[] = []
    let zi = 0
    while zi < nbytes {
      z.push(0)
      zi = zi + 1
    }
    if neg { z[nbytes - 1] = 0x80 }
    return z
  }
  // value = mant / 10^frac. Build numerator and denominator bignums.
  let num = mant
  let den: i32[] = []
  den.push(1)
  let fk = 0
  while fk < frac {
    den = bigMulSmall(den, 10)
    fk = fk + 1
  }
  // value = (num/den) * 2^exp. Align so floor(num/den) has exactly `sigBits + 1` bits, then
  // round the guard bit plus the remainder (sticky) down to a `sigBits`-bit significand.
  const alignW = sigBits + 1
  let exp = 0
  const diff = bigBitLen(num) - bigBitLen(den)
  if diff < alignW {
    num = bigShlK(num, alignW - diff)
    exp = exp - (alignW - diff)
  } else if diff > alignW {
    den = bigShlK(den, diff - alignW)
    exp = exp + (diff - alignW)
  }
  let q = bigDivmod(num, den)
  // The bit-length estimate can be one off; correct to exactly `alignW` bits.
  while bigBitLen(q) < alignW {
    num = bigShl1(num)
    exp = exp - 1
    q = bigDivmod(num, den)
  }
  while bigBitLen(q) > alignW {
    den = bigShl1(den)
    exp = exp + 1
    q = bigDivmod(num, den)
  }
  // â”€â”€ exponent-range clamp (IEEE-754 overflow / gradual underflow) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  // q is `alignW` bits, so value = q * 2^exp = 1.xx * 2^(exp + sigBits): encoded
  // NORMAL this value carries biased exponent `exp + sigBits + bias`. Outside
  // [1, 2*bias] the packing below would mask the exponent's high bits and encode
  // an arbitrary WRONG finite value â€” clamp instead: at or past all-ones encode
  // Â±infinity; at or below zero take the gradual-underflow path.
  const preBiased = exp + sigBits + bias
  let qs: i32[] = []
  let biased = 0
  if preBiased <= 0 {
    // GRADUAL UNDERFLOW: too small for a normal â€” round AT THE SUBNORMAL
    // precision (fixed exponent Emin = 1 - bias, fewer significand bits). The
    // integer significand is f = value * 2^(sigBits - 1 - Emin); compute
    // floor(2f) exactly from the num/den ratio (the extra low bit is the round
    // guard, the division remainder the sticky), then round-to-nearest-ties-
    // to-even â€” ONE rounding at the target precision, so no double-round. A
    // value below half the smallest subnormal yields qs = 0 and packs as Â±0.
    // The scale 2f = (num/den) * 2^(preBiased - 1) is always a den shift here.
    den = bigShlK(den, 1 - preBiased)
    const q2 = bigDivmod(num, den) // floor(2f)
    const sGuard = q2[0] & 1
    let sSticky = 0
    if gDivRemNonzero { sSticky = 1 }
    qs = bigShr1(q2) // floor(f)
    let sRoundUp = false
    if sGuard == 1 {
      if sSticky == 1 { sRoundUp = true }
      else if (qs[0] & 1) == 1 { sRoundUp = true }
    }
    if sRoundUp { qs = bigAddSmall(qs, 1) }
    // `biased` stays 0 (subnormal) unless rounding carried all the way up to
    // 1.0 * 2^Emin â€” the smallest NORMAL (fraction 0, biased exponent 1). The
    // shared packing below masks off the implicit-1 bit either way.
    if bigBitLen(qs) >= sigBits { biased = 1 }
  } else {
    // q is `alignW` bits; reduce to `sigBits`. guard = dropped low bit; sticky =
    // remainder nonzero.
    const guard = q[0] & 1
    let sticky = 0
    if gDivRemNonzero { sticky = 1 }
    qs = bigShr1(q)
    let es = exp + 1
    // Round-to-nearest, ties-to-even: round up on guard=1 with sticky, or an exact tie
    // (guard=1, sticky=0) when the kept LSB is odd.
    let roundUp = false
    if guard == 1 {
      if sticky == 1 { roundUp = true }
      else if (qs[0] & 1) == 1 { roundUp = true }
    }
    if roundUp {
      qs = bigAddSmall(qs, 1)
      if bigBitLen(qs) > sigBits {
        qs = bigShr1(qs)
        es = es + 1
      }
    }
    // qs is exactly `sigBits` bits in [2^(sigBits-1), 2^sigBits): qs = 1.f * 2^(sigBits-1),
    // value = 1.f * 2^(es + sigBits - 1).
    const bigE = es + (sigBits - 1)
    biased = bigE + bias
    // OVERFLOW: at or past the all-ones exponent (rounding included). An
    // out-of-range literal is a COMPILE ERROR (the checker rejects it via
    // `f64LitOverflows`/`f32LitOverflows`, the emitter's `fbF64Const`/
    // `fbF32Const` keep an `emitFail` backstop over this same flag) â€” the
    // Â±infinity encoding below is the defensive value behind those gates
    // (exponent all ones, fraction 0; the empty `qs` reads as 0 limbs).
    const maxBiased = bias + bias + 1
    if biased >= maxBiased {
      gIeeeOverflow = true
      qs = []
      biased = maxBiased
    }
  }
  // Read the low 16-bit limbs of the significand.
  let m0 = 0
  let m1 = 0
  let m2 = 0
  let m3 = 0
  if qs.length > 0 { m0 = qs[0] }
  if qs.length > 1 { m1 = qs[1] }
  if qs.length > 2 { m2 = qs[2] }
  if qs.length > 3 { m3 = qs[3] }
  let out: i32[] = []
  if nbytes == 8 {
    // 52-bit fraction in bytes 0..6 (low nibble of byte 6), 11-bit biased exponent straddling
    // byte 6 (high nibble) and byte 7, sign in bit 7 of byte 7. m3 bit 52 is the implicit 1.
    out.push(m0 & 0xff)
    out.push((m0 >>> 8) & 0xff)
    out.push(m1 & 0xff)
    out.push((m1 >>> 8) & 0xff)
    out.push(m2 & 0xff)
    out.push((m2 >>> 8) & 0xff)
    const fracHi = m3 & 0xf // frac bits 48..51 (bit 52 implicit-1 dropped)
    out.push(fracHi | ((biased & 0xf) << 4)) // byte 6: frac 48..51 | exp low 4 bits
    let signTop = 0
    if neg { signTop = 0x80 }
    out.push(((biased >>> 4) & 0x7f) | signTop) // byte 7: exp high 7 bits | sign
  } else {
    // 23-bit fraction in bytes 0..2 (low 7 bits of byte 2), 8-bit biased exponent straddling
    // byte 2 (high bit) and byte 3, sign in bit 7 of byte 3. Bit 23 of `sig` is the implicit 1.
    let sig = (m0 & 0xffff) | ((m1 & 0xff) << 16)
    out.push(sig & 0xff)
    out.push((sig >>> 8) & 0xff)
    const fracHi = (sig >>> 16) & 0x7f // frac bits 16..22 (bit 23 implicit-1 dropped)
    out.push(fracHi | ((biased & 1) << 7)) // byte 2: frac 16..22 | exp low bit
    let signTop = 0
    if neg { signTop = 0x80 }
    out.push(((biased >>> 1) & 0x7f) | signTop) // byte 3: exp high 7 bits | sign
  }
  out
}
// The 8-byte little-endian IEEE-754 double for decimal literal `text`. Sign is parsed too
// (a leading `-`/`+`), though the NumLit site never carries one (unary minus is a separate node).
export function f64Bytes(text: string) { ieeeBytes(text, 53, 1023, 8) }
// The 4-byte little-endian IEEE-754 single (Slice 5). Validated bit-for-bit against
// `DataView.setFloat32` for 2.5/5.0/4.0/6.5/0.1/3.14/etc.
export function f32Bytes(text: string) { ieeeBytes(text, 24, 127, 4) }

// The count of significant INTEGER digits of a decimal float lexeme (digits before
// the `.`, `_` separators skipped, leading zeros skipped). The cheap magnitude
// prescreen for the overflow predicates: overflow needs the boundary digit count
// (309 for f64, 39 for f32) â€” VL has no exponent syntax, so magnitude IS digits.
function decIntDigits(t: string) {
  let i = 0
  if t.length > 0 {
    if t[0] == '-' || t[0] == '+' { i = 1 }
  }
  let n = 0
  let seen = false
  while i < t.length {
    const c = t[i]
    if c == '.' { return n }
    if c != '_' {
      // A non-decimal lexeme (hex/binary/octal `0xâ€¦`) never reaches the decimal
      // encoder's range â€” report 0 digits so the predicates pass it through.
      if c < '0' || c > '9' { return 0 }
      if c != '0' { seen = true }
      if seen { n = n + 1 }
    }
    i = i + 1
  }
  n
}

// True if the decimal literal `text` rounds to Â±infinity as an f64 â€” i.e. the
// literal OVERFLOWS the format and must be rejected. Exact at the boundary: away
// from it the digit-count prescreen decides (< 309 integer digits can never
// overflow; the f64 max is ~1.798e308), at it the REAL encoder runs and its
// rounding decides (so `â€¦157e308` stays finite while the next tick past the
// overflow midpoint rejects â€” one implementation, no drift).
export function f64LitOverflows(text: string) {
  if decIntDigits(text) < 309 { return false }
  f64Bytes(text)
  gIeeeOverflow
}

// The f32 flavor: overflow needs >= 39 integer digits (the f32 max is ~3.403e38).
export function f32LitOverflows(text: string) {
  if decIntDigits(text) < 39 { return false }
  f32Bytes(text)
  gIeeeOverflow
}
