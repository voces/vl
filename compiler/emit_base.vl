// `emit_base.vl` â€” the emitter's PURE vocabulary: type-NAME analysis (`name*`/`ty*`/
// `ann*`/`ret*`/`nul*`), monomorphization name logic (`mono*`/`gae*`), and low-level
// string/byte/opcode helpers. None touch emitter state; a leaf the emitter (and
// `emit_query`) import. Carved out of `wasmEmit.vl`.

import {
  inferRetNameOf,
  isValueUnionName,
  nameIsFuncTypeAtom,
  nameIsLitUnionType,
  nodeTyArrayElemRepName,
  nodeTyIsClosureArray,
  nodeTyIsFunc,
  nodeTyIsLitUnionAlias,
  nodeTyIsNulClosure,
  nodeTyIsNulI32List,
  nodeTyIsNulString,
  nodeTyIxOf,
  nodeTyWidenedRepName,
  parenEnclosesWhole,
  splitUnionAtoms,
  unionMemberCount,
  valueAtomKind,
} from "./typecheck"
import {
  ArrayLit,
  Block,
  BoolLit,
  Call,
  CharLit,
  FieldInit,
  ForIn,
  ForRange,
  FuncDecl,
  Ident,
  IfStmt,
  LetDecl,
  Member,
  NumLit,
  ObjLit,
  P,
  Param,
  Paren,
  StrLit,
  TypeDecl,
  TypeRef,
  WhileStmt,
  i32ToStr,
} from "./ast"

// Unsigned LEB128: 7 bits per byte, low-to-high, high bit set while more remain.
export function ulebToArr(value: i32) {
  const out: i32[] = []
  let v = value
  let more = true
  while more {
    const byte = v & 0x7f
    v = v >>> 7
    if v == 0 {
      out.push(byte)
      more = false
    } else {
      out.push(byte | 0x80)
    }
  }
  out
}
// SLEB-encode `value` into a fresh `i32[]`.
export function slebToArr(value: i32) {
  const out: i32[] = []
  let v = value
  let more = true
  while more {
    const byte = v & 0x7f
    v = v >> 7
    let signBit = 0
    if (byte & 0x40) != 0 { signBit = 1 }
    if v == 0 {
      if signBit == 0 {
        out.push(byte)
        more = false
      } else {
        out.push(byte | 0x80)
      }
    } else {
      if v == -1 {
        if signBit == 1 {
          out.push(byte)
          more = false
        } else {
          out.push(byte | 0x80)
        }
      } else {
        out.push(byte | 0x80)
      }
    }
  }
  out
}
// Append all of `src` onto `dst` (in place) and return `dst`.
export function appendAll(dst: i32[], src: i32[]) {
  let i = 0
  while i < src.length {
    dst.push(src[i])
    i = i + 1
  }
  dst
}
// The IEEE-754 literal encoders (`f64Bytes`/`f32Bytes`) live in `emit_bignum` â€” a
// leaf, so the CHECKER shares the exact same overflow judgement
// (`f64LitOverflows`/`f32LitOverflows`) without an import cycle.
// True if `name` is currently in the `bound` set (a param or an in-scope `let`).
export function capIsBound(bound: string[], name: string) {
  let i = 0
  while i < bound.length {
    if bound[i] == name { return true }
    i = i + 1
  }
  false
}
// True if `name` is in `caps` already (dedup the capture list).
export function capHas(caps: string[], name: string) {
  let i = 0
  while i < caps.length {
    if caps[i] == name { return true }
    i = i + 1
  }
  false
}
// Record a free-variable reference to `name`: a capture unless it is bound locally,
// a module global, or a top-level/lifted function name (addressable directly).
// A compiler BUILTIN function name (`print`, `toString`, `Map`, â€¦): a call target the
// emitter lowers directly, NOT a value â€” so it is never a captured variable. Excluded in
// `capRecord` alongside user functions, else a closure whose body calls a builtin (e.g.
// `function f() { print(1) }` used as a value) spuriously "captures" the builtin name and
// fails `captured variable not found`.
export function isBuiltinFnName(name: string) {
  if name == "print" { return true }
  if name == "toString" { return true }
  if name == "fromCodePoint" { return true }
  if name == "fromCodePoints" { return true }
  if name == "Map" { return true }
  if name == "Set" { return true }
  if name == "__array_new__" { return true }
  if name == "__array_new_default__" { return true }
  if name == "__array_copy__" { return true }
  if name == "__log__" { return true }
  if name == "__trap__" { return true }
  false
}
// A single-entry cache for `parentLetOf`: the block whose name->LetDecl map is built, and the
// map (`name -> LetDecl arena index`, FIRST-wins). The emitter resolves identifiers in one
// function at a time, and every `parentLetOf` caller passes that function's BODY block, so a
// one-entry cache rebuilds once per function and serves the rest O(1) â€” `parentLetOf` was the
// single hottest self-compile function (~10%) because each call re-walked the whole body.
// `resetParentLetCache` clears it at `emitProgram` start (the arena is rebuilt each compile, so
// a stale block index from a prior compile on a SHARED instance must not be trusted).
let plCacheBlock: i32 = -1
let plCacheMap: {[string]: i32} = Map()

export function resetParentLetCache() {
  plCacheBlock = -1
  plCacheMap = Map()
  0
}

// Fill `plCacheMap` with every function-scoped `LetDecl` reachable from `blockIx` (descending
// into if/loop bodies â€” wasm locals are function-scoped), in the SAME pre-order `parentLetOf`
// walked, FIRST-wins, so the map's entry for a name is the first declaration that walk found.
// Scan one statement node (or a block) for `let`/`const` declarations, recording each into
// `plCacheMap` (first occurrence wins). Recurses through every body that shares the function's
// local scope: BOTH branches of an `if`/`else if` CHAIN â€” crucially the else slot may be a bare
// `Block` OR a nested `IfStmt` (an `else if`), and the old code descended only Blocks, so lets in
// `else if` arms were invisible â€” plus `while`/`for` loop bodies and nested blocks. wasm locals are
// function-scoped, so a binding ANYWHERE in the function must be found regardless of nesting.
function plScanStmt(ix: i32) {
  if ix < 0 { return 0 }
  const st = P.nodes[ix]
  if st is LetDecl {
    if !plCacheMap.has(st.letName) { plCacheMap[st.letName] = ix }
  } else if st is IfStmt {
    plScanStmt(st.ifThen)
    if st.ifElse >= 0 { plScanStmt(st.ifElse) }
  } else if st is WhileStmt {
    plScanStmt(st.whileBody)
  } else if st is ForRange {
    plScanStmt(st.frBody)
  } else if st is ForIn {
    plScanStmt(st.fiBody)
  } else if st is Block {
    const stmts = st.blkStmts
    let i = 0
    while i < stmts.length {
      plScanStmt(stmts[i])
      i = i + 1
    }
  }
  0
}

function plBuildLetMap(blockIx: i32) { plScanStmt(blockIx) }

// Find a `LetDecl` for `name` anywhere in the parent body block (incl. nested if/loop
// bodies â€” wasm locals are function-scoped). Returns its arena index or -1. Backed by the
// single-entry per-block cache above (built on a miss, then O(1)).
export function parentLetOf(blockIx: i32, name: string) {
  if blockIx < 0 { return -1 }
  if blockIx != plCacheBlock {
    plCacheMap = Map()
    plBuildLetMap(blockIx)
    plCacheBlock = blockIx
  }
  if plCacheMap.has(name) {
    const r = plCacheMap[name] ?? -1
    return r
  }
  -1
}
// The loop-stack position a `break`/`continue` targets: "" (unlabelled) binds
// to the TOP entry (the innermost loop); a label scans from the top for the
// nearest enclosing loop carrying it. Returns -1 when the label names no
// enclosing loop (the emit-time fail-loud guard).
export function loopStackFind(labels: string[], label: string) {
  if label == "" { return labels.length - 1 }
  let i = labels.length - 1
  while i >= 0 {
    if labels[i] == label { return i }
    i = i - 1
  }
  -1
}
// The VALUE type-name of a synthetic map type-name `{[K]:V}` â€” the text after the
// FIRST "]:" (the key cannot contain `]`), minus the closing `}`. Mirrors the
// checker's split (typecheck.vl `parseMapName`). "" if the name is not that shape.
export function mapValNameOf(name: string) {
  if !nameIsMap(name) { return "" }
  let i = 2
  while i < name.length - 1 {
    if name[i] == ']' {
      if name[i + 1] == ':' { return name.slice(i + 2, name.length - 1) }
    }
    i = i + 1
  }
  ""
}
// Map a binary operator lexeme to its i32 wasm opcode, or -1 if unsupported. The
// three arithmetic ops and the six signed i32 comparisons are recognized; anything
// else (`/`, `%`, `=`, logical `&&`/`||`, â€¦) falls through to -1 so the caller
// fails loudly rather than emitting a wrong opcode. Comparisons leave a 0/1 i32 on
// the stack â€” exactly what a wasm `if` condition consumes.
//   `+`  -> i32.add  (0x6a)   `-`  -> i32.sub  (0x6b)   `*`  -> i32.mul  (0x6c)
//   `==` -> i32.eq   (0x46)   `!=` -> i32.ne   (0x47)
//   `<`  -> i32.lt_s (0x48)   `>`  -> i32.gt_s (0x4a)
//   `<=` -> i32.le_s (0x4c)   `>=` -> i32.ge_s (0x4e)
export function binOpcode(op: string) {
  if op == "+" {
    return 106 // 0x6a i32.add
  }
  if op == "-" {
    return 107 // 0x6b i32.sub
  }
  if op == "*" {
    return 108 // 0x6c i32.mul
  }
  if op == "/" {
    return 109 // 0x6d i32.div_s (signed; VL `i32` division is signed)
  }
  if op == "%" {
    return 111 // 0x6f i32.rem_s (signed remainder)
  }
  if op == "==" {
    return 70 // 0x46 i32.eq
  }
  if op == "!=" {
    return 71 // 0x47 i32.ne
  }
  if op == "<" {
    return 72 // 0x48 i32.lt_s
  }
  if op == ">" {
    return 74 // 0x4a i32.gt_s
  }
  if op == "<=" {
    return 76 // 0x4c i32.le_s
  }
  if op == ">=" {
    return 78 // 0x4e i32.ge_s
  }
  // Bitwise / shift (integer-only). VL `i32` is signed, so `>>` is the SIGNED
  // (arithmetic) shift `shr_s` and `>>>` the UNSIGNED (logical) shift `shr_u` â€”
  // the distinction the LEB encoders' `v >>> 7` relies on. Mirrors the host
  // `INT_BINOPS` map in toWasm.ts (`&`->and, `|`->or, `>>`->shr_s, `>>>`->shr_u).
  if op == "&" {
    return 113 // 0x71 i32.and
  }
  if op == "|" {
    return 114 // 0x72 i32.or
  }
  if op == "^" {
    return 115 // 0x73 i32.xor
  }
  if op == "<<" {
    return 116 // 0x74 i32.shl
  }
  if op == ">>" {
    return 117 // 0x75 i32.shr_s (signed/arithmetic)
  }
  if op == ">>>" {
    return 118 // 0x76 i32.shr_u (unsigned/logical)
  }
  -1
}
// The i64 instruction variant for `op` (Slice 2), selected when an operand is i64.
// Arithmetic/bitwise/shift consume two i64 and leave an i64; comparisons consume two
// i64 and leave an i32 BOOL. Returns -1 for an op with no i64 form (`&&`/`||`/`=`/`??`).
//   +  i64.add 0x7c  -  i64.sub 0x7d  *  i64.mul 0x7e  /  i64.div_s 0x7f  %  i64.rem_s 0x81
//   &  i64.and 0x83  |  i64.or 0x84   ^  i64.xor 0x85  << i64.shl  0x86
//   >> i64.shr_s 0x87  >>> i64.shr_u 0x88
//   == i64.eq 0x51  != i64.ne 0x52  < i64.lt_s 0x53  > i64.gt_s 0x55
//   <= i64.le_s 0x57  >= i64.ge_s 0x59
export function binOpcodeI64(op: string) {
  if op == "+" {
    return 124 // 0x7c i64.add
  }
  if op == "-" {
    return 125 // 0x7d i64.sub
  }
  if op == "*" {
    return 126 // 0x7e i64.mul
  }
  if op == "/" {
    return 127 // 0x7f i64.div_s
  }
  if op == "%" {
    return 129 // 0x81 i64.rem_s
  }
  if op == "&" {
    return 131 // 0x83 i64.and
  }
  if op == "|" {
    return 132 // 0x84 i64.or
  }
  if op == "^" {
    return 133 // 0x85 i64.xor
  }
  if op == "<<" {
    return 134 // 0x86 i64.shl
  }
  if op == ">>" {
    return 135 // 0x87 i64.shr_s
  }
  if op == ">>>" {
    return 136 // 0x88 i64.shr_u
  }
  if op == "==" {
    return 81 // 0x51 i64.eq
  }
  if op == "!=" {
    return 82 // 0x52 i64.ne
  }
  if op == "<" {
    return 83 // 0x53 i64.lt_s
  }
  if op == ">" {
    return 85 // 0x55 i64.gt_s
  }
  if op == "<=" {
    return 87 // 0x57 i64.le_s
  }
  if op == ">=" {
    return 89 // 0x59 i64.ge_s
  }
  -1
}
// The f64 instruction variant for `op` (Slice 3), selected when an operand is f64.
// Arithmetic consumes two f64 and leaves an f64; comparisons consume two f64 and leave
// an i32 BOOL. Returns -1 for an op with no f64 form (`%`/bitwise/shift/`&&`/`||`/...).
//   +  f64.add 0xa0  -  f64.sub 0xa1  *  f64.mul 0xa2  /  f64.div 0xa3
//   == f64.eq 0x61   != f64.ne 0x62   <  f64.lt 0x63   >  f64.gt 0x64
//   <= f64.le 0x65   >= f64.ge 0x66
export function binOpcodeF64(op: string) {
  if op == "+" {
    return 160 // 0xa0 f64.add
  }
  if op == "-" {
    return 161 // 0xa1 f64.sub
  }
  if op == "*" {
    return 162 // 0xa2 f64.mul
  }
  if op == "/" {
    return 163 // 0xa3 f64.div
  }
  if op == "==" {
    return 97 // 0x61 f64.eq
  }
  if op == "!=" {
    return 98 // 0x62 f64.ne
  }
  if op == "<" {
    return 99 // 0x63 f64.lt
  }
  if op == ">" {
    return 100 // 0x64 f64.gt
  }
  if op == "<=" {
    return 101 // 0x65 f64.le
  }
  if op == ">=" {
    return 102 // 0x66 f64.ge
  }
  -1
}
// The f32 instruction variant for `op` (Slice 5), selected when an operand is f32.
// Arithmetic consumes two f32 and leaves an f32; comparisons consume two f32 and leave
// an i32 BOOL. Returns -1 for an op with no f32 form (`%`/bitwise/shift/`&&`/`||`/...).
//   +  f32.add 0x92  -  f32.sub 0x93  *  f32.mul 0x94  /  f32.div 0x95
//   == f32.eq 0x5b   != f32.ne 0x5c   <  f32.lt 0x5d   >  f32.gt 0x5e
//   <= f32.le 0x5f   >= f32.ge 0x60
export function binOpcodeF32(op: string) {
  if op == "+" {
    return 146 // 0x92 f32.add
  }
  if op == "-" {
    return 147 // 0x93 f32.sub
  }
  if op == "*" {
    return 148 // 0x94 f32.mul
  }
  if op == "/" {
    return 149 // 0x95 f32.div
  }
  if op == "==" {
    return 91 // 0x5b f32.eq
  }
  if op == "!=" {
    return 92 // 0x5c f32.ne
  }
  if op == "<" {
    return 93 // 0x5d f32.lt
  }
  if op == ">" {
    return 94 // 0x5e f32.gt
  }
  if op == "<=" {
    return 95 // 0x5f f32.le
  }
  if op == ">=" {
    return 96 // 0x60 f32.ge
  }
  -1
}
// Find the value-expr index for declared field `fieldName` in the object literal at
// `objIx`, or -1 if the literal does not set that field.
export function objFieldVal(objIx: i32, fieldName: string) {
  const o = P.nodes[objIx]
  if o is ObjLit {
    const fields = o.objFields
    let i = 0
    while i < fields.length {
      const f = P.nodes[fields[i]]
      if f is FieldInit {
        if f.fiName == fieldName { return f.fiValue }
      }
      i = i + 1
    }
  }
  -1
}
// True when an `is` RHS names a LITERAL type (`"a"`, `0`, `1.5`) â€” the runtime
// value-test arm of `emitIs` (the place's literal-union ANNOTATION softened to
// the base scalar in `canonEmitTypeNames`; the `is` compares the value).
export function isLitVariantName(name: string) {
  if name.length == 0 { return false }
  const c = name[0]
  if c == '"' { return true }
  c >= '0' && c <= '9'
}
// True when the union-box operand at `exprIx` can be re-evaluated without side
// effects (an ident read â€” a param, local, or module global).
export function unionEqOperandOk(exprIx: i32) {
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Ident { return true }
  false
}
// The value-eq opcode (i32 result) for a scalar union atom: `i32`/`boolean`
// share `i32.eq`; i64/f64/f32 take their own. -1 for `string` (its eq loop) /
// `null` (tag equality alone decides it â€” no payload).
export function atomEqOpcode(atom: string) {
  const k = valueAtomKind(atom)
  if k == 0 || k == 1 {
    return 70 // 0x46 i32.eq
  }
  if k == 3 {
    return 81 // 0x51 i64.eq
  }
  if k == 4 {
    return 97 // 0x61 f64.eq
  }
  if k == 5 {
    return 91 // 0x5b f32.eq
  }
  -1
}
// Lower a field read `recv.field` onto `body`: evaluate the receiver (must be a
// struct), then `struct.get $0 <fieldidx>` (`0xfb 0x02 0x00 idx`).
// The narrowing-stack KEY of a member path over a plain Ident root (`o.y`, or
// nested `n.a.b`) â€” the same string `setNarrowFromCond` pushes for a union-FIELD
// `is`/null guard. "" for any other receiver shape (no path narrowing).
export function memberPathKeyOf(memIx: i32) {
  const m = P.nodes[memIx]
  if m is Member {
    const r = P.nodes[unwrapParen(m.memObj)]
    if r is Ident { return r.identName + "." + m.memProp }
    // A nested path (`n.a.b`) keys through its receiver's own path key â€” a
    // non-Ident, non-Member link (a call, an index) stays un-narrowable.
    if r is Member {
      const inner = memberPathKeyOf(unwrapParen(m.memObj))
      if inner != "" { return inner + "." + m.memProp }
    }
  }
  ""
}
// The hex value of a hex-digit code point `c` (`0-9 a-f A-F`), or -1 if not hex.
export function hexDigit(c: i32) {
  if c >= '0' && c <= '9' { return c - '0' }
  if c >= 'a' && c <= 'f' { return c - 'a' + 10 }
  if c >= 'A' && c <= 'F' { return c - 'A' + 10 }
  -1
}
// Decode the raw string lexeme `raw` (with its surrounding quotes) into the i32 vector
// of code points it denotes, resolving escapes consistently with the lexer's
// `scanQuoted`. The first and last chars are the quote delimiters and are skipped. An
// unknown escape keeps the char after the backslash verbatim (the lexer's lenient
// policy). `\u{â€¦}`/`\xXX`/`\uXXXX` with too few/invalid hex digits keep the marker
// char (`u`/`x`) verbatim â€” again matching the lexer â€” so this never fails loudly.
export function decodeStr(raw: i32[]) {
  const out: i32[] = []
  const n = raw.length
  // Strip the surrounding quote chars (raw always has at least the two delimiters).
  let i = 1
  const last = n - 1
  while i < last {
    const c = raw[i]
    if c == '\\' && i + 1 < last {
      const e = raw[i + 1]
      if e == 'n' {
        out.push(10)
        i = i + 2
      } else if e == 't' {
        out.push(9)
        i = i + 2
      } else if e == 'r' {
        out.push(13)
        i = i + 2
      } else if e == '\\' {
        out.push(92)
        i = i + 2
      } else if e == '"' {
        out.push(34)
        i = i + 2
      } else if e == '\'' {
        out.push(39)
        i = i + 2
      } else if e == '0' {
        out.push(0)
        i = i + 2
      } else if e == 'b' {
        out.push(8)
        i = i + 2
      } else if e == 'f' {
        out.push(12)
        i = i + 2
      } else if e == 'v' {
        out.push(11)
        i = i + 2
      } else if e == 'x' {
        // `\xXX` â€” exactly two hex digits, else keep `x` verbatim.
        let h1 = -1
        let h2 = -1
        if i + 3 < last {
          h1 = hexDigit(raw[i + 2])
          h2 = hexDigit(raw[i + 3])
        }
        if h1 >= 0 && h2 >= 0 {
          out.push(h1 * 16 + h2)
          i = i + 4
        } else {
          out.push('x')
          i = i + 2
        }
      } else if e == 'u' {
        if i + 2 < last && raw[i + 2] == '{' {
          // `\u{â€¦}` â€” 1-6 hex digits up to `}`.
          let cp = 0
          let cnt = 0
          let j = i + 3
          while j < last && raw[j] != '}' && hexDigit(raw[j]) >= 0 {
            cp = cp * 16 + hexDigit(raw[j])
            cnt = cnt + 1
            j = j + 1
          }
          if (
            j < last &&
            raw[j] == '}' &&
            cnt >= 1 &&
            cnt <= 6 &&
            cp <= 1114111
          ) {
            out.push(cp)
            i = j + 1
          } else {
            out.push('u')
            i = i + 2
          }
        } else {
          // `\uXXXX` â€” exactly four hex digits, else keep `u` verbatim.
          let u1 = -1
          let u2 = -1
          let u3 = -1
          let u4 = -1
          if i + 5 < last {
            u1 = hexDigit(raw[i + 2])
            u2 = hexDigit(raw[i + 3])
            u3 = hexDigit(raw[i + 4])
            u4 = hexDigit(raw[i + 5])
          }
          if u1 >= 0 && u2 >= 0 && u3 >= 0 && u4 >= 0 {
            out.push(u1 * 4096 + u2 * 256 + u3 * 16 + u4)
            i = i + 6
          } else {
            out.push('u')
            i = i + 2
          }
        }
      } else {
        // Unknown escape: keep the char after the backslash verbatim.
        out.push(e)
        i = i + 2
      }
    } else {
      out.push(c)
      i = i + 1
    }
  }
  out
}
// Copy a `string`'s code points into an `i32[]` so `decodeStr` can index past the end
// safely with arithmetic. `s[i]` already yields the i32 code point (strings ARE
// code-point arrays in this representation), so this is a straight element copy.
export function strToCps(s: string) {
  const out: i32[] = []
  let i = 0
  while i < s.length {
    out.push(s[i])
    i = i + 1
  }
  out
}
// Peel any nested parentheses, returning the innermost wrapped expression index.
export function unwrapParen(exprIx: i32) {
  const cur = exprIx
  const node = P.nodes[cur]
  if node is Paren { return unwrapParen(node.parInner) }
  cur
}
// True when a parameter-ordered argument list failed to bind: a hole (-1, an
// unfilled parameter slot) or a length differing from the source argument
// count (a leftover named/positional arg appended past the slots).
export function directArgsBad(args: i32[], callIx: i32) {
  const c = P.nodes[callIx]
  if c is Call {
    if args.length != c.callArgs.length { return true }
  }
  let i = 0
  while i < args.length {
    if args[i] < 0 { return true }
    i = i + 1
  }
  false
}
// True if function `fnIx`'s return type CARRIES `null` â€” a niche (`boolean|null` /
// `string|null`), a nullable struct ref (`S|null`) / list (`i32[]|null`), or a value-union
// box whose atoms include `null` (`i32|null`, annotated or inferred). A structural
// fall-through in such a function is sound â€” it yields that null (`emitNullForRet`),
// not dead `unreachable` padding. A non-nullable value return with a reachable
// fall-through was already rejected by the checker, so it never reaches here.
// The inferred NICHE-nullable name for an un-annotated function `name` â€” "boolean|null"
// or "string|null" (canonicalized), or "" otherwise. A niche nullable lowers via its
// sentinel / `ref.null $array` rep (not the value box), so it is recognized by NAME from
// the A20 inferred-return table rather than by a `fn.fnRet` annotation node.
export function inferNicheNullByName(name: string) {
  const im = inferRetNameOf(name)
  if im == "boolean|null" { return "boolean|null" }
  if im == "string|null" { return "string|null" }
  ""
}
// â”€â”€ nullable struct refs (`S | null`) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// "S|null" / "null|S" (exactly TWO `|` parts, one of them `null`) â†’ the non-null
// part's name, or "" when the name is not a two-part nullable.
export function nullablePartOf(name: string) {
  // Depth-aware: a `|` INSIDE an inline shape (`{y:string|i32}|null`) is part of
  // the FIELD's union, not the nullable wrapper â€” only a depth-0 bar splits.
  let bar = -1
  let depth = 0
  let i = 0
  while i < name.length {
    const ch = name[i]
    if ch == '{' || ch == '[' || ch == '(' { depth = depth + 1 }
    if ch == '}' || ch == ']' || ch == ')' { depth = depth - 1 }
    if ch == '|' && depth == 0 {
      if bar < 0 { bar = i }
    }
    i = i + 1
  }
  if bar < 0 { return "" }
  const a = name.slice(0, bar)
  const b = name.slice(bar + 1, name.length)
  if a == "null" { return b }
  if b == "null" { return a }
  ""
}
// `1` if the type-annotation node at `tyIx` is a NULLABLE STRUCT (`S | null` with a
// resolvable struct part), else `0`. Feeds the `kind == 9` (nullable struct ref,
// `0x63`) family.
// True if the annotation node at `tyIx` is `boolean|null` â€” the NICHE scalar
// nullable (host: `nullSentinel`): an i32 holding 0/1, with the spare value 2
// encoding `null` (no box). `== null` is a sentinel compare; narrowing to
// non-null is purely type-level (the i32 is already 0/1 in the branch).
export function tyIsNulBool(tyIx: i32) {
  if tyIx < 0 { return false }
  const ty = P.nodes[tyIx]
  if ty is TypeRef { return nullablePartOf(ty.tyName) == "boolean" }
  false
}
// True if the type-annotation node at `tyIx` is `boolean`/`bool`.
export function tyIsBool(tyIx: i32) {
  if tyIx < 0 { return false }
  const ty = P.nodes[tyIx]
  if ty is TypeRef { return ty.tyName == "boolean" }
  false
}
// True if `name` is a nullable i32-BACKED list â€” `i32[] | null`, `boolean[] | null`, or a
// literal-union `K[] | null` / `("a"|"b")[] | null` (parser-joined `â€¦|null`, depth-aware either
// side of the bar). `boolean[]` (an i32 0/1) and a litunion array (interned-i32 atom elements)
// share the i32-list REP exactly, so they ride the SAME nullable i32-list kind/field-code (18 /
// `nullist`) as `i32[] | null` â€” one predicate, every i32-backed leaf, mirroring `nameIsI32Array`
// at the non-nullable position. A scalar-elem (`f64[]|null`, `i64[]|null`, `f32[]|null`,
// `string[]|null`) or ref-elem (`S[]|null`) list has a DISTINCT backing and keeps failing loudly.
export function nameIsNulI32List(name: string) {
  nameIsI32Array(nullablePartOf(name))
}
// A `string | null` field type name â€” the niche FIELD (code 20): a `(ref null $aTypeIdx)`
// storage slot (the array backing a string), the field analogue of the kind-16 local.
export function nameIsNulString(name: string) {
  nullablePartOf(name) == "string"
}
// A `boolean | null` field type name â€” the niche FIELD (code 21): an i32 storage slot
// holding 0/1 with the spare value 2 = `null` (the field analogue of the sentinel local).
export function nameIsNulBool(name: string) {
  const b = nullablePartOf(name)
  b == "boolean"
}
// True if `name` is a 1-D `(boolean | null)[]` list â€” a LIST of the boolean sentinel
// niche. Its backing is the SAME `(array (mut i32))` as `boolean[]` / `i32[]`: each
// element is an i32 holding 0/1, with the spare value 2 = `null` (the list analogue of
// the scalar `boolean | null` niche â€” no box). So it rides the i32-list machinery
// (`nameIsI32Array`) rather than the union-box ref-list, and elements coerce/read
// through the sentinel (construct/`push`/index-assign seed `null â†’ 2`; a read compares
// against 2). A nested `(boolean|null)[][]` / nullable `(boolean|null)[] | null` is NOT
// this (their element is a LIST, not the scalar niche) â€” only the single-level list.
export function nameIsNulBoolList(name: string) {
  if !nameIsArray(name) { return false }
  let elem = name.slice(0, name.length - 2)
  if elem.length > 1 {
    if elem[0] == '(' {
      if elem[elem.length - 1] == ')' { elem = elem.slice(1, elem.length - 1) }
    }
  }
  nameIsNulBool(elem)
}
// True if `name` is a 1-D `(string | null)[]` list â€” a LIST of the string ref made nullable.
// Its backing is the SAME string list (`$mkListIdx` wrapper, `(ref null $aTypeIdx)` string backing)
// as `string[]`: a `string[]` element is ALREADY a NULLABLE ref at the wasm level, so the nullable
// element needs no new type â€” only `null â†’ ref.null $aTypeIdx` on construct and the element READ
// (kept `(ref null)` = a `nulstr`, narrowed with `!= null`) differ. Rides the string-list machinery
// (`retStrArrFlag`, via `nodeTyArrayElemRepName` â†’ "string"), NOT the union-box ref list. A nested
// `(string|null)[][]` / nullable `(string|null)[] | null` is NOT this (their element is a LIST).
export function nameIsNulStrList(name: string) {
  if !nameIsArray(name) { return false }
  let elem = name.slice(0, name.length - 2)
  if elem.length > 1 {
    if elem[0] == '(' {
      if elem[elem.length - 1] == ')' { elem = elem.slice(1, elem.length - 1) }
    }
  }
  nameIsNulString(elem)
}
// True if `name` is a 1-D `(K | null)[]` list â€” a LIST of the literal-union atom made nullable via
// the i32 NICHE. Its backing is the SAME `(array (mut i32))` as `K[]` / `i32[]`: each element is an
// i32 holding a member id (â‰Ą 0) with the spare value `-1` = `null` (the list analogue of the scalar
// `K | null` niche â€” no box). So it rides the i32-list machinery (`nameIsI32Array`), NOT the
// union-box ref-list: a member-literal element lowers as its atom id, a `null` element as `-1`, and a
// read compares against `-1` for the narrow. A nested `(K|null)[][]` / nullable `(K|null)[] | null` is
// NOT this (their element is a LIST, not the scalar niche) â€” only the single-level list.
export function nameIsNulLitUnionList(name: string) {
  if !nameIsArray(name) { return false }
  let elem = name.slice(0, name.length - 2)
  if elem.length > 1 {
    if elem[0] == '(' {
      if elem[elem.length - 1] == ')' { elem = elem.slice(1, elem.length - 1) }
    }
  }
  nameIsNulLitUnion(elem)
}
// A NULLABLE LITERAL-UNION type name â€” `K | null` / `"a" | "b" | null` (the i32 atom NICHE): the
// member ids are interned â‰Ą 0 and the spare value `-1` encodes `null` (no box, like the boolean
// niche but with a NEGATIVE sentinel since atom ids start at 0). `canonEmitName` PRESERVES the
// litunion (`nulLitUnionPreserve`) so the members survive here â€” a `K | null` is detected by the
// alias non-null part (`nullablePartOf` â†’ litunion), and the expanded inline form `"a"|"b"|null` by
// its all-quoted non-null members. Routes to `vtKindOfType` kind 0 (plain i32); `== null` is a
// `-1` compare and narrowing to the bare litunion is purely type-level (the i32 already holds a
// valid id in the non-null branch).
export function nameIsNulLitUnion(name: string) {
  // Two-part `K | null`: the non-null part is a litunion alias / inline union.
  const b = nullablePartOf(name)
  if b != "" { return nameIsLitUnionType(b) }
  // Expanded multi-member form `"a" | "b" | null`: a top-level `null` member plus an all-quoted-
  // literal remainder (2+ members, so `nullablePartOf`'s two-part split missed it).
  if !nameHasNullMember(name) { return false }
  nulLitUnionCore(name)
}
// The NON-null part of a nullable-litunion name â€” the litunion alias (`K` of `K | null`)
// or the re-joined quoted members of the expanded inline form (`"a" | "b"` of
// `"a" | "b" | null`). "" when `name` is not a nullable litunion.
export function nulLitUnionInnerName(name: string) {
  if !nameIsNulLitUnion(name) { return "" }
  const b = nullablePartOf(name)
  if b != "" { return b }
  const parts: string[] = []
  splitUnionAtoms(name, parts)
  let out = ""
  let i = 0
  while i < parts.length {
    if parts[i] != "null" {
      if out == "" { out = parts[i] } else { out = out + " | " + parts[i] }
    }
    i = i + 1
  }
  out
}
// True if `name` has a top-level (depth-0) `null` union member.
function nameHasNullMember(name: string) {
  const parts: string[] = []
  splitUnionAtoms(name, parts)
  let i = 0
  while i < parts.length {
    if parts[i] == "null" { return true }
    i = i + 1
  }
  false
}
// True if `name`'s NON-null top-level members are 2+ and all quoted string literals (the expanded
// inline nullable-litunion core `"a" | "b" | null`).
function nulLitUnionCore(name: string) {
  const parts: string[] = []
  splitUnionAtoms(name, parts)
  let lits = 0
  let i = 0
  while i < parts.length {
    const p = parts[i]
    if p != "null" {
      if p.length < 2 { return false }
      if p[0] != '"' { return false }
      lits = lits + 1
    }
    i = i + 1
  }
  lits >= 2
}
// A NULLABLE FUNCTION-VALUE type name â€” `((i32) => i32) | null` (kind 19): a
// `(ref null $cloStruct)` cell, the closure analogue of the nullable struct (kind 9). The
// non-null part must be a FUNCTION type, and the WHOLE name must NOT itself be a top-level
// function type â€” `((i32) => i32) | null` (parens preserved by `canonEmitName`, arrow
// nested at depth 1) is a nullable function, whereas `(i32) => i32 | null` (top-level
// arrow) is a function RETURNING a nullable (handled by `annRetKind`, not here).
export function nameIsNulClosure(name: string) {
  if annArrowAt(name) >= 0 { return false }
  const b = nullablePartOf(name)
  if b == "" { return false }
  // The non-null part must itself BE a closure â€” a TOP-LEVEL arrow once its disambiguating
  // grouping parens are peeled (`((i32) => i32)` â†’ `(i32) => i32`). It is NOT enough to merely
  // CONTAIN a `=>`: `((i32) => boolean)[] | null` is a nullable ARRAY of closures and
  // `{f: () => i32} | null` a nullable STRUCT â€” the closure is nested in a composite, so the
  // whole is a nullable ref-array / nullable struct, not the closure niche (kind 19). Mis-
  // classifying them as nulclosure typed the field/binding slot `(ref null $cloStruct)` and the
  // construct stored a ref-array wrapper into it â€” invalid wasm.
  annArrowAt(peelGroupParens(b)) >= 0
}
// `1` if the type-annotation node at `tyIx` is a nullable function `(fn) | null`, else `0`
// â€” the closure dual of `retNulRefFlag`.
export function nulCloFlag(tyIx: i32) {
  if nodeTyIxOf(tyIx) >= 0 {
    if nodeTyIsNulClosure(tyIx) { return 1 }
    return 0
  }
  if nameIsNulClosure(tyNameOf(tyIx)) { return 1 }
  0
}
// `1` if the type-annotation node at `tyIx` is `i32[] | null`, else `0` â€” the
// nullable-LIST dual of `retNulRefFlag`. Feeds vt kind 15 (a NULLABLE `(ref null
// $lTypeIdx)` slot: narrowing is type-level only, the slot stays nullable and
// each list-op read site recovers non-null â€” mirroring the host's lowering, see
// tests/cases/types/nullable-list-index.vl's header).
// The scalar type NAME used to classify annotation node `tyIx`, read STRUCTURALLY from the
// checker's `Ty` arena (`nodeTyPrimName`) when it recorded a type for the node, else falling
// back to the parser's synthetic annotation name (`tyNameOf`) for a node the checker did not
// record. Byte-identical to the pure-name form (a scalar's arena prim-name equals its
// annotation name), but reads the CHECKED type where available â€” a first step of C1 (thread
// the structured `Ty` to the emitter). The name fallback shrinks as more annotation-resolution
// sites populate `nodeTyIx`.
function nodeScalarName(tyIx: i32) {
  // `nodeTyWidenedRepName` (not the raw `nodeTyPrimName`) so a SINGLE literal / homogeneous
  // numeric literal union widens to its base scalar name here too â€” `retI64Flag`/`retF64Flag`/
  // `retF32Flag` then fire for a `: 1.5` / `: 7`-annotated param/return, matching the widened
  // value. It is a SUPERSET of `nodeTyPrimName` for prims (identical), adding the lit widening;
  // the extra "string" it yields for a string literal/atom matches none of the numeric/bool flags.
  if nodeTyIxOf(tyIx) >= 0 { return nodeTyWidenedRepName(tyIx) }
  ""
}
// The array ELEMENT-REP name for classifying annotation node `tyIx` â€” STRUCTURAL from the `Ty`
// arena (`nodeTyArrayElemRepName`) where the checker recorded a type, else derived from the
// synthetic name for a node it did not record. Byte-identical to the per-classifier `nameIsX[]`
// tests; the `ret*ArrFlag` family reads it (C1). The name fallback shrinks as coverage widens.
function arrElemRep(tyIx: i32) {
  if nodeTyIxOf(tyIx) >= 0 { return nodeTyArrayElemRepName(tyIx) }
  ""
}
export function retNulListFlag(tyIx: i32) {
  if nodeTyIxOf(tyIx) >= 0 {
    if nodeTyIsNulI32List(tyIx) { return 1 }
    return 0
  }
  if nameIsNulI32List(tyNameOf(tyIx)) { return 1 }
  0
}
// `1` if the type-annotation node at `tyIx` is the i32 array type (`i32[]`), else `0`.
// The functype/local valtype layer multiplexes the struct/array/i32 cases through one
// `kind` code, so this flat flag feeds the `kind == 2` (array) branch of `pushVT`. A REF
// array (`S[]`/`N[]`) is NOT this â€” it feeds `kind == 5` via `retRefArrFlag`.
export function retArrFlag(tyIx: i32) {
  if arrElemRep(tyIx) == "i32" { return 1 }
  0
}
// `1` if the type-annotation node at `tyIx` is `string`, else `0`. A string is
// CURRENTLY the SAME `(array (mut i32))` of code points an array uses, so it feeds the
// `kind == 3` branch of `pushVT` (which encodes the identical array ref valtype).
export function retStrFlag(tyIx: i32) {
  // An ALIASED literal-union return (`type K = "a" | "b"`; `pick(): K`) reps as an i32
  // ATOM â€” `vtKindOfType` derives its functype result i32 (`nodeTyIsLitUnionAlias`), so
  // its `"str"` return kind must agree. `nodeTyWidenedRepName` renders every litunion
  // "string" (the print-widening name), which flagged the atom return a string; every call-result
  // consumer (`fnRetString` â†’ `exprString`, the inferred-return chain) then treated the
  // returned i32 atom as a string ref â€” `print(pick(ks))` / `useK(pick(ks))` routed it to
  // the string-ref path (invalid wasm). The atom widens to its member string at the print
  // seam (`exprIsLitAtom`), not by claiming a string RETURN. An INLINE litunion
  // (`"a" | "b"` written at the annotation) reps as the string ref (its functype result
  // is the `retStrFlag` fallthrough below), so it must stay flagged â€” the guard is
  // alias-only, matching `vtKindOfType`.
  if nodeTyIsLitUnionAlias(tyIx) { return 0 }
  if nodeTyWidenedRepName(tyIx) == "string" { return 1 }
  0
}
// `1` if the type-annotation node at `tyIx` is `boolean`/`bool`, else `0`. A bool
// rides in an i32 at the wasm level â€” this feeds ONLY the `print` import choice
// (`fRetBool`), never a valtype.
export function retBoolFlag(tyIx: i32) {
  if nodeScalarName(tyIx) == "boolean" { return 1 }
  0
}
// `1` if the type-annotation node at `tyIx` is a `string | null` â€” the NULLABLE string
// ref `(ref null $aTypeIdx)`, kind 16. A `string` is the raw i32 array `(ref $aTypeIdx)`;
// the nullable form is the same backing made nullable (`null` is `ref.null`, `!= null`
// is `ref.is_null`). Checked in `vtKindOfType` BEFORE the bare `string` (kind 3).
export function retNulStringFlag(tyIx: i32) {
  if nodeTyIxOf(tyIx) >= 0 {
    if nodeTyIsNulString(tyIx) { return 1 }
    return 0
  }
  if nullablePartOf(tyNameOf(tyIx)) == "string" { return 1 }
  0
}
// Combine the struct/array/string flags for a type-annotation node at `tyIx` into the
// single `pushVT` `kind` code: `1` struct, `2` array, `3` string, `0` i32. (Struct
// wins if a name were somehow both â€” it cannot be, the lexemes are disjoint.) String
// is a distinct code from array purely for typedness clarity; `pushVT` emits the SAME
// array ref valtype for both, since a string IS the i32-array type here.
// `1` if the type-annotation node at `tyIx` is an ARRAY OF FUNCTIONS (`((i32) => i32)[]`),
// else `0` â€” the closure-element ref-list guard `vtKindOfType` checks before the kind-14
// function-type test.
export function nameIsClosureArrayTy(tyIx: i32) {
  if nodeTyIxOf(tyIx) >= 0 {
    if nodeTyIsClosureArray(tyIx) { return 1 }
    // A NULLABLE-closure-element array (`(((i32) => boolean) | null)[]`, kind-5 niche):
    // the structural fast path has no nullable-element arm, so classify from the name.
    if nullClosureArrElem(tyNameOf(tyIx)) != "" { return 1 }
    return 0
  }
  if nameIsClosureArray(tyNameOf(tyIx)) { return 1 }
  if nullClosureArrElem(tyNameOf(tyIx)) != "" { return 1 }
  0
}
// `1` if the type-annotation node at `tyIx` is an `f64[]` (the f64-element list), else
// `0`. Feeds the `kind == 12` (f64-list wrapper) branch of `fbValtype`/`pushVT`. Checked
// BEFORE the `retRefArrFlag`/`retArrFlag` cases since `f64[]` is an `[]` array name but
// is neither a struct/union ref list nor the i32 list. (Slice 4.)
export function retF64ArrFlag(tyIx: i32) {
  if arrElemRep(tyIx) == "f64" { return 1 }
  0
}
export function retF32ArrFlag(tyIx: i32) {
  if arrElemRep(tyIx) == "f32" { return 1 }
  0
}
// `1` if the type-annotation node at `tyIx` is `i64[]` â€” the i64-list rep (kind 20).
export function retI64ArrFlag(tyIx: i32) {
  if arrElemRep(tyIx) == "i64" { return 1 }
  0
}
// `1` if the type-annotation node at `tyIx` is `i64`, else `0`. A scalar i64
// param/result/local/global classifies as kind 10 (valtype `0x7e`); checked LAST
// (after every ref/array case) since `i64` is a plain TypeRef name like `i32`.
export function retI64Flag(tyIx: i32) {
  if nodeScalarName(tyIx) == "i64" { return 1 }
  0
}
// `1` if the type-annotation node at `tyIx` is `f64`, else `0`. A scalar f64
// param/result/local/global classifies as kind 11 (valtype `0x7c`); checked LAST
// (alongside `retI64Flag`) since `f64` is a plain TypeRef name like `i32`. (Slice 3.)
export function retF64Flag(tyIx: i32) {
  if nodeScalarName(tyIx) == "f64" { return 1 }
  0
}
// `1` if the type-annotation node at `tyIx` is `f32`, else `0`. A scalar f32
// param/result/local/global classifies as kind 13 (valtype `0x7d`); checked LAST
// (alongside `retI64Flag`/`retF64Flag`) since `f32` is a plain TypeRef name like `i32`.
// (Slice 5.)
export function retF32Flag(tyIx: i32) {
  if nodeScalarName(tyIx) == "f32" { return 1 }
  0
}
// `1` if the type-annotation node at `tyIx` is a `string[]` (string-ref list), else `0`.
// Feeds the `kind == 7` (string-list wrapper) branch of `pushVT`. Checked BEFORE the
// `retRefArrFlag`/`retArrFlag` cases since `string[]` is an `[]` array name but is NOT a
// struct/union ref list nor the i32 list â€” it is the dedicated string-ref list.
export function retStrArrFlag(tyIx: i32) {
  if arrElemRep(tyIx) == "string" { return 1 }
  0
}
// The `array.new_fixed` operand cap engines enforce (V8/binaryen/wasmtime reject
// more than 10,000 operands). A literal longer than this cannot lower as one
// `array.new_fixed`: in a FUNCTION body it builds chunked (`array.new_default` +
// per-chunk `array.new_fixed`/`array.copy` â€” see `emitStr`/`emitArr`), and a
// GLOBAL initializer holding one is routed through the start function
// (`isConstInit` below returns false â€” a wasm constant expression has no locals
// to chunk through).
export const NEW_FIXED_MAX = 10000
// Whether the initializer expression at `exprIx` is a valid WasmGC *constant
// expression* â€” the forms `emitProgram` already lowers inline in the global section
// (`i32.const`, `struct.new`, `array.new_fixed`, the string array). Const forms:
// `NumLit` / `CharLit` / `BoolLit` (an `i32.const`), `StrLit` (a constant `array.new_fixed`
// over the code points), an `ArrayLit` whose elements are ALL const, an `ObjLit` whose
// field values are ALL const, and a `Paren` wrapping a const. EVERYTHING ELSE is
// non-const: an `Ident` (a `global.get` of another global), a `Member` / `Index` (a
// `struct.get` / `array.get` â€” the `curBuf = W.bytes` shape), a `Call`, a `BinExpr` /
// `Unary` (computed), an `IsExpr`. A literal past the `array.new_fixed` operand cap
// is non-const too â€” it must build CHUNKED through locals, which only a function
// body has (the raw `strText` length bounds the decoded length from above, so the
// `+ 2` quote allowance never under-routes a too-long string). CONSERVATIVE by
// construction: an unrecognized node falls through to the non-const `false`, so a
// form we have not proven const-safe is initialized via the start function rather
// than emitted as an invalid constexpr.
export function isConstInit(exprIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is NumLit { return true }
  if e is CharLit { return true }
  if e is BoolLit { return true }
  if e is StrLit { return e.strText.length <= NEW_FIXED_MAX + 2 }
  if e is Paren { return isConstInit(e.parInner) }
  if e is ArrayLit {
    if e.arrElems.length > NEW_FIXED_MAX { return false }
    let i = 0
    while i < e.arrElems.length {
      if !isConstInit(e.arrElems[i]) { return false }
      i = i + 1
    }
    return true
  }
  if e is ObjLit {
    let i = 0
    while i < e.objFields.length {
      const f = P.nodes[e.objFields[i]]
      if f is FieldInit {
        if !isConstInit(f.fiValue) { return false }
      } else {
        return false
      }
      i = i + 1
    }
    return true
  }
  false
}
// True if the type-name `name` is an ARRAY type â€” its lexeme ends in `[]` (the
// suffix `parseType` appends for every `T[]` annotation). Only `i32[]` is emittable
// in this slice; a non-i32 element array is rejected by `checkArrName`.
export function nameIsArray(name: string) {
  const n = name.length
  if n < 2 { return false }
  if name[n - 2] != '[' { return false }
  if name[n - 1] != ']' { return false }
  true
}
// True if the array type-name `name` is `i32[]` (the value-element list whose backing
// is the raw `(array (mut i32))`). A `boolean[]` shares this exact rep (a boolean is an
// i32 0/1 at the wasm level), so it rides the same i32-list machinery â€” only the element
// PRINT formatting recovers boolean-ness (`listElemIsBool`). A `T[]`/`N[]` (struct/union
// element) is NOT this.
export function nameIsI32Array(name: string) {
  if name == "i32[]" || name == "boolean[]" { return true }
  // `(boolean | null)[]` shares the exact i32-list backing: each element is an i32 0/1
  // with the spare value 2 = `null` (the sentinel niche). Only the `null â†’ 2` element
  // coercion + the sentinel-aware read/print differ (see `nameIsNulBoolList`).
  if nameIsNulBoolList(name) { return true }
  // A literal-union array (`K[]`, or an inline `("a"|"b")[]`) â€” its elements are interned-i32
  // ATOMS, so it shares the i32 backing/rep EXACTLY like `i32[]`. (Element construction seeds
  // `pendingLitUnion` so the member literals lower as their ids; reads yield the atom.)
  if nameIsLitUnionArray(name) { return true }
  // A `(K | null)[]` shares the exact i32-list backing: each element is an i32 member id (â‰Ą 0)
  // with the spare value `-1` = `null` (the atom-niche analogue of `(boolean | null)[]`). Only the
  // `null â†’ -1` element coercion + the sentinel-aware read differ (see `nameIsNulLitUnionList`).
  if nameIsNulLitUnionList(name) { return true }
  false
}
// True if `name` is `<litunion>[]` â€” an array whose element type is a literal union. The element
// name is `name` minus the trailing `[]` (a parenthesized inline union keeps its parens, which
// `nameIsLitUnionType` -> `nameIsInlineLitUnion` tolerates via the union split).
export function nameIsLitUnionArray(name: string) {
  if !nameIsArray(name) { return false }
  let elem = name.slice(0, name.length - 2)
  if elem.length > 1 {
    if elem[0] == '(' {
      if elem[elem.length - 1] == ')' { elem = elem.slice(1, elem.length - 1) }
    }
  }
  const r = nameIsLitUnionType(elem)
  r
}
// True if `name` is a 2-D array whose ELEMENT is an i32-backed scalar list â€” `i32[][]`,
// `boolean[][]`, or a literal-union `K[][]`. All three share the `i32[][]` rep EXACTLY: the
// element is the i32-list wrapper (`lTypeIdx`, ref-list element kind 4), because `i32[]`,
// `boolean[]` and a litunion `K[]` share ONE i32[] backing (`nameIsI32Array`). One predicate for
// the three ref-array classifiers (`nameIsRefArray` / `refArrElemKind` / `refArrElemName`), which
// each special-cased only the literal `"i32[][]"` name â€” so the boolean/atom leaf (`boolean[][]`,
// `K[][]`, the R4 fuzz family) now falls out of the SAME i32-list-element arm without a fourth
// drifting enumeration. A deeper `i32[][][]` is NOT this (its element `i32[][]` is itself a ref
// array, kind 9 via the recursion) â€” only a single i32-backed leaf list qualifies.
export function nameIsI32ListArray(name: string) {
  if !nameIsArray(name) { return false }
  return nameIsI32Array(name.slice(0, name.length - 2))
}
// True if the type-name `name` is a string-keyed MAP `{[string]: i32}` (G8) â€” the
// synthetic name `parseType` builds for an index-signature type, which starts with
// `"{["`. Only `{[string]: i32}` is emittable in this slice (the self-host checker's
// scope-chain element); any other index signature still parses to this shape but the
// map lowering assumes string keys + i32 values. A trailing `[]` (a list-of-maps
// `{[string]:i32}[]`) is NOT a bare map â€” that is handled by the ref-array path.
export function nameIsMap(name: string) {
  if name.length < 2 { return false }
  // A trailing `[]` makes it a LIST of maps, not a bare map.
  if name[name.length - 1] == ']' {
    if name[name.length - 2] == '[' { return false }
  }
  if name[0] != '{' { return false }
  if name[1] != '[' { return false }
  true
}
// True if `name` is a UNION whose FIRST atom is a map (`{[string]: V} | â€¦`) â€” a name that both
// STARTS with `{[` (so `nameIsMap` matches it) AND has 2+ top-level atoms. Such a name is a
// variant BOX, not a bare map: it must NOT be classified as a map local / return / value / field /
// list element. A bare map has ONE top-level atom (the inner `|` of a union-VALUED map like
// `{[string]: C | D}` sits inside the braces, so `splitUnionAtoms` keeps it a single atom).
export function nameIsMapMemberUnion(name: string) {
  if !nameIsMap(name) { return false }
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  atoms.length >= 2
}
// True if the MAP atom `mapAtom` (`{[string]: V}`) is boxable as a UNION arm. A map arm ALWAYS
// boxes as its VALUE-KIND map STRUCT ref riding the box anyref, tagged via `mapSlotTag` â€” for
// EVERY value kind: SCALAR / STRING / mono (`i32`/`boolean`/atom â†’ `$mStructIdx`; `string`/`i64`/
// `f64`/`f32` â†’ a per-value map struct over a scalar vals list) AND ref-VALUE (`{[string]: S}`
// struct, `{[string]: {[..]}}` nested, `{[string]: A|B}` union, `{[string]: () => T}` closure,
// `{[string]: S[]}` ref-list â€” a per-value map struct over a REF vals list). The value-kind map
// struct dedups across the union-box seam because BOTH the box side (`markMapUnionArms` â†’
// `mvShapeOfValName`, the authoritative `collectA` intern) and the narrowed read (`mvSlotOfâ€¦` â†’
// `mapTypeIdxOf`) key the SAME mv slot off the SAME arm atom via `mapValNameOf` â€” one slot, one
// `$mapStruct` heap type (the #860 map-struct-dedup invariant, extended to the union-box path). An
// unrepresentable value type (`mvValKindOfName == -3`) cannot cross the box: `mapShapeOfExpr`
// returns -3, so `emitUnionCoerce`'s `mSlot >= -1` gate fails and the arm stays a LOUD reject â€”
// never invalid wasm. (Lifts #865's scalar/string-only restriction; the ref-value hazard was the
// intermediate binding / field / return classifiers mis-typing a map-member union as a bare map,
// now guarded by `nameIsMapMemberUnion` at every `paramMap` / `retMapFlag` / `nameFieldCode` site.)
export function mapArmValueBoxable(_mapAtom: string) { true }
// True if the array type-name `name` is a string-keyed-MAP list `{[string]:i32}[]` â€”
// a ref list whose ELEMENT is the map struct (`mStructIdx`). It is a `nameIsMap` name
// with a trailing `[]`. The scope chain (`typecheck.vl`'s `scopes: {[string]:i32}[]`)
// is exactly this. Routed through the ref-list machinery as element-kind `3`.
export function nameIsMapArray(name: string) {
  const n = name.length
  if n < 2 { return false }
  if name[n - 2] != '[' { return false }
  if name[n - 1] != ']' { return false }
  // The bare element (without the trailing `[]`) must be a BARE map name â€” NOT a map-member union
  // (`({[string]: i32} | boolean)[]` whose paren-stripped element `{[string]: i32}|boolean` starts
  // with `{[` too): that is a union-BOX ref list (kind 2), not a list-of-maps (kind 3).
  const bare = name.slice(0, n - 2)
  nameIsMap(bare) && !nameIsMapMemberUnion(bare)
}
// True if `name` is an ARRAY OF FUNCTIONS â€” `((i32) => i32)[]`: a trailing `[]` whose
// element is a fully-parenthesized FUNCTION type, the arrow NESTED (depth > 0). A
// TOP-LEVEL arrow (`(i32) => i32[]`) is a function RETURNING a list, NOT an array of
// functions â€” excluded via `annArrowAt` (the same disambiguation as the list-return
// name guard). The element heap type is the shared closure fat-pointer struct
// (`cloStructIdx`); the ref-list element kind is 5.
export function nameIsClosureArray(name: string) {
  const n = name.length
  if n < 4 { return false }
  if name[n - 2] != '[' { return false }
  if name[n - 1] != ']' { return false }
  if annArrowAt(name) >= 0 { return false }
  const elem = name.slice(0, n - 2)
  if elem.length < 1 { return false }
  if elem[0] != '(' { return false }
  // The element must be a genuine FUNCTION type â€” a TOP-LEVEL arrow (paren-aware, after
  // peeling grouping parens). A `strContains(elem, "=>")` test also matched a UNION whose
  // FIRST member is a closure (`(() => i64) | i64`, whose `|` sits at the top level with the
  // arrow NESTED inside the first member) and mis-typed it as a closure ref list â€” a raw
  // closure element slot the boxed value could not store (invalid wasm). `nameIsFuncTypeAtom`
  // distinguishes `(i32) => C | S` (closure returning a union, kind 5) from `(() => i64) | i64`
  // (value-union box element, kind 2) by where the arrow sits.
  nameIsFuncTypeAtom(elem)
}
// The non-null FUNCTION-TYPE atom of a NULLABLE-closure array element
// (`(((i32) => boolean) | null)[]` â†’ `((i32) => boolean)`), or "". A
// `<closure> | null` element is a nullable NICHE over the shared closure
// fat-pointer (`(ref null $cloStruct)` â€” the backing a plain closure element
// already uses), NOT a union box â€” so such an array is a CLOSURE ref list
// (kind 5) whose slot keys the full `"<closure> | null"` name: the index read
// stays nullable (`rlElemNullable`) for the `e != null` narrow, exactly as the
// nullable-struct element (`nullStructArrElem`) does over its struct heap.
export function nullClosureArrElem(name: string) {
  const elem = parenUnionArrElemName(name)
  if elem == "" { return "" }
  const nn = nullablePartOf(elem)
  if nn == "" { return "" }
  if nameIsFuncTypeAtom(nn) { return nn }
  ""
}
// The VALUE-union element name of a parenthesized union-array annotation:
// `(string|i32)[]` â†’ `string|i32` (`canonEmitName` keeps a union element's
// grouping parens), or "" when `name` is not a value-union array name.
// Registration-independent (classifies from the atom set, not `unNames`).
export function parenUnionArrElemName(name: string) {
  if name.length < 5 { return "" }
  // A TOP-LEVEL arrow makes this a FUNCTION TYPE returning an array (`(i32) => (string | {w:
  // i32})[]`), NOT a value-union array. Without this guard the `name[0]=='('` / `name[len-3]==')'`
  // checks below match the closure name's OUTER parens (first `(` of the param list â€¦ last `)` of
  // the return union), capturing an unbalanced inner (`i32)=>(string|{w:i32}`) whose miscounted `|`
  // makes `unionMemberCount > 1` â€” mis-typing the whole closure LOCAL as a union-box ref list.
  // (`nameIsClosureArray` carries the same guard for the closure-element-array case.)
  if annArrowAt(name) >= 0 { return "" }
  if name[name.length - 2] != '[' { return "" }
  if name[name.length - 1] != ']' { return "" }
  if name[0] != '(' { return "" }
  if name[name.length - 3] != ')' { return "" }
  // The whole name must be ONE atom â€” a multi-arm union that merely STARTS with a paren
  // group and ENDS with `[]` (`(boolean|string)[] | (i32|f64)[]`) would otherwise slice an
  // UNBALANCED "inner" (`boolean|string)[]|(i32|f64`) and mis-classify the whole union as
  // a single union-array, derailing its registration.
  if unionMemberCount(name) > 1 { return "" }
  const inner = name.slice(1, name.length - 3)
  // A `(boolean | null)[]` element is the i32 SENTINEL niche, not a box: it reps as a
  // plain i32 list (`nameIsI32Array`), so it must NOT read as a union-box ref-array
  // element here. Return "" so `nameIsRefArray` / `refArrElemKind` skip it and it lands
  // on the i32-list path. (Scalar `boolean | null` is likewise a niche, not a value
  // union â€” `isValueUnionName` already excludes it.)
  if nameIsNulBool(inner) { return "" }
  // A `(string | null)[]` element is the string ref niche (a `(ref null $aTypeIdx)` string), not a
  // box: it reps as a plain string list (`nameIsNulStrList`), so it must NOT read as a union-box
  // ref-array element here. Return "" so `nameIsRefArray` / `refArrElemKind` skip it and it lands on
  // the string-list path. (Scalar `string | null` is likewise a niche, not a value union.)
  if nameIsNulString(inner) { return "" }
  // A `(K | null)[]` element is the litunion atom NICHE (an i32 member id with `-1` = `null`), not a
  // box: it reps as a plain i32 list (`nameIsNulLitUnionList` â†’ `nameIsI32Array`), so it must NOT read
  // as a union-box ref-array element here. Return "" so `nameIsRefArray` / `refArrElemKind` skip it
  // and it lands on the i32-list path. (Scalar `K | null` is likewise a niche, not a value union.)
  if nameIsNulLitUnion(inner) { return "" }
  if isValueUnionName(inner) { return inner }
  // A STRUCT / heterogeneous union element (`(C | S)[]`, `(A | i32)[]`): the parens are
  // annotation grouping only and the element slots hold the SAME `{tag, payload}` boxes a
  // value-union element does (element kind 2, heap `uBoxIdx`). A top-level `|` in a type
  // position is always a union, so `unionMemberCount > 1` distinguishes it from a
  // parenthesized non-union element (`((i32) => i32)[]`, no `|`).
  if unionMemberCount(inner) > 1 { return inner }
  ""
}
// True if the type-name `name` is exactly `string`. A VL string is CURRENTLY an
// `array i32` of code points (`docs/strings-design.md`), so it shares the array heap
// type â€” hence string use also sets `aUsed` and string valtypes reuse the array ref.
// (`string[]` is NOT this â€” it ends in `[]`, so `nameIsArray` catches it first and
// `checkArrName` rejects it as a non-i32 element array.)
export function nameIsString(name: string) { name == "string" }
// True if the type-name `name` is exactly `string[]` â€” a growable list whose elements
// are string refs. It reuses the map keys list types (the `{backing,len,cap}` wrapper
// over a `(ref null $aTypeIdx)` string backing); field code `6`.
export function nameIsStringArray(name: string) {
  if name == "string[]" { return true }
  // `(string | null)[]` shares the EXACT string-list backing (`$mkListIdx` wrapper, `(ref null
  // $aTypeIdx)` string backing â€” a `string[]` element is already a nullable ref). So it rides the
  // string-list machinery (param slot / `.length` / construct / arg-coerce) uniformly; only the
  // element READ diverges (kept `(ref null)`, intercepted by `exprNulStrArray` before the non-null
  // recovery) and a `null` element/push/assign lowers as `ref.null`.
  nameIsNulStrList(name)
}
// True if the type-name `name` is exactly `f64[]` â€” a growable list whose elements are
// scalar f64 (Slice 4). Its backing is `(array (mut f64))` (`fa64TypeIdx`); its wrapper
// is the `{backing,len,cap}` triple over that f64 backing (`fl64TypeIdx`). Distinct from
// `i32[]` so element reads/writes use the f64 element store.
export function nameIsF64Array(name: string) { name == "f64[]" }
export function nameIsF32Array(name: string) { name == "f32[]" }
// The i64 sibling of `nameIsF64Array`: an `i64[]` annotation (backing `ia64TypeIdx`,
// wrapper `il64TypeIdx` â€” the i64 element store).
export function nameIsI64Array(name: string) { name == "i64[]" }
// True if the node at `ix` is a struct `type` declaration (a single-level narrowing
// helper, so callers avoid an inline `is TypeDecl` on the wide `Node` union).
export function nodeIsTypeDecl(ix: i32) {
  const s = P.nodes[ix]
  if s is TypeDecl { return true }
  false
}
// True if `name` is the name of a FuncDecl ANYWHERE in the arena (top-level or a
// nested/lifted function). Used at `collectS` time â€” BEFORE `buildFnMap` populates
// `fnNames`, so `fnIndexOf` is not yet usable â€” to classify an anon-struct field
// whose value is a bare function name (`{ go: add }`). A direct arena scan, so it
// sees a function declared after the literal too.
export function nameNamesFunction(name: string) {
  if name == "" { return false }
  let i = 0
  while i < P.nodes.length {
    const n = P.nodes[i]
    if n is FuncDecl {
      if n.fnName == name { return true }
    }
    i = i + 1
  }
  false
}
// The inline-shape synthetic name of a STRUCT-ALIAS union decl â€” a `UnionDecl`
// with exactly ONE variant that is an inline object shape (`{a:i32,b:i32}`,
// not a map `{[â€¦]}`) â€” or "". The shape a canonicalized object intersection
// (`type AB = {a} & {b}` â†’ the merged single variant) leaves behind: it is a
// plain named STRUCT at runtime, so `collectS` interns it and `collectU`
// skips it.
export function unionStructAliasShape(variants: string[]) {
  if variants.length == 1 {
    const v = variants[0]
    if v.length >= 2 && v[0] == '{' && v[1] != '[' && v[v.length - 1] == '}' {
      return v
    }
  }
  ""
}
// The position of the first `<` in `name`, or -1 â€” a positive result with a
// trailing `>` marks a generic declaration/application name.
export function gaeLtAt(name: string) {
  let i = 0
  while i < name.length {
    if name[i] == '<' { return i }
    i = i + 1
  }
  -1
}
// Split a type-argument list at its TOP-LEVEL commas (`<>`/`{}`/`[]`/`()`
// nest); empty parts drop (a tolerated trailing comma).
export function gaeSplitArgs(s: string, out: string[]) {
  let depth = 0
  let start = 0
  let i = 0
  while i <= s.length {
    const atEnd = i == s.length
    let brk = atEnd
    if !atEnd {
      const c = s[i]
      if c == '<' || c == '{' || c == '[' || c == '(' { depth = depth + 1 }
      if c == '>' || c == '}' || c == ']' || c == ')' { depth = depth - 1 }
      if c == ',' && depth == 0 { brk = true }
    }
    if brk {
      const part = s.slice(start, i)
      if part.length > 0 { out.push(part) }
      start = i + 1
    }
    i = i + 1
  }
  0
}
// Substitute a declared param name (or its `T[]` array form) in a field's
// type name with the application's argument name.
export function gaeApplyFieldTy(tn: string, pnames: string[], args: string[]) {
  let i = 0
  while i < pnames.length {
    if tn == pnames[i] { return args[i] }
    if tn == pnames[i] + "[]" { return args[i] + "[]" }
    i = i + 1
  }
  tn
}
// Lexicographic `a < b` over two strings by code point (VL has no `<` on `string`).
// Compares char-by-char: at the first differing position the smaller code point wins;
// if one is a prefix of the other, the shorter is smaller. Equal strings are NOT `<`.
export function strLess(a: string, b: string) {
  let i = 0
  const na = a.length
  const nb = b.length
  while i < na && i < nb {
    const ca = a[i]
    const cb = b[i]
    if ca < cb { return true }
    if ca > cb { return false }
    i = i + 1
  }
  na < nb
}
// True if union `name` has at least one NON-null value-atom member (`i32`/`f64`/
// `boolean`/`string`/â€¦) â€” true for a pure value union AND a MIXED struct+scalar union,
// false for an all-struct union. Gates the scalar value-boxing in `emitUnionCoerce`.
export function unionHasValueAtom(name: string) {
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  let i = 0
  while i < atoms.length {
    const k = valueAtomKind(atoms[i])
    if k >= 0 && k != 6 { return true }
    // A litunion-ALIAS atom (`K0 | {w: i32}`) rides the box as its member-string atom
    // (the `K0 | i64` value-union rule) â€” it IS a value-boxable carrier, and the coerce
    // ladder below the gate already resolves the alias arm for a string carrier. Without
    // this an alias + all-struct union (no plain scalar sibling) took the all-struct raw
    // pass-through, returning the RAW member string into the box result â€” INVALID-WASM.
    if nameIsLitUnionType(atoms[i]) { return true }
    i = i + 1
  }
  false
}
// True if the value union `name` contains the member atom `atom`.
export function unionHasAtom(name: string, atom: string) {
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  let i = 0
  while i < atoms.length {
    if atoms[i] == atom { return true }
    i = i + 1
  }
  false
}
// Peel every fully-enclosing balanced grouping-paren layer from `name` (`(() => i64)` â†’
// `() => i64`), returning a non-parenthesized name unchanged. `splitUnionAtoms` KEEPS a closure
// member's grouping parens (`(() => i64) | i32` â†’ atom `(() => i64)`), but the bare `is`-test /
// annotation spelling drops them (`() => i64`) â€” so an atom-equality compare must peel first.
// (A ref-array / closure-array element ends in `]`, a struct in `}`, so only a BARE closure atom
// is affected; the paren-peel is the `nameIsFuncTypeAtom` prelude, shared to stay in lockstep.)
export function peelGroupParens(nameIn: string) {
  let name = nameIn
  while (
    name.length >= 2 &&
    name[0] == '(' &&
    name[name.length - 1] == ')' &&
    parenEnclosesWhole(name)
  ) {
    name = name.slice(1, name.length - 1)
  }
  name
}
// The pipe-joined complement of `set` (a union name / narrowed sub-set string)
// with the atom `removed` taken out â€” the ELSE-branch narrowing of `is removed`. The
// equality is grouping-paren-insensitive (`peelGroupParens`), so `is () => i64` strips the
// `(() => i64)` member `splitUnionAtoms` produced â€” otherwise the closure arm survives the
// complement and the else-branch reads the raw box where its remaining scalar arm is expected.
// PURE-FUNCTION MEMO: the narrowing passes call this millions of times per
// self-compile (~25% of compile time â€” every `if`-chain scan re-derives the
// same else-branch complements), over a SMALL set of distinct `(set, removed)`
// pairs. The result depends on nothing but the two strings, so the memo needs
// no invalidation â€” it persists across programs. The DOMINANT caller removes
// `"null"` (the else-branch of an `is null` test), so that case keys on `set`
// alone (`raftNullKeys` â€” no key-string concat on the hot path); every other
// `removed` rides the generic pair key, which length-prefixes `set`
// (`<len>:<set><removed>`) so no separator collision can conflate two pairs.
// Values live in a side pool (`raftVals`) because "" is a VALID result (the
// last atom removed) â€” the `{[string]: i32}` index maps keep a real miss
// (`?? -1`) distinguishable.
const raftNullKeys: {[string]: i32} = Map()
const raftKeys: {[string]: i32} = Map()
const raftVals: string[] = []

function removeAtomFromGo(set: string, removed: string) {
  const atoms: string[] = []
  splitUnionAtoms(set, atoms)
  const rmv = peelGroupParens(removed)
  // Atoms are VERBATIM contiguous slices of `set` separated by single `|`s
  // (see `splitUnionAtoms`), so joining KEPT atoms with `|` equals slicing the
  // kept RUNS out of `set` directly â€” one slice per run of consecutive
  // survivors (â‰¤2 in the common one-atom removal) instead of two concats per
  // atom, the same slice-over-per-atom-concat pattern as the splitter itself.
  let out = ""
  let runStart = -1 // char index where the current kept run begins, -1 = none
  let pos = 0 // char index of the current atom's start within `set`
  let i = 0
  while i < atoms.length {
    if peelGroupParens(atoms[i]) != rmv {
      if runStart < 0 { runStart = pos }
    } else if runStart >= 0 {
      // The run ends BEFORE this removed atom's separator (`pos - 1`).
      if out != "" { out = out + "|" }
      out = out + set.slice(runStart, pos - 1)
      runStart = -1
    }
    pos = pos + atoms[i].length + 1
    i = i + 1
  }
  if runStart >= 0 {
    if out != "" { out = out + "|" }
    out = out + set.slice(runStart, set.length)
  }
  out
}

export function removeAtomFrom(set: string, removed: string) {
  if removed == "null" {
    const hit = raftNullKeys[set] ?? -1
    if hit >= 0 { return raftVals[hit] }
    const out = removeAtomFromGo(set, removed)
    raftNullKeys[set] = raftVals.length
    raftVals.push(out)
    return out
  }
  const mk = i32ToStr(set.length) + ":" + set + removed
  const hit = raftKeys[mk] ?? -1
  if hit >= 0 { return raftVals[hit] }
  const out = removeAtomFromGo(set, removed)
  raftKeys[mk] = raftVals.length
  raftVals.push(out)
  out
}
// True if `name` is declared by a top-level struct `type X = {â€¦}` (`TypeDecl`). Used
// during `collectU` â€” BEFORE `collectS` runs â€” so it scans the arena directly rather
// than reading the not-yet-populated `sNames` table.
export function isDeclaredStructName(stmts: i32[], name: string) {
  let i = 0
  while i < stmts.length {
    const s = P.nodes[stmts[i]]
    if s is TypeDecl {
      if s.tdName == name { return true }
    }
    i = i + 1
  }
  false
}
// True if the atom `a` is a STRUCT variant â€” a declared `type X = {â€¦}`, or an INLINE
// object shape `{x:i32}` (its fields parse from its own text; a map shape `{[â€¦]}` is
// not). The per-member test shared by `isVariantBoxUnion` and the registration loop.
export function isStructAtom(stmts: i32[], a: string) {
  if isDeclaredStructName(stmts, a) { return true }
  if a.length >= 2 {
    if a[0] == '{' && a[1] != '[' && a[a.length - 1] == '}' { return true }
  }
  false
}
// True if `name` is a VARIANT-BOX union this emitter interns: two+ non-null members,
// every member a struct variant OR a value-atom (`i32`/`string`/â€¦) OR a REF-ELEMENT array
// (`S[]`, `(() => f64)[]`, `(C | D)[]`), with AT LEAST ONE struct OR ref-array. Covers the
// all-struct union (`A | B`, `A | B | null`), the MIXED struct + scalar union (`A | i32`,
// `A | B | i32 | f64 | boolean | string | null`), AND unions with a ref-array member
// (`S[] | {w:i32}`, `(() => f64)[] | i64`) â€” all ride the `uBoxIdx` `{tag, value}` box:
// structs as variant-struct payloads, scalars as value-box payloads, ref-arrays as the
// reflist WRAPPER ref on the anyref, tag-discriminated. A PURE value union (`i32 | string`)
// has no struct/ref-array, so it is handled earlier by `isValueUnionName`; a single struct +
// `null` (`A | null`) has one non-null member, so it stays the kind-9 niche nullable ref.
export function isVariantBoxUnion(stmts: i32[], name: string) {
  if unionMemberCount(name) < 2 { return false }
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  let structAtoms = 0
  let refArrAtoms = 0
  let mapAtoms = 0
  let nonNull = 0
  let j = 0
  while j < atoms.length {
    if atoms[j] != "null" {
      nonNull = nonNull + 1
      if isStructAtom(stmts, atoms[j]) {
        structAtoms = structAtoms + 1
      } else if valueAtomKind(atoms[j]) >= 0 || nameIsLitUnionType(atoms[j]) {
        // A value atom (scalar / string / scalar-element list [kinds 7-10] / closure) â€” it
        // boxes into a shared value box or rides the anyref, tagged via `scalarTagOf`. Checked
        // BEFORE the array test so a scalar-element list (`i32[]`, `string[]`) keeps its
        // value-atom rep instead of being mis-taken for a ref-element array.
        // A litunion-ALIAS atom (`K0` in `K0 | {w: i32} | f64`) rides the box as its
        // member-string atom too (the `K0 | i64` value-union rule); the annotated
        // named-fn spelling of such a union already lowers, so the box gate admits it.
      } else if nameIsMap(atoms[j]) {
        // A MAP arm (`{[string]: string}`, `{[string]: f64}`): not a struct (a map shape carries no
        // field set) nor a value atom, so it boxes as its MAP STRUCT ref riding the box anyref,
        // tagged via `mapTagOf` â€” the direct analogue of the ref-array arm below. Checked BEFORE
        // `nameIsArray` (a bare map ends in `}`, not `]`, so they are disjoint). Only a SCALAR /
        // string / mono value is boxable; a REF-VALUE map arm (`{[string]: S}` / nested / union /
        // closure) has a heap-type-identity hazard in the box composite, so the WHOLE union is not a
        // box union â€” it stays a LOUD reject (the registration guard fails loudly, never invalid wasm).
        if !mapArmValueBoxable(atoms[j]) { return false }
        mapAtoms = mapAtoms + 1
      } else if nameIsArray(atoms[j]) {
        // A REF-ELEMENT array arm (`S[]`, `(() => f64)[]`, `(C | D)[]`): not a scalar-element
        // list (those are value atoms, handled above), so it boxes as its reflist WRAPPER ref
        // riding the box anyref, tagged via `refArrTagOf`.
        refArrAtoms = refArrAtoms + 1
      } else {
        // Neither a struct variant, a value-atom, a map, nor a ref-element array â€” not boxable.
        return false
      }
    }
    j = j + 1
  }
  (structAtoms >= 1 || refArrAtoms >= 1 || mapAtoms >= 1) && nonNull >= 2
}
// The synthetic type-name string of the annotation node at `tyIx` (a `TypeRef`), or
// "" if `tyIx` is unset / not a type name. Lets the inline-union scan read a param /
// return annotation's name without a `P.nodes[...] is TypeRef` round-trip at the call
// site (this slice cannot narrow there).
export function tyNameOf(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef { return ty.tyName }
  }
  ""
}
// Push `atom` onto `atoms` only if absent (dedup, preserving first-seen order).
export function pushUniqueAtom(atoms: string[], atom: string) {
  let i = 0
  while i < atoms.length {
    if atoms[i] == atom { return 0 }
    i = i + 1
  }
  atoms.push(atom)
  0
}
// The number of NON-`null` members in the pipe-joined set `set`.
export function nonNullMemberCountOf(set: string) {
  const atoms: string[] = []
  splitUnionAtoms(set, atoms)
  let n = 0
  let i = 0
  while i < atoms.length {
    if atoms[i] != "null" { n = n + 1 }
    i = i + 1
  }
  n
}
// True if the `NumLit` lexeme `t` carries a `.` (a float literal). Mirrors the
// checker's literal-default rule (`.`â†’f64). (Slice 3.)
export function numTextIsFloat(t: string) {
  let i = 0
  while i < t.length {
    if t[i] == '.' { return true }
    i = i + 1
  }
  false
}
// True when the integer lexeme `t` is plain DECIMAL (digits/underscores, no `0x`/`0b`/`0o`
// radix prefix) â€” the form `ieeeBytes` can re-encode directly as an `f64.const`/`f32.const`.
export function numLexIsDecimal(t: string) {
  if t.length >= 2 && t[0] == '0' {
    const p = t[1]
    if p == 'x' || p == 'X' || p == 'b' || p == 'B' || p == 'o' || p == 'O' {
      return false
    }
  }
  true
}
// The `memProp` of a Member expression at `exprIx` (or "").
export function callMemProp(exprIx: i32) {
  const e = P.nodes[exprIx]
  if e is Member { return e.memProp }
  ""
}
// The `$fnsig` signature KEY a closure-pinned parameter carries â€” the part after
// the `"=>"` of a monomorphized instance's synthetic annotation (`"=>ii>i"` â†’
// `"ii>i"`), or "" when `name` is not such a param of function `fnIx`.
// Top-level (paren/brace/bracket depth 0) index of `=>` in a synthetic function-type
// name, or -1.
export function annArrowAt(name: string) {
  let depth = 0
  let i = 0
  while i < name.length {
    const c = name[i]
    if c == '(' || c == '{' || c == '[' {
      depth = depth + 1
    } else if c == ')' || c == '}' || c == ']' {
      depth = depth - 1
    } else if (
      depth == 0 &&
      c == '=' &&
      i + 1 < name.length &&
      name[i + 1] == '>'
    ) {
      return i
    }
    i = i + 1
  }
  -1
}
// True if `name` is a bare CANONICAL STRUCT shape (`{f:â€¦,â€¦}`, not a map) with at least one FIELD
// whose type is a top-level UNION â€” `{f:boolean|{w:i32}}`, `{f:i64|string}`. Such a struct has a
// BOXED field slot (a `(ref $uBox)`), which a body ObjLit built from bare-scalar/struct literals
// does NOT naturally produce (the literal self-infers the plain field shape). Used by
// `synthRetAnnots` to pin an anonymous lambda's `fnRet` to the checker-adopted union-field struct
// (recorded by `structFieldBoxRetName`) so its `$fnsig` result + body boxing match the annotated
// named-function form. Requires the CANONICAL (space-free, `=>`-arrow) emit spelling â€” the only
// interned `sNames` key â€” and skips a CLOSURE field (top-level `=>`, whose `|` binds to the
// closure RESULT, not the field: `(i32) => f32 | {w:i32}` is a closure returning a union, NOT a
// union field). A top-level arrow / a map (`{[`) is not a struct here.
export function nameIsStructWithUnionField(name: string) {
  if name.length < 2 { return false }
  if name[0] != '{' || name[name.length - 1] != '}' { return false }
  if name[1] == '[' { return false }
  if annArrowAt(name) >= 0 { return false }
  // CANONICAL only: a `tyToStr` obj render (spaces, `->` closure arrows â€” what the `recordable`
  // return path stores, e.g. `{f: () -> i32 | boolean}`) is NOT a `sNames` key, and its `->` hides
  // a closure field from `annArrowAt`; a space anywhere marks such a non-canonical name â€” reject it.
  let sp = 0
  while sp < name.length {
    if name[sp] == ' ' { return false }
    sp = sp + 1
  }
  const inner = name.slice(1, name.length - 1)
  let depth = 0
  let start = 0
  let k = 0
  while k <= inner.length {
    let brk = k == inner.length
    if k < inner.length {
      const c = inner[k]
      if c == '{' || c == '[' || c == '(' { depth = depth + 1 }
      else if c == '}' || c == ']' || c == ')' { depth = depth - 1 }
      else if c == ',' && depth == 0 { brk = true }
    }
    if brk {
      const field = inner.slice(start, k)
      const ci = field.indexOf(":")
      if ci > 0 {
        const ftype = field.slice(ci + 1, field.length)
        // A CLOSURE field (top-level `=>`) binds any `|` to its RESULT â€” skip it. Only a field
        // type that is itself a top-level UNION (`|` at depth 0) is a boxed field slot.
        if annArrowAt(ftype) < 0 {
          let fd = 0
          let j = 0
          while j < ftype.length {
            const cc = ftype[j]
            if cc == '{' || cc == '[' || cc == '(' { fd = fd + 1 }
            else if cc == '}' || cc == ']' || cc == ')' { fd = fd - 1 }
            else if cc == '|' && fd == 0 { return true }
            j = j + 1
          }
          // A NESTED bare-shape field (`{f:{f:i32|string}}`): the boxed slot may sit one
          // level down â€” RECURSE, so the `synthRetAnnots` pin fires for a lambda whose
          // NESTED literal field adopted a union-field shape (`objLitWidenFields`'
          // descent; without the pin its `$fnsig` kept the self-inferred plain layout â€”
          // INVALID-WASM, fuzz-nightly run 29808029476 seed 78530533 d5). A nested map
          // (`{[`) declines inside the recursion's own gate.
          if (
            ftype.length >= 2 &&
            ftype[0] == '{' &&
            ftype[ftype.length - 1] == '}'
          ) {
            if nameIsStructWithUnionField(ftype) { return true }
          }
        }
      }
      start = k + 1
    }
    k = k + 1
  }
  false
}
// True if `name` is a bare CANONICAL STRUCT shape with at least one field whose type is a
// LITUNION ALIAS (`{f:K0}`) â€” at any struct-nesting depth. Such a struct's field slot is the
// litunion's i32 ATOM, which a body ObjLit built from a bare string literal does NOT naturally
// produce (it self-infers `{f:string}` â€” a TWIN struct at a different rep). The litunion-atom
// sibling of `nameIsStructWithUnionField`: used by `synthRetAnnots` to pin an anonymous lambda's
// `fnRet` to the checker-adopted litunion-field struct (recorded by `structFieldBoxRetName`), so
// its `$fnsig` result + body literal build the atom struct the annotated named-function form
// (and every annotated consumer) codes. Without the pin a lambda nested where NO annotation
// threads (a union's closure arm inside another lambda's expression body) self-coded the string
// twin â€” a runtime cast-failure TRAP at the narrowed call (fuzz-nightly seed 26306770 d4,
// `() => ((i32) => {f: K0}) | i32`). Same CANONICAL-spelling gate as the sibling.
export function nameIsStructWithLitUnionField(name: string) {
  if name.length < 2 { return false }
  if name[0] != '{' || name[name.length - 1] != '}' { return false }
  if name[1] == '[' { return false }
  if annArrowAt(name) >= 0 { return false }
  let sp = 0
  while sp < name.length {
    if name[sp] == ' ' { return false }
    sp = sp + 1
  }
  const inner = name.slice(1, name.length - 1)
  let depth = 0
  let start = 0
  let k = 0
  while k <= inner.length {
    let brk = k == inner.length
    if k < inner.length {
      const c = inner[k]
      if c == '{' || c == '[' || c == '(' { depth = depth + 1 }
      else if c == '}' || c == ']' || c == ')' { depth = depth - 1 }
      else if c == ',' && depth == 0 { brk = true }
    }
    if brk {
      const field = inner.slice(start, k)
      const ci = field.indexOf(":")
      if ci > 0 {
        const ftype = field.slice(ci + 1, field.length)
        if nameIsLitUnionType(ftype) { return true }
        if (
          ftype.length >= 2 &&
          ftype[0] == '{' &&
          ftype[ftype.length - 1] == '}'
        ) {
          if nameIsStructWithLitUnionField(ftype) { return true }
        }
      }
      start = k + 1
    }
    k = k + 1
  }
  false
}
// True if `name` is a bare CANONICAL STRUCT shape carrying a MAP (`{[`) anywhere in its
// field tree (`{a:string,f:{f:{[string]:{f:i64}}},z:f32}`). A map-carrying struct a lambda
// body literal builds has no field-set anchor for its nested literals â€” un-pinned, the
// inner `{f: h0}` resolved by first-field-name-set match onto the map's own VALUE struct
// (a wrong-layout twin), so `synthRetAnnots` pins the lambda's `fnRet` to the checker's
// canonical record (`structMapFieldRetName`) and the body ObjLit threads the SAME
// per-field struct indices the annotated named-function spelling seeds. Same
// CANONICAL-spelling gate as its siblings; the leading `{[` test keeps a bare MAP name
// out (a map is not a field struct), and any deeper `{[` occurrence IS a map field at
// some nesting level (no other canon construct spells `{[`).
export function nameIsStructWithMapField(name: string) {
  if name.length < 2 { return false }
  if name[0] != '{' || name[name.length - 1] != '}' { return false }
  if name[1] == '[' { return false }
  if annArrowAt(name) >= 0 { return false }
  let sp = 0
  let hasMapOpen = false
  while sp < name.length {
    if name[sp] == ' ' { return false }
    if name[sp] == '{' && sp + 1 < name.length {
      if name[sp + 1] == '[' { hasMapOpen = true }
    }
    sp = sp + 1
  }
  hasMapOpen
}
// Split a function-type PARAM list (`i32,f64,S`) on top-level commas (depth-aware).
export function annSplitParams(s: string, out: string[]) {
  let cur = ""
  let depth = 0
  let i = 0
  while i < s.length {
    const c = s[i]
    if c == '(' || c == '{' || c == '[' {
      depth = depth + 1
      cur = cur + fromCodePoint(c)
    } else if c == ')' || c == '}' || c == ']' {
      depth = depth - 1
      cur = cur + fromCodePoint(c)
    } else if depth == 0 && c == ',' {
      out.push(cur)
      cur = ""
    } else {
      cur = cur + fromCodePoint(c)
    }
    i = i + 1
  }
  out.push(cur)
  0
}
// The closure-ABI return suffix for a type NAME (`i32`/`boolean` â†’ ">i", `f64` â†’ ">d", a
// struct â†’ ">s<idx>;"), or "" outside the value-returning ABI. (`void` is a later slice â€”
// its `>v` sig is not interned by the value-eligible pass.)
// Depth-aware split of a type NAME on its top-level `|` (the union/nullable separator) â€”
// the `annSplitParams` analogue for `|`.
export function annSplitPipe(s: string, out: string[]) {
  let cur = ""
  let depth = 0
  let i = 0
  while i < s.length {
    const c = s[i]
    if c == '(' || c == '{' || c == '[' {
      depth = depth + 1
      cur = cur + fromCodePoint(c)
    } else if c == ')' || c == '}' || c == ']' {
      depth = depth - 1
      cur = cur + fromCodePoint(c)
    } else if depth == 0 && c == '|' {
      out.push(cur)
      cur = ""
    } else {
      cur = cur + fromCodePoint(c)
    }
    i = i + 1
  }
  out.push(cur)
  0
}
// True if the type-annotation node at `tyIx` is a function type â€” the self-host parses a
// function-typed annotation as a `TypeRef` whose name contains `=>` or `(`/`)->`. For the
// corpus, function params are rare; a closure param is detected structurally elsewhere.
export function tyIsFuncType(tyIx: i32) {
  if tyIx < 0 { return false }
  // The arena covers every function-typed node (annotation, mono `=>sigkey` pin, struct field) â€”
  // read it ONLY; the depth-aware arrow name test is retired (C1 endgame).
  if nodeTyIxOf(tyIx) >= 0 { return nodeTyIsFunc(tyIx) }
  false
}
// True if `s` contains the substring `sub`.
export function strContains(s: string, sub: string) {
  if sub.length == 0 { return true }
  if sub.length > s.length { return false }
  let i = 0
  while i + sub.length <= s.length {
    let j = 0
    let ok = true
    while j < sub.length {
      if s[i + j] != sub[j] {
        ok = false
        j = sub.length
      } else {
        j = j + 1
      }
    }
    if ok { return true }
    i = i + 1
  }
  false
}
// Is the FuncDecl at arena index `fnIx` generic â€” explicit `<T>` params, or any
// un-annotated parameter (a per-callsite inference hole)?
export function monoIsGenericDecl(fnIx: i32) {
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    if fn.fnTyParams.length > 0 { return true }
    const ps = fn.fnParams
    let i = 0
    while i < ps.length {
      const p = P.nodes[ps[i]]
      if p is Param {
        if p.parType < 0 { return true }
      }
      i = i + 1
    }
  }
  false
}
// The type-parameter NAME a written annotation rides on â€” `ann == tp` (bare) or
// `ann == tp + "[]"` (array-of) for some `tp` in `typarams` â€” or "" when the
// annotation is concrete. Mirrors the checker's `resolveAnnot` shape.
export function monoTyParamOf(ann: string, typarams: string[]) {
  let i = 0
  while i < typarams.length {
    if typarams[i] == ann { return typarams[i] }
    i = i + 1
  }
  const n = ann.length
  if n >= 2 {
    if ann[n - 2] == '[' && ann[n - 1] == ']' {
      const base = ann.slice(0, n - 2)
      let j = 0
      while j < typarams.length {
        if typarams[j] == base { return typarams[j] }
        j = j + 1
      }
    }
  }
  ""
}
// The first-use-wins binding of type-param `tp` in the per-call binding lists,
// or "" if unbound.
export function monoBindOf(tvN: string[], tvV: string[], tp: string) {
  let i = 0
  while i < tvN.length {
    if tvN[i] == tp { return tvV[i] }
    i = i + 1
  }
  ""
}
// Does the annotation NAME reach a declared type param â€” bare (`T`), array-of
// (`T[]`), a generic-alias application argument (`Box<T>`), or an inline object
// shape's field type (`{first:B,second:A}`)?
export function monoAnnHasTyParam(ann: string, typarams: string[]) {
  if monoTyParamOf(ann, typarams) != "" { return true }
  const n = ann.length
  if n >= 3 && ann[n - 1] == '>' {
    const lt = gaeLtAt(ann)
    if lt > 0 {
      const parts: string[] = []
      gaeSplitArgs(ann.slice(lt + 1, n - 1), parts)
      let i = 0
      while i < parts.length {
        if monoAnnHasTyParam(parts[i], typarams) { return true }
        i = i + 1
      }
      return false
    }
  }
  if n >= 2 && ann[0] == '{' && ann[n - 1] == '}' {
    if n >= 3 && ann[1] == '[' { return false }
    const fields: string[] = []
    gaeSplitArgs(ann.slice(1, n - 1), fields)
    let j = 0
    while j < fields.length {
      const ci = fields[j].indexOf(":")
      if ci > 0 {
        if (
          monoAnnHasTyParam(fields[j].slice(ci + 1, fields[j].length), typarams)
        ) {
          return true
        }
      }
      j = j + 1
    }
  }
  // A FUNCTION-TYPE annotation `(p1, p2) => ret` (a closure param / return): a type
  // param may ride any parameter or the result, so recurse into each (parallel to
  // `monoSubstAnn`'s function-type branch). Without this, a generic closure param
  // `f: (A, T) => A` reads as concrete and keeps its un-substituted annotation.
  const fa = annArrowAt(ann)
  if fa >= 1 && ann[0] == '(' && ann[fa - 1] == ')' {
    const innerFn = ann.slice(1, fa - 1)
    if innerFn.length > 0 {
      const fparts: string[] = []
      annSplitParams(innerFn, fparts)
      let fi = 0
      while fi < fparts.length {
        if monoAnnHasTyParam(fparts[fi], typarams) { return true }
        fi = fi + 1
      }
    }
    if monoAnnHasTyParam(ann.slice(fa + 2, ann.length), typarams) {
      return true
    }
  }
  false
}
// Substitute the per-call type-param bindings through an annotation NAME â€”
// bare `T` / `T[]`, application arguments (`Box<T>` â†’ `Box<i32>`), and inline
// object-shape field types (`{first:B,second:A}` â†’ `{first:string,second:i32}`).
// Returns "" when an UNBOUND type param remains (the instance cannot be named);
// a fully concrete annotation returns unchanged.
export function monoSubstAnn(
  ann: string,
  typarams: string[],
  tvN: string[],
  tvV: string[],
) {
  const tp = monoTyParamOf(ann, typarams)
  if tp != "" {
    const b = monoBindOf(tvN, tvV, tp)
    if b == "" { return "" }
    if ann == tp { return b }
    return b + "[]"
  }
  const n = ann.length
  if n >= 3 && ann[n - 1] == '>' {
    const lt = gaeLtAt(ann)
    if lt > 0 {
      const parts: string[] = []
      gaeSplitArgs(ann.slice(lt + 1, n - 1), parts)
      let outAnn = ann.slice(0, lt) + "<"
      let i = 0
      while i < parts.length {
        const s = monoSubstAnn(parts[i], typarams, tvN, tvV)
        if s == "" { return "" }
        if i > 0 { outAnn = outAnn + "," }
        outAnn = outAnn + s
        i = i + 1
      }
      return outAnn + ">"
    }
  }
  if n >= 2 && ann[0] == '{' && ann[n - 1] == '}' {
    if n >= 3 && ann[1] == '[' { return ann }
    const fields: string[] = []
    gaeSplitArgs(ann.slice(1, n - 1), fields)
    let outObj = "{"
    let j = 0
    while j < fields.length {
      const ci = fields[j].indexOf(":")
      if ci <= 0 { return ann }
      const fs = monoSubstAnn(
        fields[j].slice(ci + 1, fields[j].length),
        typarams,
        tvN,
        tvV,
      )
      if fs == "" { return "" }
      if j > 0 { outObj = outObj + "," }
      outObj = outObj + fields[j].slice(0, ci) + ":" + fs
      j = j + 1
    }
    return outObj + "}"
  }
  // A FUNCTION-TYPE annotation `(p1, p2) => ret` (a closure param / return) riding type
  // params: substitute each parameter and the return through the binding, so a generic
  // closure param `f: (A, T) => A` pins to `(string, string) => string` for the instance.
  // Without it the instance body's `f(â€¦)` call resolves no interned `$fnsig` (the param
  // kept the un-substituted `(A, T) => A`) and the value call mis-lowers.
  const fa = annArrowAt(ann)
  if fa >= 1 && ann[0] == '(' && ann[fa - 1] == ')' {
    let outFn = "("
    const innerFn = ann.slice(1, fa - 1)
    if innerFn.length > 0 {
      const fparts: string[] = []
      annSplitParams(innerFn, fparts)
      let fi = 0
      while fi < fparts.length {
        const fs2 = monoSubstAnn(fparts[fi], typarams, tvN, tvV)
        if fs2 == "" { return "" }
        if fi > 0 { outFn = outFn + "," }
        outFn = outFn + fs2
        fi = fi + 1
      }
    }
    const rs2 = monoSubstAnn(ann.slice(fa + 2, ann.length), typarams, tvN, tvV)
    if rs2 == "" { return "" }
    return outFn + ")=>" + rs2
  }
  ann
}
// Bind type params by matching a parameter's annotation PATTERN against the
// argument's concrete type name: `T` against anything, `T[]` against `X[]`,
// `Box<T>` against `Box<i32>` (same head, pairwise arguments). First use wins.
export function monoBindFromAnn(
  pat: string,
  actual: string,
  typarams: string[],
  tvN: string[],
  tvV: string[],
) {
  const tp = monoTyParamOf(pat, typarams)
  if tp != "" {
    let bind = actual
    if pat != tp {
      const an = actual.length
      if an < 2 { return 0 }
      if an >= 2 && actual[an - 2] == '[' && actual[an - 1] == ']' {
        bind = actual.slice(0, an - 2)
      } else {
        return 0
      }
    }
    if monoBindOf(tvN, tvV, tp) == "" {
      tvN.push(tp)
      tvV.push(bind)
    }
    return 0
  }
  const n = pat.length
  if n >= 3 && pat[n - 1] == '>' {
    const lt = gaeLtAt(pat)
    const alt = gaeLtAt(actual)
    if (
      lt > 0 &&
      alt > 0 &&
      actual.length >= 3 &&
      actual[actual.length - 1] == '>'
    ) {
      if pat.slice(0, lt) == actual.slice(0, alt) {
        const pparts: string[] = []
        gaeSplitArgs(pat.slice(lt + 1, n - 1), pparts)
        const aparts: string[] = []
        gaeSplitArgs(actual.slice(alt + 1, actual.length - 1), aparts)
        let i = 0
        while i < pparts.length {
          if i < aparts.length {
            monoBindFromAnn(pparts[i], aparts[i], typarams, tvN, tvV)
          }
          i = i + 1
        }
      }
    }
  }
  // A FUNCTION-TYPE pattern `(P1, P2) => R` against the argument's function type
  // `(i32, i32) => i32`: bind type params pairwise across the parameters and the
  // return (parallel to `monoSubstAnn` / `monoAnnHasTyParam`). Binds `reduce`'s
  // `f: (A, T) => A` from the lambda argument's concrete `(i32, i32) => i32`.
  const pfa = annArrowAt(pat)
  const afa = annArrowAt(actual)
  if (
    pfa >= 1 &&
    afa >= 1 &&
    pat[0] == '(' &&
    pat[pfa - 1] == ')' &&
    actual[0] == '(' &&
    actual[afa - 1] == ')'
  ) {
    const pp: string[] = []
    const ap: string[] = []
    annSplitParams(pat.slice(1, pfa - 1), pp)
    annSplitParams(actual.slice(1, afa - 1), ap)
    let fi = 0
    while fi < pp.length {
      if fi < ap.length { monoBindFromAnn(pp[fi], ap[fi], typarams, tvN, tvV) }
      fi = fi + 1
    }
    monoBindFromAnn(
      pat.slice(pfa + 2, pat.length),
      actual.slice(afa + 2, actual.length),
      typarams,
      tvN,
      tvV,
    )
  }
  0
}
// Is `op` an operator that may dispatch to a `self`-method / operator field?
// Assignment, equality (structural compare), the logicals and `??` keep their
// native forms.
export function drwDispatchOp(op: string) {
  if op == "=" { return false }
  if op == "==" || op == "!=" { return false }
  if op == "&&" || op == "||" || op == "??" { return false }
  true
}
