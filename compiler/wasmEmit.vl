// VL-in-VL wasm emitter ΓÇö self-hosted codegen spike.
//
// A `.vl` program that produces RAW WebAssembly *bytes* for a minimal but valid
// module. It does NOT consume the AST arena (that is the full codegen port);
// instead it hand-builds the byte sequence for two fixed modules to exercise the
// LEB128/byte-array/section-framing machinery that a real codegen requires.
//
// The AST data layer (`compiler/ast.vl`): the global parser state `P` (whose
// `P.nodes` arena the emitter walks), the helpers, and every `Node` variant the
// emitter `is`-narrows. The emitter consumes ONLY ast.vl ΓÇö it re-derives all
// type info itself (`collectS`/`collectU`/ΓÇª + its own narrowing stack), so
// nothing is imported from `typecheck.vl`. The BUILD path still concatenates
// the compiler sources (these imports are blanked in the native assemblies and
// parse no-ops in the TS-host ones); the imports exist so the file checks as a
// MODULE ΓÇö `vl check` / `cli.ts check` / the LSP resolve every cross-file name.
import {
  P,
  i32ToStr,
  hasNamedArgs,
  orderArgsByParamNames,
  ufcsAliasOf,
  mkBinary,
  mkCall,
  mkCallN,
  mkFunc,
  mkIdent,
  mkMember,
  mkParam,
  mkStr,
  mkTypeRef,
} from "./ast"
import {
  NumLit,
  StrLit,
  CharLit,
  BoolLit,
  NullLit,
  Ident,
  Member,
  OptMember,
  Index,
  Call,
  BinExpr,
  Unary,
  Paren,
  ObjLit,
  ArrayLit,
  IsExpr,
  FieldInit,
  FieldDef,
  Param,
  FuncDecl,
  LetDecl,
  RetStmt,
  IfStmt,
  WhileStmt,
  ForRange,
  ForIn,
  BreakStmt,
  ContinueStmt,
  Block,
  TypeDecl,
  UnionDecl,
  TypeRef,
  Program,
} from "./ast"
//
// Output representation: a VL `i32[]` of byte values 0..255. WasmGC has no `u8`,
// so `i32[]` is used (see docs/selfhost-gaps.md). Bytes are masked to the low
// 8 bits on emit (`& 0xff`).

// ΓöÇΓöÇ BinaryWriter (Layer 1) ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ
// The one place bytes are appended. State lives in module-global `let`s (no
// closures, so the emitter stays self-compilable). `W.bytes` is the module
// output buffer; `curBuf` is the "current target" the streaming primitives
// (`wU8`/`wBytes`/`wULEB`/`wSLEB`/`wName`) append to. By default `curBuf` IS
// `W.bytes`; lowering that builds a section payload into a fresh `i32[]`
// redirects the writer with `wTarget(buf)` (save the returned previous buffer,
// restore it with a second `wTarget(prev)` when done). This threads "which
// buffer" without passing it to every helper and without a closure.
//
// Output representation: a VL `i32[]` of byte values 0..255 (WasmGC has no `u8`);
// bytes are masked to the low 8 bits on emit.
type Emitter = { bytes: i32[] }
const W: Emitter = { bytes: [] }
// The buffer the streaming writer currently appends to. Initialized to the
// module output buffer; rebound by `wTarget`, reset by `emitReset`.
let curBuf = W.bytes

// Number of imported FUNCTIONS (4 ΓÇö the `print` family ΓÇö when any `print` call
// exists in the program, else 0). Imports occupy wasm function indices
// 0..gImports-1, so every LOCAL function's WASM index is `gImports + position`
// (fnIndices stays the fnStmts POSITION for arena lookups; the offset applies at
// the index WRITE points: the call instruction, the export entries, the start
// index). When 0 ΓÇö every golden ΓÇö no import section is emitted and nothing
// shifts, so existing modules stay byte-identical.
let gImports = 0

// `true` when the program uses `print` AND declares an i64 binding ΓÇö pulling in a
// FIFTH import `__print_i64__` (function index 4) with a `(i64)->()` functype. Decided
// up front like `gImports` (an extra import shifts every local function's wasm index by
// one MORE). A program with no i64 annotation never sets this, so its emitted bytes are
// byte-identical to before (the existing 4-import / 0-import layouts are untouched).
let gNeedsI64Print = false

// `true` when the program uses `print` AND declares/uses an f64 value (a `.` literal,
// an `: f64` binding, or f64 arithmetic) ΓÇö pulling in the `__print_f64__` import with a
// `(f64)->()` functype, placed AFTER `__print_i64__` (so its function index is
// `4 + (gNeedsI64Print ? 1 : 0)`, recorded in `gF64PrintIdx`). A program with no f64
// never sets this, so its emitted bytes are byte-identical to before. (Slice 3.)
let gNeedsF64Print = false

// The wasm function index of the `__print_f64__` import (`fbCall` target in the print
// router). Computed up front in `emitProgram`: `4` when no i64 print, `5` when i64 print
// is also present (the i64 import takes index 4 first). Only meaningful when
// `gNeedsF64Print` is true. (Slice 3.)
let gF64PrintIdx = 0

// `true` when the program uses `print` AND declares an `f32` value ΓÇö pulling in the
// `__print_f32__` import with a `(f32)->()` functype, placed AFTER `__print_i64__` and
// `__print_f64__` (so neither of their indices shift). A program with no f32 never sets
// this, so its emitted bytes are byte-identical to before. (Slice 5.)
let gNeedsF32Print = false

// The wasm function index of the `__print_f32__` import ΓÇö `4`/`5`/`6` depending on which
// of the i64/f64 print imports also appear (f32 always trails them). Only meaningful when
// `gNeedsF32Print` is true. (Slice 5.)
let gF32PrintIdx = 0

// Scratch out-param for `bigDivmod`: set to `true` when the division left a NONZERO
// remainder (the IEEE-754 "sticky" bit). The decimalΓåÆdouble encoder reads it after the
// final divide to decide round-to-nearest-ties-to-even. (Slice 3.)
let gDivRemNonzero = false

// ΓöÇΓöÇ name-section opt-in (OFF by default ΓÇö goldens stay byte-identical) ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ
// When `1`, `emitModule` appends a wasm "name" custom section (function-name
// subsection + module-name subsection) so a wasmtime trap backtrace shows real
// function names instead of `<wasm function N>`. It is a CUSTOM section (id 0,
// name "name"): semantically inert, ignored by every conforming runtime, but it
// CHANGES the emitted bytes. The goldens, the emit/full fixpoints and the
// self-typecheck NEVER flip this on (the driver's `compileSrc` leaves it at 0),
// so the default emit path is byte-for-byte unchanged. Only the native `vl`
// host opts in (via the exported `setEmitNames` below) for `vl run` / `vl build
// --names`, where legible traps are the whole point.
let gEmitNames = 0

// Host opt-in for the name section (see `gEmitNames`). The driver does NOT call
// this, so every golden/fixpoint emit leaves names OFF; only the native tool
// turns it on. Idempotent ΓÇö any nonzero `on` enables, `0` disables.
export function setEmitNames(on: i32) {
  if on != 0 { gEmitNames = 1 } else { gEmitNames = 0 }
  0
}

// Top-level STATEMENTS (a bare `print(...)`, an assignment, a `while` over globals ΓÇö
// anything that is not a function/type/global declaration). They run inside the
// synthetic START function, in source order, after the non-const global inits ΓÇö
// the host's `__program__` model. Empty for every golden (pure-decl modules).
let startStmts: i32[] = []

function emitReset() {
  // NOTE: `gImports` and `startStmts` are NOT reset here ΓÇö they are assigned by
  // their own passes (the print-detection scan in `emitProgram`, `collectFns`)
  // which run BEFORE `emitModule` calls this; resetting them here would clobber
  // those passes' results.
  W.bytes = []
  curBuf = W.bytes
  0
}

// Redirect the writer at `buf`; return the PREVIOUS current buffer so the caller
// can restore it (closure-free save/restore ΓÇö replaces threading `body`/`payload`
// through every helper).
function wTarget(buf: i32[]) {
  const prev = curBuf
  curBuf = buf
  prev
}

// Append one byte (low 8 bits) to the current buffer.
function wU8(b: i32) {
  curBuf.push(b & 0xff)
  0
}

// Append every byte of `bs` in order to the current buffer.
function wBytes(bs: i32[]) {
  let i = 0
  while i < bs.length {
    wU8(bs[i])
    i = i + 1
  }
  0
}

// ΓöÇΓöÇ LEB128 encoders ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ
// Each encoder stores 7 data bits per output byte; the high bit (0x80) is the
// continuation flag, set on every byte except the last. `& 0x7f` extracts the
// low 7 bits, `>>> 7` does the unsigned right-shift for ULEB, `>> 7` does the
// arithmetic right-shift for SLEB (preserving sign), and `| 0x80` sets the
// continuation bit. The canonical `*ToArr` forms return a fresh `i32[]` so
// they compose into nested payload builders; `wULEB`/`wSLEB` append straight to
// the current buffer (`curBuf`) for section-length framing and operands.

// Unsigned LEB128: 7 bits per byte, low-to-high, high bit set while more remain.
function ulebToArr(value: i32) {
  let out: i32[] = []
  let v = value
  let more = true
  while more {
    const byte = v & 0x7f
    v = v >>> 7
    if v == 0 {
      out.push(byte)
      more = false
    } else {
      out.push(byte | 0x80)
    }
  }
  out
}

// SLEB-encode `value` into a fresh `i32[]`.
function slebToArr(value: i32) {
  let out: i32[] = []
  let v = value
  let more = true
  while more {
    const byte = v & 0x7f
    v = v >> 7
    let signBit = 0
    if (byte & 0x40) != 0 { signBit = 1 }
    if v == 0 {
      if signBit == 0 {
        out.push(byte)
        more = false
      } else {
        out.push(byte | 0x80)
      }
    } else {
      if v == -1 {
        if signBit == 1 {
          out.push(byte)
          more = false
        } else {
          out.push(byte | 0x80)
        }
      } else {
        out.push(byte | 0x80)
      }
    }
  }
  out
}

// Append all of `src` onto `dst` (in place) and return `dst`.
function appendAll(dst: i32[], src: i32[]) {
  let i = 0
  while i < src.length {
    dst.push(src[i])
    i = i + 1
  }
  dst
}

// Streaming unsigned-LEB: append straight to the current buffer (used for
// section-length framing and operand encoding). The `*ToArr` array forms are
// retained for the few sites that genuinely compose a fresh payload array.
function wULEB(value: i32) {
  wBytes(ulebToArr(value))
  0
}

// Streaming signed-LEB: append straight to the current buffer.
function wSLEB(value: i32) {
  wBytes(slebToArr(value))
  0
}

// Write a name: ULEB(byte length) followed by its UTF-8 bytes. For an ASCII
// identifier each `s[i]` char code IS its byte. Dedupes the hand-rolled
// length-prefix + char-loop in the export/field-name emission.
function wName(s: string) {
  wULEB(s.length)
  let i = 0
  while i < s.length {
    wU8(s[i])
    i = i + 1
  }
  0
}

// ΓöÇΓöÇ section framing ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ
// A section is: id byte, then ULEB(byte-length of payload), then payload. The
// payload is built eagerly into a temporary `i32[]`, then framed onto the
// current buffer. (No closures/builder objects ΓÇö payloads are constructed
// eagerly into arrays; no backpatching.)
function wSection(id: i32, payload: i32[]) {
  wU8(id)
  wULEB(payload.length)
  wBytes(payload)
  0
}

// ΓöÇΓöÇ FuncBuilder opcode methods (Layer 2 ΓÇö typed instruction emission) ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ
// One top-level, closure-free function per opcode (or opcode family) VL emits. Each
// writes EXACTLY the bytes the corresponding raw `body.push(<opcode>)` (+ any LEB
// operands) emitted before, straight through the BinaryWriter (`wU8`/`wULEB`/`wSLEB`)
// onto the CURRENT buffer (`curBuf`). The lowering sets `curBuf` to the buffer it is
// filling (the function body, or a global-init constexpr) via `wTarget`, so these
// methods need no `body` parameter ΓÇö they are the single place each magic opcode byte
// lives. Every method returns `0` (a side-effecting builder; statement sequencing
// replaces method chaining). The opcode set is small and closed (~40); this phase
// (Phase B) DEFINES the whole set's control/locals/consts family with real bodies and
// converts its call sites, leaving the struct / array / map / string families to land
// in Phases CΓÇôF.

// ΓöÇΓöÇ control flow / locals / consts (the universal base ΓÇö Phase B) ΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇΓöÇ
// local.get / local.set / local.tee: 0x20/0x21/0x22 <localidx-uleb>.
function fbLocalGet(i: i32) {
  wU8(32) // 0x20 local.get
  wULEB(i)
  0
}
function fbLocalSet(i: i32) {
  wU8(33) // 0x21 local.set
  wULEB(i)
  0
}
// global.get / global.set: 0x23/0x24 <globalidx-uleb>.
function fbGlobalGet(i: i32) {
  wU8(35) // 0x23 global.get
  wULEB(i)
  0
}
function fbGlobalSet(i: i32) {
  wU8(36) // 0x24 global.set
  wULEB(i)
  0
}
// i32.const: 0x41 <value-sleb>.
function fbI32Const(v: i32) {
  wU8(65) // 0x41 i32.const
  wSLEB(v)
  0
}
// Signed-LEB128 over a 64-bit value carried as a (hi, lo) i32 PAIR (`hi` the high
// 32 bits, `lo` the low 32 ΓÇö both read as UNSIGNED 32-bit lanes). The self-host
// compiler is i32-only internally, so a 64-bit literal cannot live in one i32: it
// is carried as the pair and shifted RIGHT 7 bits at a time across the lane
// boundary by hand. `wSLEB`'s i32 form cannot be reused (its `v >> 7` is a 32-bit
// arithmetic shift). Termination mirrors `slebToArr`: stop once the remaining
// value is all-0 (with the sign bit clear) or all-1 (sign bit set).
function wSLEB64(hi: i32, lo: i32) {
  let h = hi
  let l = lo
  let more = true
  while more {
    const byte = l & 0x7f
    // ARITHMETIC 64-bit right shift by 7: low lane gets its top 25 bits plus the
    // low 7 bits of `hi` rotated in; high lane is a SIGNED `>> 7` so a negative
    // value's sign bit propagates (the all-ones tail terminates correctly). For a
    // non-negative value (top bit 0) signed and unsigned shift agree, so the
    // Slice-1 non-negative literals are byte-identical.
    const newLo = (l >>> 7) | (h << 25)
    const newHi = h >> 7
    l = newLo
    h = newHi
    let signBit = 0
    if (byte & 0x40) != 0 { signBit = 1 }
    // Remaining value is "done" when both lanes are 0 (non-negative tail) or both
    // lanes are all-ones, i.e. -1 (negative tail) ΓÇö matching SLEB's sign rule.
    if l == 0 && h == 0 {
      if signBit == 0 {
        wU8(byte)
        more = false
      } else {
        wU8(byte | 0x80)
      }
    } else if l == (-1) && h == (-1) {
      if signBit == 1 {
        wU8(byte)
        more = false
      } else {
        wU8(byte | 0x80)
      }
    } else {
      wU8(byte | 0x80)
    }
  }
  0
}
// Does the non-negative integer LEXEME `t` (a `NumLit.numText`: decimal / hex /
// binary / octal, `_` separators skipped) fit the i32 range [0, 2147483647]?
// Mirrors the checker's `intLexemeFitsI32` (the host `defaultIntegerType`
// magnitude rule): a literal past the bound is TYPED i64, so it must lower as
// `i64.const` ΓÇö `i32.const` would silently wrap (0xDEAD_BEEF). The lexeme never
// carries a sign (unary minus is a separate node). Digits fold with a
// pre-multiply overflow guard (`v > (max - d) / base`), no 64-bit arithmetic.
function numLexFitsI32(t: string) {
  let v = 0
  let i = 0
  let base = 10
  if t.length >= 2 && t[0] == '0' {
    const p = t[1]
    if p == 'x' || p == 'X' {
      base = 16
      i = 2
    } else if p == 'b' || p == 'B' {
      base = 2
      i = 2
    } else if p == 'o' || p == 'O' {
      base = 8
      i = 2
    }
  }
  while i < t.length {
    let c = t[i]
    if c == '_' {
      i = i + 1
    } else {
      let d = 0
      if c >= '0' && c <= '9' { d = c - '0' }
      else if c >= 'a' && c <= 'f' { d = c - 'a' + 10 }
      else { d = c - 'A' + 10 }
      if v > (2147483647 - d) / base { return false }
      v = v * base + d
      i = i + 1
    }
  }
  true
}
// Is the integer LEXEME's magnitude EXACTLY 2^31 (2147483648)? Mirrors the
// checker's `intLexemeIs2Pow31`: the host folds a negated literal into a signed
// literal before defaulting, so `-2147483648` is i32 (it sits AT I32_MIN) even
// though the bare magnitude is one past I32_MAX. Used by the unary `-` arms.
// Compares the significant digits (base prefix, `_` separators and leading
// zeros stripped) against 2^31 written in the lexeme's base.
function numLexIs2Pow31(t: string) {
  let digits = "2147483648"
  let i = 0
  if t.length >= 2 && t[0] == '0' {
    const p = t[1]
    if p == 'x' || p == 'X' {
      digits = "80000000"
      i = 2
    } else if p == 'b' || p == 'B' {
      digits = "10000000000000000000000000000000"
      i = 2
    } else if p == 'o' || p == 'O' {
      digits = "20000000000"
      i = 2
    }
  }
  let started = false
  let j = 0
  while i < t.length {
    let c = t[i]
    if c == '_' {
      i = i + 1
    } else if !started && c == '0' {
      i = i + 1
    } else {
      started = true
      if j >= digits.length { return false }
      if c != digits[j] { return false }
      i = i + 1
      j = j + 1
    }
  }
  j == digits.length
}
// Fold a non-negative integer LEXEME (a `NumLit.numText`, possibly past the i32
// range) into a 64-bit (hi, lo) i32 PAIR, returned as `[hi, lo]`. Mirrors
// `parseI32`'s base detection (hex `0x`/binary `0b`/octal `0o`, else decimal,
// with `_` separators skipped) but accumulates into the pair via 64-bit
// multiply-add so values like `0xFFFFFFFFFF` survive intact. Each step computes
// `pair = pair * base + digit` using `mulAdd64`.
function parseI64Pair(text: string) {
  let hi = 0
  let lo = 0
  let i = 0
  let base = 10
  if text.length >= 2 && text[0] == '0' {
    const p = text[1]
    if p == 'x' || p == 'X' {
      base = 16
      i = 2
    } else if p == 'b' || p == 'B' {
      base = 2
      i = 2
    } else if p == 'o' || p == 'O' {
      base = 8
      i = 2
    }
  }
  while i < text.length {
    let c = text[i]
    if c == '_' {
      i = i + 1
    } else {
      let d = 0
      if c >= '0' && c <= '9' { d = c - '0' }
      else if c >= 'a' && c <= 'f' { d = c - 'a' + 10 }
      else { d = c - 'A' + 10 }
      let r = mulAdd64(hi, lo, base, d)
      hi = r[0]
      lo = r[1]
      i = i + 1
    }
  }
  let out: i32[] = []
  out.push(hi)
  out.push(lo)
  out
}
// 64-bit `(hi, lo) * m + add`, returned as `[hi, lo]`. `m`/`add` are small
// (base Γëñ 16, digit Γëñ 15) so the multiply fits without a full 64├ù64. The low
// lane is split into two 16-bit halves so each partial product stays within i32;
// carries propagate into the high lane. All lanes are treated as UNSIGNED 32-bit.
function mulAdd64(hi: i32, lo: i32, m: i32, add: i32) {
  const loLow = lo & 0xffff
  const loHigh = (lo >>> 16) & 0xffff
  const p0 = loLow * m + add
  const p1 = loHigh * m + (p0 >>> 16)
  const newLo = (p0 & 0xffff) | ((p1 & 0xffff) << 16)
  let carry = p1 >>> 16
  // High lane: hi * m + carry, low 32 bits kept (overflow past 64 bits is dropped,
  // as the host's `i64.const` wraps mod 2^64).
  const hiLow = hi & 0xffff
  const hiHigh = (hi >>> 16) & 0xffff
  const q0 = hiLow * m + carry
  const q1 = hiHigh * m + (q0 >>> 16)
  const newHi = (q0 & 0xffff) | ((q1 & 0xffff) << 16)
  let out: i32[] = []
  out.push(newHi)
  out.push(newLo)
  out
}
// i64.const: 0x42 <value-sleb64>. The 64-bit literal value is carried as a (hi,
// lo) i32 pair (`parseI64Pair`) and signed-LEB-encoded over 64 bits (`wSLEB64`).
function fbI64Const(hi: i32, lo: i32) {
  wU8(66) // 0x42 i64.const
  wSLEB64(hi, lo)
  0
}
// i64.extend_i32_s: 0xac. Sign-extends an i32 on the stack to i64 ΓÇö the bridge
// inserted when an i32-typed value (e.g. a bare integer literal) is used where i64
