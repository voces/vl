// VL-in-VL wasm emitter â€” self-hosted codegen spike.
//
// A `.vl` program that produces RAW WebAssembly *bytes* for a minimal but valid
// module. It does NOT consume the AST arena (that is the full codegen port);
// instead it hand-builds the byte sequence for two fixed modules to exercise the
// LEB128/byte-array/section-framing machinery that a real codegen requires.
//
// VL has NO module system, so the TS runner concatenates `compiler/ast.vl`
// (for `i32ToStr`) ahead of this file and a print driver. Mind name collisions:
// names here (`W`, `emit*`, `leb*`, `buildConstModule`, â€¦) must not clash with
// ast.vl. `i32ToStr` is reused from ast.vl.
//
// Output representation: a VL `i32[]` of byte values 0..255. WasmGC has no `u8`,
// so `i32[]` is used (see docs/selfhost-gaps.md). Bytes are masked to the low
// 8 bits on emit (`& 0xff`).

// â”€â”€ BinaryWriter (Layer 1) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// The one place bytes are appended. State lives in module-global `let`s (no
// closures, so the emitter stays self-compilable). `W.bytes` is the module
// output buffer; `curBuf` is the "current target" the streaming primitives
// (`wU8`/`wBytes`/`wULEB`/`wSLEB`/`wName`) append to. By default `curBuf` IS
// `W.bytes`; lowering that builds a section payload into a fresh `i32[]`
// redirects the writer with `wTarget(buf)` (save the returned previous buffer,
// restore it with a second `wTarget(prev)` when done). This threads "which
// buffer" without passing it to every helper and without a closure.
//
// Output representation: a VL `i32[]` of byte values 0..255 (WasmGC has no `u8`);
// bytes are masked to the low 8 bits on emit.
type Emitter = { bytes: i32[] }
let W: Emitter = { bytes: [] }
// The buffer the streaming writer currently appends to. Initialized to the
// module output buffer; rebound by `wTarget`, reset by `emitReset`.
let curBuf: i32[] = W.bytes

function emitReset(): i32 {
  W.bytes = []
  curBuf = W.bytes
  0
}

// Redirect the writer at `buf`; return the PREVIOUS current buffer so the caller
// can restore it (closure-free save/restore â€” replaces threading `body`/`payload`
// through every helper).
function wTarget(buf: i32[]): i32[] {
  let prev = curBuf
  curBuf = buf
  prev
}

// Append one byte (low 8 bits) to the current buffer.
function wU8(b: i32): i32 {
  curBuf.push(b & 0xff)
  0
}

// Append every byte of `bs` in order to the current buffer.
function wBytes(bs: i32[]): i32 {
  let i = 0
  while i < bs.length {
    wU8(bs[i])
    i = i + 1
  }
  0
}

// â”€â”€ LEB128 encoders â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Each encoder stores 7 data bits per output byte; the high bit (0x80) is the
// continuation flag, set on every byte except the last. `& 0x7f` extracts the
// low 7 bits, `>>> 7` does the unsigned right-shift for ULEB, `>> 7` does the
// arithmetic right-shift for SLEB (preserving sign), and `| 0x80` sets the
// continuation bit. The canonical `*ToArr` forms return a fresh `i32[]` so
// they compose into nested payload builders; `wULEB`/`wSLEB` append straight to
// the current buffer (`curBuf`) for section-length framing and operands.

// Unsigned LEB128: 7 bits per byte, low-to-high, high bit set while more remain.
function ulebToArr(value: i32): i32[] {
  let out: i32[] = []
  let v = value
  let more = true
  while more {
    let byte = v & 0x7f
    v = v >>> 7
    if v == 0 {
      out.push(byte)
      more = false
    } else {
      out.push(byte | 0x80)
    }
  }
  out
}

// SLEB-encode `value` into a fresh `i32[]`.
function slebToArr(value: i32): i32[] {
  let out: i32[] = []
  let v = value
  let more = true
  while more {
    let byte = v & 0x7f
    v = v >> 7
    let signBit = 0
    if (byte & 0x40) != 0 { signBit = 1 }
    if v == 0 {
      if signBit == 0 {
        out.push(byte)
        more = false
      } else {
        out.push(byte | 0x80)
      }
    } else {
      if v == 0 - 1 {
        if signBit == 1 {
          out.push(byte)
          more = false
        } else {
          out.push(byte | 0x80)
        }
      } else {
        out.push(byte | 0x80)
      }
    }
  }
  out
}

// Append all of `src` onto `dst` (in place) and return `dst`.
function appendAll(dst: i32[], src: i32[]): i32[] {
  let i = 0
  while i < src.length {
    dst.push(src[i])
    i = i + 1
  }
  dst
}

// Streaming unsigned-LEB: append straight to the current buffer (used for
// section-length framing and operand encoding). The `*ToArr` array forms are
// retained for the few sites that genuinely compose a fresh payload array.
function wULEB(value: i32): i32 {
  wBytes(ulebToArr(value))
  0
}

// Streaming signed-LEB: append straight to the current buffer.
function wSLEB(value: i32): i32 {
  wBytes(slebToArr(value))
  0
}

// Write a name: ULEB(byte length) followed by its UTF-8 bytes. For an ASCII
// identifier each `s[i]` char code IS its byte. Dedupes the hand-rolled
// length-prefix + char-loop in the export/field-name emission.
function wName(s: string): i32 {
  wULEB(s.length)
  let i = 0
  while i < s.length {
    wU8(s[i])
    i = i + 1
  }
  0
}

// â”€â”€ section framing â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// A section is: id byte, then ULEB(byte-length of payload), then payload. The
// payload is built eagerly into a temporary `i32[]`, then framed onto the
// current buffer. (No closures/builder objects â€” payloads are constructed
// eagerly into arrays; no backpatching.)
function wSection(id: i32, payload: i32[]): i32 {
  wU8(id)
  wULEB(payload.length)
  wBytes(payload)
  0
}

// â”€â”€ FuncBuilder opcode methods (Layer 2 â€” typed instruction emission) â”€â”€â”€â”€â”€â”€â”€â”€â”€
// One top-level, closure-free function per opcode (or opcode family) VL emits. Each
// writes EXACTLY the bytes the corresponding raw `body.push(<opcode>)` (+ any LEB
// operands) emitted before, straight through the BinaryWriter (`wU8`/`wULEB`/`wSLEB`)
// onto the CURRENT buffer (`curBuf`). The lowering sets `curBuf` to the buffer it is
// filling (the function body, or a global-init constexpr) via `wTarget`, so these
// methods need no `body` parameter â€” they are the single place each magic opcode byte
// lives. Every method returns `0` (a side-effecting builder; statement sequencing
// replaces method chaining). The opcode set is small and closed (~40); this phase
// (Phase B) DEFINES the whole set's control/locals/consts family with real bodies and
// converts its call sites, leaving the struct / array / map / string families to land
// in Phases Câ€“F.

// â”€â”€ control flow / locals / consts (the universal base â€” Phase B) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// local.get / local.set / local.tee: 0x20/0x21/0x22 <localidx-uleb>.
function fbLocalGet(i: i32): i32 {
  wU8(32)            // 0x20 local.get
  wULEB(i)
  0
}
function fbLocalSet(i: i32): i32 {
  wU8(33)            // 0x21 local.set
  wULEB(i)
  0
}
function fbLocalTee(i: i32): i32 {
  wU8(34)            // 0x22 local.tee
  wULEB(i)
  0
}
// global.get / global.set: 0x23/0x24 <globalidx-uleb>.
function fbGlobalGet(i: i32): i32 {
  wU8(35)            // 0x23 global.get
  wULEB(i)
  0
}
function fbGlobalSet(i: i32): i32 {
  wU8(36)            // 0x24 global.set
  wULEB(i)
  0
}
// i32.const: 0x41 <value-sleb>.
function fbI32Const(v: i32): i32 {
  wU8(65)            // 0x41 i32.const
  wSLEB(v)
  0
}
// if: 0x04 <blocktype>. `blockType` is a single byte (0x40 void, or a valtype byte).
function fbIf(blockType: i32): i32 {
  wU8(4)             // 0x04 if
  wU8(blockType)
  0
}
function fbElse(): i32 {
  wU8(5)             // 0x05 else
  0
}
// block / loop: 0x02/0x03 <blocktype> (single byte, as `fbIf`).
function fbBlock(blockType: i32): i32 {
  wU8(2)             // 0x02 block
  wU8(blockType)
  0
}
function fbLoop(blockType: i32): i32 {
  wU8(3)             // 0x03 loop
  wU8(blockType)
  0
}
// br / br_if: 0x0c/0x0d <depth-uleb>.
function fbBr(depth: i32): i32 {
  wU8(12)            // 0x0c br
  wULEB(depth)
  0
}
function fbBrIf(depth: i32): i32 {
  wU8(13)            // 0x0d br_if
  wULEB(depth)
  0
}
function fbEnd(): i32 {
  wU8(11)            // 0x0b end
  0
}
function fbDrop(): i32 {
  wU8(26)            // 0x1a drop
  0
}
function fbUnreachable(): i32 {
  wU8(0)             // 0x00 unreachable
  0
}
function fbReturn(): i32 {
  wU8(15)            // 0x0f return
  0
}
// call: 0x10 <funcidx-uleb>.
function fbCall(fnIdx: i32): i32 {
  wU8(16)            // 0x10 call
  wULEB(fnIdx)
  0
}
// i32.eqz: 0x45 (used for `!a` and the while-condition inversion).
function fbI32Eqz(): i32 {
  wU8(69)            // 0x45 i32.eqz
  0
}
// One i32 arithmetic / comparison opcode (the `binOpcode` set: 0x6a add, 0x6b sub,
// 0x6c mul, 0x6d div_s, 0x6f rem_s, 0x46 eq, 0x47 ne, 0x48 lt_s, 0x4a gt_s, 0x4c le_s,
// 0x4e ge_s). The opcode byte is resolved by `binOpcode`; this just writes it.
function fbI32Bin(op: i32): i32 {
  wU8(op)
  0
}

// â”€â”€ opcode-method STUBS for the later families (Phases Câ€“F) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Names declared now so the closed ~40-method set is coherent and self-documenting;
// their CALL SITES (in `emitObj`/`emitArr`/`emitMap*`/string ops) are NOT converted in
// this phase â€” they still push raw bytes. Each stub already emits the exact bytes its
// family's sites emit, so converting those sites in Câ€“F is a pure call-site swap.
// GC struct ops (Phase C):
function fbStructNew(heapIdx: i32): i32 {
  wU8(251)           // 0xfb GC prefix
  wU8(0)             // struct.new
  wULEB(heapIdx)
  0
}
function fbStructNewDefault(heapIdx: i32): i32 {
  wU8(251)           // 0xfb GC prefix
  wU8(1)             // struct.new_default
  wULEB(heapIdx)
  0
}
function fbStructGet(heapIdx: i32, field: i32): i32 {
  wU8(251)           // 0xfb GC prefix
  wU8(2)             // struct.get
  wULEB(heapIdx)
  wULEB(field)
  0
}
function fbStructSet(heapIdx: i32, field: i32): i32 {
  wU8(251)           // 0xfb GC prefix
  wU8(5)             // struct.set
  wULEB(heapIdx)
  wULEB(field)
  0
}
// GC array ops (Phase D):
function fbArrayNew(heapIdx: i32): i32 {
  wU8(251)           // 0xfb GC prefix
  wU8(6)             // array.new
  wULEB(heapIdx)
  0
}
function fbArrayNewDefault(heapIdx: i32): i32 {
  wU8(251)           // 0xfb GC prefix
  wU8(7)             // array.new_default
  wULEB(heapIdx)
  0
}
function fbArrayNewFixed(heapIdx: i32, n: i32): i32 {
  wU8(251)           // 0xfb GC prefix
  wU8(8)             // array.new_fixed
  wULEB(heapIdx)
  wULEB(n)
  0
}
function fbArrayGet(heapIdx: i32): i32 {
  wU8(251)           // 0xfb GC prefix
  wU8(11)            // 0x0b array.get
  wULEB(heapIdx)
  0
}
function fbArraySet(heapIdx: i32): i32 {
  wU8(251)           // 0xfb GC prefix
  wU8(14)            // 0x0e array.set
  wULEB(heapIdx)
  0
}
function fbArrayLen(): i32 {
  wU8(251)           // 0xfb GC prefix
  wU8(15)            // 0x0f array.len
  0
}
function fbArrayCopy(destHeapIdx: i32, srcHeapIdx: i32): i32 {
  wU8(251)           // 0xfb GC prefix
  wU8(17)            // 0x11 array.copy
  wULEB(destHeapIdx) // dest array type index
  wULEB(srcHeapIdx)  // src array type index
  0
}
// GC ref ops (Phases C/D/F):
function fbRefCast(heapIdx: i32): i32 {
  wU8(251)           // 0xfb GC prefix
  wU8(22)            // 0x16 ref.cast (non-null)
  wULEB(heapIdx)
  0
}

// â”€â”€ module header â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
function emitHeader(): i32 {
  // "\0asm" magic + version 1
  wU8(0)
  wU8(97)   // 'a'
  wU8(115)  // 's'
  wU8(109)  // 'm'
  wU8(1)
  wU8(0)
  wU8(0)
  wU8(0)
  0
}

// â”€â”€ full module: () -> i32 returning 42 â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// (module
//   (func $main (result i32) (i32.const 42))
//   (export "main" (func $main)))
function buildConstModule(): i32 {
  emitReset()
  emitHeader()

  // Type section (id 1): one functype () -> i32
  // payload = vec(functype): count=1, 0x60, params vec(0), results vec(1, 0x7f)
  let typePayload: i32[] = []
  typePayload.push(1)      // 1 type
  typePayload.push(96)     // 0x60 func
  typePayload.push(0)      // 0 params
  typePayload.push(1)      // 1 result
  typePayload.push(127)    // 0x7f i32
  wSection(1, typePayload)

  // Function section (id 3): one function, type index 0
  let funcPayload: i32[] = []
  funcPayload.push(1)      // 1 function
  funcPayload.push(0)      // type index 0
  wSection(3, funcPayload)

  // Export section (id 7): export "main" as func 0
  let exportPayload: i32[] = []
  exportPayload.push(1)    // 1 export
  exportPayload.push(4)    // name length 4
  exportPayload.push(109)  // 'm'
  exportPayload.push(97)   // 'a'
  exportPayload.push(105)  // 'i'
  exportPayload.push(110)  // 'n'
  exportPayload.push(0)    // export kind: func
  exportPayload.push(0)    // func index 0
  wSection(7, exportPayload)

  // Code section (id 10): one function body
  // body = vec(locals)=0, i32.const 42 (0x41 + SLEB 42), end (0x0b)
  let body: i32[] = []
  let bPrev = wTarget(body)
  wU8(0)             // 0 local declarations
  wU8(65)            // 0x41 i32.const
  wSLEB(42)
  wU8(11)            // 0x0b end
  wTarget(bPrev)

  // code payload = count=1, then size-prefixed body
  let codePayload: i32[] = []
  let cPrev = wTarget(codePayload)
  wU8(1)             // 1 code entry
  wULEB(body.length)
  wBytes(body)
  wTarget(cPrev)
  wSection(10, codePayload)
  0
}

// â”€â”€ full module: (i32) -> i32 returning its param (local.get 0) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// (module
//   (func $id (param i32) (result i32) (local.get 0))
//   (export "id" (func $id)))
// Exercises param encoding (non-empty param vec) and local.get.
function buildIdentityModule(): i32 {
  emitReset()
  emitHeader()

  // Type section: (i32) -> i32
  let typePayload: i32[] = []
  typePayload.push(1)      // 1 type
  typePayload.push(96)     // 0x60 func
  typePayload.push(1)      // 1 param
  typePayload.push(127)    // 0x7f i32 param
  typePayload.push(1)      // 1 result
  typePayload.push(127)    // 0x7f i32 result
  wSection(1, typePayload)

  // Function section
  let funcPayload: i32[] = []
  funcPayload.push(1)
  funcPayload.push(0)
  wSection(3, funcPayload)

  // Export "id"
  let exportPayload: i32[] = []
  exportPayload.push(1)
  exportPayload.push(2)    // name length 2
  exportPayload.push(105)  // 'i'
  exportPayload.push(100)  // 'd'
  exportPayload.push(0)    // func kind
  exportPayload.push(0)    // func index 0
  wSection(7, exportPayload)

  // Code: local.get 0 ; end
  let body: i32[] = []
  let bPrev = wTarget(body)
  wU8(0)             // 0 local declarations (params aren't locals here)
  wU8(32)            // 0x20 local.get
  wULEB(0)
  wU8(11)            // 0x0b end
  wTarget(bPrev)

  let codePayload: i32[] = []
  let cPrev = wTarget(codePayload)
  wU8(1)
  wULEB(body.length)
  wBytes(body)
  wTarget(cPrev)
  wSection(10, codePayload)
  0
}

// â”€â”€ AST-driven back end â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// The fixed-module builders above prove the byte machinery on hand-built bytes.
// `emitProgram` is the first slice that actually READS the parsed arena
// (`P.nodes`, the `Node[]` from `compiler/ast.vl` that `parser.vl` fills) and
// emits a real module from it â€” reusing every section / LEB / encoding helper.
//
// It handles exactly the trivial shape and nothing else:
//
//   function main(): i32 { return <integer literal> }
//
// Anything outside that shape is a HARD STOP: `emitFail` records a message and
// clears the buffer, so the driver/test sees an empty module (which never
// instantiates) plus an explanation â€” never silently-wrong bytes. Richer codegen
// (params, locals, real expressions, multiple functions) is the next slice.

// The unsupported-shape state. `emitFailed` is the set flag (a `boolean`, which
// widens on reassignment the way `true`/`false`-toggled flags do throughout the
// parser; a bare-`0`/`1` i32 global pins to the literal type and won't reassign);
// `emitErr` carries the first message. Both are top-level mutable `let`s â€” they
// lower to wasm globals readable from any helper.
let emitFailed = false
let emitErr = ""

// Record an unsupported-shape failure: keep the first message and drop any bytes
// emitted so far, so a partial/garbage module can never reach instantiation.
// Returns -1, the sentinel `emitProgram` propagates so callers can branch on it.
function emitFail(msg: string): i32 {
  if !emitFailed {
    emitFailed = true
    emitErr = msg
  }
  W.bytes = []
  0 - 1
}

// â”€â”€ function-index map â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// A module has N top-level functions. Each is assigned a wasm function index by
// its position in `progStmts` (the 0th `FuncDecl` is func 0, the 1st is func 1, â€¦),
// and every function shares the SAME type index (all are `(i32 * n) -> i32`, but
// arities differ, so each gets its own type â€” see `emitModule`). A `call` lowers a
// callee NAME to its function index, so the nameâ†’index map is built over ALL
// top-level functions BEFORE any body is emitted: that makes forward references and
// (since a function's own name is already mapped) recursion resolve for free.
//
// The map is two parallel top-level `let` arrays (they lower to wasm globals): the
// i-th name maps to the i-th function index. `fnNames[i]`'s function index is
// `fnIndices[i]`, which equals `i` here but is kept explicit for clarity.
let fnNames: string[] = []
let fnIndices: i32[] = []

// The node-arena indices of the top-level `FuncDecl`s, in order. The i-th entry is
// wasm function index i â€” the order all of function/export/code sections follow.
// Built by `collectFns` (a single `is FuncDecl` scan); `TypeDecl`s are skipped, any
// other top-level statement fails loudly there.
let fnStmts: i32[] = []

// Parallel to `fnNames`: `1` if the i-th function's declared RETURN type is the
// struct, else `0`. Populated by `buildFnMap` so `fnRetStruct` is a flat lookup.
let fRetRef: i32[] = []

// Parallel to `fnNames`: the STRUCT TABLE INDEX the i-th function returns (when
// `fRetRef[i] == 1`), else `-1`. Populated by `buildFnMap` so `fnRetStructIndex` is a
// flat lookup.
let fRetStructIdx: i32[] = []

// Parallel to `fnNames`: `1` if the i-th function's declared RETURN type is an array
// (`i32[]`), else `0`. Populated by `buildFnMap` so `fnRetArray` is a flat lookup.
let fRetArr: i32[] = []

// Parallel to `fnNames`: `1` if the i-th function's declared RETURN type is `string`,
// else `0`. Populated by `buildFnMap` so `fnRetString` is a flat lookup. A string is
// CURRENTLY the same `(array (mut i32))` of code points an `i32[]` uses (per
// `docs/strings-design.md`), so a string return reuses the array ref valtype.
let fRetStr: i32[] = []

// Parallel to `fnNames`: `1` if the i-th function's declared RETURN type is the union
// alias, else `0`. Populated by `buildFnMap` so `fnRetUnion` is a flat lookup.
let fRetUni: i32[] = []

// Parallel to `fnNames`: `1` if the i-th function's declared RETURN type is a REF array
// (`S[]`/`N[]`), else `0`. Populated by `buildFnMap` so `fnRetRefArray` is a flat lookup.
let fRetRArr: i32[] = []
// Parallel to `fnNames`: the ref-list element type-NAME the i-th function returns (its
// `S[]`/`N[]` return annotation's element), or "". Lets a ref-list-returning call resolve
// its distinct element-type table slot.
let fRetRArrElem: string[] = []

// â”€â”€ module-level GLOBALS (G2b) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// A top-level `let`/`const` (`LetDecl`) lowers to a wasm module GLOBAL (mutable),
// emitted in the global section (id 6). Its wasm GLOBAL INDEX is its position among
// the top-level `LetDecl`s in declaration order â€” that order IS the index a
// `global.get`/`global.set` references. `globalStmts` holds the arena indices of those
// `LetDecl`s (declaration order); `globalNames` the parallel names (nameâ†’index lookup).
// A bare `Ident` that is not a param/local but matches a `globalName` reads/writes the
// global (`0x23`/`0x24`) instead of a local (`0x20`/`0x21`).
let globalStmts: i32[] = []
let globalNames: string[] = []

// Scan the program's top-level statements into `fnStmts` (FuncDecls only, in order),
// skipping `TypeDecl`s and gathering top-level `LetDecl`s into `globalStmts` (module
// globals, declaration order = global index). Any other top-level statement fails
// loudly. Returns the function count, or -1 (via `emitFail`).
function collectFns(stmts: i32[]): i32 {
  fnStmts = []
  globalStmts = []
  globalNames = []
  let i = 0
  while i < stmts.length {
    let s = P.nodes[stmts[i]]
    if s is FuncDecl {
      fnStmts.push(stmts[i])
    } else if s is LetDecl {
      // A top-level `let`/`const` â€” a module global; its position here is its index.
      globalStmts.push(stmts[i])
      globalNames.push(s.letName)
    } else if nodeIsTypeDecl(stmts[i]) {
    } else if s is UnionDecl {
      // A `type N = A | B` union alias â€” collected by `collectU`, skipped here.
    } else {
      return emitFail("emitProgram: top-level statement is not a function, type, or global")
    }
    i = i + 1
  }
  fnStmts.length
}

// The wasm global index for `name`, or -1 if no top-level global has that name.
function globalIndexOf(name: string): i32 {
  let i = 0
  while i < globalNames.length {
    if globalNames[i] == name { return i }
    i = i + 1
  }
  0 - 1
}

// The arena index of the `LetDecl` for the global `name`, or -1 if not a global.
function globalLetOf(name: string): i32 {
  let gi = globalIndexOf(name)
  if gi < 0 { return 0 - 1 }
  globalStmts[gi]
}

// Whether the global `name` is a struct/array/string ref (so a bare reference to it in
// an `exprStruct`/`exprArray`/`exprString` check is recognized as that ref type). The
// global's valtype follows its `LetDecl` annotation or literal initializer, evaluated as
// a top-level constexpr (`fnIx = -1`), mirroring the local `letIsX` predicates.
function globalIsStruct(name: string): boolean {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsStruct(li, 0 - 1)
}
function globalIsArray(name: string): boolean {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsArray(li, 0 - 1)
}
function globalIsString(name: string): boolean {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsString(li, 0 - 1)
}
function globalIsRefArray(name: string): boolean {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsRefArray(li, 0 - 1)
}
function globalIsStringArray(name: string): boolean {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsStringArray(li, 0 - 1)
}

// Map each function NAME to its wasm function index (its position in `fnStmts`), and
// record whether it returns the struct. Returns the function count.
function buildFnMap(stmts: i32[]): i32 {
  fnNames = []
  fnIndices = []
  fRetRef = []
  fRetStructIdx = []
  fRetArr = []
  fRetStr = []
  fRetUni = []
  fRetRArr = []
  fRetRArrElem = []
  let i = 0
  while i < fnStmts.length {
    let s = P.nodes[fnStmts[i]]
    if s is FuncDecl {
      fnNames.push(s.fnName)
      fnIndices.push(i)
      fRetRef.push(retTRFlag(s.fnRet))
      fRetStructIdx.push(retStructIndex(s.fnRet))
      fRetArr.push(retArrFlag(s.fnRet))
      fRetStr.push(retStrFlag(s.fnRet))
      fRetUni.push(retUnionFlag(s.fnRet))
      fRetRArr.push(retRefArrFlag(s.fnRet))
      fRetRArrElem.push(retRefArrElemName(s.fnRet))
    }
    i = i + 1
  }
  fnStmts.length
}

// Look up the wasm function index for `name`, or -1 if no such top-level function
// exists (an undefined callee â€” the caller fails loudly).
function fnIndexOf(name: string): i32 {
  let i = 0
  while i < fnNames.length {
    if fnNames[i] == name {
      return fnIndices[i]
    }
    i = i + 1
  }
  0 - 1
}

// Parse a non-negative integer lexeme (a `NumLit.numText`) into its i32 value.
// The lexer stores the RAW source lexeme: a plain decimal digit run, OR a `0x`/
// `0X` hex run, OR a `0b`/`0B` binary run (it mirrors the host's base set, but
// keeps the lexeme un-normalized â€” so the base is folded here, at value time).
// The prefix is detected from the first two chars; otherwise base-10 is assumed.
// Each digit char's value is its char code minus the appropriate base offset.
function parseI32(text: string): i32 {
  let v = 0
  let i = 0
  // Hex `0xâ€¦` / binary `0bâ€¦` â€” skip the two-char prefix, then fold base 16 / 2.
  if text.length >= 2 && text[0] == '0' {
    let p = text[1]
    if p == 'x' || p == 'X' {
      i = 2
      while i < text.length {
        let c = text[i]
        let d = 0
        if c >= '0' && c <= '9' {
          d = c - '0'
        } else if c >= 'a' && c <= 'f' {
          d = c - 'a' + 10
        } else {
          d = c - 'A' + 10
        }
        v = v * 16 + d
        i = i + 1
      }
      return v
    }
    if p == 'b' || p == 'B' {
      i = 2
      while i < text.length {
        v = v * 2 + (text[i] - '0')
        i = i + 1
      }
      return v
    }
  }
  while i < text.length {
    v = v * 10 + (text[i] - '0')
    i = i + 1
  }
  v
}

// â”€â”€ parameter resolution â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// A returned `Ident` is a parameter reference; its wasm `local.get` index is the
// param's position in `fnParams` (params occupy locals 0..n-1, before any declared
// locals). `paramIndexOf` scans the FuncDecl's `fnParams` for the param whose
// `parName` matches `name`, returning its 0-based position or -1 if not a param.
// Only i32 params exist in this slice, so position == local index directly.
function paramIndexOf(fnIx: i32, name: string): i32 {
  if fnIx < 0 { return 0 - 1 }   // module-scope initializer (no enclosing function)
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    let params = fn.fnParams
    let i = 0
    while i < params.length {
      let p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          return i
        }
      }
      i = i + 1
    }
  }
  0 - 1
}

// â”€â”€ declared-local map â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// A `let`/`const` inside a function body allocates a wasm local whose index comes
// AFTER the params: params occupy locals `0..p-1`, the i-th declared local gets
// `p + i` (declaration order). Wasm locals are function-scoped (not block-scoped),
// and the code body's locals vector is fixed up-front, so EVERY `LetDecl` in the
// body â€” including those nested in `if` branches â€” must be collected before any
// instruction is emitted.
//
// `localNames` is a top-level `let` array (it lowers to a wasm global) holding the
// declared-local names of the function currently being emitted, in declaration
// order; the i-th name's wasm local index is `p + i` (with `p` the param count).
// It is rebuilt per function by `buildLocals` before that function's body is
// lowered, so only one function's locals are live at a time.
let localNames: string[] = []
// Parallel to `localNames`: the i-th declared local's value-type CODE â€” `1` for a
// struct `(ref $0)` local, `2` for a list `(ref $lTypeIdx)` local (the growable `i32[]`
// wrapper struct), `3` for a `string` local (the raw `(array (mut i32))` of code points
// â€” see `docs/strings-design.md`), `0` for an i32 local. The locals vector (`pushVT`)
// and identifier resolution consult this so a ref-typed local gets the correct ref
// valtype, not i32.
let localIsRef: i32[] = []
// Parallel to `localNames`: when the i-th local is a STRUCT ref (`localIsRef[i] == 1`),
// `localStructIdx[i]` is its struct table index (so a field read/write on the local
// resolves to the right heap type + field layout). For non-struct locals the slot is
// unused (`-1`). Rebuilt alongside `localNames` by `buildLocals`.
let localStructIdx: i32[] = []

// â”€â”€ lexical scope stack (per-block local binding resolution) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Wasm locals are function-scoped, but VL `let`s are LEXICALLY block-scoped: two
// `let s` in DISJOINT branches (then vs else) are SEPARATE bindings that may carry
// DIFFERENT types, so each must get its OWN wasm slot (the i-th slot's valtype lives
// in `localIsRef[i]`/`localStructIdx[i]`). `addLocalName` therefore no longer dedupes
// by name â€” every `let` pushes a fresh slot. To resolve an identifier to the RIGHT
// slot (innermost binding in scope at the reference site), a scope stack tracks the
// `(name â†’ declared-local position)` bindings that are live as the walk descends.
//
// `scopeNames`/`scopeSlots` are parallel: the k-th live binding's name and its
// declared-local POSITION (so its wasm index is `paramCount + scopeSlots[k]`, its
// valtype `localIsRef[scopeSlots[k]]`). `scopeFrames` is the frame-boundary stack:
// each pushed value is `scopeNames.length` AT FRAME ENTRY, so popping a frame truncates
// `scopeNames`/`scopeSlots` back to that mark. The same push/append/pop discipline runs
// in BOTH the collect pass (slot allocation) and the emit pass (slot resolution), so
// resolution is consistent across both. All reset per function in `buildLocals`.
let scopeNames: string[] = []
let scopeSlots: i32[] = []
let scopeFrames: i32[] = []

// Emit-time running declared-local slot cursor. The emit pass visits `LetDecl`s in the
// SAME pre-order `collectLocals` allocated them (block stmts â†’ if-then â†’ if-else â†’
// while-body), so the n-th `LetDecl` emitted owns declared-local slot `n` â€” exactly the
// slot `addLocalName` gave it. The cursor yields that slot WITHOUT a name lookup (a name
// lookup would wrongly resolve to an outer same-named binding still in scope at the
// store site). Reset to 0 per function before the body is lowered.
let emitLetCursor: i32 = 0

// Enter a new lexical block: remember the current binding count as this frame's
// boundary. Returns 0.
function scopePush(): i32 {
  scopeFrames.push(scopeNames.length)
  0
}

// Leave the innermost lexical block: drop its frame boundary and discard every
// binding appended within it (truncate `scopeNames`/`scopeSlots` back to the mark).
// Returns 0.
function scopePop(): i32 {
  if scopeFrames.length == 0 { return 0 }
  let mark = scopeFrames[scopeFrames.length - 1]
  scopeFrames.pop()
  while scopeNames.length > mark {
    scopeNames.pop()
    scopeSlots.pop()
  }
  0
}

// Bind name `name` to declared-local position `slot` in the CURRENT (innermost) frame.
// Called as each `let` is reached, so a binding is in scope only AFTER its declaration
// (sequential), which also yields correct shadowing of an outer same-named binding.
// Returns 0.
function scopeBind(name: string, slot: i32): i32 {
  scopeNames.push(name)
  scopeSlots.push(slot)
  0
}

// The declared-local POSITION bound to `name` by the innermost live scope frame, or
// -1 if `name` is not a live lexical binding. Searches the scope stack top-down
// (innermost first), so a shadowing inner `let` wins over an outer same-named one.
function scopeSlotOf(name: string): i32 {
  let k = scopeNames.length
  while k > 0 {
    k = k - 1
    if scopeNames[k] == name {
      return scopeSlots[k]
    }
  }
  0 - 1
}

// â”€â”€ loop control-frame tracking (for `break` / `continue`) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// wasm branch targets are RELATIVE depths, so to lower `break`/`continue` to a
// `br <depth>` the emitter must know how many control frames sit between the
// branch site and the loop it targets. `ctrlDepth` counts the control frames
// (block / loop / if) currently open at the emit cursor â€” incremented when a
// frame is opened, decremented at its matching `end`. A `while` opens a `block`
// then a `loop` (mirroring the host's outer-block-wraps-loop structure â€” see
// `loopLabels`/`brkLabel` in `toWasm.ts`): on entry it pushes the ABSOLUTE
// `ctrlDepth` of the loop frame onto `loopContDepth` (the `continue` target) and
// of the block frame onto `loopBrkDepth` (the `break` target). At a `break`/
// `continue` site the relative `br` operand is `ctrlDepth - <stack top>`. The
// stacks are popped when the `while` closes. All reset per function in the body
// emit. (The self-host AST carries no loop labels, so only the INNERMOST loop is
// ever targeted â€” `loop*Depth[length-1]`.)
let ctrlDepth: i32 = 0
let loopContDepth: i32[] = []
let loopBrkDepth: i32[] = []

// Opening a control frame: bump the running depth. Returns 0.
function ctrlEnter(): i32 {
  ctrlDepth = ctrlDepth + 1
  0
}

// Closing a control frame (its matching `end`): drop the running depth. Returns 0.
function ctrlLeave(): i32 {
  ctrlDepth = ctrlDepth - 1
  0
}

// â”€â”€ per-function `.push` scratch locals â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// `.push(x)` lowers inline to a grow-if-full + write + len-bump sequence that needs
// three temporaries: `pushVal` (the value to append, i32), `pushNewCap` (the doubled
// capacity, i32), and `pushNewBacking` (the freshly-allocated larger backing, a non-null
// `(ref $aTypeIdx)` â€” it matches the struct's non-null backing field, and is always
// `local.set` before read inside the grow branch, which wasm validation accepts for a
// non-defaultable local). They are allocated AFTER the declared locals, only in a
// function that actually contains a `.push` (detected by `fnHasPush`). `pushScratchBase`
// is the wasm local index of `pushVal`; the other two follow at +1/+2. `fnUsesPush`
// records whether this function reserved them.
let fnUsesPush: boolean = false
let pushScratchBase: i32 = 0

// The ref-list `.push` scratch triple (G7-ref): `pushRefVal` (the element ref),
// `pushRefCap` (i32), `pushRefBacking` (a non-null `(ref $raTypeIdx)`). Allocated AFTER
// the i32 triple (if any), only in a function that pushes onto a ref list. `fnUsesRefPush`
// records whether this function reserved them; `refPushScratchBase` is `pushRefVal`'s index.
let fnUsesRefPush: boolean = false
let refPushScratchBase: i32 = 0

// Per-element-type ref-push scratch frames (slice 4): a function that pushes onto
// DISTINCT ref-list element types needs a separately-TYPED 4-slot frame per element type
// (the backing/wrapper/value locals are typed per element). `fnRefPushSlots` lists the
// table slots this function pushes onto (in first-seen order); `refPushBaseBySlot[k]` is
// the wasm local base of the k-th such frame. `refPushScratchBaseFor` maps a table slot
// to its frame base.
let fnRefPushSlots: i32[] = []
let refPushBaseBySlot: i32[] = []

// The wasm local base of the ref-push scratch frame for ref-list table slot `slot`.
function refPushScratchBaseFor(slot: i32): i32 {
  let i = 0
  while i < fnRefPushSlots.length {
    if fnRefPushSlots[i] == slot { return refPushBaseBySlot[i] }
    i = i + 1
  }
  refPushScratchBase
}

// The string-list `.push` scratch quad (`string[]` field append): `pushStrVal` (a
// non-null `(ref $aTypeIdx)` string), `pushStrCap` (i32), `pushStrBacking` (a non-null
// `(ref $mkArrIdx)` string backing), `pushStrRecvRef` (a non-null `(ref $mkListIdx)`
// wrapper, for a struct-FIELD receiver). Allocated AFTER the ref-push frame, only in a
// function that pushes onto a `string[]`. `fnUsesStrPush` records the reservation;
// `strPushScratchBase` is `pushStrVal`'s index.
let fnUsesStrPush: boolean = false
let strPushScratchBase: i32 = 0

// â”€â”€ per-function string-op scratch locals (G6: `+` / `==`/`!=` / `.slice`) â”€â”€â”€â”€
// String concatenation, value-equality, and slice all lower INLINE (no helper
// functions in this emitter), and each needs temporaries to stash the operand
// strings (so an operand expression is evaluated ONCE â€” no re-eval of a side-
// effecting call) and to drive an element loop. One shared scratch frame covers
// all three, reserved AFTER the push scratch triples in a function that uses ANY
// string op (detected by `fnHasStrOp`):
//   strScrA/strScrB/strScrOut : 3 NON-NULL `(ref $aTypeIdx)` string refs â€” the two
//                               operands + the freshly-allocated result.
//   strScrI0..strScrI3        : 4 i32 temporaries â€” loop index, length, clamped
//                               start/end (slice), running result (equality).
// `strScratchBase` is the wasm local index of `strScrA`; the other six follow at
// +1..+6. `fnUsesStrOp` records whether this function reserved them. Each is non-
// defaultable but always `local.set` before read, which wasm validation accepts.
let fnUsesStrOp: boolean = false
let strScratchBase: i32 = 0

// â”€â”€ struct-type table (MULTIPLE structs per program) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// A program may declare MANY struct `type`s. Mirroring the union variant table, the
// struct table is a FLAT store keyed by struct index (declaration order): struct `i`
// is named `sNames[i]`, owns the field names `sFieldNames[sFieldStart[i] ..
// sFieldStart[i] + sFieldCount[i]]` (declaration order = wasm struct field index),
// with parallel per-field wasm-type codes `sFieldTypes[...]` (`0` = i32, `3` = string
// â€” the `pushVT` kind), and its WasmGC struct heap-type index is `sHeapIdx[i]`
// (resolved in `emitModule`; the structs occupy the first `sNames.length` heap types).
// `sDeclared` is true when at least one struct is declared. These are rebuilt per
// program by `collectS`. When a UNION is declared, the union path owns the struct
// `type`s instead (its variant table) and this table stays empty.
let sDeclared: boolean = false
let sNames: string[] = []
let sFieldNames: string[] = []
let sFieldStart: i32[] = []
let sFieldCount: i32[] = []
let sFieldTypes: i32[] = []
// Parallel to `sFieldTypes`: for a ref-list field (code 5) the element type-NAME (the
// table key into `rlElemName`); "" for any non-ref-list field. Lets a field store/load /
// empty-`[]` field-assign resolve the field's distinct ref-list slot.
let sFieldElemName: string[] = []
let sHeapIdx: i32[] = []

// â”€â”€ array-type table (the raw `(array (mut i32))` heap type) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// A single element type â€” `i32` â€” so ALL raw arrays share one WasmGC array heap type
// `(array (mut i32))`. This raw array now serves TWO roles: it is the `string` rep
// (an `array i32` of code points â€” unchanged), AND it is the BACKING store of a
// growable `i32[]` list (see the list-struct table below). It is emitted whenever the
// program uses a string OR a list (a list needs a backing), placed in the type section
// right AFTER the struct type (if any), so its index is `structOffset`. `aUsed` is a
// presence flag set by `collectA`'s up-front arena scan; `aTypeIdx` is the resolved
// heap-type index, computed in `emitModule`.
let aUsed: boolean = false
let aTypeIdx: i32 = 0

// â”€â”€ list-type table (the growable `i32[]` wrapper struct) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// A growable `i32[]` value lowers to a WasmGC struct `{ backing: (ref $aTypeIdx),
// len: i32, cap: i32 }` â€” the `{ptr,len,cap}` triple (collections-design Â§VL.1,
// mirroring `toWasm.ts`'s `listType`). `backing` is the raw `(array (mut i32))` above
// (so a grow can swap in a larger one); `len` is the user-visible size (`.length`,
// bounds, iteration); `cap` the allocated slot count. WasmGC arrays are FIXED-LENGTH,
// so the wrapper is what makes `.push` grow: when `len == cap`, allocate a backing of
// `cap == 0 ? 4 : cap * 2`, `array.copy` the live `len` elements in, swap in the new
// backing + cap, then write at `[len]` and bump `len` (Â§VL.2). The struct's three
// fields are ALL mutable. Field indices are fixed by the type-section order below:
// backing=0, len=1, cap=2. `lUsed` is set by `collectA` whenever a list is used (an
// array literal, an `i32[]` annotation); a list use also sets `aUsed` (the backing).
// `lTypeIdx` is the resolved heap-type index, computed in `emitModule`.
let lUsed: boolean = false
let lTypeIdx: i32 = 0

// â”€â”€ ref-element list-type table (G7-ref: arrays of structs / unions) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// A growable list whose ELEMENT is a REFERENCE â€” `Tok[]` (a struct ref) or `Node[]`
// (the union box ref) â€” uses the SAME `{ backing, len, cap }` wrapper shape as the
// i32 list, but its backing array's element slot is a ref, not an i32. Mirroring
// `toWasm.ts`'s `arraySlotWasmType`/`arrayReadCast` (verified empirically against the
// TS compiler's emitted module for `T[]`/`N[]`):
//
//   â€¢ the BACKING array is `(array (mut (ref null $elem)))` â€” the element ref is
//     NULLABLE-WIDENED so `array.new_default` (used by grow) can default the spare
//     slots to `ref.null`. `$elem` is the struct type (heap-type 0) for a struct
//     list, or the union BOX (`uBoxIdx`) for a union list. Its heap-type index is
//     `raTypeIdx`.
//   â€¢ the LIST WRAPPER is `{ backing: (ref $raTypeIdx), len: i32, cap: i32 }` â€” the
//     identical triple, just over the ref backing. Its heap-type index is `rlTypeIdx`.
//
// A READ `xs[i]` is `array.get $raTypeIdx (backing) i` then `ref.as_non_null`
// (`0xd4`) to surface the non-null element type (slots in `[0,len)` are always
// populated, so the cast never traps) â€” that yields the struct ref / union box.
// `.push`/index-set reuse the i32-list grow/store machinery, just over the ref
// backing (`array.new_default`/`array.copy`/`array.set` over `$raTypeIdx`, and a
// ref scratch backing local).
//
// `rElemKind` records the element kind: `1` = a struct ref (heap-type 0), `2` = the
// union box ref (`uBoxIdx`). `raUsed`/`rlUsed` are presence flags (set by `collectA`);
// `raTypeIdx`/`rlTypeIdx` are resolved in `emitModule`. ONE ref-element list type per
// program (struct OR union element), alongside the existing i32 list â€” enough for the
// `Tok[]` / `Node[]` arenas this slice targets.
let raUsed: boolean = false
let rlUsed: boolean = false
let raTypeIdx: i32 = 0
let rlTypeIdx: i32 = 0
let rElemKind: i32 = 0

// â”€â”€ per-element-type ref-list table (MULTIPLE distinct ref lists program-wide) â”€
// `parser.vl`'s `Parser` holds THREE distinct ref-list element types at once â€”
// `toks: Tok[]`, `nodes: Node[]`, `diags: Diag[]` â€” so a single program-global
// `raTypeIdx`/`rlTypeIdx`/`rElemKind` is not enough. This flat table interns a
// backing array + list wrapper heap type PER DISTINCT element type, keyed by the
// element type-NAME (a declared struct name, or the union alias name). `collectA`
// fills `rlElemName` with the distinct names; `emitModule` resolves the parallel
// heap indices (`rlElemHeap` = the struct's heap idx / `uBoxIdx`; `rlBackIdx` =
// its `(array (mut (ref null $elem)))` backing; `rlWrapIdx` = its `{backing,len,
// cap}` wrapper). `rlElemKind[s]` is `1` (struct element) or `2` (union box).
// Every site that assumed the singletons resolves a SLOT from the receiver's
// element type-name (`refListSlotOfExpr`) and consults the table at that slot.
let rlElemName: string[] = []
let rlElemHeap: i32[] = []
let rlBackIdx: i32[] = []
let rlWrapIdx: i32[] = []
let rlElemKindTbl: i32[] = []

// â”€â”€ string-keyed map table (G8: `{[string]: i32}` open-addressing hash map) â”€â”€â”€â”€
// A string-keyed map `{[string]: i32}` lowers to a REAL ordered open-addressing
// hash map (mirroring the host's `compiler/builtins/maps.ts`), a 5-field WasmGC
// struct `MAP = { keys, vals, index, count, size }` where
//   â€¢ `keys` is a growable list of STRING refs â€” the wrapper `{ backing: (ref
//     $mkArr), len, cap }` over a backing `(array (mut (ref null $aTypeIdx)))`
//     (a string IS the raw `(array i32)` at `aTypeIdx`, so a keys element is a
//     nullable ref to that array); its wrapper heap-type index is `mkListIdx`,
//     its backing `mkArrIdx`. Holds the INSERTION-ORDERED entry keys.
//   â€¢ `vals` is the EXISTING growable i32 list (`lTypeIdx` over `aTypeIdx`) â€” the
//     insertion-ordered entry values; the checker's map value type is always i32.
//   â€¢ `index` is a raw i32 array `(ref $aTypeIdx)` of hash slots â†’ entry-position
//     + 1 (0 = empty). Initial capacity 8, doubled on load factor 1/2.
//   â€¢ `count` = entries appended; `size` = live entry count. (No delete in the op
//     set, so count == size always; both kept for forward-compatibility â€” a `live`
//     tombstone array can be added later â€” and to drive the resize threshold.)
// The map struct's heap-type index is `mStructIdx`. Operations hash the key
// (FNV-1a, `emitMapHashOf`) into `index` and LINEAR-PROBE (`emitMapProbe`) to a
// free-or-matching slot, comparing keys with the G6 element-wise string `==`: set
// overwrites `vals[entry-1]` on a hit else appends an ordered entry + links the
// index slot + bumps count/size + resizes (`emitMapResize`); get/`??` returns
// `vals[entry-1]` or the default; `.has`/`in` returns 1/0. DELETE/tombstones are
// DEFERRED (the checker's op set has none). A map forces `aUsed`+`lUsed` (the vals
// list + the string backing) plus these three dedicated types.
let mUsed: boolean = false
let mkArrIdx: i32 = 0
let mkListIdx: i32 = 0
let mStructIdx: i32 = 0
// `slUsed` is set by `collectA` when a `string[]` struct/union-variant field appears.
// A `string[]` reuses the SAME string-ref list types as the map's keys list (the
// `{ backing: (ref $mkArrIdx), len, cap }` wrapper over a `(ref null $aTypeIdx)`
// backing) â€” so the keys backing + wrapper types are emitted whenever `slUsed || mUsed`,
// while the map STRUCT (`mStructIdx`) stays gated on `mUsed` alone. `string[]` fields
// thus need no new heap type; they share `mkArrIdx`/`mkListIdx`.
let slUsed: boolean = false

// The kind an EMPTY `[]` literal constructs, set by the binding site (a `let`/global
// whose declared type is a ref array `S[]`/`N[]`) just before its initializer is
// lowered: `0` = i32 list (the default), `1` = struct-ref list, `2` = union-ref list.
// `emitArr` consults this ONLY for an empty literal (a non-empty literal's kind comes
// from its elements). Saved/restored is unnecessary â€” it is overwritten at each binding
// and only read by the immediately-following empty-literal lowering.
let pendingListKind: i32 = 0

// The ref-list TABLE SLOT an empty `[]` ref-list literal constructs as, set by the
// binding/field/argument site alongside `pendingListKind` (1/2) just before the empty
// literal is lowered. Carries WHICH distinct element type (`Tok[]` vs `Diag[]` vs
// `Node[]`) the empty list must build â€” `pendingListKind` alone only says struct-vs-union.
// Like `pendingListKind`, overwritten at each use, read by the immediately-following
// empty-literal lowering; defaults to slot 0.
let pendingListSlot: i32 = 0

// The struct-table index an object literal MUST construct as, set by the binding /
// argument site just before the literal is lowered, or `-1` for "infer from fields".
// `emitObj` consults this to OVERRIDE the field-name match (`structIndexOfObj`): a
// literal passed as a struct-typed call argument must be the CALLEE PARAMETER's struct
// type, not whichever declared struct happens to match its field names first â€” those
// differ when two structs share a field-name set (e.g. the natural `parseExpr(p)` /
// `parseStmt(p)` recursive-descent shape where every parser-state struct looks alike).
// Like `pendingListKind`, it is overwritten at each use and read by the immediately-
// following literal lowering; `emitObj` clears it back to `-1` once consumed so a NESTED
// literal does not inherit the outer hint.
let pendingStructIdx: i32 = 0 - 1

// â”€â”€ discriminated-union table (G1: struct unions + `is`-narrowing) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// A program may declare ONE union alias `type N = A | B | â€¦` (a `UnionDecl`) whose
// members are struct `type`s (each a `TypeDecl`). When a union IS declared, the
// emitter switches off the single-struct path above and instead lowers, mirroring
// `toWasm.ts`'s boxed-union encoding (`docs/unions.md` Â§boxed tagged struct):
//
//   â€¢ the UNION BOX `{ tag: i32, value: anyref }` â€” a 2-field GC struct (tag
//     immutable, value immutable `anyref`). A union VALUE is one of these. Its
//     heap-type index is `uBoxIdx`.
//   â€¢ one VARIANT STRUCT per member â€” a GC struct of the member's i32 fields in
//     DECLARATION order (NOT sorted: this emitter owns BOTH construction and
//     access, so a self-consistent order is sufficient and avoids a separate
//     sorted payload-box type). The i-th variant struct's heap-type index is
//     `uVarIdx + i`.
//
// Construction of variant A: `struct.new $box (i32.const tagOf(A)) (struct.new $A
// <fieldsâ€¦>)` â€” the variant payload boxed into the `anyref` slot. `n is A` reads
// the box tag (`struct.get $box 0`) and `i32.eq tagOf(A)`. A narrowed field read
// `n.f` (inside `if n is A`) is `struct.get $A <fieldIdx> (ref.cast (ref $A)
// (struct.get $box 1 n))` â€” recover the payload from `anyref`, cast to the
// variant, read the field. Tags are assigned by SORTED structural signature
// (sorted field-name list), matching `toWasm.ts`'s `variantKey` ordering so the
// representation is faithful; since there is no cross-module value flow here, any
// stable order would also be self-consistent.
//
// `uVariants` holds the variant struct NAMES across ALL declared unions, flattened in
// source (declaration) order, which is ALSO the heap-type order (`uVarIdx + i`).
// `uTags[i]` is the GLOBALLY-UNIQUE tag of the i-th variant (ranked across every
// variant of every union, so a single tag compare discriminates a variant regardless of
// which union it belongs to). The variant structs' fields live in the flat struct table
// below.
//
// MULTIPLE UNIONS â€” a per-union interning TABLE (mirroring the multi-struct `sNames`
// table and the multi-ref-list `rlElemName` table): `unNames[u]` is the u-th declared
// union's alias name; its variants occupy the contiguous slice `uVariants[unVarStart[u]
// .. unVarStart[u] + unVarCount[u]]`. All unions SHARE one box heap type (`uBoxIdx`) â€”
// the box `{ tag: i32, value: anyref }` is structurally identical for every union, and
// globally-unique tags make narrowing unambiguous â€” so only the union-NAME identity
// (for `isUName`, ref-lists-of-union interning, and param/return/local valtypes) needs
// the table; construction / `is`-narrowing / variant-field reads already key off the
// global variant index. `uDeclared` means "at least one union is declared".
let uDeclared: boolean = false
let unNames: string[] = []
let unVarStart: i32[] = []
let unVarCount: i32[] = []
let uVariants: string[] = []
let uTags: i32[] = []
let uBoxIdx: i32 = 0
let uVarIdx: i32 = 0

// â”€â”€ flat multi-struct field table (union variant structs) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Parallel to `uVariants`: variant struct `i` owns the field names
// `uFieldNames[uFieldStart[i] .. uFieldStart[i] + uFieldCount[i]]`, all i32, in
// declaration order (= wasm struct field index). A flat backing store sidesteps a
// `string[][]` (which the codebase avoids). Built by `collectU`.
let uFieldNames: string[] = []
let uFieldStart: i32[] = []
let uFieldCount: i32[] = []
// Parallel to `uFieldNames`: each variant field's wasm-type code (`0` = i32/boolean,
// `3` = string). A string variant field lowers to a non-null `(ref $aTypeIdx)`.
let uFieldTypes: i32[] = []
// Parallel to `uFieldTypes`: a ref-list variant field's element type-NAME, "" otherwise.
let uFieldElemName: string[] = []

// â”€â”€ active `is`-narrowing scope â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// When emitting the THEN-branch of `if n is A { â€¦ }`, the union-typed identifier
// `n` is narrowed to variant `A`, so a field read `n.f` in that branch lowers to
// the downcast. The active narrowings are a STACK (parallel `narrowNames` /
// `narrowVariants`): nested guards over DISTINCT union locals (`if ta is TyPrim { if
// tb is TyPrim { â€¦ ta.primName â€¦ tb.primName â€¦ } }`, the `sameNumeric` shape) each
// push a binding, so BOTH `ta` and `tb` stay narrowed in the inner branch â€” a single
// slot would lose the outer one. A branch saves the stack LENGTH and truncates back
// on exit, so nesting + the else-branch see the right scope. `narrowVariantFor`
// resolves a receiver name to its INNERMOST active variant (shadowing-correct).
// `narrowTop` is the logical stack DEPTH: only `narrowNames[0 .. narrowTop-1]` are
// active. Entries are appended on push; on branch exit the depth is rewound (the arrays
// keep their slots â€” no `.pop()`, so no global-list-pop self-host dependency). A push
// past the current length appends; a push within reuses/overwrites the slot.
let narrowNames: string[] = []
let narrowVariants: string[] = []
let narrowTop: i32 = 0

// The variant a union local `name` is narrowed to in the current scope (the innermost
// active binding within `narrowTop`), or "" if `name` is not currently narrowed.
function narrowVariantFor(name: string): string {
  let i = narrowTop - 1
  while i >= 0 {
    if narrowNames[i] == name { return narrowVariants[i] }
    i = i - 1
  }
  ""
}

// Push an active narrowing `name â†’ variant`, growing the stack arrays if needed. Returns
// the new depth.
function pushNarrow(name: string, variant: string): i32 {
  if narrowTop < narrowNames.length {
    narrowNames[narrowTop] = name
    narrowVariants[narrowTop] = variant
  } else {
    narrowNames.push(name)
    narrowVariants.push(variant)
  }
  narrowTop = narrowTop + 1
  narrowTop
}

// Append the declared-local name `name` to `localNames` as a FRESH slot (one wasm
// local PER lexical binding â€” no dedupe by name, so two same-named `let`s in disjoint
// branches get DISTINCT slots, hence distinct valtypes). `structIdx` is the local's
// struct table index when it is a struct ref (`isRef == 1`), else `-1`. Returns the new
// slot's POSITION in `localNames` (its wasm index is `paramCount + position`).
function addLocalName(name: string, isRef: i32, structIdx: i32): i32 {
  let pos = localNames.length
  localNames.push(name)
  localIsRef.push(isRef)
  localStructIdx.push(structIdx)
  pos
}

// Recursively collect the declared-local names of the block at `blockIx` into
// `localNames`, descending into `if` then/else branches (wasm locals span the whole
// function, so a local declared inside a branch still needs a slot). Each declared
// local's init type is validated as i32-compatible here, so a non-i32 local fails
// loudly BEFORE any bytes are emitted. Returns 0, or -1 (via `emitFail`) on a
// non-block node, an out-of-scope statement (e.g. a loop), or a non-i32 local.
function collectLocals(blockIx: i32, fnIx: i32): i32 {
  let b = P.nodes[blockIx]
  if b is Block {
    // Enter this block's lexical scope: bindings appended below are live (and resolve
    // a same-named init expr to the RIGHT slot) only within it, and are dropped on exit.
    scopePush()
    let stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      let s = P.nodes[stmts[i]]
      if s is LetDecl {
        // Classify the init type BEFORE binding the name, then allocate a fresh slot and
        // bind `name â†’ slot` so a LATER reference (or a shadowing inner `let`) resolves to
        // THIS slot. `slot` is the new slot's declared-local position.
        let slot = 0 - 1
        if letIsMap(stmts[i], fnIx) {
          slot = addLocalName(s.letName, 6, 0 - 1)
        } else if letIsStringArray(stmts[i], fnIx) {
          slot = addLocalName(s.letName, 7, 0 - 1)
        } else if letIsRefArray(stmts[i], fnIx) {
          slot = addLocalName(s.letName, 5, letRefListSlot(stmts[i], fnIx))
        } else if letIsUnion(stmts[i], fnIx) {
          slot = addLocalName(s.letName, 4, 0 - 1)
        } else if letIsStruct(stmts[i], fnIx) {
          slot = addLocalName(s.letName, 1, structIndexOfLet(stmts[i], fnIx))
        } else if letIsArray(stmts[i], fnIx) {
          slot = addLocalName(s.letName, 2, 0 - 1)
        } else if letIsString(stmts[i], fnIx) {
          slot = addLocalName(s.letName, 3, 0 - 1)
        } else {
          if checkLocalI32(stmts[i]) < 0 { scopePop() return 0 - 1 }
          slot = addLocalName(s.letName, 0, 0 - 1)
        }
        scopeBind(s.letName, slot)
      } else if s is IfStmt {
        if collectLocalsIf(stmts[i], fnIx) < 0 { scopePop() return 0 - 1 }
      } else if s is WhileStmt {
        // Wasm locals are function-scoped, so collect locals from the while body too.
        if collectLocals(s.whileBody, fnIx) < 0 { scopePop() return 0 - 1 }
      }
      i = i + 1
    }
    scopePop()
    return 0
  }
  emitFail("emitProgram: function has no block body")
}

// Collect the declared locals of the `IfStmt` at `ifIx`: its then-branch block, plus
// its else, which is either a `Block` (a plain `else { â€¦ }`) or another `IfStmt`
// (an `else if â€¦`). The `else if` case recurses through THIS function, so an
// arbitrarily long `if / else if / else if / â€¦ / else` chain has EVERY arm walked â€”
// not just the first nested level. (Mirrors how `emitStmt` re-enters each arm via
// `emitStmts`/`emitStmt`, so the slots `collectLocals` allocates match the `let`s
// `emitStmt` stores into, at any nesting depth.) Returns 0, or -1 (via `emitFail`).
function collectLocalsIf(ifIx: i32, fnIx: i32): i32 {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    // Narrow `n` to its variant across the THEN-branch (mirroring `emitStmt`), so a
    // `let x = n.arrField` over a narrowed union-variant ARRAY field is classified as
    // an array local here â€” `exprArray`/`memFieldTypeCode` resolve the variant field
    // type only while narrowing is active. Save/restore so the else-branch + nesting
    // are unaffected.
    let savedTop = narrowTop
    let narrowed = setNarrowFromCond(s.ifCond, fnIx)
    let trc = collectLocals(s.ifThen, fnIx)
    if narrowed {
      restoreNarrow(savedTop)
    }
    if trc < 0 { return 0 - 1 }
    if s.ifElse >= 0 {
      let els = P.nodes[s.ifElse]
      if els is Block {
        if collectLocals(s.ifElse, fnIx) < 0 { return 0 - 1 }
      } else if els is IfStmt {
        // `else if â€¦` â€” walk the nested if (and its own else chain) recursively.
        if collectLocalsIf(s.ifElse, fnIx) < 0 { return 0 - 1 }
      }
    }
    return 0
  }
  emitFail("emitProgram: collectLocalsIf: not an if statement")
}

// Validate the `LetDecl` at `letIx`: its initializer must exist and be an i32 value
// (this slice has i32 locals only). A missing init, or an init whose type annotation
// names a non-i32 type, fails loudly. Without a per-expr type checker the init's
// VALUE-type is approximated: a `let x: T = â€¦` annotation must be `i32` if present;
// init expressions outside the i32 vocabulary (string/char/bool/float literals)
// fail loudly. Returns 0, or -1 (via `emitFail`).
function checkLocalI32(letIx: i32): i32 {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letInit < 0 {
      return emitFail("emitProgram: local declaration needs an initializer")
    }
    if d.letType >= 0 {
      let ty = P.nodes[d.letType]
      if ty is TypeRef {
        // `boolean` rides in an i32 (0/1), so a `boolean` local is the SAME i32 slot.
        if ty.tyName != "i32" {
          if ty.tyName != "boolean" {
            return emitFail("emitProgram: only i32 locals are supported")
          }
        }
      } else {
        return emitFail("emitProgram: local type is not a type name")
      }
    }
    return checkExprI32(d.letInit)
  }
  emitFail("emitProgram: not a local declaration")
}

// Reject init expressions that cannot yield an i32: a string literal, or a float
// `NumLit` whose lexeme has a `.`, fails loudly. `BoolLit` (true=1 / false=0) and
// `CharLit` (a code point) ARE i32 values â€” they ride in an i32 â€” so they pass. i32
// literals, identifiers, parens, unary/binary arithmetic and calls are all i32 in
// this slice, so they pass too (the per-node emitters re-check operand shapes).
// Returns 0, or -1.
function checkExprI32(exprIx: i32): i32 {
  if exprIx < 0 {
    return emitFail("emitProgram: missing local initializer expression")
  }
  let e = P.nodes[exprIx]
  if e is StrLit {
    return emitFail("emitProgram: only i32 locals are supported")
  }
  if e is NumLit {
    // A float literal carries a "." in its lexeme â€” out of scope (i32 only).
    let i = 0
    while i < e.numText.length {
      if e.numText[i] == '.' {
        return emitFail("emitProgram: only i32 locals are supported")
      }
      i = i + 1
    }
    return 0
  }
  0
}

// Rebuild `localNames` for the function at `fnIx`: clear it, then collect every
// declared-local name in the body (validating each as i32). Returns 0 on success,
// or -1 (via `emitFail`) on any unsupported local. Must run before lowering the
// body so identifier resolution and the locals vector see the full set.
function buildLocals(fnIx: i32): i32 {
  localNames = []
  localIsRef = []
  localStructIdx = []
  // Reset the lexical scope stack per function. `collectLocals` pushes/pops frames as
  // it walks (leaving it balanced/empty), then the emit pass rebuilds it in lockstep.
  scopeNames = []
  scopeSlots = []
  scopeFrames = []
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    return collectLocals(fn.fnBody, fnIx)
  }
  emitFail("emitProgram: not a function declaration")
}

// True if the statement at `stmtIx` is a `recv.push(x)` member-call (the `Call` whose
// `callFn` is a `Member` with property `push`) whose RECEIVER's list kind matches
// `kind` â€” `0` selects an i32-list push, `1` a ref-list push (G7-ref), `2` a string-list
// push (`string[]`). Used to detect which inline-push scratch locals a function needs;
// the three kinds get DISTINCT scratch frames so a function may push onto any mix.
function stmtIsPushKind(stmtIx: i32, fnIx: i32, kind: i32): boolean {
  let s = P.nodes[stmtIx]
  if s is Call {
    let callee = P.nodes[s.callFn]
    if callee is Member {
      if callee.memProp == "push" {
        let isRef = exprRefArray(callee.memObj, fnIx)
        let isStr = exprStringArray(callee.memObj, fnIx)
        if kind == 1 { return isRef }
        if kind == 2 { return isStr }
        return !isRef && !isStr
      }
    }
  }
  false
}

// True if `callIx` is a `recv.pop()` whose receiver is a struct-FIELD / global-field
// array read (a `Member`, e.g. `T.scopes.pop()`) of list kind `kind` (`0` i32-list, `1`
// ref-list, `2` string-list). A bare-LOCAL pop needs NO scratch (it references the local
// in place), so it is NOT counted â€” only a Member receiver, which must be materialized
// into the push frame's `recvRef` scratch slot. Lets a `.pop`-on-field function reserve
// the same scratch frame a `.push`-on-field one does.
function callIsMemberPopKind(callIx: i32, fnIx: i32, kind: i32): boolean {
  let c = P.nodes[callIx]
  if c is Call {
    let callee = P.nodes[c.callFn]
    if callee is Member {
      if callee.memProp == "pop" {
        let recv = P.nodes[callee.memObj]
        // A struct-FIELD / global-field Member receiver, OR a bare module-GLOBAL list
        // ident â€” both materialize the wrapper ref into the `recvRef` scratch slot, so
        // both need the push frame reserved. A bare LOCAL pop references the local in
        // place and needs no scratch, so it is NOT counted.
        let needsScratch = false
        if recv is Member {
          needsScratch = true
        } else if recv is Ident {
          if localIndexOf(fnIx, recv.identName) < 0 {
            if globalIndexOf(recv.identName) >= 0 { needsScratch = true }
          }
        }
        if needsScratch {
          let isRef = exprRefArray(callee.memObj, fnIx)
          let isStr = exprStringArray(callee.memObj, fnIx)
          if kind == 1 { return isRef }
          if kind == 2 { return isStr }
          return !isRef && !isStr
        }
      }
    }
  }
  false
}

// True if any expression at `exprIx` (or a sub-expression) is a Member-receiver `.pop`
// of `kind` â€” a `.pop` appears in VALUE position (`let x = T.scopes.pop()`), so the
// reservation walk must descend expressions, not just statement receivers.
function exprHasMemberPopKind(exprIx: i32, fnIx: i32, kind: i32): boolean {
  if exprIx < 0 { return false }
  let e = P.nodes[exprIx]
  if e is Call {
    if callIsMemberPopKind(exprIx, fnIx, kind) { return true }
    let args = e.callArgs
    let i = 0
    while i < args.length {
      if exprHasMemberPopKind(args[i], fnIx, kind) { return true }
      i = i + 1
    }
    return false
  }
  if e is BinExpr {
    if exprHasMemberPopKind(e.binLeft, fnIx, kind) { return true }
    return exprHasMemberPopKind(e.binRight, fnIx, kind)
  }
  if e is Member { return exprHasMemberPopKind(e.memObj, fnIx, kind) }
  if e is Index {
    if exprHasMemberPopKind(e.idxArr, fnIx, kind) { return true }
    return exprHasMemberPopKind(e.idxIndex, fnIx, kind)
  }
  if e is Unary { return exprHasMemberPopKind(e.unArg, fnIx, kind) }
  if e is Paren { return exprHasMemberPopKind(e.parInner, fnIx, kind) }
  false
}

// True if the block at `blockIx` (descending into if/else + while, the scopes
// `collectLocals` walks) contains a Member-receiver `.pop` of `kind` in any statement or
// let-init / return / while-cond expression.
function blockHasMemberPopKind(blockIx: i32, fnIx: i32, kind: i32): boolean {
  let b = P.nodes[blockIx]
  if b is Block {
    let stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      let s = P.nodes[stmts[i]]
      if s is LetDecl {
        if exprHasMemberPopKind(s.letInit, fnIx, kind) { return true }
      } else if s is RetStmt {
        if exprHasMemberPopKind(s.retArg, fnIx, kind) { return true }
      } else if s is BinExpr {
        if exprHasMemberPopKind(stmts[i], fnIx, kind) { return true }
      } else if s is Call {
        if exprHasMemberPopKind(stmts[i], fnIx, kind) { return true }
      } else if s is IfStmt {
        if ifChainHasMemberPopKind(stmts[i], fnIx, kind) { return true }
      } else if s is WhileStmt {
        if exprHasMemberPopKind(s.whileCond, fnIx, kind) { return true }
        if blockHasMemberPopKind(s.whileBody, fnIx, kind) { return true }
      }
      i = i + 1
    }
  }
  false
}

// True if any arm of the `if` / `else if` chain at `ifIx` contains a Member-receiver
// `.pop` of `kind` (then-branch, `else` block, or recursively a chained `else if`).
function ifChainHasMemberPopKind(ifIx: i32, fnIx: i32, kind: i32): boolean {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    if blockHasMemberPopKind(s.ifThen, fnIx, kind) { return true }
    if s.ifElse >= 0 {
      let els = P.nodes[s.ifElse]
      if els is Block {
        if blockHasMemberPopKind(s.ifElse, fnIx, kind) { return true }
      } else if els is IfStmt {
        if ifChainHasMemberPopKind(s.ifElse, fnIx, kind) { return true }
      }
    }
  }
  false
}

// True if the block at `blockIx` (descending into `if` branches and `while` bodies, the
// same scopes `collectLocals` walks) contains a `.push` of kind `wantRef`. A function
// with such a push reserves the matching three scratch locals after its declared locals.
function blockHasPushKind(blockIx: i32, fnIx: i32, kind: i32): boolean {
  let b = P.nodes[blockIx]
  if b is Block {
    let stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      if stmtIsPushKind(stmts[i], fnIx, kind) { return true }
      let s = P.nodes[stmts[i]]
      if s is IfStmt {
        if ifChainHasPushKind(stmts[i], fnIx, kind) { return true }
      } else if s is WhileStmt {
        if blockHasPushKind(s.whileBody, fnIx, kind) { return true }
      }
      i = i + 1
    }
  }
  false
}

// True if the `if` / `else if` chain at `ifIx` contains a `.push` of `kind` in ANY arm â€”
// the then-branch, an `else` block, OR (RECURSIVELY) a chained `else if`. Mirrors
// `collectLocalsIf`'s recursion so a push buried under several `else if` arms (the
// `parseProgram` / `parseStmt` recursive-descent dispatch shape) is detected, not just
// the first one level (the prior hand-unrolled form missed 2+-deep chains).
function ifChainHasPushKind(ifIx: i32, fnIx: i32, kind: i32): boolean {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    if blockHasPushKind(s.ifThen, fnIx, kind) { return true }
    if s.ifElse >= 0 {
      let els = P.nodes[s.ifElse]
      if els is Block {
        if blockHasPushKind(s.ifElse, fnIx, kind) { return true }
      } else if els is IfStmt {
        if ifChainHasPushKind(s.ifElse, fnIx, kind) { return true }
      }
    }
  }
  false
}

// Append the ref-list table SLOT of a ref `.push` receiver to `fnRefPushSlots` if not
// already present (so each DISTINCT pushed element type gets its own typed scratch frame).
function recordRefPushSlot(slot: i32): i32 {
  let i = 0
  while i < fnRefPushSlots.length {
    if fnRefPushSlots[i] == slot { return 0 }
    i = i + 1
  }
  fnRefPushSlots.push(slot)
  0
}

// Walk the block at `blockIx` (descending into `if` branches + `while` bodies, the scopes
// `collectLocals` walks) and collect every DISTINCT ref-list `.push` receiver slot into
// `fnRefPushSlots`. Parallel to `blockHasPushKind(..., 1)`, but RECORDING the slot rather
// than just testing presence â€” so a function pushing onto `Tok[]` and `Diag[]` reserves a
// separately-typed scratch frame for each.
function collectRefPushSlots(blockIx: i32, fnIx: i32): i32 {
  let b = P.nodes[blockIx]
  if b is Block {
    let stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      if stmtIsPushKind(stmts[i], fnIx, 1) {
        let s = P.nodes[stmts[i]]
        if s is Call {
          let callee = P.nodes[s.callFn]
          if callee is Member {
            recordRefPushSlot(refListSlotOfExpr(callee.memObj, fnIx))
          }
        }
      }
      let s = P.nodes[stmts[i]]
      if s is IfStmt {
        collectRefPushSlotsIf(stmts[i], fnIx)
      } else if s is WhileStmt {
        collectRefPushSlots(s.whileBody, fnIx)
      }
      i = i + 1
    }
  }
  0
}

// Collect ref-push receiver slots from every arm of the `if` / `else if` chain at `ifIx`
// â€” the then-branch, an `else` block, and (RECURSIVELY) each chained `else if`. Mirrors
// `ifChainHasPushKind`'s recursion so a push under 2+ `else if` arms is recorded.
function collectRefPushSlotsIf(ifIx: i32, fnIx: i32): i32 {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    collectRefPushSlots(s.ifThen, fnIx)
    if s.ifElse >= 0 {
      let els = P.nodes[s.ifElse]
      if els is Block {
        collectRefPushSlots(s.ifElse, fnIx)
      } else if els is IfStmt {
        collectRefPushSlotsIf(s.ifElse, fnIx)
      }
    }
  }
  0
}

// Record the ref-list table slot of every Member-receiver ref-list `.pop` in expression
// `exprIx` into `fnRefPushSlots` (so its typed scratch frame is reserved) â€” the pop-side
// analogue of `collectRefPushSlots`, descending VALUE positions (a `.pop` is a value).
function collectMemberPopRefSlotsExpr(exprIx: i32, fnIx: i32): i32 {
  if exprIx < 0 { return 0 }
  let e = P.nodes[exprIx]
  if e is Call {
    if callIsMemberPopKind(exprIx, fnIx, 1) {
      let callee = P.nodes[e.callFn]
      if callee is Member {
        recordRefPushSlot(refListSlotOfExpr(callee.memObj, fnIx))
      }
    }
    let args = e.callArgs
    let i = 0
    while i < args.length {
      collectMemberPopRefSlotsExpr(args[i], fnIx)
      i = i + 1
    }
    return 0
  }
  if e is BinExpr {
    collectMemberPopRefSlotsExpr(e.binLeft, fnIx)
    collectMemberPopRefSlotsExpr(e.binRight, fnIx)
    return 0
  }
  if e is Member { return collectMemberPopRefSlotsExpr(e.memObj, fnIx) }
  if e is Index {
    collectMemberPopRefSlotsExpr(e.idxArr, fnIx)
    collectMemberPopRefSlotsExpr(e.idxIndex, fnIx)
    return 0
  }
  if e is Unary { return collectMemberPopRefSlotsExpr(e.unArg, fnIx) }
  if e is Paren { return collectMemberPopRefSlotsExpr(e.parInner, fnIx) }
  0
}

// Walk the block at `blockIx` (if/else + while) collecting Member-receiver ref-list
// `.pop` slots from statements + let-inits / returns / while-conds.
function collectMemberPopRefSlots(blockIx: i32, fnIx: i32): i32 {
  let b = P.nodes[blockIx]
  if b is Block {
    let stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      let s = P.nodes[stmts[i]]
      if s is LetDecl {
        collectMemberPopRefSlotsExpr(s.letInit, fnIx)
      } else if s is RetStmt {
        collectMemberPopRefSlotsExpr(s.retArg, fnIx)
      } else if s is BinExpr {
        collectMemberPopRefSlotsExpr(stmts[i], fnIx)
      } else if s is Call {
        collectMemberPopRefSlotsExpr(stmts[i], fnIx)
      } else if s is IfStmt {
        collectMemberPopRefSlotsIf(stmts[i], fnIx)
      } else if s is WhileStmt {
        collectMemberPopRefSlotsExpr(s.whileCond, fnIx)
        collectMemberPopRefSlots(s.whileBody, fnIx)
      }
      i = i + 1
    }
  }
  0
}

// Collect Member-receiver ref-list `.pop` slots from every arm of the `if` chain.
function collectMemberPopRefSlotsIf(ifIx: i32, fnIx: i32): i32 {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    collectMemberPopRefSlots(s.ifThen, fnIx)
    if s.ifElse >= 0 {
      let els = P.nodes[s.ifElse]
      if els is Block {
        collectMemberPopRefSlots(s.ifElse, fnIx)
      } else if els is IfStmt {
        collectMemberPopRefSlotsIf(s.ifElse, fnIx)
      }
    }
  }
  0
}

// True if the FuncDecl at `fnIx` contains an i32-list `.push` anywhere in its body â€” OR
// a Member-receiver i32-list `.pop` (which reuses the same scratch frame's `recvRef`).
function fnHasPush(fnIx: i32): boolean {
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    if blockHasPushKind(fn.fnBody, fnIx, 0) { return true }
    return blockHasMemberPopKind(fn.fnBody, fnIx, 0)
  }
  false
}

// True if the FuncDecl at `fnIx` contains a ref-list `.push` anywhere â€” OR a
// Member-receiver ref-list `.pop` (which reuses the ref-push frame's `recvRef`).
function fnHasRefPush(fnIx: i32): boolean {
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    if blockHasPushKind(fn.fnBody, fnIx, 1) { return true }
    return blockHasMemberPopKind(fn.fnBody, fnIx, 1)
  }
  false
}

// True if the FuncDecl at `fnIx` contains a string-list (`string[]`) `.push` â€” OR a
// Member-receiver string-list `.pop`.
function fnHasStrPush(fnIx: i32): boolean {
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    if blockHasPushKind(fn.fnBody, fnIx, 2) { return true }
    return blockHasMemberPopKind(fn.fnBody, fnIx, 2)
  }
  false
}

// â”€â”€ string-op detection (G6: which functions need the string scratch frame) â”€â”€â”€
// A function reserves the shared string scratch frame iff it uses ANY string `+`,
// string `==`/`!=`, or `.slice` anywhere in an expression â€” so the walk below
// descends through EVERY expression position (return values, let inits, conditions,
// call args, operands, members, indices), unlike the push detection which only
// needs statement-level receivers. `exprIsStrConcat`/`exprIsStrEq`/`exprIsStrSlice`
// each classify a single node; `exprHasStrOp` recurses; `blockHasStrOp` walks
// statements. `exprString` (defined later) resolves operand string-typedness from
// the already-built `localNames`/`localIsRef` (so this runs AFTER `buildLocals`).

// True if `binIx` is a `+` whose operands are strings (string concatenation).
function exprIsStrConcat(binIx: i32, fnIx: i32): boolean {
  let e = P.nodes[binIx]
  if e is BinExpr {
    if e.binOp == "+" {
      return exprString(e.binLeft, fnIx) || exprString(e.binRight, fnIx)
    }
  }
  false
}

// True if `binIx` is `==`/`!=` whose operands are strings (string value-equality).
function exprIsStrEq(binIx: i32, fnIx: i32): boolean {
  let e = P.nodes[binIx]
  if e is BinExpr {
    if e.binOp == "==" || e.binOp == "!=" {
      return exprString(e.binLeft, fnIx) || exprString(e.binRight, fnIx)
    }
  }
  false
}

// True if `callIx` is a `recv.slice(start, end)` over a STRING receiver.
function exprIsStrSlice(callIx: i32, fnIx: i32): boolean {
  let c = P.nodes[callIx]
  if c is Call {
    let callee = P.nodes[c.callFn]
    if callee is Member {
      if callee.memProp == "slice" {
        return exprString(callee.memObj, fnIx)
      }
    }
  }
  false
}

// True if the expression at `exprIx` (or any sub-expression) is a string `+`,
// string `==`/`!=`, or string `.slice`.
function exprHasStrOp(exprIx: i32, fnIx: i32): boolean {
  if exprIx < 0 { return false }
  let e = P.nodes[exprIx]
  if e is BinExpr {
    if exprIsStrConcat(exprIx, fnIx) { return true }
    if exprIsStrEq(exprIx, fnIx) { return true }
    if exprHasStrOp(e.binLeft, fnIx) { return true }
    return exprHasStrOp(e.binRight, fnIx)
  }
  if e is Call {
    if exprIsStrSlice(exprIx, fnIx) { return true }
    if exprHasStrOp(e.callFn, fnIx) { return true }
    let args = e.callArgs
    let i = 0
    while i < args.length {
      if exprHasStrOp(args[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  if e is Member { return exprHasStrOp(e.memObj, fnIx) }
  if e is Index {
    if exprHasStrOp(e.idxArr, fnIx) { return true }
    return exprHasStrOp(e.idxIndex, fnIx)
  }
  if e is Unary { return exprHasStrOp(e.unArg, fnIx) }
  if e is Paren { return exprHasStrOp(e.parInner, fnIx) }
  if e is IsExpr { return exprHasStrOp(e.isObj, fnIx) }
  if e is ObjLit {
    let fields = e.objFields
    let i = 0
    while i < fields.length {
      let f = P.nodes[fields[i]]
      if f is FieldInit {
        if exprHasStrOp(f.fiValue, fnIx) { return true }
      }
      i = i + 1
    }
    return false
  }
  if e is ArrayLit {
    let elems = e.arrElems
    let i = 0
    while i < elems.length {
      if exprHasStrOp(elems[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  false
}

// True if any statement in the block at `blockIx` (descending into if/else branches
// and while bodies, the scopes `collectLocals` walks) contains a string op.
function blockHasStrOp(blockIx: i32, fnIx: i32): boolean {
  let b = P.nodes[blockIx]
  if b is Block {
    let stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      let s = P.nodes[stmts[i]]
      if s is LetDecl {
        if exprHasStrOp(s.letInit, fnIx) { return true }
      } else if s is RetStmt {
        if exprHasStrOp(s.retArg, fnIx) { return true }
      } else if s is BinExpr {
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is Call {
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is IfStmt {
        if ifChainHasStrOp(stmts[i], fnIx) { return true }
      } else if s is WhileStmt {
        if exprHasStrOp(s.whileCond, fnIx) { return true }
        if blockHasStrOp(s.whileBody, fnIx) { return true }
      }
      i = i + 1
    }
  }
  false
}

// True if any arm of the `if` / `else if` chain at `ifIx` contains a string op â€” its
// condition, then-branch, `else` block, OR (RECURSIVELY) a chained `else if`. Mirrors
// `ifChainHasPushKind`: walks the WHOLE else-if chain, not just one level.
function ifChainHasStrOp(ifIx: i32, fnIx: i32): boolean {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    if exprHasStrOp(s.ifCond, fnIx) { return true }
    // Narrow across the THEN-branch (mirroring `emitStmt`/`collectLocalsIf`) so a string
    // op over a NARROWED variant field (`if n is A { â€¦ n.strField == x â€¦ }`, and nested
    // guards over distinct locals) is detected â€” `exprString` resolves a variant field's
    // string type only while the receiver's narrowing is active. Save/restore the depth.
    let savedTop = narrowTop
    let narrowed = setNarrowFromCond(s.ifCond, fnIx)
    let hit = blockHasStrOp(s.ifThen, fnIx)
    if narrowed { restoreNarrow(savedTop) }
    if hit { return true }
    if s.ifElse >= 0 {
      let els = P.nodes[s.ifElse]
      if els is Block {
        if blockHasStrOp(s.ifElse, fnIx) { return true }
      } else if els is IfStmt {
        if ifChainHasStrOp(s.ifElse, fnIx) { return true }
      }
    }
  }
  false
}

// True if the FuncDecl at `fnIx` uses any string op (`+`/`==`/`!=`/`.slice`) â€” so it
// reserves the shared string scratch frame.
function fnHasStrOp(fnIx: i32): boolean {
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    return blockHasStrOp(fn.fnBody, fnIx)
  }
  false
}

// The declared-local POSITION of `name`: the innermost live lexical binding if the
// scope stack has one (so a same-named binding in a disjoint/inner block resolves to
// ITS own slot, with its own valtype), else the first `localNames` slot of that name
// as a safety net (used when no scope frame is active, e.g. the `fnUses*` detection
// pass, where any same-named slot's type suffices). -1 if `name` is not a local.
function declaredSlotOf(name: string): i32 {
  let scoped = scopeSlotOf(name)
  if scoped >= 0 {
    return scoped
  }
  let pos = 0
  while pos < localNames.length {
    if localNames[pos] == name {
      return pos
    }
    pos = pos + 1
  }
  0 - 1
}

// The wasm local index of declared local `name`, or -1 if it is not a declared
// local. Declared locals sit AFTER the params, so the slot is `paramCount + pos`
// where `pos` is the name's resolved declared-local position (`declaredSlotOf`).
function declaredIndexOf(fnIx: i32, name: string): i32 {
  if fnIx < 0 { return 0 - 1 }   // module-scope initializer (no enclosing function)
  let pos = declaredSlotOf(name)
  if pos < 0 {
    return 0 - 1
  }
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    return fn.fnParams.length + pos
  }
  0 - 1
}

// Resolve an identifier `name` to its wasm local index for function `fnIx`: a param
// first (locals 0..p-1), else a declared local (locals p..). Returns -1 if neither.
function localIndexOf(fnIx: i32, name: string): i32 {
  let pIx = paramIndexOf(fnIx, name)
  if pIx >= 0 {
    return pIx
  }
  declaredIndexOf(fnIx, name)
}

// Map a binary operator lexeme to its i32 wasm opcode, or -1 if unsupported. The
// three arithmetic ops and the six signed i32 comparisons are recognized; anything
// else (`/`, `%`, `=`, logical `&&`/`||`, â€¦) falls through to -1 so the caller
// fails loudly rather than emitting a wrong opcode. Comparisons leave a 0/1 i32 on
// the stack â€” exactly what a wasm `if` condition consumes.
//   `+`  -> i32.add  (0x6a)   `-`  -> i32.sub  (0x6b)   `*`  -> i32.mul  (0x6c)
//   `==` -> i32.eq   (0x46)   `!=` -> i32.ne   (0x47)
//   `<`  -> i32.lt_s (0x48)   `>`  -> i32.gt_s (0x4a)
//   `<=` -> i32.le_s (0x4c)   `>=` -> i32.ge_s (0x4e)
function binOpcode(op: string): i32 {
  if op == "+" { return 106 }   // 0x6a i32.add
  if op == "-" { return 107 }   // 0x6b i32.sub
  if op == "*" { return 108 }   // 0x6c i32.mul
  if op == "/" { return 109 }   // 0x6d i32.div_s (signed; VL `i32` division is signed)
  if op == "%" { return 111 }   // 0x6f i32.rem_s (signed remainder)
  if op == "==" { return 70 }   // 0x46 i32.eq
  if op == "!=" { return 71 }   // 0x47 i32.ne
  if op == "<" { return 72 }    // 0x48 i32.lt_s
  if op == ">" { return 74 }    // 0x4a i32.gt_s
  if op == "<=" { return 76 }   // 0x4c i32.le_s
  if op == ">=" { return 78 }   // 0x4e i32.ge_s
  // Bitwise / shift (integer-only). VL `i32` is signed, so `>>` is the SIGNED
  // (arithmetic) shift `shr_s` and `>>>` the UNSIGNED (logical) shift `shr_u` â€”
  // the distinction the LEB encoders' `v >>> 7` relies on. Mirrors the host
  // `INT_BINOPS` map in toWasm.ts (`&`->and, `|`->or, `>>`->shr_s, `>>>`->shr_u).
  if op == "&" { return 113 }   // 0x71 i32.and
  if op == "|" { return 114 }   // 0x72 i32.or
  if op == ">>" { return 117 }  // 0x75 i32.shr_s (signed/arithmetic)
  if op == ">>>" { return 118 } // 0x76 i32.shr_u (unsigned/logical)
  0 - 1
}

// Emit the instructions for the returned expression at `exprIx` onto `body`, in
// stack order, resolving identifiers against function `fnIx`'s params. Returns 0
// on success, or calls `emitFail` and returns -1 on any unsupported shape.
//
// Supported operands (any of which may nest as children):
//   NumLit  -> i32.const <value>           (the literal, via parseI32 + slebToArr)
//   Ident   -> local.get <param index>     (a parameter reference)
//   BinExpr -> emit(left), emit(right), <opcode>   (operands first, then the op,
//              the natural wasm post-order stack encoding; arithmetic OR comparison).
//              Logical `&&`/`||` instead lower to a SHORT-CIRCUIT value-typed `if`
//              (blocktype 0x7f): `a && b` â‰¡ if(a){b}else{0}, `a || b` â‰¡ if(a){1}else{b}.
//   Unary   -> negation `-x` as i32.const 0, emit(x), i32.sub; logical `!a` as eqz (0x45)
//   Call    -> emit each arg left-to-right, then `call <funcIndex>` (the callee is
//              an `Ident` resolved through the function-index map; recursion works
//              because the function's own name is mapped before its body is emitted)
//   Paren   -> the inner expression (parentheses carry no runtime instruction)
//
// Node shapes read (all from `compiler/ast.vl`):
//   NumLit  { numText: string }
//   Ident   { identName: string }
//   Unary   { unOp: string, unArg: i32 }
//   BinExpr { binOp: string, binLeft: i32, binRight: i32 }
//   Call    { callFn: i32, callArgs: i32[] }
//   Paren   { parInner: i32 }
// The wasm struct field index of `name` within struct `si` (declaration order), or
// -1 if that struct has no such field.
function sFieldIndex(si: i32, name: string): i32 {
  let start = sFieldStart[si]
  let cnt = sFieldCount[si]
  let j = 0
  while j < cnt {
    if sFieldNames[start + j] == name { return j }
    j = j + 1
  }
  0 - 1
}

// The wasm-type code (`0` i32, `3` string, `4` i32-list, `5` ref-list) of struct `si`'s
// field at field index `fi`.
function sFieldTypeAt(si: i32, fi: i32): i32 {
  sFieldTypes[sFieldStart[si] + fi]
}

// The ref-list element type-NAME of struct `si`'s field `fi` (a code-5 field), "" else.
function sFieldElemNameAt(si: i32, fi: i32): string {
  sFieldElemName[sFieldStart[si] + fi]
}

// The ref-list table SLOT of struct `si`'s ref-list field `fi`, or -1 if not a ref list.
function sFieldRefSlot(si: i32, fi: i32): i32 {
  rlSlotByName(sFieldElemNameAt(si, fi))
}

// Push the STORAGETYPE bytes (NOT the trailing mutability flag) for a struct / variant
// field whose wasm-type `code` is one of `0` i32, `3` string, `4` i32-list, `5` ref-list.
// Each array-typed field stores a non-null REF to the corresponding list wrapper struct
// (`0x64 <heap-type-index>`): `lTypeIdx` for `i32[]`, `rlTypeIdx` for a `T[]`/`N[]` ref
// list â€” exactly the wrappers the map's `keys`/`vals` fields already reference. The
// referenced wrapper types are interned in the SAME rec group (forced present by
// `collectA`), so the forward index resolves. Used by the type-section struct emission.
// For a ref-list field (code 5) `refSlot` is the field's per-element-type table slot
// (its wrapper is `rlWrapIdx[refSlot]`); ignored for other codes. Streams to the
// current target (`curBuf`) â€” the caller binds it at the type-section payload.
function pushFieldStorage(code: i32, refSlot: i32): i32 {
  if code == 3 {
    wU8(100)                   // 0x64 (ref ht) â€” non-null string ref
    wULEB(aTypeIdx)
  } else if code == 4 {
    wU8(100)                   // 0x64 (ref ht) â€” non-null i32-list wrapper ref
    wULEB(lTypeIdx)
  } else if code == 5 {
    wU8(100)                   // 0x64 (ref ht) â€” non-null ref-list wrapper ref
    let s = refSlot
    if s < 0 { s = 0 }
    wULEB(rlWrapIdx[s])        // THIS field's distinct ref-list wrapper
  } else if code == 6 {
    wU8(100)                   // 0x64 (ref ht) â€” non-null string-list wrapper ref
    wULEB(mkListIdx)
  } else {
    wU8(127)                   // 0x7f i32 storagetype
  }
  0
}

// The struct table index whose name is `name`, or -1 if `name` is not a declared
// struct type.
function structIndexByName(name: string): i32 {
  let i = 0
  while i < sNames.length {
    if sNames[i] == name { return i }
    i = i + 1
  }
  0 - 1
}

// The struct table index whose field-name SET matches the object literal at `objIx`
// EXACTLY (same count, every literal field present in the struct), or -1 if no struct
// matches. With distinct field-name sets across structs this disambiguates which
// struct an `{ â€¦ }` literal constructs (the struct analogue of `objVariantName`).
function structIndexOfObj(objIx: i32): i32 {
  let o = P.nodes[objIx]
  if o is ObjLit {
    let nf = o.objFields.length
    let si = 0
    while si < sNames.length {
      if sFieldCount[si] == nf {
        let ok = true
        let k = 0
        while k < nf {
          let f = P.nodes[o.objFields[k]]
          if f is FieldInit {
            if sFieldIndex(si, f.fiName) < 0 { ok = false }
          } else {
            ok = false
          }
          k = k + 1
        }
        if ok { return si }
      }
      si = si + 1
    }
  }
  0 - 1
}

// Find the value-expr index for declared field `fieldName` in the object literal at
// `objIx`, or -1 if the literal does not set that field.
function objFieldVal(objIx: i32, fieldName: string): i32 {
  let o = P.nodes[objIx]
  if o is ObjLit {
    let fields = o.objFields
    let i = 0
    while i < fields.length {
      let f = P.nodes[fields[i]]
      if f is FieldInit {
        if f.fiName == fieldName { return f.fiValue }
      }
      i = i + 1
    }
  }
  0 - 1
}

// Lower an object literal `{ f: v, ... }` onto `body`: resolve WHICH struct the
// literal's field-name set names, push each field's value IN THAT STRUCT'S DECLARED
// FIELD ORDER, then `struct.new $<heapIdx>` (`0xfb 0x00 <heapIdx>`). The literal must
// match exactly one struct's fields (no missing/extra field) â€” else fails loudly.
function emitObj(body: i32[], objIx: i32, fnIx: i32): i32 {
  if !sDeclared {
    return emitFail("emitProgram: object literal but no struct type declared")
  }
  let o = P.nodes[objIx]
  if o is ObjLit {
    // An EXPECTED struct index from the binding/argument site (`pendingStructIdx`) wins
    // over the field-name match: a struct-typed call argument must be the callee
    // parameter's type even when another struct shares its field names. Consume the hint
    // (reset to -1) so a nested literal value falls back to inference.
    let si = pendingStructIdx
    pendingStructIdx = 0 - 1
    if si < 0 {
      si = structIndexOfObj(objIx)
    }
    if si < 0 {
      return emitFail("emitProgram: object literal field count does not match struct")
    }
    let cnt = sFieldCount[si]
    let fi = 0
    while fi < cnt {
      let valIx = objFieldVal(objIx, sFieldNames[sFieldStart[si] + fi])
      if valIx < 0 {
        return emitFail("emitProgram: object literal is missing a struct field")
      }
      if exprStruct(valIx, fnIx) {
        return emitFail("emitProgram: nested struct fields are not supported")
      }
      // A ref-list field (`code 5`: `T[]`/`N[]`) whose value is an EMPTY `[]` literal
      // needs the element kind to build a REF-list (not an i32-list) wrapper â€” the same
      // way a `let xs: T[] = []` annotation threads `pendingListKind`. The element kind
      // is global (union box `2` when a union is declared, else a struct `1`).
      pendingListKind = 0
      pendingListSlot = 0
      let scode = sFieldTypeAt(si, fi)
      if scode == 5 {
        let fslot = sFieldRefSlot(si, fi)
        if fslot < 0 { fslot = 0 }
        pendingListSlot = fslot
        if rlElemKindTbl[fslot] == 2 { pendingListKind = 2 } else { pendingListKind = 1 }
      } else if scode == 6 {
        pendingListKind = 3
      }
      if emitExpr(body, valIx, fnIx) < 0 { return 0 - 1 }
      pendingListKind = 0
      fi = fi + 1
    }
    fbStructNew(sHeapIdx[si])   // 0xfb 0x00 <heap-type index>
    return 0
  }
  emitFail("emitProgram: expected an object literal")
}

// â”€â”€ union value construction + discrimination + narrowing (G1) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

// Lower the VARIANT-PAYLOAD struct for an object literal `{ f: v, â€¦ }` matching union
// variant `vi`: push each field value in the variant's DECLARATION field order, then
// `struct.new $<uVarIdx + vi>`. (No box yet â€” `emitUnionBox` wraps this.)
function emitVariantStruct(body: i32[], objIx: i32, vi: i32, fnIx: i32): i32 {
  let start = uFieldStart[vi]
  let cnt = uFieldCount[vi]
  let fj = 0
  while fj < cnt {
    let valIx = objFieldVal(objIx, uFieldNames[start + fj])
    if valIx < 0 {
      return emitFail("emitProgram: object literal is missing a union-variant field")
    }
    // An empty `[]` literal for a ref-list (code 5) / string-list (code 6) variant field
    // needs its element kind threaded (the same `pendingListKind` an annotated `let`
    // uses): a struct/union ref list (1/2) or a string list (3).
    pendingListKind = 0
    pendingListSlot = 0
    let vcode = variantFieldTypeAt(vi, fj)
    if vcode == 5 {
      let vslot = variantFieldRefSlot(vi, fj)
      if vslot < 0 { vslot = 0 }
      pendingListSlot = vslot
      if rlElemKindTbl[vslot] == 2 { pendingListKind = 2 } else { pendingListKind = 1 }
    } else if vcode == 6 {
      pendingListKind = 3
    }
    if emitExpr(body, valIx, fnIx) < 0 { return 0 - 1 }
    pendingListKind = 0
    fj = fj + 1
  }
  fbStructNew(uVarIdx + vi)   // 0xfb 0x00 <variant struct heap-type index>
  0
}

// Lower an object literal `{ f: v, â€¦ }` BOXED into the declared union onto `body`:
//   struct.new $box (i32.const tagOf(variant)) (struct.new $variant <fieldsâ€¦>)
// i.e. push the variant's global tag, build the variant payload struct, then
// `struct.new $uBoxIdx` to wrap `{ tag, value }`. The literal must match exactly one
// union variant's field-name set, else fails loudly.
function emitUnionBox(body: i32[], objIx: i32, fnIx: i32): i32 {
  let vname = objVariantName(objIx)
  if vname == "" {
    return emitFail("emitProgram: object literal matches no union variant")
  }
  let vi = variantIndexOf(vname)
  // tag first (struct field 0 of the box), then the boxed payload (field 1).
  fbI32Const(uTags[vi])      // 0x41 i32.const <tag>
  if emitVariantStruct(body, objIx, vi, fnIx) < 0 { return 0 - 1 }
  fbStructNew(uBoxIdx)        // 0xfb 0x00 <union box heap-type index>
  0
}

// Lower a type guard `recv is Variant` onto `body` as the box-tag compare (mirroring
// `toWasm.ts`): evaluate the receiver (a union box), `struct.get $box 0` (the tag),
// then `i32.const tagOf(Variant)` and `i32.eq` â€” leaving a 0/1 i32 (an `if` condition).
function emitIs(body: i32[], isIx: i32, fnIx: i32): i32 {
  if !uDeclared {
    return emitFail("emitProgram: `is` test but no union type declared")
  }
  let nd = P.nodes[isIx]
  if nd is IsExpr {
    let vi = variantIndexOf(nd.isVariant)
    if vi < 0 {
      return emitFail("emitProgram: `is` names a type that is not a union variant")
    }
    if !exprUnion(nd.isObj, fnIx) {
      return emitFail("emitProgram: `is` receiver is not a union value")
    }
    if emitExpr(body, nd.isObj, fnIx) < 0 { return 0 - 1 }
    fbStructGet(uBoxIdx, 0)  // 0xfb 0x02 <box ht> field 0: tag
    fbI32Const(uTags[vi])    // 0x41 i32.const <tag>
    fbI32Bin(70)             // 0x46 i32.eq
    return 0
  }
  emitFail("emitProgram: expected an `is` expression")
}

// Lower a narrowed field read `recv.field` where `recv` is a union value narrowed (by
// an enclosing `if recv is Variant`) to `narrowVariant`. The downcast mirrors
// `toWasm.ts`: evaluate the box, `struct.get $box 1` (the `anyref` value), `ref.cast
// (ref $variant)` to recover the payload, then `struct.get $variant <fieldIdx>`.
//   ref.cast is `0xfb 0x16 <heaptype>` (non-null target â€” the box value is never null).
function emitNarrowedMem(body: i32[], memIx: i32, fnIx: i32): i32 {
  let m = P.nodes[memIx]
  if m is Member {
    // Resolve the variant from the RECEIVER's own active narrowing (not a global slot) â€”
    // so two simultaneously-narrowed locals each downcast to THEIR variant.
    let recvVar = ""
    let recvN = P.nodes[m.memObj]
    if recvN is Ident { recvVar = narrowVariantFor(recvN.identName) }
    let vi = variantIndexOf(recvVar)
    if vi < 0 {
      return emitFail("emitProgram: narrowed receiver names no union variant")
    }
    let idx = variantFieldIndex(vi, m.memProp)
    if idx < 0 {
      return emitFail("emitProgram: unknown variant field in narrowed field access")
    }
    if emitExpr(body, m.memObj, fnIx) < 0 { return 0 - 1 }
    fbStructGet(uBoxIdx, 1)  // 0xfb 0x02 <box ht> field 1: value (anyref)
    fbRefCast(uVarIdx + vi)  // 0xfb 0x16 <variant struct> ref.cast (non-null)
    fbStructGet(uVarIdx + vi, idx)  // 0xfb 0x02 <variant struct ht> <field index>
    return 0
  }
  emitFail("emitProgram: expected a field access")
}

// True if the member access at `memIx` reads a field of a CURRENTLY-narrowed union
// identifier (the receiver `Ident` has an active binding on the narrowing stack).
function memIsNarrowed(memIx: i32): boolean {
  if narrowTop == 0 { return false }
  let m = P.nodes[memIx]
  if m is Member {
    let recv = P.nodes[m.memObj]
    if recv is Ident {
      if narrowVariantFor(recv.identName) != "" { return true }
    }
  }
  false
}

// The variant table index the Member `memIx`'s receiver is currently narrowed to, or -1
// if its receiver is not a narrowed union identifier. Resolves each receiver's OWN active
// narrowing â€” so simultaneously-narrowed locals each map to their own variant.
function memNarrowVariantIndex(memIx: i32): i32 {
  let m = P.nodes[memIx]
  if m is Member {
    let recv = P.nodes[m.memObj]
    if recv is Ident {
      return variantIndexOf(narrowVariantFor(recv.identName))
    }
  }
  0 - 1
}

// Lower a field read `recv.field` onto `body`: evaluate the receiver (must be a
// struct), then `struct.get $0 <fieldidx>` (`0xfb 0x02 0x00 idx`).
function emitMem(body: i32[], memIx: i32, fnIx: i32): i32 {
  // A field read on a NARROWED union identifier downcasts through the box (G1).
  if memIsNarrowed(memIx) {
    return emitNarrowedMem(body, memIx, fnIx)
  }
  // A field read on a VARIANT-typed param `o.field` (`o: TyObj`) reads the variant
  // struct directly â€” the param already IS the unboxed variant ref, so there is NO box
  // unwrap / cast (gap #2). Evaluate the receiver (`local.get o`), then `struct.get
  // $<uVarIdx + vi> <fieldIdx>`.
  let m0 = P.nodes[memIx]
  if m0 is Member {
    let pvi = exprVariantIndex(m0.memObj, fnIx)
    if pvi >= 0 {
      let pvfi = variantFieldIndex(pvi, m0.memProp)
      if pvfi < 0 {
        return emitFail("emitProgram: unknown variant field in field access")
      }
      if emitExpr(body, m0.memObj, fnIx) < 0 { return 0 - 1 }
      fbStructGet(uVarIdx + pvi, pvfi)  // 0xfb 0x02 <variant struct ht> <field index>
      return 0
    }
  }
  if !sDeclared {
    return emitFail("emitProgram: field access but no struct type declared")
  }
  let m = P.nodes[memIx]
  if m is Member {
    let si = structIndexOfExpr(m.memObj, fnIx)
    if si < 0 {
      return emitFail("emitProgram: field access receiver is not a struct")
    }
    let idx = sFieldIndex(si, m.memProp)
    if idx < 0 {
      return emitFail("emitProgram: unknown struct field in field access")
    }
    if emitExpr(body, m.memObj, fnIx) < 0 { return 0 - 1 }
    fbStructGet(sHeapIdx[si], idx)   // 0xfb 0x02 <struct ht> <field index>
    return 0
  }
  emitFail("emitProgram: expected a field access")
}

// â”€â”€ string-literal decoding â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// A `StrLit` carries the RAW lexeme in `strText` (surrounding quotes kept, escapes
// UNRESOLVED â€” see `parser.vl`'s `mkStr(advance().text)`), so the emitter decodes it
// here to the sequence of Unicode CODE POINTS the string denotes. Because a VL string
// is itself a code-point `array i32` (this very representation), `strText[i]` already
// yields the i32 code point of the i-th source char, so decoding is a direct walk over
// those code points with the same escape grammar the lexer applies (`scanQuoted`):
// `\n \t \r \\ \" \' \0 \b \f \v`, `\xXX`, `\uXXXX`, `\u{â€¦}`. The result is the
// emittable code-point vector that `emitStr` lowers to `array.new_fixed`.

// The hex value of a hex-digit code point `c` (`0-9 a-f A-F`), or -1 if not hex.
function hexDigit(c: i32): i32 {
  if c >= '0' && c <= '9' { return c - '0' }
  if c >= 'a' && c <= 'f' { return c - 'a' + 10 }
  if c >= 'A' && c <= 'F' { return c - 'A' + 10 }
  0 - 1
}

// Decode the raw string lexeme `raw` (with its surrounding quotes) into the i32 vector
// of code points it denotes, resolving escapes consistently with the lexer's
// `scanQuoted`. The first and last chars are the quote delimiters and are skipped. An
// unknown escape keeps the char after the backslash verbatim (the lexer's lenient
// policy). `\u{â€¦}`/`\xXX`/`\uXXXX` with too few/invalid hex digits keep the marker
// char (`u`/`x`) verbatim â€” again matching the lexer â€” so this never fails loudly.
function decodeStr(raw: i32[]): i32[] {
  let out: i32[] = []
  let n = raw.length
  // Strip the surrounding quote chars (raw always has at least the two delimiters).
  let i = 1
  let last = n - 1
  while i < last {
    let c = raw[i]
    if c == '\\' && i + 1 < last {
      let e = raw[i + 1]
      if e == 'n' {
        out.push(10)
        i = i + 2
      } else if e == 't' {
        out.push(9)
        i = i + 2
      } else if e == 'r' {
        out.push(13)
        i = i + 2
      } else if e == '\\' {
        out.push(92)
        i = i + 2
      } else if e == '"' {
        out.push(34)
        i = i + 2
      } else if e == '\'' {
        out.push(39)
        i = i + 2
      } else if e == '0' {
        out.push(0)
        i = i + 2
      } else if e == 'b' {
        out.push(8)
        i = i + 2
      } else if e == 'f' {
        out.push(12)
        i = i + 2
      } else if e == 'v' {
        out.push(11)
        i = i + 2
      } else if e == 'x' {
        // `\xXX` â€” exactly two hex digits, else keep `x` verbatim.
        let h1 = 0 - 1
        let h2 = 0 - 1
        if i + 3 < last {
          h1 = hexDigit(raw[i + 2])
          h2 = hexDigit(raw[i + 3])
        }
        if h1 >= 0 && h2 >= 0 {
          out.push(h1 * 16 + h2)
          i = i + 4
        } else {
          out.push('x')
          i = i + 2
        }
      } else if e == 'u' {
        if i + 2 < last && raw[i + 2] == '{' {
          // `\u{â€¦}` â€” 1-6 hex digits up to `}`.
          let cp = 0
          let cnt = 0
          let j = i + 3
          while j < last && raw[j] != '}' && hexDigit(raw[j]) >= 0 {
            cp = cp * 16 + hexDigit(raw[j])
            cnt = cnt + 1
            j = j + 1
          }
          if j < last && raw[j] == '}' && cnt >= 1 && cnt <= 6 && cp <= 1114111 {
            out.push(cp)
            i = j + 1
          } else {
            out.push('u')
            i = i + 2
          }
        } else {
          // `\uXXXX` â€” exactly four hex digits, else keep `u` verbatim.
          let u1 = 0 - 1
          let u2 = 0 - 1
          let u3 = 0 - 1
          let u4 = 0 - 1
          if i + 5 < last {
            u1 = hexDigit(raw[i + 2])
            u2 = hexDigit(raw[i + 3])
            u3 = hexDigit(raw[i + 4])
            u4 = hexDigit(raw[i + 5])
          }
          if u1 >= 0 && u2 >= 0 && u3 >= 0 && u4 >= 0 {
            out.push(u1 * 4096 + u2 * 256 + u3 * 16 + u4)
            i = i + 6
          } else {
            out.push('u')
            i = i + 2
          }
        }
      } else {
        // Unknown escape: keep the char after the backslash verbatim.
        out.push(e)
        i = i + 2
      }
    } else {
      out.push(c)
      i = i + 1
    }
  }
  out
}

// Copy a `string`'s code points into an `i32[]` so `decodeStr` can index past the end
// safely with arithmetic. `s[i]` already yields the i32 code point (strings ARE
// code-point arrays in this representation), so this is a straight element copy.
function strToCps(s: string): i32[] {
  let out: i32[] = []
  let i = 0
  while i < s.length {
    out.push(s[i])
    i = i + 1
  }
  out
}

// Lower a string literal `"abc"` onto `body`: decode `strText` to its code-point
// vector, push each code point as `i32.const`, then `array.new_fixed $aTypeIdx <count>`
// â€” i.e. the IDENTICAL shape an `i32[]` literal of those code points uses (a string is
// CURRENTLY an `array i32` of code points; `docs/strings-design.md`). The UTF-8
// `array i8` storage migration is the deliberate B7 follow-up and is NOT built here.
function emitStr(body: i32[], strIx: i32, fnIx: i32): i32 {
  if !aUsed {
    return emitFail("emitProgram: string literal but array type not collected")
  }
  let s = P.nodes[strIx]
  if s is StrLit {
    let cps = decodeStr(strToCps(s.strText))
    let i = 0
    while i < cps.length {
      fbI32Const(cps[i])     // 0x41 i32.const <code point>
      i = i + 1
    }
    fbArrayNewFixed(aTypeIdx, cps.length)  // 0xfb 0x08 <typeidx> <count>; type shared with i32[]
    return 0
  }
  emitFail("emitProgram: expected a string literal")
}

// Lower an array literal `[e, e, ...]` onto `body` as a GROWABLE list value (mirroring
// `toWasm.ts`'s `ArrayLiteral` case): push each element value in source order (all i32),
// then `array.new_fixed $aTypeIdx <count>` to build the raw backing (`0xfb 0x08 <typeidx>
// <count>`), then push `count` (len) and `count` (cap), then `struct.new $lTypeIdx`
// (`0xfb 0x00 <lTypeIdx>`) to wrap them into `{ backing, len, cap }`. An empty `[]` is
// `array.new_fixed` of count 0 wrapped with len 0 / cap 0. An element that is itself an
// array (nested) is out of scope â€” fails loudly.
function emitArr(body: i32[], arrIx: i32, fnIx: i32): i32 {
  let a = P.nodes[arrIx]
  if a is ArrayLit {
    let elems = a.arrElems
    // A REF list literal â€” ref ELEMENTS, OR an empty `[]` whose binding annotation is a
    // ref array (`pendingListKind` 1/2). The element store is `(ref null $elem)`; each
    // element lowers via `emitExpr` (an objlit â†’ struct.new / union box). Otherwise the
    // i32 list path.
    let isRefLit = arrLitIsRef(arrIx)
    // A `string[]` literal â€” string ELEMENTS, OR an empty `[]` whose binding/field is a
    // `string[]` (`pendingListKind == 3`). Its backing is `(ref null $aTypeIdx)` (string
    // refs) wrapped in the string-list wrapper (`mkListIdx`). Checked before the i32/ref
    // paths since a string element is neither i32 nor a struct/union ref.
    let isStrLit = arrLitIsStr(arrIx, fnIx)
    if elems.length == 0 {
      if pendingListKind == 3 { isStrLit = true }
      else { if pendingListKind != 0 { isRefLit = true } }
    }
    if isStrLit {
      if !slUsed {
        return emitFail("emitProgram: string array literal but string list type not collected")
      }
      let i = 0
      while i < elems.length {
        if emitExpr(body, elems[i], fnIx) < 0 { return 0 - 1 }
        i = i + 1
      }
      fbArrayNewFixed(mkArrIdx, elems.length)  // 0xfb 0x08; builds the string-ref backing
      fbI32Const(elems.length) // 0x41 i32.const (len)
      fbI32Const(elems.length) // 0x41 i32.const (cap)
      fbStructNew(mkListIdx)   // 0xfb 0x00 <string-list wrapper struct type index>
      return 0
    }
    if isRefLit {
      if !rlUsed {
        return emitFail("emitProgram: ref array literal but ref list type not collected")
      }
      // The element type determines WHICH (backing, wrapper) pair this literal builds.
      // A non-empty literal types itself from its first element; an EMPTY `[]` (no
      // elements) takes the slot the binding site threaded via `pendingListSlot`.
      let rslot = 0
      if elems.length >= 1 {
        rslot = rlSlotByName(arrLitElemName(arrIx))
      } else {
        rslot = pendingListSlot
      }
      if rslot < 0 { rslot = 0 }
      let i = 0
      while i < elems.length {
        if exprArray(elems[i], fnIx) || exprRefArray(elems[i], fnIx) {
          return emitFail("emitProgram: nested arrays are not supported")
        }
        if emitExpr(body, elems[i], fnIx) < 0 { return 0 - 1 }
        i = i + 1
      }
      fbArrayNewFixed(rlBackIdx[rslot], elems.length)  // 0xfb 0x08; builds the ref backing
      fbI32Const(elems.length) // 0x41 i32.const (len)
      fbI32Const(elems.length) // 0x41 i32.const (cap)
      fbStructNew(rlWrapIdx[rslot])  // 0xfb 0x00 <this slot's ref-list wrapper>
      return 0
    }
    if !lUsed {
      return emitFail("emitProgram: array literal but list type not collected")
    }
    let i = 0
    while i < elems.length {
      if exprArray(elems[i], fnIx) || exprRefArray(elems[i], fnIx) {
        return emitFail("emitProgram: nested arrays are not supported")
      }
      if exprStruct(elems[i], fnIx) {
        return emitFail("emitProgram: struct array elements are not supported")
      }
      if emitExpr(body, elems[i], fnIx) < 0 { return 0 - 1 }
      i = i + 1
    }
    fbArrayNewFixed(aTypeIdx, elems.length)  // 0xfb 0x08; builds the raw backing
    // Wrap { backing, len = count, cap = count } via struct.new.
    fbI32Const(elems.length) // 0x41 i32.const (len)
    fbI32Const(elems.length) // 0x41 i32.const (cap)
    fbStructNew(lTypeIdx)    // 0xfb 0x00 <list wrapper struct type index>
    return 0
  }
  emitFail("emitProgram: expected an array literal")
}

// â”€â”€ G8: string-keyed maps (`{[string]: i32}`) â€” open-addressing hash map â”€â”€â”€â”€â”€â”€â”€
// A map is the 5-field `MAP = { keys, vals, index, count, size }` (see the map-table
// section above for the full representation). Operations HASH the key (FNV-1a) into
// `index` and LINEAR-PROBE to a free-or-matching slot â€” NO O(n) scan. A function that
// touches a map reserves a 12-slot scratch frame (`mapScratchBase` + 0..11):
//   +0  mapRef : (ref $mStructIdx)  â€” the map value
//   +1  keyRef : (ref $aTypeIdx)    â€” the target key string
//   +2  curRef : (ref $aTypeIdx)    â€” the current probed key string
//   +3  slot   : i32                â€” probe slot offset into `index`
//   +4  cap    : i32                â€” index length / newCap (resize)
//   +5  entry  : i32                â€” index[slot] (entry+1; 0 = miss)
//   +6  keysBk : (ref $mkArrIdx)    â€” grown keys backing
//   +7  valsBk : (ref $aTypeIdx)    â€” grown vals backing
//   +8  chr    : i32                â€” inner char cursor (key compare / hash)
//   +9  hcur   : i32                â€” FNV hash accumulator
//   +10 idxBk  : (ref $aTypeIdx)    â€” fresh `index` backing (resize)
//   +11 rslot  : i32                â€” inner probe slot (resize)
// `emitMapProbe` leaves `slot` = the probe slot and `entry` = index[slot]; reused by
// set / get / `??` / `.has`. `emitMapResize` rehashes at load factor 1/2.

let fnUsesMap: boolean = false
let mapScratchBase: i32 = 0

// True if function `fnIx` operates on a map â€” it has a map PARAM, or `buildLocals`
// flagged a map LOCAL (code `6`). Drives the map scratch-frame reservation. (Run
// AFTER `buildLocals`, so `localIsRef` is populated.)
function fnHasMap(fnIx: i32): boolean {
  let i = 0
  while i < localNames.length {
    if localIsRef[i] == 6 { return true }
    // A map-ARRAY local (`{[string]:i32}[]`, code 5 with element kind 3) lets map ops
    // run on an indexed element (`scopes[i][k]`) â€” so the function needs the map scratch
    // frame even though no bare map local is declared.
    if localIsRef[i] == 5 {
      let s = localStructIdx[i]
      if s >= 0 { if s < rlElemKindTbl.length { if rlElemKindTbl[s] == 3 { return true } } }
    }
    i = i + 1
  }
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    let params = fn.fnParams
    let pj = 0
    while pj < params.length {
      let p = P.nodes[params[pj]]
      if p is Param {
        if p.parType >= 0 {
          let ty = P.nodes[p.parType]
          if ty is TypeRef {
            if nameIsMap(ty.tyName) { return true }
          }
        }
      }
      pj = pj + 1
    }
  }
  false
}

// `local.get` of map scratch slot `n`.
function pushMapScr(body: i32[], n: i32): i32 {
  fbLocalGet(mapScratchBase + n)  // 0x20 local.get
  0
}

// `local.set` of map scratch slot `n`.
function setMapScr(body: i32[], n: i32): i32 {
  fbLocalSet(mapScratchBase + n)  // 0x21 local.set
  0
}

// `M.keys` (the keys list wrapper ref): `local.get mapRef ; struct.get $mStructIdx 0`.
function pushMapKeys(body: i32[]): i32 {
  pushMapScr(body, 0)
  fbStructGet(mStructIdx, 0)  // field 0: keys
  0
}

// `M.vals` (the i32 vals list wrapper ref): `local.get mapRef ; struct.get $mStructIdx 1`.
function pushMapVals(body: i32[]): i32 {
  pushMapScr(body, 0)
  fbStructGet(mStructIdx, 1)  // field 1: vals
  0
}

// `M.index` (the i32 hash-slot array): `local.get mapRef ; struct.get $mStructIdx 2`.
function pushMapIndex(body: i32[]): i32 {
  pushMapScr(body, 0)
  fbStructGet(mStructIdx, 2)  // field 2: index
  0
}

// `M.count` (entries appended): `local.get mapRef ; struct.get $mStructIdx 3`.
function pushMapCount(body: i32[]): i32 {
  pushMapScr(body, 0)
  fbStructGet(mStructIdx, 3)  // field 3: count
  0
}

// `M.size` (live entry count): `local.get mapRef ; struct.get $mStructIdx 4`.
function pushMapSize(body: i32[]): i32 {
  pushMapScr(body, 0)
  fbStructGet(mStructIdx, 4)  // field 4: size
  0
}

// Element-wise string equality of the two refs in map scratch slots `aSlot`/`bSlot`,
// leaving a 0/1 on the stack. A SELF-CONTAINED port of `emitStrEq`'s compare core
// (no operands consumed; reads the two scratch string locals directly) so the map
// scan can compare a stored key against the target key WITHOUT the str-op frame.
function emitMapKeyEq(body: i32[], aSlot: i32, bSlot: i32): i32 {
  // block i32 { ... } â€” yields the 0/1 result.
  fbBlock(127)               // 0x02 block, 0x7f i32 blocktype
  // if len(A) != len(B) { push 0 ; br 1 }
  pushMapScr(body, aSlot)
  fbArrayLen()               // array.len(A)
  pushMapScr(body, bSlot)
  fbArrayLen()               // array.len(B)
  fbI32Bin(71)               // 0x47 i32.ne
  fbIf(64)                   // 0x04 if, 0x40 void blocktype
  fbI32Const(0)              // i32.const 0
  fbBr(1)                    // 0x0c br depth 1 â†’ out of the i32 block
  fbEnd()                    // 0x0b end (if)
  // I = 0  (slot 8, the dedicated char cursor â€” distinct from the OUTER scan's `idx`
  // in slot 3, which must survive across the key compare to set `hit = idx`)
  fbI32Const(0)
  setMapScr(body, 8)
  // loop { if I >= len(A) {} else { A[I] != B[I] ? 0,br : I++ , br loop } }
  fbLoop(64)                 // 0x03 loop, 0x40 void blocktype
  pushMapScr(body, 8)        // I
  pushMapScr(body, aSlot)
  fbArrayLen()               // array.len(A)
  fbI32Bin(78)               // 0x4e i32.ge_s  (I >= len â†’ done)
  fbIf(64)                   // 0x04 if, void
  // then: done (empty)
  fbElse()                   // 0x05 else
  // A[I] != B[I] ?
  pushMapScr(body, aSlot)
  pushMapScr(body, 8)
  fbArrayGet(aTypeIdx)       // array.get
  pushMapScr(body, bSlot)
  pushMapScr(body, 8)
  fbArrayGet(aTypeIdx)       // array.get
  fbI32Bin(71)               // 0x47 i32.ne
  fbIf(64)                   // 0x04 if (mismatch â†’ 0, exit block), void
  fbI32Const(0)              // i32.const 0
  fbBr(3)                    // 0x0c br depth 3 â†’ out of: if(0)Â·else(1)Â·loop(2)Â·block(3)
  fbEnd()                    // 0x0b end (mismatch if)
  // I = I + 1
  pushMapScr(body, 8)
  fbI32Const(1)
  fbI32Bin(106)              // i32.add
  setMapScr(body, 8)
  fbBr(1)                    // 0x0c br depth 1 â†’ loop header
  fbEnd()                    // 0x0b end (ge_s if)
  fbEnd()                    // 0x0b end (loop)
  // All chars matched â†’ 1.
  fbI32Const(1)
  fbEnd()                    // 0x0b end (block)
  0
}

// FNV-1a hash of the string in scratch slot `strSlot`, leaving a NON-NEGATIVE i32
// hash on the stack. `h = 2166136261; for c in str { h = (h ^ c) * 16777619 };
// h & 0x7fffffff`. Uses slot 9 (accumulator `h`) and slot 8 (char cursor `i`). The
// 32-bit wasm `i32.mul` wraps exactly as the host's hash does.
function emitMapHashOf(body: i32[], strSlot: i32): i32 {
  // h = 2166136261 (0x811c9dc5 â€” the FNV offset basis, as a signed i32 constant).
  fbI32Const(0 - 2128831035) // i32.const; 2166136261 as signed = -2128831035
  setMapScr(body, 9)         // h
  // i = 0
  fbI32Const(0)
  setMapScr(body, 8)         // i
  // loop { if i >= len(str) {} else { h = (h ^ str[i]) * 16777619 ; i++ ; br } }
  fbLoop(64)                 // 0x03 loop, void
  pushMapScr(body, 8)        // i
  pushMapScr(body, strSlot)
  fbArrayLen()               // array.len
  fbI32Bin(78)               // i32.ge_s (i >= len â†’ done)
  fbIf(64)                   // if, void
  // then: done (empty)
  fbElse()                   // else
  // h = (h ^ str[i]) * 16777619
  pushMapScr(body, 9)        // h
  pushMapScr(body, strSlot)
  pushMapScr(body, 8)        // i
  fbArrayGet(aTypeIdx)       // array.get
  fbI32Bin(115)              // 0x73 i32.xor
  fbI32Const(16777619)       // i32.const 16777619
  fbI32Bin(108)              // 0x6c i32.mul
  setMapScr(body, 9)         // h
  // i = i + 1
  pushMapScr(body, 8)
  fbI32Const(1)
  fbI32Bin(106)              // i32.add
  setMapScr(body, 8)
  fbBr(1)                    // br â†’ loop header
  fbEnd()                    // end (ge_s if)
  fbEnd()                    // end (loop)
  // h & 0x7fffffff  â€” force non-negative (left on the stack).
  pushMapScr(body, 9)
  fbI32Const(2147483647)     // i32.const 0x7fffffff
  fbI32Bin(113)              // 0x71 i32.and
  0
}

// PROBE: with `mapRef` (slot 0) and the target `keyRef` (slot 1) set, hash the key
// into `M.index` and linear-probe (wrapping) to the slot holding either the matching
// key's entry or a free (0) slot. Leaves `slot` (slot 3) = that probe slot and `entry`
// (slot 5) = `index[slot]` (0 = miss; else entry-position + 1). Shared by get / has /
// set. The index load factor is kept < 1/2, so a free slot is always reached.
function emitMapProbe(body: i32[]): i32 {
  // cap = array.len(index)
  pushMapIndex(body)
  fbArrayLen()               // array.len
  setMapScr(body, 4)         // cap
  // slot = hash(keyRef) % cap
  if emitMapHashOf(body, 1) < 0 { return 0 - 1 }
  pushMapScr(body, 4)        // cap
  fbI32Bin(112)              // 0x70 i32.rem_u
  setMapScr(body, 3)         // slot
  // loop { entry = index[slot]
  //        if entry == 0 { break(miss) }
  //        curRef = keys.backing[entry-1]
  //        if keyEq(curRef, keyRef) { break(hit) }
  //        slot = (slot + 1) % cap ; br loop }
  fbBlock(64)                // 0x02 block (probe break target), void
  fbLoop(64)                 // 0x03 loop, void
  // entry = index[slot]
  pushMapIndex(body)
  pushMapScr(body, 3)        // slot
  fbArrayGet(aTypeIdx)       // array.get
  setMapScr(body, 5)         // entry
  // if entry == 0 { br 2 â†’ out of the probe block (miss) }
  pushMapScr(body, 5)
  fbI32Eqz()                 // i32.eqz
  fbBrIf(1)                  // 0x0d br_if depth 1 â†’ out of the probe block
  // curRef = keys.backing[entry-1]  (ref.as_non_null â€” a stored slot is populated)
  pushMapKeys(body)
  fbStructGet(mkListIdx, 0)  // field 0: backing
  pushMapScr(body, 5)        // entry
  fbI32Const(1)
  fbI32Bin(107)              // 0x6b i32.sub  (entry - 1)
  fbArrayGet(mkArrIdx)       // array.get
  wU8(212)                   // 0xd4 ref.as_non_null
  setMapScr(body, 2)         // curRef
  // if keyEq(curRef, keyRef) { br 2 â†’ out of the probe block (hit) }
  if emitMapKeyEq(body, 2, 1) < 0 { return 0 - 1 }
  fbBrIf(1)                  // 0x0d br_if depth 1 â†’ out of the probe block
  // slot = (slot + 1) % cap
  pushMapScr(body, 3)
  fbI32Const(1)
  fbI32Bin(106)              // i32.add
  pushMapScr(body, 4)        // cap
  fbI32Bin(112)              // i32.rem_u
  setMapScr(body, 3)         // slot
  fbBr(0)                    // br â†’ loop header
  fbEnd()                    // end (loop)
  fbEnd()                    // end (probe block)
  0
}

// Construct an EMPTY map `Map()` onto `body`: two empty lists (each `array.new_fixed`
// count 0, wrapped `{ backing, len=0, cap=0 }`), boxed into the map struct.
function emitMapNew(body: i32[]): i32 {
  if !mUsed {
    return emitFail("emitProgram: Map() but map type not collected")
  }
  // keys list: empty string-ref backing â†’ wrapper.
  fbArrayNewFixed(mkArrIdx, 0)             // 0 elements
  fbI32Const(0)              // len = 0
  fbI32Const(0)              // cap = 0
  fbStructNew(mkListIdx)
  // vals list: empty i32 backing â†’ wrapper.
  fbArrayNewFixed(aTypeIdx, 0)
  fbI32Const(0)
  fbI32Const(0)
  fbStructNew(lTypeIdx)
  // index: i32 hash-slot array of INITIAL_CAP (8) zero-filled slots (0 = empty).
  fbI32Const(8)              // i32.const 8
  fbArrayNewDefault(aTypeIdx)
  // count = 0, size = 0.
  fbI32Const(0)
  fbI32Const(0)
  // map struct { keys, vals, index, count, size }.
  fbStructNew(mStructIdx)
  0
}

// Load the map receiver + key into the scratch frame (slots 0/1) and run the PROBE,
// leaving `slot` (slot 3) = the probe slot and `entry` (slot 5) = `index[slot]`
// (0 = miss; else entry-position + 1). `recvIx`/`keyIx` are arena indices; `recvIx`
// must be a map-typed expression and `keyIx` a string.
function emitMapPrep(body: i32[], recvIx: i32, keyIx: i32, fnIx: i32): i32 {
  if !mUsed {
    return emitFail("emitProgram: map op but map type not collected")
  }
  if !exprMap(recvIx, fnIx) {
    return emitFail("emitProgram: map op receiver is not a map")
  }
  if !exprString(keyIx, fnIx) {
    return emitFail("emitProgram: map key is not a string")
  }
  if emitExpr(body, recvIx, fnIx) < 0 { return 0 - 1 }
  setMapScr(body, 0)         // mapRef
  if emitExpr(body, keyIx, fnIx) < 0 { return 0 - 1 }
  setMapScr(body, 1)         // keyRef
  emitMapProbe(body)
}

// Lower a map GET `m[k]` with a DEFAULT (`m[k] ?? d`) onto `body`: probe, then if the
// key was found push `vals[entry-1]`, else push the default `d`. The self-host checker
// ALWAYS reads a map through `?? -1` (a total fallback), so this is the primary get.
function emitMapGetOr(body: i32[], recvIx: i32, keyIx: i32, defIx: i32, fnIx: i32): i32 {
  if emitMapPrep(body, recvIx, keyIx, fnIx) < 0 { return 0 - 1 }
  // if entry != 0 { vals.backing[entry-1] } else { d }  â€” a value-typed if yielding i32.
  pushMapScr(body, 5)        // entry
  fbIf(127)                  // if (entry != 0 â†’ found; a nonzero condition is true), 0x7f i32 blocktype
  // vals.backing[entry-1]
  pushMapVals(body)
  fbStructGet(lTypeIdx, 0)   // struct.get (vals backing), field 0: backing
  pushMapScr(body, 5)        // entry
  fbI32Const(1)
  fbI32Bin(107)              // 0x6b i32.sub  (entry - 1)
  fbArrayGet(aTypeIdx)       // array.get
  fbElse()                   // else
  if emitExpr(body, defIx, fnIx) < 0 { return 0 - 1 }
  fbEnd()                    // end (if)
  0
}

// Lower a bare map GET `m[k]` (no `??`) onto `body`: probe, return `vals[entry-1]` or
// `0` when absent. The checker never uses a bare map get (always `?? -1`); provided for
// completeness so `m[k]` in value position is total (0 default).
function emitMapGet(body: i32[], recvIx: i32, keyIx: i32, fnIx: i32): i32 {
  if emitMapPrep(body, recvIx, keyIx, fnIx) < 0 { return 0 - 1 }
  pushMapScr(body, 5)        // entry
  fbIf(127)                  // if (entry != 0), i32 blocktype
  pushMapVals(body)
  fbStructGet(lTypeIdx, 0)
  pushMapScr(body, 5)        // entry
  fbI32Const(1)
  fbI32Bin(107)              // i32.sub (entry - 1)
  fbArrayGet(aTypeIdx)
  fbElse()                   // else
  fbI32Const(0)              // i32.const 0
  fbEnd()                    // end
  0
}

// Lower a map HAS `m.has(k)` / `k in m` onto `body`: probe, push 1 if found else 0.
function emitMapHas(body: i32[], recvIx: i32, keyIx: i32, fnIx: i32): i32 {
  if emitMapPrep(body, recvIx, keyIx, fnIx) < 0 { return 0 - 1 }
  pushMapScr(body, 5)        // entry
  fbI32Const(0)
  fbI32Bin(71)               // 0x47 i32.ne (entry != 0 â†’ 1, else 0)
  0
}

// Resize the `index` when the load factor (size / cap) crosses 1/2: allocate a fresh
// `index` of `2*cap` slots and REBUILD it from the ordered entries â€” for each entry
// `i` in `[0, count)`, hash `keys[i]` into the new index and linear-probe to a free
// slot, writing `i+1`. The ordered keys/vals lists are UNTOUCHED (insertion order
// preserved); only `index` is rebuilt. `mapRef` is in slot 0. Scratch use (all free
// after the probe/append): 4 newCap, 3 entry cursor `i`, 10 new index backing, 11
// inner probe slot; `emitMapHashOf` uses 9/8 internally (disjoint from these).
function emitMapResize(body: i32[]): i32 {
  // if size * 2 >= len(index) { rehash to 2 * len(index) }
  pushMapSize(body)
  fbI32Const(2)
  fbI32Bin(108)              // i32.mul (size * 2)
  pushMapIndex(body)
  fbArrayLen()               // array.len
  fbI32Bin(79)               // 0x4f i32.ge_u (size*2 >= cap)
  fbIf(64)                   // if, void
  // newCap = 2 * len(index)
  pushMapIndex(body)
  fbArrayLen()               // array.len
  fbI32Const(2)
  fbI32Bin(108)              // i32.mul
  setMapScr(body, 4)         // newCap (slot 4)
  // idxBk = array.new_default $aTypeIdx newCap  (zero-filled)
  pushMapScr(body, 4)
  fbArrayNewDefault(aTypeIdx)
  setMapScr(body, 10)        // idxBk (slot 10)
  // i = 0
  fbI32Const(0)
  setMapScr(body, 3)         // i (slot 3)
  // loop { if i >= count {} else { rebuild entry i ; i++ ; br } }
  fbLoop(64)                 // loop, void
  pushMapScr(body, 3)        // i
  pushMapCount(body)
  fbI32Bin(78)               // i32.ge_s (i >= count â†’ done)
  fbIf(64)                   // if, void
  // then: done (empty)
  fbElse()                   // else
  // curRef = keys.backing[i]  (ref.as_non_null â€” entries are populated)
  pushMapKeys(body)
  fbStructGet(mkListIdx, 0)  // struct.get (keys backing), field 0: backing
  pushMapScr(body, 3)        // i
  fbArrayGet(mkArrIdx)       // array.get
  wU8(212)                   // 0xd4 ref.as_non_null
  setMapScr(body, 2)         // curRef
  // rslot = hash(curRef) % newCap
  if emitMapHashOf(body, 2) < 0 { return 0 - 1 }
  pushMapScr(body, 4)        // newCap
  fbI32Bin(112)              // i32.rem_u
  setMapScr(body, 11)        // rslot
  // while idxBk[rslot] != 0 { rslot = (rslot + 1) % newCap }
  fbBlock(64)                // block (inner probe break), void
  fbLoop(64)                 // loop, void
  // if idxBk[rslot] == 0 { br 1 â†’ out of inner block }
  pushMapScr(body, 10)       // idxBk
  pushMapScr(body, 11)       // rslot
  fbArrayGet(aTypeIdx)       // array.get
  fbI32Eqz()                 // i32.eqz
  fbBrIf(1)                  // br_if depth 1 â†’ out of inner block
  // rslot = (rslot + 1) % newCap
  pushMapScr(body, 11)
  fbI32Const(1)
  fbI32Bin(106)              // i32.add
  pushMapScr(body, 4)        // newCap
  fbI32Bin(112)              // i32.rem_u
  setMapScr(body, 11)
  fbBr(0)                    // br â†’ inner loop header
  fbEnd()                    // end (inner loop)
  fbEnd()                    // end (inner block)
  // idxBk[rslot] = i + 1
  pushMapScr(body, 10)       // idxBk
  pushMapScr(body, 11)       // rslot
  pushMapScr(body, 3)        // i
  fbI32Const(1)
  fbI32Bin(106)              // i32.add (i + 1)
  fbArraySet(aTypeIdx)       // array.set
  // i = i + 1
  pushMapScr(body, 3)
  fbI32Const(1)
  fbI32Bin(106)              // i32.add
  setMapScr(body, 3)
  fbBr(1)                    // br â†’ outer loop header
  fbEnd()                    // end (ge_s if)
  fbEnd()                    // end (outer loop)
  // M.index = idxBk
  pushMapScr(body, 0)        // mapRef
  pushMapScr(body, 10)       // idxBk
  fbStructSet(mStructIdx, 2) // struct.set field 2: index
  fbEnd()                    // end (resize if)
  0
}

// Lower a map SET `m[k] = v` onto `body`: probe; on a HIT (`entry != 0`) overwrite
// `vals.backing[entry-1] = v`, else APPEND a new entry â€” link the index slot, push the
// key + value onto the ordered entry lists, bump `count`/`size`, and resize the index
// if the load factor crossed 1/2. The append reuses the inline list-grow push over the
// keys (string-ref) and vals (i32) lists. Run from `emitAssign` (a statement).
//
// Ordering matters: `index[slot] = count+1` is written BEFORE the two pushes, because
// `emitMapPushKey`/`emitMapPushVal` clobber the probe slot (slot 3) and cap (slot 4).
function emitMapSet(body: i32[], recvIx: i32, keyIx: i32, valIx: i32, fnIx: i32): i32 {
  if emitMapPrep(body, recvIx, keyIx, fnIx) < 0 { return 0 - 1 }
  pushMapScr(body, 5)        // entry
  fbIf(64)                   // if (entry != 0 â†’ overwrite), void
  // OVERWRITE: vals.backing[entry-1] = v
  pushMapVals(body)
  fbStructGet(lTypeIdx, 0)   // struct.get (vals backing), field 0: backing
  pushMapScr(body, 5)        // entry
  fbI32Const(1)
  fbI32Bin(107)              // i32.sub (entry - 1)
  if emitExpr(body, valIx, fnIx) < 0 { return 0 - 1 }   // value
  fbArraySet(aTypeIdx)       // array.set
  fbElse()                   // else
  // APPEND. index[slot] = count + 1  (the new entry's position + 1).
  pushMapIndex(body)
  pushMapScr(body, 3)        // slot
  pushMapCount(body)
  fbI32Const(1)
  fbI32Bin(106)              // i32.add (count + 1)
  fbArraySet(aTypeIdx)       // array.set
  // keys.push(keyRef) ; vals.push(v)  (clobbers slots 3/4 â€” already linked above).
  if emitMapPushKey(body) < 0 { return 0 - 1 }
  if emitMapPushVal(body, valIx, fnIx) < 0 { return 0 - 1 }
  // count = count + 1
  pushMapScr(body, 0)        // mapRef (struct.set receiver)
  pushMapCount(body)
  fbI32Const(1)
  fbI32Bin(106)              // i32.add
  fbStructSet(mStructIdx, 3) // struct.set field 3: count
  // size = size + 1
  pushMapScr(body, 0)        // mapRef
  pushMapSize(body)
  fbI32Const(1)
  fbI32Bin(106)              // i32.add
  fbStructSet(mStructIdx, 4) // struct.set field 4: size
  if emitMapResize(body) < 0 { return 0 - 1 }
  fbEnd()                    // end (if)
  0
}

// Inline list-grow append of the scratch `keyRef` (slot 1) onto `M.keys` (the
// string-ref list). The keys list backing is `(array (mut (ref null $aTypeIdx)))`,
// so grow uses `array.new_default`/`array.copy` over `$mkArrIdx`, and the value
// written is the (non-null) key string ref â€” reusing the map scratch frame's spare
// i32 slots (4 = newCap, 3 = char cursor is free here) and a fresh backing local.
// To keep it self-contained, the new backing is built/stored via `M.keys.backing`
// directly (no extra ref local): grow path mirrors `emitPush`.
function emitMapPushKey(body: i32[]): i32 {
  // if keys.len == keys.cap { grow }
  pushMapKeysLen(body)
  pushMapKeysCap(body)
  fbI32Bin(70)               // i32.eq
  fbIf(64)                   // if, void
  // newCap = cap == 0 ? 4 : cap*2   (slot 4)
  pushMapKeysCap(body)
  fbI32Eqz()                 // i32.eqz
  fbIf(127)                  // if, i32 blocktype
  fbI32Const(4)
  fbElse()                   // else
  pushMapKeysCap(body)
  fbI32Const(2)
  fbI32Bin(108)              // i32.mul
  fbEnd()                    // end
  setMapScr(body, 4)         // newCap
  // keys.backing = copy of old into a fresh array.new_default(newCap), keys.cap=newCap
  // newBacking on stack: array.new_default $mkArrIdx newCap
  pushMapScr(body, 4)        // newCap
  fbArrayNewDefault(mkArrIdx)
  // stash newBacking into curRef? curRef is a (ref $aTypeIdx) string ref â€” WRONG type.
  // Instead copy directly: keep newBacking on stack, but array.copy needs it as an
  // operand twice (dest for copy, then store into keys.backing). Use the keys list:
  // 1) set keys.backing = newBacking, 2) array.copy newBacking 0 (re-read old via a
  // saved ref). Simpler: array.copy first (dest = newBacking on stack is consumed),
  // so duplicate by storing into keys.backing FIRST, then copy from a SECOND fresh
  // read of the (now-updated) backing â€” but the old elements are gone. So we must
  // copy BEFORE swapping. We therefore need a ref local for newBacking.
  // Store newBacking into keys.backing AFTER copying from the OLD backing. To do that
  // without a typed ref local, we copy oldâ†’new while new is still only on the stack is
  // impossible (copy consumes operands). Fall back: set keys.backing, copy oldâ†’new is
  // lost. ==> use the dedicated newKeysBacking local (slot 6).
  setMapScrKB(body)          // newKeysBacking (slot 6)
  // array.copy newBacking 0 oldBacking 0 len
  pushMapScrKB(body)         // dest
  fbI32Const(0)
  pushMapKeysBacking(body)   // src (old)
  fbI32Const(0)
  pushMapKeysLen(body)       // count
  fbArrayCopy(mkArrIdx, mkArrIdx)   // array.copy (dest type, src type)
  // keys.backing = newBacking
  pushMapKeys(body)
  pushMapScrKB(body)
  fbStructSet(mkListIdx, 0)  // struct.set field 0: backing
  // keys.cap = newCap
  pushMapKeys(body)
  pushMapScr(body, 4)
  fbStructSet(mkListIdx, 2)  // struct.set field 2: cap
  fbEnd()                    // end (grow if)
  // keys.backing[keys.len] = keyRef
  pushMapKeysBacking(body)
  pushMapKeysLen(body)
  pushMapScr(body, 1)        // keyRef
  fbArraySet(mkArrIdx)       // array.set
  // keys.len = keys.len + 1
  pushMapKeys(body)
  pushMapKeysLen(body)
  fbI32Const(1)
  fbI32Bin(106)              // i32.add
  fbStructSet(mkListIdx, 1)  // struct.set field 1: len
  0
}

// Inline list-grow append of value `v` (arena `valIx`) onto `M.vals` (the i32 list).
// Mirrors `emitPush` over the i32 list, but the wrapper ref is `M.vals` (not a local)
// and the grow uses the map scratch i32 slots + the vals-backing ref local (slot 7).
function emitMapPushVal(body: i32[], valIx: i32, fnIx: i32): i32 {
  // newVal first (slot 3 â€” free after the scan/keys push)
  if emitExpr(body, valIx, fnIx) < 0 { return 0 - 1 }
  setMapScr(body, 3)
  // if vals.len == vals.cap { grow }
  pushMapValsLen(body)
  pushMapValsCap(body)
  fbI32Bin(70)               // i32.eq
  fbIf(64)                   // if, void
  // newCap (slot 4)
  pushMapValsCap(body)
  fbI32Eqz()                 // i32.eqz
  fbIf(127)                  // if, i32 blocktype
  fbI32Const(4)
  fbElse()                   // else
  pushMapValsCap(body)
  fbI32Const(2)
  fbI32Bin(108)              // i32.mul
  fbEnd()                    // end
  setMapScr(body, 4)
  // newBacking = array.new_default $aTypeIdx newCap  â†’ slot 7 (i32 vals backing)
  pushMapScr(body, 4)
  fbArrayNewDefault(aTypeIdx)
  setMapScrVB(body)          // newValsBacking (slot 7)
  // array.copy newBacking 0 oldBacking 0 len
  pushMapScrVB(body)
  fbI32Const(0)
  pushMapValsBacking(body)
  fbI32Const(0)
  pushMapValsLen(body)
  fbArrayCopy(aTypeIdx, aTypeIdx)   // array.copy (dest type, src type)
  // vals.backing = newBacking
  pushMapVals(body)
  pushMapScrVB(body)
  fbStructSet(lTypeIdx, 0)   // struct.set field 0: backing
  // vals.cap = newCap
  pushMapVals(body)
  pushMapScr(body, 4)
  fbStructSet(lTypeIdx, 2)   // struct.set field 2: cap
  fbEnd()                    // end (grow if)
  // vals.backing[vals.len] = newVal
  pushMapValsBacking(body)
  pushMapValsLen(body)
  pushMapScr(body, 3)        // newVal
  fbArraySet(aTypeIdx)       // array.set
  // vals.len = vals.len + 1
  pushMapVals(body)
  pushMapValsLen(body)
  fbI32Const(1)
  fbI32Bin(106)              // i32.add
  fbStructSet(lTypeIdx, 1)   // struct.set field 1: len
  0
}

// `M.keys.len` / `.cap` / `.backing` field reads (struct.get $mkListIdx 1/2/0).
function pushMapKeysLen(body: i32[]): i32 {
  pushMapKeys(body)
  fbStructGet(mkListIdx, 1)
  0
}
function pushMapKeysCap(body: i32[]): i32 {
  pushMapKeys(body)
  fbStructGet(mkListIdx, 2)
  0
}
function pushMapKeysBacking(body: i32[]): i32 {
  pushMapKeys(body)
  fbStructGet(mkListIdx, 0)
  0
}
// `M.vals.len` / `.cap` / `.backing` field reads (struct.get $lTypeIdx 1/2/0).
function pushMapValsLen(body: i32[]): i32 {
  pushMapVals(body)
  fbStructGet(lTypeIdx, 1)
  0
}
function pushMapValsCap(body: i32[]): i32 {
  pushMapVals(body)
  fbStructGet(lTypeIdx, 2)
  0
}
function pushMapValsBacking(body: i32[]): i32 {
  pushMapVals(body)
  fbStructGet(lTypeIdx, 0)
  0
}

// The two ref scratch locals beyond the 6-slot core frame: a non-null keys backing
// ref (slot 6) and a non-null vals backing ref (slot 7), used by the two grows.
function setMapScrKB(body: i32[]): i32 {
  fbLocalSet(mapScratchBase + 6)
  0
}
function pushMapScrKB(body: i32[]): i32 {
  fbLocalGet(mapScratchBase + 6)
  0
}
function setMapScrVB(body: i32[]): i32 {
  fbLocalSet(mapScratchBase + 7)
  0
}
function pushMapScrVB(body: i32[]): i32 {
  fbLocalGet(mapScratchBase + 7)
  0
}

// Lower an index READ `a[i]` onto `body`. The element store is the raw `(array (mut
// i32))` in BOTH cases, but a list receiver carries it inside the wrapper struct:
//   list `a[i]`   â†’ eval `a` (a wrapper ref), `struct.get $lTypeIdx 0` (backing), eval
//                   `i`, then `array.get $aTypeIdx` â€” the element i32.
//   string `s[i]` â†’ eval `s` (a raw array ref), eval `i`, `array.get $aTypeIdx` â€” the
//                   i32 CODE POINT (unchanged from the fixed-array string rep).
// `array.get` is `0xfb 0x0b <typeidx>` (the `_s/_u` forms `0x0c/0x0d` are only for
// PACKED arrays; an unpacked i32 array uses `0x0b`).
function emitIndex(body: i32[], idxIx: i32, fnIx: i32): i32 {
  let nd = P.nodes[idxIx]
  if nd is Index {
    // A REF list `xs[i]` â†’ unwrap to its `(ref null $elem)` backing, `array.get`, then
    // `ref.as_non_null` (`0xd4`) to surface the non-null element (a struct ref / union
    // box) â€” slots in `[0,len)` are always populated, so the cast never traps. (Checked
    // BEFORE the `aUsed` guard: a pure ref-list program uses no i32 array.)
    if exprRefArray(nd.idxArr, fnIx) {
      if !raUsed {
        return emitFail("emitProgram: ref index access but ref array type not collected")
      }
      let rslot = refListSlotOfExpr(nd.idxArr, fnIx)
      if emitExpr(body, nd.idxArr, fnIx) < 0 { return 0 - 1 }
      fbStructGet(rlWrapIdx[rslot], 0)  // 0xfb 0x02 <ref-list wrapper> field 0: backing
      if emitExpr(body, nd.idxIndex, fnIx) < 0 { return 0 - 1 }
      fbArrayGet(rlBackIdx[rslot])      // 0xfb 0x0b <this slot's ref backing array>
      wU8(212)               // 0xd4 ref.as_non_null (recover the non-null element)
      return 0
    }
    // A STRING list `xs[i]` â†’ unwrap to its `(ref null $aTypeIdx)` string backing,
    // `array.get $mkArrIdx`, then `ref.as_non_null` to surface the non-null string ref.
    // (Checked before the i32 path: a string element is not an i32.)
    if exprStringArray(nd.idxArr, fnIx) {
      if !slUsed {
        return emitFail("emitProgram: string index access but string list type not collected")
      }
      if emitExpr(body, nd.idxArr, fnIx) < 0 { return 0 - 1 }
      fbStructGet(mkListIdx, 0)  // 0xfb 0x02 <string-list wrapper> field 0: backing
      if emitExpr(body, nd.idxIndex, fnIx) < 0 { return 0 - 1 }
      fbArrayGet(mkArrIdx)       // 0xfb 0x0b <string backing array type index>
      wU8(212)               // 0xd4 ref.as_non_null (recover the non-null string)
      return 0
    }
    if !aUsed {
      return emitFail("emitProgram: index access but array type not collected")
    }
    let isList = exprArray(nd.idxArr, fnIx)
    if !isList && !exprString(nd.idxArr, fnIx) {
      return emitFail("emitProgram: index receiver is not an array or string")
    }
    if emitExpr(body, nd.idxArr, fnIx) < 0 { return 0 - 1 }
    if isList {
      // Unwrap the list to its backing before indexing.
      fbStructGet(lTypeIdx, 0)  // 0xfb 0x02 <list wrapper struct type index> field 0: backing
    }
    if emitExpr(body, nd.idxIndex, fnIx) < 0 { return 0 - 1 }
    fbArrayGet(aTypeIdx)       // 0xfb 0x0b <raw array type index>
    return 0
  }
  emitFail("emitProgram: expected an index access")
}

// Lower a `.length` onto `body`. A list's length is its wrapper's `len` field (NOT the
// backing's physical length, which is `cap`); a string's length is the raw array's
// physical length:
//   list `a.length`   â†’ eval `a`, `struct.get $lTypeIdx 1` (the `len` field) â€” i32.
//   string `s.length` â†’ eval `s`, `array.len` (`0xfb 0x0f`, NO type-index operand,
//                        unlike `array.get`/`array.set`) â€” the code-point count.
function emitArrLen(body: i32[], memIx: i32, fnIx: i32): i32 {
  let m = P.nodes[memIx]
  if m is Member {
    // A REF list's `.length` is its wrapper's `len` field (`struct.get $wrap 1`).
    if exprRefArray(m.memObj, fnIx) {
      let rslot = refListSlotOfExpr(m.memObj, fnIx)
      if emitExpr(body, m.memObj, fnIx) < 0 { return 0 - 1 }
      fbStructGet(rlWrapIdx[rslot], 1)  // 0xfb 0x02 <ref-list wrapper> field 1: len
      return 0
    }
    // A STRING list's `.length` is its wrapper's `len` field (`struct.get $mkListIdx 1`).
    if exprStringArray(m.memObj, fnIx) {
      if emitExpr(body, m.memObj, fnIx) < 0 { return 0 - 1 }
      fbStructGet(mkListIdx, 1)  // 0xfb 0x02 <string-list wrapper> field 1: len
      return 0
    }
    let isList = exprArray(m.memObj, fnIx)
    if emitExpr(body, m.memObj, fnIx) < 0 { return 0 - 1 }
    if isList {
      fbStructGet(lTypeIdx, 1)   // 0xfb 0x02 <list wrapper struct type index> field 1: len
      return 0
    }
    fbArrayLen()             // 0xfb 0x0f array.len (no type-index operand)
    return 0
  }
  emitFail("emitProgram: expected a length access")
}

// â”€â”€ G6: string concatenation / value-equality / slice â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Strings are WasmGC `(array (mut i32))` of code points, so all three lower to the
// same array machinery the list `.push` uses (`array.new_default`/`array.copy`/
// `array.get`/`array.len`), INLINE â€” no helper functions. Each routine evaluates
// BOTH operands onto the stack FIRST, then stashes them into the shared string
// scratch frame (`strScratchBase`+0/+1/+2 = string refs A/B/Out; +3/+4/+5/+6 = i32
// temps) â€” so a NESTED string op (an operand that is itself a `+`/`==`/`.slice`)
// fully completes and leaves its result on the stack BEFORE any scratch `local.set`,
// and the single frame is safe to share. Mirrors `toWasm.ts`'s string `+`/`==`/
// `__string_slice__` shapes, just without the named helper functions.

// `local.get` of string scratch local `n` (0=A, 1=B, 2=Out).
function pushStrScrRef(body: i32[], n: i32): i32 {
  fbLocalGet(strScratchBase + n)      // 0x20 local.get
  0
}

// `local.get` of i32 scratch temp `n` (0..3 â†’ frame slots +3..+6).
function pushStrScrI(body: i32[], n: i32): i32 {
  fbLocalGet(strScratchBase + 3 + n)  // 0x20 local.get
  0
}

// `local.set` of i32 scratch temp `n`.
function setStrScrI(body: i32[], n: i32): i32 {
  fbLocalSet(strScratchBase + 3 + n)  // 0x21 local.set
  0
}

// Lower a string concatenation `a + b` onto `body`, leaving the new string ref on
// the stack. Allocate a fresh `(array i32)` of `len(a)+len(b)` (`array.new_default`,
// which zero-inits â€” every slot is then overwritten), `array.copy` a's code points
// into `[0,lenA)` and b's into `[lenA, lenA+lenB)`. Both operands are evaluated
// first, then stashed (nested-op-safe). `array.copy` is `0xfb 0x11 <dest> <src>`.
function emitStrConcat(body: i32[], binIx: i32, fnIx: i32): i32 {
  if !aUsed {
    return emitFail("emitProgram: string concat but array type not collected")
  }
  let e = P.nodes[binIx]
  if e is BinExpr {
    // Eval BOTH operands onto the stack first (nested string ops complete here),
    // then pop into the scratch refs (B first â€” it is on top).
    if emitExpr(body, e.binLeft, fnIx) < 0 { return 0 - 1 }
    if emitExpr(body, e.binRight, fnIx) < 0 { return 0 - 1 }
    fbLocalSet(strScratchBase + 1)  // local.set strScrB
    fbLocalSet(strScratchBase + 0)  // local.set strScrA
    // I0 = lenA = array.len(A)
    pushStrScrRef(body, 0)
    fbArrayLen()             // 0xfb 0x0f array.len
    setStrScrI(body, 0)
    // I1 = lenB = array.len(B)
    pushStrScrRef(body, 1)
    fbArrayLen()             // array.len
    setStrScrI(body, 1)
    // Out = array.new_default $aTypeIdx (lenA + lenB)
    pushStrScrI(body, 0)
    pushStrScrI(body, 1)
    fbI32Bin(106)            // 0x6a i32.add
    fbArrayNewDefault(aTypeIdx)   // 0xfb 0x07 array.new_default <typeidx>
    fbLocalSet(strScratchBase + 2)  // local.set strScrOut
    // array.copy Out 0 A 0 lenA
    pushStrScrRef(body, 2)   // dest
    fbI32Const(0)            // i32.const 0 (dest offset)
    pushStrScrRef(body, 0)   // src A
    fbI32Const(0)            // i32.const 0 (src offset)
    pushStrScrI(body, 0)     // count lenA
    fbArrayCopy(aTypeIdx, aTypeIdx)   // 0xfb 0x11 array.copy (dest type, src type)
    // array.copy Out lenA B 0 lenB
    pushStrScrRef(body, 2)   // dest
    pushStrScrI(body, 0)     // dest offset = lenA
    pushStrScrRef(body, 1)   // src B
    fbI32Const(0)            // i32.const 0 (src offset)
    pushStrScrI(body, 1)     // count lenB
    fbArrayCopy(aTypeIdx, aTypeIdx)   // array.copy (dest type, src type)
    // Result: the new string ref.
    pushStrScrRef(body, 2)
    return 0
  }
  emitFail("emitProgram: expected a string concatenation")
}

// Lower a string VALUE-equality `a == b` (or `a != b`) onto `body`, leaving a 0/1
// i32 on the stack. This is ELEMENT-WISE, NOT ref identity: `false` if the lengths
// differ, else loop `i in [0,len)` comparing `a[i] == b[i]`; all-equal â†’ 1. `!=`
// negates the result with `i32.eqz`. Lowered as a value-typed `block`/`loop`:
//   block i32 {                 ; yields the 0/1 result
//     A=..; B=..                 ; stash operands (nested-op-safe)
//     I0 = len(A)
//     if I0 != len(B) { (i32.const 0) br 0 }   ; length mismatch â†’ 0
//     I1 = 0                                     ; loop index
//     loop {                                     ; void loop
//       if I1 >= I0 { }            ; fall through past loop when done
//       else {
//         if A[I1] != B[I1] { (i32.const 0) br 1 }   ; mismatch â†’ 0, exit block
//         I1 = I1 + 1
//         br <loop>
//       }
//     }
//     (i32.const 1)               ; every element matched
//   }
function emitStrEq(body: i32[], binIx: i32, fnIx: i32): i32 {
  if !aUsed {
    return emitFail("emitProgram: string equality but array type not collected")
  }
  let e = P.nodes[binIx]
  if e is BinExpr {
    let isNe = e.binOp == "!="
    // Eval both operands, then stash (B on top â†’ set B first).
    if emitExpr(body, e.binLeft, fnIx) < 0 { return 0 - 1 }
    if emitExpr(body, e.binRight, fnIx) < 0 { return 0 - 1 }
    fbLocalSet(strScratchBase + 1)  // local.set strScrB
    fbLocalSet(strScratchBase + 0)  // local.set strScrA
    // block i32 { ... }  â€” yields the 0/1 result.
    fbBlock(127)             // 0x02 block, 0x7f i32 blocktype
    // I0 = len(A)
    pushStrScrRef(body, 0)
    fbArrayLen()             // array.len
    setStrScrI(body, 0)
    // if I0 != len(B) { push 0 ; br 0 (out of block) }
    pushStrScrI(body, 0)
    pushStrScrRef(body, 1)
    fbArrayLen()             // array.len(B)
    fbI32Bin(71)             // 0x47 i32.ne
    fbIf(64)                 // 0x04 if, 0x40 void blocktype
    fbI32Const(0)            // i32.const 0
    fbBr(1)                  // 0x0c br depth 1 â†’ out of the i32 block (this `if` is depth 0)
    fbEnd()                  // 0x0b end (if)
    // I1 = 0
    fbI32Const(0)
    setStrScrI(body, 1)
    // loop (void) { if I1 >= I0 {} else { compare; I1++; br loop } }
    fbLoop(64)               // 0x03 loop, 0x40 void blocktype
    pushStrScrI(body, 1)     // I1
    pushStrScrI(body, 0)     // I0
    fbI32Bin(78)             // 0x4e i32.ge_s  (I1 >= I0 â†’ done)
    fbIf(64)                 // 0x04 if, 0x40 void blocktype
    // then: done â€” fall through (empty)
    fbElse()                 // 0x05 else
    // A[I1] != B[I1] ?
    pushStrScrRef(body, 0)
    pushStrScrI(body, 1)
    fbArrayGet(aTypeIdx)     // 0xfb 0x0b array.get
    pushStrScrRef(body, 1)
    pushStrScrI(body, 1)
    fbArrayGet(aTypeIdx)     // array.get
    fbI32Bin(71)             // 0x47 i32.ne
    fbIf(64)                 // 0x04 if (mismatch â†’ 0, exit block), 0x40 void blocktype
    fbI32Const(0)            // i32.const 0
    fbBr(3)                  // 0x0c br depth 3 â†’ out of: if(0)Â·else(1)Â·loop(2)Â·block(3)
    fbEnd()                  // 0x0b end (mismatch if)
    // I1 = I1 + 1
    pushStrScrI(body, 1)
    fbI32Const(1)
    fbI32Bin(106)            // i32.add
    setStrScrI(body, 1)
    fbBr(1)                  // 0x0c br depth 1 â†’ back to the loop header (else=0, loop=1)
    fbEnd()                  // 0x0b end (else's if â€” i.e. the ge_s if)
    fbEnd()                  // 0x0b end (loop)
    // Every element matched â†’ 1.
    fbI32Const(1)            // i32.const 1
    fbEnd()                  // 0x0b end (block) â€” leaves the 0/1 result
    if isNe {
      fbI32Eqz()             // 0x45 i32.eqz  (`!=` negates value-equality)
    }
    return 0
  }
  emitFail("emitProgram: expected a string equality")
}

// Emit `clamp(idx, len)` where `idx` is in i32 temp `idxSlot` and `len` in temp
// `lenSlot`, leaving the clamped value on the stack. JS slice semantics: a negative
// index counts from the end (`len + idx`, floored at 0), a non-negative index is
// capped at `len` â€” `idx < 0 ? max(len+idx, 0) : min(idx, len)`. Built from `select`
// (`0x1b`: `[a, b, cond] -> a if cond else b`).
function emitClampIdx(body: i32[], idxSlot: i32, lenSlot: i32): i32 {
  // negCase = max(len+idx, 0) = select( len+idx, 0, (len+idx) > 0 )
  pushStrScrI(body, lenSlot)
  pushStrScrI(body, idxSlot)
  fbI32Bin(106)              // i32.add â†’ (len+idx)  [the `a` value]
  fbI32Const(0)              // i32.const 0          [the `b` value]
  pushStrScrI(body, lenSlot)
  pushStrScrI(body, idxSlot)
  fbI32Bin(106)              // i32.add â†’ (len+idx)
  fbI32Const(0)              // i32.const 0
  fbI32Bin(74)               // 0x4a i32.gt_s â†’ (len+idx) > 0   [cond]
  wU8(27)                    // 0x1b select â†’ negCase on stack
  // nonNegCase = min(idx, len) = select( idx, len, idx < len )
  pushStrScrI(body, idxSlot)         // a = idx
  pushStrScrI(body, lenSlot)         // b = len
  pushStrScrI(body, idxSlot)
  pushStrScrI(body, lenSlot)
  fbI32Bin(72)               // 0x48 i32.lt_s â†’ idx < len   [cond]
  wU8(27)                    // select â†’ nonNegCase on stack
  // result = select( negCase, nonNegCase, idx < 0 )
  // Stack currently: [negCase, nonNegCase]; push cond then select.
  pushStrScrI(body, idxSlot)
  fbI32Const(0)              // i32.const 0
  fbI32Bin(72)               // 0x48 i32.lt_s â†’ idx < 0
  wU8(27)                    // select â†’ clamped value
  0
}

// Lower a string `s.slice(start, end)` onto `body`, leaving the new string ref on
// the stack â€” a fresh `(array i32)` over the half-open clamped range `[start, end)`.
// JS semantics (mirroring `__string_slice__`): each bound clamps via `emitClampIdx`,
// the out length is `max(end - start, 0)`, then one `array.copy` from `s[start]`.
// i32 temps: I0 = clamped start, I1 = clamped end, I2 = len(s), I3 = out length.
function emitStrSlice(body: i32[], callIx: i32, fnIx: i32): i32 {
  if !aUsed {
    return emitFail("emitProgram: string slice but array type not collected")
  }
  let c = P.nodes[callIx]
  if c is Call {
    if c.callArgs.length != 2 {
      return emitFail("emitProgram: string .slice takes exactly two arguments (start, end)")
    }
    let callee = P.nodes[c.callFn]
    if callee is Member {
      // Eval receiver + both args onto the stack first (nested string ops complete),
      // then stash: end on top â†’ I1, then start â†’ I0, then receiver â†’ strScrA.
      if emitExpr(body, callee.memObj, fnIx) < 0 { return 0 - 1 }
      if emitExpr(body, c.callArgs[0], fnIx) < 0 { return 0 - 1 }
      if emitExpr(body, c.callArgs[1], fnIx) < 0 { return 0 - 1 }
      setStrScrI(body, 1)    // raw end â†’ I1
      setStrScrI(body, 0)    // raw start â†’ I0
      fbLocalSet(strScratchBase + 0)  // local.set strScrA (receiver)
      // I2 = len(s)
      pushStrScrRef(body, 0)
      fbArrayLen()           // array.len
      setStrScrI(body, 2)
      // I0 = clamp(rawStart, len)
      if emitClampIdx(body, 0, 2) < 0 { return 0 - 1 }
      setStrScrI(body, 0)
      // I1 = clamp(rawEnd, len)
      if emitClampIdx(body, 1, 2) < 0 { return 0 - 1 }
      setStrScrI(body, 1)
      // I3 = out length = max(end - start, 0) = select( end-start, 0, end > start )
      pushStrScrI(body, 1)
      pushStrScrI(body, 0)
      fbI32Bin(107)          // 0x6b i32.sub â†’ end - start   [a]
      fbI32Const(0)          // i32.const 0                  [b]
      pushStrScrI(body, 1)
      pushStrScrI(body, 0)
      fbI32Bin(74)           // 0x4a i32.gt_s â†’ end > start  [cond]
      wU8(27)                // 0x1b select
      setStrScrI(body, 3)
      // Out = array.new_default $aTypeIdx I3
      pushStrScrI(body, 3)
      fbArrayNewDefault(aTypeIdx)   // 0xfb 0x07 array.new_default <typeidx>
      fbLocalSet(strScratchBase + 2)  // local.set strScrOut
      // array.copy Out 0 s start n
      pushStrScrRef(body, 2) // dest
      fbI32Const(0)          // i32.const 0 (dest offset)
      pushStrScrRef(body, 0) // src s
      pushStrScrI(body, 0)   // src offset = clamped start
      pushStrScrI(body, 3)   // count = n
      fbArrayCopy(aTypeIdx, aTypeIdx)   // array.copy (dest type, src type)
      // Result: the new string ref.
      pushStrScrRef(body, 2)
      return 0
    }
    return emitFail("emitProgram: string .slice receiver is not a member access")
  }
  emitFail("emitProgram: expected a string slice call")
}

function emitExpr(body: i32[], exprIx: i32, fnIx: i32): i32 {
  if exprIx < 0 {
    return emitFail("emitProgram: missing expression")
  }
  let e = P.nodes[exprIx]
  if e is NumLit {
    fbI32Const(parseI32(e.numText))
    return 0
  }
  if e is BoolLit {
    // `boolean` rides in an i32: true=1, false=0 (already decoded into `boolVal`).
    fbI32Const(e.boolVal)
    return 0
  }
  if e is CharLit {
    // A char literal IS its single Unicode code point as an i32. `charText` is the RAW
    // lexeme (quotes kept, escapes unresolved), so decode it the SAME way string
    // literals decode (`decodeStr` strips the quotes + resolves escapes); a well-formed
    // char yields exactly one code point.
    let cps = decodeStr(strToCps(e.charText))
    if cps.length != 1 {
      return emitFail("emitProgram: char literal must denote exactly one code point")
    }
    fbI32Const(cps[0])
    return 0
  }
  if e is Ident {
    // A name resolves to a param (locals 0..p-1) or a declared local (locals p..).
    let idx = localIndexOf(fnIx, e.identName)
    if idx < 0 {
      // Not a local â€” a module global? Read it with `global.get` (0x23 <globalidx>).
      let gIdx = globalIndexOf(e.identName)
      if gIdx >= 0 {
        fbGlobalGet(gIdx)
        // A NON-const ref global rides in a NULLABLE cell (zero-initialized with
        // `ref.null`, set by the start function before any code runs). Recover the
        // non-null value type the rest of codegen expects with `ref.as_non_null`
        // (0xd4); the cell is always initialized first, so the cast never traps. A
        // const global keeps its non-null cell, so no cast (goldens unchanged). A
        // scalar (i32/boolean) global needs no cast either.
        if globalNameIsNonConst(e.identName) {
          if globalCellKind(globalLetOf(e.identName)) != 0 {
            wU8(212)         // 0xd4 ref.as_non_null
          }
        }
        return 0
      }
      return emitFail("emitProgram: identifier is not a parameter, local, or global")
    }
    fbLocalGet(idx)
    return 0
  }
  if e is Paren {
    return emitExpr(body, e.parInner, fnIx)
  }
  if e is Unary {
    // Logical not `!a`: a boolean rides in an i32 (0/1), so `i32.eqz` (0x45) maps
    // 0â†’1 and any non-zeroâ†’0 â€” exactly `a == 0`. Push the operand, then eqz.
    if e.unOp == "!" {
      if emitExpr(body, e.unArg, fnIx) < 0 { return 0 - 1 }
      fbI32Eqz()             // 0x45 i32.eqz
      return 0
    }
    // Integer negation: `-x` == `0 - x`, so push 0, the operand, then sub.
    if e.unOp != "-" {
      return emitFail("emitProgram: unsupported unary operator")
    }
    fbI32Const(0)
    if emitExpr(body, e.unArg, fnIx) < 0 { return 0 - 1 }
    fbI32Bin(107)            // 0x6b i32.sub
    return 0
  }
  if e is Call {
    // G6: `s.slice(start, end)` over a string receiver is an intrinsic â€” a new
    // `(array i32)` over the clamped half-open range. Other member-calls in value
    // position are out of scope (the only member-call STATEMENT is `.push`).
    if exprIsStrSlice(exprIx, fnIx) {
      return emitStrSlice(body, exprIx, fnIx)
    }
    // G8: the `Map()` builtin constructs an empty string-keyed map.
    let callee = P.nodes[e.callFn]
    if callee is Ident {
      if callee.identName == "Map" {
        return emitMapNew(body)
      }
    }
    // G8: a map `m.has(k)` member-call yields a 0/1 i32 (linear scan).
    if callee is Member {
      if callee.memProp == "has" {
        if exprMap(callee.memObj, fnIx) {
          if e.callArgs.length != 1 {
            return emitFail("emitProgram: .has takes exactly one argument")
          }
          return emitMapHas(body, callee.memObj, e.callArgs[0], fnIx)
        }
      }
      // `xs.pop()` removes + returns the last list element (any list kind).
      if callee.memProp == "pop" {
        return emitPop(body, exprIx, fnIx)
      }
    }
    return emitCall(body, exprIx, fnIx)
  }
  if e is IsExpr {
    return emitIs(body, exprIx, fnIx)
  }
  if e is ObjLit {
    // A literal whose field-set matches a STANDALONE struct constructs that struct
    // directly (even alongside a union â€” `ast.vl`'s `Tok`/`Diag` coexist with `Node`).
    // Otherwise, in a union program, it is a union variant: box it `{tag, value}`.
    if structIndexOfObj(exprIx) >= 0 {
      return emitObj(body, exprIx, fnIx)
    }
    if uDeclared {
      return emitUnionBox(body, exprIx, fnIx)
    }
    return emitObj(body, exprIx, fnIx)
  }
  if e is StrLit {
    return emitStr(body, exprIx, fnIx)
  }
  if e is ArrayLit {
    return emitArr(body, exprIx, fnIx)
  }
  if e is Index {
    // G8: a map GET `m[k]` (no `??`) â€” scan, value or 0. A `??` get is fused in the
    // BinExpr branch below (it carries the default).
    if exprMap(e.idxArr, fnIx) {
      return emitMapGet(body, e.idxArr, e.idxIndex, fnIx)
    }
    return emitIndex(body, exprIx, fnIx)
  }
  if e is Member {
    // `a.length` on an array OR string receiver is `array.len` (a string is the SAME
    // `array i32` of code points, so `.length` is the code-point count); every other
    // member access is a struct field read. `length` over a non-array/non-string
    // receiver falls through to the struct path (which fails loudly if no such field),
    // matching the slice's scope.
    if e.memProp == "length" {
      if exprArray(e.memObj, fnIx) || exprString(e.memObj, fnIx) || exprRefArray(e.memObj, fnIx) || exprStringArray(e.memObj, fnIx) {
        return emitArrLen(body, exprIx, fnIx)
      }
    }
    return emitMem(body, exprIx, fnIx)
  }
  if e is BinExpr {
    // Assignment (`=`) is a STATEMENT, not a value expression in this slice: it has
    // no result on the stack (it `local.set`s). It is lowered by `emitAssign` from
    // `emitStmt`, so seeing it as an operand here is an unsupported nested-assignment.
    if e.binOp == "=" {
      return emitFail("emitProgram: assignment is not a value expression")
    }
    // G8: nullish-coalescing `m[k] ?? d` â€” a FUSED map get-with-default: scan `m` for
    // `k`, push `vals[hit]` on a hit else the default `d`. The self-host checker reads
    // every scope map through `?? -1`. The LHS must be a map index in this slice.
    if e.binOp == "??" {
      let lhs = P.nodes[e.binLeft]
      if lhs is Index {
        if exprMap(lhs.idxArr, fnIx) {
          return emitMapGetOr(body, lhs.idxArr, lhs.idxIndex, e.binRight, fnIx)
        }
      }
      return emitFail("emitProgram: `??` is only supported on a map index get")
    }
    // Short-circuit logical operators lower to a VALUE-TYPED `if` (blocktype 0x7f),
    // an `if` expression that leaves one i32 on the stack â€” both arms push an i32:
    //   `a && b`  â‰¡  if (a) { b } else { 0 }   (skip b when a is false â†’ 0)
    //   `a || b`  â‰¡  if (a) { 1 } else { b }   (skip b when a is true  â†’ 1)
    // The condition `a` is evaluated first, then `if 0x04` with i32 result-type
    // blocktype `0x7f`; the then-branch, `else 0x05`, the else-branch, then `end 0x0b`.
    if e.binOp == "&&" || e.binOp == "||" {
      if emitExpr(body, e.binLeft, fnIx) < 0 { return 0 - 1 }   // condition `a`
      fbIf(127)                // 0x04 if, 0x7f i32 result-type blocktype (yields an i32)
      if e.binOp == "&&" {
        // then = b, else = 0
        if emitExpr(body, e.binRight, fnIx) < 0 { return 0 - 1 }
        fbElse()               // 0x05 else
        fbI32Const(0)
      } else {
        // then = 1, else = b
        fbI32Const(1)
        fbElse()               // 0x05 else
        if emitExpr(body, e.binRight, fnIx) < 0 { return 0 - 1 }
      }
      fbEnd()                  // 0x0b end
      return 0
    }
    // G6 string operators (a string is a `(array i32)` of code points): `+` is a NEW
    // concatenated array; `==`/`!=` are ELEMENT-WISE value-equality, NOT ref identity
    // â€” so they take their own inline lowering BEFORE the i32 `binOpcode` path (which
    // would emit `i32.eq` = ref identity, the WRONG answer for strings). Only string-
    // typed operands route here; i32/other-type `+`/`==`/`!=` are unchanged.
    if exprIsStrConcat(exprIx, fnIx) {
      return emitStrConcat(body, exprIx, fnIx)
    }
    if exprIsStrEq(exprIx, fnIx) {
      return emitStrEq(body, exprIx, fnIx)
    }
    let opcode = binOpcode(e.binOp)
    if opcode < 0 {
      return emitFail("emitProgram: unsupported binary operator")
    }
    // Operands first (left then right), then the operator â€” wasm's stack order.
    if emitExpr(body, e.binLeft, fnIx) < 0 { return 0 - 1 }
    if emitExpr(body, e.binRight, fnIx) < 0 { return 0 - 1 }
    fbI32Bin(opcode)
    return 0
  }
  emitFail("emitProgram: unsupported expression in return")
}

// Lower a call expression at `callIx` onto `body`: evaluate every argument left-to-
// right (each pushes one i32), then `call <funcIndex>`. The callee must be a bare
// `Ident` naming a top-level function (no indirect/computed calls in this slice);
// its index comes from the function-index map, so a recursive call resolves to the
// enclosing function's own already-mapped index.
//
// Node shapes read: Call { callFn: i32, callArgs: i32[] }, callee Ident { identName }.
function emitCall(body: i32[], callIx: i32, fnIx: i32): i32 {
  let c = P.nodes[callIx]
  if c is Call {
    let callee = P.nodes[c.callFn]
    if callee is Ident {
      // `fromCodePoint(code)` is a compiler builtin (H2): construct a single-character
      // VL string from an i32 code point. A VL string IS the shared `(array i32)` of
      // code points (`aTypeIdx`), so this is a length-1 array â€” push the one i32 arg,
      // then `array.new_fixed $aTypeIdx 1`. Mirrors toWasm's `fromCodePoint` lowering.
      // BEFORE the `fnIndexOf` lookup, which would fail ("unknown function").
      if callee.identName == "fromCodePoint" {
        if !aUsed {
          return emitFail("emitProgram: fromCodePoint but array type not collected")
        }
        if c.callArgs.length != 1 {
          return emitFail("emitProgram: fromCodePoint takes exactly one argument")
        }
        if emitExpr(body, c.callArgs[0], fnIx) < 0 { return 0 - 1 }
        fbArrayNewFixed(aTypeIdx, 1)  // 0xfb 0x08 <typeidx> 1; type shared with i32[]
        return 0
      }
      let target = fnIndexOf(callee.identName)
      if target < 0 {
        return emitFail("emitProgram: call to unknown function")
      }
      // The callee's FuncDecl lives at `fnStmts[target]` (the function index IS the
      // fnStmts position). Its parameter list lets a struct-literal argument construct as
      // the callee's DECLARED param struct type rather than a field-name guess â€” the fix
      // for passing a struct value into a forward-referenced / mutually-recursive callee
      // whose param struct shares field names with another struct.
      let cFn = P.nodes[fnStmts[target]]
      let args = c.callArgs
      let i = 0
      while i < args.length {
        // If this argument position is a struct-typed parameter, hint `emitObj` with the
        // callee's struct index (consumed by the immediately-following object-literal
        // lowering; a non-literal argument simply ignores it). Default -1 = infer.
        pendingStructIdx = 0 - 1
        // A VARIANT-typed param position (kind 8): the callee wants the CONCRETE variant
        // struct ref, but a union-valued argument (a narrowed local/param, a union-
        // returning call) is the BOX `{tag, value}`. Bridge the boundary by unboxing the
        // arg to the param's variant struct â€” `struct.get $box 1 ; ref.cast (ref $var)`
        // (gap #2). The cast is statically safe: control reached this call only with the
        // arg narrowed to this variant.
        let cVi = 0 - 1
        if cFn is FuncDecl {
          let cParams = cFn.fnParams
          if i < cParams.length {
            if vtKindOfParam(cParams[i]) == 1 {
              pendingStructIdx = paramStructIdxOf(cParams[i])
            }
            if vtKindOfParam(cParams[i]) == 8 {
              cVi = paramStructIdxOf(cParams[i])
            }
          }
        }
        if emitExpr(body, args[i], fnIx) < 0 { return 0 - 1 }
        if cVi >= 0 {
          if exprUnion(args[i], fnIx) {
            fbStructGet(uBoxIdx, 1)   // 0xfb 0x02 <box ht> field 1: value (anyref)
            fbRefCast(uVarIdx + cVi)  // 0xfb 0x16 <variant struct> ref.cast (non-null)
          }
        }
        pendingStructIdx = 0 - 1
        i = i + 1
      }
      fbCall(target)         // 0x10 call
      return 0
    }
    return emitFail("emitProgram: callee is not a function name")
  }
  emitFail("emitProgram: expected a call expression")
}

// â”€â”€ statement-sequence lowering â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// A function body is a SEQUENCE of statements, lowered onto `body` in order. Only
// `return` and `if` are handled; `else if` chains fall out naturally because an
// `IfStmt`'s `ifElse` may itself be an `IfStmt` (lowered recursively). Control flow
// is kept simple by relying on explicit `return`s rather than block result types:
// a `return` leaves its value and emits the `return` instruction (0x0f), and an
// `if` is a VOID structured block (blocktype 0x40) whose branches `return` on their
// own â€” so the `if` never has to yield a value, and no block result type is needed.

// Lower an assignment `target = value` (a `BinExpr` whose `binOp` is `"="`) onto
// `body`: emit the value expression, then `local.set <index>` for the target local.
// The target must be a bare `Ident` naming a param or declared local (no member /
// indexed assignment in this slice). `local.set` consumes the value and leaves no
// result, so an assignment statement contributes nothing to the stack. Returns 0,
// or -1 (via `emitFail`) on a non-local / unsupported target.
//
// Node shapes read: BinExpr { binOp, binLeft, binRight }, target Ident { identName }.
function emitAssign(body: i32[], binIx: i32, fnIx: i32): i32 {
  let a = P.nodes[binIx]
  if a is BinExpr {
    let target = P.nodes[a.binLeft]
    if target is Ident {
      let idx = localIndexOf(fnIx, target.identName)
      if idx < 0 {
        // Not a local â€” a module global? Store with `global.set` (0x24 <globalidx>).
        let gIdx = globalIndexOf(target.identName)
        if gIdx >= 0 {
          if emitExpr(body, a.binRight, fnIx) < 0 { return 0 - 1 }
          fbGlobalSet(gIdx)    // 0x24 global.set
          return 0
        }
        return emitFail("emitProgram: assignment target is not a parameter, local, or global")
      }
      // Value first, then store it into the local's slot.
      if emitExpr(body, a.binRight, fnIx) < 0 { return 0 - 1 }
      fbLocalSet(idx)        // 0x21 local.set
      return 0
    }
    if target is Index {
      // G8: a map store `m[k] = v` â€” scan for `k`; overwrite `vals[hit]` on a hit, else
      // append `keys.push(k); vals.push(v)`. Checked BEFORE the list path (a map index
      // is not an array index).
      if exprMap(target.idxArr, fnIx) {
        return emitMapSet(body, target.idxArr, target.idxIndex, a.binRight, fnIx)
      }
      // Indexed store `a[i] = v`: unwrap the list to its backing (`struct.get $lTy 0`),
      // push the index, then the value, then `array.set $aTy` (`0xfb 0x0e <typeidx>`). A
      // REF list (G7-ref) stores a struct ref / union box (a subtype of the `(ref null
      // $elem)` slot) over the ref list/backing indices; an i32 list stores an i32.
      let isRef = exprRefArray(target.idxArr, fnIx)
      let lTy = lTypeIdx
      let aTy = aTypeIdx
      if isRef {
        if !rlUsed {
          return emitFail("emitProgram: ref indexed assignment but ref list type not collected")
        }
        let rslot = refListSlotOfExpr(target.idxArr, fnIx)
        lTy = rlWrapIdx[rslot]
        aTy = rlBackIdx[rslot]
      } else {
        if !lUsed {
          return emitFail("emitProgram: indexed assignment but list type not collected")
        }
        if !exprArray(target.idxArr, fnIx) {
          return emitFail("emitProgram: indexed-assignment target is not an array")
        }
      }
      if emitExpr(body, target.idxArr, fnIx) < 0 { return 0 - 1 }
      fbStructGet(lTy, 0)    // 0xfb 0x02 <list wrapper struct type index> field 0: backing
      if emitExpr(body, target.idxIndex, fnIx) < 0 { return 0 - 1 }
      if emitExpr(body, a.binRight, fnIx) < 0 { return 0 - 1 }
      fbArraySet(aTy)        // 0xfb 0x0e <backing array type index>
      return 0
    }
    if target is Member {
      // Field WRITE `recv.field = v` â†’ `struct.set $0 <fieldidx>` (`0xfb 0x05`). The
      // single declared struct lives at WasmGC type index 0 (matching `emitMem`'s read
      // path). Operand order is load-bearing: push the struct REF first, then the value,
      // then the `fb 05` opcode pops `[ref, value]` (same shape `emitPush` uses for the
      // list `backing`/`len`/`cap` field stores).
      if !sDeclared {
        return emitFail("emitProgram: field assignment but no struct type declared")
      }
      let si = structIndexOfExpr(target.memObj, fnIx)
      if si < 0 {
        return emitFail("emitProgram: field-assignment receiver is not a struct")
      }
      let fieldIdx = sFieldIndex(si, target.memProp)
      if fieldIdx < 0 {
        return emitFail("emitProgram: unknown struct field in field assignment")
      }
      if emitExpr(body, target.memObj, fnIx) < 0 { return 0 - 1 }   // struct ref first
      // An empty `[]` for an array-typed field needs its element kind threaded so the
      // wrapper matches the field's declared type â€” the same `pendingListKind` an
      // annotated `let xs: T[] = []` or an object-literal array field uses (else the
      // empty literal defaults to the i32-list wrapper and the `struct.set` rejects it).
      pendingListKind = 0
      pendingListSlot = 0
      let fscode = sFieldTypeAt(si, fieldIdx)
      if fscode == 5 {
        let faslot = sFieldRefSlot(si, fieldIdx)
        if faslot < 0 { faslot = 0 }
        pendingListSlot = faslot
        if rlElemKindTbl[faslot] == 2 { pendingListKind = 2 } else { pendingListKind = 1 }
      } else if fscode == 6 {
        pendingListKind = 3
      }
      if emitExpr(body, a.binRight, fnIx) < 0 { return 0 - 1 }      // then the value
      pendingListKind = 0
      fbStructSet(sHeapIdx[si], fieldIdx)   // 0xfb 0x05 <struct ht> <field index>
      return 0
    }
    return emitFail("emitProgram: assignment target is not a simple name")
  }
  emitFail("emitProgram: expected an assignment expression")
}

// Lower a `recv.push(x)` member-call statement onto `body` â€” the growable-list append
// (mirroring `toWasm.ts`'s `__list_grow__`/`__list_push__`, but INLINED). `recv` must be
// a bare `Ident` naming a LIST local/param (so its `local.get` is side-effect-free and
// can be re-read), and the call takes exactly one i32 argument.
//
// The sequence, with `L` = the list local index and scratch locals `pushVal` (V),
// `pushNewCap` (NC), `pushNewBacking` (NB):
//   V = x                                              ; stash the value
//   if len(L) == cap(L) {                              ; grow when full
//     NC = (cap(L) == 0) ? 4 : cap(L) * 2              ; 2Ã— growth, floor 4 (Â§VL.2)
//     NB = array.new_default $aTypeIdx NC              ; zero-init spare slots
//     array.copy NB 0 backing(L) 0 len(L)              ; copy the live elements
//     L.backing = NB ; L.cap = NC                      ; swap in the larger backing
//   }
//   backing(L)[len(L)] = V                             ; write at the end
//   L.len = len(L) + 1                                 ; bump the length
// `len`/`cap`/`backing` are `struct.get $lTy` of fields 1/2/0; the field setters are
// `struct.set $lTy`. `array.copy` is `0xfb 0x11 <dest> <src>` (both the backing array).
//
// G7-ref: a REF-list `.push` runs the IDENTICAL sequence over the ref list/backing type
// indices + ref scratch triple (`lTy = rlTypeIdx`, `aTy = raTypeIdx`, scratch base
// `refPushScratchBase`). The value is a struct ref / union box (emitted by the SAME
// `emitExpr`); `array.new_default` over the `(ref null $elem)` backing zero-inits spare
// slots to null, and `array.set` writes the non-null value (a subtype of the slot).
function emitPush(body: i32[], callIx: i32, fnIx: i32): i32 {
  let c = P.nodes[callIx]
  if c is Call {
    let callee = P.nodes[c.callFn]
    if callee is Member {
      let recv = P.nodes[callee.memObj]
      // The receiver must PRODUCE a list â€” either a bare list local/param (`xs.push`) or
      // a struct-FIELD array read (`P.nodes.push`, gap #3). Both `exprArray`/`exprRefArray`
      // already classify a `Member` array-field read, so the only extra work for a field
      // receiver is to materialize its wrapper ref into the `recvRef` scratch slot.
      let isRef = exprRefArray(callee.memObj, fnIx)
      let isStr = exprStringArray(callee.memObj, fnIx)
      if !isRef && !isStr && !exprArray(callee.memObj, fnIx) {
        return emitFail("emitProgram: .push receiver is not a list")
      }
      // Pick the list/backing type indices + scratch base for this push kind. A string
      // list (`string[]`) runs the IDENTICAL grow/append sequence over its wrapper/backing
      // (`mkListIdx`/`mkArrIdx`) + the string-push quad: `array.new_default` over the
      // `(ref null $aTypeIdx)` backing zero-inits spare slots to null, and `array.set`
      // writes the non-null string ref (a subtype of the slot).
      let lTy = lTypeIdx
      let aTy = aTypeIdx
      let base = pushScratchBase
      if isRef {
        if !rlUsed {
          return emitFail("emitProgram: ref .push but ref list type not collected")
        }
        let rslot = refListSlotOfExpr(callee.memObj, fnIx)
        lTy = rlWrapIdx[rslot]
        aTy = rlBackIdx[rslot]
        base = refPushScratchBaseFor(rslot)
      } else if isStr {
        if !slUsed {
          return emitFail("emitProgram: string .push but string list type not collected")
        }
        lTy = mkListIdx
        aTy = mkArrIdx
        base = strPushScratchBase
      } else if !lUsed {
        return emitFail("emitProgram: .push but list type not collected")
      }
      // Resolve the receiver to a wasm local index holding the list-wrapper ref. A bare
      // identifier IS such a local. A struct-FIELD receiver (`P.nodes`) is evaluated once
      // into the `recvRef` scratch slot (`base + 3`); because the wrapper is mutated IN
      // PLACE by reference, pushing through the scratch local also mutates the field's
      // list â€” no write-back needed.
      let lIdx = 0 - 1
      if recv is Ident {
        lIdx = localIndexOf(fnIx, recv.identName)
        if lIdx < 0 {
          // Not a local â€” a module-GLOBAL list ident? Materialize its wrapper ref into
          // the `recvRef` scratch slot (`base + 3`), IDENTICALLY to the Member path:
          // `emitExpr` on the receiver runs the existing Identâ†’global read (`global.get`
          // + `ref.as_non_null` for a non-const ref cell). Because the list wrapper is
          // mutated IN PLACE by reference, pushing through the scratch local also mutates
          // the global's list â€” and growth swaps the backing on the shared wrapper â€” so
          // no write-back to the global is needed.
          if globalIndexOf(recv.identName) < 0 {
            return emitFail("emitProgram: .push receiver is not a list local")
          }
          if emitExpr(body, callee.memObj, fnIx) < 0 { return 0 - 1 }
          fbLocalSet(base + 3)   // local.set recvRef
          lIdx = base + 3
        }
      } else if recv is Member {
        if emitExpr(body, callee.memObj, fnIx) < 0 { return 0 - 1 }
        fbLocalSet(base + 3)   // local.set recvRef
        lIdx = base + 3
      } else {
        return emitFail("emitProgram: .push receiver must be a local or struct field")
      }
      if true {
        if c.callArgs.length != 1 {
          return emitFail("emitProgram: .push takes exactly one argument")
        }
        let valIdx = base
        let capIdx = base + 1
        let backIdx = base + 2
        // V = x
        if emitExpr(body, c.callArgs[0], fnIx) < 0 { return 0 - 1 }
        fbLocalSet(valIdx)     // local.set
        // if len(L) == cap(L)
        pushListLen(body, lIdx, lTy)
        pushListCap(body, lIdx, lTy)
        fbI32Bin(70)           // 0x46 i32.eq
        fbIf(64)               // 0x04 if, 0x40 void blocktype
        // NC = (cap(L) == 0) ? 4 : cap(L) * 2   â€” via if/else yielding i32
        pushListCap(body, lIdx, lTy)
        fbI32Eqz()             // 0x45 i32.eqz  (cap == 0)
        fbIf(127)              // 0x04 if, 0x7f i32 blocktype (yields an i32)
        fbI32Const(4)          // i32.const 4
        fbElse()               // 0x05 else
        pushListCap(body, lIdx, lTy)
        fbI32Const(2)          // i32.const 2
        fbI32Bin(108)          // 0x6c i32.mul
        fbEnd()                // 0x0b end (if/else)
        fbLocalSet(capIdx)     // local.set NC
        // NB = array.new_default $aTy NC
        fbLocalGet(capIdx)     // local.get NC
        fbArrayNewDefault(aTy) // 0xfb 0x07 <aTy>
        fbLocalSet(backIdx)    // local.set NB
        // array.copy NB 0 backing(L) 0 len(L)
        fbLocalGet(backIdx)    // local.get NB (dest)
        fbI32Const(0)          // i32.const 0 (dest offset)
        pushListBacking(body, lIdx, lTy)   // src
        fbI32Const(0)          // i32.const 0 (src offset)
        pushListLen(body, lIdx, lTy)       // count
        fbArrayCopy(aTy, aTy)  // 0xfb 0x11 <dest type> <src type>
        // L.backing = NB
        fbLocalGet(lIdx)       // local.get L
        fbLocalGet(backIdx)    // local.get NB
        fbStructSet(lTy, 0)    // 0xfb 0x05 <lTy> field 0: backing
        // L.cap = NC
        fbLocalGet(lIdx)       // local.get L
        fbLocalGet(capIdx)     // local.get NC
        fbStructSet(lTy, 2)    // 0xfb 0x05 <lTy> field 2: cap
        fbEnd()                // 0x0b end (if)
        // backing(L)[len(L)] = V
        pushListBacking(body, lIdx, lTy)
        pushListLen(body, lIdx, lTy)
        fbLocalGet(valIdx)     // local.get V
        fbArraySet(aTy)        // 0xfb 0x0e <aTy>
        // L.len = len(L) + 1
        fbLocalGet(lIdx)       // local.get L
        pushListLen(body, lIdx, lTy)
        fbI32Const(1)          // i32.const 1
        fbI32Bin(106)          // 0x6a i32.add
        fbStructSet(lTy, 1)    // 0xfb 0x05 <lTy> field 1: len
        return 0
      }
    }
  }
  emitFail("emitProgram: expected a .push call")
}

// Lower a `.pop()` value-position call onto `body`: remove + return the list's last
// element. Generic over the list kind â€” picks the wrapper/backing type indices the same
// way `.push` does (i32 list, REF list `T[]`/`N[]`/`{[string]:i32}[]`, or string list).
// Sequence (no scratch â€” the receiver is a bare local, referenced repeatedly):
//   L.len = len - 1            (decrement first, so the new len IS the popped index)
//   push backing[L.len]        (the removed element; `ref.as_non_null` for a ref/string
//                               element so a non-null struct/union/map/string surfaces)
// The receiver must be a bare list local. An empty-list pop is the caller's contract
// (reading `backing[-1]` would trap) â€” matched to the host semantics of `.pop()`.
function emitPop(body: i32[], callIx: i32, fnIx: i32): i32 {
  let c = P.nodes[callIx]
  if c is Call {
    let callee = P.nodes[c.callFn]
    if callee is Member {
      let recv = P.nodes[callee.memObj]
      if c.callArgs.length != 0 {
        return emitFail("emitProgram: .pop takes no arguments")
      }
      let isRef = exprRefArray(callee.memObj, fnIx)
      let isStr = exprStringArray(callee.memObj, fnIx)
      if !isRef && !isStr && !exprArray(callee.memObj, fnIx) {
        return emitFail("emitProgram: .pop receiver is not a list")
      }
      // The popped element is a REF (struct / union box / map struct / string) for a
      // ref or string list â€” surface it non-null; an i32 list yields a raw i32. `base` is
      // the scratch frame whose `+3` `recvRef` slot holds a struct-FIELD receiver's wrapper
      // ref (same frame `.push` uses) â€” used only for a Member receiver.
      let lTy = lTypeIdx
      let aTy = aTypeIdx
      let base = pushScratchBase
      let elemIsRef = false
      if isRef {
        if !rlUsed {
          return emitFail("emitProgram: ref .pop but ref list type not collected")
        }
        let rslot = refListSlotOfExpr(callee.memObj, fnIx)
        lTy = rlWrapIdx[rslot]
        aTy = rlBackIdx[rslot]
        base = refPushScratchBaseFor(rslot)
        elemIsRef = true
      } else if isStr {
        if !slUsed {
          return emitFail("emitProgram: string .pop but string list type not collected")
        }
        lTy = mkListIdx
        aTy = mkArrIdx
        base = strPushScratchBase
        elemIsRef = true
      } else if !lUsed {
        return emitFail("emitProgram: .pop but list type not collected")
      }
      // Resolve the receiver to a wasm local holding the list-wrapper ref. A bare local IS
      // that local; a struct-FIELD receiver (`T.scopes`) is evaluated ONCE into the frame's
      // `recvRef` scratch (`base + 3`) â€” the wrapper is mutated in place by reference, so no
      // write-back is needed (mirrors `emitPush`).
      let lIdx = 0 - 1
      if recv is Ident {
        lIdx = localIndexOf(fnIx, recv.identName)
        if lIdx < 0 {
          // Not a local â€” a module-GLOBAL list ident? Materialize its wrapper ref into
          // the `recvRef` scratch slot (`base + 3`), IDENTICALLY to the Member path (and
          // to `emitPush`): `emitExpr` runs the existing Identâ†’global read; the wrapper is
          // mutated in place by reference, so no write-back to the global is needed.
          if globalIndexOf(recv.identName) < 0 {
            return emitFail("emitProgram: .pop receiver is not a list local")
          }
          if emitExpr(body, callee.memObj, fnIx) < 0 { return 0 - 1 }
          fbLocalSet(base + 3)     // local.set recvRef
          lIdx = base + 3
        }
      } else if recv is Member {
        if emitExpr(body, callee.memObj, fnIx) < 0 { return 0 - 1 }
        fbLocalSet(base + 3)     // local.set recvRef
        lIdx = base + 3
      } else {
        return emitFail("emitProgram: .pop receiver must be a local or struct field")
      }
      if true {
        // L.len = len - 1
        fbLocalGet(lIdx)       // local.get L
        pushListLen(body, lIdx, lTy)
        fbI32Const(1)          // i32.const 1
        fbI32Bin(107)          // 0x6b i32.sub
        fbStructSet(lTy, 1)    // 0xfb 0x05 <lTy> field 1: len
        // backing[L.len]  (the just-decremented len is the popped element's index)
        pushListBacking(body, lIdx, lTy)
        pushListLen(body, lIdx, lTy)
        fbArrayGet(aTy)        // 0xfb 0x0b <aTy>
        if elemIsRef {
          wU8(212)             // 0xd4 ref.as_non_null
        }
        return 0
      }
    }
  }
  emitFail("emitProgram: expected a .pop call")
}

// `local.get L ; struct.get $lTy 1` â€” push the list's `len` field onto `body`.
function pushListLen(body: i32[], lIdx: i32, lTy: i32): i32 {
  fbLocalGet(lIdx)           // local.get
  fbStructGet(lTy, 1)        // 0xfb 0x02 <lTy> field 1: len
  0
}

// `local.get L ; struct.get $lTy 2` â€” push the list's `cap` field onto `body`.
function pushListCap(body: i32[], lIdx: i32, lTy: i32): i32 {
  fbLocalGet(lIdx)           // local.get
  fbStructGet(lTy, 2)        // 0xfb 0x02 <lTy> field 2: cap
  0
}

// `local.get L ; struct.get $lTy 0` â€” push the list's `backing` ref onto `body`.
function pushListBacking(body: i32[], lIdx: i32, lTy: i32): i32 {
  fbLocalGet(lIdx)           // local.get
  fbStructGet(lTy, 0)        // 0xfb 0x02 <lTy> field 0: backing
  0
}

// If the `if` condition at `condIx` is `n is Variant` over a bare union identifier
// `n`, PUSH the narrowing (`narrowNames`/`narrowVariants`) so the then-branch's
// `n.field` reads downcast through the box, and return true. Otherwise leave the
// narrowing stack untouched and return false. A non-identifier receiver (e.g. `f(x) is
// A`) is not narrowable (no stable name to re-read) and is left un-narrowed. The caller
// saves the stack length and truncates back on branch exit (`restoreNarrow`).
function setNarrowFromCond(condIx: i32, fnIx: i32): boolean {
  let c = P.nodes[condIx]
  if c is IsExpr {
    let recv = P.nodes[c.isObj]
    if recv is Ident {
      if exprUnion(c.isObj, fnIx) {
        pushNarrow(recv.identName, c.isVariant)
        return true
      }
    }
  }
  false
}

// Rewind the narrowing stack depth back to `n` (drop bindings a branch pushed). The
// arrays keep their backing slots â€” only the logical depth changes, so no `.pop()`.
function restoreNarrow(n: i32): i32 {
  narrowTop = n
  0
}

// Lower a single statement at `stmtIx` onto `body`, resolving identifiers/params
// against function `fnIx`. Returns 0, or -1 (via `emitFail`) on an unsupported shape.
//
// Node shapes read (all from `compiler/ast.vl`):
//   LetDecl { letName, letType, letInit }         â€” `let`/`const` local declaration.
//   RetStmt { retArg: i32 }                       â€” `retArg` -1 means a bare return.
//   IfStmt  { ifCond: i32, ifThen: i32, ifElse: i32 }
//   BinExpr { binOp, binLeft, binRight }          â€” an assignment expression statement.
//   Call    { callFn, callArgs }                  â€” a `recv.push(x)` member-call.
//   Block   { blkStmts: i32[] }
function emitStmt(body: i32[], stmtIx: i32, fnIx: i32): i32 {
  if stmtIx < 0 {
    return emitFail("emitProgram: missing statement")
  }
  let s = P.nodes[stmtIx]
  if s is LetDecl {
    // `let x = <expr>` / `const x = <expr>`: emit the init, then store it into the
    // local's slot. This `LetDecl`'s slot is the next cursor position (collect allocated
    // slots in this SAME pre-order), so it owns declared-local slot `emitLetCursor` â€”
    // do NOT name-resolve it (a name lookup would hit an outer same-named binding still
    // in scope here). `paramN + slot` is its wasm local index.
    let slot = emitLetCursor
    emitLetCursor = emitLetCursor + 1
    let paramN = 0
    let fn = P.nodes[fnIx]
    if fn is FuncDecl { paramN = fn.fnParams.length }
    let idx = paramN + slot
    if s.letInit < 0 {
      return emitFail("emitProgram: local declaration needs an initializer")
    }
    // An empty `[]` initializer over a ref-array annotation (`let xs: T[] = []`) needs
    // the element kind to pick the ref-list construction â€” record it for `emitArr`.
    pendingListKind = letAnnRefListKind(stmtIx)
    pendingListSlot = letAnnRefListSlot(stmtIx)
    if emitExpr(body, s.letInit, fnIx) < 0 { return 0 - 1 }
    pendingListKind = 0
    pendingListSlot = 0
    fbLocalSet(idx)          // 0x21 local.set
    // Bind `name â†’ slot` in the current emit-time frame AFTER emitting the init (so the
    // init resolved any same-named OUTER binding), making this binding live for the rest
    // of the block â€” mirrors the collect pass so resolution matches slot allocation.
    scopeBind(s.letName, slot)
    return 0
  }
  if s is BinExpr {
    // A bare `BinExpr` statement is an assignment (`x = <expr>`); any other operator
    // in statement position is a discarded value, which this slice does not emit.
    if s.binOp == "=" {
      return emitAssign(body, stmtIx, fnIx)
    }
    return emitFail("emitProgram: expression statement is not an assignment")
  }
  if s is Call {
    // The only call STATEMENT this slice lowers is a list append `recv.push(x)` (a
    // `Call` whose `callFn` is a `Member`). A bare top-level call statement (a function
    // call whose value is discarded) is out of scope.
    let callee = P.nodes[s.callFn]
    if callee is Member {
      if callee.memProp == "push" {
        return emitPush(body, stmtIx, fnIx)
      }
      // A `.pop()` STATEMENT discards the popped element â€” emit the pop, then `drop`
      // the value it leaves on the stack.
      if callee.memProp == "pop" {
        if emitPop(body, stmtIx, fnIx) < 0 { return 0 - 1 }
        fbDrop()               // 0x1a drop
        return 0
      }
      return emitFail("emitProgram: unsupported member-call statement")
    }
    if callee is Ident {
      // A bare top-level call whose RESULT is discarded (e.g. a helper invoked for its
      // global side effects): emit the call, then `drop` the single value it leaves on
      // the stack (every function returns one value here).
      if emitCall(body, stmtIx, fnIx) < 0 { return 0 - 1 }
      fbDrop()                 // 0x1a drop
      return 0
    }
    return emitFail("emitProgram: bare call statement is not supported")
  }
  if s is RetStmt {
    if s.retArg < 0 {
      return emitFail("emitProgram: bare return is not supported")
    }
    // Push the return value, then the `return` instruction.
    if emitExpr(body, s.retArg, fnIx) < 0 { return 0 - 1 }
    fbReturn()               // 0x0f return
    return 0
  }
  if s is IfStmt {
    // Structured void `if`: push the i32 condition, then `if 0x04` with void
    // blocktype `0x40`. The then-branch's statements run when the condition is
    // non-zero; an optional `else 0x05` branch runs otherwise; `end 0x0b` closes it.
    // Both branches `return` on their own, so the `if` yields no value.
    if emitExpr(body, s.ifCond, fnIx) < 0 { return 0 - 1 }
    fbIf(64)                 // 0x04 if, 0x40 void blocktype
    // The `if` opens ONE control frame (the `else` reuses it, `end` closes it), so a
    // `break`/`continue` nested in either arm sees the right relative `br` depth.
    ctrlEnter()
    // If the condition is `n is Variant` over a bare union identifier, narrow `n` to
    // that variant for the THEN-branch only (so `n.field` downcasts). Save/restore the
    // outer narrowing around the branch so nesting and the else-branch are unaffected.
    let savedTop = narrowTop
    let narrowed = setNarrowFromCond(s.ifCond, fnIx)
    if emitStmts(body, s.ifThen, fnIx) < 0 { return 0 - 1 }
    if narrowed {
      restoreNarrow(savedTop)
    }
    if s.ifElse >= 0 {
      fbElse()               // 0x05 else
      // The else may be a Block or a nested IfStmt (`else if`); both go through
      // `emitStmt` (a lone statement) â€” a Block re-enters `emitStmts`. The narrowing
      // does NOT hold in the else-branch (the guard was false there).
      let els = P.nodes[s.ifElse]
      if els is Block {
        if emitStmts(body, s.ifElse, fnIx) < 0 { return 0 - 1 }
      } else {
        if emitStmt(body, s.ifElse, fnIx) < 0 { return 0 - 1 }
      }
    }
    fbEnd()                  // 0x0b end
    ctrlLeave()
    return 0
  }
  if s is WhileStmt {
    // Structured while loop: block (void) wrapping a loop (void).
    // The condition is checked at the top; if false (eqz), br_if 1 exits the block;
    // body runs, then br 0 continues the loop. Two `end` bytes close loop then block.
    // Track the two control frames so `break`/`continue` in the body compute their
    // relative `br` depth: the BLOCK is the `break` target (resume after the loop),
    // the LOOP is the `continue` target (re-check the condition). Push the ABSOLUTE
    // `ctrlDepth` of each frame; a branch site at depth D uses `D - <that depth>`.
    fbBlock(64)              // 0x02 block, 0x40 void blocktype
    ctrlEnter()
    loopBrkDepth.push(ctrlDepth)
    fbLoop(64)               // 0x03 loop, 0x40 void blocktype
    ctrlEnter()
    loopContDepth.push(ctrlDepth)
    // condition + eqz: if condition is false (zero), exit block
    if emitExpr(body, s.whileCond, fnIx) < 0 { return 0 - 1 }
    fbI32Eqz()               // 0x45 i32.eqz (invert: exit if condition was false)
    fbBrIf(1)                // 0x0d br_if, depth 1 = break out of block
    // body statements
    if emitStmts(body, s.whileBody, fnIx) < 0 { return 0 - 1 }
    fbBr(0)                  // 0x0c br, depth 0 = continue loop
    fbEnd()                  // 0x0b end (loop)
    ctrlLeave()
    loopContDepth.pop()
    fbEnd()                  // 0x0b end (block)
    ctrlLeave()
    loopBrkDepth.pop()
    return 0
  }
  if s is BreakStmt {
    // `break`: branch out of the innermost loop's wrapping BLOCK, so control resumes
    // after the whole loop. No loop labels in the self-host AST, so always the
    // innermost (`loopBrkDepth` top). The relative `br` operand is the frame distance
    // `ctrlDepth - <block depth>`. A `break` outside any loop is a parser/typecheck
    // error upstream; guard anyway so a stray one fails loudly, not with a bad `br`.
    if loopBrkDepth.length == 0 {
      return emitFail("emitProgram: `break` outside a loop")
    }
    let blkDepth = loopBrkDepth[loopBrkDepth.length - 1]
    fbBr(ctrlDepth - blkDepth)   // 0x0c br to the loop's wrapping block
    return 0
  }
  if s is ContinueStmt {
    // `continue`: branch to the innermost loop frame, re-checking the condition. The
    // relative `br` operand is the frame distance `ctrlDepth - <loop depth>`.
    if loopContDepth.length == 0 {
      return emitFail("emitProgram: `continue` outside a loop")
    }
    let loopDepth = loopContDepth[loopContDepth.length - 1]
    fbBr(ctrlDepth - loopDepth)  // 0x0c br to the loop header
    return 0
  }
  emitFail("emitProgram: unsupported statement in body")
}

// True if the statement at `stmtIx` is a BARE VALUE EXPRESSION usable as an IMPLICIT
// RETURN â€” a VL function whose last statement is an expression (no `return` keyword)
// yields that expression's value (the idiom every `ast.vl` constructor uses:
// `addNode(n)` / `out` as the final line). Recognized: literals, an identifier, a
// unary, a non-assignment `BinExpr`, a paren, a member / index access, an `is` guard,
// an object / array literal, and a value-returning CALL (`f(..)` whose callee is an
// Ident â€” NOT a `recv.push(x)` member-call, which is void). A `LetDecl`/`RetStmt`/
// `IfStmt`/`WhileStmt`/assignment/`.push` is a STATEMENT, not a tail value, so it is
// lowered normally by `emitStmt`.
function stmtIsTailValue(stmtIx: i32): boolean {
  let s = P.nodes[stmtIx]
  if s is NumLit { return true }
  if s is StrLit { return true }
  if s is CharLit { return true }
  if s is BoolLit { return true }
  if s is Ident { return true }
  if s is Unary { return true }
  if s is Paren { return true }
  if s is Member { return true }
  if s is Index { return true }
  if s is IsExpr { return true }
  if s is ObjLit { return true }
  if s is ArrayLit { return true }
  if s is BinExpr {
    // An assignment statement is NOT a value; any other binary op is.
    return s.binOp != "="
  }
  if s is Call {
    // A value-returning call `f(..)` is a tail value; a `recv.push(x)` member-call is
    // a void statement, so it is NOT.
    let callee = P.nodes[s.callFn]
    if callee is Ident { return true }
    return false
  }
  false
}

// True if the BLOCK at `blockIx` ends in a bare tail VALUE statement (an implicit
// return), as opposed to an explicit `return`/`while`/etc. â€” i.e. lowering it in tail
// position would need `emitStmtTail`. A nested `if`/`else` tail recurses (any arm).
function blockTailIsValue(blockIx: i32): boolean {
  let b = P.nodes[blockIx]
  if b is Block {
    let stmts = b.blkStmts
    let n = stmts.length
    if n == 0 { return false }
    let last = stmts[n - 1]
    let s = P.nodes[last]
    if s is IfStmt {
      return ifTailIsValue(last)
    }
    return stmtIsTailValue(last)
  }
  false
}

// True if the `if`/`else` at `stmtIx` (in tail position) has any arm that ends in a
// bare value expression rather than an explicit `return` â€” so it must be lowered via
// `emitIfTail`. An `if` WITHOUT an `else` can fall through with no value, so it never
// qualifies (the existing void-if path handles it). Recurses through `else if` chains.
function ifTailIsValue(stmtIx: i32): boolean {
  let s = P.nodes[stmtIx]
  if s is IfStmt {
    if s.ifElse < 0 { return false }
    if blockTailIsValue(s.ifThen) { return true }
    let els = P.nodes[s.ifElse]
    if els is Block {
      return blockTailIsValue(s.ifElse)
    }
    return ifTailIsValue(s.ifElse)
  }
  false
}

// True if the statement at `stmtIx` is a body-tail `if`/`else` whose arms yield a
// value (implicit return) and so must be lowered tail-aware by `emitIfTail`.
function lastStmtIsValueIf(stmtIx: i32): boolean {
  let s = P.nodes[stmtIx]
  if s is IfStmt {
    return ifTailIsValue(stmtIx)
  }
  false
}

// Lower a function's TOP-LEVEL body block at `blockIx`: every statement but the last
// is lowered normally; if the LAST statement is a bare value expression (no `return`
// keyword), it is lowered as the function's return value (`emitExpr` + `return`) â€”
// VL's implicit-return idiom. A last statement that is itself a real statement (a
// `return`, `if`, `while`, assignment, `.push`, or `let`) is lowered unchanged. An
// empty body is left to the existing validation. Returns 0, or -1 (via `emitFail`).
function emitFuncBody(body: i32[], blockIx: i32, fnIx: i32): i32 {
  let b = P.nodes[blockIx]
  if b is Block {
    // Enter the function's top-level lexical scope (mirrors `collectLocals` on the body
    // block). The emit-time scope stack drives same-named-local resolution.
    scopePush()
    let stmts = b.blkStmts
    let n = stmts.length
    let i = 0
    while i < n {
      let isLast = i == n - 1
      if isLast && stmtIsTailValue(stmts[i]) {
        // Implicit return: push the value, then `return` (0x0f).
        if emitExpr(body, stmts[i], fnIx) < 0 { scopePop() return 0 - 1 }
        fbReturn()             // 0x0f return
      } else if isLast && lastStmtIsValueIf(stmts[i]) {
        // The body ends in an `if`/`else` whose arms each yield a value (implicit
        // return) rather than `return`ing â€” lower it tail-aware so each arm's trailing
        // value expression becomes the function's return.
        if emitIfTail(body, stmts[i], fnIx) < 0 { scopePop() return 0 - 1 }
      } else {
        if emitStmt(body, stmts[i], fnIx) < 0 { scopePop() return 0 - 1 }
      }
      i = i + 1
    }
    scopePop()
    return 0
  }
  emitFail("emitProgram: function has no block body")
}

// True if the function's TOP-LEVEL body block at `blockIx` ends in an instruction
// that the wasm validator treats as making the function's fallthrough UNREACHABLE â€”
// i.e. its last statement is an explicit `return` (`RetStmt`) or a bare tail value
// (lowered by `emitFuncBody` as `emitExpr` + `return`). In those cases the function's
// trailing `end` is reached only via the polymorphic post-`return` stack, so no
// padding is needed. Otherwise (the body ends in an `if`/`while`/assignment/`.push`
// whose own `return`s exit from INSIDE a structured block) control structurally falls
// through to `end` with an empty stack â€” which fails the result-type check unless an
// explicit `unreachable` precedes the `end`. The typechecker has already proven such
// a fallthrough is dynamically dead (every path returns), so the `unreachable` is
// sound padding, never executed.
function bodyEndsInReturn(blockIx: i32): boolean {
  let b = P.nodes[blockIx]
  if b is Block {
    let stmts = b.blkStmts
    let n = stmts.length
    if n == 0 { return false }
    let last = stmts[n - 1]
    let s = P.nodes[last]
    if s is RetStmt { return true }
    return stmtIsTailValue(last)
  }
  false
}

// Lower every statement of the block at `blockIx` onto `body`, in order. Returns 0,
// or -1 (via `emitFail`) on a non-block node or an unsupported statement within.
function emitStmts(body: i32[], blockIx: i32, fnIx: i32): i32 {
  let b = P.nodes[blockIx]
  if b is Block {
    // A nested block (if-then / if-else / while-body) is its own lexical scope (mirrors
    // `collectLocals` recursing into it): push a frame so its `let`s shadow correctly and
    // are dropped on exit.
    scopePush()
    let stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      if emitStmt(body, stmts[i], fnIx) < 0 { scopePop() return 0 - 1 }
      i = i + 1
    }
    scopePop()
    return 0
  }
  emitFail("emitProgram: function has no block body")
}

// Lower a block at `blockIx` that sits in TAIL position (its value is the enclosing
// function's return value). Every statement but the last is lowered normally; the
// LAST is lowered tail-aware via `emitStmtTail`, so a bare value expression there
// becomes an implicit return and a nested `if`/`else` recurses with each arm in tail
// position. This is the structured-block analogue of `emitFuncBody`'s top-level
// implicit-return handling, letting a function body like `if c { a } else { b }`
// (each arm an implicit-return expression) lower correctly. Returns 0, or -1.
function emitStmtsTail(body: i32[], blockIx: i32, fnIx: i32): i32 {
  let b = P.nodes[blockIx]
  if b is Block {
    let stmts = b.blkStmts
    let n = stmts.length
    if n == 0 {
      return emitFail("emitProgram: empty block in tail position")
    }
    // A tail-position nested block is its own lexical scope too (mirrors `collectLocals`).
    scopePush()
    let i = 0
    while i < n - 1 {
      if emitStmt(body, stmts[i], fnIx) < 0 { scopePop() return 0 - 1 }
      i = i + 1
    }
    let rc = emitStmtTail(body, stmts[n - 1], fnIx)
    scopePop()
    return rc
  }
  emitFail("emitProgram: function has no block body")
}

// Lower the single statement at `stmtIx` in TAIL position. A bare tail value becomes
// `emitExpr` + `return`; a nested `if`/`else` recurses tail-aware into its arms; any
// other statement (an explicit `return`, a `while`, etc.) is lowered unchanged by
// `emitStmt` (it already exits or falls through on its own). Returns 0, or -1.
function emitStmtTail(body: i32[], stmtIx: i32, fnIx: i32): i32 {
  let s = P.nodes[stmtIx]
  if s is IfStmt {
    return emitIfTail(body, stmtIx, fnIx)
  }
  if stmtIsTailValue(stmtIx) {
    if emitExpr(body, stmtIx, fnIx) < 0 { return 0 - 1 }
    fbReturn()               // 0x0f return
    return 0
  }
  emitStmt(body, stmtIx, fnIx)
}

// Lower an `if`/`else` at `stmtIx` whose VALUE is the function's return value (tail
// position): each arm is lowered with its last statement tail-aware (`emitStmtsTail`),
// so an arm ending in a bare value expression returns it. Mirrors `emitStmt`'s void-if
// shape (same `if 0x04`/`else 0x05`/`end 0x0b`, same union narrowing) but routes the
// arm bodies through the tail path. Returns 0, or -1.
function emitIfTail(body: i32[], stmtIx: i32, fnIx: i32): i32 {
  let s = P.nodes[stmtIx]
  if s is IfStmt {
    if emitExpr(body, s.ifCond, fnIx) < 0 { return 0 - 1 }
    fbIf(64)                 // 0x04 if, 0x40 void blocktype
    let savedTop = narrowTop
    let narrowed = setNarrowFromCond(s.ifCond, fnIx)
    if emitStmtsTail(body, s.ifThen, fnIx) < 0 { return 0 - 1 }
    if narrowed {
      restoreNarrow(savedTop)
    }
    if s.ifElse >= 0 {
      fbElse()               // 0x05 else
      let els = P.nodes[s.ifElse]
      if els is Block {
        if emitStmtsTail(body, s.ifElse, fnIx) < 0 { return 0 - 1 }
      } else {
        // `else if`: a lone nested IfStmt, still in tail position.
        if emitStmtTail(body, s.ifElse, fnIx) < 0 { return 0 - 1 }
      }
    }
    fbEnd()                  // 0x0b end
    return 0
  }
  emitFail("emitProgram: emitIfTail: not an if statement")
}

// Verify every parameter of the FuncDecl at `fnIx` is typed `i32` â€” the only type
// this slice emits. Returns 0 on success or -1 (via `emitFail`) otherwise.
function checkParams(fnIx: i32): i32 {
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    let params = fn.fnParams
    let pi = 0
    while pi < params.length {
      let p = P.nodes[params[pi]]
      if p is Param {
        if p.parType < 0 {
          return emitFail("emitProgram: parameter needs an i32 type")
        }
        let ty = P.nodes[p.parType]
        if ty is TypeRef {
          // i32, `boolean` (which rides in an i32, 0/1 â€” encoded as the SAME 0x7f
          // valtype), the declared struct type, an array (`i32[]`), or `string` (the
          // SAME `array i32` of code points) are allowed; anything else fails.
          // (`collectA` already validated every array annotation is i32[].)
          if ty.tyName != "i32" {
            if ty.tyName != "boolean" {
              if !isSName(ty.tyName) {
                if !isUName(ty.tyName) {
                  if variantIndexOf(ty.tyName) < 0 {
                    if !nameIsArray(ty.tyName) {
                      if !nameIsString(ty.tyName) {
                        return emitFail("emitProgram: only i32, boolean, struct, union, array, or string parameters are supported")
                      }
                    }
                  }
                }
              }
            }
          }
        } else {
          return emitFail("emitProgram: parameter type is not a type name")
        }
      } else {
        return emitFail("emitProgram: malformed parameter")
      }
      pi = pi + 1
    }
    return 0
  }
  emitFail("emitProgram: not a function declaration")
}

// â”€â”€ FuncBuilder: per-function local + scratch-frame allocation (Phase H) â”€â”€â”€â”€â”€â”€
// The single owner of a function's wasm local layout. `fbBeginFunc` lays out the
// scratch frames that follow the params + declared locals, in a fixed order:
//   [params] [declared locals] [i32-push 4] [ref-push 4Â·k] [str-push 4] [str-op 7]
//   [map 12]
// Each frame is reserved only when its `fnUses*` flag is set (`fnRefPushSlots`
// drives the per-slot ref-push frames). `fbScratchCur` is the running wasm-local
// cursor; `fbReserve` hands out a frame's base and advances it. This replaces the
// five hand-written running-offset assignments in `emitFuncCode` â€” the bases come
// from ONE cursor walked in frame order, so they cannot desync. The locals vector
// (`fbEmitLocalsVec`) is then DERIVED from the same flags, never separately counted.
//
// The running wasm-local cursor, set to (params + declared locals) by `fbBeginFunc`
// and advanced by each reserved scratch frame.
let fbScratchCur: i32 = 0

// Reserve `n` wasm locals at the current cursor, returning the frame's base index
// and advancing the cursor past the frame. The single place the cursor moves.
function fbReserve(n: i32): i32 {
  let base = fbScratchCur
  fbScratchCur = fbScratchCur + n
  base
}

// Lay out this function's local frame: set every `*ScratchBase` global from ONE
// running cursor walked in frame order. Must run AFTER `fnUsesPush`/`fnUsesRefPush`/
// `fnUsesStrPush`/`fnUsesStrOp`/`fnUsesMap` and `fnRefPushSlots` are populated, and
// AFTER `buildLocals` (so `nLocals` is final). Returns the cursor's END index (the
// first local index past all scratch frames).
function fbBeginFunc(nParams: i32, nLocals: i32): i32 {
  fbScratchCur = nParams + nLocals
  // i32-list push grow quad (val / cap / backing / recvRef).
  pushScratchBase = fbScratchCur
  if fnUsesPush { fbReserve(4) }
  // One typed 4-slot ref-push frame per distinct pushed element-type slot, in
  // `fnRefPushSlots` order; `refPushScratchBase` aliases the FIRST such frame.
  refPushScratchBase = fbScratchCur
  let rk = 0
  while rk < fnRefPushSlots.length {
    refPushBaseBySlot.push(fbReserve(4))
    rk = rk + 1
  }
  // String-list push quad.
  strPushScratchBase = fbScratchCur
  if fnUsesStrPush { fbReserve(4) }
  // String-op frame (3 non-null string refs + 4 i32 temporaries).
  strScratchBase = fbScratchCur
  if fnUsesStrOp { fbReserve(7) }
  // G8 map scratch frame (12 slots).
  mapScratchBase = fbScratchCur
  if fnUsesMap { fbReserve(12) }
  fbScratchCur
}

// â”€â”€ locals-vector emission (derived, never separately counted) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// The locals vector is a sequence of (count, valtype) runs. This emitter uses a
// count of 1 per local â€” one run per declared local and per scratch slot â€” so the
// run total equals the local count. The run helpers below stream straight to
// `curBuf` (bind it with `wTarget` first); each emits the `1` count then a valtype.

// One (1, i32) run â€” `0x7f`.
function fbI32Run(): i32 {
  wU8(1)
  wU8(127)                 // 0x7f i32
  0
}

// One (1, (ref ht)) run â€” non-null `0x64 <uleb heapIdx>`.
function fbRefRun(heapIdx: i32): i32 {
  wU8(1)
  wU8(100)                 // 0x64 (ref ht) â€” non-null ref
  wULEB(heapIdx)
  0
}

// One (1, valtype) run for a DECLARED local, via the shared `fbValtype` switch
// (`kind`/`structIdx` are the `localIsRef`/`localStructIdx` codes).
function fbLocalRun(kind: i32, structIdx: i32): i32 {
  wU8(1)
  fbValtype(kind, structIdx)
  0
}

// The number of (count=1) runs this function's locals vector holds: one per declared
// local plus the slot count of every reserved scratch frame. DERIVED from the same
// `fnUses*` flags + `fnRefPushSlots` that drove `fbBeginFunc`, so it cannot desync
// from the actual layout.
function fbLocalsCount(nLocals: i32): i32 {
  let n = nLocals
  if fnUsesPush { n = n + 4 }
  n = n + fnRefPushSlots.length * 4
  if fnUsesStrPush { n = n + 4 }
  if fnUsesStrOp { n = n + 7 }
  if fnUsesMap { n = n + 12 }
  n
}

// Emit the full locals vector onto `body`: the run count, then one (1, valtype) run
// per declared local, then the scratch frames in `fbBeginFunc`'s layout order
// (i32-push quad, per-slot ref-push quads, string-push quad, string-op frame, map
// frame). Byte-identical to the old hand-written block; derived from the local set
// and scratch flags rather than separately counted. Returns 0.
function fbEmitLocalsVec(body: i32[], nLocals: i32): i32 {
  let prev = wTarget(body)
  wULEB(fbLocalsCount(nLocals))
  // Declared locals (struct / list / string / ref-list ref or i32 â€” see `fbValtype`).
  let li = 0
  while li < nLocals {
    fbLocalRun(localIsRef[li], localStructIdx[li])
    li = li + 1
  }
  // i32-list push grow quad: pushVal i32, pushNewCap i32, pushNewBacking (ref $aTypeIdx),
  // pushRecvRef (ref $lTypeIdx) â€” the wrapper ref for a struct-FIELD receiver (gap #3).
  if fnUsesPush {
    fbI32Run()
    fbI32Run()
    fbRefRun(aTypeIdx)
    fbRefRun(lTypeIdx)
  }
  // One typed 4-slot ref-push frame per distinct pushed element-type slot, in
  // `fnRefPushSlots` order: pushRefVal (ref $elem), pushRefCap i32,
  // pushRefBacking (ref $back), pushRefRecvRef (ref $wrap).
  let rfk = 0
  while rfk < fnRefPushSlots.length {
    let rfs = fnRefPushSlots[rfk]
    fbRefRun(rlElemHeap[rfs])
    fbI32Run()
    fbRefRun(rlBackIdx[rfs])
    fbRefRun(rlWrapIdx[rfs])
    rfk = rfk + 1
  }
  // String-list push quad: pushStrVal (ref $aTypeIdx), pushStrCap i32,
  // pushStrBacking (ref $mkArrIdx), pushStrRecvRef (ref $mkListIdx).
  if fnUsesStrPush {
    fbRefRun(aTypeIdx)
    fbI32Run()
    fbRefRun(mkArrIdx)
    fbRefRun(mkListIdx)
  }
  // String-op frame: strScrA/B/Out (3 non-null `(ref $aTypeIdx)` string refs),
  // then strScrI0..strScrI3 (4 i32 temporaries).
  if fnUsesStrOp {
    fbRefRun(aTypeIdx)
    fbRefRun(aTypeIdx)
    fbRefRun(aTypeIdx)
    fbI32Run()
    fbI32Run()
    fbI32Run()
    fbI32Run()
  }
  // G8 map scratch frame, in slot order (see the map scratch layout / probe + rehash):
  //   0 mapRef (ref $mStructIdx), 1 keyRef (ref $aTypeIdx), 2 curRef (ref $aTypeIdx),
  //   3 slot i32, 4 cap i32, 5 entry i32, 6 keysBk (ref $mkArrIdx),
  //   7 valsBk (ref $aTypeIdx), 8 chr i32, 9 hcur i32, 10 idxBk (ref $aTypeIdx),
  //   11 rslot i32.
  if fnUsesMap {
    fbRefRun(mStructIdx)
    fbRefRun(aTypeIdx)
    fbRefRun(aTypeIdx)
    fbI32Run()
    fbI32Run()
    fbI32Run()
    fbRefRun(mkArrIdx)
    fbRefRun(aTypeIdx)
    fbI32Run()
    fbI32Run()
    fbRefRun(aTypeIdx)
    fbI32Run()
  }
  wTarget(prev)
  0
}

// Build the size-prefixed code-section body for the FuncDecl at `fnIx`: the locals
// vector (declared locals, all i32 â€” see `buildLocals`), the body's statement
// instructions, then `end`. The framed bytes are appended onto `out`. Returns 0, or
// -1 (via `emitFail`) on any unsupported shape.
//
// The locals vector groups consecutive locals of the same type into (count, valtype)
// runs. Every declared local is i32 here, so it is a single run `(L, 0x7f)` for
// `L = localNames.length` declared locals (or an empty vector `0` when there are
// none). Params are NOT counted here â€” they are encoded in the functype, not the
// code body's locals vector.
function emitFuncCode(out: i32[], fnIx: i32): i32 {
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    // Collect + validate declared locals BEFORE lowering, so identifier resolution
    // and the locals vector both see the full per-function set.
    if buildLocals(fnIx) < 0 { return 0 - 1 }

    // If this function pushes, reserve three scratch locals after the declared ones.
    // `pushScratchBase` is their first wasm index (= params + declared locals); the
    // inline-push sequence reads `pushScratchBase`+0/+1/+2. Set BEFORE `emitStmts` so a
    // `.push` can resolve its scratch slots.
    fnUsesPush = fnHasPush(fnIx)
    fnUsesRefPush = fnHasRefPush(fnIx)
    fnUsesStrPush = fnHasStrPush(fnIx)
    fnUsesStrOp = fnHasStrOp(fnIx)
    fnUsesMap = fnHasMap(fnIx)
    // `fnHasMap` only scans LOCALS/params; also reserve the frame when a map op runs
    // on a GLOBAL struct-field map-array element (e.g. `T.scopes[top][k] = v`).
    if !fnUsesMap { fnUsesMap = fnHasGlobalMapOp(fnIx) }
    // Collect the DISTINCT ref-list element-type slots this function pushes onto (each
    // gets its own typed 4-slot scratch frame). Empty unless `fnUsesRefPush`.
    fnRefPushSlots = []
    refPushBaseBySlot = []
    collectRefPushSlots(fn.fnBody, fnIx)
    // A Member-receiver ref-list `.pop` (`T.scopes.pop()`) needs the SAME typed scratch
    // frame as a ref `.push` onto that slot â€” record its slot too, so a pop-only function
    // reserves the frame whose `recvRef` holds the field's wrapper ref.
    collectMemberPopRefSlots(fn.fnBody, fnIx)
    let nLocals = localNames.length
    // Lay out every scratch frame after the params + declared locals via the
    // FuncBuilder cursor (Phase H), which sets `pushScratchBase` /
    // `refPushScratchBase` / `refPushBaseBySlot` / `strPushScratchBase` /
    // `strScratchBase` / `mapScratchBase` from ONE running offset in frame order.
    fbBeginFunc(fn.fnParams.length, nLocals)

    let bodyExpr: i32[] = []
    // Bind the writer at `bodyExpr` so the `fb*` opcode methods (which append to
    // `curBuf`) write the function-body instructions; the recursive lowering threads
    // the SAME `bodyExpr` as its `body` arg, so `curBuf == body` throughout and the
    // not-yet-converted raw `body.push(...)` sites interleave identically. Restore
    // the previous target afterwards.
    let exprPrev = wTarget(bodyExpr)
    // Reset the emit-time scope stack + slot cursor; `emitFuncBody` re-walks the body
    // in collect's pre-order, so the n-th `LetDecl` it emits re-derives declared-local
    // slot `n` and binds it for in-scope resolution.
    scopeNames = []
    scopeSlots = []
    scopeFrames = []
    emitLetCursor = 0
    // Reset the loop control-frame tracking (`break`/`continue` branch-depth state)
    // so a previous function's open frames never leak into this one.
    ctrlDepth = 0
    loopContDepth = []
    loopBrkDepth = []
    if emitFuncBody(bodyExpr, fn.fnBody, fnIx) < 0 { return 0 - 1 }
    wTarget(exprPrev)

    let body: i32[] = []
    // Locals vector: one (count=1, valtype) run per DECLARED local, then the scratch
    // frames in `fbBeginFunc`'s layout order. Derived from the local set + scratch
    // flags by the FuncBuilder (Phase H) â€” the run count and every valtype come from
    // ONE place, so they cannot desync from the frame layout above.
    if fbEmitLocalsVec(body, nLocals) < 0 { return 0 - 1 }
    appendAll(body, bodyExpr)
    // Bind the writer at `body` (the framed code entry) for the trailing padding/end
    // opcodes emitted via the `fb*` methods.
    let endPrev = wTarget(body)
    // If the body does NOT end in an explicit `return` / tail value, control
    // structurally falls through to the function `end` with an empty stack (e.g. a
    // body ending in `if c { return a } else { return b }`, whose `return`s exit from
    // inside the structured `if`). The validator requires the function's result type
    // at fallthrough, so emit an `unreachable` (0x00) â€” the typechecker has proven
    // this fallthrough is dead, so it is sound padding, never executed.
    if !bodyEndsInReturn(fn.fnBody) {
      fbUnreachable()        // 0x00 unreachable
    }
    fbEnd()                  // 0x0b end
    wTarget(endPrev)
    // Stream the size-prefixed code entry onto `out` (the code-section payload). Bind
    // the writer at `out` explicitly: the caller restores `curBuf` off the payload
    // before this loop, so `curBuf` is NOT `out` on entry here.
    let outPrev = wTarget(out)
    wULEB(body.length)
    wBytes(body)
    wTarget(outPrev)
    return 0
  }
  emitFail("emitProgram: not a function declaration")
}

// `1` if the type-annotation node at `tyIx` names the struct, else `0` (i32 / none).
// Used for functype param/result valtypes and the `fRetRef` table. Returning the
// flag (not pushing bytes) keeps each call free of a `0â†’1` local reassignment, which
// pins a `let x = 0` to the literal `0` type and fails to typecheck.
function retTRFlag(tyIx: i32): i32 {
  if tyIx >= 0 {
    let ty = P.nodes[tyIx]
    if ty is TypeRef {
      if isSName(ty.tyName) { return 1 }
    }
  }
  0
}

// The struct table index named by the type-annotation node at `tyIx`, or -1 if it
// names no declared struct.
function retStructIndex(tyIx: i32): i32 {
  if tyIx >= 0 {
    let ty = P.nodes[tyIx]
    if ty is TypeRef {
      let si = structIndexByName(ty.tyName)
      if si >= 0 { return si }
      // A union-variant name carries its VARIANT index here (consumed by `pushVT`'s
      // `kind == 8` variant-struct case); not a standalone struct, so it is -1 above.
      return variantIndexOf(ty.tyName)
    }
  }
  0 - 1
}

// `1` if the parameter node at `paramIx` is the struct type, else `0`.
function paramTRFlag(paramIx: i32): i32 {
  let p = P.nodes[paramIx]
  if p is Param {
    return retTRFlag(p.parType)
  }
  0
}

// `1` if the type-annotation node at `tyIx` is the i32 array type (`i32[]`), else `0`.
// The functype/local valtype layer multiplexes the struct/array/i32 cases through one
// `kind` code, so this flat flag feeds the `kind == 2` (array) branch of `pushVT`. A REF
// array (`S[]`/`N[]`) is NOT this â€” it feeds `kind == 5` via `retRefArrFlag`.
function retArrFlag(tyIx: i32): i32 {
  if tyIx >= 0 {
    let ty = P.nodes[tyIx]
    if ty is TypeRef {
      if nameIsI32Array(ty.tyName) { return 1 }
    }
  }
  0
}

// `1` if the type-annotation node at `tyIx` is a REF array (`S[]`/`N[]`), else `0`.
// Feeds the `kind == 5` (ref list) branch of `pushVT` and the `fRetRArr` table.
function retRefArrFlag(tyIx: i32): i32 {
  if tyIx >= 0 {
    let ty = P.nodes[tyIx]
    if ty is TypeRef {
      if nameIsRefArray(ty.tyName) { return 1 }
    }
  }
  0
}

// The ref-list element type-NAME of a function RETURN type node `tyIx` (an `S[]`/`N[]`),
// or "". Populates `fRetRArrElem`.
function retRefArrElemName(tyIx: i32): string {
  if tyIx >= 0 {
    let ty = P.nodes[tyIx]
    if ty is TypeRef {
      if nameIsRefArray(ty.tyName) { return refArrElemName(ty.tyName) }
    }
  }
  ""
}

// `1` if the parameter node at `paramIx` is an array type, else `0`.
function paramArrFlag(paramIx: i32): i32 {
  let p = P.nodes[paramIx]
  if p is Param {
    return retArrFlag(p.parType)
  }
  0
}

// `1` if the type-annotation node at `tyIx` is `string`, else `0`. A string is
// CURRENTLY the SAME `(array (mut i32))` of code points an array uses, so it feeds the
// `kind == 3` branch of `pushVT` (which encodes the identical array ref valtype).
function retStrFlag(tyIx: i32): i32 {
  if tyIx >= 0 {
    let ty = P.nodes[tyIx]
    if ty is TypeRef {
      if nameIsString(ty.tyName) { return 1 }
    }
  }
  0
}

// Combine the struct/array/string flags for a type-annotation node at `tyIx` into the
// single `pushVT` `kind` code: `1` struct, `2` array, `3` string, `0` i32. (Struct
// wins if a name were somehow both â€” it cannot be, the lexemes are disjoint.) String
// is a distinct code from array purely for typedness clarity; `pushVT` emits the SAME
// array ref valtype for both, since a string IS the i32-array type here.
function vtKindOfType(tyIx: i32): i32 {
  if retStrArrFlag(tyIx) == 1 { return 7 }
  if retRefArrFlag(tyIx) == 1 { return 5 }
  if retUnionFlag(tyIx) == 1 { return 4 }
  if retVariantFlag(tyIx) == 1 { return 8 }
  if retTRFlag(tyIx) == 1 { return 1 }
  if retArrFlag(tyIx) == 1 { return 2 }
  if retStrFlag(tyIx) == 1 { return 3 }
  0
}

// `1` if the type-annotation node at `tyIx` names a union VARIANT struct (e.g. `TyObj`
// of `Ty`), else `0`. Feeds the `kind == 8` (concrete variant struct ref) branch of
// `pushVT`. A variant-struct param/result is the unboxed variant ref directly â€” gap #2.
function retVariantFlag(tyIx: i32): i32 {
  if tyIx >= 0 {
    let ty = P.nodes[tyIx]
    if ty is TypeRef {
      if variantIndexOf(ty.tyName) >= 0 { return 1 }
    }
  }
  0
}

// The union-variant table index named by the type-annotation node at `tyIx`, or -1.
// Supplies the `structIdx` argument to `pushVT`'s `kind == 8` (variant struct ref) case
// (its heap type is `uVarIdx + vi`).
function retVariantIndex(tyIx: i32): i32 {
  if tyIx >= 0 {
    let ty = P.nodes[tyIx]
    if ty is TypeRef {
      return variantIndexOf(ty.tyName)
    }
  }
  0 - 1
}

// `1` if the type-annotation node at `tyIx` is a `string[]` (string-ref list), else `0`.
// Feeds the `kind == 7` (string-list wrapper) branch of `pushVT`. Checked BEFORE the
// `retRefArrFlag`/`retArrFlag` cases since `string[]` is an `[]` array name but is NOT a
// struct/union ref list nor the i32 list â€” it is the dedicated string-ref list.
function retStrArrFlag(tyIx: i32): i32 {
  if tyIx >= 0 {
    let ty = P.nodes[tyIx]
    if ty is TypeRef {
      if nameIsStringArray(ty.tyName) { return 1 }
    }
  }
  0
}

// `1` if the type-annotation node at `tyIx` names the declared union alias, else `0`.
// Feeds the `kind == 4` (union box) branch of `pushVT`.
function retUnionFlag(tyIx: i32): i32 {
  if tyIx >= 0 {
    let ty = P.nodes[tyIx]
    if ty is TypeRef {
      if isUName(ty.tyName) { return 1 }
    }
  }
  0
}

// The `pushVT` `kind` for a parameter node at `paramIx` (`1` struct, `2` array, `3`
// string, `0` i32).
function vtKindOfParam(paramIx: i32): i32 {
  let p = P.nodes[paramIx]
  if p is Param {
    return vtKindOfType(p.parType)
  }
  0
}

// The struct table index of the parameter node at `paramIx` (from its annotation), or
// -1 â€” feeds `pushVT`'s `kind == 1` struct case for a function param's valtype.
function paramStructIdxOf(paramIx: i32): i32 {
  let p = P.nodes[paramIx]
  if p is Param {
    return retStructIndex(p.parType)
  }
  0 - 1
}

// The `pushVT` `kind` for a module global from its literal INITIALIZER at `initIx`:
// `1` struct ref (object literal), `2` list ref (array literal), `3` string ref (string
// literal), else `0` i32. The global's valtype must match the init's wasm type so the
// constexpr validates; the literal cases are the only ones in scope (a non-literal init
// fails loudly when `emitExpr` lowers it as a constexpr with `fnIx = -1`).
function globalKind(initIx: i32): i32 {
  if initIx < 0 { return 0 }
  let e = P.nodes[initIx]
  if e is ObjLit {
    // A literal matching a standalone struct is that struct ref (kind 1) â€” even in a
    // union program. Otherwise, in a union program it boxes into the union (kind 4).
    if structIndexOfObj(initIx) >= 0 { return 1 }
    if uDeclared { return 4 }
    return 1
  }
  if e is ArrayLit {
    // A ref-element array literal is a ref list (kind 5); an i32/empty literal is the
    // i32 list (kind 2). A module-global empty `[]` over a ref type is out of scope
    // (a global ref-list constexpr needs the binding annotation â€” deferred).
    if arrLitIsRef(initIx) { return 5 }
    return 2
  }
  if e is StrLit { return 3 }
  0
}

// Whether the initializer expression at `exprIx` is a valid WasmGC *constant
// expression* â€” the forms `emitProgram` already lowers inline in the global section
// (`i32.const`, `struct.new`, `array.new_fixed`, the string array). Const forms:
// `NumLit` / `CharLit` / `BoolLit` (an `i32.const`), `StrLit` (a constant `array.new_fixed`
// over the code points), an `ArrayLit` whose elements are ALL const, an `ObjLit` whose
// field values are ALL const, and a `Paren` wrapping a const. EVERYTHING ELSE is
// non-const: an `Ident` (a `global.get` of another global), a `Member` / `Index` (a
// `struct.get` / `array.get` â€” the `curBuf = W.bytes` shape), a `Call`, a `BinExpr` /
// `Unary` (computed), an `IsExpr`. CONSERVATIVE by construction: an unrecognized node
// falls through to the non-const `false`, so a form we have not proven const-safe is
// initialized via the start function rather than emitted as an invalid constexpr.
function isConstInit(exprIx: i32): boolean {
  if exprIx < 0 { return false }
  let e = P.nodes[exprIx]
  if e is NumLit { return true }
  if e is CharLit { return true }
  if e is BoolLit { return true }
  if e is StrLit { return true }
  if e is Paren { return isConstInit(e.parInner) }
  if e is ArrayLit {
    let i = 0
    while i < e.arrElems.length {
      if !isConstInit(e.arrElems[i]) { return false }
      i = i + 1
    }
    return true
  }
  if e is ObjLit {
    let i = 0
    while i < e.objFields.length {
      let f = P.nodes[e.objFields[i]]
      if f is FieldInit {
        if !isConstInit(f.fiValue) { return false }
      } else {
        return false
      }
      i = i + 1
    }
    return true
  }
  false
}

// Whether the module global declared by the `LetDecl` at `letIx` has a non-const
// initializer (so its cell is zero-initialized and set by the synthetic start
// function). False for a non-`LetDecl` or a missing init.
function globalIsNonConst(letIx: i32): boolean {
  if letIx < 0 { return false }
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letInit < 0 { return false }
    return !isConstInit(d.letInit)
  }
  false
}

// Whether the module global `name` has a non-const initializer â€” used at READ sites
// (`global.get`) to decide whether the (nullable) cell needs a `ref.as_non_null`.
function globalNameIsNonConst(name: string): boolean {
  globalIsNonConst(globalLetOf(name))
}

// True if the module global `LetDecl` at `letIx` carries a TYPE ANNOTATION (`let g: T
// = â€¦`). When it does, the cell's wasm type must come from that annotation â€” exactly as
// a local/param resolves its valtype â€” so a global agrees with a same-typed local/param/
// field on the struct table index (otherwise a `global.get g` of an init-inferred struct
// type mismatches a `local.set`/call of the annotation's struct type).
function globalHasTypeAnn(letIx: i32): boolean {
  let d = P.nodes[letIx]
  if d is LetDecl {
    return d.letType >= 0
  }
  false
}

// The `fbValtype` kind for a module global's CELL. When the binding has a TYPE
// ANNOTATION (const init OR not), the kind is derived from that annotation via the
// `letIs*` ladder â€” so a global agrees with a same-typed local/param/field on its
// valtype (kind + struct index). Only an UN-annotated const global (`let g = { â€¦ }`,
// no `: T`) falls back to the literal-initializer kind (`globalKind`); the `g_globals`
// golden's struct global IS annotated, and its annotation names the SAME struct its
// literal infers, so the emitted bytes are unchanged. A non-const init's literal kind is
// meaningless (member/index/call), so it likewise rides the annotation ladder. Mirrors
// `buildLocals`' annotationâ†’kind ladder (map 6, string-array 7, ref-array 5, struct 1,
// array 2, string 3, else i32 0).
function globalCellKind(letIx: i32): i32 {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if globalHasTypeAnn(letIx) {
      if letIsMap(letIx, 0 - 1) { return 6 }
      if letIsStringArray(letIx, 0 - 1) { return 7 }
      if letIsRefArray(letIx, 0 - 1) { return 5 }
      if letIsStruct(letIx, 0 - 1) { return 1 }
      if letIsArray(letIx, 0 - 1) { return 2 }
      if letIsString(letIx, 0 - 1) { return 3 }
      return 0
    }
    // No annotation: a const literal init types itself; a non-const un-annotated init is
    // out of scope (no annotation to derive from) and `globalKind` returns its best guess.
    return globalKind(d.letInit)
  }
  0
}

// The struct table index for a global cell of kind 1 (struct ref), else -1. When the
// binding has a struct ANNOTATION the index comes from THAT annotation (`structIndexOfLet`,
// which prefers the annotation over the init) â€” so a struct global agrees with a same-
// typed local/param/field. An un-annotated const struct global infers from its literal.
function globalCellStructIdx(letIx: i32): i32 {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if globalHasTypeAnn(letIx) {
      return structIndexOfLet(letIx, 0 - 1)
    }
    return structIndexOfExpr(d.letInit, 0 - 1)
  }
  0 - 1
}

// Emit `ref.null <heaptype>` (0xd0 <heaptype-sleb>) for a global cell of ref `kind`,
// the zero initializer that lets the cell be declared NULLABLE before the start
// function `global.set`s the real value. The heap type mirrors `fbValtype`'s kindâ†’
// heap-index map (struct / i32-list / string array / union box / ref-list / map /
// string-list). A scalar global (kind 0) never reaches here â€” it zero-inits with
// `i32.const 0`.
function fbRefNullForKind(kind: i32, structIdx: i32): i32 {
  wU8(208)                     // 0xd0 ref.null
  if kind == 1 {
    wSLEB(sHeapIdx[structIdx])
  } else if kind == 2 {
    wSLEB(lTypeIdx)
  } else if kind == 3 {
    wSLEB(aTypeIdx)
  } else if kind == 4 {
    wSLEB(uBoxIdx)
  } else if kind == 5 {
    wSLEB(rlTypeIdx)
  } else if kind == 6 {
    wSLEB(mStructIdx)
  } else if kind == 7 {
    wSLEB(mkListIdx)
  } else {
    wSLEB(aTypeIdx)
  }
  0
}

// Emit a global cell valtype, NULLABLE for refs (`0x63` instead of `0x64`) so a
// non-const ref cell can be `ref.null`-initialized. The scalar case (kind 0) is the
// same `0x7f` i32 as `fbValtype`. Only used for NON-const globals; const globals keep
// the non-null `fbValtype` (so goldens are unchanged).
function fbValtypeNullable(kind: i32, structIdx: i32): i32 {
  if kind == 1 {
    wU8(99)                    // 0x63 (ref null ht)
    wULEB(sHeapIdx[structIdx])
  } else if kind == 2 {
    wU8(99)
    wULEB(lTypeIdx)
  } else if kind == 3 {
    wU8(99)
    wULEB(aTypeIdx)
  } else if kind == 4 {
    wU8(99)
    wULEB(uBoxIdx)
  } else if kind == 5 {
    wU8(99)
    wULEB(rlTypeIdx)
  } else if kind == 6 {
    wU8(99)
    wULEB(mStructIdx)
  } else if kind == 7 {
    wU8(99)
    wULEB(mkListIdx)
  } else {
    wU8(127)                   // 0x7f i32
  }
  0
}

// The heap-type index of a ref list's ELEMENT: the struct (heap-type 0) when
// `rElemKind == 1`, or the union box (`uBoxIdx`) when `rElemKind == 2`. Used for the
// ref backing's element ref, the index-read `ref.cast`/result, and the push value.
function refElemHeapType(): i32 {
  if rElemKind == 2 { return uBoxIdx }
  0
}

// â”€â”€ valtype emission (Phase G â€” was `pushVT`) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Write a wasm value type onto the CURRENT buffer (`curBuf`). The `kind` tag
// selects the encoding (the valtype ladder formerly in `pushVT`):
//   0    â†’ i32 (`0x7f`)
//   1    â†’ struct ref `(ref $sHeapIdx[structIdx])` â€” a standalone struct
//   2    â†’ i32-list ref `(ref $lTypeIdx)` (the growable `i32[]` wrapper struct)
//   3    â†’ string ref `(ref $aTypeIdx)` â€” the raw `(array (mut i32))` of code points
//   4    â†’ union-box ref `(ref $uBoxIdx)` â€” the `{tag, value}` box
//   5    â†’ ref-list ref `(ref $rlTypeIdx)` â€” the ref-element list wrapper
//   6    â†’ map ref `(ref $mStructIdx)` â€” the string-keyed map struct
//   7    â†’ string-list ref `(ref $mkListIdx)` â€” the string-list wrapper
//   8    â†’ concrete union-variant ref `(ref $uVarIdx+structIdx)` (gap #2)
// A ref is always non-null (`0x64`), matching binaryen's `(ref $T)` for a value
// statically known present (a constructed list / struct / string, never `null`).
// The kindâ†’heap-index resolution reads the interned indices (`sHeapIdx`/`lTypeIdx`/
// `aTypeIdx`/â€¦ â€” assigned by `emitModule`'s type-index pass). Replaces `pushVT`;
// callers `wTarget(buf)` the destination buffer first (the writer streams to
// `curBuf`), matching every other `fb*` method.
function fbValtype(kind: i32, structIdx: i32): i32 {
  if kind == 1 {
    wU8(100)             // 0x64 (ref ht) â€” non-null ref
    wULEB(sHeapIdx[structIdx])   // this struct's heap-type index
  } else if kind == 2 {
    wU8(100)
    wULEB(lTypeIdx)      // the i32-list wrapper struct heap-type index
  } else if kind == 3 {
    wU8(100)
    wULEB(aTypeIdx)      // the raw i32 array heap-type index (string)
  } else if kind == 4 {
    wU8(100)
    wULEB(uBoxIdx)       // the union box `{tag, value}` heap-type index
  } else if kind == 5 {
    wU8(100)
    wULEB(rlTypeIdx)     // the REF-list wrapper struct heap-type index
  } else if kind == 6 {
    wU8(100)
    wULEB(mStructIdx)    // the string-keyed MAP struct heap-type index (G8)
  } else if kind == 7 {
    wU8(100)
    wULEB(mkListIdx)     // the STRING-LIST wrapper struct heap-type index
  } else if kind == 8 {
    wU8(100)
    wULEB(uVarIdx + structIdx)   // the CONCRETE union-variant struct heap-type index (gap #2)
  } else {
    wU8(127)             // 0x7f i32
  }
  0
}

// â”€â”€ type interning (Phase G â€” replaces emitModule's offset arithmetic) â”€â”€â”€â”€â”€â”€â”€â”€
// The heap-type index allocator. Every type the module emits (standalone structs,
// union variants + box, the raw i32 array, the i32-list wrapper, each ref-list
// (backing, wrapper) pair, the string-list (backing, wrapper) pair, the map struct,
// and the functypes) occupies one slot in the single rec group, in EMIT ORDER.
// `mNextType` is the running counter; `mAllocType` hands out the next index. This
// centralizes the running-sum invariant the old parallel `*Offset` formulas
// open-coded ("a type that references a later type still goes in the one rec
// group, so all indices are mutually visible"). Reset per program by
// `mResetTypeIntern`, driven in declaration order by `mAssignTypeIndices`.
let mNextType: i32 = 0

// Reset the interning counter (call once per module, before assigning indices).
function mResetTypeIntern(): i32 {
  mNextType = 0
  0
}

// Allocate the next heap-type index (interning in emit order): return the current
// counter, then advance it by one. This is the single auditable place a type index
// is minted â€” every `mIntern*` below funnels through here.
function mAllocType(): i32 {
  let idx = mNextType
  mNextType = mNextType + 1
  idx
}

// The Phase-G safety assert (risk R2): the interned index MUST equal the value the
// old offset formula computes. On divergence, fail loudly (drops the buffer so a
// mis-indexed module never reaches instantiation) â€” never silence it. Retained as
// a cheap debug check for one release after the old arithmetic is deleted.
function mAssertIdx(got: i32, want: i32, who: string): i32 {
  if got != want {
    return emitFail("emitProgram: Phase G type-index drift in " + who)
  }
  0
}

// Walk the type-section emit order with the `mAllocType` counter, assigning each
// type's heap index into the module-global index state (`sHeapIdx`/`uVarIdx`/
// `uBoxIdx`/`aTypeIdx`/`lTypeIdx`/`rlBackIdx`/`rlWrapIdx`/`mkArrIdx`/`mkListIdx`/
// `mStructIdx`) and asserting each equals the old offset formula. Returns the
// functype base index (`typeOffset` â€” where the first functype lands), or -1 on a
// drift (via `mAssertIdx`/`emitFail`). The order MUST match the type-section
// emission below EXACTLY: standalone structs â†’ union variants â†’ union box â†’ raw
// i32 array â†’ i32-list wrapper â†’ ref-list (backing, wrapper) pairs â†’ string-list
// (backing, wrapper) â†’ map struct â†’ functypes.
function mAssignTypeIndices(n: i32): i32 {
  mResetTypeIntern()

  // â”€â”€ the OLD offset formulas (kept as the Phase-G debug-assert oracle) â”€â”€
  let structOffset = sNames.length
  let oldUnionOffset = 0
  let oldUVarIdx = structOffset
  let oldUBoxIdx = structOffset + uVariants.length
  if uDeclared { oldUnionOffset = uVariants.length + 1 }
  let preTypes = structOffset + oldUnionOffset
  let arrayOffset = 0
  if aUsed { arrayOffset = 1 }
  let listOffset = 0
  if lUsed { listOffset = 1 }
  let oldATypeIdx = preTypes
  let oldLTypeIdx = preTypes + arrayOffset
  let refPairBase = preTypes + arrayOffset + listOffset
  let refPairsTotal = rlElemName.length * 2
  let preMap = refPairBase + refPairsTotal
  let oldMkArrIdx = preMap
  let oldMkListIdx = preMap + 1
  let oldMStructIdx = preMap + 2

  // â”€â”€ the NEW interned assignment (the single auditable counter) â”€â”€
  // Standalone structs occupy the first `sNames.length` indices (decl order).
  sHeapIdx = []
  let shi = 0
  while shi < sNames.length {
    let si = mAllocType()
    if mAssertIdx(si, shi, "struct") < 0 { return 0 - 1 }
    sHeapIdx.push(si)
    shi = shi + 1
  }
  // Union variant structs (nv of them) then the union box.
  if uDeclared {
    uVarIdx = mNextType
    if mAssertIdx(uVarIdx, oldUVarIdx, "uVarIdx") < 0 { return 0 - 1 }
    let vi = 0
    while vi < uVariants.length {
      mAllocType()
      vi = vi + 1
    }
    uBoxIdx = mAllocType()
    if mAssertIdx(uBoxIdx, oldUBoxIdx, "uBoxIdx") < 0 { return 0 - 1 }
  }
  // The raw i32 array (string rep + list/map backing), then the i32-list wrapper.
  if aUsed {
    aTypeIdx = mAllocType()
    if mAssertIdx(aTypeIdx, oldATypeIdx, "aTypeIdx") < 0 { return 0 - 1 }
  } else {
    aTypeIdx = oldATypeIdx
  }
  if lUsed {
    lTypeIdx = mAllocType()
    if mAssertIdx(lTypeIdx, oldLTypeIdx, "lTypeIdx") < 0 { return 0 - 1 }
  } else {
    lTypeIdx = oldLTypeIdx
  }
  // The map struct index is needed BELOW to resolve a map-array ref-list element
  // (it references `(ref null $mStructIdx)`), yet the map struct lands AFTER the ref
  // pairs + string-list. It is computable up front from the counter: it follows the
  // `refPairsTotal` ref-pair slots plus the 2 string-list slots.
  let mStructIdxPre = mNextType + refPairsTotal + 2
  // One (backing, wrapper) pair per distinct ref-list element type, interleaved.
  let rs = 0
  while rs < rlElemName.length {
    let back = mAllocType()
    let wrap = mAllocType()
    if mAssertIdx(back, refPairBase + rs * 2, "rlBackIdx") < 0 { return 0 - 1 }
    if mAssertIdx(wrap, refPairBase + rs * 2 + 1, "rlWrapIdx") < 0 { return 0 - 1 }
    rlBackIdx[rs] = back
    rlWrapIdx[rs] = wrap
    if rlElemKindTbl[rs] == 2 {
      rlElemHeap[rs] = uBoxIdx
    } else if rlElemKindTbl[rs] == 3 {
      rlElemHeap[rs] = mStructIdxPre
    } else {
      let esi = structIndexByName(rlElemName[rs])
      if esi >= 0 { rlElemHeap[rs] = sHeapIdx[esi] } else { rlElemHeap[rs] = 0 }
    }
    rs = rs + 1
  }
  // The legacy singletons alias slot 0 (or the next index when no ref list).
  if rlElemName.length >= 1 {
    raTypeIdx = rlBackIdx[0]
    rlTypeIdx = rlWrapIdx[0]
  } else {
    raTypeIdx = mNextType
    rlTypeIdx = mNextType
    if mAssertIdx(raTypeIdx, refPairBase, "raTypeIdx") < 0 { return 0 - 1 }
  }
  // The string-ref list (keys backing + keys wrapper), shared by the map's keys
  // list AND any `string[]` field (present when `slUsed || mUsed`).
  if slUsed || mUsed {
    mkArrIdx = mAllocType()
    mkListIdx = mAllocType()
    if mAssertIdx(mkArrIdx, oldMkArrIdx, "mkArrIdx") < 0 { return 0 - 1 }
    if mAssertIdx(mkListIdx, oldMkListIdx, "mkListIdx") < 0 { return 0 - 1 }
  } else {
    mkArrIdx = oldMkArrIdx
    mkListIdx = oldMkListIdx
  }
  // The map struct (present only when `mUsed`).
  if mUsed {
    mStructIdx = mAllocType()
    if mAssertIdx(mStructIdx, oldMStructIdx, "mStructIdx") < 0 { return 0 - 1 }
    if mAssertIdx(mStructIdx, mStructIdxPre, "mStructIdxPre") < 0 { return 0 - 1 }
  } else {
    mStructIdx = oldMStructIdx
  }
  // The functypes follow; the first lands at the current counter (`typeOffset`).
  let typeOffset = mNextType
  let oldTypeOffset = preMap + strListOffsetOf() + mapStructOffsetOf()
  if mAssertIdx(typeOffset, oldTypeOffset, "typeOffset") < 0 { return 0 - 1 }
  typeOffset
}

// The string-list type count (keys backing + wrapper): 2 when present, else 0.
function strListOffsetOf(): i32 {
  if slUsed || mUsed { return 2 }
  0
}

// The map-struct type count: 1 when a map is used, else 0.
function mapStructOffsetOf(): i32 {
  if mUsed { return 1 }
  0
}

// Detect, over the SET of non-const global init expressions, the scratch frames the
// start function's body needs â€” the start-fn analogue of `emitFuncCode`'s per-function
// `fnHas*` detection. A `.push` is a statement-level void call (never in an init VALUE
// position), so the i32/ref/string-push frames are driven by Member-receiver `.pop`s
// (which DO appear in value position, `let x = T.scopes.pop()` shape) via
// `exprHasMemberPopKind`; string ops and map ops are detected over the same exprs. Sets
// the `fnUses*` flags + `fnRefPushSlots`/`refPushBaseBySlot` exactly as `emitFuncCode`
// does, so the shared `fbBeginFunc`/`fbEmitLocalsVec` lay out an identical frame. For
// the common `curBuf = W.bytes` shape (a plain `global.get`+`struct.get`) every flag is
// false and the locals vector is empty.
function startFnDetectScratch(): i32 {
  fnUsesPush = false
  fnUsesRefPush = false
  fnUsesStrPush = false
  fnUsesStrOp = false
  fnUsesMap = false
  fnRefPushSlots = []
  refPushBaseBySlot = []
  let gi = 0
  while gi < globalStmts.length {
    if globalIsNonConst(globalStmts[gi]) {
      let g = P.nodes[globalStmts[gi]]
      if g is LetDecl {
        let ix = g.letInit
        if exprHasMemberPopKind(ix, 0 - 1, 0) { fnUsesPush = true }
        if exprHasMemberPopKind(ix, 0 - 1, 1) { fnUsesRefPush = true }
        if exprHasMemberPopKind(ix, 0 - 1, 2) { fnUsesStrPush = true }
        if exprHasStrOp(ix, 0 - 1) { fnUsesStrOp = true }
        if exprHasMapOp(ix, 0 - 1) { fnUsesMap = true }
        collectMemberPopRefSlotsExpr(ix, 0 - 1)
      }
    }
    gi = gi + 1
  }
  0
}

// Emit the synthetic start function's size-prefixed code entry onto `out` (the code
// section payload). The body runs every NON-const global initializer in declaration
// order â€” `emitExpr(body, letInit, -1)` (module scope, `fnIx = -1`) then `global.set gi`
// â€” so each cell holds its real value before any other code runs. Mirrors
// `emitFuncCode`'s framing: detect scratch frames, lay out locals via `fbBeginFunc`,
// emit the locals vector (`fbEmitLocalsVec`) with NO declared locals, then the body and
// the `end`, size-prefixed. Returns 0, or -1 (via `emitFail`).
function emitStartFnCode(out: i32[]): i32 {
  // Scratch detection + layout: the start fn has no params and no declared locals, so
  // the cursor starts at 0 and only reserved scratch frames advance it.
  startFnDetectScratch()
  fbBeginFunc(0, 0)

  let bodyExpr: i32[] = []
  let exprPrev = wTarget(bodyExpr)
  // Reset the emit-time scope/loop bookkeeping (the start fn has its own empty frame),
  // mirroring `emitFuncCode` â€” no leak from the last user function.
  scopeNames = []
  scopeSlots = []
  scopeFrames = []
  emitLetCursor = 0
  ctrlDepth = 0
  loopContDepth = []
  loopBrkDepth = []
  let gi = 0
  while gi < globalStmts.length {
    if globalIsNonConst(globalStmts[gi]) {
      let g = P.nodes[globalStmts[gi]]
      if g is LetDecl {
        if emitExpr(bodyExpr, g.letInit, 0 - 1) < 0 { wTarget(exprPrev) return 0 - 1 }
        let setPrev = wTarget(bodyExpr)
        fbGlobalSet(gi)
        wTarget(setPrev)
      }
    }
    gi = gi + 1
  }
  wTarget(exprPrev)

  let body: i32[] = []
  // Locals vector: no declared locals, just the (possibly empty) scratch frames.
  if fbEmitLocalsVec(body, 0) < 0 { return 0 - 1 }
  appendAll(body, bodyExpr)
  let endPrev = wTarget(body)
  fbEnd()                  // 0x0b end (void â†’ void: stack already empty)
  wTarget(endPrev)

  let outPrev = wTarget(out)
  wULEB(body.length)
  wBytes(body)
  wTarget(outPrev)
  0
}

// Emit the complete module for the top-level functions in `fnStmts` (each a FuncDecl,
// validated by `collectFns`/`buildFnMap`/`checkParams`). If a struct `type` was
// declared, its WasmGC struct type is emitted FIRST (type index 0) and the functypes
// follow (1..N); otherwise functypes start at 0. Struct-typed params/results encode
// as `(ref $0)`. The function section binds func i to its functype, an export per
// function under its own name, and one code body per function â€” every section framed
// through the SAME LEB/section helpers the fixed builders use.
function emitModule(stmts: i32[]): i32 {
  emitReset()
  emitHeader()

  let n = fnStmts.length

  // â”€â”€ Start-function model (non-const module-global initializers) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
  // A module global whose initializer is NOT a WasmGC constant expression (a member
  // access like `curBuf = W.bytes`, a reference to another global, a call, â€¦) cannot
  // be emitted inline in the global section. Its cell is zero-initialized there
  // (nullable `ref.null` / `i32.const 0`) and a SINGLE synthetic start function â€” the
  // LAST function index, so no user index shifts â€” runs every such init via
  // `global.set` before any other code. Count them up front; the count drives one
  // extra `()->()` functype, one extra function-section + code-section entry, and the
  // start section (id 8). When zero (the case for EVERY golden), nothing below
  // changes, so the module stays byte-identical.
  let nNonConst = 0
  let gci = 0
  while gci < globalStmts.length {
    if globalIsNonConst(globalStmts[gci]) { nNonConst = nNonConst + 1 }
    gci = gci + 1
  }
  let hasStart = 0
  if nNonConst > 0 { hasStart = 1 }
  // The synthetic start function's index (last, after all `n` user functions) and its
  // `()->()` functype index (one past the user functypes). Both unused when no start.
  let startFnIdx = n

  // Heap-type indices, in type-section order: standalone structs at 0..ns-1, then
  // (for the union path) the variant structs + box, then the raw i32 array, the
  // i32-list wrapper, each ref-list (backing, wrapper) pair, the string-list
  // (backing, wrapper), the map struct, and finally the functypes. Every index is
  // minted by the centralized `mIntern*` counter inside `mAssignTypeIndices`, which
  // assigns the module-global index state (`sHeapIdx`/`uVarIdx`/`uBoxIdx`/`aTypeIdx`/
  // `lTypeIdx`/`rlBackIdx`/`rlWrapIdx`/`raTypeIdx`/`rlTypeIdx`/`mkArrIdx`/`mkListIdx`/
  // `mStructIdx`) in that order and ALSO asserts each equals the old offset formula
  // (risk R2 â€” index drift; the formulas survive as the assert oracle, scheduled for
  // deletion one release after Phase G). It returns the functype base index
  // (`typeOffset` â€” where the first functype lands), or -1 on a drift. All types are
  // emitted inside ONE recursion group below, so a type may reference one that lands
  // later (a string field's `(ref $aTypeIdx)`).
  let typeOffset = mAssignTypeIndices(n)
  if typeOffset < 0 { return 0 - 1 }

  // Type section (id 1): the struct type (if any) at index 0 â€” `0x5f` struct form,
  // field count, then each field's storagetype (`0x7f` i32) + mutability (`0x01`);
  // the raw i32 array type (if used) next â€” `0x5e` array form, `0x7f` i32 storagetype,
  // `0x01` mutable (derived from binaryen: `5e 7f 01`); the growable-list wrapper struct
  // (if used) next â€” `0x5f` struct of three mutable fields `{ backing: (ref $aTypeIdx),
  // len: i32, cap: i32 }` (verified against binaryen's `listType`); then one functype
  // per function (`(i32|ref)* -> i32|ref`).
  // The type section is a vector of rectypes. We emit ALL types inside ONE recursion
  // group (`0x4e <count>`), so every type index is mutually visible â€” a struct field
  // can reference the raw array type that lands AFTER it (a string field's `(ref
  // $aTypeIdx)`), which a non-grouped section's strictly-earlier-only index rule would
  // reject. (binaryen emits the same single rec group; functypes inside it are valid.)
  // So the section's rectype count is 1 (the rec group), and the rec group holds the
  // `n + typeOffset` actual type definitions.
  let typePayload: i32[] = []
  // Bind the writer at `typePayload` for the WHOLE type-section payload build, so the
  // raw framing bytes, `pushFieldStorage`, and `fbValtype` all stream to `curBuf ==
  // typePayload` identically. Restored just before `wSection` frames it (below).
  let tyPrev = wTarget(typePayload)
  wU8(1)                                 // one rectype: the rec group
  wU8(78)                                // 0x4e rec group
  wULEB(n + typeOffset + hasStart)       // types inside the rec group (+1 for start fn)
  if sDeclared {
    // One `0x5f` struct per declared type (declaration order = heap-type index),
    // each a struct of its fields in declaration order. A field is `0x7f` i32
    // (`sFieldTypes == 0`) or, for a string field (`== 3`), a non-null `(ref
    // $aTypeIdx)` (`0x64 <aTypeIdx>` â€” the raw `(array i32)` string rep); both mutable.
    let si = 0
    while si < sNames.length {
      wU8(95)                    // 0x5f struct
      let cnt = sFieldCount[si]
      wULEB(cnt)
      let fj = 0
      while fj < cnt {
        pushFieldStorage(sFieldTypeAt(si, fj), sFieldRefSlot(si, fj))
        wU8(1)                   // mutable
        fj = fj + 1
      }
      si = si + 1
    }
  }
  if uDeclared {
    // The `nv` variant structs FIRST (heap types 0..nv-1), each a struct of its i32
    // fields in declaration order (`0x5f` struct, count, then `0x7f 0x01` per field â€”
    // mutable i32). Then the union BOX `{ tag: i32, value: anyref }` at index `nv`:
    // `0x5f` struct, 2 fields â€” `0x7f 0x00` (i32, IMMUTABLE tag) and `0x6e 0x00`
    // (`anyref` abbreviation, IMMUTABLE value) â€” mirroring binaryen's `5f 02 7f 00
    // 6e 00` (verified against `toWasm.ts`'s `unionStruct`).
    let vi = 0
    while vi < uVariants.length {
      wU8(95)                    // 0x5f struct
      let cnt = uFieldCount[vi]
      wULEB(cnt)
      let fj = 0
      while fj < cnt {
        pushFieldStorage(variantFieldTypeAt(vi, fj), variantFieldRefSlot(vi, fj))
        wU8(1)                   // mutable
        fj = fj + 1
      }
      vi = vi + 1
    }
    wU8(95)                      // 0x5f struct (union box)
    wU8(2)                       // 2 fields
    wU8(127)                     // field 0 tag: 0x7f i32
    wU8(0)                       // immutable
    wU8(110)                     // field 1 value: 0x6e anyref
    wU8(0)                       // immutable
  }
  if aUsed {
    wU8(94)                      // 0x5e array
    wU8(127)                     // 0x7f i32 storagetype
    wU8(1)                       // mutable
  }
  if lUsed {
    wU8(95)                      // 0x5f struct
    wU8(3)                       // 3 fields
    wU8(100)                     // field 0 backing: 0x64 (ref ht) â€” non-null
    wULEB(aTypeIdx)              // ...to the raw array heap type
    wU8(1)                       // mutable
    wU8(127)                     // field 1 len: 0x7f i32
    wU8(1)                       // mutable
    wU8(127)                     // field 2 cap: 0x7f i32
    wU8(1)                       // mutable
  }
  // One (backing, wrapper) PAIR per distinct ref-list element type, interleaved so each
  // wrapper immediately follows (and references) its own backing â€” the heap indices laid
  // out above. Each backing is `(array (mut (ref null $elem)))` over the slot's element
  // (struct heap idx / union box); each wrapper is `{ backing: (ref $back), len, cap }`.
  let rti = 0
  while rti < rlElemName.length {
    wU8(94)                      // 0x5e array (ref backing)
    wU8(99)                      // 0x63 (ref null ht) â€” nullable element ref
    wULEB(rlElemHeap[rti])
    wU8(1)                       // mutable
    wU8(95)                      // 0x5f struct (ref-list wrapper)
    wU8(3)                       // 3 fields
    wU8(100)                     // field 0 backing: 0x64 (ref ht) â€” non-null
    wULEB(rlBackIdx[rti])        // ...to THIS slot's ref backing
    wU8(1)                       // mutable
    wU8(127)                     // field 1 len: 0x7f i32
    wU8(1)                       // mutable
    wU8(127)                     // field 2 cap: 0x7f i32
    wU8(1)                       // mutable
    rti = rti + 1
  }
  if slUsed || mUsed {
    // The STRING-REF list types, shared by the map's keys list and any `string[]`
    // field. (1) the backing array `(array (mut (ref null $aTypeIdx)))` â€” element is a
    // NULLABLE string ref (`0x63 <aTypeIdx>`) so `array.new_default` defaults spare
    // slots to null; an element read recovers the non-null string. (2) the list wrapper
    // `{ backing: (ref $mkArrIdx), len, cap }` â€” the same `{backing,len,cap}` triple as
    // the i32 list, over the string backing.
    wU8(94)                      // 0x5e array (keys/string backing)
    wU8(99)                      // 0x63 (ref null ht) â€” nullable string ref
    wULEB(aTypeIdx)
    wU8(1)                       // mutable
    wU8(95)                      // 0x5f struct (string-list wrapper)
    wU8(3)                       // 3 fields
    wU8(100)                     // field 0 backing: 0x64 (ref ht) â€” non-null
    wULEB(mkArrIdx)
    wU8(1)                       // mutable
    wU8(127)                     // field 1 len: 0x7f i32
    wU8(1)                       // mutable
    wU8(127)                     // field 2 cap: 0x7f i32
    wU8(1)                       // mutable
  }
  if mUsed {
    // The MAP struct `{ keys: (ref $mkListIdx), vals: (ref $lTypeIdx), index, count,
    // size }` â€” two non-null list refs (the keys string-list + the i32 vals list), the
    // i32 `index` hash-slot array `(ref $aTypeIdx)`, and the `count`/`size` counters.
    wU8(95)                      // 0x5f struct (map)
    wU8(5)                       // 5 fields (open-addressing hash map)
    wU8(100)                     // field 0 keys: 0x64 (ref $mkListIdx) â€” non-null
    wULEB(mkListIdx)
    wU8(1)                       // mutable
    wU8(100)                     // field 1 vals: 0x64 (ref $lTypeIdx) â€” non-null
    wULEB(lTypeIdx)
    wU8(1)                       // mutable
    wU8(100)                     // field 2 index: 0x64 (ref $aTypeIdx) â€” non-null i32 array
    wULEB(aTypeIdx)
    wU8(1)                       // mutable
    wU8(127)                     // field 3 count: 0x7f i32
    wU8(1)                       // mutable
    wU8(127)                     // field 4 size: 0x7f i32
    wU8(1)                       // mutable
  }
  // The functype param/result valtypes (`fbValtype`) stream to `curBuf == typePayload`,
  // interleaved identically with the surrounding raw framing bytes (the `wTarget` bind
  // covering this whole payload build was established above).
  let ti = 0
  while ti < n {
    let fn = P.nodes[fnStmts[ti]]
    if fn is FuncDecl {
      let params = fn.fnParams
      let nParams = params.length
      wU8(96)                    // 0x60 func
      wULEB(nParams)             // param count
      let pi = 0
      while pi < nParams {
        fbValtype(vtKindOfParam(params[pi]), paramStructIdxOf(params[pi]))
        pi = pi + 1
      }
      wU8(1)                     // 1 result
      fbValtype(vtKindOfType(fn.fnRet), retStructIndex(fn.fnRet))
    }
    ti = ti + 1
  }
  // The synthetic start function's `()->()` functype (lands at index `typeOffset + n`,
  // AFTER every user functype â€” so no user type index shifts and the Phase-G assert is
  // untouched). `0x60` func, 0 params, 0 results.
  if hasStart == 1 {
    wU8(96)                      // 0x60 func
    wU8(0)                       // 0 params
    wU8(0)                       // 0 results
  }
  wTarget(tyPrev)
  wSection(1, typePayload)

  // Function section (id 3): N functions; func i uses functype `typeOffset + i`. The
  // synthetic start function (if any) is the LAST entry â€” function index `n` â€” using
  // the `()->()` functype at index `typeOffset + n`.
  let funcPayload: i32[] = []
  let fnPrev = wTarget(funcPayload)
  wULEB(n + hasStart)
  let fi = 0
  while fi < n {
    wULEB(typeOffset + fi)   // functype index
    fi = fi + 1
  }
  if hasStart == 1 {
    wULEB(typeOffset + n)    // start fn functype index
  }
  wTarget(fnPrev)
  wSection(3, funcPayload)

  // Global section (id 6): one mutable global per top-level `let`/`const`, in
  // declaration order (that order IS the global index `global.get`/`global.set` use).
  // Each entry is `<valtype> 0x01 <init constexpr> 0x0b`. The valtype mirrors `pushVT`'s
  // kind for the initializer (i32 / struct ref / list ref / string ref); the init reuses
  // the ordinary `emitExpr` literal lowering â€” `i32.const`, `struct.new`, and
  // `array.new_fixed` are all valid WasmGC constant expressions, so no start function is
  // needed for the literal initializers in scope. A non-constexpr init (a reference to a
  // local/param) fails loudly via `emitExpr(fnIx = -1)` (start-fn fallback deferred).
  let ng = globalStmts.length
  if ng > 0 {
    let globalPayload: i32[] = []
    // Bind the writer at `globalPayload` for the WHOLE global-section payload build, so
    // the count, each entry's valtype (`fbValtype`), mutability flag, and init constexpr
    // (`fb*` opcodes) all stream to `curBuf == globalPayload`. Restored before framing.
    let gPrev = wTarget(globalPayload)
    wULEB(ng)
    let gi = 0
    while gi < ng {
      let g = P.nodes[globalStmts[gi]]
      if g is LetDecl {
        if g.letInit < 0 {
          return emitFail("emitProgram: module global has no initializer")
        }
        if globalIsNonConst(globalStmts[gi]) {
          // A non-constexpr init (`curBuf = W.bytes` â€” a `global.get`+`struct.get`, a
          // reference to another global, a call, etc.) cannot be a WasmGC constant
          // expression. Declare the cell NULLABLE and zero-init it (`i32.const 0` for a
          // scalar, `ref.null` for a ref); the synthetic start function below runs the
          // real init via `global.set` before any other code, so reads never see the
          // zero. The cell stays mutable.
          let ck = globalCellKind(globalStmts[gi])
          let cs = globalCellStructIdx(globalStmts[gi])
          fbValtypeNullable(ck, cs)                     // nullable valtype
          wU8(1)                                        // 0x01 mutable
          if ck == 0 {
            fbI32Const(0)                               // scalar zero
          } else {
            fbRefNullForKind(ck, cs)                    // ref.null zero
          }
          fbEnd()                                       // 0x0b end of init expr
        } else {
          // The cell's valtype comes from the binding's ANNOTATION when present (so a
          // global agrees with a same-typed local/param/field on its struct table index),
          // falling back to the literal-init kind for an un-annotated global. The init
          // constexpr (`emitExpr`) lowers the literal â€” and must build the SAME wasm type:
          // `pendingStructIdx` seeds an `ObjLit` to the annotated struct (not the first
          // field-name match), and `pendingListKind`/`pendingListSlot` seed an empty `[]`
          // to the annotation's ref/string list (not the i32-list the bare literal infers),
          // exactly as the local-`let` path threads them.
          let gck = globalCellKind(globalStmts[gi])
          let gcs = globalCellStructIdx(globalStmts[gi])
          if gck == 1 { pendingStructIdx = gcs }
          pendingListKind = letAnnRefListKind(globalStmts[gi])
          pendingListSlot = letAnnRefListSlot(globalStmts[gi])
          fbValtype(gck, gcs)                            // valtype
          wU8(1)                                         // 0x01 mutable
          if emitExpr(globalPayload, g.letInit, 0 - 1) < 0 { return 0 - 1 }   // init constexpr
          pendingListKind = 0
          pendingListSlot = 0
          fbEnd()                                         // 0x0b end of init expr
        }
      }
      gi = gi + 1
    }
    wTarget(gPrev)
    wSection(6, globalPayload)
  }

  // Export section (id 7): export each function under its own name. A name is a
  // UTF-8 byte vec; for an ASCII identifier each `name[i]` char code IS its byte.
  let exportPayload: i32[] = []
  let exPrev = wTarget(exportPayload)
  wULEB(n)
  let ei = 0
  while ei < n {
    let fn = P.nodes[fnStmts[ei]]
    if fn is FuncDecl {
      wName(fn.fnName)
      wU8(0)         // export kind: func
      wULEB(ei)      // func index
    }
    ei = ei + 1
  }
  wTarget(exPrev)
  wSection(7, exportPayload)

  // Start section (id 8): names the function the runtime invokes once at instantiation,
  // before any export is callable â€” here the synthetic start fn that runs the non-const
  // global initializers. Per the section-id order it sits AFTER the export section (7)
  // and BEFORE the code section (10). Omitted entirely when no non-const global exists
  // (so EVERY golden, which has only const globals, emits no start section).
  if hasStart == 1 {
    let startPayload: i32[] = []
    let stPrev = wTarget(startPayload)
    wULEB(startFnIdx)
    wTarget(stPrev)
    wSection(8, startPayload)
  }

  // Code section (id 10): one size-prefixed body per function, in index order, then
  // (if any) the synthetic start function's body LAST.
  let codePayload: i32[] = []
  let codePrev = wTarget(codePayload)
  wULEB(n + hasStart)
  wTarget(codePrev)
  let ci = 0
  while ci < n {
    if emitFuncCode(codePayload, fnStmts[ci]) < 0 { return 0 - 1 }
    ci = ci + 1
  }
  if hasStart == 1 {
    if emitStartFnCode(codePayload) < 0 { return 0 - 1 }
  }
  wSection(10, codePayload)
  0
}

// Walk the arena from `rootIx` and emit a module for ALL top-level functions of the
// form:
//
//   function NAME(p0: i32, â€¦): i32 { <stmt>* }
//
// where each <stmt> is a `let`/`const` i32 local declaration, an assignment
// `x = <expr>`, a `return <expr>`, or an `if <cond> { <stmt>* } [else â€¦]`, and
// <expr> is built from integer literals, parameter / local references, calls to any
// top-level function (recursion included), the `+`/`-`/`*` arithmetic operators, the
// six signed i32 comparisons, and unary negation. Declared locals get wasm slots
// AFTER the params (see `buildLocals`). Each function is exported under its own NAME.
// Returns 0 on success; on any unsupported shape it calls `emitFail` (leaving
// `emitErr` set and the buffer empty) and returns -1.
//
// Node shapes read (all from `compiler/ast.vl`):
//   Program  { progStmts: i32[] }   â€” top-level statements; the functions.
//   FuncDecl { fnName, fnParams: i32[], fnRet: i32, fnBody: i32 }
//   Param    { parName: string, parType: i32 }
//   Block    { blkStmts: i32[] }    â€” a function body / branch.
//   LetDecl  { letName, letType, letInit }   â€” a local declaration.
//   RetStmt  { retArg: i32 } ; IfStmt { ifCond, ifThen, ifElse }
//   BinExpr  { binOp, binLeft, binRight }    â€” `binOp == "="` is an assignment.

// â”€â”€ struct-type collection + struct-typedness of expressions â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// `isSName` tells whether a type-name refers to the declared struct; `collectS`
// records the program's single struct type; the rest decide whether a given
// expression / param / local PRODUCES the struct (a `(ref $0)`) rather than an i32.

// True if the type-name `name` refers to one of the declared struct types.
function isSName(name: string): boolean {
  structIndexByName(name) >= 0
}

// True if the type-name `name` is an ARRAY type â€” its lexeme ends in `[]` (the
// suffix `parseType` appends for every `T[]` annotation). Only `i32[]` is emittable
// in this slice; a non-i32 element array is rejected by `checkArrName`.
function nameIsArray(name: string): boolean {
  let n = name.length
  if n < 2 { return false }
  if name[n - 2] != '[' { return false }
  if name[n - 1] != ']' { return false }
  true
}

// True if the array type-name `name` is `i32[]` (the value-element list whose backing
// is the raw `(array (mut i32))`). A `T[]`/`N[]` (struct/union element) is NOT this.
function nameIsI32Array(name: string): boolean {
  name == "i32[]"
}

// True if the type-name `name` is a string-keyed MAP `{[string]: i32}` (G8) â€” the
// synthetic name `parseType` builds for an index-signature type, which starts with
// `"{["`. Only `{[string]: i32}` is emittable in this slice (the self-host checker's
// scope-chain element); any other index signature still parses to this shape but the
// map lowering assumes string keys + i32 values. A trailing `[]` (a list-of-maps
// `{[string]:i32}[]`) is NOT a bare map â€” that is handled by the ref-array path.
function nameIsMap(name: string): boolean {
  if name.length < 2 { return false }
  // A trailing `[]` makes it a LIST of maps, not a bare map.
  if name[name.length - 1] == ']' {
    if name[name.length - 2] == '[' { return false }
  }
  if name[0] != '{' { return false }
  if name[1] != '[' { return false }
  true
}

// True if the array type-name `name` is a string-keyed-MAP list `{[string]:i32}[]` â€”
// a ref list whose ELEMENT is the map struct (`mStructIdx`). It is a `nameIsMap` name
// with a trailing `[]`. The scope chain (`typecheck.vl`'s `scopes: {[string]:i32}[]`)
// is exactly this. Routed through the ref-list machinery as element-kind `3`.
function nameIsMapArray(name: string): boolean {
  let n = name.length
  if n < 2 { return false }
  if name[n - 2] != '[' { return false }
  if name[n - 1] != ']' { return false }
  // The bare element (without the trailing `[]`) must be a map name.
  nameIsMap(name.slice(0, n - 2))
}

// True if the array type-name `name` is a REF-element list â€” `S[]` over a declared
// struct, `N[]` over the declared union alias (the box-ref element), or `{[string]:i32}[]`
// (a map-struct element). Either lowers to the `{ backing: (ref $raTypeIdx), len, cap }`
// wrapper over a `(ref null $elem)` backing (G7-ref). A non-`[]` name or an `i32[]` is
// NOT a ref array. The element name is recovered by checking each declared struct/union
// name + `"[]"` (a `string + string` concat; a `string + i32` would be a type error).
function nameIsRefArray(name: string): boolean {
  let i = 0
  while i < sNames.length {
    if name == sNames[i] + "[]" { return true }
    i = i + 1
  }
  let u = 0
  while u < unNames.length {
    if name == unNames[u] + "[]" { return true }
    u = u + 1
  }
  if nameIsMapArray(name) { return true }
  false
}

// The ref-element kind for an array type-name (assumes `nameIsRefArray(name)`):
// `1` = a struct element, `2` = a union-box element (`uBoxIdx`), `3` = a map-struct
// element (`mStructIdx`, the scope-chain `{[string]:i32}[]`).
function refArrElemKind(name: string): i32 {
  if nameIsMapArray(name) { return 3 }
  let u = 0
  while u < unNames.length {
    if name == unNames[u] + "[]" { return 2 }
    u = u + 1
  }
  1
}

// True if the type-name `name` is exactly `string`. A VL string is CURRENTLY an
// `array i32` of code points (`docs/strings-design.md`), so it shares the array heap
// type â€” hence string use also sets `aUsed` and string valtypes reuse the array ref.
// (`string[]` is NOT this â€” it ends in `[]`, so `nameIsArray` catches it first and
// `checkArrName` rejects it as a non-i32 element array.)
function nameIsString(name: string): boolean {
  name == "string"
}

// True if the type-name `name` is exactly `string[]` â€” a growable list whose elements
// are string refs. It reuses the map keys list types (the `{backing,len,cap}` wrapper
// over a `(ref null $aTypeIdx)` string backing); field code `6`.
function nameIsStringArray(name: string): boolean {
  name == "string[]"
}

// The per-field wasm-type code for a struct / union-variant field whose type node is
// `tyIx` (a `TypeRef`). Mirrors the inline classifier `collectS`/`collectVariantFields`
// used to use, EXTENDED with array-typed fields (gap #5): a field of array type stores a
// REF to a list wrapper, so its code records WHICH wrapper:
//   `0` = i32 / boolean   (`0x7f`)
//   `3` = string          (`(ref $aTypeIdx)`)
//   `4` = i32 list  `i32[]`         (`(ref $lTypeIdx)`)
//   `5` = ref list  `T[]` / `N[]`   (`(ref $rlTypeIdx)`)
// An `X[]` whose element `X` is not `i32` is a REF list (`5`) â€” its element is a struct
// or the union box; the element-kind (`rElemKind`) is fixed globally by `collectA`, so it
// is not stored per-field. An unsupported field type yields `-1` (caller fails loudly).
// (`string[]` is NOT yet supported â€” it would need a string-ref list distinct from the
// struct/union ref backing â€” so it falls through to `-1`.)
function fieldTypeCode(tyIx: i32): i32 {
  if tyIx < 0 { return 0 - 1 }
  let ty = P.nodes[tyIx]
  if ty is TypeRef {
    if ty.tyName == "i32" { return 0 }
    if ty.tyName == "boolean" { return 0 }
    if nameIsString(ty.tyName) { return 3 }
    if nameIsArray(ty.tyName) {
      if nameIsI32Array(ty.tyName) { return 4 }
      // A `string[]` field is a string-ref list (code `6`) â€” it reuses the map keys
      // list types (`mkListIdx`/`mkArrIdx`). Any OTHER `X[]` is a struct/union ref list.
      if nameIsStringArray(ty.tyName) { return 6 }
      return 5
    }
    return 0 - 1
  }
  0 - 1
}

// The ref-list ELEMENT type-NAME of a field whose type node is `tyIx` â€” the table key
// into `rlElemName` â€” when `fieldTypeCode(tyIx) == 5` (a struct/union ref list); "" for
// any other field. Strips the trailing `"[]"` directly so it does NOT depend on `sNames`
// being fully populated (collectS builds it incrementally; a field may reference a
// later-declared struct). Used to fill `sFieldElemName`/`uFieldElemName`.
function fieldRefElemName(tyIx: i32): string {
  if fieldTypeCode(tyIx) != 5 { return "" }
  let ty = P.nodes[tyIx]
  if ty is TypeRef {
    return ty.tyName.slice(0, ty.tyName.length - 2)
  }
  ""
}

// Validate an array type-name as a supported element type: `i32[]` (the value list),
// or a REF list `S[]`/`N[]` over the declared struct / union alias (G7-ref). A nested
// `i32[][]` or an array of an unknown / unsupported element fails loudly. Returns 0 on
// success, or -1 (via `emitFail`).
function checkArrName(name: string): i32 {
  if name == "i32[]" { return 0 }
  if nameIsRefArray(name) { return 0 }
  emitFail("emitProgram: only i32[] arrays and struct/union element arrays are supported")
}

// Scan the whole arena for any use of the shared `(array (mut i32))` heap type â€” an
// `ArrayLit` or `StrLit` expression, or an array (`i32[]`) / `string` type annotation
// â€” setting `aUsed`. A VL string IS that same array-i32 of code points, so a string
// literal / `string` annotation needs the very type an array does. A single linear
// pass over `P.nodes` is exhaustive (every node, reachable or not, is checked) and
// stable: it fixes whether the program needs the array heap type BEFORE the type
// section is emitted. Each `[]` annotation is validated as `i32[]` here, so a non-i32
// element array (e.g. `string[]`) fails loudly up-front. Returns 0, or -1 (via
// `emitFail`).
function collectA(stmts: i32[]): i32 {
  aUsed = false
  lUsed = false
  raUsed = false
  rlUsed = false
  rElemKind = 0
  rlElemName = []
  rlElemHeap = []
  rlBackIdx = []
  rlWrapIdx = []
  rlElemKindTbl = []
  mUsed = false
  slUsed = false
  let i = 0
  while i < P.nodes.length {
    let nd = P.nodes[i]
    if nd is ArrayLit {
      // A `[â€¦]` literal is a growable list. A literal with struct/union-variant
      // elements is a REF list (its backing is `(ref null $elem)`); an i32-element
      // or EMPTY literal contributes the i32 list (an empty `[]` over a REF type is
      // typed by its binding's annotation, collected via the TypeRef branch â€” so the
      // i32 list types it also forces are harmless presence, never wrong bytes).
      if arrLitIsRef(i) {
        rlUsed = true
        raUsed = true
        rElemKind = arrLitElemKind(i)
        rlInternName(arrLitElemName(i), arrLitElemKind(i))
      } else {
        lUsed = true
        aUsed = true
      }
    } else if nd is StrLit {
      aUsed = true
    } else if nd is Call {
      // A `fromCodePoint(code)` call (H2) constructs a length-1 VL string â€” the shared
      // `(array i32)` heap type â€” so it forces `aUsed` just like a string literal, even
      // in a program with no other string. The callee is a bare `Ident`.
      let cf = P.nodes[nd.callFn]
      if cf is Ident {
        if cf.identName == "fromCodePoint" {
          aUsed = true
        }
      }
    } else if nd is TypeRef {
      if nameIsMap(nd.tyName) {
        // A `{[string]: i32}` annotation (G8) is a string-keyed map: the map struct
        // + the keys list (string-ref backing) + the i32 VALS list (the existing
        // `lTypeIdx`/`aTypeIdx`). So it forces `aUsed` (string backing + vals backing)
        // and `lUsed` (the vals wrapper) alongside the three dedicated map types.
        mUsed = true
        lUsed = true
        aUsed = true
      } else if nameIsStringArray(nd.tyName) {
        // A `string[]` annotation is a string-ref list â€” the SAME wrapper/backing as
        // the map keys list. Force the keys list types (`slUsed`) + the string backing
        // (`aUsed`, since the elements are `(ref null $aTypeIdx)`).
        slUsed = true
        aUsed = true
      } else if nameIsRefArray(nd.tyName) {
        // A `S[]`/`N[]` annotation is a ref list (wrapper + `(ref null $elem)` backing).
        // A `{[string]:i32}[]` (map-array) ALSO forces the map struct + its keys/vals
        // list types (the element is `(ref $mStructIdx)`).
        rlUsed = true
        raUsed = true
        rElemKind = refArrElemKind(nd.tyName)
        rlInternName(refArrElemName(nd.tyName), refArrElemKind(nd.tyName))
        if nameIsMapArray(nd.tyName) {
          mUsed = true
          lUsed = true
          aUsed = true
        }
      } else if nameIsArray(nd.tyName) {
        if checkArrName(nd.tyName) < 0 { return 0 - 1 }
        // An `i32[]` annotation is a list (wrapper struct + raw-array backing).
        lUsed = true
        aUsed = true
      } else if nameIsString(nd.tyName) {
        aUsed = true
      }
    }
    i = i + 1
  }
  0
}

// True if the array literal at `arrIx` has ref ELEMENTS â€” its first element is a
// struct object literal (a `T[]` element) or a union-variant object literal (an
// `N[]` element). An empty literal is NOT detectable here (it has no elements); its
// kind comes from the binding annotation (`pendingListKind`).
function arrLitIsRef(arrIx: i32): boolean {
  let a = P.nodes[arrIx]
  if a is ArrayLit {
    if a.arrElems.length < 1 { return false }
    let e0 = P.nodes[a.arrElems[0]]
    if e0 is ObjLit { return true }
  }
  false
}

// True if the array literal at `arrIx` has STRING elements â€” its first element is a
// string-typed expression (a `"â€¦"` literal, or a string-returning call / string
// param/local). An empty literal is NOT detectable here; its kind comes from the
// binding/field annotation (`pendingListKind == 3`).
function arrLitIsStr(arrIx: i32, fnIx: i32): boolean {
  let a = P.nodes[arrIx]
  if a is ArrayLit {
    if a.arrElems.length < 1 { return false }
    return exprString(a.arrElems[0], fnIx)
  }
  false
}

// The ref-element kind of the array literal at `arrIx` (assumes `arrLitIsRef`): `2`
// when the FIRST element is a union variant (boxes into the union), else `1` (a direct
// struct element). Per-element-type: a `Tok[]` literal whose element is a plain struct
// is kind `1` even in a program that ALSO declares a union (which `Node[]` uses).
function arrLitElemKind(arrIx: i32): i32 {
  let a = P.nodes[arrIx]
  if a is ArrayLit {
    if a.arrElems.length >= 1 {
      let e0 = P.nodes[a.arrElems[0]]
      if e0 is ObjLit {
        // A union-variant element boxes into the union (kind 2); a plain struct is kind 1.
        if uDeclared {
          if objVariantName(a.arrElems[0]) != "" { return 2 }
        }
        return 1
      }
    }
  }
  if uDeclared { return 2 }
  1
}

// The ref-list ELEMENT type-NAME of the array literal at `arrIx` (assumes `arrLitIsRef`):
// the union alias name for a union-variant element, else the matched struct's name. This
// is the table key (`rlElemName`) the per-element-type interning uses.
function arrLitElemName(arrIx: i32): string {
  let a = P.nodes[arrIx]
  if a is ArrayLit {
    if a.arrElems.length >= 1 {
      let e0 = P.nodes[a.arrElems[0]]
      if e0 is ObjLit {
        if uDeclared {
          let vn = objVariantName(a.arrElems[0])
          if vn != "" { return unionNameOfVariant(variantIndexOf(vn)) }
        }
        let si = structIndexOfObj(a.arrElems[0])
        if si >= 0 { return sNames[si] }
      }
    }
  }
  ""
}

// The element type-NAME for a ref-array type-name (assumes `nameIsRefArray(name)`): the
// element is `name` with the trailing `"[]"` removed â€” i.e. the struct / union alias
// name. Mirrors `refArrElemKind` but yields the table key.
function refArrElemName(name: string): string {
  if nameIsMapArray(name) { return name.slice(0, name.length - 2) }
  let u = 0
  while u < unNames.length {
    if name == unNames[u] + "[]" { return unNames[u] }
    u = u + 1
  }
  let i = 0
  while i < sNames.length {
    if name == sNames[i] + "[]" { return sNames[i] }
    i = i + 1
  }
  ""
}

// Intern a ref-list element type-NAME into the per-element-type table, returning its
// SLOT index (existing slot if already present). `kind` is 1 (struct) or 2 (union box).
// Heap/backing/wrapper indices are filled later in `emitModule`.
function rlInternName(name: string, kind: i32): i32 {
  if name == "" { return 0 - 1 }
  let i = 0
  while i < rlElemName.length {
    if rlElemName[i] == name { return i }
    i = i + 1
  }
  rlElemName.push(name)
  rlElemHeap.push(0)
  rlBackIdx.push(0)
  rlWrapIdx.push(0)
  rlElemKindTbl.push(kind)
  rlElemName.length - 1
}

// The table SLOT for a ref-list element type-NAME, or -1 if not interned.
function rlSlotByName(name: string): i32 {
  let i = 0
  while i < rlElemName.length {
    if rlElemName[i] == name { return i }
    i = i + 1
  }
  0 - 1
}

// True if the node at `ix` is a struct `type` declaration (a single-level narrowing
// helper, so callers avoid an inline `is TypeDecl` on the wide `Node` union).
function nodeIsTypeDecl(ix: i32): boolean {
  let s = P.nodes[ix]
  if s is TypeDecl { return true }
  false
}

// Scan the top-level statements for EVERY struct `type` declaration and record each
// into the flat multi-struct table (name + field names in declaration order, plus a
// per-field wasm-type code: `0` = i32 / boolean, `3` = string). Each `type X = {â€¦}`
// interns its own WasmGC struct heap type. A field whose type is neither i32/boolean
// nor string fails loudly. Returns 0 on success, or -1 (via `emitFail`).
function collectS(stmts: i32[]): i32 {
  sDeclared = false
  sNames = []
  sFieldNames = []
  sFieldStart = []
  sFieldCount = []
  sFieldTypes = []
  sFieldElemName = []
  // A `type X = {â€¦}` that is a UNION VARIANT is collected by `collectU` into its own
  // variant table â€” it is NOT a standalone struct, so skip it here. Any OTHER struct
  // `type` (e.g. `ast.vl`'s `Tok`/`Diag`, declared alongside the `Node` union) IS a
  // standalone struct and is interned here, so standalone structs coexist with a union.
  let i = 0
  while i < stmts.length {
    let s = P.nodes[stmts[i]]
    // A union variant `TypeDecl` is owned by the variant table, NOT a standalone struct.
    if s is TypeDecl {
      if variantIndexOf(s.tdName) < 0 {
        sDeclared = true
        sNames.push(s.tdName)
        sFieldStart.push(sFieldNames.length)
        let fields = s.tdFields
        let cnt = 0
        let fi = 0
        while fi < fields.length {
          let fnode = P.nodes[fields[fi]]
          if fnode is FieldDef {
            let code = fieldTypeCode(fnode.fdType)
            if code < 0 {
              return emitFail("emitProgram: only i32 / boolean / string / array struct fields are supported")
            }
            sFieldTypes.push(code)
            sFieldElemName.push(fieldRefElemName(fnode.fdType))
            sFieldNames.push(fnode.fdName)
            cnt = cnt + 1
          } else {
            return emitFail("emitProgram: malformed struct field")
          }
          fi = fi + 1
        }
        sFieldCount.push(cnt)
      }
    }
    i = i + 1
  }
  0
}

// â”€â”€ union collection (G1) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// The struct field names + per-field wasm-type codes (`0` i32/boolean, `3` string) of
// the `TypeDecl` named `name` are recorded into the flat
// `uFieldNames`/`uFieldStart`/`uFieldCount`/`uFieldTypes` table (declaration order =
// wasm field index). The struct must exist among the top-level statements and carry
// only i32/boolean/string fields, else fails loudly. Returns 0, or -1 (via `emitFail`).
function collectVariantFields(stmts: i32[], name: string): i32 {
  let i = 0
  while i < stmts.length {
    let s = P.nodes[stmts[i]]
    if s is TypeDecl {
      if s.tdName == name {
        uFieldStart.push(uFieldNames.length)
        let fields = s.tdFields
        let cnt = 0
        let fi = 0
        while fi < fields.length {
          let fnode = P.nodes[fields[fi]]
          if fnode is FieldDef {
            let code = fieldTypeCode(fnode.fdType)
            if code < 0 {
              return emitFail("emitProgram: only i32 / boolean / string / array union-variant fields are supported")
            }
            uFieldTypes.push(code)
            uFieldElemName.push(fieldRefElemName(fnode.fdType))
            uFieldNames.push(fnode.fdName)
            cnt = cnt + 1
          } else {
            return emitFail("emitProgram: malformed union-variant field")
          }
          fi = fi + 1
        }
        uFieldCount.push(cnt)
        return 0
      }
    }
    i = i + 1
  }
  emitFail("emitProgram: union variant names an unknown struct type")
}

// The wasm-type code (`0` i32, `3` string) of variant `vi`'s field at field index `fi`.
function variantFieldTypeAt(vi: i32, fi: i32): i32 {
  uFieldTypes[uFieldStart[vi] + fi]
}

// The ref-list table SLOT of variant `vi`'s ref-list field `fi`, or -1 if not a ref list.
function variantFieldRefSlot(vi: i32, fi: i32): i32 {
  rlSlotByName(uFieldElemName[uFieldStart[vi] + fi])
}

// The structural signature of variant `vi` â€” its field names joined with `,` (a
// stable per-shape key). Two variants with the same field-name set share a sig (and
// so, under structural typing, are the same variant â€” `docs/unions.md`); the slice's
// AST-style unions use DISTINCT field-name prefixes per variant, so every sig differs.
function variantSig(vi: i32): string {
  let out = ""
  let start = uFieldStart[vi]
  let cnt = uFieldCount[vi]
  let j = 0
  while j < cnt {
    if j > 0 { out = out + "," }
    out = out + uFieldNames[start + j]
    j = j + 1
  }
  out
}

// Lexicographic `a < b` over two strings by code point (VL has no `<` on `string`).
// Compares char-by-char: at the first differing position the smaller code point wins;
// if one is a prefix of the other, the shorter is smaller. Equal strings are NOT `<`.
function strLess(a: string, b: string): boolean {
  let i = 0
  let na = a.length
  let nb = b.length
  while i < na && i < nb {
    let ca = a[i]
    let cb = b[i]
    if ca < cb { return true }
    if ca > cb { return false }
    i = i + 1
  }
  na < nb
}

// Assign each variant its GLOBAL tag = its rank when the variants are ordered by
// structural signature (mirroring `toWasm.ts`'s sorted `variantKey` tag assignment).
// `uTags[i]` is variant i's tag: the number of variants whose sig sorts strictly
// before variant i's (sigs are distinct, so this is a dense 0..n-1 permutation).
function assignTags(): i32 {
  uTags = []
  let i = 0
  while i < uVariants.length {
    let sigI = variantSig(i)
    let rank = 0
    let j = 0
    while j < uVariants.length {
      if j != i {
        let sigJ = variantSig(j)
        if strLess(sigJ, sigI) { rank = rank + 1 }
      }
      j = j + 1
    }
    uTags.push(rank)
    i = i + 1
  }
  0
}

// Scan the top-level statements for EVERY union alias `type N = A | B | â€¦` (a
// `UnionDecl`); for each, record its name + variant-slice range in the per-union table
// (`unNames`/`unVarStart`/`unVarCount`), append its variant struct names to the GLOBAL
// `uVariants` list, collect each variant's i32 fields into the flat table, and finally
// assign globally-unique tags across all variants of all unions. Multiple unions
// coexist (mirroring the multi-struct table). Returns 0, or -1 (via `emitFail`).
function collectU(stmts: i32[]): i32 {
  uDeclared = false
  unNames = []
  unVarStart = []
  unVarCount = []
  uVariants = []
  uFieldNames = []
  uFieldStart = []
  uFieldCount = []
  uFieldTypes = []
  uFieldElemName = []
  let i = 0
  while i < stmts.length {
    let s = P.nodes[stmts[i]]
    if s is UnionDecl {
      uDeclared = true
      let vs = s.udVariants
      if vs.length < 1 {
        return emitFail("emitProgram: union must have at least one variant")
      }
      unNames.push(s.udName)
      unVarStart.push(uVariants.length)
      unVarCount.push(vs.length)
      let vi = 0
      while vi < vs.length {
        uVariants.push(vs[vi])
        if collectVariantFields(stmts, vs[vi]) < 0 { return 0 - 1 }
        vi = vi + 1
      }
    }
    i = i + 1
  }
  if uDeclared {
    if assignTags() < 0 { return 0 - 1 }
  }
  0
}

// The per-union table index that OWNS global variant `vi` (the union whose variant
// slice contains it), or -1. Mirrors the `structIndexByName`-style resolver.
function unionOfVariant(vi: i32): i32 {
  let u = 0
  while u < unNames.length {
    let start = unVarStart[u]
    if vi >= start && vi < start + unVarCount[u] { return u }
    u = u + 1
  }
  0 - 1
}

// The position of variant struct `name` in `uVariants` (its heap-type is `uVarIdx +
// pos`), or -1 if `name` is not a variant of the declared union.
function variantIndexOf(name: string): i32 {
  let i = 0
  while i < uVariants.length {
    if uVariants[i] == name { return i }
    i = i + 1
  }
  0 - 1
}

// True if the type-name `name` is ANY declared union alias.
function isUName(name: string): boolean {
  let u = 0
  while u < unNames.length {
    if unNames[u] == name { return true }
    u = u + 1
  }
  false
}

// The union alias name that owns global variant `vi` (assumes `vi` is a variant of some
// declared union), or "" if none. Used to intern a ref-list-of-union by the SPECIFIC
// union (so `Node[]` and `Ty[]` are distinct table slots).
function unionNameOfVariant(vi: i32): string {
  let u = unionOfVariant(vi)
  if u >= 0 { return unNames[u] }
  ""
}

// The wasm struct field index of `field` within variant `vi` (declaration order), or
// -1 if that variant has no such field.
function variantFieldIndex(vi: i32, field: string): i32 {
  let start = uFieldStart[vi]
  let cnt = uFieldCount[vi]
  let j = 0
  while j < cnt {
    if uFieldNames[start + j] == field { return j }
    j = j + 1
  }
  0 - 1
}

// True if the function `name` declares the struct as its return type (flat lookup
// over the `fRetRef` flags `buildFnMap` recorded â€” no arena rescan).
function fnRetStruct(name: string): boolean {
  let i = 0
  while i < fnNames.length {
    if fnNames[i] == name { return fRetRef[i] == 1 }
    i = i + 1
  }
  false
}

// True if the parameter `name` of function `fnIx` is the struct type.
function paramStruct(fnIx: i32, name: string): boolean {
  if fnIx < 0 { return false }   // module-scope initializer (no enclosing function)
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    let params = fn.fnParams
    let i = 0
    while i < params.length {
      let p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            let ty = P.nodes[p.parType]
            if ty is TypeRef { return isSName(ty.tyName) }
          }
          return false
        }
      }
      i = i + 1
    }
  }
  false
}
// True if evaluating the expression at `exprIx` yields the struct (a `(ref $0)`):
// an object literal (constructs it), a struct-returning call, a struct param/local
// reference, or a parenthesized struct expression. Anything else is an i32 value.
function exprStruct(exprIx: i32, fnIx: i32): boolean {
  if exprIx < 0 { return false }
  let e = P.nodes[exprIx]
  if e is ObjLit { return true }
  if e is Paren { return exprStruct(e.parInner, fnIx) }
  if e is Call {
    let callee = P.nodes[e.callFn]
    if callee is Ident { return fnRetStruct(callee.identName) }
    return false
  }
  if e is Ident {
    if paramStruct(fnIx, e.identName) { return true }
    if declaredStruct(e.identName) { return true }
    return globalIsStruct(e.identName)
  }
  // `xs[i]` over a STRUCT-element ref list yields the struct (G7-ref). Per-slot: the
  // element kind comes from the receiver's distinct ref-list slot (1 = struct).
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      let slot = refListSlotOfExpr(e.idxArr, fnIx)
      return rlElemKindTbl[slot] == 1
    }
  }
  false
}

// True if the already-collected declared local `name` is a struct ref. Resolves to
// the IN-SCOPE binding's slot (so a same-named binding in a sibling/inner block reads
// ITS own valtype, not an unrelated branch's).
function declaredStruct(name: string): boolean {
  let slot = declaredSlotOf(name)
  if slot < 0 { return false }
  localIsRef[slot] == 1
}

// True if the `LetDecl` at `letIx` declares a struct-typed local: its annotation
// names the struct, OR its initializer produces the struct. Picks the local's
// valtype (`(ref $0)` vs i32) in `collectLocals`.
function letIsStruct(letIx: i32, fnIx: i32): boolean {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      let lt = P.nodes[d.letType]
      if lt is TypeRef {
        if isSName(lt.tyName) { return true }
      }
    }
    return exprStruct(d.letInit, fnIx)
  }
  false
}

// â”€â”€ multi-struct index resolution â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Parallel to the boolean `exprStruct` family, these return the STRUCT TABLE INDEX a
// struct-typed expression / param / local / return produces, so a field read/write
// can resolve the right heap type + field layout. Return -1 when not a struct.

// The struct table index of the param `name` of function `fnIx` (from its annotation),
// or -1.
function paramStructIndex(fnIx: i32, name: string): i32 {
  if fnIx < 0 { return 0 - 1 }   // module-scope initializer (no enclosing function)
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    let params = fn.fnParams
    let i = 0
    while i < params.length {
      let p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            let ty = P.nodes[p.parType]
            if ty is TypeRef { return structIndexByName(ty.tyName) }
          }
          return 0 - 1
        }
      }
      i = i + 1
    }
  }
  0 - 1
}

// The union-variant table index of the param `name` of function `fnIx` (when its
// annotation names a VARIANT struct of the declared union, e.g. `o: TyObj`), or -1.
// A variant-struct param's value IS the concrete variant struct ref `(ref $(uVarIdx +
// vi))` â€” already narrowed/unboxed by the caller â€” so a field read on it reads the
// variant struct directly (no box unwrap), the gap-#2 boundary.
function paramVariantIndex(fnIx: i32, name: string): i32 {
  if fnIx < 0 { return 0 - 1 }   // module-scope initializer (no enclosing function)
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    let params = fn.fnParams
    let i = 0
    while i < params.length {
      let p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            let ty = P.nodes[p.parType]
            if ty is TypeRef { return variantIndexOf(ty.tyName) }
          }
          return 0 - 1
        }
      }
      i = i + 1
    }
  }
  0 - 1
}

// The union-variant table index an expression at `exprIx` yields a CONCRETE variant
// struct ref for (a variant-typed param reference, or a parenthesized one), or -1. The
// receiver shape for a gap-#2 field read `o.field` where `o: TyObj`.
function exprVariantIndex(exprIx: i32, fnIx: i32): i32 {
  if exprIx < 0 { return 0 - 1 }
  let e = P.nodes[exprIx]
  if e is Paren { return exprVariantIndex(e.parInner, fnIx) }
  if e is Ident { return paramVariantIndex(fnIx, e.identName) }
  0 - 1
}

// The struct table index of the declared local `name` (recorded in `localStructIdx`),
// or -1 if `name` is not a struct local.
function declaredStructIndex(name: string): i32 {
  let slot = declaredSlotOf(name)
  if slot < 0 { return 0 - 1 }
  if localIsRef[slot] == 1 { return localStructIdx[slot] }
  0 - 1
}

// The struct table index a function `name` returns (recorded in `fRetStructIdx`), or -1.
function fnRetStructIndex(name: string): i32 {
  let i = 0
  while i < fnNames.length {
    if fnNames[i] == name { return fRetStructIdx[i] }
    i = i + 1
  }
  0 - 1
}

// The struct table index of a module global `name` (from its annotation/initializer),
// or -1.
function globalStructIndex(name: string): i32 {
  let li = globalLetOf(name)
  if li < 0 { return 0 - 1 }
  structIndexOfLet(li, 0 - 1)
}

// The struct table index that the expression at `exprIx` produces, or -1 if it is not
// a struct value. Mirrors `exprStruct`'s cases.
function structIndexOfExpr(exprIx: i32, fnIx: i32): i32 {
  if exprIx < 0 { return 0 - 1 }
  let e = P.nodes[exprIx]
  if e is ObjLit { return structIndexOfObj(exprIx) }
  if e is Paren { return structIndexOfExpr(e.parInner, fnIx) }
  if e is Call {
    let callee = P.nodes[e.callFn]
    if callee is Ident { return fnRetStructIndex(callee.identName) }
    return 0 - 1
  }
  if e is Ident {
    let pi = paramStructIndex(fnIx, e.identName)
    if pi >= 0 { return pi }
    let di = declaredStructIndex(e.identName)
    if di >= 0 { return di }
    return globalStructIndex(e.identName)
  }
  // `xs[i]` over a STRUCT-element ref list yields that list's element struct. The
  // element struct TABLE INDEX comes from the receiver's per-element-type slot's name
  // (`Tok[]` â†’ `Tok` â†’ its struct index), so distinct struct ref-lists resolve to
  // distinct struct types â€” not always heap-type 0.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      let nm = refListElemNameOfExpr(e.idxArr, fnIx)
      let si = structIndexByName(nm)
      if si >= 0 { return si }
    }
  }
  0 - 1
}

// The struct table index a struct-typed `LetDecl` binds: from its annotation if
// present, else inferred from its initializer. -1 if not a struct local.
function structIndexOfLet(letIx: i32, fnIx: i32): i32 {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      let lt = P.nodes[d.letType]
      if lt is TypeRef {
        let si = structIndexByName(lt.tyName)
        if si >= 0 { return si }
      }
    }
    return structIndexOfExpr(d.letInit, fnIx)
  }
  0 - 1
}

// â”€â”€ union-typedness of expressions (G1) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Parallel to the struct family: decide whether an expression / param / local / let
// is the declared UNION (a `(ref $uBoxIdx)` boxed value). Unlike structs, an object
// literal's INTRINSIC type is its variant struct, NOT the union â€” boxing happens at a
// flow boundary (a `let n: U = â€¦`, a union-returning `return`, a union-typed arg). So
// `exprUnion` is true for a union-returning call / union param / union local, but NOT
// a bare object literal (its boxing is driven by the EXPECTED type at the boundary).

// True if function `name` declares the union as its return type.
function fnRetUnion(name: string): boolean {
  let i = 0
  while i < fnNames.length {
    if fnNames[i] == name { return fRetUni[i] == 1 }
    i = i + 1
  }
  false
}

// True if the parameter `name` of function `fnIx` is the union type.
function paramUnion(fnIx: i32, name: string): boolean {
  if fnIx < 0 { return false }   // module-scope initializer (no enclosing function)
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    let params = fn.fnParams
    let i = 0
    while i < params.length {
      let p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            let ty = P.nodes[p.parType]
            if ty is TypeRef { return isUName(ty.tyName) }
          }
          return false
        }
      }
      i = i + 1
    }
  }
  false
}

// True if the already-collected declared local `name` is a union ref (code `4`).
function declaredUnion(name: string): boolean {
  let slot = declaredSlotOf(name)
  if slot < 0 { return false }
  localIsRef[slot] == 4
}

// True if evaluating the expression at `exprIx` yields the union box: a union-returning
// call, a union param/local reference, or a parenthesized union expression. (A bare
// object literal is NOT a union here â€” see the family note.)
function exprUnion(exprIx: i32, fnIx: i32): boolean {
  if exprIx < 0 { return false }
  let e = P.nodes[exprIx]
  if e is Paren { return exprUnion(e.parInner, fnIx) }
  if e is Call {
    let callee = P.nodes[e.callFn]
    if callee is Ident { return fnRetUnion(callee.identName) }
    return false
  }
  if e is Ident {
    if paramUnion(fnIx, e.identName) { return true }
    return declaredUnion(e.identName)
  }
  // `ns[i]` over a UNION-element ref list yields the union box (G7-ref) â€” so the value
  // is usable with `is`-narrowing (a `let n0 = ns[i]` is a union local). Per-slot: the
  // element kind comes from the receiver's distinct ref-list slot (2 = union box).
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      let slot = refListSlotOfExpr(e.idxArr, fnIx)
      return rlElemKindTbl[slot] == 2
    }
  }
  false
}

// True if the `LetDecl` at `letIx` declares a union-typed local: its annotation names
// the union, OR its initializer produces the union (a union-returning call etc.). An
// object-literal init under a union annotation is BOXED as the union (`emitStmt`).
function letIsUnion(letIx: i32, fnIx: i32): boolean {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      let lt = P.nodes[d.letType]
      if lt is TypeRef {
        if isUName(lt.tyName) { return true }
      }
    }
    return exprUnion(d.letInit, fnIx)
  }
  false
}

// The variant struct name an object literal at `objIx` matches: the union variant
// whose field-name set EQUALS the literal's field names (order-independent), or "" if
// none. Used to pick the tag + variant struct when boxing an object literal into the
// union.
function objVariantName(objIx: i32): string {
  let o = P.nodes[objIx]
  if o is ObjLit {
    let vi = 0
    while vi < uVariants.length {
      let cnt = uFieldCount[vi]
      if cnt == o.objFields.length {
        let start = uFieldStart[vi]
        let allMatch = true
        let fj = 0
        while fj < cnt {
          if objFieldVal(objIx, uFieldNames[start + fj]) < 0 { allMatch = false }
          fj = fj + 1
        }
        if allMatch { return uVariants[vi] }
      }
      vi = vi + 1
    }
  }
  ""
}

// â”€â”€ array-typedness of expressions â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Parallel to the struct family above: decide whether an expression / param / local
// PRODUCES the i32 array (a `(ref $aTypeIdx)`) rather than an i32. An index read
// `a[i]` and `a.length` are i32 (NOT arrays), so they are deliberately absent here.

// True if the function `name` declares an array (`i32[]`) as its return type.
function fnRetArray(name: string): boolean {
  let i = 0
  while i < fnNames.length {
    if fnNames[i] == name { return fRetArr[i] == 1 }
    i = i + 1
  }
  false
}

// True if the parameter `name` of function `fnIx` is an array type.
function paramArray(fnIx: i32, name: string): boolean {
  if fnIx < 0 { return false }   // module-scope initializer (no enclosing function)
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    let params = fn.fnParams
    let i = 0
    while i < params.length {
      let p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            let ty = P.nodes[p.parType]
            if ty is TypeRef { return nameIsI32Array(ty.tyName) }
          }
          return false
        }
      }
      i = i + 1
    }
  }
  false
}

// True if the already-collected declared local `name` is an i32-array ref (code `2`).
function declaredArray(name: string): boolean {
  let slot = declaredSlotOf(name)
  if slot < 0 { return false }
  localIsRef[slot] == 2
}

// True if evaluating the expression at `exprIx` yields the i32 array: an array
// literal (with i32 / no elements â€” a ref-element literal is NOT this), an
// array-returning call, an array param/local reference, or a parenthesized array
// The wasm-type code of the struct / variant FIELD a `Member` expression at `memIx`
// reads (`0` i32, `3` string, `4` i32-list, `5` ref-list), or `-1` if `memIx` is not a
// field read of a known struct/variant field. Mirrors `exprString`'s Member dispatch:
// a read on a NARROWED union identifier reads the variant field's type; otherwise the
// receiver's struct field's type. Used by `exprArray`/`exprRefArray` to type array-field
// reads (gap #5) so `.length` / indexing / assignment treat the result as a list.
function memFieldTypeCode(memIx: i32, fnIx: i32): i32 {
  let e = P.nodes[memIx]
  if e is Member {
    if memIsNarrowed(memIx) {
      let vi = memNarrowVariantIndex(memIx)
      if vi >= 0 {
        let vfi = variantFieldIndex(vi, e.memProp)
        if vfi >= 0 { return variantFieldTypeAt(vi, vfi) }
      }
      return 0 - 1
    }
    // A field read on a VARIANT-typed param `o.field` (`o: TyObj`) reads the variant
    // struct's field type directly (gap #2) â€” same table as a narrowed read, but the
    // receiver is the unboxed param, not a `narrowName` ident.
    let pvi = exprVariantIndex(e.memObj, fnIx)
    if pvi >= 0 {
      let pvfi = variantFieldIndex(pvi, e.memProp)
      if pvfi >= 0 { return variantFieldTypeAt(pvi, pvfi) }
    }
    let si = structIndexOfExpr(e.memObj, fnIx)
    if si >= 0 {
      let fi = sFieldIndex(si, e.memProp)
      if fi >= 0 { return sFieldTypeAt(si, fi) }
    }
  }
  0 - 1
}

// expression. An index read / `.length` yields an i32, so neither counts.
function exprArray(exprIx: i32, fnIx: i32): boolean {
  if exprIx < 0 { return false }
  let e = P.nodes[exprIx]
  if e is ArrayLit { return !arrLitIsRef(exprIx) }
  if e is Paren { return exprArray(e.parInner, fnIx) }
  if e is Call {
    let callee = P.nodes[e.callFn]
    if callee is Ident { return fnRetArray(callee.identName) }
    return false
  }
  if e is Ident {
    if paramArray(fnIx, e.identName) { return true }
    if declaredArray(e.identName) { return true }
    return globalIsArray(e.identName)
  }
  // A field read `p.items` whose struct field is an `i32[]` (code `4`) yields the i32
  // list wrapper ref â€” so `.length` / indexing / assignment treat it as a list (gap #5).
  if e is Member {
    if memFieldTypeCode(exprIx, fnIx) == 4 { return true }
  }
  false
}

// True if the `LetDecl` at `letIx` declares an array-typed local: its annotation is an
// array type (`i32[]`), OR its initializer produces an array. Picks the local's
// valtype (`(ref $aTypeIdx)` vs i32) in `collectLocals`.
function letIsArray(letIx: i32, fnIx: i32): boolean {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      let lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsI32Array(lt.tyName) { return true }
      }
    }
    return exprArray(d.letInit, fnIx)
  }
  false
}

// â”€â”€ ref-array-typedness of expressions (G7-ref) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Parallel to the i32-array family: decide whether an expression / param / local
// PRODUCES a REF list â€” `Tok[]` / `Node[]`, a `(ref $rlTypeIdx)`. Its receiver shapes
// mirror `exprArray` but for `S[]`/`N[]` annotations (the index/`.length` reads still
// yield i32 / the element, not the list). `localIsRef` code `5` flags a ref-list local.

// True if function `name` declares a ref array (`S[]`/`N[]`) as its return type.
function fnRetRefArray(name: string): boolean {
  let i = 0
  while i < fnNames.length {
    if fnNames[i] == name { return fRetRArr[i] == 1 }
    i = i + 1
  }
  false
}

// True if the parameter `name` of function `fnIx` is a ref-array type.
function paramRefArray(fnIx: i32, name: string): boolean {
  if fnIx < 0 { return false }   // module-scope initializer (no enclosing function)
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    let params = fn.fnParams
    let i = 0
    while i < params.length {
      let p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            let ty = P.nodes[p.parType]
            if ty is TypeRef { return nameIsRefArray(ty.tyName) }
          }
          return false
        }
      }
      i = i + 1
    }
  }
  false
}

// True if the already-collected declared local `name` is a ref-list ref (code `5`).
function declaredRefArray(name: string): boolean {
  let slot = declaredSlotOf(name)
  if slot < 0 { return false }
  localIsRef[slot] == 5
}

// True if evaluating the expression at `exprIx` yields a ref list: a ref-element array
// literal, a ref-array-returning call, a ref-array param/local reference, or a
// parenthesized ref-array expression. An index read / `.length` is NOT a list.
function exprRefArray(exprIx: i32, fnIx: i32): boolean {
  if exprIx < 0 { return false }
  let e = P.nodes[exprIx]
  if e is ArrayLit { return arrLitIsRef(exprIx) }
  if e is Paren { return exprRefArray(e.parInner, fnIx) }
  if e is Call {
    let callee = P.nodes[e.callFn]
    if callee is Ident { return fnRetRefArray(callee.identName) }
    return false
  }
  if e is Ident {
    if paramRefArray(fnIx, e.identName) { return true }
    if declaredRefArray(e.identName) { return true }
    return globalIsRefArray(e.identName)
  }
  // A field read `p.items` whose struct field is a `T[]`/`N[]` (code `5`) yields the ref
  // list wrapper ref â€” so `.length` / indexing / assignment treat it as a ref list.
  if e is Member {
    if memFieldTypeCode(exprIx, fnIx) == 5 { return true }
  }
  false
}

// The ref-list ELEMENT type-NAME a ref-array param `name` of function `fnIx` declares
// (`p: Tok[]` â†’ `Tok`), or "" if not a ref-array param.
function paramRefArrayName(fnIx: i32, name: string): string {
  if fnIx < 0 { return "" }   // module-scope initializer (no enclosing function)
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    let params = fn.fnParams
    let i = 0
    while i < params.length {
      let p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            let ty = P.nodes[p.parType]
            if ty is TypeRef {
              if nameIsRefArray(ty.tyName) { return refArrElemName(ty.tyName) }
            }
          }
          return ""
        }
      }
      i = i + 1
    }
  }
  ""
}

// The ref-list ELEMENT type-NAME a function `name` returns (from its `S[]`/`N[]` return
// annotation, recorded in `fRetRArrElem`), or "".
function fnRetRefArrayName(name: string): string {
  let i = 0
  while i < fnNames.length {
    if fnNames[i] == name { return fRetRArrElem[i] }
    i = i + 1
  }
  ""
}

// The ref-list ELEMENT type-NAME of the declared local `name` (recorded in
// `localStructIdx` as its table SLOT for code-5 locals), or "".
function declaredRefArrayName(name: string): string {
  let i = declaredSlotOf(name)
  if i >= 0 {
    if localIsRef[i] == 5 {
      let slot = localStructIdx[i]
      if slot >= 0 { if slot < rlElemName.length { return rlElemName[slot] } }
    }
  }
  ""
}

// The ref-list ELEMENT type-NAME a module global `name` declares (`S[]`/`N[]`), or "".
function globalRefArrayName(name: string): string {
  let li = globalLetOf(name)
  if li < 0 { return "" }
  letRefListElemName(li, 0 - 1)
}

// The ref-list ELEMENT type-NAME the expression at `exprIx` produces, or "" if it is not
// a ref list. Mirrors `exprRefArray`'s receiver shapes â€” used to resolve the per-element-
// type table SLOT (`refListSlotOfExpr`) at every push / index / `.length` / store site.
function refListElemNameOfExpr(exprIx: i32, fnIx: i32): string {
  if exprIx < 0 { return "" }
  let e = P.nodes[exprIx]
  if e is ArrayLit { return arrLitElemName(exprIx) }
  if e is Paren { return refListElemNameOfExpr(e.parInner, fnIx) }
  if e is Call {
    let callee = P.nodes[e.callFn]
    if callee is Ident { return fnRetRefArrayName(callee.identName) }
    return ""
  }
  if e is Ident {
    let pn = paramRefArrayName(fnIx, e.identName)
    if pn != "" { return pn }
    let dn = declaredRefArrayName(e.identName)
    if dn != "" { return dn }
    return globalRefArrayName(e.identName)
  }
  if e is Member {
    // A `recv.field` ref-list field read â€” the field's element name from the receiver's
    // struct / narrowed variant.
    if memIsNarrowed(exprIx) {
      let vi = memNarrowVariantIndex(exprIx)
      if vi >= 0 {
        let vfi = variantFieldIndex(vi, e.memProp)
        if vfi >= 0 { return uFieldElemName[uFieldStart[vi] + vfi] }
      }
      return ""
    }
    let si = structIndexOfExpr(e.memObj, fnIx)
    if si >= 0 {
      let fi = sFieldIndex(si, e.memProp)
      if fi >= 0 { return sFieldElemNameAt(si, fi) }
    }
  }
  ""
}

// The per-element-type ref-list table SLOT the expression at `exprIx` produces, or 0
// (slot fallback) if the element type can't be resolved â€” every migrated site uses this
// to pick the right backing/wrapper/element indices.
function refListSlotOfExpr(exprIx: i32, fnIx: i32): i32 {
  let nm = refListElemNameOfExpr(exprIx, fnIx)
  let s = rlSlotByName(nm)
  if s < 0 { return 0 }
  s
}

// True if the `LetDecl` at `letIx` declares a ref-list local: its annotation is a ref
// array (`S[]`/`N[]`), OR its initializer produces a ref list. Picks the local's valtype
// (`(ref $rlTypeIdx)`) and the code-`5` flag in `collectLocals`.
function letIsRefArray(letIx: i32, fnIx: i32): boolean {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      let lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsRefArray(lt.tyName) { return true }
      }
    }
    return exprRefArray(d.letInit, fnIx)
  }
  false
}

// The ref-list ELEMENT type-NAME a ref-list `LetDecl` binds: from its `S[]`/`N[]`
// annotation if present, else inferred from its initializer (`refListElemNameOfExpr`).
// "" if not a ref-list local.
function letRefListElemName(letIx: i32, fnIx: i32): string {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      let lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsRefArray(lt.tyName) { return refArrElemName(lt.tyName) }
      }
    }
    return refListElemNameOfExpr(d.letInit, fnIx)
  }
  ""
}

// The ref-list TABLE SLOT a ref-list `LetDecl` binds (stored in `localStructIdx` for a
// code-5 local so `declaredRefArrayName` can recover its element type), or -1.
function letRefListSlot(letIx: i32, fnIx: i32): i32 {
  rlSlotByName(letRefListElemName(letIx, fnIx))
}

// The ref-list element kind a `LetDecl`'s ANNOTATION declares (`S[]` â†’ 1, `N[]` â†’ 2),
// or `0` when it is not a ref-array annotation. Used to type an empty `[]` initializer
// (a non-empty literal types itself from its elements).
function letAnnRefListKind(letIx: i32): i32 {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      let lt = P.nodes[d.letType]
      if lt is TypeRef {
        // `pendingListKind` semantics: 1 = struct/MAP ref list (use `pendingListSlot`),
        // 2 = union box ref list, 3 = string list. A map-array (`refArrElemKind` 3) is a
        // ref list disambiguated by its slot, so it threads kind 1 (NOT the string-3).
        if nameIsRefArray(lt.tyName) {
          if refArrElemKind(lt.tyName) == 2 { return 2 }
          return 1
        }
        if nameIsStringArray(lt.tyName) { return 3 }
      }
    }
  }
  0
}

// The ref-list TABLE SLOT a `LetDecl`'s ref-array annotation names (`let xs: Tok[] = []`
// â†’ the `Tok` slot), or 0 when it is not a ref-array annotation. Threads `pendingListSlot`
// so an empty `[]` initializer builds the annotation's distinct element type.
function letAnnRefListSlot(letIx: i32): i32 {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      let lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsRefArray(lt.tyName) {
          let s = rlSlotByName(refArrElemName(lt.tyName))
          if s >= 0 { return s }
        }
      }
    }
  }
  0
}

// â”€â”€ string-array-typedness of expressions (`string[]`) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Parallel to the ref-array family: decide whether an expression / param / local
// PRODUCES a string list â€” a `(ref $mkListIdx)`. Receiver shapes: a `string[]` literal,
// a `string[]` param/local, a parenthesized string-array, or a `string[]` FIELD read
// (code `6`). An index read `xs[i]` (a string) / `.length` (i32) is NOT a list.

// True if the parameter `name` of function `fnIx` is a `string[]` type.
function paramStringArray(fnIx: i32, name: string): boolean {
  if fnIx < 0 { return false }   // module-scope initializer (no enclosing function)
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    let params = fn.fnParams
    let i = 0
    while i < params.length {
      let p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            let ty = P.nodes[p.parType]
            if ty is TypeRef { return nameIsStringArray(ty.tyName) }
          }
          return false
        }
      }
      i = i + 1
    }
  }
  false
}

// True if the already-collected declared local `name` is a string-list ref (code `7`).
function declaredStringArray(name: string): boolean {
  let slot = declaredSlotOf(name)
  if slot < 0 { return false }
  localIsRef[slot] == 7
}

// True if evaluating the expression at `exprIx` yields a string list: a string-element
// array literal, a `string[]` param/local reference, a parenthesized string-array, or a
// `string[]` field read (code `6`). An index read / `.length` is NOT a list.
function exprStringArray(exprIx: i32, fnIx: i32): boolean {
  if exprIx < 0 { return false }
  let e = P.nodes[exprIx]
  if e is ArrayLit { return arrLitIsStr(exprIx, fnIx) }
  if e is Paren { return exprStringArray(e.parInner, fnIx) }
  if e is Ident {
    if paramStringArray(fnIx, e.identName) { return true }
    if declaredStringArray(e.identName) { return true }
    return globalIsStringArray(e.identName)
  }
  // A field read `p.names` whose field is a `string[]` (code `6`) yields the string-list
  // wrapper ref â€” so `.length` / indexing / assignment / `.push` treat it as a string list.
  if e is Member {
    if memFieldTypeCode(exprIx, fnIx) == 6 { return true }
  }
  false
}

// True if the `LetDecl` at `letIx` declares a `string[]` local: its annotation is
// `string[]`, OR its initializer produces a string list. Picks the local's valtype
// (`(ref $mkListIdx)`) and the code-`7` flag in `collectLocals`.
function letIsStringArray(letIx: i32, fnIx: i32): boolean {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      let lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsStringArray(lt.tyName) { return true }
      }
    }
    return exprStringArray(d.letInit, fnIx)
  }
  false
}

// â”€â”€ map-typedness of expressions (G8: `{[string]: i32}`) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Parallel to the array family: decide whether an expression / param / local PRODUCES
// a string-keyed MAP â€” a `(ref $mStructIdx)`. The receiver shapes that matter for the
// self-host checker are a map LOCAL (`let m: {[string]: i32} = Map()` â†’ code `6`), a
// map PARAM, and `Map()` itself (the empty-map constructor). An index read `m[k]` /
// `m.has(k)` yields an i32, NOT a map, so neither counts here.

// True if the parameter `name` of function `fnIx` is a map type.
function paramMap(fnIx: i32, name: string): boolean {
  if fnIx < 0 { return false }   // module-scope initializer (no enclosing function)
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    let params = fn.fnParams
    let i = 0
    while i < params.length {
      let p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            let ty = P.nodes[p.parType]
            if ty is TypeRef { return nameIsMap(ty.tyName) }
          }
          return false
        }
      }
      i = i + 1
    }
  }
  false
}

// True if the already-collected declared local `name` is a map ref (code `6`).
function declaredMap(name: string): boolean {
  let slot = declaredSlotOf(name)
  if slot < 0 { return false }
  localIsRef[slot] == 6
}

// True if evaluating the expression at `exprIx` yields a string-keyed map: the
// `Map()` constructor call, a map param/local reference, or a parenthesized map
// expression.
function exprMap(exprIx: i32, fnIx: i32): boolean {
  if exprIx < 0 { return false }
  let e = P.nodes[exprIx]
  if e is Paren { return exprMap(e.parInner, fnIx) }
  if e is Call {
    let callee = P.nodes[e.callFn]
    if callee is Ident { return callee.identName == "Map" }
    // `scopes.pop()` over a map ref list (`{[string]:i32}[]`) yields a Map ref.
    if callee is Member {
      if callee.memProp == "pop" {
        if exprRefArray(callee.memObj, fnIx) {
          let slot = refListSlotOfExpr(callee.memObj, fnIx)
          if slot >= 0 { return rlElemKindTbl[slot] == 3 }
        }
      }
    }
    return false
  }
  if e is Ident {
    if paramMap(fnIx, e.identName) { return true }
    return declaredMap(e.identName)
  }
  // `scopes[i]` over a MAP ref list (`{[string]:i32}[]`, element kind 3) yields a Map ref
  // â€” so map member/index ops on it route to the existing map lowering. Per-slot: the
  // element kind comes from the receiver's distinct ref-list slot.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      let slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 { return rlElemKindTbl[slot] == 3 }
    }
  }
  false
}

// â”€â”€ G8: map ops on a GLOBAL struct-field map-array element â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// `fnHasMap` (above) reserves the map scratch frame from map PARAMS / map LOCALS /
// map-array LOCALS (code 5 + element kind 3). But a map op can also run on an
// element of a GLOBAL struct-field map-array â€” e.g. `T.scopes[top][name] = v` in the
// self-host checker's `declare`, where `T` is a module global struct and `scopes` is
// a `{[string]:i32}[]` field. Such a function has NO map local, so the local scan
// misses it and `mapScratchBase` points past the locals â†’ `invalid local index`.
//
// This walk fires on EXACTLY the four shapes `emitExpr`/`emitStmt` lower as map ops â€”
// each gated by `exprMap` on the same receiver (`exprMap` already resolves a
// global-field map-array element via `exprRefArray`â†’`memFieldTypeCode`==5 +
// `rlElemKindTbl`==3): the map GET `recv[k]`, the fused `recv[k] ?? d`, the
// `.has(k)` member-call, and the map SET `recv[k] = v`. Matching the lowered set
// EXACTLY means it never over-reserves: a function with no map-op shape stays
// byte-identical. The map LOCAL / param cases are already handled by `fnHasMap`, so
// this is OR'd in only as the additional global-field coverage.
//
// (No narrowing is applied here â€” a global-field map-array receiver resolves through
// `structIndexOfExpr` on a global ident, independent of any active variant narrowing,
// and this helper must stay declare-before-use-safe relative to the narrow stack.)

// True if the expression at `exprIx` (recursively) contains a map-op shape whose
// receiver `exprMap` resolves â€” i.e. a shape the emitter lowers via the map scratch
// frame.
function exprHasMapOp(exprIx: i32, fnIx: i32): boolean {
  if exprIx < 0 { return false }
  let e = P.nodes[exprIx]
  if e is Index {
    // Map GET `recv[k]`.
    if exprMap(e.idxArr, fnIx) { return true }
    if exprHasMapOp(e.idxArr, fnIx) { return true }
    return exprHasMapOp(e.idxIndex, fnIx)
  }
  if e is BinExpr {
    // Fused map get-with-default `recv[k] ?? d`.
    if e.binOp == "??" {
      let lhs = P.nodes[e.binLeft]
      if lhs is Index {
        if exprMap(lhs.idxArr, fnIx) { return true }
      }
    }
    // Map SET `recv[k] = v` (an assignment is a statement, but walk it defensively).
    if e.binOp == "=" {
      let target = P.nodes[e.binLeft]
      if target is Index {
        if exprMap(target.idxArr, fnIx) { return true }
      }
    }
    if exprHasMapOp(e.binLeft, fnIx) { return true }
    return exprHasMapOp(e.binRight, fnIx)
  }
  if e is Call {
    // `recv.has(k)` map membership.
    let callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "has" {
        if exprMap(callee.memObj, fnIx) { return true }
      }
    }
    if exprHasMapOp(e.callFn, fnIx) { return true }
    let args = e.callArgs
    let i = 0
    while i < args.length {
      if exprHasMapOp(args[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  if e is Member { return exprHasMapOp(e.memObj, fnIx) }
  if e is Unary { return exprHasMapOp(e.unArg, fnIx) }
  if e is Paren { return exprHasMapOp(e.parInner, fnIx) }
  if e is IsExpr { return exprHasMapOp(e.isObj, fnIx) }
  if e is ObjLit {
    let fields = e.objFields
    let i = 0
    while i < fields.length {
      let f = P.nodes[fields[i]]
      if f is FieldInit {
        if exprHasMapOp(f.fiValue, fnIx) { return true }
      }
      i = i + 1
    }
    return false
  }
  if e is ArrayLit {
    let elems = e.arrElems
    let i = 0
    while i < elems.length {
      if exprHasMapOp(elems[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  false
}

// True if any statement in the block at `blockIx` (descending into if/else branches
// and while bodies) contains a map op. An assignment statement (`recv[k] = v`) is a
// bare `BinExpr` with `binOp == "="` â€” `exprHasMapOp` recognizes its SET shape.
function blockHasMapOp(blockIx: i32, fnIx: i32): boolean {
  let b = P.nodes[blockIx]
  if b is Block {
    let stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      let s = P.nodes[stmts[i]]
      if s is LetDecl {
        if exprHasMapOp(s.letInit, fnIx) { return true }
      } else if s is RetStmt {
        if exprHasMapOp(s.retArg, fnIx) { return true }
      } else if s is BinExpr {
        if exprHasMapOp(stmts[i], fnIx) { return true }
      } else if s is Call {
        if exprHasMapOp(stmts[i], fnIx) { return true }
      } else if s is IfStmt {
        if ifChainHasMapOp(stmts[i], fnIx) { return true }
      } else if s is WhileStmt {
        if exprHasMapOp(s.whileCond, fnIx) { return true }
        if blockHasMapOp(s.whileBody, fnIx) { return true }
      }
      i = i + 1
    }
  }
  false
}

// True if any arm of the `if` / `else if` chain at `ifIx` contains a map op â€” its
// condition, then-branch, `else` block, OR (recursively) a chained `else if`.
function ifChainHasMapOp(ifIx: i32, fnIx: i32): boolean {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    if exprHasMapOp(s.ifCond, fnIx) { return true }
    if blockHasMapOp(s.ifThen, fnIx) { return true }
    if s.ifElse >= 0 {
      let els = P.nodes[s.ifElse]
      if els is Block {
        if blockHasMapOp(s.ifElse, fnIx) { return true }
      } else if els is IfStmt {
        if ifChainHasMapOp(s.ifElse, fnIx) { return true }
      }
    }
  }
  false
}

// True if the FuncDecl at `fnIx` performs a map op on a GLOBAL struct-field map-array
// element (or any map-op shape `fnHasMap`'s local scan does not already cover) â€” so it
// reserves the shared 12-slot map scratch frame. OR'd into `fnUsesMap`.
function fnHasGlobalMapOp(fnIx: i32): boolean {
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    return blockHasMapOp(fn.fnBody, fnIx)
  }
  false
}

// True if the `LetDecl` at `letIx` declares a map-typed local: its annotation is a map
// type (`{[string]: i32}`), OR its initializer produces a map (`Map()`). Picks the
// local's valtype (`(ref $mStructIdx)`) and the code-`6` flag in `collectLocals`.
function letIsMap(letIx: i32, fnIx: i32): boolean {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      let lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsMap(lt.tyName) { return true }
      }
    }
    return exprMap(d.letInit, fnIx)
  }
  false
}

// â”€â”€ string-typedness of expressions â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Parallel to the array family above: decide whether an expression / param / local
// PRODUCES a `string` (CURRENTLY the same `(array (mut i32))` of code points an array
// is â€” `docs/strings-design.md`). Used to route `s.length` to `array.len` and `s[i]`
// to `array.get`, and to give string locals/params the array ref valtype. Like the
// array family, a `.length`/index READ yields an i32 (NOT a string), so neither
// counts here. Concatenation (`+`), equality (`==`), and `slice`/`indexOf` are DEFERRED
// (this slice covers only literal construction + `.length` + index read), so no
// binary/call op below produces a string except a `string`-returning call.

// True if the function `name` declares `string` as its return type. The `fromCodePoint`
// compiler builtin (H2) constructs a single-character VL string, so it is `string`-
// returning too â€” classifying it here (the single chokepoint `exprString` consults for
// a named call) routes `value + fromCodePoint(cp)` to string concat, flags
// `let s = fromCodePoint(n)` as a string local, etc., exactly as a user `string`-
// returning function would be.
function fnRetString(name: string): boolean {
  if name == "fromCodePoint" { return true }
  let i = 0
  while i < fnNames.length {
    if fnNames[i] == name { return fRetStr[i] == 1 }
    i = i + 1
  }
  false
}

// True if the parameter `name` of function `fnIx` is `string`-typed.
function paramString(fnIx: i32, name: string): boolean {
  if fnIx < 0 { return false }   // module-scope initializer (no enclosing function)
  let fn = P.nodes[fnIx]
  if fn is FuncDecl {
    let params = fn.fnParams
    let i = 0
    while i < params.length {
      let p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            let ty = P.nodes[p.parType]
            if ty is TypeRef { return nameIsString(ty.tyName) }
          }
          return false
        }
      }
      i = i + 1
    }
  }
  false
}

// True if the already-collected declared local `name` is a string ref (code `3`).
function declaredString(name: string): boolean {
  let slot = declaredSlotOf(name)
  if slot < 0 { return false }
  localIsRef[slot] == 3
}

// True if evaluating the expression at `exprIx` yields a string: a string literal, a
// `string`-returning call, a string param/local reference, or a parenthesized string
// expression. An index read / `.length` yields an i32, so neither counts.
function exprString(exprIx: i32, fnIx: i32): boolean {
  if exprIx < 0 { return false }
  let e = P.nodes[exprIx]
  if e is StrLit { return true }
  if e is Paren { return exprString(e.parInner, fnIx) }
  if e is Call {
    // G6: `s.slice(...)` over a string receiver produces a string. Otherwise a
    // bare call produces a string iff the callee declares a `string` return.
    if exprIsStrSlice(exprIx, fnIx) { return true }
    let callee = P.nodes[e.callFn]
    if callee is Ident { return fnRetString(callee.identName) }
    return false
  }
  if e is BinExpr {
    // G6: string concatenation `a + b` produces a string; no other binary operator
    // does (`==`/`!=` yield an i32).
    return exprIsStrConcat(exprIx, fnIx)
  }
  if e is Ident {
    if paramString(fnIx, e.identName) { return true }
    if declaredString(e.identName) { return true }
    return globalIsString(e.identName)
  }
  // A field read `p.f` where `f` is a STRING struct field yields a string ref (gap #2:
  // `let k = t.kind` must give `k` the string type, not i32).
  if e is Member {
    // A field read on a NARROWED union identifier (`if n is A { â€¦ n.f â€¦ }`) reads the
    // variant field; a string variant field yields a string ref.
    if memIsNarrowed(exprIx) {
      let vi = memNarrowVariantIndex(exprIx)
      if vi >= 0 {
        let vfi = variantFieldIndex(vi, e.memProp)
        if vfi >= 0 {
          if variantFieldTypeAt(vi, vfi) == 3 { return true }
        }
      }
      return false
    }
    let si = structIndexOfExpr(e.memObj, fnIx)
    if si >= 0 {
      let fi = sFieldIndex(si, e.memProp)
      if fi >= 0 {
        if sFieldTypeAt(si, fi) == 3 { return true }
      }
    }
  }
  false
}

// True if the `LetDecl` at `letIx` declares a string-typed local: its annotation is
// `string`, OR its initializer produces a string. Picks the local's valtype
// (`(ref $aTypeIdx)` vs i32) in `collectLocals`.
function letIsString(letIx: i32, fnIx: i32): boolean {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      let lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsString(lt.tyName) { return true }
      }
    }
    return exprString(d.letInit, fnIx)
  }
  false
}

function emitProgram(rootIx: i32): i32 {
  emitFailed = false
  emitErr = ""
  narrowNames = []
  narrowVariants = []
  narrowTop = 0
  if rootIx < 0 {
    return emitFail("emitProgram: empty arena (root index < 0)")
  }
  let root = P.nodes[rootIx]
  if root is Program {
    let stmts = root.progStmts
    if stmts.length < 1 {
      return emitFail("emitProgram: expected at least one top-level statement")
    }
    // Collect the union alias FIRST (so `collectS` knows whether the program's
    // structs are union variants vs a single direct struct), then the (single)
    // struct type, so param/return/local checks can recognize its name, then the
    // function list (FuncDecls only), then the nameâ†’index map. Forward references and
    // recursion resolve because every name is mapped before any body is emitted.
    if collectU(stmts) < 0 { return 0 - 1 }
    if collectS(stmts) < 0 { return 0 - 1 }
    if collectA(stmts) < 0 { return 0 - 1 }
    if collectFns(stmts) < 0 { return 0 - 1 }
    if fnStmts.length < 1 {
      return emitFail("emitProgram: expected at least one top-level function")
    }
    if buildFnMap(stmts) < 0 { return 0 - 1 }
    // Every function's parameters must be i32 or the struct type before we commit.
    let i = 0
    while i < fnStmts.length {
      if checkParams(fnStmts[i]) < 0 { return 0 - 1 }
      i = i + 1
    }
    return emitModule(stmts)
  }
  emitFail("emitProgram: root node is not a Program")
}

// Render the current buffer as a comma-joined decimal string (the round-trip
// wire format the TS test parses back into a Uint8Array).
function bytesToStr(): string {
  let out = ""
  let i = 0
  while i < W.bytes.length {
    if i > 0 { out = out + "," }
    out = out + i32ToStr(W.bytes[i])
    i = i + 1
  }
  out
}
