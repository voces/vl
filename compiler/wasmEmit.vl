import { emitFail, fbArrayCopy, fbArrayGet, fbArrayLen, fbArrayNew, fbArrayNewDefault, fbArrayNewFixed, fbArraySet, fbBeginFunc, fbBlock, fbBr, fbBrIf, fbCall, fbCallRef, fbDrop, fbElse, fbEmitLocalsVec, fbEnd, fbF32Const, fbF32ConvertI32S, fbF64Const, fbF64ConvertI32S, fbF64ConvertI64S, fbF64PromoteF32, fbF32Run, fbGlobalGet, fbGlobalSet, fbI32Bin, fbI32Const, fbI32Eqz, fbI32Load, fbI32Run, fbI32Store, fbI64Const, fbI64ExtendI32S, fbIf, fbLocalGet, fbLocalRun, fbLocalSet, fbLocalsCount, fbLoop, fbRefAsNonNull, fbRefCast, fbRefFunc, fbRefNull, fbRefNullForKind, fbRefNullNone, fbRefNullRun, fbRefNullStruct, fbRefRun, fbReserve, fbReturn, fbStructGet, fbStructNew, fbStructSet, fbUnreachable, fbValtype, fbValtypeNullable, mapTypeIdxOf, mvValElemHeapOf, mvValsBackOf, wBytes, wName, wSLEB, wSLEB64, wSection, wTarget, wU8, wULEB } from "./emit_bytes"
//
// Output representation: a VL `i32[]` of byte values 0..255. WasmGC has no `u8`,
// so `i32[]` is used (see docs/selfhost-gaps.md). Bytes are masked to the low
// 8 bits on emit (`& 0xff`).

// Host opt-in for the name section (see `gEmitNames`). The driver does NOT call
// this, so every golden/fixpoint emit leaves names OFF; only the native tool
// turns it on. Idempotent — any nonzero `on` enables, `0` disables.
export function setEmitNames(on: i32) {
  if on != 0 { gEmitNames = 1 } else { gEmitNames = 0 }
  0
}

function emitReset() {
  // NOTE: `gImports` and `startStmts` are NOT reset here — they are assigned by
  // their own passes (the print-detection scan in `emitProgram`, `collectFns`)
  // which run BEFORE `emitModule` calls this; resetting them here would clobber
  // those passes' results.
  W.bytes = []
  curBuf = W.bytes
  0
}

// ── LEB128 encoders ──────────────────────────────────────────────────────────
// Each encoder stores 7 data bits per output byte; the high bit (0x80) is the
// continuation flag, set on every byte except the last. `& 0x7f` extracts the
// low 7 bits, `>>> 7` does the unsigned right-shift for ULEB, `>> 7` does the
// arithmetic right-shift for SLEB (preserving sign), and `| 0x80` sets the
// continuation bit. The canonical `*ToArr` forms return a fresh `i32[]` so
// they compose into nested payload builders; `wULEB`/`wSLEB` append straight to
// the current buffer (`curBuf`) for section-length framing and operands.

// ── FuncBuilder opcode methods (Layer 2 — typed instruction emission) ─────────
// One top-level, closure-free function per opcode (or opcode family) VL emits. Each
// writes EXACTLY the bytes the corresponding raw `body.push(<opcode>)` (+ any LEB
// operands) emitted before, straight through the BinaryWriter (`wU8`/`wULEB`/`wSLEB`)
// onto the CURRENT buffer (`curBuf`). The lowering sets `curBuf` to the buffer it is
// filling (the function body, or a global-init constexpr) via `wTarget`, so these
// methods need no `body` parameter — they are the single place each magic opcode byte
// lives. Every method returns `0` (a side-effecting builder; statement sequencing
// replaces method chaining). The opcode set is small and closed (~40); this phase
// (Phase B) DEFINES the whole set's control/locals/consts family with real bodies and
// converts its call sites, leaving the struct / array / map / string families to land
// in Phases C–F.

// ── f64.const: pure-i32 decimal-string → IEEE-754 double (Slice 3) ─────────────
// The self-host compiler is i32-only — it has no float runtime and cannot ask the
// host for a value's bits. So `f64.const` is synthesized arithmetically from the
// decimal LEXEME: parse it as an exact rational `mantissa / 10^fracDigits`, then
// long-divide in binary to a 53-bit significand with round-to-nearest-ties-to-even,
// and pack sign|exp|mantissa. All intermediates exceed 32 bits, so a "bignum" is
// carried as a little-endian array of base-2^16 i32 LIMBS (each 0..0xffff); every
// partial product (16×16) stays within i32. Validated bit-for-bit against the
// hardware IEEE-754 encoder for 2.5/1.0/0.5/3.14/0.1/0.2/0.3/1000.5/pi and rounding
// torture cases before wiring in.

// ── module header ────────────────────────────────────────────────────────────
function emitHeader() {
  // "\0asm" magic + version 1
  wU8(0)
  wU8(97)  // 'a'
  wU8(115) // 's'
  wU8(109) // 'm'
  wU8(1)
  wU8(0)
  wU8(0)
  wU8(0)
  0
}

// ── AST-driven back end ──────────────────────────────────────────────────────
// The fixed-module builders above prove the byte machinery on hand-built bytes.
// `emitProgram` is the first slice that actually READS the parsed arena
// (`P.nodes`, the `Node[]` from `compiler/ast.vl` that `parser.vl` fills) and
// emits a real module from it — reusing every section / LEB / encoding helper.
//
// It handles exactly the trivial shape and nothing else:
//
//   function main(): i32 { return <integer literal> }
//
// Anything outside that shape is a HARD STOP: `emitFail` records a message and
// clears the buffer, so the driver/test sees an empty module (which never
// instantiates) plus an explanation — never silently-wrong bytes. Richer codegen
// (params, locals, real expressions, multiple functions) is the next slice.

// ── function-index map ───────────────────────────────────────────────────────
// A module has N top-level functions. Each is assigned a wasm function index by
// its position in `progStmts` (the 0th `FuncDecl` is func 0, the 1st is func 1, …),
// and every function shares the SAME type index (all are `(i32 * n) -> i32`, but
// arities differ, so each gets its own type — see `emitModule`). A `call` lowers a
// callee NAME to its function index, so the name→index map is built over ALL
// top-level functions BEFORE any body is emitted: that makes forward references and
// (since a function's own name is already mapped) recursion resolve for free.
//
// The map is two parallel top-level `let` arrays (they lower to wasm globals): the
// i-th name maps to the i-th function index. `fnNames[i]`'s function index is
// `fnIndices[i]`, which equals `i` here but is kept explicit for clarity.

// Scan the program's top-level statements into `fnStmts` (FuncDecls only, in order),
// skipping `TypeDecl`s and gathering top-level `LetDecl`s into `globalStmts` (module
// globals, declaration order = global index). Any other top-level statement fails
// loudly. Returns the function count, or -1 (via `emitFail`).
function collectFns(stmts: i32[]) {
  fnStmts = []
  fnParent = []
  globalStmts = []
  globalNames = []
  globalNameMap = Map()
  startStmts = []
  lambdaCtr = 0
  fnDispNames = []
  fnValUsed = false
  let i = 0
  while i < stmts.length {
    let s = P.nodes[stmts[i]]
    if s is FuncDecl {
      fnStmts.push(stmts[i])
      fnParent.push(-1)
      fnDispNames.push("")
    } else if s is LetDecl {
      // A top-level `let`/`const` — a module global; its position here is its index.
      globalStmts.push(stmts[i])
      if !globalNameMap.has(s.letName) {
        globalNameMap[s.letName] = globalNames.length
      }
      globalNames.push(s.letName)
    } else if nodeIsTypeDecl(stmts[i]) {
    } else if s is UnionDecl {
      // A `type N = A | B` union alias — collected by `collectU`, skipped here.
    } else {
      // A top-level STATEMENT — runs in the synthetic start function (source order).
      startStmts.push(stmts[i])
    }
    i = i + 1
  }
  // Lift nested function declarations and anonymous `function(...)...` literals into
  // the flat `fnStmts` list (lambda support). Each lifted FuncDecl becomes a real
  // top-level wasm function with its own index. Scan the bodies of every function
  // already collected AND every top-level global init / start statement; the worklist
  // grows as nested functions are discovered (a closure inside a closure). Anonymous
  // literals (`fnName == ""`) get a synthesized `__lambda_N` name written into the node.
  let wi = 0
  while wi < fnStmts.length {
    const fn = P.nodes[fnStmts[wi]]
    if fn is FuncDecl { liftFnsInExpr(fn.fnBody, wi) }
    wi = wi + 1
  }
  // Also lift lambdas in top-level global initializers and start statements (parent -1).
  let gi = 0
  while gi < globalStmts.length {
    const g = P.nodes[globalStmts[gi]]
    if g is LetDecl {
      if g.letInit >= 0 {
        const before = fnStmts.length
        liftFnsInExpr(g.letInit, -1)
        recordLambdaDispName(before, g.letInit, g.letName)
      }
    }
    gi = gi + 1
  }
  let si = 0
  while si < startStmts.length {
    liftFnsInExpr(startStmts[si], -1)
    si = si + 1
  }
  // The `$fnsig` signature collection happens LATER (`collectCloSigs`, after
  // `computeRetInference`): a signature key reads each function's param AND return
  // kinds, and an un-annotated callback's return kind is only known once inference ran.
  cloSigKeys = []
  cloSigRepFn = []
  fnStmts.length
}

// The `$fnsig` PARAM-spine token for the parameter at `paramIx` — one token per distinct
// param VALTYPE, so two functions share a `$fnsig` exactly when their param valtypes
// byte-match. Mirrors `fbValtype`'s coverage (the functype emitter writes
// `fbValtype(vtKindOfParam, paramStructIdxOf)` for each param) and the annotation-string
// scheme in `annParamKind`. Single-char tokens for the FIXED-valtype kinds (every i32 /
// string / closure / list param has an identical valtype); the struct-table index is
// appended (delimited by `;`) for the per-shape kinds (struct, nullable struct, ref list).
// "" for a kind still outside the value-call ABI (union box / variant / map param) — that
// keeps the signature un-interned (a clean "no interned signature" rejection at the call /
// value site, never a mis-lowered all-i32 fallback).
function cloParamTok(paramIx: i32) {
  const k = vtKindOfParam(paramIx)
  if k == 0 {
    return "i" // i32 / boolean
  }
  if k == 11 {
    return "d" // f64
  }
  if k == 3 {
    return "S" // string
  }
  if k == 2 {
    return "a" // i32[]
  }
  if k == 7 {
    return "A" // string[]
  }
  if k == 12 {
    return "D" // f64[]
  }
  if k == 14 {
    return "c" // closure (all closures share `$cloStruct`)
  }
  if k == 10 {
    return "I" // i64 (a scalar valtype — never a `>`-prefixed result token here)
  }
  if k == 13 {
    return "f" // f32 (a scalar valtype; the call site widens an i32/f32 argument to it)
  }
  if k == 4 {
    return "u" // union box (all unions share `$uBox`; tags are program-global)
  }
  if k == 1 {
    return "s" + i32ToStr(paramStructIdxOf(paramIx)) + ";" // struct
  }
  if k == 8 {
    return "V" + i32ToStr(paramStructIdxOf(paramIx)) + ";" // concrete variant (`uVarIdx + vi`)
  }
  if k == 5 {
    return "r" + i32ToStr(paramStructIdxOf(paramIx)) + ";" // ref list (T[])
  }
  // f32 / the nullable-ref kinds (9 struct|null, 15 i32[]|null, 16 string|null, 19
  // closure|null) still mis-lower as a closure-call param — left "" so the value's
  // signature stays un-interned and the soundness floor (`emitClosureValue`) rejects it
  // with a clear message rather than emitting invalid wasm.
  ""
}

// The interning KEY for lifted function `fe`'s env-leading `$fnsig`, or "" when the
// signature is not function-value-eligible (a void / closure-returning function, or a
// param/return kind outside the `cloParamTok` / value-result ABI). The key encodes the
// param kinds (`cloParamTok`) and the return kind, so two functions share one `$fnsig`
// exactly when their env-leading functypes are byte-identical. `fnSigKeyOf` is the
// value-eligible (i32/f64-result) variant; `cloSigKeyExt` extends the RESULT spine.
function fnSigKeyOf(fe: i32) {
  if fe < 0 || fe >= fnStmts.length { return "" }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    let key = ""
    const params = fn.fnParams
    let pi = 0
    while pi < params.length {
      const tok = cloParamTok(params[pi])
      if tok == "" { return "" }
      key = key + tok
      pi = pi + 1
    }
    let r = cloRetKindOf(fe)
    if r == 0 { return key + ">i" }
    if r == 11 { return key + ">d" }
    return ""
  }
  ""
}

// The VALUE-ABI return kind of lifted function `fe` for `$fnsig` purposes: `0`
// (i32/boolean), `11` (f64), or `-1` (void / closure-returning / any other kind).
// Annotated returns read the annotation; un-annotated ones ride the inferred fRet*
// tables, plus a registry-INDEPENDENT f64 tail check (`tailIsF64NoLocal` — the
// general `exprIsF64` consults the per-function locals registry, whose contents
// depend on WHICH function is currently being emitted, so the key must not use it).
function cloRetKindOf(fe: i32) {
  if fe < 0 || fe >= fnStmts.length { return -1 }
  if fe >= fRetVoid.length { return -1 }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    if fRetVoid[fe] == 1 { return -1 }
    if fnReturnsClosure(fe) { return -1 }
    if fn.fnRet >= 0 {
      let k = vtKindOfType(fn.fnRet)
      if k == 0 { return 0 }
      if k == 11 { return 11 }
      return -1
    }
    // Un-annotated: any inferred ref/i64/f32 kind is out of the value ABI; an f64
    // tail is kind 11; everything else (i32 / boolean) rides the i32 result.
    if fRetStr[fe] == 1 { return -1 }
    if fRetListKind[fe] != 0 { return -1 }
    if fRetUni[fe] == 1 { return -1 }
    if fRetRef[fe] == 1 { return -1 }
    if fRetNul[fe] == 1 { return -1 }
    if fRetMap[fe] == 1 { return -1 }
    if fRetI64[fe] == 1 { return -1 }
    if fRetF32[fe] == 1 { return -1 }
    if fRetF64[fe] == 1 { return 11 }
    if tailIsF64NoLocal(fnRetExprOf(fnStmts[fe]), fnStmts[fe]) { return 11 }
    return 0
  }
  -1
}

// Whether the lifted callback at `fe` returns a STRING — its annotation (`: string`) or the
// inferred `fRetStr`. `cloRetKindOf` folds string into -1 (it is outside the i32/f64 value
// ABI), so `.map`/`.filter` consult this separately to pick the string-list result kind.
function cloRetIsString(fe: i32) {
  if fe < 0 || fe >= fnStmts.length { return false }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    if fn.fnRet >= 0 { return nameIsString(tyNameOf(fn.fnRet)) }
    if fe < fRetStr.length { return fRetStr[fe] == 1 }
  }
  false
}

// Registry-independent f64-ness of a lifted callback's tail expression: float
// literals, f64 PARAMS, f64 arithmetic over those, and f64-returning named calls.
// Deliberately avoids `declaredF64`/`declaredSlotOf` (the locals registry belongs to
// whichever function is currently being emitted), so the answer is STABLE whether
// asked during sig collection or during section emission.
function tailIsF64NoLocal(ix: i32, fnArenaIx: i32) {
  if ix < 0 { return false }
  const e = P.nodes[ix]
  if e is NumLit { return numTextIsFloat(e.numText) }
  if e is Paren { return tailIsF64NoLocal(e.parInner, fnArenaIx) }
  if e is Ident { return paramIsF64(fnArenaIx, e.identName) }
  if e is BinExpr {
    const op = e.binOp
    if op == "+" || op == "-" || op == "*" || op == "/" {
      if tailIsF64NoLocal(e.binLeft, fnArenaIx) { return true }
      return tailIsF64NoLocal(e.binRight, fnArenaIx)
    }
    return false
  }
  if e is Unary {
    if e.unOp == "-" { return tailIsF64NoLocal(e.unArg, fnArenaIx) }
    return false
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const t = fnIndexOf(callee.identName)
      if t >= 0 {
        if t < fRetF64.length { return fRetF64[t] == 1 }
      }
    }
    return false
  }
  false
}

// Collect the distinct `$fnsig` env-leading functypes — one per distinct eligible
// signature KEY across all lifted functions (any could be used as a value), in
// `fnStmts` order. Runs AFTER `computeRetInference` (the key reads inferred return
// kinds) and after `collectMapFilterUse` (which may flip `fnValUsed` for a program
// whose only function value is a named `.map`/`.filter` callback). Empty (zero new
// types) unless `fnValUsed` — the byte-identical-golden invariant.
function collectCloSigs() {
  cloSigKeys = []
  cloSigRepFn = []
  if !fnValUsed { return 0 }
  let fe = 0
  while fe < fnStmts.length {
    let key = fnSigKeyOf(fe)
    // A VOID- (`>v`) or STRUCT-returning (`>sN;`) function used as a VALUE (bound,
    // passed, returned) needs its EXTENDED sig interned too — the value-eligible key
    // above excludes both. Mirrors the object-field-closure pass below, but for a
    // function reached through a binding / param rather than a struct field.
    // `cloSigKeyExt` yields "" for the kinds still outside the value ABI (string, i64),
    // so those stay unminted; usage-gated by `fnValUsed`, so a program without such a
    // function value emits byte-identical types.
    if key == "" { key = cloSigKeyExt(fe) }
    if key != "" {
      if cloSigPosOfKey(key) < 0 {
        cloSigKeys.push(key)
        cloSigRepFn.push(fe)
      }
    }
    fe = fe + 1
  }
  // EXTENDED field-closure signatures (index/operator-trap dispatch): a closure
  // that is an OBJECT-FIELD VALUE may be void (`"[]=": function(k,v) {…}`) or
  // struct-returning (`"[]": function(i) row(i)`, an operator field returning a
  // struct) — sigs the value ABI above excludes. Intern each such field
  // closure's extended key (`>v` / `>sN;` results) so the member-call site can
  // `ref.cast` to the callee's REAL functype. Usage-gated: only fires for a
  // field closure whose sig is NOT already value-eligible, so a program without
  // one emits byte-identical types.
  let ai = 0
  while ai < P.nodes.length {
    const an = P.nodes[ai]
    if an is ObjLit {
      const fs = an.objFields
      let fi = 0
      while fi < fs.length {
        const f = P.nodes[fs[fi]]
        if f is FieldInit {
          const ffe = fieldValueFeOf(f.fiValue)
          if ffe >= 0 {
            if fnSigKeyOf(ffe) == "" {
              const ek = cloSigKeyExt(ffe)
              if ek != "" {
                if cloSigPosOfKey(ek) < 0 {
                  cloSigKeys.push(ek)
                  cloSigRepFn.push(ffe)
                }
              }
            }
          }
        }
        fi = fi + 1
      }
    }
    ai = ai + 1
  }
  0
}

// The lifted-function position (`fnStmts` index) of an object-literal FIELD
// VALUE that is a function: an inline lambda (`FuncDecl` node — lifted in place,
// so its arena index appears in `fnStmts`) or a bare Ident naming a function.
// -1 for any other field value.
function fieldValueFeOf(valIx: i32) {
  if valIx < 0 { return -1 }
  let v = P.nodes[valIx]
  if v is FuncDecl { return fnStmtsPosOf(valIx) }
  if v is Ident { return fnIndexOf(v.identName) }
  -1
}

// The single mapping from an UN-ANNOTATED function's inferred `fRet*` tables to its RESULT
// valtype kind — the one place a new inferred-return kind is added. Shared by the named-function
// functype-result emission and `cloRetValKind` (the closure result), so the two can no longer
// drift (the f32/f64/i64 inferred-return holes were each one of these two sites missing a kind the
// other had). LAST-MATCH wins, preserving the original override chains EXACTLY — the flags are NOT
// all mutually exclusive (a struct-UNION return sets both `fRetUni` and `fRetRef`, and the later
// `fRetRef` must win → kind 1). 0 (i32) when nothing matched. The closure- and variant-collapse
// cases (kinds 14 / 8) and the `tailIsF64NoLocal` backup are layered by the callers — they are not
// driven by these flags.
function inferredRetKindCore(ti: i32) {
  let k = 0
  if fRetStr[ti] == 1 { k = 3 }
  if fRetListKind[ti] == 2 { k = 2 }
  if fRetUni[ti] == 1 { k = 4 }
  if fRetRef[ti] == 1 { k = 1 }
  if fRetNul[ti] == 1 { k = 9 }
  if fRetListKind[ti] == 5 { k = 5 }
  if fRetListKind[ti] == 7 { k = 7 }
  if fRetListKind[ti] == 12 { k = 12 }
  if fRetMap[ti] == 1 { k = 6 }
  if fRetNulStr[ti] == 1 { k = 16 }
  if fRetF64[ti] == 1 { k = 11 }
  if fRetI64[ti] == 1 { k = 10 }
  if fRetF32[ti] == 1 { k = 13 }
  k
}

// The RESULT valtype KIND of lifted function `fe`'s `$fnsig` functype — the same kind the
// function's OWN functype emits, read from an annotation (`vtKindOfType`) or the inferred
// `fRet*` tables, so the closure functype byte-matches the callee. -1 for void (0 results)
// and for the kinds still outside the value-call ABI (a ref-list / closure return — `5` /
// `14` are minted by their own paths, not here). The slot (struct index for kinds 1 / 9)
// comes from `cloRetValSlot`.
function cloRetValKind(fe: i32) {
  if fe < 0 || fe >= fnStmts.length { return -1 }
  if fe >= fRetVoid.length { return -1 }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    if fRetVoid[fe] == 1 { return -1 }
    if fn.fnRet >= 0 {
      if tyIsFuncType(fn.fnRet) { return 14 }
      return vtKindOfType(fn.fnRet)
    }
    if fnReturnsClosure(fe) { return 14 }
    // A callback that COLLAPSES to one concrete variant (`(a) => if a is Cat { a } else {
    // catShape }`) — the checker types it as that variant, so the `$fnsig` result is the
    // variant struct (kind 8), NOT the union box. Checked BEFORE `fRetUni`, which the
    // emitter's syntactic inference also sets for the narrowed receiver arm.
    if cbRetVariantIdx(fe) >= 0 { return 8 }
    // The shared inferred-return-kind mapping (the SAME one the named-function functype result
    // uses) — so a scalar/list/ref kind added there is reflected here too. The closure-specific
    // cases (closure / variant-collapse above; the `tailIsF64NoLocal` backup below) are layered
    // around it.
    const core = inferredRetKindCore(fe)
    if core != 0 { return core }
    // An f64 tail with no intervening local (a `.map`/`.filter` callback `n => n * 2.0`)
    // — its f64-ness is detected structurally, not via `fRetF64` (mirrors the old
    // `cloRetKindOf`; without this the callback's functype declared i32 over an f64 body).
    if tailIsF64NoLocal(fnRetExprOf(fnStmts[fe]), fnStmts[fe]) { return 11 }
    return 0
  }
  -1
}

// The struct-table slot for `fe`'s result valtype — a real index only for a struct (kind
// 1) or nullable-struct (kind 9) return, `-1` otherwise.
function cloRetValSlot(fe: i32) {
  if fe < 0 || fe >= fnStmts.length { return -1 }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    if fn.fnRet >= 0 {
      const k = vtKindOfType(fn.fnRet)
      if k == 1 || k == 9 { return retStructIndex(fn.fnRet) }
      // A `: Cat` annotated variant result (kind 8) — the slot is the VARIANT index.
      if k == 8 { return variantIndexOf(tyNameOf(fn.fnRet)) }
      // A `: S[]` / `: ((i32) => i32)[]` annotated REF-LIST result (kind 5) — the slot is the
      // ref-list slot (`rlWrapIdx`-bearing), the dual of a `cloParamTok` kind-5 param's slot.
      if k == 5 { return tyAnnRefListSlot(fn.fnRet) }
      return -1
    }
    // A collapsed-to-one-variant inferred result (kind 8) — the variant index.
    const cvi = cbRetVariantIdx(fe)
    if cvi >= 0 { return cvi }
    if fRetRef[fe] == 1 { return fRetStructIdx[fe] }
    if fRetNul[fe] == 1 { return fRetStructIdx[fe] }
    // An inferred ref-list return (`() => [{…}]` / `() => [(x) => …]`, kind 5) — its element
    // NAME (`fRetRArrElem`, set by the return-classify scan) resolves the ref-list slot.
    if fRetListKind[fe] == 5 { return rlSlotByName(fRetRArrElem[fe]) }
  }
  -1
}

// The `>X` RESULT suffix of `fe`'s extended `$fnsig` key — one token per distinct result
// functype shape, so two functions share a sig iff their params AND result byte-match.
// Mirrors `cloRetValKind`: `>i`/`>d`/`>I` scalars, `>S` string, `>a`/`>A`/`>D` the i32/
// string/f64 lists, `>u` a union box, `>N` `string | null`, `>sN;`/`>nN;` a struct /
// nullable-struct. "" for the kinds not yet value-callable (a `>v` void is handled by the
// caller; ref-list `5` and closure `14` returns are a later slice).
function cloRetKeySuffix(fe: i32) {
  const k = cloRetValKind(fe)
  if k == 0 { return ">i" }
  if k == 11 { return ">d" }
  if k == 10 { return ">I" }
  if k == 13 {
    return ">f" // f32 scalar result (matches `annRetKind`)
  }
  if k == 3 { return ">S" }
  if k == 4 { return ">u" }
  if k == 16 { return ">N" }
  if k == 1 { return ">s" + i32ToStr(cloRetValSlot(fe)) + ";" }
  if k == 9 { return ">n" + i32ToStr(cloRetValSlot(fe)) + ";" }
  // A concrete-VARIANT result (kind 8) — the `(ref $(uVarIdx + vi))` struct, keyed by the
  // variant index so two callbacks share a sig iff they return the SAME variant.
  if k == 8 { return ">V" + i32ToStr(cloRetValSlot(fe)) + ";" }
  // List returns: `i32[]` (2) → `>a`, `string[]` (7) → `>A`, `f64[]` (12) → `>D`. The
  // closure `$fnsig` result is the list WRAPPER ref (`fbValtype` kinds 2/7/12), recovered
  // non-null at the value-call site like every other non-null closure result.
  if k == 2 { return ">a" }
  if k == 7 { return ">A" }
  if k == 12 { return ">D" }
  // A CLOSURE result (kind 14 — a function returning a function, `(i32) => ((i32) => i32)`):
  // the `$fnsig` result is the shared closure fat-pointer `(ref $cloStructIdx)` (`fbValtype`
  // kind 14), recovered non-null at the value-call site like any other ref result. Lets a
  // curried lambda (`(a) => (b) => …`) lower as a callable closure VALUE.
  if k == 14 { return ">c" }
  // A REF-LIST result (kind 5 — `S[]` / `((i32) => i32)[]` / a union list): the `$fnsig` result
  // is the ref-list WRAPPER ref (`fbValtype` kind 5, slot = `cloRetValSlot`), recovered non-null
  // at the value-call site like every other ref result. Keyed by the slot so two closures share a
  // sig iff they return the SAME ref-list shape — the result dual of the `r<idx>;` PARAM token.
  if k == 5 {
    const rs = cloRetValSlot(fe)
    if rs >= 0 { return ">r" + i32ToStr(rs) + ";" }
  }
  ""
}

// The EXTENDED `$fnsig` key of lifted function `fe`: `fnSigKeyOf`'s key when the sig is
// value-eligible, else the same param spine with the extended RESULT suffix
// (`cloRetKeySuffix`) — void, the i32/string/f64 lists, a union box, a nullable scalar/
// struct, a struct ref. "" when any param OR the result kind is still outside the ABI.
function cloSigKeyExt(fe: i32) {
  let base = fnSigKeyOf(fe)
  if base != "" { return base }
  if fe < 0 || fe >= fnStmts.length { return "" }
  if fe >= fRetVoid.length { return "" }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    const params = fn.fnParams
    let key = ""
    let pi = 0
    while pi < params.length {
      const tok = cloParamTok(params[pi])
      if tok == "" { return "" }
      key = key + tok
      pi = pi + 1
    }
    if fRetVoid[fe] == 1 { return key + ">v" }
    const suf = cloRetKeySuffix(fe)
    if suf == "" { return "" }
    return key + suf
  }
  ""
}

// The lifted-function position of the closure held by FIELD `prop` of struct
// `si`, resolved through the object LITERAL(s) that intern shape `si` — every
// literal of one shape carries sig-identical closures (monomorphized instances
// included), so the first match types the call. -1 when no literal of shape
// `si` sets a function-valued `prop`.
function fieldClosureFeOf(si: i32, prop: string) {
  if si < 0 { return -1 }
  let ai = 0
  while ai < P.nodes.length {
    const an = P.nodes[ai]
    if an is ObjLit {
      if structIndexOfObj(ai) == si {
        const ffe = fieldValueFeOf(objFieldVal(ai, prop))
        if ffe >= 0 { return ffe }
      }
    }
    ai = ai + 1
  }
  -1
}

// The lifted-function position of the closure a member call `recv.prop(...)`
// dispatches to, resolved as precisely as possible: first by following the
// RECEIVER to the literal that built it (a `const o = make(...)` whose maker
// returns an object literal — so two same-shaped receivers from different
// monomorphized makers each resolve their OWN closure), else by the receiver's
// struct SHAPE (`fieldClosureFeOf`). -1 when neither resolves.
function fieldClosureFeOfRecv(recvIx: i32, prop: string, fnIx: i32) {
  const e = P.nodes[unwrapParen(recvIx)]
  if e is Ident {
    let li = -1
    if fnIx >= 0 {
      const fn = P.nodes[fnIx]
      if fn is FuncDecl { li = parentLetOf(fn.fnBody, e.identName) }
    }
    if li < 0 { li = globalLetOf(e.identName) }
    if li >= 0 {
      let d = P.nodes[li]
      if d is LetDecl {
        const ffe = fieldClosureFeOfInit(d.letInit, prop)
        if ffe >= 0 { return ffe }
      }
    }
  }
  if e is Call {
    const ffe2 = fieldClosureFeOfInit(unwrapParen(recvIx), prop)
    if ffe2 >= 0 { return ffe2 }
  }
  fieldClosureFeOf(structIndexOfExpr(recvIx, fnIx), prop)
}

// The MAKER function (`fnStmts` position) whose tail object literal built the
// receiver expression at `recvIx`: a direct `make(...)` call, or an ident bound
// (let/global) to one. -1 when the receiver's origin is not a maker call.
function recvMakerFnOf(recvIx: i32, fnIx: i32) {
  const e = P.nodes[unwrapParen(recvIx)]
  let initIx = unwrapParen(recvIx)
  if e is Ident {
    let li = -1
    if fnIx >= 0 {
      const fn = P.nodes[fnIx]
      if fn is FuncDecl { li = parentLetOf(fn.fnBody, e.identName) }
    }
    if li < 0 { li = globalLetOf(e.identName) }
    if li < 0 { return -1 }
    let d = P.nodes[li]
    if d is LetDecl { initIx = unwrapParen(d.letInit) } else { return -1 }
  }
  const ie = P.nodes[initIx]
  if ie is Call {
    const callee = P.nodes[ie.callFn]
    if callee is Ident { return fnIndexOf(callee.identName) }
  }
  -1
}

// The annotation NAME of parameter `name` of the lifted function at `fe` ("" if
// not a param / un-annotated).
function feParamTyName(fe: i32, name: string) {
  if fe < 0 || fe >= fnStmts.length { return "" }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    const params = fn.fnParams
    let i = 0
    while i < params.length {
      const p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name { return tyNameOf(p.parType) }
      }
      i = i + 1
    }
  }
  ""
}

// BOOLEAN-ness of a field-closure trap call `recv.prop(...)`. Monomorphized
// maker instances SHARE the closure body, so the closure's own inferred return
// kind cannot distinguish `wrap(true)` from `wrap(99)` — instead, follow the
// receiver to ITS maker instance and read the closure's tail through the
// instance's pinned param annotations (`function(_k) x` with the instance's
// `x: boolean` → true). Falls back to the shared closure's `fRetBool`.
function fieldCloCallIsBool(recvIx: i32, prop: string, fnIx: i32) {
  const mk = recvMakerFnOf(recvIx, fnIx)
  if mk >= 0 {
    let rx = fnRetExprOf(fnStmts[mk])
    if rx >= 0 {
      const re = P.nodes[unwrapParen(rx)]
      if re is ObjLit {
        let v = objFieldVal(unwrapParen(rx), prop)
        if v >= 0 {
          const vf = P.nodes[v]
          if vf is FuncDecl {
            const vRet = vf.fnRet
            if vRet >= 0 { return tyNameOf(vRet) == "boolean" }
            const tx = fnRetExprOf(v)
            if tx >= 0 {
              const te = P.nodes[unwrapParen(tx)]
              if te is Ident {
                const ptn = feParamTyName(mk, te.identName)
                if ptn != "" { return ptn == "boolean" }
              }
              return exprIsBool(tx, v)
            }
          }
        }
      }
    }
  }
  const bfe = fieldClosureFeOfRecv(recvIx, prop, fnIx)
  if bfe >= 0 {
    const bfn = P.nodes[fnStmts[bfe]]
    if bfn is FuncDecl {
      if bfn.fnRet >= 0 { return tyNameOf(bfn.fnRet) == "boolean" }
    }
    if bfe < fRetBool.length { return fRetBool[bfe] == 1 }
  }
  false
}

// Resolve `prop`'s closure through an INITIALIZER expression: an object literal
// reads its own field; a call to a maker follows the maker's return expression
// (its tail object literal). -1 otherwise.
function fieldClosureFeOfInit(initIx: i32, prop: string) {
  if initIx < 0 { return -1 }
  const e = P.nodes[unwrapParen(initIx)]
  if e is ObjLit {
    return fieldValueFeOf(objFieldVal(unwrapParen(initIx), prop))
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const t = fnIndexOf(callee.identName)
      if t >= 0 {
        let rx = fnRetExprOf(fnStmts[t])
        if rx >= 0 {
          const re = P.nodes[unwrapParen(rx)]
          if re is ObjLit {
            return fieldValueFeOf(objFieldVal(unwrapParen(rx), prop))
          }
        }
      }
    }
  }
  -1
}

// The position of `key` in `cloSigKeys`, or -1.
function cloSigPosOfKey(key: string) {
  let i = 0
  while i < cloSigKeys.length {
    if cloSigKeys[i] == key { return i }
    i = i + 1
  }
  -1
}

// The `$fnsig` type index for lifted function `fe`'s own signature, or -1 when its
// signature is not value-eligible / not interned. The EXTENDED key (`cloSigKeyExt`)
// equals the value-ABI key for an eligible sig; a void / struct-returning FIELD
// closure resolves its interned `>v`/`>sN;` sig (so its function-section type IS
// that `$fnsig` and the trap call site's `ref.cast` accepts it); any other
// non-eligible sig stays -1 (its ext key is never interned).
function fnSigIdxOfFn(fe: i32) {
  let key = cloSigKeyExt(fe)
  if key == "" { return -1 }
  const p = cloSigPosOfKey(key)
  if p < 0 { return -1 }
  cloSigBase + p
}

// The type index of the all-i32 `$fnsig` functype for value-call arity `ar`
// (`(structref, i32 * ar) -> i32`) — the signature every GENERIC value call (a
// let-bound / param / field closure `f(args)`) dispatches through. -1 if not interned.
function fnSigIdxForArity(ar: i32) {
  let key = ""
  let i = 0
  while i < ar {
    key = key + "i"
    i = i + 1
  }
  const p = cloSigPosOfKey(key + ">i")
  if p < 0 { return -1 }
  cloSigBase + p
}

// Recursively walk the node at `ix` (a statement or expression subtree) and append
// every nested `FuncDecl` — whether a nested declaration statement or an arrow
// lambda in expression position — to `fnStmts` (lambda lifting). An anonymous
// lambda (`fnName == ""`) is given a synthesized unique name first, so it resolves
// like a named function. The function's OWN body is NOT descended here (the outer
// worklist loop in `collectFns` descends each lifted function once it is in
// `fnStmts`), preventing double-collection. Any function value's existence flips the
// module-wide `fnValUsed` flag.
//
// Record a directly-bound lambda's DEBUG display name (the `let`/`const` it is
// assigned to) for the name section. `initIx` is the initializer node and `slot` is
// the `fnStmts` index it lifted to (`fnStmts.length` captured BEFORE the lift call —
// a directly-bound lambda is the first and only push of that call). `fnName` is left
// as the synthesized `__lambda_N` so call resolution and `fnNameMap` are untouched —
// only a trap backtrace reads the friendlier name.
function recordLambdaDispName(slot: i32, initIx: i32, name: string) {
  if initIx < 0 || name.length == 0 || slot >= fnDispNames.length { return 0 }
  const iv = P.nodes[initIx]
  if iv is FuncDecl { fnDispNames[slot] = name }
  0
}

function liftFnsInExpr(ix: i32, parent: i32) {
  if ix < 0 { return 0 }
  let n = P.nodes[ix]
  if n is FuncDecl {
    if n.fnName == "" {
      n.fnName = "__lambda_" + i32ToStr(lambdaCtr)
      lambdaCtr = lambdaCtr + 1
    }
    fnStmts.push(ix)
    fnParent.push(parent)
    fnDispNames.push("")
    fnValUsed = true
    return 0
  }
  if n is Block {
    const stmts = n.blkStmts
    let i = 0
    while i < stmts.length {
      liftFnsInExpr(stmts[i], parent)
      i = i + 1
    }
    return 0
  }
  if n is LetDecl {
    if n.letInit >= 0 {
      const before = fnStmts.length
      liftFnsInExpr(n.letInit, parent)
      recordLambdaDispName(before, n.letInit, n.letName)
    }
    return 0
  }
  if n is RetStmt {
    if n.retArg >= 0 { liftFnsInExpr(n.retArg, parent) }
    return 0
  }
  if n is IfStmt {
    liftFnsInExpr(n.ifCond, parent)
    liftFnsInExpr(n.ifThen, parent)
    if n.ifElse >= 0 { liftFnsInExpr(n.ifElse, parent) }
    return 0
  }
  if n is WhileStmt {
    liftFnsInExpr(n.whileCond, parent)
    liftFnsInExpr(n.whileBody, parent)
    return 0
  }
  if n is ForRange {
    liftFnsInExpr(n.frFrom, parent)
    liftFnsInExpr(n.frTo, parent)
    if n.frStep >= 0 { liftFnsInExpr(n.frStep, parent) }
    liftFnsInExpr(n.frBody, parent)
    return 0
  }
  if n is ForIn {
    liftFnsInExpr(n.fiIter, parent)
    liftFnsInExpr(n.fiBody, parent)
    return 0
  }
  if n is Call {
    liftFnsInExpr(n.callFn, parent)
    const args = n.callArgs
    let i = 0
    while i < args.length {
      liftFnsInExpr(args[i], parent)
      i = i + 1
    }
    return 0
  }
  if n is BinExpr {
    liftFnsInExpr(n.binLeft, parent)
    liftFnsInExpr(n.binRight, parent)
    return 0
  }
  if n is Unary {
    liftFnsInExpr(n.unArg, parent)
    return 0
  }
  if n is Paren {
    liftFnsInExpr(n.parInner, parent)
    return 0
  }
  if n is Member {
    liftFnsInExpr(n.memObj, parent)
    return 0
  }
  if n is Index {
    liftFnsInExpr(n.idxArr, parent)
    liftFnsInExpr(n.idxIndex, parent)
    return 0
  }
  if n is ObjLit {
    const fields = n.objFields
    let i = 0
    while i < fields.length {
      const f = P.nodes[fields[i]]
      if f is FieldInit { liftFnsInExpr(f.fiValue, parent) }
      i = i + 1
    }
    return 0
  }
  if n is ArrayLit {
    const elems = n.arrElems
    let i = 0
    while i < elems.length {
      liftFnsInExpr(elems[i], parent)
      i = i + 1
    }
    return 0
  }
  0
}

// The wasm global index for `name`, or -1 if no top-level global has that name.
function globalIndexOf(name: string) { globalNameMap[name] ?? -1 }

// The arena index of the `LetDecl` for the global `name`, or -1 if not a global.
function globalLetOf(name: string) {
  let gi = globalIndexOf(name)
  if gi < 0 { return -1 }
  globalStmts[gi]
}

// Whether the global `name` is a struct/array/string ref (so a bare reference to it in
// an `exprStruct`/`exprArray`/`exprString` check is recognized as that ref type). The
// global's valtype follows its `LetDecl` annotation or literal initializer, evaluated as
// a top-level constexpr (`fnIx = -1`), mirroring the local `letIsX` predicates.
function globalIsStruct(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsStruct(li, -1)
}
function globalIsArray(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsArray(li, -1)
}
function globalIsString(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return false }
  // A `string | null` (kind 16) global reads AS a string under narrowing — the global
  // read recovers non-null (`ref.as_non_null`), and the `!= null` check reads it raw.
  letIsString(li, -1) || letIsNulString(li, -1)
}
function globalIsRefArray(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsRefArray(li, -1)
}
function globalIsStringArray(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsStringArray(li, -1)
}
function globalIsMap(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsMap(li, -1)
}
function globalIsF64Array(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsF64Array(li, -1)
}
function globalIsNulRef(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsNulRef(li, -1)
}
function globalIsNulList(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsNulList(li, -1)
}

// True if the parameter `name` of function `fnIx` is a nullable struct (`S | null`).
function paramNulRef(fnIx: i32, name: string) {
  retNulRefFlag(paramTypeNode(fnIx, name)) == 1
}

// True if the function `name` returns a nullable struct (`fRetNul`).
function fnRetNulRef(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetNul[i] == 1
}

// True if the `LetDecl` at `letIx` declares a nullable-struct local: its annotation
// is `S | null`, OR its initializer produces one (a nullable-returning call).
function letIsNulRef(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      if retNulRefFlag(d.letType) == 1 { return true }
    }
    return exprNullableStruct(d.letInit, fnIx)
  }
  false
}

// A bare `m[k]` map read is `V | null`. A struct (kind 9), string (16), or closure (19) value
// binds a supported nullable local — but a UNION (mv kind 2) or ref-LIST (mv kind 6) value has no
// nullable local rep, so the bare read would lower to a non-null local while `emitMapGet` yields a
// `(ref null …)`: invalid wasm. Detect that shape so the binding is a CLEAN reject (use `m[k] ??
// <default>`, which loads the non-null value) instead. Gated to un-annotated bindings — an
// annotation drives the kind explicitly and is classified before this.
function letBareUnwiredNulMapRead(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 { return false }
    const mrs = mapReadMvSlot(d.letInit, fnIx)
    if mrs >= 0 {
      const k = mvValKind[mrs]
      return k == 2 || k == 6
    }
  }
  false
}

// True if evaluating the expression at `exprIx` yields a NULLABLE i32-list ref —
// a nullable-list-annotated param/local/global reference or a `rest: i32[]|null`
// FIELD read (code 18). The nullable-LIST dual of `exprNullableStruct`: list-op
// read sites consult it to insert the `ref.as_non_null` recover (the checker
// proved every such read guarded, so the cast can never trap).
function exprNullableList(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Paren { return exprNullableList(e.parInner, fnIx) }
  if e is Ident {
    if paramNulList(fnIx, e.identName) { return true }
    if declaredNulList(e.identName) { return true }
    return globalIsNulList(e.identName)
  }
  if e is Member { return memberFieldCode(exprIx, fnIx) == 18 }
  // Indexing a `(i32[] | null)[]` (a kind-4 ref list whose element slot keeps the `| null`) yields a
  // NULLABLE i32 list — the read left it `(ref null $lTypeIdx)`, so `const t = xs[i]; if t != null` narrows.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemNullable.length {
        if rlElemKindTbl[slot] == 4 && rlElemNullable[slot] == 1 { return true }
      }
    }
  }
  // A call to a function whose ANNOTATED return is `i32[] | null` yields a nullable list, so an
  // un-annotated `const r = f(…)` infers kind 15 (and narrows with `if r != null`). Mirrors the
  // niche-nullable call inference for bool/string returns.
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const target = fnIndexOf(callee.identName)
      if target >= 0 {
        const fn = P.nodes[fnStmts[target]]
        if fn is FuncDecl {
          if fn.fnRet >= 0 { return retNulListFlag(fn.fnRet) == 1 }
        }
      }
    }
  }
  false
}

// True if `exprIx` yields a NULLABLE REF-ARRAY (`i32[][] | null` etc., LOCAL kind 18) — the ref-array
// analogue of `exprNullableList`. An `Index` over a `(<ref-array> | null)[]` (a kind-9 ref list whose
// element slot keeps the `| null`) reads `(ref null $innerWrapper)`, so `const t = xs[i]; if t != null`.
function exprNullableRefArray(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Paren { return exprNullableRefArray(e.parInner, fnIx) }
  if e is Ident { return declaredKind(e.identName) == 18 }
  // A `recv.f` read of a NULLABLE ref-list FIELD (`f: S[] | null`, code 28) yields a nullable ref array.
  if e is Member { return memberFieldCode(exprIx, fnIx) == 28 }
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemNullable.length {
        if rlElemKindTbl[slot] == 9 && rlElemNullable[slot] == 1 { return true }
      }
    }
  }
  false
}

// The INNER ref-list slot of a nullable ref-array expression — a kind-18 LOCAL stores it in
// `localStructIdx`; an `Index` `v[i]` over a `(<ref-array> | null)[]` resolves it from the kind-9 element
// (its inner = `refArrElemName` of the element name, which recurses through the `| null`).
function nulRefArrayInnerSlot(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return -1 }
  const e = P.nodes[exprIx]
  if e is Paren { return nulRefArrayInnerSlot(e.parInner, fnIx) }
  if e is Ident {
    const sl = declaredSlotOf(e.identName)
    if sl >= 0 { return localStructIdx[sl] }
    return -1
  }
  // A code-28 nullable ref-list field member: its element ref-list slot (the field's element name).
  if e is Member {
    if memberFieldCode(exprIx, fnIx) == 28 {
      return refListSlotOfExpr(exprIx, fnIx)
    }
    return -1
  }
  if e is Index {
    const slot = refListSlotOfExpr(e.idxArr, fnIx)
    if slot >= 0 && slot < rlElemName.length {
      return rlSlotByName(refArrElemName(rlElemName[slot]))
    }
  }
  -1
}

// Binding test for a kind-18 nullable ref-array local: annotation `<ref-array> | null`, else an
// un-annotated init that yields a nullable ref array.
function letIsNulRefArray(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        const np = nullablePartOf(lt.tyName)
        // A value-union-element inner (`(i32|null)[] | null`) is excluded — its annotated-local value
        // build is not yet supported, so it falls through to a clean reject rather than the kind-18 path
        // (which traps). A struct / nested-array inner is fine. The INFERRED path below is unaffected.
        if np != "" && nameIsRefArray(np) { return true }
      }
      return false
    }
    return exprNullableRefArray(d.letInit, fnIx)
  }
  false
}

// The inner ref-list slot to store for a kind-18 binding — from its annotation (`<ref-array> | null` →
// the ref-array's element slot) or its initializer.
function nulRefArrayInnerSlotOfLet(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        const np = nullablePartOf(lt.tyName)
        if np != "" { return rlSlotByName(refArrElemName(np)) }
      }
      return -1
    }
    return nulRefArrayInnerSlot(d.letInit, fnIx)
  }
  -1
}

// Annotation-OR-init nullable-i32-list test for a BINDING: the annotation (`letIsNulList`), else an
// UN-ANNOTATED `const t = <nullable-i32-list expr>` — e.g. a code-18 field read `const t = v.f` where
// `v.f: i32[] | null`. Without the init inference such a binding took a non-null list kind, so `t != null`
// emitted a bare `null` with no list context. Mirrors `letIsNulString`'s init fallback for nullable strings.
function letIsNulListInfer(letIx: i32, fnIx: i32) {
  if letIsNulList(letIx, fnIx) { return true }
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType < 0 { return exprNullableList(d.letInit, fnIx) }
  }
  false
}

// ── nullable-string (`string | null`, kind 16) predicates — the ref-rep analog of
// the nullable-list family above; `null` is `ref.null $aTypeIdx`, `!= null` is
// `ref.is_null`. Unlike a nullable list, an INITIALIZER can produce one (a string
// literal, or a `string | null`-returning call), so `letIsNulString` consults the init.
function declaredNulString(name: string) { declaredKind(name) == 16 }

function globalIsNulString(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsNulString(li, -1)
}

function fnRetNulString(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetNulStr[i] == 1
}

function letIsNulString(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      if retNulStringFlag(d.letType) == 1 { return true }
    }
    if d.letType < 0 {
      // An un-annotated `const x = if c then "hi" else null` infers `string | null`
      // (a niche the emitter can't statically derive from the if-expr arms). The
      // CHECKER typed it and exported the binding by node index; consult that first,
      // then fall back to the init-shape probe (a nullable-string param/local/call).
      if isInferLetNulStr(letIx) { return true }
      return exprNullableString(d.letInit, fnIx)
    }
  }
  false
}

// True if evaluating the expression at `exprIx` yields a `string | null` ref — a
// nullable-string param/local/global, or a `: string | null`-returning call. Consulted
// by the `!= null` `ref.is_null` path and the assignment/return/arg null-seeding.
function exprNullableString(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetNulString(callee.identName) { return true }
      // A `string | null`-returning function VALUE (a binding / `(…) => string | null`
      // param callee) — its result is the nullable raw array, `>N`.
      return calleeRetKind(callee.identName, fnIx) == 16
    }
    // A `string | null`-returning FIELD-closure call.
    if callee is Member {
      const ffe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
      if ffe >= 0 { return fRetNulStr[ffe] == 1 }
    }
    // FALLBACK (scoped to a CALL): a `string | null`-returning closure value call whose callee the
    // cases above miss — an INDEXED closure-array element (`arr[i](x)`). The cheap NO-RENDER
    // `nodeTyIsNullableString` reads the checker's per-node type (the niche-string dual of
    // `exprNullableStruct`'s `nodeTyIsNullableStruct` fallback).
    return nodeTyIsNullableString(exprIx)
  }
  if e is Ident {
    if paramNulString(fnIx, e.identName) { return true }
    if declaredNulString(e.identName) { return true }
    return globalIsNulString(e.identName)
  }
  // A `string | null` struct FIELD read (`a.v`, code 20) yields a nullable string ref.
  if e is Member { return memberFieldCode(exprIx, fnIx) == 20 }
  // A BARE `m[k]` over a STRING-valued map is `string | null` (kind 16) — `emitMapGet` yields the
  // `(ref null)` value unrecovered, the string dual of the bare struct-map read.
  if e is Index {
    const mrs = mapReadMvSlot(exprIx, fnIx)
    if mrs >= 0 { return mvValKind[mrs] == 3 }
  }
  // A chained `a ?? b` over nullable strings is ITSELF nullable-string when the default
  // `b` is also nullable (the result can still be null) — the left-associative
  // `(f() ?? g()) ?? d` shape, where the classifier sees this nested `??` as `binLeft`
  // before `emitExpr` re-associates it. Keeps print-routing / `exprString` consistent
  // with the emitted rep.
  if e is BinExpr {
    if e.binOp == "??" {
      if exprNullableString(e.binLeft, fnIx) {
        return exprNullableString(e.binRight, fnIx)
      }
    }
  }
  false
}

// The base struct index of a nullable-struct `LetDecl`: the annotation's base, or
// the initializer's resolved struct (a nullable-returning call's `fRetStructIdx`).
function nulRefStructIdxOfLet(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const ri = retNulRefIndex(d.letType)
      if ri >= 0 { return ri }
    }
    return structIndexOfExpr(d.letInit, fnIx)
  }
  -1
}

// True if evaluating the expression at `exprIx` yields a NULLABLE struct ref —
// a nullable-annotated param/local/global reference or a `S | null`-returning call.
function exprNullableStruct(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Paren { return exprNullableStruct(e.parInner, fnIx) }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetNulRef(callee.identName) { return true }
      // An `S | null`-returning function VALUE (a binding / `(…) => S | null` param
      // callee) — its result is the nullable struct ref, `>nN;`.
      if calleeRetKind(callee.identName, fnIx) == 9 { return true }
    }
    // An `S | null`-returning FIELD-closure call.
    if callee is Member {
      const ffe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
      if ffe >= 0 && fRetNul[ffe] == 1 { return true }
    }
    // `xs.pop()` / `xs.get(i)` over a STRUCT-element ref list yield `S | null` (the
    // host's nullable list reads — `pop` of an empty list / OOB `get` is null).
    if structListPopGetElem(exprIx, fnIx) >= 0 { return true }
    // FALLBACK (scoped to a CALL): a nullable-struct-returning closure value call whose callee the
    // cases above miss — an INDEXED closure-array element (`arr[i](x)`). The cheap NO-RENDER
    // `nodeTyIsNullableStruct` reads the checker's per-node type. The nullable dual of `exprStruct`'s
    // `nodeTyIsObj` fallback (#654), so `letIsNulRef` classifies such a binding kind-9 and its
    // `!= null` narrow gets the struct context.
    return nodeTyIsNullableStruct(exprIx)
  }
  if e is Ident {
    if paramNulRef(fnIx, e.identName) { return true }
    if declaredNulRef(e.identName) { return true }
    // A CAPTURED nullable struct (`const p: P | null = …; () => if p != null { p.x }`): the env
    // field is `(ref null $S)` (kind 9), so classify it nullable — else `p != null` reads as
    // struct equality. The struct index resolves via `capturedStructIndex`.
    if capturedKindOf(fnIx, e.identName) == 9 { return true }
    return globalIsNulRef(e.identName)
  }
  // A NESTED-STRUCT field read (code 15) is stored `(ref null $S)` — a `S|null`
  // field genuinely carries null; a plain `inner: S` field is always written
  // non-null but shares the nullable storage, so the read is nullable-classified
  // (the consumer inserts `ref.as_non_null` before a chained field access).
  if e is Member { return memberFieldCode(exprIx, fnIx) == 15 }
  // An INDEX into a NULLABLE-struct array (`(P | null)[]`, ref-list slot key "P | null")
  // yields `P | null` — the element legitimately holds null, so the read is NOT recovered
  // to non-null (unlike a `P[]` element). `const e = xs[i]` binds the kind-9 niche.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      let slot = refListSlotOfExpr(e.idxArr, fnIx)
      if rlElemKindTbl[slot] == 1 {
        if nullablePartOf(rlElemName[slot]) != "" { return true }
      }
    }
    // A BARE map get `m[k]` over a STRUCT-valued map (`{[string]: S}`) is `S | null` — the
    // `vals` slot is `(ref null $S)` and `emitMapGet` yields it unrecovered (a miss is
    // `ref.null`). So `const v = m[k]` binds the kind-9 niche and narrows with `if v != null`,
    // the map-read dual of the nullable-struct ARRAY element above. (A `?? d` read is a BinExpr,
    // not this Index, and stays the non-null value.)
    const mrs = mapReadMvSlot(exprIx, fnIx)
    if mrs >= 0 { return mvValKind[mrs] == 1 }
  }
  false
}

// Map each function NAME to its wasm function index (its position in `fnStmts`), and
// record whether it returns the struct. Returns the function count.
function buildFnMap(stmts: i32[]) {
  fnNames = []
  fnNameMap = Map()
  nestedNameSet = Map()
  fnIndices = []
  fRetVoid = []
  fRetRef = []
  fRetStructIdx = []
  fRetListKind = []
  fRetStr = []
  fRetUni = []
  fRetRArrElem = []
  fRetMap = []
  fRetBool = []
  fRetNul = []
  fRetNulStr = []
  fRetI64 = []
  fRetF64 = []
  fRetF32 = []
  let i = 0
  while i < fnStmts.length {
    let s = P.nodes[fnStmts[i]]
    if s is FuncDecl {
      fnNames.push(s.fnName)
      // FIRST occurrence wins (mirrors the old linear `fnIndexOf`): a later lifted
      // function sharing a name does not overwrite the earlier slot.
      if !fnNameMap.has(s.fnName) { fnNameMap[s.fnName] = i }
      // A nested (lifted) function's name — drives `fnIndexOfInScope`'s scan gate.
      if i < fnParent.length && fnParent[i] >= 0 {
        nestedNameSet[s.fnName] = true
      }
      fnIndices.push(i)
      fRetVoid.push(0)
      fRetRef.push(retTRFlag(s.fnRet))
      fRetStructIdx.push(retStructIndex(s.fnRet))
      // The folded list-return code (mutually-exclusive flags → one rep code, in priority
      // order; `0` when the return is not a list).
      fRetListKind.push(retListKindFlag(s.fnRet))
      fRetStr.push(retStrFlag(s.fnRet))
      fRetUni.push(retUnionFlag(s.fnRet))
      fRetRArrElem.push(retRefArrElemName(s.fnRet))
      fRetMap.push(retMapFlag(s.fnRet))
      fRetBool.push(retBoolFlag(s.fnRet))
      fRetNul.push(retNulRefFlag(s.fnRet))
      fRetNulStr.push(retNulStringFlag(s.fnRet))
      fRetI64.push(retI64Flag(s.fnRet))
      fRetF64.push(retF64Flag(s.fnRet))
      fRetF32.push(retF32Flag(s.fnRet))
      // A20: an un-annotated SCALAR/STRING/array function's return is set DIRECTLY from
      // the checker's inferred return name — the emitter's expression-based fallback
      // below misses a return that is a plain variable (a `let`-bound string or list),
      // which then mis-classifies and fails codegen. Set the one classifying flag from
      // the name; no AST node is synthesized (so `fmt` is untouched and the node arena
      // isn't grown mid-pass) and `i32` needs nothing (it is the default). `string[]`
      // rides `fRetListKind` (kind 7, the module-global string-list wrapper) — the
      // signature-emission path maps that flag to the right result valtype, where a bare
      // un-annotated return would otherwise fall back to i32.
      if s.fnRet < 0 {
        // An anonymous lambda's inferred return is keyed by NODE INDEX (the checker
        // recorded `#<nodeIx>`, since the lambda has no name the checker saw); fall back
        // to that when the name-keyed lookup misses (`__lambda_N` is unknown to the checker).
        let inm = inferRetNameOf(s.fnName)
        if inm == "" { inm = inferRetNameByNode(fnStmts[i]) }
        const li = fRetStr.length - 1
        if inm == "string" {
          fRetStr[li] = 1
        } else if inm == "i64" {
          fRetI64[li] = 1
        } else if inm == "f64" {
          fRetF64[li] = 1
        } else if inm == "f32" {
          fRetF32[li] = 1
        } else if inm == "boolean" {
          fRetBool[li] = 1
        } else if inm == "i32[]" {
          fRetListKind[li] = 2
        } else if inm == "string[]" {
          fRetListKind[li] = 7
        } else if inm == "f64[]" {
          fRetListKind[li] = 12
        } else if nameIsMap(inm) && mapValNameOf(inm) == "i32" {
          // A mono `{[string]: i32}` map inferred return (a returned map local). `criClassify`'s
          // `exprMap` can miss it (a returned LOCAL's kind isn't collected during the global
          // return pass), so set it reliably from the checker's inferred return NAME.
          fRetMap[li] = 1
        } else if inm == "string|null" {
          // A `string | null` niche inferred return drives the kind-16 result valtype
          // (`ref null $array`) — same flag the annotated `: string | null` path sets, so
          // `fnRetNulString` and the signature emission both classify it. The `boolean |
          // null` niche needs NO flag: its result valtype is plain i32 (the sentinel rides
          // an i32), so it falls through to the default.
          fRetNulStr[li] = 1
        } else if isValueUnionName(inm) {
          fRetUni[li] = 1
        } else if isUName(inm) {
          // A registered STRUCT-union inferred return (`Cat | Dog` — registered from this
          // same name in `collectU`): the variant-boxed rep rides the SAME union result
          // valtype as a value union (kind 4 box), so set `fRetUni`. The expression-based
          // fallback would NOT catch it (a single object-literal return is not itself a
          // union expression), so set it from the name here.
          fRetUni[li] = 1
        }
      }
    }
    i = i + 1
  }
  fnStmts.length
}

// Classify each function's VOIDNESS as a monotone fixed point: a candidate (no
// return annotation) is void when its body has no valued `return` and no tail
// value. `stmtIsTailValue` consults `fRetVoid` for tail CALLS, so marking a
// callee void can make its CALLERS' tails non-values — iterate until stable
// (the void set only grows; bounded by the function count).
function computeVoidFns() {
  let changed = true
  while changed {
    changed = false
    let i = 0
    while i < fnStmts.length {
      if fRetVoid[i] == 0 {
        const fn = P.nodes[fnStmts[i]]
        if fn is FuncDecl {
          if fn.fnRet < 0 {
            if !blockHasValuedReturn(fn.fnBody) {
              // An else-less tail `if` makes the return `T | null` (`function f(c) { if
              // c then 5 }`), but `blockTailIsValue` deliberately ignores else-less ifs
              // (they feed THIS fixpoint — a void procedure's recursive tail
              // `if n>0 { rec(n-1) }` must not look like a value). So also consult the
              // static checker classification: a NULLABLE inferred return (a name with a
              // `null` atom) is non-void. Gated to nullable specifically (not just
              // non-empty) so an i32-valued tail the emitter can't lower as a value — e.g.
              // a Member-target assignment `state.x = …`, which the checker reads as an
              // i32 expression but `stmtIsTailValue` rejects — still classifies void.
              if (
                !blockTailIsValue(fn.fnBody, fnStmts[i]) &&
                !unionHasAtom(inferRetNameOf(fn.fnName), "null") &&
                !fnReturnsClosure(i)
              ) {
                // A function whose tail is a function VALUE (`(a) => (b) => …`) returns a
                // closure, NOT void — `blockTailIsValue` ignores a bare lambda tail, so guard
                // it here (else f's functype is `()->()` and `f(4)` reads as a void result).
                fRetVoid[i] = 1
                changed = true
              }
            }
          }
        }
      }
      i = i + 1
    }
  }
  0
}

// The arena index of the expression an UN-ANNOTATED function returns: the body's
// trailing tail-value statement, or the first valued `return`'s argument (walking
// into if/while/for bodies). -1 when the function yields nothing (void).
function fnRetExprOf(fnIx: i32) {
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    let b = P.nodes[fn.fnBody]
    if b is Block {
      const stmts = b.blkStmts
      if stmts.length > 0 {
        const last = stmts[stmts.length - 1]
        if stmtIsTailValue(last, fnIx) { return last }
      }
    }
    return firstValuedReturn(fn.fnBody)
  }
  -1
}

// True if `rx` is a reference to a LOCAL whose annotation is a mono `{[string]: i32}` map —
// the ordering-safe way to classify a returned map local during the GLOBAL return pass (before
// per-function local kinds are collected, so `exprMap`/`declaredMap` can't see it yet).
// The map SHAPE of a RETURN expression, resolved from ANNOTATIONS ONLY (not collected local
// state) — so it is valid at the type-section emit (before locals are collected) AND from a
// DIFFERENT function (a caller resolving a map factory's value type). A returned map PARAM reads
// its annotation (`paramMapShape`); a returned map LOCAL its `let` annotation (`mapAnnShape`); a
// `Map()`/`Set()` is the mono map (-1); a call to another map fn recurses (`fnRetMapShape`).
// -1 (mono) for anything else.
function mapRetExprShape(rx: i32, fnIx: i32) {
  let u = rx
  let done = false
  while !done {
    const node = P.nodes[u]
    if node is Paren { u = node.parInner } else { done = true }
  }
  const e = P.nodes[u]
  if e is Ident {
    if paramMap(fnIx, e.identName) { return paramMapShape(fnIx, e.identName) }
    const fn = P.nodes[fnIx]
    if fn is FuncDecl {
      const li = parentLetOf(fn.fnBody, e.identName)
      if li >= 0 {
        const d = P.nodes[li]
        if d is LetDecl {
          if d.letType >= 0 { return mapAnnShape(d.letType) }
        }
      }
    }
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if callee.identName == "Map" || callee.identName == "Set" { return -1 }
      return fnRetMapShape(callee.identName)
    }
  }
  -1
}

function retIsMapLocalAnnot(rx: i32, fnIx: i32) {
  let u = rx
  let done = false
  while !done {
    const node = P.nodes[u]
    if node is Paren { u = node.parInner } else { done = true }
  }
  const e = P.nodes[u]
  if e is Ident {
    const fn = P.nodes[fnIx]
    if fn is FuncDecl {
      const li = parentLetOf(fn.fnBody, e.identName)
      if li >= 0 {
        const d = P.nodes[li]
        if d is LetDecl {
          if d.letType >= 0 {
            const lt = P.nodes[d.letType]
            if lt is TypeRef {
              if nameIsMap(lt.tyName) {
                // A supported map value type (mono i32/boolean, `string`, or a struct) — the
                // same set `retMapFlag` lets cross the boundary; the return's SHAPE is recovered
                // at the functype-result site via `mapShapeOfExpr` over this same local.
                const vn = mapValNameOf(lt.tyName)
                if vn == "i32" || vn == "boolean" || vn == "string" {
                  return true
                }
                return structIndexByValName(vn) >= 0
              }
            }
          }
        }
      }
    }
  }
  false
}

// Classify ONE valued return expression at `rx0` of the function at `fnStmts`
// position `i`, under the CURRENT narrowing stack — the loop body the flat
// return scan used to run, extracted so the narrowing-aware walk shares it.
function criClassify(rx0: i32, i: i32) {
  let rx = rx0
  // A tail ASSIGNMENT yields its RHS (assignment-as-expression), so the
  // function's return kind is the RHS's kind (`function emit(s: string)
  // { acc = acc + s }` returns the new string).
  const rxe = P.nodes[rx]
  if rxe is BinExpr {
    if rxe.binOp == "=" { rx = rxe.binRight }
  }
  if fRetStr[i] == 0 && exprString(rx, fnStmts[i]) {
    fRetStr[i] = 1
    criChanged = true
  }
  if fRetListKind[i] == 0 && exprRefArray(rx, fnStmts[i]) {
    fRetListKind[i] = 5
    // Record the element type-NAME so the inferred functype result can resolve its ref-list
    // slot (`rlSlotByName`) — the annotated path fills `fRetRArrElem` from the annotation, but
    // an un-annotated `return ps` / `return ps.filter(…)` must read it off the return expr.
    if i < fRetRArrElem.length && fRetRArrElem[i] == "" {
      fRetRArrElem[i] = refListElemNameOfExpr(rx, fnStmts[i])
    }
    criChanged = true
  }
  if fRetListKind[i] == 0 && exprStringArray(rx, fnStmts[i]) {
    fRetListKind[i] = 7
    criChanged = true
  }
  if fRetListKind[i] == 0 && exprF64Array(rx, fnStmts[i]) {
    fRetListKind[i] = 12
    criChanged = true
  }
  if fRetMap[i] == 0 {
    // `exprMap` classifies a returned map PARAM (reads `parType` directly) and a `Map()`/
    // map-returning-call. A returned map LOCAL needs `retIsMapLocalAnnot` — its kind isn't
    // collected during this GLOBAL return pass, so read its `{[string]: i32}` annotation.
    if exprMap(rx, fnStmts[i]) || retIsMapLocalAnnot(rx, fnStmts[i]) {
      fRetMap[i] = 1
      criChanged = true
    }
  }
  // The `== 0` guard subsumes the old `fRetArr==0 && fRetF64Arr==0`: `exprArray`'s array-
  // literal case is `!arrLitIsRef`, and an f64 element is NOT a ref, so `exprArray` also
  // claims an f64 literal (`[1.5, 2.5]`). The f64-list code was set just above, leaving
  // `fRetListKind != 0`, so this skips it — no separate i32/f64 mis-classification.
  if fRetListKind[i] == 0 && exprArray(rx, fnStmts[i]) {
    fRetListKind[i] = 2
    criChanged = true
  }
  if fRetUni[i] == 0 && exprUnion(rx, fnStmts[i]) {
    fRetUni[i] = 1
    // A union return SUBSUMES a per-arm struct classification: a value-if join (`if c {
    // catVal } else { dogVal }`) has one arm a union-VARIANT object literal (which
    // `exprStruct` would also claim as a plain struct return) and another the union. If the
    // struct arm was classified FIRST it set `fRetRef` while `fRetUni` was still 0 (the
    // `fRetRef` guard only blocks the reverse order). Clear it so the union wins — else the
    // inferred-result valtype declares a struct ref over a body that yields the union box.
    // Lambda-gated: only the lambda value-if path (above) sets both, and a named function's
    // classification must stay byte-identical.
    if criFnIsAnonLambda(i) { fRetRef[i] = 0 }
    criChanged = true
  }
  if fRetNul[i] == 0 && fRetUni[i] == 0 && exprNullableStruct(rx, fnStmts[i]) {
    fRetNul[i] = 1
    fRetStructIdx[i] = structIndexOfExpr(rx, fnStmts[i])
    criChanged = true
  }
  if (
    fRetRef[i] == 0 &&
    fRetNul[i] == 0 &&
    fRetUni[i] == 0 &&
    exprStruct(rx, fnStmts[i])
  ) {
    // GUARD `fRetUni == 0`: an INFERRED struct-union return (`Cat | Dog`) sets `fRetUni`
    // in the A20 name pass, but each of its returns is a SINGLE object literal that
    // `exprStruct` would (wrongly) also classify as a plain struct return — the union
    // flag dominates, so don't also set `fRetRef`/`fRetStructIdx` (a conflicting rep).
    fRetRef[i] = 1
    fRetStructIdx[i] = structIndexOfExpr(rx, fnStmts[i])
    criChanged = true
  }
  if fRetBool[i] == 0 && exprIsBool(rx, fnStmts[i]) {
    fRetBool[i] = 1
    criChanged = true
  }
  // SCALAR f64 / f32 / i64 returns, detected from the return EXPRESSION — the dual of the string
  // / list / struct cases above. A function the checker never recorded an inferred-return name for
  // — a MONOMORPHIZED instance (`f(n)` pinned to `n: f64` by the emitter, whose body the checker
  // only saw with `n` a type variable) — would otherwise default its functype result to i32 over
  // an f64/f32/i64 body: "expected i32, found f64". Gated on the flag being unset (so an annotated
  // return and every i32 return are untouched) AND on a "pure" scalar return: a value-union `?? d`
  // coalesce reads as its unboxed atom (`exprIsF64`/`exprIsI64`) but its result REP is the union
  // box, classified separately — so exclude it, and skip when another return flag already claimed
  // the function.
  let scalarOk = fRetStr[i] == 0 &&
    fRetListKind[i] == 0 &&
    fRetMap[i] == 0 &&
    fRetUni[i] == 0 &&
    fRetNul[i] == 0 &&
    fRetNulStr[i] == 0 &&
    fRetRef[i] == 0 &&
    fRetBool[i] == 0
  const rxn = P.nodes[rx]
  if rxn is BinExpr {
    if rxn.binOp == "??" { scalarOk = false }
  }
  if scalarOk {
    if fRetF64[i] == 0 && exprIsF64(rx, fnStmts[i]) {
      fRetF64[i] = 1
      criChanged = true
    }
    if fRetF32[i] == 0 && exprIsF32(rx, fnStmts[i]) {
      fRetF32[i] = 1
      criChanged = true
    }
    if fRetI64[i] == 0 && exprIsI64(rx, fnStmts[i]) {
      fRetI64[i] = 1
      criChanged = true
    }
  }
  0
}

// Walk a block's statements classifying every `return <e>` under the SAME
// narrowing the emit loops apply: each `if` arm classifies under its
// condition's then/else narrowing, and a divergent guard narrows the rest of
// the block (`pushPostGuardNarrow`). The stack rewinds at block exit.
// True if lifted function `i` (an `fnStmts` index) is an ANONYMOUS lambda (no source
// name). Restricts the if-arm tail-value return classification below to lambdas, leaving
// NAMED-function return inference byte-identical (a named function's inferred-return name
// already rides `buildFnMap`'s A20 pass + `criWalkStmt`'s explicit-`return` classification;
// perturbing it would change the compiler's own self-compilation).
function criFnIsAnonLambda(i: i32) {
  if i < 0 || i >= fnStmts.length { return false }
  const fn = P.nodes[fnStmts[i]]
  if fn is FuncDecl {
    // The emitter rewrites an anonymous lambda's empty name to the synthesized
    // `__lambda_N` (before this pass runs), so test that prefix — `fnName == ""` never
    // matches a lifted lambda here. A source function never starts with `__lambda`.
    const nm = fn.fnName
    return nm.length >= 8 && nm.slice(0, 8) == "__lambda"
  }
  false
}

function criWalkBlock(blockIx: i32, i: i32) {
  if blockIx < 0 { return 0 }
  let b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    const savedGuardTop = narrowTop
    let k = 0
    while k < stmts.length {
      // An if-ARM's last statement may be a bare tail VALUE (an implicit return —
      // `if c { catVal } else { dogVal }`), not an explicit `return`. For an ANONYMOUS
      // LAMBDA, classify it under the arm's active narrowing so a value-if union return
      // types from its arms (a named union-returning callback already works via explicit
      // `return`s). Lambda-gated to keep named-function inference byte-identical.
      if (
        k == stmts.length - 1 &&
        criFnIsAnonLambda(i) &&
        stmtIsTailValue(stmts[k], fnStmts[i])
      ) {
        criClassify(stmts[k], i)
      }
      criWalkStmt(stmts[k], i)
      pushPostGuardNarrow(stmts[k], fnStmts[i])
      k = k + 1
    }
    restoreNarrow(savedGuardTop)
    return 0
  }
  criWalkStmt(blockIx, i)
}

function criWalkStmt(stmtIx: i32, i: i32) {
  if stmtIx < 0 { return 0 }
  let s = P.nodes[stmtIx]
  if s is RetStmt {
    if s.retArg >= 0 { criClassify(s.retArg, i) }
    return 0
  }
  if s is IfStmt {
    const savedTop = narrowTop
    setNarrowFromCond(s.ifCond, fnStmts[i])
    criWalkBlock(s.ifThen, i)
    restoreNarrow(savedTop)
    if s.ifElse >= 0 {
      const savedElseTop = narrowTop
      setNarrowFromCondElse(s.ifCond, fnStmts[i])
      criWalkBlock(s.ifElse, i)
      restoreNarrow(savedElseTop)
    }
    return 0
  }
  if s is WhileStmt { return criWalkBlock(s.whileBody, i) }
  if s is ForRange { return criWalkBlock(s.frBody, i) }
  if s is ForIn { return criWalkBlock(s.fiBody, i) }
  0
}

function computeRetInference() {
  let changed = true
  while changed {
    changed = false
    let i = 0
    while i < fnStmts.length {
      const fn = P.nodes[fnStmts[i]]
      if fn is FuncDecl {
        if fn.fnRet < 0 && fRetVoid[i] == 0 {
          // Classify over EVERY valued return (tail value first — the same
          // preference `fnRetExprOf` had), not just the first: a function whose
          // first return is an unclassifiable narrowed path read (`if x?.y is
          // string { return x.y } return "-1"`) still types from its other
          // returns — the checker already proved all returns agree. The walk is
          // NARROWING-AWARE (`criWalkBlock` mirrors the emit loops' condition /
          // post-guard narrowing), so `if v !is i32 { return v }` classifies the
          // narrowed `v` as its complement (a string return, not the union box) —
          // the host's flow-sensitive return typing.
          criChanged = false
          const fnb = P.nodes[fnStmts[i]]
          if fnb is FuncDecl {
            const fb = P.nodes[fnb.fnBody]
            if fb is Block {
              const fbs = fb.blkStmts
              if fbs.length > 0 {
                const tailIx = fbs[fbs.length - 1]
                if stmtIsTailValue(tailIx, fnStmts[i]) {
                  criClassify(tailIx, i)
                } else {
                  // A tail VALUE-IF (`function pick(c) if c > 1 then mk(1) else mk(2)`) is not a
                  // `stmtIsTailValue` (that predicate has no IfStmt case), so a NAMED function's
                  // inferred STRUCT return through an if-join went unclassified — the name path
                  // records only scalar/string/list returns and `criWalkBlock` classifies a tail
                  // value only for anonymous lambdas. Classify the whole `if` here: `exprStruct`/
                  // `exprString` see through it (then-arm rep), so the join's struct/string ref is
                  // picked up. A struct-UNION join is already `fRetUni` (name path) — the
                  // `fRetUni == 0` guard in `criClassify` keeps it from being re-claimed a struct.
                  const tn = P.nodes[tailIx]
                  if tn is IfStmt {
                    if tn.ifElse >= 0 { criClassify(tailIx, i) }
                  }
                }
              }
            }
            criWalkBlock(fnb.fnBody, i)
          }
          if criChanged { changed = true }
        }
      }
      i = i + 1
    }
  }
  0
}

// Look up the wasm function index for `name`, or -1 if no such top-level function
// exists (an undefined callee — the caller fails loudly).
function fnIndexOf(name: string) { fnNameMap[name] ?? -1 }

// `fnIndexOf` but SCOPE-AWARE for a name referenced as a VALUE inside function `fnIx`
// (a node index): when two lifted functions share a name (each `makeX` declaring its
// own nested `add`), the flat `fnIndexOf` always returns the FIRST — wrong for the
// SECOND maker's body, whose `add` captures a different frame. Prefer a lifted function
// named `name` whose PARENT is `fnIx`'s own `fnStmts` position; fall back to the flat
// lookup (a top-level function, or no nested match). Only consulted on the function-
// VALUE path (gated by `fnValUsed`), so by-name resolution elsewhere is unchanged.
function fnIndexOfInScope(name: string, fnIx: i32) {
  // The parent-matching scan can only succeed for a NESTED function named `name`; skip
  // it entirely (→ O(1) `fnIndexOf`) when no lifted function carries this name.
  if fnIx >= 0 && (nestedNameSet[name] ?? false) {
    const pp = fnStmtsPosOf(fnIx)
    if pp >= 0 {
      let i = 0
      while i < fnStmts.length {
        let s = P.nodes[fnStmts[i]]
        if s is FuncDecl {
          if s.fnName == name {
            if i < fnParent.length && fnParent[i] == pp { return i }
          }
        }
        i = i + 1
      }
    }
  }
  fnIndexOf(name)
}

// ── capture analysis (closures) ───────────────────────────────────────────────
// The captured-variable NAMES of the lifted function at `fnStmts[fe]`, in
// encounter (= env field) order. A capture is a free variable: an identifier read
// in the body that is NOT one of the function's own params, NOT a `let`/`const`
// declared in the body, NOT a module global, and NOT a top-level/lifted function
// name (those are addressable directly). Recomputed on demand (no `string[][]`
// state — that type is not self-host-emittable). The walk threads a growable
// `bound` set (params, then each `let` as it is declared) and accumulates free
// names into `caps` (deduped). Mirrors the host's `captureCollector`.
function captureNamesOf(fe: i32) {
  const caps: string[] = []
  if fe < 0 || fe >= fnStmts.length { return caps }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    const bound: string[] = []
    const params = fn.fnParams
    let pi = 0
    while pi < params.length {
      const p = P.nodes[params[pi]]
      if p is Param { bound.push(p.parName) }
      pi = pi + 1
    }
    capScan(fn.fnBody, bound, caps)
  }
  caps
}

// The number of captured variables of the lifted function at `fnStmts[fe]`.
function captureCountOf(fe: i32) {
  const caps = captureNamesOf(fe)
  caps.length
}

function capRecord(name: string, bound: string[], caps: string[]) {
  if capIsBound(bound, name) { return 0 }
  if globalIndexOf(name) >= 0 { return 0 }
  if fnIndexOf(name) >= 0 { return 0 }
  if isBuiltinFnName(name) { return 0 }
  if capHas(caps, name) { return 0 }
  caps.push(name)
  0
}

// Walk a statement/expression subtree collecting free-variable captures. `bound`
// grows as `let`/`const` declarations are seen (wasm locals are function-scoped, so
// once declared a name shadows an enclosing binding for the rest of the body — a
// conservative but sound match for the corpus). A NESTED FuncDecl is NOT descended
// (it is lifted to its own function with its own capture analysis); its name, if
// any, binds locally.
export function capScan(ix: i32, bound: string[], caps: string[]) {
  if ix < 0 { return 0 }
  let n = P.nodes[ix]
  if n is Ident {
    capRecord(n.identName, bound, caps)
    return 0
  }
  if n is FuncDecl {
    if n.fnName != "" { bound.push(n.fnName) }
    return 0
  }
  if n is Block {
    const stmts = n.blkStmts
    let i = 0
    while i < stmts.length {
      capScan(stmts[i], bound, caps)
      i = i + 1
    }
    return 0
  }
  if n is LetDecl {
    if n.letInit >= 0 { capScan(n.letInit, bound, caps) }
    bound.push(n.letName)
    return 0
  }
  if n is RetStmt {
    if n.retArg >= 0 { capScan(n.retArg, bound, caps) }
    return 0
  }
  if n is IfStmt {
    capScan(n.ifCond, bound, caps)
    capScan(n.ifThen, bound, caps)
    if n.ifElse >= 0 { capScan(n.ifElse, bound, caps) }
    return 0
  }
  if n is WhileStmt {
    capScan(n.whileCond, bound, caps)
    capScan(n.whileBody, bound, caps)
    return 0
  }
  if n is ForRange {
    capScan(n.frFrom, bound, caps)
    capScan(n.frTo, bound, caps)
    if n.frStep >= 0 { capScan(n.frStep, bound, caps) }
    bound.push(n.frVar)
    capScan(n.frBody, bound, caps)
    return 0
  }
  if n is ForIn {
    capScan(n.fiIter, bound, caps)
    bound.push(n.fiVar)
    capScan(n.fiBody, bound, caps)
    return 0
  }
  if n is Call {
    capScan(n.callFn, bound, caps)
    const args = n.callArgs
    let i = 0
    while i < args.length {
      capScan(args[i], bound, caps)
      i = i + 1
    }
    return 0
  }
  if n is BinExpr {
    capScan(n.binLeft, bound, caps)
    capScan(n.binRight, bound, caps)
    return 0
  }
  if n is Unary {
    capScan(n.unArg, bound, caps)
    return 0
  }
  if n is Paren {
    capScan(n.parInner, bound, caps)
    return 0
  }
  if n is Member {
    capScan(n.memObj, bound, caps)
    return 0
  }
  if n is OptMember {
    capScan(n.omObj, bound, caps)
    return 0
  }
  if n is Index {
    capScan(n.idxArr, bound, caps)
    capScan(n.idxIndex, bound, caps)
    return 0
  }
  if n is IsExpr {
    capScan(n.isObj, bound, caps)
    return 0
  }
  if n is ObjLit {
    const fields = n.objFields
    let i = 0
    while i < fields.length {
      const f = P.nodes[fields[i]]
      if f is FieldInit { capScan(f.fiValue, bound, caps) }
      i = i + 1
    }
    return 0
  }
  if n is ArrayLit {
    const elems = n.arrElems
    let i = 0
    while i < elems.length {
      capScan(elems[i], bound, caps)
      i = i + 1
    }
    return 0
  }
  0
}

// The env struct heap-type index for the lifted function at index `fe`, or -1 if it
// captures nothing (its closure env is `ref.null structref`). Resolved by
// `mAssignTypeIndices` into `fnEnvIdx`.
function fnEnvIdxOf(fe: i32) {
  if fe < 0 || fe >= fnEnvIdx.length { return -1 }
  fnEnvIdx[fe]
}

// True if function `fe`'s env-leading signature matches an interned `$fnsig`
// `(structref, params...) -> ret` (`fnSigKeyOf` eligibility: i32/boolean, f64, or
// struct-ref params; an i32/boolean or f64 result; non-void). Such a function is
// declared with `fnSigIdxOfFn` as its functype (so its ACTUAL type IS `$fnsig`),
// making `ref.func` of it yield a value the `call_ref` site's `ref.cast` to `$fnsig`
// accepts. A function outside the eligible kinds keeps its own functype and cannot
// be used as a value (none in the corpus are).
function fnSigIsClosure(fe: i32) { fnSigIdxOfFn(fe) >= 0 }

// The arena index of the parent frame's binding for a captured `name` — the parent
// FuncDecl's matching `Param` node, or a `LetDecl` in the parent body, or -1. Used to
// resolve a capture's wasm valtype (its declared type lives in the parent frame).
function parentBindingOf(fe: i32, name: string) {
  if fe < 0 || fe >= fnParent.length { return -1 }
  const par = fnParent[fe]
  if par < 0 || par >= fnStmts.length { return -1 }
  const pfn = P.nodes[fnStmts[par]]
  if pfn is FuncDecl {
    const params = pfn.fnParams
    let i = 0
    while i < params.length {
      const p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name { return params[i] }
      }
      i = i + 1
    }
    return parentLetOf(pfn.fnBody, name)
  }
  -1
}

// The `fbValtype` kind for a captured variable `name` of lifted function `fe`,
// resolved against the parent frame's binding (a param's annotation, or a local
// `let`'s annotation / struct-literal initializer). Defaults to i32 (kind 0).
function captureValKind(fe: i32, name: string) {
  let b = parentBindingOf(fe, name)
  if b < 0 { return 0 }
  const bn = P.nodes[b]
  if bn is Param { return vtKindOfType(bn.parType) }
  if bn is LetDecl {
    if bn.letType >= 0 { return vtKindOfType(bn.letType) }
    // Un-annotated local: classify the INITIALIZER through the same ladder
    // `collectLocals` types the binding with (resolved in the PARENT frame), so
    // a captured list/string/struct env field carries its real ref valtype —
    // `const store = [a, b]` captured by a closure is the i32-list wrapper ref
    // (kind 2), not an i32 cell. Order mirrors `collectLocals`.
    if bn.letInit >= 0 {
      const pf = fnParent[fe]
      if letIsMap(b, pf) { return 6 }
      if letIsNulRef(b, pf) { return 9 }
      // A value union wins over a scalar-list INIT (`f64[] | string = [1.5]`) — see the
      // local-decl chain. Checked before the scalar-list cases for that reason.
      if letIsUnion(b, pf) { return 4 }
      if letIsStringArray(b, pf) { return 7 }
      if letIsF32Array(b, pf) { return 21 }
      if letIsF64Array(b, pf) { return 12 }
      if letIsI64Array(b, pf) { return 20 }
      if letIsRefArray(b, pf) { return 5 }
      if letIsStruct(b, pf) { return 1 }
      if letIsArray(b, pf) { return 2 }
      if letIsString(b, pf) { return 3 }
      if letIsI64(b, pf) { return 10 }
      if letIsF32(b) || letInfersF32(b, pf) { return 13 }
      if letIsF64(b, pf) { return 11 }
      if letIsClosure(b, pf) { return 14 }
    }
  }
  0
}

// The second `fbValtype` arg (struct table index) for a captured struct-ref variable.
function captureValStructIdx(fe: i32, name: string) {
  let b = parentBindingOf(fe, name)
  if b < 0 { return -1 }
  const bn = P.nodes[b]
  if bn is Param { return retStructIndex(bn.parType) }
  if bn is LetDecl {
    if bn.letType >= 0 { return retStructIndex(bn.letType) }
    if bn.letInit >= 0 {
      const pf = fnParent[fe]
      // The kind-specific companion index, mirroring `captureValKind`'s ladder:
      // a map capture carries its mv SHAPE slot, a nullable-struct / struct
      // capture its struct table index, a ref-list capture its ref-list slot.
      if letIsMap(b, pf) { return letMapShapeOf(b, pf) }
      if letIsNulRef(b, pf) { return nulRefStructIdxOfLet(b, pf) }
      if letIsRefArray(b, pf) { return letRefListSlot(b, pf) }
      const iv = P.nodes[bn.letInit]
      if iv is ObjLit { return structIndexOfExpr(bn.letInit, pf) }
    }
  }
  -1
}

// Enter a new lexical block: remember the current binding count as this frame's
// boundary. Returns 0.
function scopePush() {
  scopeFrames.push(scopeNames.length)
  0
}

// Leave the innermost lexical block: drop its frame boundary and discard every
// binding appended within it (truncate `scopeNames`/`scopeSlots` back to the mark).
// Returns 0.
function scopePop() {
  if scopeFrames.length == 0 { return 0 }
  const mark = scopeFrames[scopeFrames.length - 1]
  scopeFrames.pop()
  while scopeNames.length > mark {
    scopeNames.pop()
    scopeSlots.pop()
  }
  0
}

// Bind name `name` to declared-local position `slot` in the CURRENT (innermost) frame.
// Called as each `let` is reached, so a binding is in scope only AFTER its declaration
// (sequential), which also yields correct shadowing of an outer same-named binding.
// Returns 0.
function scopeBind(name: string, slot: i32) {
  scopeNames.push(name)
  scopeSlots.push(slot)
  0
}

// Drop the most recent binding — the loop-VARIABLE unbind. A `for` binds its
// variable in the ENCLOSING frame (no frame of its own), but the variable's
// scope is the LOOP (host parity: the loop declares it in the loop's scope), so
// both passes unbind it as the loop closes. Without this the loop var would
// keep shadowing a same-named binding that resolves through a LATER channel
// (e.g. a top-level `let` lowered to a wasm GLOBAL — locals win the lookup), so
// `for i in …` followed by `let i = 0` mis-read the dead loop counter.
// Returns 0.
function scopeUnbind() {
  scopeNames.pop()
  scopeSlots.pop()
  0
}

// The declared-local POSITION bound to `name` by the innermost live scope frame, or
// -1 if `name` is not a live lexical binding. Searches the scope stack top-down
// (innermost first), so a shadowing inner `let` wins over an outer same-named one.
function scopeSlotOf(name: string) {
  let k = scopeNames.length
  while k > 0 {
    k = k - 1
    if scopeNames[k] == name { return scopeSlots[k] }
  }
  -1
}

// Opening a control frame: bump the running depth. Returns 0.
function ctrlEnter() {
  ctrlDepth = ctrlDepth + 1
  0
}

// Closing a control frame (its matching `end`): drop the running depth. Returns 0.
function ctrlLeave() {
  ctrlDepth = ctrlDepth - 1
  0
}

// The wasm local base of the ref-push scratch frame for ref-list table slot `slot`.
function refPushScratchBaseFor(slot: i32) {
  let i = 0
  while i < fnRefPushSlots.length {
    if fnRefPushSlots[i] == slot { return refPushBaseBySlot[i] }
    i = i + 1
  }
  refPushScratchBase
}

// Resolve a value type-NAME to a struct TABLE index: a declared struct by name, or
// an inline object type `{a:T,b:U}` matched by FIELD-NAME SET against the table
// (anonymous shapes are interned from literals by `collectAnonShapes` under `#anonN`
// names, so the annotation text never matches by name — the field set is the key,
// exactly how `structIndexOfObj` binds literals). -1 when nothing matches.
function structIndexByValName(name: string) {
  let si = structIndexByName(name)
  if si >= 0 { return si }
  if name.length < 2 { return -1 }
  if name[0] != '{' { return -1 }
  if name[1] == '[' { return -1 }
  // Parse the field NAMES out of `{a:T,b:U}`: each field name runs from a `{`/`,`
  // at depth 1 to its `:`. Nested `{}`/`[]` in field types are depth-tracked so
  // their commas/colons don't split.
  const fnames: string[] = []
  let depth = 0
  let i = 0
  let start = -1
  while i < name.length {
    let c = name[i]
    if c == '{' || c == '[' {
      depth = depth + 1
      if depth == 1 { start = i + 1 }
    } else if c == '}' || c == ']' {
      depth = depth - 1
    } else if c == ',' {
      if depth == 1 { start = i + 1 }
    } else if c == ':' {
      if depth == 1 {
        if start >= 0 { fnames.push(name.slice(start, i)) }
        start = -1
      }
    }
    i = i + 1
  }
  if fnames.length == 0 { return -1 }
  // Match by exact field-name set (count + every name present).
  let s = 0
  while s < sNames.length {
    if sFieldCount[s] == fnames.length {
      let ok = true
      let k = 0
      while k < fnames.length {
        if sFieldIndex(s, fnames[k]) < 0 { ok = false }
        k = k + 1
      }
      if ok { return s }
    }
    s = s + 1
  }
  -1
}

// Classify + intern a map VALUE type-name, returning the binding's map SHAPE code:
// `-1` mono i32 map (i32 / boolean values), a slot `>= 0` for a ref value type
// (string / struct), or `-3` unsupported (unions, arrays, nested maps — the op
// sites fail loudly). Interning is idempotent (one slot per distinct name).
// Kind-1 (struct) values force the element's ref-list types (`rlInternName`), and
// every ref-valued map forces the string-list (keys) + mono map types — the shared
// probe machinery and the keys list ride on them.
function mvShapeOfValName(valName: string) {
  if valName == "i32" || valName == "boolean" { return -1 }
  let kind = -1
  let vsi = -1
  if valName == "string" {
    kind = 3
  } else if valName == "f64" {
    // An f64-valued map: its vals list is the scalar f64 list (`$fl64TypeIdx` wrapper /
    // `$fa64TypeIdx` backing), NOT a ref list. Rides the existing mv-slot frame, but the
    // value is a scalar — its typed valStash is an f64 local (not a nullable ref).
    kind = 11
  } else if valName == "i64" {
    // An i64-valued map: the scalar i64 list (`$il64TypeIdx`/`$ia64TypeIdx`); valStash i64.
    kind = 10
  } else if valName == "f32" {
    // An f32-valued map: the scalar f32 list (`$fl32TypeIdx`/`$fa32TypeIdx`); valStash f32.
    kind = 13
  } else if nameIsMap(valName) {
    // A NESTED map (`{[string]: {[string]: V}}`): the value is an INNER map struct ref,
    // stored in a ref list whose element kind is 3 (a map element → the inner map struct).
    // Reuses the SAME ref-value spine as a struct-valued map; only the element heap differs.
    kind = 6
  } else if (
    nameIsI32Array(valName) ||
    nameIsStringArray(valName) ||
    nameIsF64Array(valName) ||
    nameIsI64Array(valName) ||
    nameIsF32Array(valName)
  ) {
    // A LIST-valued map (`{[string]: i32[]}` / `string[]` / `f64[]` / `i64[]` / `f32[]` /
    // `boolean[]`): the value is a list WRAPPER ref, stored in a ref list whose element kind
    // picks the inner list's wrapper (`refArrElemKind("<value>[]")` → 4/6/7/8/10). Same ref-value
    // spine as a nested map.
    kind = 6
  } else if nameIsRefArray(valName) {
    // ANY ref-array map value — struct-list (`S[]`), union-list (`(C|D)[]`), a NESTED `S[][]` /
    // `i32[][]`, or a closure list (`((i32)=>i32)[]`): the value is a list WRAPPER ref, stored in
    // a ref-value list whose element is this value's wrapper (`ensureRefElem`, recursive). The
    // store seeds the value literal off this slot and the read classifies the value's element
    // recursively, so any nesting / leaf falls out — one predicate, no per-shape special cases.
    kind = 6
  } else if unionMemberCount(unionMemberSetOf(valName)) > 1 {
    // A UNION-valued map: each value is the shared union BOX ref (`uBoxIdx`), stored in a ref
    // list whose element kind is 2 (the union box) — the SAME ref-value spine as a struct
    // value, only the element heap + the store-coerce / read-classify differ. Covers a VALUE
    // union (`{[string]: i32 | string}`), a STRUCT / heterogeneous union (`{[string]: C | S}`),
    // and a union ALIAS (`type Shape = C | S`; `unionMemberSetOf` expands it before the count).
    // A value union also interns its scalar value-box reps (`registerValueUnionName`); a
    // struct/heterogeneous union just rides the box payload, so no value boxes are needed.
    kind = 2
    if isValueUnionName(valName) { registerValueUnionName(valName) }
  } else if annArrowAt(valName) >= 0 {
    // A FUNCTION-valued map (`{[string]: (i32) => i32}`): each value is a closure fat-pointer
    // (`ref $cloStructIdx`), stored in a ref list whose element kind is 5 (the closure) — the
    // SAME rep an `((i32) => i32)[]` array uses. A read yields a closure local; the call
    // resolves its sig from the value annotation.
    kind = 14
  } else {
    vsi = structIndexByValName(valName)
    if vsi >= 0 { kind = 1 }
  }
  if kind < 0 { return -3 }
  let i = 0
  while i < mvValName.length {
    if mvValName[i] == valName { return i }
    i = i + 1
  }
  // A kind-6 (ref-VALUE: nested map / list) value forces the i32-list + map types, and a
  // MAP value also interns its INNER value shape first (so a ref-valued inner map's struct
  // exists) — for the common mono inner (`{[string]: i32}`) that is a no-op
  // (`mvShapeOfValName("i32")` returns -1). Done BEFORE pushing this slot's parallel arrays
  // so the recursive intern lands at an earlier slot index.
  if kind == 6 {
    lUsed = true
    aUsed = true
    if nameIsMap(valName) {
      mUsed = true
      mvShapeOfValName(mapValNameOf(valName))
    }
    // A non-i32 LIST value forces its inner list's type so the element wrapper heap exists.
    if nameIsStringArray(valName) { slUsed = true }
    else if nameIsF64Array(valName) { fa64Used = true }
    else if nameIsI64Array(valName) { ia64Used = true }
  }
  mvValName.push(valName)
  mvValKind.push(kind)
  mvValStructIdx.push(vsi)
  if kind == 1 {
    mvRlSlot.push(rlInternName(sNames[vsi], 1))
    rlUsed = true
    raUsed = true
  } else if kind == 2 {
    // A union-VALUE ref list: element kind 2 (the union box, heap `uBoxIdx`).
    mvRlSlot.push(rlInternName(valName, 2))
    rlUsed = true
    raUsed = true
  } else if kind == 6 {
    // The map's VALUE is a ref LIST (`S[]` struct-list, `(C|D)[]` union-list, `i32[]` scalar
    // list, or a nested map). Its vals ref-list slot is keyed by the value name with the
    // recursively-interned inner slots — the SAME `ensureRefElem` the array path uses, replacing
    // the three hand-coded interning cases that duplicated it. (The `mvShapeOfValName` classifier
    // still gates WHICH value types reach here; fully nested / closure list map VALUES additionally
    // need the map store/read/coerce paths migrated to the recursive resolver — a larger change.)
    mvRlSlot.push(ensureRefElem(valName))
    rlUsed = true
    raUsed = true
  } else if kind == 14 {
    // A CLOSURE-VALUE ref list: element kind 5 (the closure fat-pointer, heap `cloStructIdx`).
    mvRlSlot.push(rlInternName(valName, 5))
    rlUsed = true
    raUsed = true
  } else {
    mvRlSlot.push(-1)
  }
  if kind == 11 { fa64Used = true }
  if kind == 10 { ia64Used = true }
  if kind == 13 { fa32Used = true }
  // A string-valued map: force the string-LIST value flag so a bound `m.values()` (a
  // `string[]`) supports `.length` / indexing (which gate on `slUsed`).
  if kind == 3 {
    slUsed = true
    aUsed = true
  }
  mvMapTypeIdx.push(0)
  mvValName.length - 1
}

// FIND-ONLY mv-slot lookup by value type-name: `-1` for the mono i32 map
// (i32/boolean values), the interned slot otherwise. NEVER interns — all mv
// interning happens in `collectA`'s arena scan (a slot interned after
// `mAssignTypeIndices` would mint no type index) — so a miss is a compiler bug
// and fails loudly.
function mvSlotOfValNameFind(valName: string) {
  if valName == "i32" || valName == "boolean" { return -1 }
  let i = 0
  while i < mvValName.length {
    if mvValName[i] == valName { return i }
    i = i + 1
  }
  emitFail("emitProgram: map value type has no interned slot")
  -1
}

function mvValsWrapOf(slot: i32) {
  if slot < 0 { return lTypeIdx }
  if mvValKind[slot] == 3 { return mkListIdx }
  if mvValKind[slot] == 11 {
    return fl64TypeIdx // f64-valued map: f64-list wrapper
  }
  if mvValKind[slot] == 13 {
    return fl32TypeIdx // f32-valued map: f32-list wrapper
  }
  if mvValKind[slot] == 10 {
    return il64TypeIdx // i64-valued map: i64-list wrapper
  }
  rlWrapIdx[mvRlSlot[slot]]
}

// The SCALAR element kind (11 f64 / 10 i64 — the `emitScalarValue`/`scalarListBlocktype`
// codes) of an mv map-value slot whose value is a non-i32 scalar, else -1 (a ref value —
// string/struct — which rides the nullable valStash + `ref.as_non_null`). The chokepoint
// the map get/set/push consult to branch scalar-store vs ref-store.
function mvScalarValKind(slot: i32) {
  if slot < 0 { return -1 }
  if mvValKind[slot] == 11 { return 11 }
  if mvValKind[slot] == 10 { return 10 }
  if mvValKind[slot] == 13 { return 13 }
  -1
}

// A kind-6 (ref-VALUE) map slot's values are either inner MAP structs (ref-list element
// kind 3) or i32-LIST wrappers (element kind 4). These split the two so a read classifies
// as the right thing — `m[k]` over a nested map is a Map, over a list-valued map an i32 list.
function mvValIsMap(slot: i32) {
  if slot < 0 { return false }
  if mvValKind[slot] != 6 { return false }
  rlElemKindTbl[mvRlSlot[slot]] == 3
}
function mvValIsList(slot: i32) {
  if slot < 0 { return false }
  if mvValKind[slot] != 6 { return false }
  const ek = rlElemKindTbl[mvRlSlot[slot]]
  ek == 4 || ek == 6 || ek == 7 || ek == 8 || ek == 10
}

// The list-element rep of a list-VALUED map slot — `2` i32-list (ref-list elem 4), `7`
// string-list (elem 6), `12` f64-list (elem 7), `20` i64-list (elem 8) — or -1 if the slot's
// value is not a list. Maps the ref-list element kind to the value list's classifier rep.
function mvListValKind(slot: i32) {
  if slot < 0 { return -1 }
  if mvValKind[slot] != 6 { return -1 }
  const ek = rlElemKindTbl[mvRlSlot[slot]]
  if ek == 4 { return 2 }
  if ek == 6 { return 7 }
  if ek == 7 { return 12 }
  if ek == 8 { return 20 }
  if ek == 10 {
    return 21 // f32-inner list → an f32-list value (kind 21)
  }
  if ek == 9 {
    return 5 // struct-list value → a ref list
  }
  -1
}

// The mv slot of a `m[k]` / `m[k] ?? d` read over a struct-LIST-valued map (the value is a
// struct list, element kind 9), else -1. The hook `refListElemNameOfExpr` uses to name the
// read's element (the inner struct), so `(m[k] ?? []).length` / `[i].field` resolve.
function mapReadStructListMvSlot(exprIx: i32, fnIx: i32) {
  const cm = coalesceMvSlot(exprIx, fnIx)
  if cm >= 0 {
    if mvListValKind(cm) == 5 { return cm }
  }
  const mr = mapReadMvSlot(exprIx, fnIx)
  if mr >= 0 {
    if mvListValKind(mr) == 5 { return mr }
  }
  -1
}

// ── scalar-list descriptor (the i32 / f64 / i64 list unification) ──────────────
// A SCALAR-element list (`i32[]` / `boolean[]` / `f64[]` / `i64[]`) is one shape
// parameterized by its element's valtype: a growable `{ backing, len, cap }` wrapper over
// a raw `(array (mut <elem>))`. The list ops (`.get`/`.pop`/`.slice`/index/`.map`) used to
// branch `if exprF64Array { fl64/fa64 } else { l/a }` — a binary fork with no room for a
// third element type. These descriptors map a CANONICAL element kind (the `fbValtype`
// codes: 0 i32/boolean · 11 f64 · 10 i64) to its list types + read shape, so a list op is
// written ONCE over the kind and a new scalar type is a descriptor arm, not a new branch
// in every function.

// The canonical scalar element kind of a list-valued expression — 0 (i32/boolean), 11
// (f64), 10 (i64) — or -1 (a ref / string / map list, or not a list). The single dispatch
// the scalar list ops consult instead of each re-deriving `exprF64Array`.
function scalarListElemKind(exprIx: i32, fnIx: i32) {
  if exprF32Array(exprIx, fnIx) { return 13 }
  if exprF64Array(exprIx, fnIx) { return 11 }
  if exprI64Array(exprIx, fnIx) { return 10 }
  if exprArray(exprIx, fnIx) { return 0 }
  -1
}

// The WRAPPER struct heap type for a scalar element kind.
function scalarListWrap(elemKind: i32) {
  if elemKind == 11 { return fl64TypeIdx }
  if elemKind == 10 { return il64TypeIdx }
  if elemKind == 13 { return fl32TypeIdx }
  lTypeIdx
}

// The BACKING `(array (mut <elem>))` heap type for a scalar element kind.
function scalarListBack(elemKind: i32) {
  if elemKind == 11 { return fa64TypeIdx }
  if elemKind == 10 { return ia64TypeIdx }
  if elemKind == 13 { return fa32TypeIdx }
  aTypeIdx
}

// The `array.get` RESULT blocktype byte for a scalar element kind (i32 `0x7f`, f64 `0x7c`,
// i64 `0x7e`) — the value-typed-`if` rep a fused `?? d` read joins on.
function scalarListBlocktype(elemKind: i32) {
  if elemKind == 11 { return 124 }
  if elemKind == 10 { return 126 }
  if elemKind == 13 { return 125 }
  127
}

// Whether the module-global list types for a scalar element kind were collected (the
// loud-fail guard every list op shares).
function scalarListUsed(elemKind: i32) {
  if elemKind == 11 { return fa64Used }
  if elemKind == 10 { return ia64Used }
  if elemKind == 13 { return fa32Used }
  lUsed
}

// Emit `exprIx` COERCED to a scalar element kind's value rep — the f64/i64 widen of a
// narrower literal/`i32` so a list element / `?? d` default matches the backing element
// type. The i32 kind passes through unchanged (byte-identical to a bare `emitExpr`).
function emitScalarValue(body: i32[], exprIx: i32, fnIx: i32, elemKind: i32) {
  if elemKind == 11 { return emitExprAsF64(body, exprIx, fnIx) }
  if elemKind == 10 { return emitExprAsI64(body, exprIx, fnIx) }
  if elemKind == 13 { return emitExprAsF32(body, exprIx, fnIx) }
  emitExpr(body, exprIx, fnIx)
}

// ── active `is`-narrowing scope ───────────────────────────────────────────────
// When emitting the THEN-branch of `if n is A { … }`, the union-typed identifier
// `n` is narrowed to variant `A`, so a field read `n.f` in that branch lowers to
// the downcast. The active narrowings are a STACK (parallel `narrowNames` /
// `narrowVariants`): nested guards over DISTINCT union locals (`if ta is TyPrim { if
// tb is TyPrim { … ta.primName … tb.primName … } }`, the `sameNumeric` shape) each
// push a binding, so BOTH `ta` and `tb` stay narrowed in the inner branch — a single
// slot would lose the outer one. A branch saves the stack LENGTH and truncates back
// on exit, so nesting + the else-branch see the right scope. `narrowVariantFor`
// resolves a receiver name to its INNERMOST active variant (shadowing-correct).
// `narrowTop` is the logical stack DEPTH: only `narrowNames[0 .. narrowTop-1]` are
// active. Entries are appended on push; on branch exit the depth is rewound (the arrays
// keep their slots — no `.pop()`, so no global-list-pop self-host dependency). A push
// past the current length appends; a push within reuses/overwrites the slot.
// (`narrowNames`/`narrowVariants`/`narrowTop` and the `nli*` tables are declared
// early, before `computeRetInference` — module-level `let`s must textually
// precede the function bodies/call sites that read them.)

// The variant a union local `name` is narrowed to in the current scope (the innermost
// active binding within `narrowTop`), or "" if `name` is not currently narrowed.
function narrowVariantFor(name: string) {
  let i = narrowTop - 1
  while i >= 0 {
    if narrowNames[i] == name { return narrowVariants[i] }
    i = i - 1
  }
  ""
}

// Push an active narrowing `name → variant`, growing the stack arrays if needed. Returns
// the new depth.
function pushNarrow(name: string, variant: string) {
  if narrowTop < narrowNames.length {
    narrowNames[narrowTop] = name
    narrowVariants[narrowTop] = variant
  } else {
    narrowNames.push(name)
    narrowVariants.push(variant)
  }
  narrowTop = narrowTop + 1
  narrowTop
}

// Append the declared-local name `name` to `localNames` as a FRESH slot (one wasm
// local PER lexical binding — no dedupe by name, so two same-named `let`s in disjoint
// branches get DISTINCT slots, hence distinct valtypes). `structIdx` is the local's
// struct table index when it is a struct ref (`isRef == 1`), else `-1`. Returns the new
// slot's POSITION in `localNames` (its wasm index is `paramCount + position`).
function addLocalName(name: string, isRef: i32, structIdx: i32) {
  let pos = localNames.length
  localNames.push(name)
  localIsRef.push(isRef)
  localStructIdx.push(structIdx)
  localLoopVar.push(0)
  localLitUnion.push(0)
  pos
}

// Mark the declared-local slot as a LOOP VARIABLE (a `for` counter / for-in
// element). A loop var's scope is the LOOP: while it is live the scope stack
// resolves it; once its loop closes (`scopeUnbind`) it must NOT be resolvable
// again — but the flat `localNames` fallback scan would still find it (it
// serves the scope-less DETECTION passes, which must keep seeing loop vars for
// in-body classification). RESOLUTION (`declaredIndexOf`) therefore skips
// flagged slots in its fallback, so a post-loop reference falls through to an
// outer/global binding exactly as the host's loop-scoped declaration does.
function markLoopVarSlot(slot: i32) {
  localLoopVar[slot] = 1
  0
}

// Recursively collect the declared-local names of the block at `blockIx` into
// `localNames`, descending into `if` then/else branches (wasm locals span the whole
// function, so a local declared inside a branch still needs a slot). Each declared
// local's init type is validated as i32-compatible here, so a non-i32 local fails
// loudly BEFORE any bytes are emitted. Returns 0, or -1 (via `emitFail`) on a
// non-block node, an out-of-scope statement (e.g. a loop), or a non-i32 local.
function collectLocals(blockIx: i32, fnIx: i32) {
  let b = P.nodes[blockIx]
  if b is Block {
    // Enter this block's lexical scope: bindings appended below are live (and resolve
    // a same-named init expr to the RIGHT slot) only within it, and are dropped on exit.
    scopePush()
    const stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      let s = P.nodes[stmts[i]]
      if s is LetDecl {
        // TYPED-IR: an un-annotated empty `[]` whose element a downstream `.push` pinned —
        // synthesize the equivalent `<elem>[]` annotation from the checker's recorded type,
        // so the slot classifier below AND the later `[]`-seeding (`letAnnRefListKind`) and
        // every other annotation-reading path agree for ALL element types. This extends the
        // i32/string-only inferred build to f64/struct without per-rep usage predicates.
        // Emit-time (post-check), so `fmt` is untouched; the generic case is excluded by
        // `nodeArrayElemName` returning "" for a `TyVar` element.
        if s.letType < 0 {
          const synInit = unwrapParen(s.letInit)
          const synN = P.nodes[synInit]
          if synN is ArrayLit {
            if synN.arrElems.length == 0 {
              const synElem = nodeArrayElemName(synInit)
              if synElem != "" {
                // A STRUCT element renders as a structural shape (`{v: i32}`), but the
                // ref-list machinery (`nameIsRefArray`/`rlSlotByName`) keys on the DECLARED
                // struct name — so resolve the shape to its interned struct's name. A scalar
                // element (`f64`) is not a struct, so it passes through unchanged.
                let synName = synElem
                const synSi = structIndexOfTypeName(synElem)
                if synSi >= 0 {
                  if sNames[synSi] != "" { synName = sNames[synSi] }
                }
                s.letType = mkTypeRef(synName + "[]", -1)
              }
            }
          }
        }
        // Classify the init type BEFORE binding the name, then allocate a fresh slot and
        // bind `name → slot` so a LATER reference (or a shadowing inner `let`) resolves to
        // THIS slot. `slot` is the new slot's declared-local position.
        let slot = -1
        if letIsLitUnion(stmts[i]) {
          // A literal-union local (`: K`) is an i32-backed interned ATOM, NOT a value-union box. FIRST —
          // its members are registered as value-union variants, so it must be intercepted before
          // `letIsVariant` / `letIsUnion` claim it.
          slot = addLocalName(s.letName, 0, -1)
          localLitUnion[slot] = 1
        } else if letIsMap(stmts[i], fnIx) {
          // The kind-6 parallel slot carries the map SHAPE: `-2` for a `Set()`
          // binding (its `.values()` walks the keys), an mv slot (>= 0) for a
          // ref-valued map, `-1` for the mono i32 map.
          slot = addLocalName(s.letName, 6, letMapShapeOf(stmts[i], fnIx))
        } else if letBareUnwiredNulMapRead(stmts[i], fnIx) {
          // `const v = m[k]` over a UNION- or ref-LIST-valued map is `V | null` with no nullable
          // local rep — reject cleanly (bind `m[k] ?? <default>`) rather than emit invalid wasm.
          // Struct / string / closure value reads fall through to their nullable kinds below.
          return emitFail(
            "emitProgram: a bare `m[k]` read of a union- or list-valued map is `V | null`; " +
              "use `m[k] ?? <default>`",
          )
        } else if letIsNulRef(stmts[i], fnIx) {
          // Nullable struct (`S | null`, code 9): annotation-first, else the
          // initializer's nullable-returning call. BEFORE the struct case (a
          // nullable init must not collapse to the non-null kind 1).
          slot = addLocalName(s.letName, 9, nulRefStructIdxOfLet(stmts[i], fnIx))
        } else if letIsNulListInfer(stmts[i], fnIx) {
          // Nullable i32 list (`i32[] | null`, kind 15): BEFORE the array case —
          // `letIsArray`'s init fallback would otherwise claim the binding as a
          // non-null kind 2, and a later `xs = null` write would be invalid.
          slot = addLocalName(s.letName, 15, -1)
          // The scalar-list checks gate on `!letIsUnion`: a `f64[] | string` (etc.) binding
          // whose INIT is a bare list literal would otherwise let `letIsF64Array`'s init
          // fallback claim it as an f64 list instead of the value-union box (kind 4). A plain
          // `f64[]` binding is not a union name, so the guard never blocks it.
        } else if (
          letIsStringArray(stmts[i], fnIx) &&
          !letIsUnion(stmts[i], fnIx)
        ) {
          slot = addLocalName(s.letName, 7, -1)
        } else if letIsF32Array(stmts[i], fnIx) && !letIsUnion(stmts[i], fnIx) {
          // Scalar-f32-element list local (`let xs: f32[] = …`), kind 21 — `(ref $fl32TypeIdx)`.
          // BEFORE the f64 case: an `f32[]` annotation over a float-literal init would else be
          // claimed by `letIsF64Array`'s init fallback (a `[1.5]` is `exprF64Array`).
          slot = addLocalName(s.letName, 21, -1)
        } else if letIsF64Array(stmts[i], fnIx) && !letIsUnion(stmts[i], fnIx) {
          // Scalar-f64-element list local (`let xs: f64[] = …` / a float-literal array
          // init), kind 12 — its cell is `(ref $fl64TypeIdx)`. (Slice 4.)
          slot = addLocalName(s.letName, 12, -1)
        } else if letIsI64Array(stmts[i], fnIx) && !letIsUnion(stmts[i], fnIx) {
          // Scalar-i64-element list local (`let xs: i64[] = …`), kind 20 — `(ref $il64TypeIdx)`.
          slot = addLocalName(s.letName, 20, -1)
        } else if letIsNulRefArray(stmts[i], fnIx) {
          // A NULLABLE ref-array local (`i32[][] | null`, kind 18) — BEFORE the non-null ref-array case
          // (its init `v[i]` over a `(<ref-array>|null)[]` would otherwise be claimed as a non-null kind
          // 5). Stores the INNER ref-list slot in `localStructIdx`, like kind 5 (the analogue of kind 15).
          slot = addLocalName(s.letName, 18, nulRefArrayInnerSlotOfLet(stmts[i], fnIx))
        } else if letIsRefArray(stmts[i], fnIx) {
          slot = addLocalName(s.letName, 5, letRefListSlot(stmts[i], fnIx))
        } else if (
          letIsNulClosure(stmts[i], fnIx) ||
          letInfersNulClosure(stmts[i], fnIx)
        ) {
          // A NULLABLE function-VALUE local (`let c: ((i32) => i32) | null`, kind 19), OR an
          // un-annotated `const f = m[k]` over a function-valued map (a bare map read is
          // nullable — `letInfersNulClosure`). Its cell is the NULLABLE closure fat-pointer
          // `(ref null $cloStructIdx)`, holding a function OR `null`. BEFORE `letIsUnion` (the
          // `fn | null` annotation reads as a union name) and the non-null closure (kind 14).
          slot = addLocalName(s.letName, 19, -1)
        } else if letIsVariant(stmts[i], fnIx) {
          // A CONCRETE union-variant local (`const c: Cat = …`), kind 8 — its cell is the
          // variant struct ref `(ref $(uVarIdx + vi))`. BEFORE `letIsUnion`/`letIsStruct`:
          // a variant name is neither the union box nor a standalone struct.
          slot = addLocalName(s.letName, 8, variantIndexOfLet(stmts[i], fnIx))
        } else if letIsUnion(stmts[i], fnIx) {
          slot = addLocalName(s.letName, 4, -1)
        } else if letIsStruct(stmts[i], fnIx) {
          // `letIsStruct` also matches via the INIT object literal's field-name set — so an UN-INTERNABLE
          // inline-shape ANNOTATION (an unsupported field type, e.g. `{f: {g:i32}[] | null}` /
          // `{f: (i32|null)[][]}`) still lands here, but `structIndexOfLet` then resolves to a WRONG struct
          // (a same-field-named one) and emits its layout → invalid wasm. Reject cleanly when the
          // annotation shape itself could not be interned (the construct-side hole the read fuzzer masked).
          if letAnnIsUninternedShape(stmts[i]) {
            return emitFail(
              "emitProgram: binding's inline-shape type has an unsupported field",
            )
          }
          slot = addLocalName(s.letName, 1, structIndexOfLet(stmts[i], fnIx))
        } else if letIsArray(stmts[i], fnIx) {
          slot = addLocalName(s.letName, 2, -1)
        } else if letIsNulString(stmts[i], fnIx) {
          // Nullable string (`string | null`, kind 16): BEFORE the string case so a
          // nullable annotation/init doesn't collapse to the non-null kind 3 (a later
          // `x = null` write would then be invalid).
          slot = addLocalName(s.letName, 16, -1)
        } else if letIsString(stmts[i], fnIx) {
          slot = addLocalName(s.letName, 3, -1)
        } else if letIsI64(stmts[i], fnIx) {
          // Scalar i64 local (`let x: i64 = …`, kind 10, valtype 0x7e). Bypasses
          // `checkLocalI32` (which rejects a non-i32 annotation); the init literal
          // lowers as `i64.const` in `emitStmt`'s LetDecl path.
          slot = addLocalName(s.letName, 10, -1)
        } else if letIsF32(stmts[i]) || letInfersF32(stmts[i], fnIx) {
          // Scalar f32 local (`let x: f32 = …`, kind 13, valtype 0x7d), OR an un-annotated
          // `let y = <f32 expr>` (`letInfersF32`: an f32 field/index/call/arith source — the
          // f32 dual of the init fallback `letIsF64`/`letIsI64` carry). An annotated float
          // literal lowers as `f32.const`; an inferred f32 init is already an f32 VALUE, so
          // the LetDecl emit's `else` arm pushes it as-is into this kind-13 slot. A BARE
          // un-annotated float literal stays f64 (`letIsF64` below). (Slice 5.)
          slot = addLocalName(s.letName, 13, -1)
        } else if letIsF64(stmts[i], fnIx) {
          // Scalar f64 local (`let x: f64 = …` OR an un-annotated `.` literal init,
          // kind 11, valtype 0x7c). Bypasses `checkLocalI32`; the init literal lowers
          // as `f64.const` in `emitStmt`'s LetDecl path. (Slice 3.)
          slot = addLocalName(s.letName, 11, -1)
        } else if letIsClosure(stmts[i], fnIx) {
          // A function-VALUE local (`const f = function(...)...` or `const g = namedFn`),
          // kind 14 — its cell is the closure fat-pointer struct `(ref $cloStructIdx)`.
          slot = addLocalName(s.letName, 14, -1)
        } else if letNulBool(stmts[i], fnIx) {
          // `boolean | null` NICHE local (kind 17): the cell is a plain i32 holding 0/1,
          // with the spare value 2 encoding `null` (no box) — so `fbValtype` renders it
          // i32 (the default), same as a plain boolean. A DEDICATED kind so the annotation
          // / inferred-if init isn't rejected by `checkLocalI32` and the if-binding emit
          // routes it to the sentinel-2 rep (rep 2); a later `x = null` stays valid (the
          // write consults `exprNulBool`, an AST walk, not the slot kind).
          slot = addLocalName(s.letName, 17, -1)
        } else {
          if checkLocalI32(stmts[i]) < 0 {
            scopePop()
            return -1
          }
          slot = addLocalName(s.letName, 0, -1)
        }
        scopeBind(s.letName, slot)
      } else if s is IfStmt {
        if collectLocalsIf(stmts[i], fnIx) < 0 {
          scopePop()
          return -1
        }
      } else if s is WhileStmt {
        // Wasm locals are function-scoped, so collect locals from the while body too.
        if collectLocals(s.whileBody, fnIx) < 0 {
          scopePop()
          return -1
        }
      } else if s is ForRange {
        // A range `for` introduces TWO i32 slots in pre-order: the loop variable and
        // a synthetic bound temp (the `to` expression is evaluated ONCE). The temp's
        // name carries a `#` so it can never collide with a user identifier.
        const fvSlot = addLocalName(s.frVar, 0, -1)
        markLoopVarSlot(fvSlot)
        scopeBind(s.frVar, fvSlot)
        addLocalName(s.frVar + "#b", 0, -1)
        if collectLocals(s.frBody, fnIx) < 0 {
          scopePop()
          return -1
        }
        // The loop variable's scope is the loop (see `scopeUnbind`).
        scopeUnbind()
      } else if s is ForIn {
        // A `for v in <list>` introduces THREE slots in pre-order: the element var
        // (i32, or a string ref for a string-list / `.keys()` iterable), a hidden
        // i32 cursor, and a hidden list temp holding the iterable (evaluated ONCE).
        // The hidden names carry `#` so they can never collide with user identifiers.
        const fiEk = forInElemKind(s.fiIter, fnIx)
        if fiEk < 0 {
          scopePop()
          return emitFail("emitProgram: unsupported for-in iterable")
        }
        // A struct element (`S[]`, code 1) binds the loop var as a struct local
        // carrying the element struct table index; the `#l` temp holds the ref-list
        // WRAPPER (code 5 + the ref-list slot). i32/string elements keep their slots.
        let fiVarIdx = -1
        let fiLk = 2
        if fiEk == 1 {
          fiVarIdx = forInRefArrayStructIdx(s.fiIter, fnIx)
          fiLk = 5
        } else if fiEk == 9 {
          // A NULLABLE-struct element (`(P | null)[]`): the loop var is a kind-9 niche carrying
          // the element struct index; the `#l` temp is the ref-list WRAPPER (code 5).
          fiVarIdx = forInRefArrayStructIdx(s.fiIter, fnIx)
          fiLk = 5
        } else if fiEk == 4 {
          // A union-box element list: the loop var is a kind-4 union box (no struct index);
          // the `#l` temp is the ref-list WRAPPER (code 5), like the struct case.
          fiLk = 5
        } else if (
          fiEk == 2 ||
          fiEk == 7 ||
          fiEk == 12 ||
          fiEk == 20 ||
          fiEk == 21
        ) {
          // A NESTED-ARRAY loop var — the inner LIST (kind 2/7/12/20). The `#l` temp is the
          // OUTER ref-list WRAPPER (code 5); each element is the inner list wrapper ref.
          fiLk = 5
        } else if fiEk == 14 {
          // A CLOSURE element (`((i32) => i32)[]`): the loop var is a kind-14 closure (no struct
          // index); the `#l` temp is the ref-list WRAPPER (code 5), like the struct case.
          fiLk = 5
        } else if fiEk == 5 {
          // A NESTED REF array (`S[][]`): the loop var is the inner REF LIST (kind 5) carrying its
          // ref-list slot; the `#l` temp is the OUTER ref-list wrapper (code 5).
          const fiOuter = refListSlotOfExpr(s.fiIter, fnIx)
          fiVarIdx = rlSlotByName(refArrElemName(rlElemName[fiOuter]))
          fiLk = 5
        } else if fiEk == 3 {
          fiLk = 7
        } else if fiEk == 11 {
          fiLk = 12 // f64 element → f64-list `#l` temp
        } else if fiEk == 10 {
          fiLk = 20 // i64 element → i64-list `#l` temp
        } else if fiEk == 13 {
          fiLk = 21 // f32 element → f32-list `#l` temp
        }
        // A STRING iterable (`for ch in s`): the `#l` temp holds the string itself (code 3, the
        // raw `(ref $aTypeIdx)` array), not an i32-list wrapper. The loop var stays code 0 (i32).
        if fiEk == 0 && forInStringSrc(s.fiIter, fnIx) { fiLk = 3 }
        const fiSlot = addLocalName(s.fiVar, fiEk, fiVarIdx)
        markLoopVarSlot(fiSlot)
        scopeBind(s.fiVar, fiSlot)
        addLocalName(s.fiVar + "#i", 0, -1)
        let fiLs = -1
        if (
          fiEk == 1 ||
          fiEk == 4 ||
          fiEk == 9 ||
          fiEk == 2 ||
          fiEk == 7 ||
          fiEk == 12 ||
          fiEk == 20 ||
          fiEk == 21 ||
          fiEk == 14 ||
          fiEk == 5
        ) {
          const fiMvs = forInMapValsSlot(s.fiIter, fnIx)
          if fiMvs >= 0 {
            fiLs = mvRlSlot[fiMvs]
          } else {
            fiLs = refListSlotOfExpr(s.fiIter, fnIx)
          }
        }
        addLocalName(s.fiVar + "#l", fiLk, fiLs)
        if collectLocals(s.fiBody, fnIx) < 0 {
          scopePop()
          return -1
        }
        // The loop variable's scope is the loop (see `scopeUnbind`).
        scopeUnbind()
      }
      i = i + 1
    }
    scopePop()
    return 0
  }
  emitFail("emitProgram: function has no block body")
}

// Collect the declared locals of the `IfStmt` at `ifIx`: its then-branch block, plus
// its else, which is either a `Block` (a plain `else { … }`) or another `IfStmt`
// (an `else if …`). The `else if` case recurses through THIS function, so an
// arbitrarily long `if / else if / else if / … / else` chain has EVERY arm walked —
// not just the first nested level. (Mirrors how `emitStmt` re-enters each arm via
// `emitStmts`/`emitStmt`, so the slots `collectLocals` allocates match the `let`s
// `emitStmt` stores into, at any nesting depth.) Returns 0, or -1 (via `emitFail`).
function collectLocalsIf(ifIx: i32, fnIx: i32) {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    // Narrow `n` to its variant across the THEN-branch (mirroring `emitStmt`), so a
    // `let x = n.arrField` over a narrowed union-variant ARRAY field is classified as
    // an array local here — `exprArray`/`memFieldTypeCode` resolve the variant field
    // type only while narrowing is active. Save/restore so the else-branch + nesting
    // are unaffected.
    const savedTop = narrowTop
    const narrowed = setNarrowFromCond(s.ifCond, fnIx)
    const trc = collectLocals(s.ifThen, fnIx)
    if narrowed { restoreNarrow(savedTop) }
    if trc < 0 { return -1 }
    if s.ifElse >= 0 {
      const els = P.nodes[s.ifElse]
      if els is Block {
        if collectLocals(s.ifElse, fnIx) < 0 { return -1 }
      } else if els is IfStmt {
        // `else if …` — walk the nested if (and its own else chain) recursively.
        if collectLocalsIf(s.ifElse, fnIx) < 0 { return -1 }
      }
    }
    return 0
  }
  emitFail("emitProgram: collectLocalsIf: not an if statement")
}

// Validate the `LetDecl` at `letIx`: its initializer must exist and be an i32 value
// (this slice has i32 locals only). A missing init, or an init whose type annotation
// names a non-i32 type, fails loudly. Without a per-expr type checker the init's
// VALUE-type is approximated: a `let x: T = …` annotation must be `i32` if present;
// init expressions outside the i32 vocabulary (string/char/bool/float literals)
// fail loudly. Returns 0, or -1 (via `emitFail`).
function checkLocalI32(letIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letInit < 0 {
      // An UNINITIALIZED `let x: T` (A-definite-assign) is legal for a SCALAR
      // (i32/boolean) annotation: the checker guarantees write-before-read, and the
      // wasm local's implicit zero-init covers the declaration. A ref-typed or
      // un-annotated uninitialized local still fails (non-null refs have no default).
      if d.letType >= 0 {
        const ty = P.nodes[d.letType]
        if ty is TypeRef {
          if ty.tyName == "i32" || ty.tyName == "boolean" { return 0 }
        }
      }
      return emitFail("emitProgram: local declaration needs an initializer")
    }
    if d.letType >= 0 {
      const ty = P.nodes[d.letType]
      if ty is TypeRef {
        // `boolean` rides in an i32 (0/1), so a `boolean` local is the SAME i32 slot.
        if ty.tyName != "i32" {
          if ty.tyName != "boolean" {
            if !nameIsLitUnionType(ty.tyName) {
              return emitFail("emitProgram: only i32 locals are supported")
            }
          }
        }
      } else {
        return emitFail("emitProgram: local type is not a type name")
      }
    }
    return checkExprI32(d.letInit)
  }
  emitFail("emitProgram: not a local declaration")
}

// Reject init expressions that cannot yield an i32: a string literal, or a float
// `NumLit` whose lexeme has a `.`, fails loudly. `BoolLit` (true=1 / false=0) and
// `CharLit` (a code point) ARE i32 values — they ride in an i32 — so they pass. i32
// literals, identifiers, parens, unary/binary arithmetic and calls are all i32 in
// this slice, so they pass too (the per-node emitters re-check operand shapes).
// Returns 0, or -1.
function checkExprI32(exprIx: i32) {
  if exprIx < 0 {
    return emitFail("emitProgram: missing local initializer expression")
  }
  const e = P.nodes[exprIx]
  if e is StrLit {
    return emitFail("emitProgram: only i32 locals are supported")
  }
  if e is NumLit {
    // A float literal carries a "." in its lexeme — out of scope (i32 only).
    let i = 0
    while i < e.numText.length {
      if e.numText[i] == '.' {
        return emitFail("emitProgram: only i32 locals are supported")
      }
      i = i + 1
    }
    return 0
  }
  0
}

// Rebuild `localNames` for the function at `fnIx`: clear it, then collect every
// declared-local name in the body (validating each as i32). Returns 0 on success,
// or -1 (via `emitFail`) on any unsupported local. Must run before lowering the
// body so identifier resolution and the locals vector see the full set.
function buildLocals(fnIx: i32) {
  localNames = []
  localIsRef = []
  localStructIdx = []
  localLoopVar = []
  localLitUnion = []
  localLitUnion = []
  // Reset the lexical scope stack per function. `collectLocals` pushes/pops frames as
  // it walks (leaving it balanced/empty), then the emit pass rebuilds it in lockstep.
  scopeNames = []
  scopeSlots = []
  scopeFrames = []
  const fn = P.nodes[fnIx]
  if fn is FuncDecl { return collectLocals(fn.fnBody, fnIx) }
  emitFail("emitProgram: not a function declaration")
}

// True if the statement at `stmtIx` is a `recv.push(x)` member-call (the `Call` whose
// `callFn` is a `Member` with property `push`) whose RECEIVER's list kind matches
// `kind` — `0` selects an i32-list push, `1` a ref-list push (G7-ref), `2` a string-list
// push (`string[]`). Used to detect which inline-push scratch locals a function needs;
// the three kinds get DISTINCT scratch frames so a function may push onto any mix.
function stmtIsPushKind(stmtIx: i32, fnIx: i32, kind: i32) {
  let s = P.nodes[stmtIx]
  if s is Call {
    const callee = P.nodes[s.callFn]
    if callee is Member {
      if callee.memProp == "push" {
        const isRef = exprRefArray(callee.memObj, fnIx)
        const isStr = exprStringArray(callee.memObj, fnIx)
        const isF64 = exprF64Array(callee.memObj, fnIx)
        const isI64 = exprI64Array(callee.memObj, fnIx)
        const isF32 = exprF32Array(callee.memObj, fnIx)
        if kind == 1 { return isRef }
        if kind == 2 { return isStr }
        if kind == 3 { return isF64 }
        if kind == 4 { return isI64 }
        if kind == 5 { return isF32 }
        return !isRef && !isStr && !isF64 && !isI64 && !isF32
      }
    }
  }
  false
}

// True if `callIx` is a `recv.pop()` whose receiver is a struct-FIELD / global-field
// array read (a `Member`, e.g. `T.scopes.pop()`) of list kind `kind` (`0` i32-list, `1`
// ref-list, `2` string-list). A bare-LOCAL pop needs NO scratch (it references the local
// in place), so it is NOT counted — only a Member receiver, which must be materialized
// into the push frame's `recvRef` scratch slot. Lets a `.pop`-on-field function reserve
// the same scratch frame a `.push`-on-field one does.
function callIsMemberPopKind(callIx: i32, fnIx: i32, kind: i32) {
  let c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      // `.clear()` resolves its receiver the same way `.pop()` does (a Member /
      // global receiver stages the wrapper ref in `recvRef`), so it counts too.
      if callee.memProp == "pop" || callee.memProp == "clear" {
        const recv = P.nodes[callee.memObj]
        // A struct-FIELD / global-field Member receiver, OR a bare module-GLOBAL list
        // ident — both materialize the wrapper ref into the `recvRef` scratch slot, so
        // both need the push frame reserved. A bare LOCAL pop references the local in
        // place and needs no scratch, so it is NOT counted.
        let needsScratch = false
        if recv is Member {
          needsScratch = true
        } else if recv is Ident {
          if localIndexOf(fnIx, recv.identName) < 0 {
            if globalIndexOf(recv.identName) >= 0 { needsScratch = true }
          }
        }
        if needsScratch {
          const isRef = exprRefArray(callee.memObj, fnIx)
          const isStr = exprStringArray(callee.memObj, fnIx)
          const isF64 = exprF64Array(callee.memObj, fnIx)
          const isI64 = exprI64Array(callee.memObj, fnIx)
          const isF32 = exprF32Array(callee.memObj, fnIx)
          if kind == 1 { return isRef }
          if kind == 2 { return isStr }
          if kind == 3 { return isF64 }
          if kind == 4 { return isI64 }
          if kind == 5 { return isF32 }
          return !isRef && !isStr && !isF64 && !isI64 && !isF32
        }
      }
    }
  }
  false
}

// True if any expression at `exprIx` (or a sub-expression) is a Member-receiver `.pop`
// of `kind` — a `.pop` appears in VALUE position (`let x = T.scopes.pop()`), so the
// reservation walk must descend expressions, not just statement receivers.
function exprHasMemberPopKind(exprIx: i32, fnIx: i32, kind: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Call {
    if callIsMemberPopKind(exprIx, fnIx, kind) { return true }
    const args = e.callArgs
    let i = 0
    while i < args.length {
      if exprHasMemberPopKind(args[i], fnIx, kind) { return true }
      i = i + 1
    }
    return false
  }
  if e is BinExpr {
    if exprHasMemberPopKind(e.binLeft, fnIx, kind) { return true }
    return exprHasMemberPopKind(e.binRight, fnIx, kind)
  }
  if e is Member { return exprHasMemberPopKind(e.memObj, fnIx, kind) }
  if e is Index {
    if exprHasMemberPopKind(e.idxArr, fnIx, kind) { return true }
    return exprHasMemberPopKind(e.idxIndex, fnIx, kind)
  }
  if e is Unary { return exprHasMemberPopKind(e.unArg, fnIx, kind) }
  if e is Paren { return exprHasMemberPopKind(e.parInner, fnIx, kind) }
  false
}

// True if the block at `blockIx` (descending into if/else + while, the scopes
// `collectLocals` walks) contains a Member-receiver `.pop` of `kind` in any statement or
// let-init / return / while-cond expression.
function blockHasMemberPopKind(blockIx: i32, fnIx: i32, kind: i32) {
  let b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      let s = P.nodes[stmts[i]]
      if s is LetDecl {
        if exprHasMemberPopKind(s.letInit, fnIx, kind) { return true }
      } else if s is RetStmt {
        if exprHasMemberPopKind(s.retArg, fnIx, kind) { return true }
      } else if s is BinExpr {
        if exprHasMemberPopKind(stmts[i], fnIx, kind) { return true }
      } else if s is Call {
        if exprHasMemberPopKind(stmts[i], fnIx, kind) { return true }
      } else if s is IfStmt {
        if ifChainHasMemberPopKind(stmts[i], fnIx, kind) { return true }
      } else if s is WhileStmt {
        if exprHasMemberPopKind(s.whileCond, fnIx, kind) { return true }
        if blockHasMemberPopKind(s.whileBody, fnIx, kind) { return true }
      } else if s is ForIn {
        if exprHasMemberPopKind(s.fiIter, fnIx, kind) { return true }
        if blockHasMemberPopKind(s.fiBody, fnIx, kind) { return true }
      } else if s is ForRange {
        if exprHasMemberPopKind(s.frFrom, fnIx, kind) { return true }
        if exprHasMemberPopKind(s.frTo, fnIx, kind) { return true }
        if blockHasMemberPopKind(s.frBody, fnIx, kind) { return true }
      }
      i = i + 1
    }
  }
  false
}

// True if any arm of the `if` / `else if` chain at `ifIx` contains a Member-receiver
// `.pop` of `kind` (then-branch, `else` block, or recursively a chained `else if`).
function ifChainHasMemberPopKind(ifIx: i32, fnIx: i32, kind: i32) {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    if blockHasMemberPopKind(s.ifThen, fnIx, kind) { return true }
    if s.ifElse >= 0 {
      const els = P.nodes[s.ifElse]
      if els is Block {
        if blockHasMemberPopKind(s.ifElse, fnIx, kind) { return true }
      } else if els is IfStmt {
        if ifChainHasMemberPopKind(s.ifElse, fnIx, kind) { return true }
      }
    }
  }
  false
}

// True if the block at `blockIx` (descending into `if` branches and `while` bodies, the
// same scopes `collectLocals` walks) contains a `.push` of kind `wantRef`. A function
// with such a push reserves the matching three scratch locals after its declared locals.
function blockHasPushKind(blockIx: i32, fnIx: i32, kind: i32) {
  let b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      if stmtIsPushKind(stmts[i], fnIx, kind) { return true }
      let s = P.nodes[stmts[i]]
      if s is IfStmt {
        if ifChainHasPushKind(stmts[i], fnIx, kind) { return true }
      } else if s is WhileStmt {
        if blockHasPushKind(s.whileBody, fnIx, kind) { return true }
      } else if s is ForRange {
        if blockHasPushKind(s.frBody, fnIx, kind) { return true }
      } else if s is ForIn {
        if blockHasPushKind(s.fiBody, fnIx, kind) { return true }
      }
      i = i + 1
    }
  }
  false
}

// True if the `if` / `else if` chain at `ifIx` contains a `.push` of `kind` in ANY arm —
// the then-branch, an `else` block, OR (RECURSIVELY) a chained `else if`. Mirrors
// `collectLocalsIf`'s recursion so a push buried under several `else if` arms (the
// `parseProgram` / `parseStmt` recursive-descent dispatch shape) is detected, not just
// the first one level (the prior hand-unrolled form missed 2+-deep chains).
function ifChainHasPushKind(ifIx: i32, fnIx: i32, kind: i32) {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    if blockHasPushKind(s.ifThen, fnIx, kind) { return true }
    if s.ifElse >= 0 {
      const els = P.nodes[s.ifElse]
      if els is Block {
        if blockHasPushKind(s.ifElse, fnIx, kind) { return true }
      } else if els is IfStmt {
        if ifChainHasPushKind(s.ifElse, fnIx, kind) { return true }
      }
    }
  }
  false
}

// Append the ref-list table SLOT of a ref `.push` receiver to `fnRefPushSlots` if not
// already present (so each DISTINCT pushed element type gets its own typed scratch frame).
function recordRefPushSlot(slot: i32) {
  let i = 0
  while i < fnRefPushSlots.length {
    if fnRefPushSlots[i] == slot { return 0 }
    i = i + 1
  }
  fnRefPushSlots.push(slot)
  0
}

// Walk the block at `blockIx` (descending into `if` branches + `while` bodies, the scopes
// `collectLocals` walks) and collect every DISTINCT ref-list `.push` receiver slot into
// `fnRefPushSlots`. Parallel to `blockHasPushKind(..., 1)`, but RECORDING the slot rather
// than just testing presence — so a function pushing onto `Tok[]` and `Diag[]` reserves a
// separately-typed scratch frame for each.
function collectRefPushSlots(blockIx: i32, fnIx: i32) {
  let b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      if stmtIsPushKind(stmts[i], fnIx, 1) {
        let s = P.nodes[stmts[i]]
        if s is Call {
          const callee = P.nodes[s.callFn]
          if callee is Member {
            recordRefPushSlot(refListSlotOfExpr(callee.memObj, fnIx))
          }
        }
      }
      let s = P.nodes[stmts[i]]
      if s is IfStmt { collectRefPushSlotsIf(stmts[i], fnIx) }
      else if s is WhileStmt { collectRefPushSlots(s.whileBody, fnIx) }
      else if s is ForRange { collectRefPushSlots(s.frBody, fnIx) }
      else if s is ForIn { collectRefPushSlots(s.fiBody, fnIx) }
      i = i + 1
    }
  }
  0
}

// Collect ref-push receiver slots from every arm of the `if` / `else if` chain at `ifIx`
// — the then-branch, an `else` block, and (RECURSIVELY) each chained `else if`. Mirrors
// `ifChainHasPushKind`'s recursion so a push under 2+ `else if` arms is recorded.
function collectRefPushSlotsIf(ifIx: i32, fnIx: i32) {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    collectRefPushSlots(s.ifThen, fnIx)
    if s.ifElse >= 0 {
      const els = P.nodes[s.ifElse]
      if els is Block { collectRefPushSlots(s.ifElse, fnIx) }
      else if els is IfStmt { collectRefPushSlotsIf(s.ifElse, fnIx) }
    }
  }
  0
}

// Record the ref-list table slot of every Member-receiver ref-list `.pop` in expression
// `exprIx` into `fnRefPushSlots` (so its typed scratch frame is reserved) — the pop-side
// analogue of `collectRefPushSlots`, descending VALUE positions (a `.pop` is a value).
function collectMemberPopRefSlotsExpr(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return 0 }
  const e = P.nodes[exprIx]
  if e is Call {
    if callIsMemberPopKind(exprIx, fnIx, 1) {
      const callee = P.nodes[e.callFn]
      if callee is Member {
        recordRefPushSlot(refListSlotOfExpr(callee.memObj, fnIx))
      }
    }
    const args = e.callArgs
    let i = 0
    while i < args.length {
      collectMemberPopRefSlotsExpr(args[i], fnIx)
      i = i + 1
    }
    return 0
  }
  if e is BinExpr {
    collectMemberPopRefSlotsExpr(e.binLeft, fnIx)
    collectMemberPopRefSlotsExpr(e.binRight, fnIx)
    return 0
  }
  if e is Member { return collectMemberPopRefSlotsExpr(e.memObj, fnIx) }
  if e is Index {
    collectMemberPopRefSlotsExpr(e.idxArr, fnIx)
    collectMemberPopRefSlotsExpr(e.idxIndex, fnIx)
    return 0
  }
  if e is Unary { return collectMemberPopRefSlotsExpr(e.unArg, fnIx) }
  if e is Paren { return collectMemberPopRefSlotsExpr(e.parInner, fnIx) }
  0
}

// Walk the block at `blockIx` (if/else + while) collecting Member-receiver ref-list
// `.pop` slots from statements + let-inits / returns / while-conds.
function collectMemberPopRefSlots(blockIx: i32, fnIx: i32) {
  let b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      let s = P.nodes[stmts[i]]
      if s is LetDecl {
        collectMemberPopRefSlotsExpr(s.letInit, fnIx)
      } else if s is RetStmt {
        collectMemberPopRefSlotsExpr(s.retArg, fnIx)
      } else if s is BinExpr {
        collectMemberPopRefSlotsExpr(stmts[i], fnIx)
      } else if s is Call {
        collectMemberPopRefSlotsExpr(stmts[i], fnIx)
      } else if s is IfStmt {
        collectMemberPopRefSlotsIf(stmts[i], fnIx)
      } else if s is WhileStmt {
        collectMemberPopRefSlotsExpr(s.whileCond, fnIx)
        collectMemberPopRefSlots(s.whileBody, fnIx)
      } else if s is ForIn {
        collectMemberPopRefSlotsExpr(s.fiIter, fnIx)
        collectMemberPopRefSlots(s.fiBody, fnIx)
      } else if s is ForRange {
        collectMemberPopRefSlotsExpr(s.frFrom, fnIx)
        collectMemberPopRefSlotsExpr(s.frTo, fnIx)
        collectMemberPopRefSlots(s.frBody, fnIx)
      }
      i = i + 1
    }
  }
  0
}

// Collect Member-receiver ref-list `.pop` slots from every arm of the `if` chain.
function collectMemberPopRefSlotsIf(ifIx: i32, fnIx: i32) {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    collectMemberPopRefSlots(s.ifThen, fnIx)
    if s.ifElse >= 0 {
      const els = P.nodes[s.ifElse]
      if els is Block { collectMemberPopRefSlots(s.ifElse, fnIx) }
      else if els is IfStmt { collectMemberPopRefSlotsIf(s.ifElse, fnIx) }
    }
  }
  0
}

// True if the FuncDecl at `fnIx` contains an i32-list `.push` anywhere in its body — OR
// a Member-receiver i32-list `.pop` (which reuses the same scratch frame's `recvRef`).
function fnHasPush(fnIx: i32) {
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    if blockHasPushKind(fn.fnBody, fnIx, 0) { return true }
    return blockHasMemberPopKind(fn.fnBody, fnIx, 0)
  }
  false
}

// True if the FuncDecl at `fnIx` contains a ref-list `.push` anywhere — OR a
// Member-receiver ref-list `.pop` (which reuses the ref-push frame's `recvRef`).
function fnHasRefPush(fnIx: i32) {
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    if blockHasPushKind(fn.fnBody, fnIx, 1) { return true }
    return blockHasMemberPopKind(fn.fnBody, fnIx, 1)
  }
  false
}

// True if the FuncDecl at `fnIx` contains a string-list (`string[]`) `.push` — OR a
// Member-receiver string-list `.pop`.
function fnHasStrPush(fnIx: i32) {
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    if blockHasPushKind(fn.fnBody, fnIx, 2) { return true }
    return blockHasMemberPopKind(fn.fnBody, fnIx, 2)
  }
  false
}

// True if the FuncDecl at `fnIx` contains an f64-list (`f64[]`) `.push` — OR a
// Member-receiver f64-list `.pop` (the f64 push quad's `recvRef`).
function fnHasF64Push(fnIx: i32) {
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    if blockHasPushKind(fn.fnBody, fnIx, 3) { return true }
    return blockHasMemberPopKind(fn.fnBody, fnIx, 3)
  }
  false
}

// True if the FuncDecl at `fnIx` contains an i64-list (`i64[]`) `.push` — or a
// Member-receiver i64-list `.pop` (push kind 4).
function fnHasI64Push(fnIx: i32) {
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    if blockHasPushKind(fn.fnBody, fnIx, 4) { return true }
    return blockHasMemberPopKind(fn.fnBody, fnIx, 4)
  }
  false
}

// True if the FuncDecl at `fnIx` contains an f32-list (`f32[]`) `.push` — or a
// Member-receiver f32-list `.pop` (push kind 5).
function fnHasF32Push(fnIx: i32) {
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    if blockHasPushKind(fn.fnBody, fnIx, 5) { return true }
    return blockHasMemberPopKind(fn.fnBody, fnIx, 5)
  }
  false
}

// ── string-op detection (G6: which functions need the string scratch frame) ───
// A function reserves the shared string scratch frame iff it uses ANY string `+`,
// string `==`/`!=`, or `.slice` anywhere in an expression — so the walk below
// descends through EVERY expression position (return values, let inits, conditions,
// call args, operands, members, indices), unlike the push detection which only
// needs statement-level receivers. `exprIsStrConcat`/`exprIsStrEq`/`exprIsStrSlice`
// each classify a single node; `exprHasStrOp` recurses; `blockHasStrOp` walks
// statements. `exprString` (defined later) resolves operand string-typedness from
// the already-built `localNames`/`localIsRef` (so this runs AFTER `buildLocals`).

// True if `binIx` is a `+` whose operands are strings (string concatenation).
function exprIsStrConcat(binIx: i32, fnIx: i32) {
  const e = P.nodes[binIx]
  if e is BinExpr {
    if e.binOp == "+" {
      // A literal-union atom is a `string` subtype, so `"x" + k` / `k + "y"` (and `k1 + k2`)
      // concatenate — the atom operand widens to its member string in `emitStrConcat`.
      const lStr = exprString(e.binLeft, fnIx) || exprIsLitAtom(e.binLeft, fnIx)
      const rStr = exprString(e.binRight, fnIx) || exprIsLitAtom(e.binRight, fnIx)
      return lStr || rStr
    }
  }
  false
}

// True if the Call at `callIx` passes a literal-union ATOM into a `string` parameter — the
// atom widens to its member string (`emitAtomToStr`), which rides the string-op scratch frame.
// An over-approximation (any atom arg + any `string` param) is fine: it only reserves a frame.
function callWidensAtomToStr(callIx: i32, fnIx: i32) {
  if gLitUnionUsed == 0 { return false }
  const c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Ident {
      const target = fnIndexOf(callee.identName)
      if target >= 0 {
        const cFn = P.nodes[fnStmts[target]]
        if cFn is FuncDecl {
          let anyAtom = false
          let ai = 0
          while ai < c.callArgs.length {
            if exprIsLitAtom(c.callArgs[ai], fnIx) { anyAtom = true }
            ai = ai + 1
          }
          if anyAtom {
            const params = cFn.fnParams
            let pi = 0
            while pi < params.length {
              if vtKindOfParam(params[pi]) == 3 { return true }
              pi = pi + 1
            }
          }
        }
      }
    }
  }
  false
}

// True if the assignment at `binIx` writes a literal-union atom into a `string`-typed target (a
// local, global, or struct field) — the atom widens to its member string, riding the string-op
// scratch frame. `exprString` over the TARGET uniformly covers all three lvalue forms.
function assignWidensAtomToStr(binIx: i32, fnIx: i32) {
  if gLitUnionUsed == 0 { return false }
  const a = P.nodes[binIx]
  if a is BinExpr {
    if a.binOp == "=" {
      if exprString(a.binLeft, fnIx) {
        if exprIsLitAtom(a.binRight, fnIx) { return true }
      }
    }
  }
  false
}

// True if `initIx` is a literal-union ATOM read in a GLOBAL initializer — an `Ident` referencing
// another module global whose declared type is a literal union. (Module-global inits have no
// locals/params, so an Ident is the only atom form; a member literal is a plain string, not an
// atom.) Gates the start-fn `string`-global widening + its scratch-frame reservation.
function globalInitIsLitAtom(initIx: i32) {
  if initIx < 0 { return false }
  const e = P.nodes[unwrapParen(initIx)]
  if e is Ident {
    const gli = globalLetOf(e.identName)
    if gli >= 0 {
      const r = letIsLitUnion(gli)
      return r
    }
  }
  false
}

// True if the global at `letIx` is a `string` cell (kind 3) initialized with a literal-union atom
// — it widens to its member string in the start function, riding the string-op scratch frame.
function globalInitWidensAtomToStr(letIx: i32) {
  if gLitUnionUsed == 0 { return false }
  if letIx < 0 { return false }
  const gk = globalCellKind(letIx)
  if gk != 3 && gk != 16 { return false }
  const d = P.nodes[letIx]
  if d is LetDecl {
    const r = globalInitIsLitAtom(d.letInit)
    return r
  }
  false
}

// True if the binding at `letIx` is annotated `: string` and initialized with a literal-union
// atom — it widens to its member string at the init, riding the string-op scratch frame.
function letWidensAtomToStr(letIx: i32, fnIx: i32) {
  if gLitUnionUsed == 0 { return false }
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      if tyNameOf(d.letType) == "string" {
        if exprIsLitAtom(d.letInit, fnIx) { return true }
      }
    }
  }
  false
}

// True if `retArgIx` is a literal-union atom returned from a `string`-typed function (`fnIx`'s
// `fnRet`) — it widens to its member string at the return, riding the string-op scratch frame.
function retWidensAtomToStr(retArgIx: i32, fnIx: i32) {
  if gLitUnionUsed == 0 { return false }
  if retArgIx < 0 { return false }
  if fnIx < 0 { return false }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    if tyNameOf(fn.fnRet) == "string" {
      if exprIsLitAtom(retArgIx, fnIx) { return true }
    }
  }
  false
}

// True if `binIx` is `==`/`!=` whose operands are strings (string value-equality).
function exprIsStrEq(binIx: i32, fnIx: i32) {
  const e = P.nodes[binIx]
  if e is BinExpr {
    if e.binOp == "==" || e.binOp == "!=" {
      // A comparison with `null` is a NULL-CHECK (handled by the nullable-string /
      // -struct / -list `ref.is_null` paths), never element-wise string equality — a
      // `string | null` operand would otherwise be element-compared against `null`.
      if P.nodes[unwrapParen(e.binLeft)] is NullLit { return false }
      if P.nodes[unwrapParen(e.binRight)] is NullLit { return false }
      return exprString(e.binLeft, fnIx) || exprString(e.binRight, fnIx)
    }
  }
  false
}

// True if `binIx` is an ORDERING comparison (`<`/`>`/`<=`/`>=`) over two STRING operands
// — a lexicographic compare (`emitStrLessCore`), not the numeric `i32.lt_s` path that
// would compare the array refs. BOTH operands must be strings (the checker rejects a
// mixed string/numeric ordering); the frame reserved by `exprHasStrOp` carries the loop.
function exprIsStrOrder(binIx: i32, fnIx: i32) {
  const e = P.nodes[binIx]
  if e is BinExpr {
    const op = e.binOp
    if op == "<" || op == ">" || op == "<=" || op == ">=" {
      return exprString(e.binLeft, fnIx) && exprString(e.binRight, fnIx)
    }
  }
  false
}

// True if `binIx` is a `==`/`!=` whose union-box value compare can hit the
// STRING arm — a box compared against a string operand, or two boxes whose
// shared arms include `string`. Those payload compares stage their operands in
// the string scratch frame (`emitStrEqCore`), so the frame must be reserved.
function exprIsUnionStrEq(binIx: i32, fnIx: i32) {
  const e = P.nodes[binIx]
  if e is BinExpr {
    if e.binOp == "==" || e.binOp == "!=" {
      const lU = exprUnion(e.binLeft, fnIx)
      const rU = exprUnion(e.binRight, fnIx)
      if lU && rU {
        const ln = unionNameOfExpr(e.binLeft, fnIx)
        const rn = unionNameOfExpr(e.binRight, fnIx)
        return unionHasAtom(ln, "string") && unionHasAtom(rn, "string")
      }
      if lU { return exprString(e.binRight, fnIx) }
      if rU { return exprString(e.binLeft, fnIx) }
    }
  }
  false
}

// True if `binIx` is a same-shape STRUCT `==`/`!=` (a field-wise compare). Its
// string/array field compares stage operands in the string-op scratch frame, so
// it counts as a string op for frame reservation.
function exprIsStructEq(binIx: i32, fnIx: i32) {
  const e = P.nodes[binIx]
  if e is BinExpr {
    if e.binOp == "==" || e.binOp == "!=" {
      let lsi = structIndexOfExpr(e.binLeft, fnIx)
      if lsi >= 0 { return lsi == structIndexOfExpr(e.binRight, fnIx) }
    }
  }
  false
}

// ── list `==`/`!=`/`+` detection (which functions need the list-op frames) ────
// The list-op operand KIND of an expression: `0` an i32 list, `3` a string
// list, `4` an `i32[][]` (a ref list of i32-list elements), or -1 (not a list /
// an unsupported element kind). Order mirrors `emitIndex`'s receiver dispatch.
function listOpKindOf(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return -1 }
  if exprString(exprIx, fnIx) { return -1 }
  if exprStringArray(exprIx, fnIx) { return 3 }
  if exprF64Array(exprIx, fnIx) { return -1 }
  if exprRefArray(exprIx, fnIx) {
    let slot = refListSlotOfExpr(exprIx, fnIx)
    if slot >= 0 && slot < rlElemKindTbl.length {
      if rlElemKindTbl[slot] == 4 { return 4 }
    }
    return -1
  }
  if exprArray(exprIx, fnIx) { return 0 }
  -1
}

// The list-op kind of a `==`/`!=`/`+` BinExpr whose operands are BOTH lists of
// one kind, or -1 (not a list op — the caller keeps its existing dispatch).
function listOpKindOfBin(binIx: i32, fnIx: i32) {
  const e = P.nodes[binIx]
  if e is BinExpr {
    if e.binOp == "==" || e.binOp == "!=" || e.binOp == "+" {
      const lk = listOpKindOf(e.binLeft, fnIx)
      if lk < 0 { return -1 }
      let rk = listOpKindOf(e.binRight, fnIx)
      if rk != lk { return -1 }
      return lk
    }
  }
  -1
}

// Note one BinExpr's list-op kind into the per-function frame flags.
function leqNoteBin(binIx: i32, fnIx: i32) {
  let k = listOpKindOfBin(binIx, fnIx)
  if k == 0 { fnUsesListEqI = true }
  if k == 3 {
    fnUsesListEqS = true
    // The per-element string compares stage operands in the string-op frame.
    fnUsesStrOp = true
  }
  if k == 4 {
    // The nested element compare recurses into the i32-list frame.
    fnUsesListEqI = true
    const e = P.nodes[binIx]
    if e is BinExpr {
      let slot = refListSlotOfExpr(e.binLeft, fnIx)
      if slot >= 0 {
        let seen = false
        let i = 0
        while i < fnListEqRSlots.length {
          if fnListEqRSlots[i] == slot { seen = true }
          i = i + 1
        }
        if !seen { fnListEqRSlots.push(slot) }
      }
    }
  }
  0
}

// True if struct shape `si` carries a function-typed field (code 14), looking
// through nested-struct fields (code 15). `seen` guards recursive shapes.
function shapeHasCloField(si: i32, seen: i32[]) {
  let k = 0
  while k < seen.length {
    if seen[k] == si { return false }
    k = k + 1
  }
  seen.push(si)
  let fi = 0
  while fi < sFieldCount[si] {
    let code = sFieldTypeAt(si, fi)
    if code == 14 { return true }
    if code == 15 {
      const nsi = structIndexByName(sFieldElemNameAt(si, fi))
      if nsi >= 0 {
        if shapeHasCloField(nsi, seen) { return true }
      }
    }
    fi = fi + 1
  }
  false
}

// Note one BinExpr's function-identity equality site (`f == g`, or a struct
// equality whose shape carries a function-typed field) into `fnUsesCloEq` — the
// compare stages both operands in the 2-slot closure-eq frame.
function cloEqNoteBin(binIx: i32, fnIx: i32) {
  const e = P.nodes[binIx]
  if e is BinExpr {
    if e.binOp == "==" || e.binOp == "!=" {
      if exprIsClosure(e.binLeft, fnIx) || exprIsClosure(e.binRight, fnIx) {
        fnUsesCloEq = true
        return 0
      }
      let si = structIndexOfExpr(e.binLeft, fnIx)
      if si >= 0 {
        let seen: i32[] = []
        if shapeHasCloField(si, seen) { fnUsesCloEq = true }
      }
    }
  }
  0
}

// Recursive expression walk noting every list `==`/`!=`/`+` site (and, riding the
// same walk, every function-identity equality site — `cloEqNoteBin`).
function leqScanExpr(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return 0 }
  const e = P.nodes[exprIx]
  if e is BinExpr {
    leqNoteBin(exprIx, fnIx)
    cloEqNoteBin(exprIx, fnIx)
    leqScanExpr(e.binLeft, fnIx)
    return leqScanExpr(e.binRight, fnIx)
  }
  if e is Unary { return leqScanExpr(e.unArg, fnIx) }
  if e is Paren { return leqScanExpr(e.parInner, fnIx) }
  if e is Call {
    leqScanExpr(e.callFn, fnIx)
    const args = e.callArgs
    let i = 0
    while i < args.length {
      leqScanExpr(args[i], fnIx)
      i = i + 1
    }
    return 0
  }
  if e is Member { return leqScanExpr(e.memObj, fnIx) }
  if e is OptMember { return leqScanExpr(e.omObj, fnIx) }
  if e is Index {
    leqScanExpr(e.idxArr, fnIx)
    return leqScanExpr(e.idxIndex, fnIx)
  }
  if e is ArrayLit {
    const es = e.arrElems
    let i2 = 0
    while i2 < es.length {
      leqScanExpr(es[i2], fnIx)
      i2 = i2 + 1
    }
    return 0
  }
  if e is ObjLit {
    const fs = e.objFields
    let i3 = 0
    while i3 < fs.length {
      const f = P.nodes[fs[i3]]
      if f is FieldInit { leqScanExpr(f.fiValue, fnIx) }
      i3 = i3 + 1
    }
    return 0
  }
  if e is IsExpr { return leqScanExpr(e.isObj, fnIx) }
  0
}

// Statement-level walk (descends branch/loop bodies; a bare expression
// statement falls through to the expression walk).
function leqScanStmt(stmtIx: i32, fnIx: i32) {
  if stmtIx < 0 { return 0 }
  let s = P.nodes[stmtIx]
  if s is LetDecl { return leqScanExpr(s.letInit, fnIx) }
  if s is RetStmt { return leqScanExpr(s.retArg, fnIx) }
  if s is IfStmt {
    leqScanExpr(s.ifCond, fnIx)
    leqScanBlock(s.ifThen, fnIx)
    return leqScanBlock(s.ifElse, fnIx)
  }
  if s is WhileStmt {
    leqScanExpr(s.whileCond, fnIx)
    return leqScanBlock(s.whileBody, fnIx)
  }
  if s is ForRange {
    leqScanExpr(s.frFrom, fnIx)
    leqScanExpr(s.frTo, fnIx)
    leqScanExpr(s.frStep, fnIx)
    return leqScanBlock(s.frBody, fnIx)
  }
  if s is ForIn {
    leqScanExpr(s.fiIter, fnIx)
    return leqScanBlock(s.fiBody, fnIx)
  }
  if s is Block { return leqScanBlock(stmtIx, fnIx) }
  leqScanExpr(stmtIx, fnIx)
}

function leqScanBlock(ix: i32, fnIx: i32) {
  if ix < 0 { return 0 }
  let b = P.nodes[ix]
  if b is Block {
    const stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      leqScanStmt(stmts[i], fnIx)
      i = i + 1
    }
    return 0
  }
  leqScanStmt(ix, fnIx)
}

// True if `callIx` is a `recv.slice(start, end)` over a STRING receiver.
function exprIsStrSlice(callIx: i32, fnIx: i32) {
  let c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      if callee.memProp == "slice" { return exprString(callee.memObj, fnIx) }
    }
  }
  false
}

// True if `callIx` is a `recv.indexOf(sub)` / `recv.includes(sub)` over a STRING
// receiver — both ride the same indexOf scan (`includes` negates the -1 compare).
function exprIsStrIndexOf(callIx: i32, fnIx: i32) {
  let c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      if callee.memProp == "indexOf" || callee.memProp == "includes" {
        return exprString(callee.memObj, fnIx)
      }
    }
  }
  false
}

// True if `callIx` is a `recv.charCodeAt(i)` over a STRING receiver.
function exprIsStrCharCode(callIx: i32, fnIx: i32) {
  let c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      if callee.memProp == "charCodeAt" {
        return exprString(callee.memObj, fnIx)
      }
    }
  }
  false
}

// True if the expression at `exprIx` (or any sub-expression) is a string `+`,
// string `==`/`!=`, or string `.slice`.
function exprHasStrOp(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is BinExpr {
    if exprIsStrConcat(exprIx, fnIx) { return true }
    if exprIsStrEq(exprIx, fnIx) { return true }
    // A string ORDERING (`<`/`>`/`<=`/`>=`) rides the same lexicographic compare loop.
    if exprIsStrOrder(exprIx, fnIx) { return true }
    // A union-box `==`/`!=` whose value compare can hit the STRING arm stages
    // its payloads in the same frame (`emitStrEqCore`).
    if exprIsUnionStrEq(exprIx, fnIx) { return true }
    // A struct `==`/`!=` stages its string/array FIELD compares in the same frame.
    if exprIsStructEq(exprIx, fnIx) { return true }
    // An assignment of a literal-union atom into a `string` target widens (`emitAtomToStr`),
    // which stages the atom id in the string-op scratch frame.
    if assignWidensAtomToStr(exprIx, fnIx) { return true }
    if exprHasStrOp(e.binLeft, fnIx) { return true }
    return exprHasStrOp(e.binRight, fnIx)
  }
  if e is Call {
    if exprIsStrSlice(exprIx, fnIx) { return true }
    // A literal-union atom argument flowing into a `string` param widens (`emitAtomToStr`),
    // which stages the atom id in the string-op scratch frame.
    if callWidensAtomToStr(exprIx, fnIx) { return true }
    // `s.indexOf(sub)` / `s.includes(sub)` stage their receiver + needle + loop
    // counters in the same string scratch frame. (`charCodeAt` is a bare
    // `array.get` — no frame needed; its operands recurse below.)
    if exprIsStrIndexOf(exprIx, fnIx) { return true }
    // `print(<string>)` rides the string-op scratch frame (the streaming loop's
    // string ref + cursor + length live there).
    const pcal = P.nodes[e.callFn]
    if pcal is Ident {
      if pcal.identName == "print" {
        if e.callArgs.length == 1 {
          if exprString(e.callArgs[0], fnIx) { return true }
          // `print(<literal-union atom>)` widens to its member string — its per-member print chain rides
          // the same string-op scratch frame.
          if exprIsLitAtom(e.callArgs[0], fnIx) { return true }
        }
      }
      // `toString(x)` builds its digits in the string-op scratch frame.
      if pcal.identName == "toString" { return true }
      // `fromCodePoints(xs)` stages its length + result there too.
      if pcal.identName == "fromCodePoints" { return true }
    }
    if exprHasStrOp(e.callFn, fnIx) { return true }
    const args = e.callArgs
    let i = 0
    while i < args.length {
      if exprHasStrOp(args[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  if e is Member { return exprHasStrOp(e.memObj, fnIx) }
  if e is Index {
    if exprHasStrOp(e.idxArr, fnIx) { return true }
    return exprHasStrOp(e.idxIndex, fnIx)
  }
  // An if-EXPRESSION in value position (`print(if a < b then …)`): a string op in the
  // condition or either arm needs the frame reserved too.
  if e is IfStmt {
    if exprHasStrOp(e.ifCond, fnIx) { return true }
    if blockHasStrOp(e.ifThen, fnIx) { return true }
    if e.ifElse >= 0 { return blockHasStrOp(e.ifElse, fnIx) }
    return false
  }
  if e is Unary { return exprHasStrOp(e.unArg, fnIx) }
  if e is Paren { return exprHasStrOp(e.parInner, fnIx) }
  if e is IsExpr {
    // A string-LITERAL `is` (`s is "a"`) lowers through `emitStrEqCore`, so it
    // stages operands in the string scratch frame like a string `==`.
    if e.isVariant.length > 0 && e.isVariant[0] == '"' { return true }
    return exprHasStrOp(e.isObj, fnIx)
  }
  if e is ObjLit {
    const fields = e.objFields
    let i = 0
    while i < fields.length {
      const f = P.nodes[fields[i]]
      if f is FieldInit {
        if exprHasStrOp(f.fiValue, fnIx) { return true }
        // A literal-union atom field value widens to a string (`string` field) — reserve the
        // string-op frame. (Any atom field value is destined for a `string` field; a literal-
        // union FIELD is not yet a rep, so this is a safe over-approximation.)
        if exprIsLitAtom(f.fiValue, fnIx) { return true }
      }
      i = i + 1
    }
    return false
  }
  if e is ArrayLit {
    const elems = e.arrElems
    let i = 0
    while i < elems.length {
      if exprHasStrOp(elems[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  false
}

// True if any statement in the block at `blockIx` (descending into if/else branches
// and while bodies, the scopes `collectLocals` walks) contains a string op. A
// wrapper restores the narrowing depth the scan's post-guard pushes (mirroring
// the emit loops) may leave behind on an early `true`.
function blockHasStrOp(blockIx: i32, fnIx: i32) {
  const savedGuardTop = narrowTop
  const hit = blockHasStrOpScan(blockIx, fnIx)
  restoreNarrow(savedGuardTop)
  hit
}

function blockHasStrOpScan(blockIx: i32, fnIx: i32) {
  let b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      let s = P.nodes[stmts[i]]
      if s is LetDecl {
        if exprHasStrOp(s.letInit, fnIx) { return true }
        // A literal-union atom initializing a `string` local widens — reserve the frame.
        if letWidensAtomToStr(stmts[i], fnIx) { return true }
      } else if s is RetStmt {
        if exprHasStrOp(s.retArg, fnIx) { return true }
        // A literal-union atom returned as `string` widens — reserve the string-op frame.
        if retWidensAtomToStr(s.retArg, fnIx) { return true }
      } else if s is BinExpr {
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is Call {
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is ObjLit {
        // A bare trailing object-literal statement is a function's implicit-return value
        // (e.g. `mkTok` returns `{ …, text: gSrc.slice(…), … }`). Its field initializers
        // can contain string ops, so descend — `exprHasStrOp` walks `objFields`.
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is Member {
        // A bare trailing MEMBER access is also an implicit-return value — and its
        // receiver may be a string op, e.g. `s.slice(a, b).length` (a `.length` over
        // a slice call). Without this the slice's scratch frame goes unreserved and
        // the slice emit references an unallocated local. `exprHasStrOp` walks `memObj`.
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is Index {
        // Likewise a trailing `xs[i]` / `m[k]` index whose receiver/key uses a string op.
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is Paren {
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is Unary {
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is IsExpr {
        if exprHasStrOp(stmts[i], fnIx) { return true }
      } else if s is IfStmt {
        if ifChainHasStrOp(stmts[i], fnIx) { return true }
      } else if s is WhileStmt {
        if exprHasStrOp(s.whileCond, fnIx) { return true }
        if blockHasStrOp(s.whileBody, fnIx) { return true }
      } else if s is ForIn {
        if exprHasStrOp(s.fiIter, fnIx) { return true }
        if blockHasStrOp(s.fiBody, fnIx) { return true }
      } else if s is ForRange {
        if exprHasStrOp(s.frFrom, fnIx) { return true }
        if exprHasStrOp(s.frTo, fnIx) { return true }
        if blockHasStrOp(s.frBody, fnIx) { return true }
      }
      // Post-guard complement narrowing (mirrors the emit loops) — so a string
      // read below a returning guard (`if x is i32 { return 0 } print(x)`) is
      // detected under the SAME narrowing the emit applies. The wrapper restores.
      pushPostGuardNarrow(stmts[i], fnIx)
      i = i + 1
    }
  }
  false
}

// True if any arm of the `if` / `else if` chain at `ifIx` contains a string op — its
// condition, then-branch, `else` block, OR (RECURSIVELY) a chained `else if`. Mirrors
// `ifChainHasPushKind`: walks the WHOLE else-if chain, not just one level.
function ifChainHasStrOp(ifIx: i32, fnIx: i32) {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    if exprHasStrOp(s.ifCond, fnIx) { return true }
    // Narrow across the THEN-branch (mirroring `emitStmt`/`collectLocalsIf`) so a string
    // op over a NARROWED variant field (`if n is A { … n.strField == x … }`, and nested
    // guards over distinct locals) is detected — `exprString` resolves a variant field's
    // string type only while the receiver's narrowing is active. Save/restore the depth.
    const savedTop = narrowTop
    const narrowed = setNarrowFromCond(s.ifCond, fnIx)
    const hit = blockHasStrOp(s.ifThen, fnIx)
    if narrowed { restoreNarrow(savedTop) }
    if hit { return true }
    if s.ifElse >= 0 {
      // A VALUE union narrows to the COMPLEMENT set in the else-arm (mirroring
      // `emitStmt`'s else lowering), so `else { print(v) }` with `v` now `string`
      // is detected as a string print and reserves the scratch frame.
      const savedElseTop = narrowTop
      const narrowedElse = setNarrowFromCondElse(s.ifCond, fnIx)
      const els = P.nodes[s.ifElse]
      let hitElse = false
      if els is Block { hitElse = blockHasStrOp(s.ifElse, fnIx) }
      else if els is IfStmt { hitElse = ifChainHasStrOp(s.ifElse, fnIx) }
      if narrowedElse { restoreNarrow(savedElseTop) }
      if hitElse { return true }
    }
  }
  false
}

// True if the FuncDecl at `fnIx` uses any string op (`+`/`==`/`!=`/`.slice`) — so it
// reserves the shared string scratch frame.
function fnHasStrOp(fnIx: i32) {
  const fn = P.nodes[fnIx]
  if fn is FuncDecl { return blockHasStrOp(fn.fnBody, fnIx) }
  false
}

// ── array-intrinsic detection (std-design D1 / collections-design §LS.2) ──────
// `__array_new__(n, fill)` / `__array_new_default__(n)` / `__array_copy__(…)` /
// `__trap__()` lower INLINE at the call site (host parity: toWasm.ts lowers the
// same names to array.new / array.new_default / array.copy / unreachable). The
// two allocators reserve the 1-slot `arrNewScratchBase` frame; these walkers
// find them anywhere in a body — a pure NAME walk (no classification, so no
// narrowing bookkeeping is needed, unlike the string-op scan).

// The intrinsic-allocation ELEMENT KIND of the Call at `callIx`: `0` = the i32
// list (i32/boolean fills — the i32 backing), `1` = the f64 list (an f64 fill),
// `-1` = not an intrinsic allocation. `__array_new_default__` is always the i32
// list natively: its element kind is not derivable from the argument list (an
// f64 default needs `__array_new__(n, 0.0)`); the host covers it generically.
function arrNewIntrKind(callIx: i32, fnIx: i32) {
  let c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Ident {
      if callee.identName == "__array_new__" {
        if c.callArgs.length == 2 {
          if exprIsF64(c.callArgs[1], fnIx) { return 1 }
          // A STRING fill (kind 2) builds the string list; a STRUCT/object-literal
          // fill (kind 3) builds the ref list for that element struct. (Ref
          // long-tail: closures / nested arrays / maps as fills still fail loudly.)
          if exprString(c.callArgs[1], fnIx) { return 2 }
          const anf = P.nodes[c.callArgs[1]]
          if anf is ObjLit { return 3 }
          if exprStruct(c.callArgs[1], fnIx) { return 3 }
        }
        return 0
      }
      if callee.identName == "__array_new_default__" { return 0 }
    }
  }
  -1
}

// The declared-local POSITION of `name`: the innermost live lexical binding if the
// scope stack has one (so a same-named binding in a disjoint/inner block resolves to
// ITS own slot, with its own valtype), else the first `localNames` slot of that name
// as a safety net (used when no scope frame is active, e.g. the `fnUses*` detection
// pass, where any same-named slot's type suffices). -1 if `name` is not a local.
// The RESOLUTION variant of `declaredSlotOf`: identical, except the flat
// fallback scan SKIPS loop-variable slots (`localLoopVar`). At resolution time
// the scope stack is maintained in lockstep with the walk, so a live loop var
// always resolves through it; a flat-scan hit on a loop var would be a DEAD
// binding (its loop already closed) shadowing the outer/global the host would
// resolve (see `markLoopVarSlot`). Detection/classifier passes keep using
// `declaredSlotOf` (they run scope-less and must see in-body loop vars).
function declaredSlotLive(name: string) {
  const scoped = scopeSlotOf(name)
  if scoped >= 0 { return scoped }
  let pos = 0
  while pos < localNames.length {
    if localNames[pos] == name && localLoopVar[pos] == 0 { return pos }
    pos = pos + 1
  }
  -1
}

function declaredSlotOf(name: string) {
  const scoped = scopeSlotOf(name)
  if scoped >= 0 { return scoped }
  let pos = 0
  while pos < localNames.length {
    if localNames[pos] == name { return pos }
    pos = pos + 1
  }
  -1
}

// The local-kind code (`localIsRef`) of declared local `name`, or -1 if there is no such
// declared local. The single `declaredSlotOf` + `localIsRef` lookup the `declared*` type
// predicates share — each compares the result against its kind code (2 i32-list, 5 ref-
// list, 7 string-list, 12 f64-list, 20 i64-list, 1 struct, 4 union, 6 map, 3 string, 9/15/
// 16/19 the niche nullables, 10/11/13 scalar i64/f64/f32).
function declaredKind(name: string) {
  const slot = declaredSlotOf(name)
  if slot < 0 { return -1 }
  localIsRef[slot]
}

// The wasm local index of declared local `name`, or -1 if it is not a declared
// local. Declared locals sit AFTER the params, so the slot is `paramCount + pos`
// where `pos` is the name's resolved declared-local position (`declaredSlotOf`).
function declaredIndexOf(fnIx: i32, name: string) {
  let pos = declaredSlotLive(name)
  if pos < 0 { return -1 }
  if fnIx < 0 {
    // Module scope = the START FUNCTION's body (top-level statements — a `for`
    // loop's var/bound live here). It has no params, so the local index IS the
    // slot. (A global-section constexpr init also runs with fnIx -1, but the
    // scope stack is empty there, so `declaredSlotOf` already returned -1.)
    return pos
  }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl { return envSlotShift(fnIx) + fn.fnParams.length + pos }
  -1
}

// The wasm-local-index offset introduced by the env-leading closure param: when ANY
// function value exists in the module (`fnValUsed`), EVERY function (except the start
// fn, `fnIx < 0`) carries a hidden leading `structref env` at local 0, so its declared
// params shift to locals 1..p and its declared locals to p+1... Zero otherwise — so a
// no-lambda module keeps the original 0-based param layout and stays byte-identical.
function envSlotShift(fnIx: i32) {
  if fnValUsed && fnIx >= 0 { return 1 }
  0
}

// Resolve an identifier `name` to its wasm local index for function `fnIx`: a param
// first (locals 0..p-1, shifted past the env param when `fnValUsed`), else a declared
// local. Returns -1 if neither.
function localIndexOf(fnIx: i32, name: string) {
  const pIx = paramIndexOf(fnIx, name)
  if pIx >= 0 { return envSlotShift(fnIx) + pIx }
  declaredIndexOf(fnIx, name)
}

// Emit the instructions for the returned expression at `exprIx` onto `body`, in
// stack order, resolving identifiers against function `fnIx`'s params. Returns 0
// on success, or calls `emitFail` and returns -1 on any unsupported shape.
//
// Supported operands (any of which may nest as children):
//   NumLit  -> i32.const <value>           (the literal, via parseI32 + slebToArr)
//   Ident   -> local.get <param index>     (a parameter reference)
//   BinExpr -> emit(left), emit(right), <opcode>   (operands first, then the op,
//              the natural wasm post-order stack encoding; arithmetic OR comparison).
//              Logical `&&`/`||` instead lower to a SHORT-CIRCUIT value-typed `if`
//              (blocktype 0x7f): `a && b` ≡ if(a){b}else{0}, `a || b` ≡ if(a){1}else{b}.
//   Unary   -> negation `-x` as i32.const 0, emit(x), i32.sub; logical `!a` as eqz (0x45)
//   Call    -> emit each arg left-to-right, then `call <funcIndex>` (the callee is
//              an `Ident` resolved through the function-index map; recursion works
//              because the function's own name is mapped before its body is emitted)
//   Paren   -> the inner expression (parentheses carry no runtime instruction)
//
// Node shapes read (all from `compiler/ast.vl`):
//   NumLit  { numText: string }
//   Ident   { identName: string }
//   Unary   { unOp: string, unArg: i32 }
//   BinExpr { binOp: string, binLeft: i32, binRight: i32 }
//   Call    { callFn: i32, callArgs: i32[] }
//   Paren   { parInner: i32 }
// The wasm struct field index of `name` within struct `si` (declaration order), or
// -1 if that struct has no such field.
function sFieldIndex(si: i32, name: string) {
  if si < 0 {
    return -1 // unresolved struct (e.g. an inferred ref with no interned shape)
  }
  let start = sFieldStart[si]
  let cnt = sFieldCount[si]
  let j = 0
  while j < cnt {
    if sFieldNames[start + j] == name { return j }
    j = j + 1
  }
  -1
}

// The wasm-type code (`0` i32, `3` string, `4` i32-list, `5` ref-list) of struct `si`'s
// field at field index `fi`.
function sFieldTypeAt(si: i32, fi: i32) { sFieldTypes[sFieldStart[si] + fi] }

// The ref-list element type-NAME of struct `si`'s field `fi` (a code-5 field), "" else.
function sFieldElemNameAt(si: i32, fi: i32) {
  sFieldElemName[sFieldStart[si] + fi]
}

// The ref-list table SLOT of struct `si`'s ref-list field `fi`, or -1 if not a ref list.
function sFieldRefSlot(si: i32, fi: i32) {
  rlSlotByName(sFieldElemNameAt(si, fi))
}

// Push the STORAGETYPE bytes (NOT the trailing mutability flag) for a struct / variant
// field whose wasm-type `code` is one of `0` i32, `3` string, `4` i32-list, `5` ref-list.
// Each array-typed field stores a non-null REF to the corresponding list wrapper struct
// (`0x64 <heap-type-index>`): `lTypeIdx` for `i32[]`, `rlTypeIdx` for a `T[]`/`N[]` ref
// list — exactly the wrappers the map's `keys`/`vals` fields already reference. The
// referenced wrapper types are interned in the SAME rec group (forced present by
// `collectA`), so the forward index resolves. Used by the type-section struct emission.
// For a ref-list field (code 5) `refSlot` is the field's per-element-type table slot
// (its wrapper is `rlWrapIdx[refSlot]`); ignored for other codes. Streams to the
// current target (`curBuf`) — the caller binds it at the type-section payload.
function pushFieldStorage(code: i32, refSlot: i32) {
  if code == 3 {
    wU8(100) // 0x64 (ref ht) — non-null string ref
    wSLEB(aTypeIdx)
  } else if code == 4 {
    wU8(100) // 0x64 (ref ht) — non-null i32-list wrapper ref
    wSLEB(lTypeIdx)
  } else if code == 5 {
    wU8(100)            // 0x64 (ref ht) — non-null ref-list wrapper ref
    let s = refSlot
    if s < 0 { s = 0 }
    wSLEB(rlWrapIdx[s]) // THIS field's distinct ref-list wrapper (s33 heap type)
  } else if code == 6 {
    wU8(100) // 0x64 (ref ht) — non-null string-list wrapper ref
    wSLEB(mkListIdx)
  } else if code == 14 {
    wU8(100)            // 0x64 (ref ht) — non-null closure fat-pointer ref
    wSLEB(cloStructIdx) // the closure struct heap type (#306)
  } else if code == 15 {
    // A NESTED-STRUCT field: a NULLABLE ref to the target struct (`refSlot` is its
    // struct TABLE index here). Nullable storage serves both the plain (`inner: S`,
    // always written non-null) and the `S|null` field — and lets a recursive shape
    // (`next: Node|null`) terminate. Forward indices resolve in the shared rec group.
    wU8(99) // 0x63 (ref null ht)
    wSLEB(sHeapIdx[refSlot])
  } else if code == 16 {
    // A VALUE-UNION field (`y: string | i32`): a non-null ref to the shared
    // union box — a `null` MEMBER rides the box's tag, never a null field ref.
    // The box's heap index is a forward reference inside the shared rec group.
    wU8(100) // 0x64 (ref ht)
    wSLEB(uBoxIdx)
  } else if code == 17 {
    wU8(124) // 0x7c f64 storagetype
  } else if code == 23 {
    wU8(126) // 0x7e i64 storagetype
  } else if code == 24 {
    wU8(125) // 0x7d f32 storagetype
  } else if code == 25 {
    // An `f64[]` list field: a non-null ref to the f64-list WRAPPER (`$fl64TypeIdx`) — the scalar
    // analogue of code 4's `i32[]`→`$lTypeIdx`. The value builds it via the generic `emitExpr` path
    // (an f64 array literal lowers to this wrapper), the read indexes it via the checker's f64-list type.
    wU8(100) // 0x64 (ref ht)
    wSLEB(fl64TypeIdx)
  } else if code == 26 {
    // An `i64[]` list field: a non-null ref to the i64-list wrapper (`$il64TypeIdx`).
    wU8(100) // 0x64 (ref ht)
    wSLEB(il64TypeIdx)
  } else if code == 27 {
    // An `f32[]` list field: a non-null ref to the f32-list wrapper (`$fl32TypeIdx`).
    wU8(100) // 0x64 (ref ht)
    wSLEB(fl32TypeIdx)
  } else if code == 18 {
    // A NULLABLE i32-list field (`rest: i32[] | null`): the same wrapper as
    // code 4, with NULLABLE storage — the field genuinely carries null.
    wU8(99) // 0x63 (ref null ht)
    wSLEB(lTypeIdx)
  } else if code == 28 {
    // A NULLABLE REF-LIST field (`S[] | null` / `(i32|null)[] | null`): a NULLABLE ref to the element's
    // ref-list wrapper — the ref-list analogue of code 18. `refSlot` is the element ref-list slot.
    if refSlot < 0 || refSlot >= rlWrapIdx.length {
      wU8(127)
      return emitFail(
        "emitProgram: nullable ref-list field element type is not interned",
      )
    }
    wU8(99) // 0x63 (ref null ht)
    wSLEB(rlWrapIdx[refSlot])
  } else if code == 19 {
    // A MAP-typed field (`children: {[string]: Tree}`): a non-null ref to the
    // value type's map struct (`refSlot` is the mv SLOT here; -1 = the mono
    // map). A recursive value (Tree → map → Tree) ties in the shared rec group.
    wU8(100) // 0x64 (ref ht)
    wSLEB(mapTypeIdxOf(refSlot))
  } else if code == 20 {
    // A `string | null` niche field: a NULLABLE ref to the raw string array (the
    // same backing as code 3, the nullability in the field's storage type).
    wU8(99) // 0x63 (ref null ht)
    wSLEB(aTypeIdx)
  } else if code == 22 {
    // A NULLABLE-closure field (`op: ((i32) => i32) | null`): a NULLABLE ref to the
    // closure fat-pointer struct (the same backing as code 14, nullable storage) —
    // `null` rides as `ref.null $cloStruct`, the field analogue of a kind-19 local.
    wU8(99) // 0x63 (ref null ht)
    wSLEB(cloStructIdx)
  } else {
    // code 21 (`boolean | null`, the i32 sentinel) shares this default i32 storage.
    wU8(127) // 0x7f i32 storagetype
  }
  0
}

// The struct table index whose name is `name`, or -1 if `name` is not a declared
// struct type.
function structIndexByName(name: string) {
  let i = 0
  while i < sNames.length {
    if sNames[i] == name { return i }
    i = i + 1
  }
  -1
}

// The struct table index whose field-name SET matches the object literal at `objIx`
// EXACTLY (same count, every literal field present in the struct), or -1 if no struct
// matches. With distinct field-name sets across structs this disambiguates which
// struct an `{ … }` literal constructs (the struct analogue of `objVariantName`).
function structIndexOfObj(objIx: i32) { structIndexOfObjCtx(objIx, -1) }

// The context-aware variant: `fnIx` (when >= 0) classifies field VALUES through
// the expression family too, so a monomorphized instance's SHARED tail literal
// (`{ x: self.x + b.x }`) resolves per instance — f64 against the f64-param
// instance, i32 against the i32 one.
function structIndexOfObjCtx(objIx: i32, fnIx: i32) {
  const o = P.nodes[objIx]
  if o is ObjLit {
    const nf = o.objFields.length
    let si = 0
    while si < sNames.length {
      if sFieldCount[si] == nf {
        let ok = true
        let k = 0
        while k < nf {
          const f = P.nodes[o.objFields[k]]
          if f is FieldInit {
            let mfi = sFieldIndex(si, f.fiName)
            if mfi < 0 {
              ok = false
            } else {
              // F64 DISCRIMINATION: an `{x}` literal matches the i32 `{x}` and
              // the f64 `{x}` shapes by NAME — split them on the value's float-
              // ness so `{x: 1.5}` builds the f64 shape and `{x: 1}` the i32
              // one (monomorphized `addx` instances each pin their own). Only
              // the f64 axis discriminates; every other code keeps the lenient
              // name-only match (a `{v: 5}` literal still matches a
              // `{v: i32|null}` union-field shape).
              const sc = sFieldTypeAt(si, mfi)
              const vc = anonFieldCode(f.fiValue)
              let isFloat = vc == 17
              if !isFloat && fnIx >= 0 {
                if exprIsF64(f.fiValue, fnIx) { isFloat = true }
              }
              if isFloat {
                if sc != 17 && sc != 24 && sc != 16 { ok = false }
              } else if sc == 17 {
                if fnIx >= 0 || vc >= 0 { ok = false }
              }
            }
          } else {
            ok = false
          }
          k = k + 1
        }
        if ok { return si }
      }
      si = si + 1
    }
  }
  -1
}

// Emit the NULL value of an OMITTED nullable field (`si`/`fi`, field code `scode`) in a
// struct literal — the completion coercion's per-rep null: a `string | null` field (20) is
// `ref.null $aTypeIdx`, a `boolean | null` field (21) the i32 sentinel 2, a nullable
// struct (15) `ref.null $S`, a nullable i32-list (18) `ref.null $lTypeIdx`, and a value/box
// union field (16) WITH a `null` member the null-tagged box. Returns 0, or -1 when the
// field is NOT nullable (the caller turns that into the missing-field error).
function emitOmittedFieldNull(body: i32[], si: i32, fi: i32, scode: i32) {
  if scode == 20 {
    fbRefNull(aTypeIdx) // ref.null $aTypeIdx
    return 0
  }
  if scode == 21 {
    fbI32Const(2) // the boolean|null sentinel
    return 0
  }
  if scode == 15 {
    const tgt = structIndexByName(sFieldElemNameAt(si, fi))
    if tgt < 0 { return -1 }
    fbRefNull(sHeapIdx[tgt]) // ref.null $S
    return 0
  }
  if scode == 18 {
    fbRefNull(lTypeIdx) // ref.null $lTypeIdx (i32[] | null)
    return 0
  }
  if scode == 28 {
    // A NULLABLE ref-list field omitted -> `ref.null $wrapper` (the element's ref-list wrapper).
    const rs28 = sFieldRefSlot(si, fi)
    if rs28 >= 0 && rs28 < rlWrapIdx.length {
      fbRefNull(rlWrapIdx[rs28])
      return 0
    }
    return -1
  }
  if scode == 22 {
    fbRefNull(cloStructIdx) // ref.null $cloStruct (a nullable-closure field, kind 19)
    return 0
  }
  if scode == 16 {
    // A value/box-union field defaults to null ONLY when `null` is a member.
    if unionHasAtom(sFieldElemNameAt(si, fi), "null") {
      fbI32Const(scalarTagOf("null"))
      fbRefNullNone() // payload slot unread under the null tag
      fbStructNew(uBoxIdx)
      return 0
    }
    return -1
  }
  -1
}

// Lower an object literal `{ f: v, ... }` onto `body`: resolve WHICH struct the
// literal's field-name set names, push each field's value IN THAT STRUCT'S DECLARED
// FIELD ORDER, then `struct.new $<heapIdx>` (`0xfb 0x00 <heapIdx>`). The literal must
// match exactly one struct's fields, EXCEPT a nullable field may be omitted (the
// completion coercion — it is materialized as `null` via `emitOmittedFieldNull`).
function emitObj(body: i32[], objIx: i32, fnIx: i32) {
  if !sDeclared {
    return emitFail("emitProgram: object literal but no struct type declared")
  }
  const o = P.nodes[objIx]
  if o is ObjLit {
    // An EXPECTED struct index from the binding/argument site (`pendingStructIdx`) wins
    // over the field-name match: a struct-typed call argument must be the callee
    // parameter's type even when another struct shares its field names. Consume the hint
    // (reset to -1) so a nested literal value falls back to inference.
    let si = pendingStructIdx
    pendingStructIdx = -1
    if si < 0 { si = structIndexOfObjCtx(objIx, fnIx) }
    if si < 0 {
      return emitFail("emitProgram: object literal field count does not match struct")
    }
    let cnt = sFieldCount[si]
    let fi = 0
    while fi < cnt {
      const valIx = objFieldVal(objIx, sFieldNames[sFieldStart[si] + fi])
      const scode = sFieldTypeAt(si, fi)
      if valIx < 0 {
        // COMPLETION COERCION: a NULLABLE field omitted from the literal is materialized
        // as `null` (the checker `assignableExpr` already permitted the omission). A
        // non-nullable omitted field is still an error.
        if emitOmittedFieldNull(body, si, fi, scode) < 0 {
          return emitFail("emitProgram: object literal is missing a struct field")
        }
        fi = fi + 1
        continue
      }
      // A nested struct VALUE is allowed for a nested-struct field (code 15) and for a
      // BOX-union field (code 16) — the latter boxes the struct as a variant via
      // `emitUnionCoerce` (`{ v: { a: 7 } }` against `{ v: A | B }`). Any OTHER field type
      // receiving a struct value is unsupported.
      if scode != 15 && scode != 16 {
        if exprStruct(valIx, fnIx) {
          return emitFail("emitProgram: nested struct fields are not supported")
        }
      }
      // A ref-list field (`code 5`: `T[]`/`N[]`) whose value is an EMPTY `[]` literal
      // needs the element kind to build a REF-list (not an i32-list) wrapper — the same
      // way a `let xs: T[] = []` annotation threads `pendingListKind`. The element kind
      // is global (union box `2` when a union is declared, else a struct `1`).
      pendingListKind = 0
      pendingListSlot = 0
      pendingNulRefHeap = -1
      if scode == 5 {
        let fslot = sFieldRefSlot(si, fi)
        if fslot < 0 { fslot = 0 }
        pendingListSlot = fslot
        if rlElemKindTbl[fslot] == 2 {
          pendingListKind = 2
        } else if rlElemKindTbl[fslot] == 1 {
          pendingListKind = 1
        } else {
          // A NESTED-element ref-list field (element kind 9 a nested ref array, or a scalar-2D inner): the
          // value is a ref list built THROUGH this slot, like a `<ref-array>[]` local binding
          // (`pendingListKind` 5). `pendingListKind` 1 (struct) mis-built array elements as structs →
          // invalid wasm (the construct-side hole for `{f: (i32|null)[][]}` / `{f: {g:i32}[][]}`).
          pendingListKind = 5
        }
      } else if scode == 6 {
        pendingListKind = 3
      } else if scode == 25 {
        pendingListKind = 4 // f64[] field — coerce the value's elements to f64 (`emitArr`)
      } else if scode == 26 {
        pendingListKind = 6 // i64[] field — widen bare-int elements to i64
      } else if scode == 27 {
        pendingListKind = 7 // f32[] field — re-encode float elements at f32
      } else if scode == 28 {
        // A NULLABLE ref-list field value is a list (build it THROUGH the element slot, like code 5) OR a
        // bare `null` -> `ref.null $wrapper` (the `pendingNulRefHeap` seed; a list value ignores it).
        let fslot28 = sFieldRefSlot(si, fi)
        if fslot28 < 0 { fslot28 = 0 }
        pendingListSlot = fslot28
        if rlElemKindTbl[fslot28] == 2 { pendingListKind = 2 }
        else if rlElemKindTbl[fslot28] == 1 { pendingListKind = 1 }
        else { pendingListKind = 5 }
        if fslot28 < rlWrapIdx.length { pendingNulRefHeap = rlWrapIdx[fslot28] }
      }
      // A NESTED-STRUCT field (code 15) seeds the TARGET struct so its literal
      // builds that struct (not a field-shape guess) and a bare `null` value
      // lowers as `ref.null $S`. Saved/restored around the field's own emit.
      const savedPSI = pendingStructIdx
      if scode == 15 {
        pendingStructIdx = structIndexByName(sFieldElemNameAt(si, fi))
      }
      // A MAP-typed field (code 19) seeds `pendingMapSlot` so a `Map()` field
      // value constructs THIS field's value-typed map struct (not the mono map).
      if scode == 19 {
        pendingMapSlot = mvSlotOfValNameFind(sFieldElemNameAt(si, fi))
      }
      // A VALUE-UNION field (code 16) coerces a raw scalar/string/null value into
      // the box (`{ y: 5 }` against `{ y: string | i32 }` boxes the 5 with its
      // atom tag); a union-valued field expression passes through unchanged.
      if scode == 16 {
        if emitUnionCoerce(body, sFieldElemNameAt(si, fi), valIx, fnIx) < 0 {
          return -1
        }
      } else if scode == 17 {
        // An f64 field widens its value at the construction boundary (an int
        // literal into `x: f64` re-encodes; an f64 expression passes through).
        if emitExprAsF64(body, valIx, fnIx) < 0 { return -1 }
      } else if scode == 23 {
        // An i64 field widens a bare-int literal to i64 at the construction boundary.
        if emitExprAsI64(body, valIx, fnIx) < 0 { return -1 }
      } else if scode == 24 {
        // An f32 field re-encodes its float value at the construction boundary.
        if emitExprAsF32(body, valIx, fnIx) < 0 { return -1 }
      } else if scode == 20 {
        // A `string | null` niche field: a `null` value lowers as `ref.null $aTypeIdx`
        // (`pendingNulString`); a non-null string ref passes through.
        const svNS = pendingNulString
        pendingNulString = true
        const rcNS = emitExpr(body, valIx, fnIx)
        pendingNulString = svNS
        if rcNS < 0 { return -1 }
      } else if scode == 21 {
        // A `boolean | null` niche field: a `null` value lowers as the i32 sentinel 2
        // (`pendingNulBool`); a boolean rides its i32 0/1.
        const svNB = pendingNulBool
        pendingNulBool = true
        const rcNB = emitExpr(body, valIx, fnIx)
        pendingNulBool = svNB
        if rcNB < 0 { return -1 }
      } else if scode == 22 {
        // A nullable-closure field (`op: ((i32) => i32) | null`): a `null` value lowers
        // as `ref.null $cloStruct` (`pendingNulClosure`); a function value passes through
        // as the non-null fat pointer (widened to the nullable storage on `struct.new`).
        const svNC = pendingNulClosure
        pendingNulClosure = true
        const rcNC = emitExpr(body, valIx, fnIx)
        pendingNulClosure = svNC
        if rcNC < 0 { return -1 }
      } else if scode == 3 && exprIsLitAtom(valIx, fnIx) {
        // A literal-union atom in a `string` field (code 3) widens to its member string.
        if emitAtomToStr(body, valIx, fnIx) < 0 { return -1 }
      } else {
        if emitExpr(body, valIx, fnIx) < 0 { return -1 }
      }
      if scode == 15 { pendingStructIdx = savedPSI }
      if scode == 19 {
        pendingMapSlot = -1 // a non-`Map()` value never consumed it
      }
      pendingListKind = 0
      fi = fi + 1
    }
    fbStructNew(sHeapIdx[si]) // 0xfb 0x00 <heap-type index>
    return 0
  }
  emitFail("emitProgram: expected an object literal")
}

// ── function-value construction (lambdas) ─────────────────────────────────────
// Emit a function VALUE for the lifted function at `fnStmts` position `fe`: the closure
// fat-pointer `struct.new $cloStruct [ ref.func $(gImports+fe), env, id ]`. The env is
// True if lifted function `fe` has any UN-ANNOTATED parameter — a generic (its un-annotated param
// is a per-call-site inference hole). Such a function monomorphizes per direct call but i32-defaults
// when taken as a VALUE, so the value site rejects it.
function fnHasUnannotatedParam(fe: i32) {
  if fe < 0 || fe >= fnStmts.length { return false }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    const ps = fn.fnParams
    let i = 0
    while i < ps.length {
      const p = P.nodes[ps[i]]
      if p is Param {
        if p.parType < 0 { return true }
      }
      i = i + 1
    }
  }
  false
}

// Does `name` appear as a VALUE — any position OTHER than the callee of a direct `name(...)`
// call — anywhere in the subtree at `ix`? A generic function value bound to `name` (`const g
// = f`) is sound to emit only when every use is a direct call: `monomorphize` rewrites each
// `g(args)` to its per-call instance, so the stored closure is `call_ref`'d only at the type
// its slot was pinned to. A value-USE (an argument, a return, an array element) escapes to a
// `call_ref` whose type the binding cannot guarantee. Mirrors `monoWalk`'s node coverage.
function nameUsedAsValueIn(name: string, ix: i32) {
  if ix < 0 { return false }
  const n = P.nodes[ix]
  if n is Ident { return n.identName == name }
  if n is Call {
    const callee = P.nodes[n.callFn]
    let direct = false
    if callee is Ident {
      if callee.identName == name { direct = true }
    }
    if !direct {
      if nameUsedAsValueIn(name, n.callFn) { return true }
    }
    const args = n.callArgs
    let i = 0
    while i < args.length {
      if nameUsedAsValueIn(name, args[i]) { return true }
      i = i + 1
    }
    return false
  }
  if n is Block {
    const bs = n.blkStmts
    let i2 = 0
    while i2 < bs.length {
      if nameUsedAsValueIn(name, bs[i2]) { return true }
      i2 = i2 + 1
    }
    return false
  }
  if n is LetDecl { return nameUsedAsValueIn(name, n.letInit) }
  if n is IfStmt {
    if nameUsedAsValueIn(name, n.ifCond) { return true }
    if nameUsedAsValueIn(name, n.ifThen) { return true }
    return nameUsedAsValueIn(name, n.ifElse)
  }
  if n is WhileStmt {
    if nameUsedAsValueIn(name, n.whileCond) { return true }
    return nameUsedAsValueIn(name, n.whileBody)
  }
  if n is ForRange {
    if nameUsedAsValueIn(name, n.frFrom) { return true }
    if nameUsedAsValueIn(name, n.frTo) { return true }
    if nameUsedAsValueIn(name, n.frStep) { return true }
    return nameUsedAsValueIn(name, n.frBody)
  }
  if n is ForIn {
    if nameUsedAsValueIn(name, n.fiIter) { return true }
    return nameUsedAsValueIn(name, n.fiBody)
  }
  if n is RetStmt { return nameUsedAsValueIn(name, n.retArg) }
  if n is BinExpr {
    if nameUsedAsValueIn(name, n.binLeft) { return true }
    return nameUsedAsValueIn(name, n.binRight)
  }
  if n is Unary { return nameUsedAsValueIn(name, n.unArg) }
  if n is Paren { return nameUsedAsValueIn(name, n.parInner) }
  if n is Member { return nameUsedAsValueIn(name, n.memObj) }
  if n is OptMember { return nameUsedAsValueIn(name, n.omObj) }
  if n is Index {
    if nameUsedAsValueIn(name, n.idxArr) { return true }
    return nameUsedAsValueIn(name, n.idxIndex)
  }
  if n is IsExpr { return nameUsedAsValueIn(name, n.isObj) }
  if n is ArrayLit {
    const es = n.arrElems
    let i3 = 0
    while i3 < es.length {
      if nameUsedAsValueIn(name, es[i3]) { return true }
      i3 = i3 + 1
    }
    return false
  }
  if n is ObjLit {
    const fs = n.objFields
    let i4 = 0
    while i4 < fs.length {
      const f = P.nodes[fs[i4]]
      if f is FieldInit {
        if nameUsedAsValueIn(name, f.fiValue) { return true }
      }
      i4 = i4 + 1
    }
    return false
  }
  false
}

// `ref.null struct` for a non-capturing function, else a `struct.new $envStruct` of the
// captured values, each READ in the enclosing frame `fnIx` (so a capture of `n` emits a
// `local.get` of `n` in the maker's frame). The id is the lifted function's wasm index
// (`gImports + fe`) — the `==` identity token. Mirrors the host's `closureValue`.
function emitClosureValue(body: i32[], fe: i32, fnIx: i32) {
  // SOUNDNESS FLOOR: a GENERIC function (un-annotated parameters) taken as a VALUE emits its
  // params at the i32 DEFAULT (`vtKindOfParam(-1)` → 0), so the value is only callable at i32 —
  // `g(2.5, …)` / `g("x", …)` then `ref.cast`s the funcref to the wrong functype (invalid wasm),
  // and even the i32 case only "works" by coincidence. A function VALUE must be monomorphic. A
  // `const g = f` binding whose `g` is used ONLY as a direct-call callee IS sound (each `g(args)`
  // is monomorphized per call site, so the closure is `call_ref`'d only at the type its slot was
  // pinned to) — that case routes through `emitClosureValueCore` directly (the LetDecl emit),
  // skipping this floor. Every OTHER value-use (passed as an argument, returned, stored in an
  // array) escapes to a `call_ref` whose type the binding can't guarantee, and lands here: reject
  // (annotate its parameters, or call it directly by name). NAMED source functions only: a lifted
  // LAMBDA with un-annotated params is either checker-rejected (a bare uninferable binding) or
  // cloned/contextually-pinned per use (a `.map`/`.filter` callback), so its i32 default is sound
  // — `criFnIsAnonLambda` excludes it.
  if fnHasUnannotatedParam(fe) {
    if !criFnIsAnonLambda(fe) {
      return emitFail(
        "emitProgram: cannot take a generic function (un-annotated parameters) as a value — its " +
          "parameters would default to i32; annotate them, or call it directly by name",
      )
    }
  }
  return emitClosureValueCore(body, fe, fnIx)
}

// The closure-value emission WITHOUT the un-annotated-param floor — the `cloSigKeyExt`
// representability floor still applies (even a sound direct-call-only binding is `call_ref`'d,
// so its env-leading signature must be representable). Reached either through `emitClosureValue`
// (after its floor) or directly from the LetDecl emit for a monomorphized direct-call-only alias.
function emitClosureValueCore(body: i32[], fe: i32, fnIx: i32) {
  if fe < 0 || fe >= fnStmts.length {
    return emitFail("emitProgram: function value with no lifted function")
  }
  // SOUNDNESS FLOOR: a function whose env-leading signature is not representable as a
  // closure `$fnsig` (`cloSigKeyExt` returns "" — a nullable-ref or map PARAMETER/result;
  // i64/f32 are now in the ABI) cannot be soundly `call_ref`'d: the call site would
  // fall back to the all-i32 arity functype and `ref.cast` the funcref to the WRONG type,
  // trapping wasm validation. Reject at the value site with a clear, source-located
  // message instead of emitting invalid wasm (mirrors the inferred-union-return floor).
  if cloSigKeyExt(fe) == "" {
    return emitFail(
      "emitProgram: a function value's signature is not yet supported — a function " +
        "value may not take a nullable or map parameter (or return one); annotate and " +
        "call it as a named function instead",
    )
  }
  // field 0: the typed funcref to the lifted function (imports occupy 0..gImports-1).
  fbRefFunc(gImports + fe)
  // field 1: the env. Non-capturing → null; capturing → a fresh env struct.
  const envIdx = fnEnvIdxOf(fe)
  if envIdx < 0 {
    fbRefNullStruct()
  } else {
    const caps = captureNamesOf(fe)
    let ci = 0
    while ci < caps.length {
      // Read each captured variable in the ENCLOSING frame. The capture's value is its
      // current local/param/global value at the point the closure is created.
      if emitCaptureRead(body, caps[ci], fnIx) < 0 { return -1 }
      ci = ci + 1
    }
    fbStructNew(envIdx)
  }
  // field 2: the identity token — the lifted function's wasm index.
  fbI32Const(gImports + fe)
  fbStructNew(cloStructIdx)
  0
}

// If `name` is a CAPTURED variable of the capturing lifted function currently being
// emitted (`fnIx`), emit a read of it from the env struct and return 1; else return 0
// (the caller falls through to the normal param/local/global path). The env rides as
// the leading `structref` param at local 0; recover the concrete env struct with
// `ref.cast`, then `struct.get` the field at the capture's index. Mirrors the host's
// captured-Name lowering.
function emitCapturedRead(body: i32[], name: string, fnIx: i32) {
  if fnIx < 0 { return 0 }
  if !fnValUsed { return 0 }
  let fe = fnStmtsPosOf(fnIx)
  if fe < 0 { return 0 }
  const envIdx = fnEnvIdxOf(fe)
  if envIdx < 0 { return 0 }
  const caps = captureNamesOf(fe)
  let ci = 0
  while ci < caps.length {
    if caps[ci] == name {
      // (ref.cast (ref $env) (local.get 0)) then struct.get $env ci.
      fbLocalGet(0)     // the leading env param (structref)
      fbRefCast(envIdx) // 0xfb 0x16 <env heap> ref.cast — narrow to this env
      fbStructGet(envIdx, ci)
      return 1
    }
    ci = ci + 1
  }
  0
}

// Read a captured variable `name` in the enclosing frame `fnIx` for the env struct
// build. A param/local is a `local.get`; a module global a `global.get`. (Captures of
// globals/top-level functions are excluded by capture analysis, so this only sees
// params/locals of the maker.)
function emitCaptureRead(body: i32[], name: string, fnIx: i32) {
  const idx = localIndexOf(fnIx, name)
  if idx >= 0 {
    fbLocalGet(idx)
    return 0
  }
  const gIdx = globalIndexOf(name)
  if gIdx >= 0 {
    fbGlobalGet(gIdx)
    return 0
  }
  emitFail("emitProgram: captured variable not found in enclosing frame")
}

// ── union value construction + discrimination + narrowing (G1) ────────────────

// Lower the VARIANT-PAYLOAD struct for an object literal `{ f: v, … }` matching union
// variant `vi`: push each field value in the variant's DECLARATION field order, then
// `struct.new $<uVarIdx + vi>`. (No box yet — `emitUnionBox` wraps this.)
function emitVariantStruct(body: i32[], objIx: i32, vi: i32, fnIx: i32) {
  let start = uFieldStart[vi]
  let cnt = uFieldCount[vi]
  let fj = 0
  while fj < cnt {
    const valIx = objFieldVal(objIx, uFieldNames[start + fj])
    if valIx < 0 {
      return emitFail("emitProgram: object literal is missing a union-variant field")
    }
    // An empty `[]` literal for a ref-list (code 5) / string-list (code 6) variant field
    // needs its element kind threaded (the same `pendingListKind` an annotated `let`
    // uses): a struct/union ref list (1/2) or a string list (3).
    pendingListKind = 0
    pendingListSlot = 0
    const vcode = variantFieldTypeAt(vi, fj)
    if vcode == 5 {
      let vslot = variantFieldRefSlot(vi, fj)
      if vslot < 0 { vslot = 0 }
      pendingListSlot = vslot
      if rlElemKindTbl[vslot] == 2 {
        pendingListKind = 2
      } else {
        pendingListKind = 1
      }
    } else if vcode == 6 {
      pendingListKind = 3
    }
    if emitExpr(body, valIx, fnIx) < 0 { return -1 }
    pendingListKind = 0
    fj = fj + 1
  }
  fbStructNew(uVarIdx + vi) // 0xfb 0x00 <variant struct heap-type index>
  0
}

// Lower an object literal `{ f: v, … }` BOXED into the declared union onto `body`:
//   struct.new $box (i32.const tagOf(variant)) (struct.new $variant <fields…>)
// i.e. push the variant's global tag, build the variant payload struct, then
// `struct.new $uBoxIdx` to wrap `{ tag, value }`. The literal must match exactly one
// union variant's field-name set, else fails loudly.
function emitUnionBox(body: i32[], objIx: i32, fnIx: i32) {
  const vname = objVariantName(objIx)
  if vname == "" {
    return emitFail("emitProgram: object literal matches no union variant")
  }
  let vi = variantIndexOf(vname)
  // tag first (struct field 0 of the box), then the boxed payload (field 1).
  fbI32Const(uTags[vi]) // 0x41 i32.const <tag>
  if emitVariantStruct(body, objIx, vi, fnIx) < 0 { return -1 }
  fbStructNew(uBoxIdx)  // 0xfb 0x00 <union box heap-type index>
  0
}

// Lower a type guard `recv is Variant` onto `body` as the box-tag compare (mirroring
// `toWasm.ts`): evaluate the receiver (a union box), `struct.get $box 0` (the tag),
// then `i32.const tagOf(Variant)` and `i32.eq` — leaving a 0/1 i32 (an `if` condition).
function emitIs(body: i32[], isIx: i32, fnIx: i32) {
  // `p is null` over a NULLABLE struct ref — `ref.is_null` (no union needed).
  const nd0 = P.nodes[isIx]
  if nd0 is IsExpr {
    if nd0.isVariant == "null" {
      if exprNullableStruct(nd0.isObj, fnIx) {
        if emitExpr(body, nd0.isObj, fnIx) < 0 { return -1 }
        wU8(209) // 0xd1 ref.is_null
        return 0
      }
    }
    // `p is { x: i32 }` / `p is S` over a NICHE nullable struct (`S | null` — one
    // struct member, a nullable REF not a box): the checker already proved the
    // tested shape matches the struct member, so the only runtime distinction is
    // null vs non-null — the test lowers to `!ref.is_null` (host: the nullable's
    // non-null narrowing test).
    if nd0.isVariant != "null" {
      if exprNullableStruct(nd0.isObj, fnIx) {
        if emitExpr(body, nd0.isObj, fnIx) < 0 { return -1 }
        wU8(209)   // 0xd1 ref.is_null
        fbI32Eqz() // 0x45 → non-null
        return 0
      }
    }
  }
  // `x is i32` / `x is string` / … over a BOXED value union: the same box-tag
  // compare as a struct variant, against the atom's globally-stable scalar tag.
  const ndv = P.nodes[isIx]
  if ndv is IsExpr {
    if valueAtomKind(ndv.isVariant) >= 0 {
      // A union-typed IDENT receiver pushes its RAW box slot directly — even
      // when an outer arm has already narrowed it to a single atom (the last
      // `else if x is boolean` of an exhaustive chain), where the narrowed
      // Ident read would unbox instead of yielding the box.
      const vrecv = P.nodes[unwrapParen(ndv.isObj)]
      if vrecv is Ident {
        if unionNameOfIdent(vrecv.identName, fnIx) != "" {
          if emitUnionBoxPush(body, vrecv.identName, fnIx) < 0 { return -1 }
          fbStructGet(uBoxIdx, 0) // 0xfb 0x02 <box ht> field 0: tag
          fbI32Const(scalarTagOf(ndv.isVariant))
          fbI32Bin(70)            // 0x46 i32.eq
          return 0
        }
      }
      // `o.y is i32` over a UNION-typed struct FIELD (code 16): read the field's
      // box (recovering a nullable receiver first) and compare its tag — the
      // member-path narrowing's runtime test.
      if vrecv is Member {
        if memberUnionFieldName(unwrapParen(ndv.isObj), fnIx) != "" {
          const msi = structIndexOfExpr(vrecv.memObj, fnIx)
          let mfi = sFieldIndex(msi, vrecv.memProp)
          if emitExpr(body, vrecv.memObj, fnIx) < 0 { return -1 }
          if exprNullableStruct(vrecv.memObj, fnIx) {
            wU8(212) // 0xd4 ref.as_non_null
          }
          fbStructGet(sHeapIdx[msi], mfi) // the field's box
          fbStructGet(uBoxIdx, 0)         // field 0: tag
          fbI32Const(scalarTagOf(ndv.isVariant))
          fbI32Bin(70)                    // 0x46 i32.eq
          return 0
        }
      }
      // `x?.y is i32` — an OPTIONAL-CHAIN receiver folds its null test into the
      // result: any null link → false (the host's chain yields `null`, and
      // `null is i32` is false), else the union FIELD's box-tag compare.
      if vrecv is OptMember {
        const oisSi = optChainStructIdxOf(vrecv.omObj, fnIx)
        if oisSi >= 0 {
          const oisFi = sFieldIndex(oisSi, vrecv.omProp)
          if oisFi >= 0 {
            if sFieldTypeAt(oisSi, oisFi) == 16 {
              if emitOptChainIsNull(body, vrecv.omObj, fnIx) < 0 { return -1 }
              fbIf(127)                           // a null link → false
              ctrlEnter()
              fbI32Const(0)
              fbElse()
              if emitOptChainValue(body, vrecv.omObj, fnIx) < 0 { return -1 }
              fbStructGet(sHeapIdx[oisSi], oisFi) // the field's box
              fbStructGet(uBoxIdx, 0)             // field 0: tag
              fbI32Const(scalarTagOf(ndv.isVariant))
              fbI32Bin(70)                        // 0x46 i32.eq
              fbEnd()
              ctrlLeave()
              return 0
            }
          }
        }
      }
      if exprUnion(ndv.isObj, fnIx) {
        if emitExpr(body, ndv.isObj, fnIx) < 0 { return -1 }
        fbStructGet(uBoxIdx, 0) // 0xfb 0x02 <box ht> field 0: tag
        fbI32Const(scalarTagOf(ndv.isVariant))
        fbI32Bin(70)            // 0x46 i32.eq
        return 0
      }
    }
  }
  // `v is <literal>` over a SOFTENED scalar: a same-base literal union rides
  // its base scalar after `canonEmitTypeNames` (`"a" | "b"` a string, `0 | 1`
  // an i32, `1.5 | 2.5` an f64), so the `is` is a runtime VALUE test — the
  // same lowering as `v == <literal>` (string value-equality / numeric eq).
  // A literal `is` over a still-BOXED mixed-rep union (`"a" | "b" | 1`) is the
  // tag-gated payload compare (`emitUnionLitIs`) — same-rep literals share a
  // tag, so the tag alone cannot discriminate them.
  if nd0 is IsExpr {
    const lv = nd0.isVariant
    if isLitVariantName(lv) {
      if exprUnion(nd0.isObj, fnIx) {
        return emitUnionLitIs(body, nd0.isObj, lv, fnIx)
      }
      if !exprUnion(nd0.isObj, fnIx) {
        if lv[0] == '"' {
          // The variant lexeme IS a raw quoted string lexeme (quotes kept,
          // escapes unresolved — the same shape a `StrLit.strText` carries),
          // so a synthesized `StrLit` node lowers it; then the value-eq core.
          if !aUsed {
            return emitFail("emitProgram: string `is` test but array type not collected")
          }
          if emitExpr(body, nd0.isObj, fnIx) < 0 { return -1 }
          if emitExpr(body, mkStr(lv, -1), fnIx) < 0 { return -1 }
          return emitStrEqCore(body)
        }
        if emitExpr(body, nd0.isObj, fnIx) < 0 { return -1 }
        if numTextIsFloat(lv) {
          fbF64Const(lv)
          fbI32Bin(97) // 0x61 f64.eq
          return 0
        }
        if exprIsI64(nd0.isObj, fnIx) || !numLexFitsI32(lv) {
          const pr = parseI64Pair(lv)
          fbI64Const(pr[0], pr[1])
          fbI32Bin(81) // 0x51 i64.eq
          return 0
        }
        fbI32Const(parseI32(lv))
        fbI32Bin(70) // 0x46 i32.eq
        return 0
      }
    }
  }
  // STATIC `is` over a NON-union operand against a base TYPE NAME (`x is i32`,
  // `x is string`) — the monomorphized-generic-param guard. Each instance pins
  // the param to one concrete type, so the test is decided AT COMPILE TIME per
  // instance and lowers to a constant (host parity: `is T` on a generic param
  // is resolved statically per monomorphized call site, so calls don't
  // cross-contaminate). Union-typed operands took the tag-compare paths above;
  // a declared VARIANT name keeps the loud union-only failure below.
  if nd0 is IsExpr {
    if variantIndexOf(nd0.isVariant) < 0 {
      if !exprUnion(nd0.isObj, fnIx) {
        const sk = monoArgTyName(nd0.isObj, fnIx)
        if sk != "" {
          if sk == nd0.isVariant { fbI32Const(1) } else { fbI32Const(0) }
          return 0
        }
      }
    }
  }
  // `f is (A) => B` over a NULLABLE-closure operand (`f: ((i32) => i32) | null`) is a NON-NULL
  // test — the closure-typed `is` form of `f != null`. Calling `f(x)` in the then-branch
  // already ref-casts the nullable value to non-null, so no narrowing key is needed.
  if nd0 is IsExpr {
    if strContains(nd0.isVariant, "=>") {
      if exprNulClosure(nd0.isObj, fnIx) {
        if emitExpr(body, nd0.isObj, fnIx) < 0 { return -1 }
        wU8(209)   // 0xd1 ref.is_null
        fbI32Eqz() // invert: non-null
        return 0
      }
    }
  }
  if !uDeclared {
    return emitFail("emitProgram: `is` test but no union type declared")
  }
  const nd = P.nodes[isIx]
  if nd is IsExpr {
    let vi = variantIndexOf(nd.isVariant)
    if vi < 0 {
      return emitFail("emitProgram: `is` names a type that is not a union variant")
    }
    // A CONCRETE-variant receiver (`f0 is Dog` where `f0: Dog`, e.g. a collapsed `.map`
    // element): the value IS exactly one variant, so the test folds to a compile-time
    // constant (no box to tag-compare). Checked before the union-receiver requirement.
    const rvi = exprVariantIndex(nd.isObj, fnIx)
    if rvi >= 0 {
      if rvi == vi { fbI32Const(1) } else { fbI32Const(0) }
      return 0
    }
    if !exprUnion(nd.isObj, fnIx) {
      return emitFail("emitProgram: `is` receiver is not a union value")
    }
    if emitExpr(body, nd.isObj, fnIx) < 0 { return -1 }
    fbStructGet(uBoxIdx, 0) // 0xfb 0x02 <box ht> field 0: tag
    fbI32Const(uTags[vi])   // 0x41 i32.const <tag>
    fbI32Bin(70)            // 0x46 i32.eq
    return 0
  }
  emitFail("emitProgram: expected an `is` expression")
}

// Lower a narrowed field read `recv.field` where `recv` is a union value narrowed (by
// an enclosing `if recv is Variant`) to `narrowVariant`. The downcast mirrors
// `toWasm.ts`: evaluate the box, `struct.get $box 1` (the `anyref` value), `ref.cast
// (ref $variant)` to recover the payload, then `struct.get $variant <fieldIdx>`.
//   ref.cast is `0xfb 0x16 <heaptype>` (non-null target — the box value is never null).
function emitNarrowedMem(body: i32[], memIx: i32, fnIx: i32) {
  const m = P.nodes[memIx]
  if m is Member {
    // Resolve the variant from the RECEIVER's own active narrowing (not a global slot) —
    // so two simultaneously-narrowed locals each downcast to THEIR variant.
    let recvVar = ""
    const recvN = P.nodes[m.memObj]
    if recvN is Ident { recvVar = narrowVariantFor(recvN.identName) }
    // A nested union-FIELD receiver (`t.v.a`): resolve the variant from its path key.
    if recvN is Member {
      const pk = memberPathKeyOf(m.memObj)
      if pk != "" { recvVar = narrowVariantFor(pk) }
    }
    let vi = variantIndexOf(recvVar)
    if vi < 0 {
      return emitFail("emitProgram: narrowed receiver names no union variant")
    }
    const idx = variantFieldIndex(vi, m.memProp)
    if idx < 0 {
      return emitFail("emitProgram: unknown variant field in narrowed field access")
    }
    if emitExpr(body, m.memObj, fnIx) < 0 { return -1 }
    fbStructGet(uBoxIdx, 1)        // 0xfb 0x02 <box ht> field 1: value (anyref)
    fbRefCast(uVarIdx + vi)        // 0xfb 0x16 <variant struct> ref.cast (non-null)
    fbStructGet(uVarIdx + vi, idx) // 0xfb 0x02 <variant struct ht> <field index>
    return 0
  }
  emitFail("emitProgram: expected a field access")
}

// ── optional chains over niche nullable structs (`o?.inner?.v`) ───────────────
// Every link is an effect-free place (an Ident root + field reads), so the chain
// is re-evaluated instead of spilling to a scratch local — mirroring the host's
// temp-local OptionalAccess only in VALUE, not in shape.

// The struct TABLE index of an optional-chain RECEIVER's value: an `a?.b` link
// resolves its field's TARGET struct (a code-15 nested-struct field); any other
// receiver resolves through the normal classifier. -1 when unresolvable.
// True if `exprIx` is a re-readable PLACE — a bare name, or a member chain bottoming out in a
// name (`n`, `n.next`, `a.b.c`). Such a receiver is an effect-free `local.get`/`struct.get`, so
// `recv?.f ?? d` may read it twice (the null test + the field) without double side effects.
function optRecvReReadable(exprIx: i32) {
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Ident { return true }
  if e is Member { return optRecvReReadable(e.memObj) }
  false
}

function optChainStructIdxOf(exprIx: i32, fnIx: i32) {
  const e = P.nodes[unwrapParen(exprIx)]
  if e is OptMember {
    const psi = optChainStructIdxOf(e.omObj, fnIx)
    if psi < 0 { return -1 }
    const pfi = sFieldIndex(psi, e.omProp)
    if pfi < 0 { return -1 }
    if sFieldTypeAt(psi, pfi) != 15 { return -1 }
    return structIndexByName(sFieldElemNameAt(psi, pfi))
  }
  structIndexOfExpr(exprIx, fnIx)
}

// Push 1 if the optional-chain VALUE at `exprIx` is null — any null link folds
// `null` through (the host's OptionalAccess) — else 0. A code-15 leaf field tests
// its own ref; a code-16 (value-union box) leaf compares the box tag against the
// global null tag (the box ref itself is never null); any other leaf is never
// null once every link held.
function emitOptChainIsNull(body: i32[], exprIx: i32, fnIx: i32) {
  const e = P.nodes[unwrapParen(exprIx)]
  if e is OptMember {
    const psi = optChainStructIdxOf(e.omObj, fnIx)
    if psi < 0 {
      return emitFail("emitProgram: `?.` receiver is not a struct chain")
    }
    const pfi = sFieldIndex(psi, e.omProp)
    if pfi < 0 {
      return emitFail("emitProgram: `?.` field is not on the struct")
    }
    if emitOptChainIsNull(body, e.omObj, fnIx) < 0 { return -1 }
    fbIf(127) // 0x04 if, i32 result — receiver null → 1
    ctrlEnter()
    fbI32Const(1)
    fbElse()
    const pfc = sFieldTypeAt(psi, pfi)
    if pfc == 15 {
      if emitOptChainValue(body, e.omObj, fnIx) < 0 { return -1 }
      fbStructGet(sHeapIdx[psi], pfi) // the (ref null $S) field
      wU8(209)                        // 0xd1 ref.is_null
    } else if pfc == 16 {
      if emitOptChainValue(body, e.omObj, fnIx) < 0 { return -1 }
      fbStructGet(sHeapIdx[psi], pfi) // the field's union box (non-null ref)
      fbStructGet(uBoxIdx, 0)         // box field 0: tag
      fbI32Const(scalarTagOf("null"))
      fbI32Bin(70)                    // 0x46 i32.eq
    } else {
      fbI32Const(0) // a non-nullable field is never null past its links
    }
    fbEnd()
    ctrlLeave()
    return 0
  }
  if emitExpr(body, exprIx, fnIx) < 0 { return -1 }
  wU8(209) // 0xd1 ref.is_null
  0
}

// Push the NON-NULL value of the optional-chain receiver at `exprIx` (assumes
// every link was already null-tested): each nullable link recovers
// `ref.as_non_null` so the next `struct.get` sees a non-null ref.
function emitOptChainValue(body: i32[], exprIx: i32, fnIx: i32) {
  const e = P.nodes[unwrapParen(exprIx)]
  if e is OptMember {
    const psi = optChainStructIdxOf(e.omObj, fnIx)
    if psi < 0 {
      return emitFail("emitProgram: `?.` receiver is not a struct chain")
    }
    const pfi = sFieldIndex(psi, e.omProp)
    if pfi < 0 {
      return emitFail("emitProgram: `?.` field is not on the struct")
    }
    if emitOptChainValue(body, e.omObj, fnIx) < 0 { return -1 }
    fbStructGet(sHeapIdx[psi], pfi)
    fbRefAsNonNull() // 0xd4 — the link was null-tested
    return 0
  }
  if emitExpr(body, exprIx, fnIx) < 0 { return -1 }
  if exprNullableStruct(exprIx, fnIx) {
    fbRefAsNonNull() // 0xd4
  }
  0
}

// Push the RAW union box ref of the binding `name` (a local/param or a module
// global) — bypassing the narrowed-unbox Ident path, so a tag read works even
// while the binding is narrowed to a single atom (its slot still holds the box;
// narrowing is type-level only).
function emitUnionBoxPush(body: i32[], name: string, fnIx: i32) {
  const idx = localIndexOf(fnIx, name)
  if idx >= 0 {
    fbLocalGet(idx)
  } else {
    const gIdx = globalIndexOf(name)
    if gIdx < 0 {
      // A captured VALUE-union (`i32 | string`) narrowed-atom read is not yet wired (the unbox
      // would read off the env) — a clean reject, not invalid wasm. Captured STRUCT-unions,
      // strings, and nullable structs DO work (their reads route through the ref env field).
      return emitFail("emitProgram: narrowed union binding is not a local or global")
    }
    fbGlobalGet(gIdx)
    // A non-const global box rides in a NULLABLE cell (start-fn initialized);
    // recover the non-null box ref (same as the plain Ident global read).
    if globalNameIsNonConst(name) {
      wU8(212) // 0xd4 ref.as_non_null
    }
  }
  0
}

// Lower a narrowed VALUE-union ident read `name` (active narrowing = the single
// scalar atom `atom`): push the box (a local/param or a module global), then
// `struct.get $box 1` (the `anyref` payload) and recover the atom's rep — a
// `ref.cast (ref $aTypeIdx)` for a string payload (stored unboxed), or a
// `ref.cast (ref $vb)` + `struct.get $vb 0` for a scalar in its value box.
// The list WRAPPER heap type a value-union LIST atom's box payload is (a `string[]` →
// `$mkListIdx`, `i32[]`/`boolean[]` → `$lTypeIdx`, `f64[]` → `$fl64TypeIdx`, `i64[]` →
// `$il64TypeIdx`), or -1 if `atom` is not a list type. A list member rides the box's anyref
// `value` field as this wrapper ref directly (no scalar value box) — the `is`-narrow casts
// to it, the coerce stores it.
function atomListWrapHeap(atom: string) {
  if atom == "i32[]" || atom == "boolean[]" { return lTypeIdx }
  if atom == "f64[]" { return fl64TypeIdx }
  if atom == "string[]" { return mkListIdx }
  if atom == "i64[]" { return il64TypeIdx }
  -1
}

// True if a value-union ATOM is a REF that rides the box's anyref `value` directly with no
// per-rep scalar value box: a string, or any list type.
function atomIsRef(atom: string) {
  if atom == "string" { return true }
  return atomListWrapHeap(atom) >= 0
}

function emitValueUnionUnboxRead(
  body: i32[],
  name: string,
  atom: string,
  fnIx: i32,
) {
  if emitUnionBoxPush(body, name, fnIx) < 0 { return -1 }
  fbStructGet(uBoxIdx, 1) // 0xfb 0x02 <box ht> field 1: value (anyref)
  if atom == "string" {
    fbRefCast(aTypeIdx) // the payload IS the string array ref
    return 0
  }
  const lw = atomListWrapHeap(atom)
  if lw >= 0 {
    fbRefCast(lw) // the payload IS the list WRAPPER ref
    return 0
  }
  const vb = vbHeapIdxOfAtom(atom)
  if vb < 0 {
    return emitFail("emitProgram: narrowed union atom has no value box")
  }
  fbRefCast(vb)      // 0xfb 0x16 <value box>
  fbStructGet(vb, 0) // the scalar payload
  0
}

// Lower the expression at `exprIx` COERCED into the boxed union `unionName`'s
// representation (the host's `coerceToUnion` at a flow boundary — a binding init,
// an assignment, an argument, a return). Pass-through when the value already IS
// the box (a union-typed ident / call, including a sub-union narrowing); a bare
// `null` boxes as the null tag with a `ref.null` payload (any boxed union — a
// value union OR a struct union with a `null` member); a raw scalar/string boxes
// as its atom's tag + payload. A struct union's object literal falls through to
// the normal lowering (`emitUnionBox` boxes it via the `uDeclared` path).
function emitUnionCoerce(
  body: i32[],
  unionNameIn: string,
  exprIx: i32,
  fnIx: i32,
) {
  // Resolve a union ALIAS (`type Tagged = {x:i32} | string`) to its pipe-joined member set
  // so the value-atom boxing below (`unionHasValueAtom`/`unionHasAtom`/the atom ladder) sees
  // the atoms — an alias name has no `|` to split. An INLINE union name (already a member
  // set) and a non-union name resolve to "" and pass through unchanged.
  let unionName = unionNameIn
  const ums = unionMemberSetOf(unionName)
  if ums != "" { unionName = ums }
  if exprUnion(exprIx, fnIx) { return emitExpr(body, exprIx, fnIx) }
  const bareIx = unwrapParen(exprIx)
  const bare = P.nodes[bareIx]
  // An if-EXPRESSION join (`return if c { catVal } else { dogVal }`): each arm is a distinct
  // union member (a variant struct, a passed-through union, a scalar), so the join can't ride
  // a single numeric blocktype — emit a value-typed `if` whose result IS the union box,
  // union-coercing each arm. Without this the join defaults to an i32 blocktype over ref arms
  // (invalid wasm — a pre-existing gap that hits named functions too).
  if bare is IfStmt { return emitUnionIfValue(body, unionName, bareIx, fnIx) }
  if bare is NullLit {
    fbI32Const(scalarTagOf("null"))
    fbRefNullNone() // the payload slot is unread under the null tag
    fbStructNew(uBoxIdx)
    return 0
  }
  // A STRUCT value (an object literal, or a struct-typed expr) auto-boxes through
  // `emitExpr`'s `uDeclared` variant path; only a SCALAR value is value-boxed below.
  // This is what lets a MIXED union (`A | i32`) coerce either kind of member: an object
  // arm boxes as a variant struct, a scalar arm as a value box.
  if bare is ObjLit { return emitExpr(body, exprIx, fnIx) }
  if exprStruct(exprIx, fnIx) { return emitExpr(body, exprIx, fnIx) }
  if unionName == "" || !unionHasValueAtom(unionName) {
    return emitExpr(body, exprIx, fnIx)
  }
  // Classify the value's atom. Order mirrors the print-import ladder (f32 before
  // f64 — a float literal classifies f64 too; string/bool/i64 are disjoint). The
  // default is i32 unless the union has no `i32` member but does have `i64` (an
  // integer flowing into `i64 | …`), or the literal exceeds the i32 range.
  let atom = "i32"
  if exprString(exprIx, fnIx) {
    atom = "string"
  } else if exprStringArray(exprIx, fnIx) {
    atom = "string[]" // a list member rides as a wrapper ref (like a string)
  } else if exprF64Array(exprIx, fnIx) {
    atom = "f64[]"
  } else if exprI64Array(exprIx, fnIx) {
    atom = "i64[]"
  } else if exprArray(exprIx, fnIx) {
    atom = "i32[]"
  } else if exprIsF32(exprIx, fnIx) {
    atom = "f32"
  } else if exprIsF64(exprIx, fnIx) {
    atom = "f64"
  } else if exprIsI64(exprIx, fnIx) {
    atom = "i64"
  } else if exprIsBool(exprIx, fnIx) {
    atom = "boolean"
  } else {
    if !unionHasAtom(unionName, "i32") && unionHasAtom(unionName, "i64") {
      atom = "i64"
    }
    if bare is NumLit {
      if !numLexFitsI32(bare.numText) { atom = "i64" }
    }
  }
  // A float literal types f64 by default, but if the union's float atom is f32 (`f32 | string`,
  // no f64) the literal re-encodes at f32 — pick the f32 atom so it boxes into the f32 value box.
  if (
    atom == "f64" &&
    !unionHasAtom(unionName, "f64") &&
    unionHasAtom(unionName, "f32")
  ) {
    atom = "f32"
  }
  fbI32Const(scalarTagOf(atom))
  if atom == "i64" {
    if emitExprAsI64(body, exprIx, fnIx) < 0 { return -1 }
  } else if atom == "f64" {
    if emitExprAsF64(body, exprIx, fnIx) < 0 { return -1 }
  } else if atom == "f32" {
    const savedF32 = pendingF32
    pendingF32 = true
    if emitExprAsF32(body, exprIx, fnIx) < 0 { return -1 }
    pendingF32 = savedF32
  } else {
    if emitExpr(body, exprIx, fnIx) < 0 { return -1 }
  }
  // A `string` / list member is a REF and rides the box's anyref `value` directly; only a
  // SCALAR atom wraps in its per-rep value box.
  if !atomIsRef(atom) {
    const vb = vbHeapIdxOfAtom(atom)
    if vb < 0 { return emitFail("emitProgram: union atom has no value box") }
    fbStructNew(vb) // wrap the scalar payload
  }
  fbStructNew(uBoxIdx) // { tag, payload }
  0
}

// Coerce an expression into a union-BOX position whose wasm rep is `(ref $uBox)` — a call
// ARGUMENT to a union param, or a RETURN where the return type is the union. A concrete
// VARIANT-struct VALUE (`s: S` passed to a `C | S` param, or returned from a `: C | S`
// function) is a raw `(ref $variant)`: a struct that is a union member is itself allocated as
// a kind-8 variant local (so it narrows in place), but that raw ref does NOT match the boxed
// param/return rep — passing / returning it was invalid wasm ("expected (ref $type), found
// (ref $type)"). Box the existing variant ref into the shared `{tag, payload}` rep, exactly
// as `emitUnionBox` boxes a struct LITERAL (the variant ref IS the payload type the box wants,
// so no field copy is needed). Every other shape — a struct literal, a passed-through union
// value, a scalar atom — defers to `emitUnionCoerce`. This wrapper is used ONLY at box-typed
// positions; a let-init to a union-annotated-but-variant-init local stays a raw kind-8 variant
// and keeps calling `emitUnionCoerce` directly (it must NOT box).
function emitUnionBoxArg(
  body: i32[],
  unionName: string,
  exprIx: i32,
  fnIx: i32,
) {
  if !exprUnion(exprIx, fnIx) {
    const svi = exprVariantIndex(exprIx, fnIx)
    if svi >= 0 {
      fbI32Const(uTags[svi]) // 0x41 i32.const <variant tag> (program-global)
      if emitExpr(body, exprIx, fnIx) < 0 { return -1 }
      fbStructNew(uBoxIdx) // { tag, variant-ref }
      return 0
    }
  }
  emitUnionCoerce(body, unionName, exprIx, fnIx)
}

// Lower an if-EXPRESSION whose VALUE is a union (`if c { A } else { B }` in a union return /
// coerce position) as a value-typed `if` with the union BOX result type, each arm
// union-coerced (`emitUnionCoerce`). Mirrors `emitIfExprAs` (narrowing save/restore, `else
// if` recursion) but the blocktype is the `(ref $uBox)` valtype, not a numeric byte, and arms
// route through `emitUnionCoerce` so a variant-struct / passthrough / scalar arm each boxes to
// the same union rep.
function emitUnionIfValue(
  body: i32[],
  unionName: string,
  ifIx: i32,
  fnIx: i32,
) {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    if s.ifElse < 0 {
      return emitFail("emitProgram: union if-expression requires an else arm")
    }
    if emitExpr(body, s.ifCond, fnIx) < 0 { return -1 }
    wU8(4)           // 0x04 if
    fbValtype(4, -1) // result blocktype: the union box `(ref $uBox)`
    const savedTop = narrowTop
    const narrowed = setNarrowFromCond(s.ifCond, fnIx)
    const rcT = emitUnionIfArm(body, unionName, s.ifThen, fnIx)
    if narrowed { restoreNarrow(savedTop) }
    if rcT < 0 { return -1 }
    fbElse()         // 0x05 else
    const savedElseTop = narrowTop
    const narrowedElse = setNarrowFromCondElse(s.ifCond, fnIx)
    const els = P.nodes[s.ifElse]
    let rc = 0
    if els is IfStmt {
      rc = emitUnionIfValue(body, unionName, s.ifElse, fnIx)
    } else {
      rc = emitUnionIfArm(body, unionName, s.ifElse, fnIx)
    }
    if narrowedElse { restoreNarrow(savedElseTop) }
    if rc < 0 { return -1 }
    fbEnd() // 0x0b end
    return 0
  }
  emitFail("emitProgram: expected a union if-expression")
}

// One arm of a union if-expression: the arm Block's single tail-value statement,
// union-coerced to the box rep (`emitUnionCoerce` — a variant struct boxes, a passthrough
// union rides as-is, a scalar value-boxes).
function emitUnionIfArm(
  body: i32[],
  unionName: string,
  blockIx: i32,
  fnIx: i32,
) {
  let b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    if stmts.length == 1 {
      if stmtIsTailValue(stmts[0], fnIx) {
        // The if-value's result IS the union BOX `(ref $uBox)` (the blocktype), so a CONCRETE-
        // VARIANT arm (`cat`, a kind-8 `(ref $variant)` local/value — `if c then cat else dog`)
        // must be BOXED to match, exactly as a variant return/argument is: `emitUnionBoxArg`
        // boxes a variant ref and defers every other shape (object literal, passthrough union,
        // scalar) to `emitUnionCoerce`. Plain `emitUnionCoerce` emitted the raw variant ref —
        // invalid wasm ("expected (ref $uBox), found (ref $variant)").
        return emitUnionBoxArg(body, unionName, stmts[0], fnIx)
      }
    }
    return emitFail("emitProgram: union if-expression arm is not a single value")
  }
  emitFail("emitProgram: union if-expression arm is not a block")
}

// Coerce the expression at `exprIx` to the CONCRETE variant `vi`'s rep `(ref $(uVarIdx +
// vi))`. The collapse boundary: a `.map` callback typed as one variant whose arms are a
// MIX of reps — an object LITERAL (build the bare variant), a NARROWED union value (`a`
// after `a is Cat`, still a box at the wasm level → unbox: `struct.get $box 1` + `ref.cast`
// to the variant), an already-bare variant (pass through), or a value-`if` join (recurse).
// The variant analogue of `emitUnionCoerce`.
function emitVariantCoerce(body: i32[], vi: i32, exprIx: i32, fnIx: i32) {
  const bareIx = unwrapParen(exprIx)
  const bare = P.nodes[bareIx]
  if bare is IfStmt { return emitVariantIfValue(body, vi, bareIx, fnIx) }
  if bare is ObjLit { return emitVariantStruct(body, bareIx, vi, fnIx) }
  // Already the bare variant struct (a variant param/local/call/index): pass through.
  if exprVariantIndex(exprIx, fnIx) >= 0 { return emitExpr(body, exprIx, fnIx) }
  // A union BOX (a narrowed receiver still boxed at the wasm level): unbox to the variant.
  if exprUnion(exprIx, fnIx) {
    if emitExpr(body, exprIx, fnIx) < 0 { return -1 }
    fbStructGet(uBoxIdx, 1) // field 1: value (anyref)
    fbRefCast(uVarIdx + vi) // 0xfb 0x16 <variant struct> ref.cast (non-null)
    return 0
  }
  emitExpr(body, exprIx, fnIx)
}

// Lower an if-EXPRESSION whose VALUE collapses to the concrete variant `vi` as a value-
// typed `if` with the variant struct result blocktype, each arm variant-coerced. Mirrors
// `emitUnionIfValue` (narrowing save/restore, `else if` recursion).
function emitVariantIfValue(body: i32[], vi: i32, ifIx: i32, fnIx: i32) {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    if s.ifElse < 0 {
      return emitFail("emitProgram: variant if-expression requires an else arm")
    }
    if emitExpr(body, s.ifCond, fnIx) < 0 { return -1 }
    wU8(4)           // 0x04 if
    fbValtype(8, vi) // result blocktype: the variant struct `(ref $(uVarIdx + vi))`
    const savedTop = narrowTop
    const narrowed = setNarrowFromCond(s.ifCond, fnIx)
    const rcT = emitVariantIfArm(body, vi, s.ifThen, fnIx)
    if narrowed { restoreNarrow(savedTop) }
    if rcT < 0 { return -1 }
    fbElse()         // 0x05 else
    const savedElseTop = narrowTop
    const narrowedElse = setNarrowFromCondElse(s.ifCond, fnIx)
    const els = P.nodes[s.ifElse]
    let rc = 0
    if els is IfStmt {
      rc = emitVariantIfValue(body, vi, s.ifElse, fnIx)
    } else {
      rc = emitVariantIfArm(body, vi, s.ifElse, fnIx)
    }
    if narrowedElse { restoreNarrow(savedElseTop) }
    if rc < 0 { return -1 }
    fbEnd() // 0x0b end
    return 0
  }
  emitFail("emitProgram: expected a variant if-expression")
}

function emitVariantIfArm(body: i32[], vi: i32, blockIx: i32, fnIx: i32) {
  let b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    if stmts.length == 1 {
      if stmtIsTailValue(stmts[0], fnIx) {
        return emitVariantCoerce(body, vi, stmts[0], fnIx)
      }
    }
    return emitFail("emitProgram: variant if-expression arm is not a single value")
  }
  emitFail("emitProgram: variant if-expression arm is not a block")
}

// ── union `==`/`!=` (the host's structural-equality union branch) ─────────────
// `==`/`!=` are structural by value, so a still-BOXED value-union operand
// compares by "does the box's tag select the arm whose rep matches the other
// side, AND does the unboxed payload value-equal it". The tag compare GATES the
// payload compare (the payload `ref.cast` would trap on a wrong-rep arm), as a
// value-typed `if` (blocktype 0x7f) — the same short-circuit `toWasm.ts` folds.
// REPRESENTATION NOTE: the host hoists each box into a fresh local so the tag
// read and the payload read share one evaluation; this emitter RE-EVALUATES the
// operand instead (the established struct-`==` re-evaluation pattern), so a
// union operand is restricted to a simple BINDING read — re-reading an ident is
// effect-free and yields the same box. Anything effectful fails loudly.

// Unbox a union payload already pushed as `anyref` (`struct.get $box 1`) to the
// atom's rep: a string payload IS the string array (cast only); a scalar rides
// its per-rep value box (cast + field 0). Mirrors `emitValueUnionUnboxRead`.
function emitUnionPayloadUnbox(body: i32[], atom: string) {
  if atom == "string" {
    fbRefCast(aTypeIdx) // the payload IS the string array ref
    return 0
  }
  const vb = vbHeapIdxOfAtom(atom)
  if vb < 0 { return emitFail("emitProgram: union `==` atom has no value box") }
  fbRefCast(vb)      // 0xfb 0x16 <value box>
  fbStructGet(vb, 0) // the scalar payload
  0
}

// The union ATOM the concrete (non-box) side of a union `==` compares under —
// the same rep ladder `emitUnionCoerce` classifies a coerced value with.
function unionEqAtomOf(otherIx: i32, unionName: string, fnIx: i32) {
  let atom = "i32"
  if exprString(otherIx, fnIx) {
    atom = "string"
  } else if exprIsF32(otherIx, fnIx) {
    atom = "f32"
  } else if exprIsF64(otherIx, fnIx) {
    atom = "f64"
  } else if exprIsI64(otherIx, fnIx) {
    atom = "i64"
  } else if exprIsBool(otherIx, fnIx) {
    atom = "boolean"
  } else {
    if !unionHasAtom(unionName, "i32") && unionHasAtom(unionName, "i64") {
      atom = "i64"
    }
    const bare = P.nodes[unwrapParen(otherIx)]
    if bare is NumLit {
      if !numLexFitsI32(bare.numText) { atom = "i64" }
    }
  }
  atom
}

// Emit the concrete operand at `otherIx` in the atom's rep (the host's
// `withDesiredType(member, …)` — an i32 literal widens to the arm's i64/f64/f32).
function emitUnionEqOther(body: i32[], otherIx: i32, atom: string, fnIx: i32) {
  if atom == "i64" { return emitExprAsI64(body, otherIx, fnIx) }
  if atom == "f64" { return emitExprAsF64(body, otherIx, fnIx) }
  if atom == "f32" {
    const savedF32 = pendingF32
    pendingF32 = true
    if emitExprAsF32(body, otherIx, fnIx) < 0 { return -1 }
    pendingF32 = savedF32
    return 0
  }
  emitExpr(body, otherIx, fnIx)
}

// union == concrete (either operand order — equality is symmetric): the box's
// tag must select the arm whose rep matches the other side, then the unboxed
// payload value-compares it. A rep with no arm is statically unequal (`==` 0 /
// `!=` 1) — both operands still evaluate for side effects, box side first
// (the host's drop-block). `isNe` negates the result for `!=`.
function emitUnionConcreteEq(
  body: i32[],
  boxIx: i32,
  otherIx: i32,
  isNe: boolean,
  fnIx: i32,
) {
  if !unionEqOperandOk(boxIx) {
    return emitFail(
      "emitProgram: union `==` over a non-binding union value is not supported yet",
    )
  }
  const uname = unionNameOfExpr(boxIx, fnIx)
  if uname == "" || !isValueUnionName(uname) {
    return emitFail("emitProgram: `==` over a struct union is not supported yet")
  }
  let atom = unionEqAtomOf(otherIx, uname, fnIx)
  if !unionHasAtom(uname, atom) {
    // No arm has the other operand's rep: the box can never hold such a value.
    if emitExpr(body, boxIx, fnIx) < 0 { return -1 }
    fbDrop() // 0x1a drop
    if emitUnionEqOther(body, otherIx, atom, fnIx) < 0 { return -1 }
    fbDrop() // 0x1a drop
    if isNe { fbI32Const(1) } else { fbI32Const(0) }
    return 0
  }
  if atom == "string" && !aUsed {
    return emitFail("emitProgram: union string `==` but array type not collected")
  }
  // tag == tagOf(atom), gating the payload compare.
  if emitExpr(body, boxIx, fnIx) < 0 { return -1 }
  fbStructGet(uBoxIdx, 0) // 0xfb 0x02 <box ht> field 0: tag
  fbI32Const(scalarTagOf(atom))
  fbI32Bin(70)            // 0x46 i32.eq
  fbIf(127)               // 0x04 if, 0x7f i32 result blocktype
  if emitExpr(body, boxIx, fnIx) < 0 { return -1 }
  fbStructGet(uBoxIdx, 1) // 0xfb 0x02 <box ht> field 1: value (anyref)
  if emitUnionPayloadUnbox(body, atom) < 0 { return -1 }
  if emitUnionEqOther(body, otherIx, atom, fnIx) < 0 { return -1 }
  if atom == "string" {
    if emitStrEqCore(body) < 0 { return -1 }
  } else {
    fbI32Bin(atomEqOpcode(atom))
  }
  fbElse() // 0x05 else: wrong-rep arm — structurally unequal
  fbI32Const(0)
  fbEnd()  // 0x0b end
  if isNe {
    fbI32Eqz() // 0x45 i32.eqz (`!=` negates value-equality)
  }
  0
}

// union == union: equal iff the SAME arm (tag) holds AND the unboxed payloads
// value-compare equal per that arm. Folded as a nested value-typed `if` chain
// over the SHARED non-null arms, bottoming out at bare tag equality (covers the
// `null` arm and any non-shared arm: distinct tags ⇒ unequal, equal null tags
// ⇒ equal). The right payload's unbox short-circuits on ITS tag too.
function emitUnionUnionEq(
  body: i32[],
  lIx: i32,
  rIx: i32,
  isNe: boolean,
  fnIx: i32,
) {
  if !unionEqOperandOk(lIx) || !unionEqOperandOk(rIx) {
    return emitFail(
      "emitProgram: union `==` over a non-binding union value is not supported yet",
    )
  }
  const lname = unionNameOfExpr(lIx, fnIx)
  const rname = unionNameOfExpr(rIx, fnIx)
  if !isValueUnionName(lname) || !isValueUnionName(rname) {
    return emitFail("emitProgram: `==` over a struct union is not supported yet")
  }
  // The shared non-null arms (matched by atom — atoms tag globally).
  const lAtoms: string[] = []
  splitUnionAtoms(lname, lAtoms)
  const arms: string[] = []
  let ai = 0
  while ai < lAtoms.length {
    if lAtoms[ai] != "null" && unionHasAtom(rname, lAtoms[ai]) {
      arms.push(lAtoms[ai])
    }
    ai = ai + 1
  }
  if unionHasAtom(lname, "string") && unionHasAtom(rname, "string") && !aUsed {
    return emitFail("emitProgram: union string `==` but array type not collected")
  }
  // Outermost `if` is the LAST arm (the host wraps its chain in arm order).
  let k = arms.length - 1
  while k >= 0 {
    if emitExpr(body, lIx, fnIx) < 0 { return -1 }
    fbStructGet(uBoxIdx, 0) // left tag
    fbI32Const(scalarTagOf(arms[k]))
    fbI32Bin(70)            // 0x46 i32.eq
    fbIf(127)               // left holds this arm
    if emitExpr(body, rIx, fnIx) < 0 { return -1 }
    fbStructGet(uBoxIdx, 0) // right tag
    fbI32Const(scalarTagOf(arms[k]))
    fbI32Bin(70)            // 0x46 i32.eq
    fbIf(127)               // right holds it too → payload value-compare
    if emitExpr(body, lIx, fnIx) < 0 { return -1 }
    fbStructGet(uBoxIdx, 1) // left payload (anyref)
    if emitUnionPayloadUnbox(body, arms[k]) < 0 { return -1 }
    if emitExpr(body, rIx, fnIx) < 0 { return -1 }
    fbStructGet(uBoxIdx, 1) // right payload (anyref)
    if emitUnionPayloadUnbox(body, arms[k]) < 0 { return -1 }
    if arms[k] == "string" {
      if emitStrEqCore(body) < 0 { return -1 }
    } else {
      fbI32Bin(atomEqOpcode(arms[k]))
    }
    fbElse() // right holds a different arm → unequal
    fbI32Const(0)
    fbEnd()
    fbElse() // left holds an earlier arm → recurse down the chain
    k = k - 1
  }
  // Chain bottom: bare tag equality (null arm / non-shared arms).
  if emitExpr(body, lIx, fnIx) < 0 { return -1 }
  fbStructGet(uBoxIdx, 0)
  if emitExpr(body, rIx, fnIx) < 0 { return -1 }
  fbStructGet(uBoxIdx, 0)
  fbI32Bin(70) // 0x46 i32.eq
  // Close every arm's outer `if` frame.
  let c = 0
  while c < arms.length {
    fbEnd()
    c = c + 1
  }
  if isNe {
    fbI32Eqz() // 0x45 i32.eqz
  }
  0
}

// `v is <literal>` over a STILL-BOXED mixed-rep union (`"a" | "b" | 1` boxes as
// `string|i32` — same-rep literals SHARE a tag): the tag selects the literal's
// rep arm, then the unboxed payload value-compares the literal. A literal whose
// rep has no arm is statically false (literal-is-always-false), evaluating the
// receiver for effects. The same gated shape as `emitUnionConcreteEq`.
function emitUnionLitIs(body: i32[], objIx: i32, lit: string, fnIx: i32) {
  if !unionEqOperandOk(objIx) {
    return emitFail(
      "emitProgram: literal `is` over a non-binding union value is not supported yet",
    )
  }
  const uname = unionNameOfExpr(objIx, fnIx)
  if uname == "" || !isValueUnionName(uname) {
    return emitFail(
      "emitProgram: literal `is` over a struct union is not supported",
    )
  }
  // The literal's rep atom (a quoted lexeme is a string; a float f64; an
  // integer i32, widening to i64 when out of range or when the union's only
  // integer arm is i64 — the `emitUnionCoerce` default).
  let atom = "i32"
  if lit[0] == '"' {
    atom = "string"
  } else if numTextIsFloat(lit) {
    atom = "f64"
  } else if !numLexFitsI32(lit) {
    atom = "i64"
  } else if !unionHasAtom(uname, "i32") && unionHasAtom(uname, "i64") {
    atom = "i64"
  }
  if !unionHasAtom(uname, atom) {
    if emitExpr(body, objIx, fnIx) < 0 { return -1 }
    fbDrop() // 0x1a drop
    fbI32Const(0)
    return 0
  }
  if atom == "string" && !aUsed {
    return emitFail("emitProgram: string `is` test but array type not collected")
  }
  if emitExpr(body, objIx, fnIx) < 0 { return -1 }
  fbStructGet(uBoxIdx, 0) // 0xfb 0x02 <box ht> field 0: tag
  fbI32Const(scalarTagOf(atom))
  fbI32Bin(70)            // 0x46 i32.eq
  fbIf(127)               // 0x04 if, 0x7f i32 result blocktype
  if emitExpr(body, objIx, fnIx) < 0 { return -1 }
  fbStructGet(uBoxIdx, 1) // field 1: value (anyref)
  if emitUnionPayloadUnbox(body, atom) < 0 { return -1 }
  if atom == "string" {
    // The literal lexeme rides a synthesized `StrLit` (same shape as `strText`).
    if emitExpr(body, mkStr(lit, -1), fnIx) < 0 { return -1 }
    if emitStrEqCore(body) < 0 { return -1 }
  } else if atom == "f64" {
    fbF64Const(lit)
    fbI32Bin(97) // 0x61 f64.eq
  } else if atom == "i64" {
    const pr = parseI64Pair(lit)
    fbI64Const(pr[0], pr[1])
    fbI32Bin(81) // 0x51 i64.eq
  } else {
    fbI32Const(parseI32(lit))
    fbI32Bin(70) // 0x46 i32.eq
  }
  fbElse() // wrong-rep arm — the literal can never match
  fbI32Const(0)
  fbEnd()  // 0x0b end
  0
}

// True if the member access at `memIx` reads a field of a CURRENTLY-narrowed union
// identifier (the receiver `Ident` has an active binding on the narrowing stack).
function memIsNarrowed(memIx: i32) {
  if narrowTop == 0 { return false }
  const m = P.nodes[memIx]
  if m is Member {
    const recv = P.nodes[m.memObj]
    if recv is Ident {
      if narrowVariantFor(recv.identName) != "" { return true }
    }
    // A nested union-FIELD receiver (`t.v.a` where `t.v` is narrowed to a variant): the
    // receiver is itself a Member, narrowed by its path key (`t.v`).
    if recv is Member {
      const pk = memberPathKeyOf(m.memObj)
      if pk != "" {
        if narrowVariantFor(pk) != "" { return true }
      }
    }
  }
  false
}

// The variant table index the Member `memIx`'s receiver is currently narrowed to, or -1
// if its receiver is not a narrowed union identifier. Resolves each receiver's OWN active
// narrowing — so simultaneously-narrowed locals each map to their own variant.
function memNarrowVariantIndex(memIx: i32) {
  const m = P.nodes[memIx]
  if m is Member {
    const recv = P.nodes[m.memObj]
    if recv is Ident { return variantIndexOf(narrowVariantFor(recv.identName)) }
    if recv is Member {
      const pk = memberPathKeyOf(m.memObj)
      if pk != "" { return variantIndexOf(narrowVariantFor(pk)) }
    }
  }
  -1
}

// The VALUE-union name of a union-typed struct FIELD read `o.y` (field code 16),
// or "" when the member is not a union-box field.
function memberUnionFieldName(memIx: i32, fnIx: i32) {
  const m = P.nodes[memIx]
  if m is Member {
    let si = structIndexOfExpr(m.memObj, fnIx)
    if si >= 0 {
      let fi = sFieldIndex(si, m.memProp)
      if fi >= 0 {
        if sFieldTypeAt(si, fi) == 16 { return sFieldElemNameAt(si, fi) }
      }
    }
  }
  ""
}

function emitMem(body: i32[], memIx: i32, fnIx: i32) {
  // A field read on a NARROWED union identifier downcasts through the box (G1).
  if memIsNarrowed(memIx) { return emitNarrowedMem(body, memIx, fnIx) }
  // A field read on a VARIANT-typed param `o.field` (`o: TyObj`) reads the variant
  // struct directly — the param already IS the unboxed variant ref, so there is NO box
  // unwrap / cast (gap #2). Evaluate the receiver (`local.get o`), then `struct.get
  // $<uVarIdx + vi> <fieldIdx>`.
  let m0 = P.nodes[memIx]
  if m0 is Member {
    const pvi = exprVariantIndex(m0.memObj, fnIx)
    if pvi >= 0 {
      const pvfi = variantFieldIndex(pvi, m0.memProp)
      if pvfi < 0 {
        return emitFail("emitProgram: unknown variant field in field access")
      }
      if emitExpr(body, m0.memObj, fnIx) < 0 { return -1 }
      fbStructGet(uVarIdx + pvi, pvfi) // 0xfb 0x02 <variant struct ht> <field index>
      return 0
    }
  }
  // Shared-field access over an UN-narrowed struct union (`(A | B).tag` — the
  // host's `sharedUnionFieldRead`): the checker proved the field present on EVERY
  // member, but members may store it at DIFFERENT indices, so dispatch on the box
  // tag and read the field at THAT member's own index. The arms are exhaustive
  // (the LAST member is the unconditional fall-through, host parity). Ported
  // SUBSET: an IDENT receiver (an effect-free place — it is re-evaluated per arm
  // instead of spilling to a scratch local) and an i32-rep field (a single-byte
  // `if (result i32)` blocktype); anything else falls through to the loud
  // failures below. A multi-variant NARROWED set ("N2|N3") dispatches over just
  // its remaining members.
  const mS = P.nodes[memIx]
  if mS is Member {
    if exprUnion(mS.memObj, fnIx) {
      const shRecv = P.nodes[unwrapParen(mS.memObj)]
      if shRecv is Ident {
        const shSet = currentStructNarrowSetOf(shRecv.identName, fnIx)
        if shSet != "" {
          const shAtoms: string[] = []
          splitUnionAtoms(shSet, shAtoms)
          // Validate: every member a struct VARIANT carrying the field as i32.
          const shVis: i32[] = []
          const shFis: i32[] = []
          let shOk = shAtoms.length >= 2
          let sa = 0
          while sa < shAtoms.length {
            const svi = variantIndexOf(shAtoms[sa])
            if svi < 0 {
              shOk = false
            } else {
              const sfi = variantFieldIndex(svi, mS.memProp)
              if sfi < 0 || variantFieldTypeAt(svi, sfi) != 0 {
                shOk = false
              } else {
                shVis.push(svi)
                shFis.push(sfi)
              }
            }
            sa = sa + 1
          }
          if shOk {
            let si2 = 0
            while si2 < shAtoms.length - 1 {
              if emitExpr(body, mS.memObj, fnIx) < 0 { return -1 }
              fbStructGet(uBoxIdx, 0) // field 0: tag
              fbI32Const(uTags[shVis[si2]])
              fbI32Bin(70)            // 0x46 i32.eq
              fbIf(127)               // if (result i32)
              if emitExpr(body, mS.memObj, fnIx) < 0 { return -1 }
              fbStructGet(uBoxIdx, 1) // field 1: value (anyref)
              fbRefCast(uVarIdx + shVis[si2])
              fbStructGet(uVarIdx + shVis[si2], shFis[si2])
              fbElse()
              si2 = si2 + 1
            }
            const shLast = shAtoms.length - 1
            if emitExpr(body, mS.memObj, fnIx) < 0 { return -1 }
            fbStructGet(uBoxIdx, 1) // field 1: value (anyref)
            fbRefCast(uVarIdx + shVis[shLast])
            fbStructGet(uVarIdx + shVis[shLast], shFis[shLast])
            let se = 0
            while se < shAtoms.length - 1 {
              fbEnd()
              se = se + 1
            }
            return 0
          }
        }
      }
    }
  }
  if !sDeclared {
    return emitFail("emitProgram: field access but no struct type declared")
  }
  const m = P.nodes[memIx]
  if m is Member {
    let si = structIndexOfExpr(m.memObj, fnIx)
    if si < 0 {
      return emitFail("emitProgram: field access receiver is not a struct")
    }
    const idx = sFieldIndex(si, m.memProp)
    if idx < 0 {
      return emitFail("emitProgram: unknown struct field in field access")
    }
    if emitExpr(body, m.memObj, fnIx) < 0 { return -1 }
    // A NULLABLE-struct receiver (`S | null`) recovers its non-null ref before the
    // field read — the checker proved every such access guarded, so the cast can
    // never trap on a checked program.
    if exprNullableStruct(m.memObj, fnIx) {
      wU8(212) // 0xd4 ref.as_non_null
    }
    fbStructGet(sHeapIdx[si], idx) // 0xfb 0x02 <struct ht> <field index>
    // A `string | null` field (code 20) read AS A VALUE recovers the non-null string ref
    // (`ref.as_non_null` — the checker narrowed it non-null at every value read). The `!=
    // null` / `??` null-check sets `pendingRawNullRead` to keep the raw nullable ref. A
    // `boolean | null` field (code 21) needs no recovery (its i32 sentinel reads as-is).
    if sFieldTypeAt(si, idx) == 20 {
      // A nullable-string TARGET (`pendingNulString` — `const g = r.f` binding a `string | null`, or a
      // nullable arg/return) keeps the raw nullable ref, like the kind-16 ident read: recovering would
      // `ref.as_non_null` a possibly-null field value and trap.
      if !pendingRawNullRead && !pendingNulString {
        wU8(212) // 0xd4 ref.as_non_null
      }
    }
    // A UNION-typed field (code 16) read while the member PATH is narrowed to one
    // scalar atom (`if o.y is i32 { … o.y … }`) unboxes the payload — the same
    // recovery as a narrowed union IDENT read. An un-narrowed read is the box.
    if sFieldTypeAt(si, idx) == 16 {
      const mAtom = narrowVariantFor(memberPathKeyOf(memIx))
      const mk = valueAtomKind(mAtom)
      if mk >= 0 && mk != 6 {
        fbStructGet(uBoxIdx, 1) // field 1: value (anyref)
        if mAtom == "string" {
          if !aUsed {
            return emitFail(
              "emitProgram: narrowed string union field read but array type not collected",
            )
          }
          fbRefCast(aTypeIdx) // the payload IS the string array ref
        } else {
          const mvb = vbHeapIdxOfAtom(mAtom)
          if mvb < 0 {
            return emitFail("emitProgram: narrowed union field atom has no value box")
          }
          fbRefCast(mvb)
          fbStructGet(mvb, 0) // the scalar payload
        }
      }
    }
    return 0
  }
  emitFail("emitProgram: expected a field access")
}

// ── string-literal decoding ───────────────────────────────────────────────────
// A `StrLit` carries the RAW lexeme in `strText` (surrounding quotes kept, escapes
// UNRESOLVED — see `parser.vl`'s `mkStr` of the STRING token's raw text), so the emitter decodes it
// here to the sequence of Unicode CODE POINTS the string denotes. Because a VL string
// is itself a code-point `array i32` (this very representation), `strText[i]` already
// yields the i32 code point of the i-th source char, so decoding is a direct walk over
// those code points with the same escape grammar the lexer applies (`scanQuoted`):
// `\n \t \r \\ \" \' \0 \b \f \v`, `\xXX`, `\uXXXX`, `\u{…}`. The result is the
// emittable code-point vector that `emitStr` lowers to `array.new_fixed`.

// Lower a string literal `"abc"` onto `body`: decode `strText` to its code-point
// vector, push each code point as `i32.const`, then `array.new_fixed $aTypeIdx <count>`
// — i.e. the IDENTICAL shape an `i32[]` literal of those code points uses (a string is
// CURRENTLY an `array i32` of code points; `docs/strings-design.md`). The UTF-8
// `array i8` storage migration is the deliberate B7 follow-up and is NOT built here.
function emitStr(body: i32[], strIx: i32, fnIx: i32) {
  if !aUsed {
    return emitFail("emitProgram: string literal but array type not collected")
  }
  let s = P.nodes[strIx]
  if s is StrLit {
    const cps = decodeStr(strToCps(s.strText))
    let i = 0
    while i < cps.length {
      fbI32Const(cps[i]) // 0x41 i32.const <code point>
      i = i + 1
    }
    fbArrayNewFixed(aTypeIdx, cps.length) // 0xfb 0x08 <typeidx> <count>; type shared with i32[]
    return 0
  }
  emitFail("emitProgram: expected a string literal")
}

// Lower an array literal `[e, e, ...]` onto `body` as a GROWABLE list value (mirroring
// `toWasm.ts`'s `ArrayLiteral` case): push each element value in source order (all i32),
// then `array.new_fixed $aTypeIdx <count>` to build the raw backing (`0xfb 0x08 <typeidx>
// <count>`), then push `count` (len) and `count` (cap), then `struct.new $lTypeIdx`
// (`0xfb 0x00 <lTypeIdx>`) to wrap them into `{ backing, len, cap }`. An empty `[]` is
// `array.new_fixed` of count 0 wrapped with len 0 / cap 0. An element that is itself an
// array (nested) is out of scope — fails loudly.
function emitArr(body: i32[], arrIx: i32, fnIx: i32) {
  const a = P.nodes[arrIx]
  if a is ArrayLit {
    const elems = a.arrElems
    // A REF list literal — ref ELEMENTS, OR an empty `[]` whose binding annotation is a
    // ref array (`pendingListKind` 1/2). The element store is `(ref null $elem)`; each
    // element lowers via `emitExpr` (an objlit → struct.new / union box). Otherwise the
    // i32 list path.
    let isRefLit = arrLitIsRef(arrIx)
    // A `string[]` literal — string ELEMENTS, OR an empty `[]` whose binding/field is a
    // `string[]` (`pendingListKind == 3`). Its backing is `(ref null $aTypeIdx)` (string
    // refs) wrapped in the string-list wrapper (`mkListIdx`). Checked before the i32/ref
    // paths since a string element is neither i32 nor a struct/union ref.
    let isStrLit = arrLitIsStr(arrIx, fnIx)
    // An f64-element literal — float ELEMENTS, OR an empty `[]` whose binding is an
    // `f64[]` (`pendingListKind == 4`). Its backing is `(array (mut f64))` (Slice 4).
    let isF64Lit = arrLitIsF64(arrIx, fnIx)
    // An i64-element literal — an i64-typed first element, OR (the common case) a literal
    // under an `i64[]` annotation (`pendingListKind == 6`), whose bare-integer elements
    // are i32 literals widened to i64 at the store. Its backing is `(array (mut i64))`.
    let isI64Lit = arrLitIsI64(arrIx, fnIx)
    if pendingListKind == 6 {
      isI64Lit = true
      isF64Lit = false
      isStrLit = false
    }
    // An f32-element literal is set ONLY by an `f32[]` binding/annotation (`pendingListKind ==
    // 7`) — a bare float literal stays f64. The same `[1.5]` elements re-encode at f32.
    let isF32Lit = false
    if pendingListKind == 7 {
      isF32Lit = true
      isF64Lit = false
      isI64Lit = false
      isStrLit = false
    }
    if elems.length == 0 {
      if pendingListKind == 3 {
        isStrLit = true
      } else if pendingListKind == 4 {
        isF64Lit = true
      } else if pendingListKind == 6 {
        isI64Lit = true
      } else if pendingListKind == 7 {
        isF32Lit = true
      } else {
        if pendingListKind != 0 { isRefLit = true }
      }
    }
    // A NON-EMPTY literal under a threaded UNION-list annotation (kind 2) is a
    // ref literal even when its elements are bare scalars/strings — a
    // `(string|i32)[]` literal's elements COERCE into the union box at the
    // write boundary (the host's `coerceUnion` per element), they don't type
    // the list. Without the annotation a scalar literal stays the i32 list.
    if pendingListKind == 2 {
      isRefLit = true
      isStrLit = false
      isF64Lit = false
    }
    // A CLOSURE-element list (kind 5, `((i32) => i32)[]`): a literal of function values
    // (`[inc, dbl]`) reads as bare idents, so `arrLitIsRef` (which keys off an objlit /
    // nested-array first element) misses it — the threaded annotation is authoritative.
    if pendingListKind == 5 {
      isRefLit = true
      isStrLit = false
      isF64Lit = false
    }
    // A STRUCT ref-list (kind 1) under a threaded annotation: authoritative, like kind 2/5.
    // Matters for a NULLABLE-struct array (`(P | null)[]`) whose FIRST element is `null` —
    // `arrLitIsRef` keys off the first element (a `null` is neither objlit nor nested array)
    // and would otherwise mis-route the literal to the i32-list path.
    if pendingListKind == 1 {
      isRefLit = true
      isStrLit = false
      isF64Lit = false
      isI64Lit = false
    }
    if isF32Lit {
      if !fa32Used {
        return emitFail(
          "emitProgram: f32 array literal but f32 list type not collected",
        )
      }
      let i32f = 0
      while i32f < elems.length {
        if exprArray(elems[i32f], fnIx) || exprRefArray(elems[i32f], fnIx) {
          return emitFail("emitProgram: nested arrays are not supported")
        }
        // Each element lowered as f32 (a float literal re-encoded; an i32 operand converted
        // via `f32.convert_i32_s`) so the backing's element type matches.
        if emitExprAsF32(body, elems[i32f], fnIx) < 0 { return -1 }
        i32f = i32f + 1
      }
      fbArrayNewFixed(fa32TypeIdx, elems.length) // builds the f32 backing
      fbI32Const(elems.length) // len
      fbI32Const(elems.length) // cap
      fbStructNew(fl32TypeIdx) // the f32-list wrapper
      return 0
    }
    if isF64Lit {
      if !fa64Used {
        return emitFail(
          "emitProgram: f64 array literal but f64 list type not collected",
        )
      }
      let i = 0
      while i < elems.length {
        if exprArray(elems[i], fnIx) || exprRefArray(elems[i], fnIx) {
          return emitFail("emitProgram: nested arrays are not supported")
        }
        // Each element is lowered as an f64 (a float literal → `f64.const`; an i32
        // operand widened via `f64.convert_i32_s`) so the backing's element type matches.
        if emitExprAsF64(body, elems[i], fnIx) < 0 { return -1 }
        i = i + 1
      }
      fbArrayNewFixed(fa64TypeIdx, elems.length) // 0xfb 0x08; builds the f64 backing
      fbI32Const(elems.length) // 0x41 i32.const (len)
      fbI32Const(elems.length) // 0x41 i32.const (cap)
      fbStructNew(fl64TypeIdx) // 0xfb 0x00 <f64-list wrapper struct type index>
      return 0
    }
    if isI64Lit {
      if !ia64Used {
        return emitFail(
          "emitProgram: i64 array literal but i64 list type not collected",
        )
      }
      let i = 0
      while i < elems.length {
        if exprArray(elems[i], fnIx) || exprRefArray(elems[i], fnIx) {
          return emitFail("emitProgram: nested arrays are not supported")
        }
        // Each element lowered as i64 (an i64 literal directly; an i32 operand sign-
        // extended via `i64.extend_i32_s`) so the backing's element type matches.
        if emitExprAsI64(body, elems[i], fnIx) < 0 { return -1 }
        i = i + 1
      }
      fbArrayNewFixed(ia64TypeIdx, elems.length) // builds the i64 backing
      fbI32Const(elems.length) // len
      fbI32Const(elems.length) // cap
      fbStructNew(il64TypeIdx) // the i64-list wrapper
      return 0
    }
    if isStrLit {
      if !slUsed {
        return emitFail(
          "emitProgram: string array literal but string list type not collected",
        )
      }
      let i = 0
      while i < elems.length {
        if emitExpr(body, elems[i], fnIx) < 0 { return -1 }
        i = i + 1
      }
      fbArrayNewFixed(mkArrIdx, elems.length) // 0xfb 0x08; builds the string-ref backing
      fbI32Const(elems.length)                // 0x41 i32.const (len)
      fbI32Const(elems.length)                // 0x41 i32.const (cap)
      fbStructNew(mkListIdx)                  // 0xfb 0x00 <string-list wrapper struct type index>
      return 0
    }
    if isRefLit {
      if !rlUsed {
        return emitFail(
          "emitProgram: ref array literal but ref list type not collected",
        )
      }
      // The element type determines WHICH (backing, wrapper) pair this literal builds.
      // A binding/field site that threaded a ref-list annotation (`pendingListKind` 1/2,
      // `pendingListSlot` the element slot) is AUTHORITATIVE — its declared element type
      // wins over the first-element field-shape guess so a `B[] = [{…}]` literal of a
      // struct sharing field names with another struct still builds B's list. Only a
      // literal WITHOUT a threaded annotation types itself from its first element. An
      // EMPTY `[]` (no elements) always takes the threaded slot.
      const annKind = pendingListKind
      const annSlot = pendingListSlot
      let rslot = 0
      if annKind == 1 || annKind == 2 || annKind == 5 { rslot = annSlot }
      else if elems.length >= 1 { rslot = rlSlotByName(arrLitElemName(arrIx)) }
      else { rslot = annSlot }
      if rslot < 0 {
        if rlElemName.length < 1 {
          return emitFail("emitProgram: ref array literal with no interned element type")
        }
        rslot = 0
      }
      // A STRUCT-element list (kind 1, NOT a union box) types each element literal as the
      // list's declared element struct — seed `pendingStructIdx` (consumed by `emitObj`)
      // so a same-field-name sibling struct does not win the field-shape match. A union
      // list (kind 2) boxes by variant name and needs no struct hint.
      let elemStructIdx = -1
      let elemVariantIdx = -1
      if rlElemKindTbl[rslot] == 1 {
        // A NULLABLE-struct element list (`(P | null)[]`, slot key "P | null"): strip the
        // `| null` to the bare struct so an object element builds `P` and a `null` element
        // gets `ref.null $P` (the seeded `pendingStructIdx`).
        let rlen = rlElemName[rslot]
        const rnn = nullablePartOf(rlen)
        if rnn != "" { rlen = rnn }
        elemStructIdx = structIndexByName(rlen)
        // A concrete-VARIANT element list (`Cat[]`): no `sNames` entry, so seed the VARIANT
        // index instead so each element literal builds the bare variant struct (kind 8).
        if elemStructIdx < 0 { elemVariantIdx = variantIndexOf(rlen) }
      }
      // A UNION-element list (kind 2) coerces each element into the box at the
      // write boundary (`emitUnionCoerce` — the host's per-element `coerceUnion`):
      // a bare scalar/string boxes under its atom's tag; an object literal /
      // already-union value passes through to its existing boxing.
      let elemUnionNm = ""
      if rlElemKindTbl[rslot] == 2 { elemUnionNm = rlElemName[rslot] }
      // A nested LIST element kind (`i32[][]` 4 / `string[][]` 6 / `f64[][]` 7 / `i64[][]` 8):
      // the elements ARE arrays. Kind 4 builds the default i32-list; 6/7/8 seed the inner list
      // kind (`pendingListKind` 3 string / 4 f64 / 6 i64) so a bare `["a"]` / `[1.0]` / `[1,2]`
      // element builds the right list, not the default i32-list.
      const elemNest = rlElemKindTbl[rslot]
      let i = 0
      // A kind-9 element is itself a REF list (`Cell[]` of `Cell[][]`, any ref leaf, any depth):
      // its inner ref-list slot, seeded so each element builds as that inner list (recursively).
      let nestInnerSlot = -1
      if elemNest == 9 {
        nestInnerSlot = rlSlotByName(refArrElemName(rlElemName[rslot]))
      }
      while i < elems.length {
        // A NON-nested-list element list must not hold array elements. Kinds 4/6/7/8 (scalar inner
        // lists) and 9 (ref inner list) legitimately do.
        if (
          elemNest != 4 &&
          elemNest != 6 &&
          elemNest != 7 &&
          elemNest != 8 &&
          elemNest != 9 &&
          elemNest != 10
        ) {
          if exprArray(elems[i], fnIx) || exprRefArray(elems[i], fnIx) {
            return emitFail("emitProgram: nested arrays are not supported")
          }
        }
        pendingStructIdx = elemStructIdx
        pendingVariantIdx = elemVariantIdx
        if elemUnionNm != "" {
          // Box the element into the shared union box — a concrete VARIANT element
          // (`[s]` where `s: S`) widens via `emitUnionBoxArg`, like a call arg / return.
          if emitUnionBoxArg(body, elemUnionNm, elems[i], fnIx) < 0 {
            return -1
          }
        } else {
          // Reset `pendingListKind`/`pendingListSlot` to the INNER list's kind so the element
          // builds the right list, NOT the outer ref-list kind it would inherit. Scalar inner
          // lists seed kind 0/3/4/6; a ref inner list (kind 9) seeds kind 5 + the inner slot, so
          // the element builds as that ref list — which may itself be kind 9 (nesting falls out).
          const savedNest = pendingListKind
          const savedSlot = pendingListSlot
          if elemNest == 4 {
            pendingListKind = 0
          } else if elemNest == 6 {
            pendingListKind = 3
          } else if elemNest == 7 {
            pendingListKind = 4
          } else if elemNest == 8 {
            pendingListKind = 6
          } else if elemNest == 10 {
            pendingListKind = 7 // f32-inner list -> build each element as an f32[] (kind 7)
          } else if elemNest == 9 {
            pendingListKind = 5
            pendingListSlot = nestInnerSlot
          }
          // A `(i32[] | null)[]` element (kind 4 nullable niche) may be a bare `null` → `ref.null
          // $lTypeIdx`; a `(<ref-array> | null)[]` element (kind 9 nullable niche) → `ref.null
          // $innerWrapper`. Each seed only affects a `null` element (a non-null literal ignores it).
          const savedNulList = pendingNulList
          const savedNRH = pendingNulRefHeap
          if elemNest == 4 && rlElemNullable[rslot] == 1 {
            pendingNulList = true
          }
          if elemNest == 9 && rlElemNullable[rslot] == 1 && nestInnerSlot >= 0 {
            pendingNulRefHeap = rlWrapIdx[nestInnerSlot]
          }
          if emitExpr(body, elems[i], fnIx) < 0 { return -1 }
          pendingNulList = savedNulList
          pendingNulRefHeap = savedNRH
          pendingListKind = savedNest
          pendingListSlot = savedSlot
        }
        pendingVariantIdx = -1
        i = i + 1
      }
      pendingStructIdx = -1
      fbArrayNewFixed(rlBackIdx[rslot], elems.length) // 0xfb 0x08; builds the ref backing
      fbI32Const(elems.length)                        // 0x41 i32.const (len)
      fbI32Const(elems.length)                        // 0x41 i32.const (cap)
      fbStructNew(rlWrapIdx[rslot])                   // 0xfb 0x00 <this slot's ref-list wrapper>
      return 0
    }
    if !lUsed {
      return emitFail("emitProgram: array literal but list type not collected")
    }
    let i = 0
    while i < elems.length {
      if exprArray(elems[i], fnIx) || exprRefArray(elems[i], fnIx) {
        return emitFail("emitProgram: nested arrays are not supported")
      }
      if exprStruct(elems[i], fnIx) {
        return emitFail("emitProgram: struct array elements are not supported")
      }
      if emitExpr(body, elems[i], fnIx) < 0 { return -1 }
      i = i + 1
    }
    fbArrayNewFixed(aTypeIdx, elems.length) // 0xfb 0x08; builds the raw backing
    // Wrap { backing, len = count, cap = count } via struct.new.
    fbI32Const(elems.length) // 0x41 i32.const (len)
    fbI32Const(elems.length) // 0x41 i32.const (cap)
    fbStructNew(lTypeIdx)    // 0xfb 0x00 <list wrapper struct type index>
    return 0
  }
  emitFail("emitProgram: expected an array literal")
}

// ── G8: string-keyed maps (`{[string]: i32}`) — open-addressing hash map ───────
// A map is the 5-field `MAP = { keys, vals, index, count, size }` (see the map-table
// section above for the full representation). Operations HASH the key (FNV-1a) into
// `index` and LINEAR-PROBE to a free-or-matching slot — NO O(n) scan. A function that
// touches a map reserves a 14-slot scratch frame (`mapScratchBase` + 0..13):
//   +0  mapRef : (ref $mStructIdx)  — the map value
//   +1  keyRef : (ref $aTypeIdx)    — the target key string
//   +2  curRef : (ref $aTypeIdx)    — the current probed key string
//   +3  slot   : i32                — probe slot offset into `index`
//   +4  cap    : i32                — index length / newCap (resize)
//   +5  entry  : i32                — index[slot] (entry+1; 0 = miss)
//   +6  keysBk : (ref $mkArrIdx)    — grown keys backing (compact: new keys backing)
//   +7  valsBk : (ref $aTypeIdx)    — grown vals backing (compact: new vals backing)
//   +8  chr    : i32                — inner char cursor (key compare / hash); compact `i`
//   +9  hcur   : i32                — FNV hash accumulator; compact write cursor `j`
//   +10 idxBk  : (ref $aTypeIdx)    — fresh `index` backing (resize); compact new live
//   +11 rslot  : i32                — inner probe slot (resize); compact target cap
//   +12 liveBk : (ref $aTypeIdx)    — grown `live` backing (keys-grow lockstep)
//   +13 hashBk : (ref $aTypeIdx)    — grown `hashes` backing (keys-grow lockstep);
//                                     compact new hashes backing
// `emitMapProbe` leaves `slot` = the probe slot and `entry` = index[slot]; reused by
// set / get / `??` / `.has` / `delete`. `emitMapResize` rehashes at load factor 1/2;
// `emitMapDelete` tombstones + amortized-`emitMapCompact`s.

// Record a distinct (kind, ref-list slot) source frame requirement.
function mfRecordSrc(kind: i32, slot: i32) {
  let i = 0
  while i < mfSrcKinds.length {
    if mfSrcKinds[i] == kind && mfSrcSlots[i] == slot { return 0 }
    i = i + 1
  }
  mfSrcKinds.push(kind)
  mfSrcSlots.push(slot)
  0
}

// Record a distinct (result-element-kind, ref-list slot) dest frame requirement. `slot` is the
// ref-list table slot for a kind-2 (ref-list) dest (so two struct-array filters of DIFFERENT
// element types get distinct backing locals), -1 for a non-ref dest.
function mfRecordDst(kind: i32, slot: i32) {
  let i = 0
  while i < mfDstKinds.length {
    if mfDstKinds[i] == kind && mfDstSlots[i] == slot { return 0 }
    i = i + 1
  }
  mfDstKinds.push(kind)
  mfDstSlots.push(slot)
  0
}

// The wasm local holding the SOURCE wrapper ref for (kind, slot), or -1.
function mfSrcLocalFor(kind: i32, slot: i32) {
  let i = 0
  while i < mfSrcKinds.length {
    if mfSrcKinds[i] == kind && mfSrcSlots[i] == slot {
      if i < mfSrcBases.length { return mfSrcBases[i] }
    }
    i = i + 1
  }
  -1
}

// The wasm local holding the DEST backing ref for result (kind, slot), or -1.
function mfDstLocalFor(kind: i32, slot: i32) {
  let i = 0
  while i < mfDstKinds.length {
    if mfDstKinds[i] == kind && mfDstSlots[i] == slot {
      if i < mfDstBases.length { return mfDstBases[i] }
    }
    i = i + 1
  }
  -1
}

// Walk the statement/expression tree at `ix`, recording every `.map`/`.filter` call
// over a LIST receiver into the scratch-frame requirement lists above (and setting
// `fnUsesMapFilter`). Mirrors `blockHasCallRef`'s node coverage; a nested `FuncDecl`
// (a lifted callback literal) is NOT descended — its own body's sites are detected
// when that lifted function is emitted.
function mfScan(ix: i32, fnIx: i32) {
  if ix < 0 { return 0 }
  let n = P.nodes[ix]
  if n is Call {
    const callee = P.nodes[n.callFn]
    if callee is Member {
      if callee.memProp == "map" || callee.memProp == "filter" {
        if n.callArgs.length == 1 {
          let rk = mfRecvKindOf(callee.memObj, fnIx)
          if rk >= 0 {
            fnUsesMapFilter = true
            let slot = -1
            if rk == 2 { slot = refListSlotOfExpr(callee.memObj, fnIx) }
            mfRecordSrc(rk, slot)
            const resK = mfResultKindOf(ix, fnIx)
            if resK >= 0 { mfRecordDst(resK, mfResultSlotOf(ix, fnIx)) }
          }
        }
      }
      // `xs.slice(start, end?)` builds a NEW list of the SAME element type — it reserves
      // the same src wrapper + dst backing scratch locals as a `.filter` (result kind/slot
      // == receiver). `emitArrSlice` reads the source backing/len through `srcL` and writes
      // the copied range into a fresh `dstL` backing.
      if callee.memProp == "slice" {
        if n.callArgs.length == 1 || n.callArgs.length == 2 {
          let rk = mfRecvKindOf(callee.memObj, fnIx)
          if rk >= 0 {
            fnUsesMapFilter = true
            let slot = -1
            if rk == 2 { slot = refListSlotOfExpr(callee.memObj, fnIx) }
            mfRecordSrc(rk, slot)
            mfRecordDst(rk, slot)
          }
        }
      }
      // `m.keys()` builds a fresh LIVE-key string list — reserve its 6-slot frame.
      if callee.memProp == "keys" {
        if exprMap(callee.memObj, fnIx) { fnUsesMapKeys = true }
      }
      // `m.values()` builds a fresh LIVE-value list. A MONO map uses the self-contained
      // `mapValsBase` frame; an mv-slot (ref/scalar-valued) map uses its per-slot output
      // backing (`mvValsOutBase`) + the key-list frame for live/i/j/count.
      if callee.memProp == "values" {
        if exprMap(callee.memObj, fnIx) {
          const vsh = mapShapeOfExpr(callee.memObj, fnIx)
          if vsh == -1 {
            fnUsesMapVals = true
          } else if vsh >= 0 {
            fnUsesMapVals = true
            fnUsesMapKeys = true
          }
        }
      }
    }
    mfScan(n.callFn, fnIx)
    const args = n.callArgs
    let i = 0
    while i < args.length {
      mfScan(args[i], fnIx)
      i = i + 1
    }
    return 0
  }
  if n is Block {
    const stmts = n.blkStmts
    let i = 0
    while i < stmts.length {
      mfScan(stmts[i], fnIx)
      i = i + 1
    }
    return 0
  }
  if n is LetDecl {
    if n.letInit >= 0 { mfScan(n.letInit, fnIx) }
    return 0
  }
  if n is RetStmt {
    if n.retArg >= 0 { mfScan(n.retArg, fnIx) }
    return 0
  }
  if n is IfStmt {
    mfScan(n.ifCond, fnIx)
    mfScan(n.ifThen, fnIx)
    if n.ifElse >= 0 { mfScan(n.ifElse, fnIx) }
    return 0
  }
  if n is WhileStmt {
    mfScan(n.whileCond, fnIx)
    mfScan(n.whileBody, fnIx)
    return 0
  }
  if n is ForRange {
    mfScan(n.frFrom, fnIx)
    mfScan(n.frTo, fnIx)
    if n.frStep >= 0 { mfScan(n.frStep, fnIx) }
    mfScan(n.frBody, fnIx)
    return 0
  }
  if n is ForIn {
    mfScan(n.fiIter, fnIx)
    mfScan(n.fiBody, fnIx)
    return 0
  }
  if n is BinExpr {
    mfScan(n.binLeft, fnIx)
    mfScan(n.binRight, fnIx)
    return 0
  }
  if n is Unary { return mfScan(n.unArg, fnIx) }
  if n is Paren { return mfScan(n.parInner, fnIx) }
  if n is Member { return mfScan(n.memObj, fnIx) }
  if n is Index {
    mfScan(n.idxArr, fnIx)
    mfScan(n.idxIndex, fnIx)
    return 0
  }
  if n is ObjLit {
    const fields = n.objFields
    let i = 0
    while i < fields.length {
      const f = P.nodes[fields[i]]
      if f is FieldInit { mfScan(f.fiValue, fnIx) }
      i = i + 1
    }
    return 0
  }
  if n is ArrayLit {
    const elems = n.arrElems
    let i = 0
    while i < elems.length {
      mfScan(elems[i], fnIx)
      i = i + 1
    }
    return 0
  }
  0
}

// True if function `fnIx` operates on a map — it has a map PARAM, or `buildLocals`
// flagged a map LOCAL (code `6`). Drives the map scratch-frame reservation. (Run
// AFTER `buildLocals`, so `localIsRef` is populated.)
function fnHasMap(fnIx: i32) {
  let i = 0
  while i < localNames.length {
    if localIsRef[i] == 6 { return true }
    // A map-ARRAY local (`{[string]:i32}[]`, code 5 with element kind 3) lets map ops
    // run on an indexed element (`scopes[i][k]`) — so the function needs the map scratch
    // frame even though no bare map local is declared.
    if localIsRef[i] == 5 {
      let s = localStructIdx[i]
      if s >= 0 {
        if s < rlElemKindTbl.length {
          if rlElemKindTbl[s] == 3 { return true }
        }
      }
    }
    i = i + 1
  }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    const params = fn.fnParams
    let pj = 0
    while pj < params.length {
      const p = P.nodes[params[pj]]
      if p is Param {
        if p.parType >= 0 {
          const ty = P.nodes[p.parType]
          if ty is TypeRef {
            if nameIsMap(ty.tyName) { return true }
          }
        }
      }
      pj = pj + 1
    }
  }
  false
}

// True if the statement/expression tree at `ix` contains a function-VALUE call (a
// `Call` whose callee is a closure value rather than a known function name) — so the
// function needs the closure scratch slot for `call_ref`. (Lambdas.)
function blockHasCallRef(ix: i32, fnIx: i32) {
  if ix < 0 { return false }
  let n = P.nodes[ix]
  if n is Call {
    const callee = P.nodes[n.callFn]
    let isVal = false
    if callee is Ident {
      const t = fnIndexOf(callee.identName)
      if t < 0 {
        if exprIsClosure(n.callFn, fnIx) { isVal = true }
      } else {
        // A direct call to a CAPTURING function is lowered via call_ref too.
        if captureCountOf(t) > 0 { isVal = true }
      }
    } else {
      if exprIsClosure(n.callFn, fnIx) { isVal = true }
    }
    if isVal { return true }
    if blockHasCallRef(n.callFn, fnIx) { return true }
    const args = n.callArgs
    let i = 0
    while i < args.length {
      if blockHasCallRef(args[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  if n is Block {
    const stmts = n.blkStmts
    let i = 0
    while i < stmts.length {
      if blockHasCallRef(stmts[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  if n is LetDecl {
    if n.letInit >= 0 { return blockHasCallRef(n.letInit, fnIx) }
    return false
  }
  if n is RetStmt {
    if n.retArg >= 0 { return blockHasCallRef(n.retArg, fnIx) }
    return false
  }
  if n is IfStmt {
    if blockHasCallRef(n.ifCond, fnIx) { return true }
    if blockHasCallRef(n.ifThen, fnIx) { return true }
    if n.ifElse >= 0 { return blockHasCallRef(n.ifElse, fnIx) }
    return false
  }
  if n is WhileStmt {
    if blockHasCallRef(n.whileCond, fnIx) { return true }
    return blockHasCallRef(n.whileBody, fnIx)
  }
  if n is ForRange {
    if blockHasCallRef(n.frFrom, fnIx) { return true }
    if blockHasCallRef(n.frTo, fnIx) { return true }
    if n.frStep >= 0 {
      if blockHasCallRef(n.frStep, fnIx) { return true }
    }
    return blockHasCallRef(n.frBody, fnIx)
  }
  if n is ForIn {
    if blockHasCallRef(n.fiIter, fnIx) { return true }
    return blockHasCallRef(n.fiBody, fnIx)
  }
  if n is BinExpr {
    if blockHasCallRef(n.binLeft, fnIx) { return true }
    return blockHasCallRef(n.binRight, fnIx)
  }
  if n is Unary { return blockHasCallRef(n.unArg, fnIx) }
  if n is Paren { return blockHasCallRef(n.parInner, fnIx) }
  // An `is` operand (`f(x) is i32`) may itself be a function-value call — without this the
  // closure scratch slot (`callRefSlot`) goes unreserved and the inline `call_ref` reads a
  // non-existent local 0.
  if n is IsExpr { return blockHasCallRef(n.isObj, fnIx) }
  if n is Member { return blockHasCallRef(n.memObj, fnIx) }
  if n is Index {
    if blockHasCallRef(n.idxArr, fnIx) { return true }
    return blockHasCallRef(n.idxIndex, fnIx)
  }
  if n is ObjLit {
    const fields = n.objFields
    let i = 0
    while i < fields.length {
      const f = P.nodes[fields[i]]
      if f is FieldInit {
        if blockHasCallRef(f.fiValue, fnIx) { return true }
      }
      i = i + 1
    }
    return false
  }
  if n is ArrayLit {
    const elems = n.arrElems
    let i = 0
    while i < elems.length {
      if blockHasCallRef(elems[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  false
}

// The current op's map struct heap type / vals wrapper / vals backing.
function cmMapTy() { mapTypeIdxOf(cmSlot) }
function cmValsWrap() { mvValsWrapOf(cmSlot) }
function cmValsBack() { mvValsBackOf(cmSlot) }

// The current op's mapRef local: the shared mono scratch slot 0, or this mv
// slot's typed frame slot (the mono `(ref $mStructIdx)` local cannot hold an mv
// map ref — the types differ).
function cmMapRefLocal() {
  if cmSlot < 0 { return mapScratchBase }
  fnMvMapRefLocal(cmSlot)
}
// The current op's vals-backing scratch local (grow/compact temporary).
function cmValsBkLocal() {
  if cmSlot < 0 { return mapScratchBase + 7 }
  fnMvValsBkLocal(cmSlot)
}

// `local.get` / `local.set` of the current op's mapRef.
function pushMapRef(body: i32[]) {
  fbLocalGet(cmMapRefLocal()) // 0x20 local.get
  0
}
function setMapRef(body: i32[]) {
  fbLocalSet(cmMapRefLocal()) // 0x21 local.set
  0
}

// `local.get` of map scratch slot `n` (the shared mono frame — every slot except
// the mapRef/valsBk/valStash trio is map-shape-agnostic and stays shared).
function pushMapScr(body: i32[], n: i32) {
  fbLocalGet(mapScratchBase + n) // 0x20 local.get
  0
}

// `local.set` of map scratch slot `n`.
function setMapScr(body: i32[], n: i32) {
  fbLocalSet(mapScratchBase + n) // 0x21 local.set
  0
}

// `M.keys` (the keys list wrapper ref): `local.get mapRef ; struct.get <mapTy> 0`.
function pushMapKeys(body: i32[]) {
  pushMapRef(body)
  fbStructGet(cmMapTy(), 0) // field 0: keys
  0
}

// `M.vals` (the vals list wrapper ref): `local.get mapRef ; struct.get <mapTy> 1`.
function pushMapVals(body: i32[]) {
  pushMapRef(body)
  fbStructGet(cmMapTy(), 1) // field 1: vals
  0
}

// `M.live` (the i32 tombstone array, parallel to entries; all 1s in this slice):
// `local.get mapRef ; struct.get <mapTy> 2`.
function pushMapLive(body: i32[]) {
  pushMapRef(body)
  fbStructGet(cmMapTy(), 2) // field 2: live
  0
}

// `M.index` (the i32 hash-slot array): `local.get mapRef ; struct.get <mapTy> 3`.
function pushMapIndex(body: i32[]) {
  pushMapRef(body)
  fbStructGet(cmMapTy(), 3) // field 3: index
  0
}

// `M.count` (entries appended): `local.get mapRef ; struct.get <mapTy> 4`.
function pushMapCount(body: i32[]) {
  pushMapRef(body)
  fbStructGet(cmMapTy(), 4) // field 4: count
  0
}

// `M.size` (live entry count): `local.get mapRef ; struct.get <mapTy> 5`.
function pushMapSize(body: i32[]) {
  pushMapRef(body)
  fbStructGet(cmMapTy(), 5) // field 5: size
  0
}

// `M.hashes` (the i32 per-entry FNV cache, parallel to the entries):
// `local.get mapRef ; struct.get <mapTy> 6`.
function pushMapHashes(body: i32[]) {
  pushMapRef(body)
  fbStructGet(cmMapTy(), 6) // field 6: hashes
  0
}

// Element-wise string equality of the two refs in map scratch slots `aSlot`/`bSlot`,
// leaving a 0/1 on the stack. A SELF-CONTAINED port of `emitStrEq`'s compare core
// (no operands consumed; reads the two scratch string locals directly) so the map
// scan can compare a stored key against the target key WITHOUT the str-op frame.
function emitMapKeyEq(body: i32[], aSlot: i32, bSlot: i32) {
  // block i32 { ... } — yields the 0/1 result.
  fbBlock(127) // 0x02 block, 0x7f i32 blocktype
  // if len(A) != len(B) { push 0 ; br 1 }
  pushMapScr(body, aSlot)
  fbArrayLen()  // array.len(A)
  pushMapScr(body, bSlot)
  fbArrayLen()  // array.len(B)
  fbI32Bin(71)  // 0x47 i32.ne
  fbIf(64)      // 0x04 if, 0x40 void blocktype
  fbI32Const(0) // i32.const 0
  fbBr(1)       // 0x0c br depth 1 → out of the i32 block
  fbEnd()       // 0x0b end (if)
  // I = 0  (slot 8, the dedicated char cursor — distinct from the OUTER scan's `idx`
  // in slot 3, which must survive across the key compare to set `hit = idx`)
  fbI32Const(0)
  setMapScr(body, 8)
  // loop { if I >= len(A) {} else { A[I] != B[I] ? 0,br : I++ , br loop } }
  fbLoop(64)          // 0x03 loop, 0x40 void blocktype
  pushMapScr(body, 8) // I
  pushMapScr(body, aSlot)
  fbArrayLen()        // array.len(A)
  fbI32Bin(78)        // 0x4e i32.ge_s  (I >= len → done)
  fbIf(64)            // 0x04 if, void
  // then: done (empty)
  fbElse() // 0x05 else
  // A[I] != B[I] ?
  pushMapScr(body, aSlot)
  pushMapScr(body, 8)
  fbArrayGet(aTypeIdx) // array.get
  pushMapScr(body, bSlot)
  pushMapScr(body, 8)
  fbArrayGet(aTypeIdx) // array.get
  fbI32Bin(71)         // 0x47 i32.ne
  fbIf(64)             // 0x04 if (mismatch → 0, exit block), void
  fbI32Const(0)        // i32.const 0
  fbBr(3)              // 0x0c br depth 3 → out of: if(0)·else(1)·loop(2)·block(3)
  fbEnd()              // 0x0b end (mismatch if)
  // I = I + 1
  pushMapScr(body, 8)
  fbI32Const(1)
  fbI32Bin(106) // i32.add
  setMapScr(body, 8)
  fbBr(1)       // 0x0c br depth 1 → loop header
  fbEnd()       // 0x0b end (ge_s if)
  fbEnd()       // 0x0b end (loop)
  // All chars matched → 1.
  fbI32Const(1)
  fbEnd() // 0x0b end (block)
  0
}

// FNV-1a hash of the string in scratch slot `strSlot`, leaving a NON-NEGATIVE i32
// hash on the stack. `h = 2166136261; for c in str { h = (h ^ c) * 16777619 };
// h & 0x7fffffff`. Uses slot 9 (accumulator `h`) and slot 8 (char cursor `i`). The
// 32-bit wasm `i32.mul` wraps exactly as the host's hash does.
function emitMapHashOf(body: i32[], strSlot: i32) {
  // h = 2166136261 (0x811c9dc5 — the FNV offset basis, as a signed i32 constant).
  fbI32Const(-2128831035) // i32.const; 2166136261 as signed = -2128831035
  setMapScr(body, 9)      // h
  // i = 0
  fbI32Const(0)
  setMapScr(body, 8) // i
  // loop { if i >= len(str) {} else { h = (h ^ str[i]) * 16777619 ; i++ ; br } }
  fbLoop(64)          // 0x03 loop, void
  pushMapScr(body, 8) // i
  pushMapScr(body, strSlot)
  fbArrayLen()        // array.len
  fbI32Bin(78)        // i32.ge_s (i >= len → done)
  fbIf(64)            // if, void
  // then: done (empty)
  fbElse() // else
  // h = (h ^ str[i]) * 16777619
  pushMapScr(body, 9)  // h
  pushMapScr(body, strSlot)
  pushMapScr(body, 8)  // i
  fbArrayGet(aTypeIdx) // array.get
  fbI32Bin(115)        // 0x73 i32.xor
  fbI32Const(16777619) // i32.const 16777619
  fbI32Bin(108)        // 0x6c i32.mul
  setMapScr(body, 9)   // h
  // i = i + 1
  pushMapScr(body, 8)
  fbI32Const(1)
  fbI32Bin(106) // i32.add
  setMapScr(body, 8)
  fbBr(1)       // br → loop header
  fbEnd()       // end (ge_s if)
  fbEnd()       // end (loop)
  // h & 0x7fffffff  — force non-negative (left on the stack).
  pushMapScr(body, 9)
  fbI32Const(2147483647) // i32.const 0x7fffffff
  fbI32Bin(113)          // 0x71 i32.and
  0
}

// PROBE: with `mapRef` (slot 0) and the target `keyRef` (slot 1) set, hash the key
// into `M.index` and linear-probe (wrapping) to the slot holding either the matching
// key's entry or a free (0) slot. Leaves `slot` (slot 3) = that probe slot and `entry`
// (slot 5) = `index[slot]` (0 = miss; else entry-position + 1). Shared by get / has /
// set / delete. The index load factor is kept < 1/2, so a free slot is always reached.
//
// TOMBSTONE-AWARE (mirrors the host's `mapSlotFn`): a slot whose entry is tombstoned
// (`live[entry-1] == 0`) is NOT a hit — it acts as a probe MARKER (kept so delete
// doesn't break the chain), so the probe skips past it. The stored per-entry hash
// (`hashes[entry-1]`) GATES the (string) key comparison: only run `keyEq` when the
// hash matches AND the entry is live. With `live` all-1s (delete-free programs) this
// is behavior-preserving — the live check is always true, and the hash always matches
// for the matching key (it is the same FNV of the same key).
function emitMapProbe(body: i32[]) {
  // cap = array.len(index)
  pushMapIndex(body)
  fbArrayLen()       // array.len
  setMapScr(body, 4) // cap
  // keyHash = hash(keyRef)  — computed ONCE, reused for the initial slot and to gate
  // the per-probe key comparison. Stash into slot 11 (rslot, free in the probe).
  if emitMapHashOf(body, 1) < 0 { return -1 }
  setMapScr(body, 11) // keyHash
  // slot = keyHash % cap
  pushMapScr(body, 11) // keyHash
  pushMapScr(body, 4)  // cap
  fbI32Bin(112)        // 0x70 i32.rem_u
  setMapScr(body, 3)   // slot
  // loop { entry = index[slot]
  //        if entry == 0 { break(miss) }
  //        if hashes[entry-1] == keyHash && live[entry-1] != 0 && keyEq(...) { break(hit) }
  //        slot = (slot + 1) % cap ; br loop }
  fbBlock(64) // 0x02 block (probe break target), void
  fbLoop(64)  // 0x03 loop, void
  // entry = index[slot]
  pushMapIndex(body)
  pushMapScr(body, 3)  // slot
  fbArrayGet(aTypeIdx) // array.get
  setMapScr(body, 5)   // entry
  // if entry == 0 { br 2 → out of the probe block (miss) }
  pushMapScr(body, 5)
  fbI32Eqz() // i32.eqz
  fbBrIf(1)  // 0x0d br_if depth 1 → out of the probe block
  // Match test, yielding 0/1 on the stack: hashes[entry-1] == keyHash
  //   && live[entry-1] != 0 && keyEq(keys[entry-1], keyRef). `i32.and` is
  //   unconditional, so the expensive `keyEq` rides an `if` to keep it off the
  //   mismatch path (mirrors the host's guarded `keyEq`).
  // hashes[entry-1] == keyHash
  pushMapHashes(body)
  pushMapScr(body, 5)  // entry
  fbI32Const(1)
  fbI32Bin(107)        // 0x6b i32.sub  (entry - 1)
  fbArrayGet(aTypeIdx) // array.get hashes[entry-1]
  pushMapScr(body, 11) // keyHash
  fbI32Bin(70)         // 0x46 i32.eq
  // && live[entry-1] != 0
  pushMapLive(body)
  pushMapScr(body, 5)  // entry
  fbI32Const(1)
  fbI32Bin(107)        // i32.sub (entry - 1)
  fbArrayGet(aTypeIdx) // array.get live[entry-1]
  fbI32Const(0)
  fbI32Bin(71)         // 0x47 i32.ne (live != 0)
  fbI32Bin(113)        // 0x71 i32.and (hash-match AND live)
  // ? keyEq(keys[entry-1], keyRef) : 0   — a value-typed if yielding i32.
  fbIf(127) // 0x04 if, 0x7f i32 blocktype
  // curRef = keys.backing[entry-1]  (ref.as_non_null — a stored slot is populated)
  pushMapKeys(body)
  fbStructGet(mkListIdx, 0) // field 0: backing
  pushMapScr(body, 5)       // entry
  fbI32Const(1)
  fbI32Bin(107)             // 0x6b i32.sub  (entry - 1)
  fbArrayGet(mkArrIdx)      // array.get
  wU8(212)                  // 0xd4 ref.as_non_null
  setMapScr(body, 2)        // curRef
  if emitMapKeyEq(body, 2, 1) < 0 { return -1 }
  fbElse()                  // else
  fbI32Const(0)             // hash/live mismatch → not a hit
  fbEnd()                   // end (if)
  // if match { br 2 → out of the probe block (hit) }
  fbBrIf(1) // 0x0d br_if depth 1 → out of the probe block
  // slot = (slot + 1) % cap  (collision OR a tombstoned slot: keep probing)
  pushMapScr(body, 3)
  fbI32Const(1)
  fbI32Bin(106)       // i32.add
  pushMapScr(body, 4) // cap
  fbI32Bin(112)       // i32.rem_u
  setMapScr(body, 3)  // slot
  fbBr(0)             // br → loop header
  fbEnd()             // end (loop)
  fbEnd()             // end (probe block)
  0
}

// Construct an EMPTY map `Map()` onto `body`: two empty lists (each `array.new_fixed`
// count 0, wrapped `{ backing, len=0, cap=0 }`), boxed into the map struct.
function emitMapNew(body: i32[]) {
  if !mUsed { return emitFail("emitProgram: Map() but map type not collected") }
  // The binding-seeded map SHAPE (consumed here): -1/-2 build the mono map; an mv
  // slot >= 0 builds THIS value type's map struct over its ref vals list.
  let slot = pendingMapSlot
  pendingMapSlot = -1
  if slot == -2 { slot = -1 }
  if slot == -3 {
    return emitFail(
      "emitProgram: unsupported map value type (only i32 / boolean / string / struct values)",
    )
  }
  // keys list: empty string-ref backing → wrapper.
  fbArrayNewFixed(mkArrIdx, 0) // 0 elements
  fbI32Const(0)                // len = 0
  fbI32Const(0)                // cap = 0
  fbStructNew(mkListIdx)
  // vals list: empty backing → wrapper (the i32 list, or the slot's ref list).
  fbArrayNewFixed(mvValsBackOf(slot), 0)
  fbI32Const(0)
  fbI32Const(0)
  fbStructNew(mvValsWrapOf(slot))
  // live: empty i32 array (cap 0), parallel to the empty keys/vals entry lists. It
  // grows in lockstep with the keys backing on append (a fresh entry is live = 1).
  fbArrayNewFixed(aTypeIdx, 0)
  // index: i32 hash-slot array of INITIAL_CAP*2 (16) zero-filled slots (0 = empty) —
  // matches the host's `mapNewFn` (4th `struct.new` operand `INITIAL_CAP * 2`). The
  // load factor is kept < 1/2 (resize at `size*2 >= cap`); starting at 2×INITIAL_CAP
  // (not INITIAL_CAP) means a tombstone-churn workload reaches the amortized-compaction
  // threshold (`(count - size) > size + INITIAL_CAP`) BEFORE the index fills with dead
  // probe markers — without it, same-key add/delete churn would fill all 8 slots with
  // dead markers and the next probe would spin forever (no free slot).
  fbI32Const(16) // i32.const 16 (INITIAL_CAP * 2)
  fbArrayNewDefault(aTypeIdx)
  // count = 0, size = 0.
  fbI32Const(0)
  fbI32Const(0)
  // hashes: empty i32 array (cap 0), parallel to the entries; grows in lockstep with
  // the keys backing on append (the stored FNV hash of each key). Mirrors the host's
  // 7th `struct.new` operand (`mapNewFn`); native sizes it like `live` (cap 0, grown
  // on demand) rather than INITIAL_CAP so the entry-parallel arrays stay length-locked.
  fbArrayNewFixed(aTypeIdx, 0)
  // map struct { keys, vals, live, index, count, size, hashes } — the mono struct,
  // or the mv slot's (identical shape, vals field referencing the slot's wrapper).
  fbStructNew(mapTypeIdxOf(slot))
  0
}

// Load the map receiver + key into the scratch frame (slots 0/1) and run the PROBE,
// leaving `slot` (slot 3) = the probe slot and `entry` (slot 5) = `index[slot]`
// (0 = miss; else entry-position + 1). `recvIx`/`keyIx` are arena indices; `recvIx`
// must be a map-typed expression and `keyIx` a string.
function emitMapPrep(body: i32[], recvIx: i32, keyIx: i32, fnIx: i32) {
  if !mUsed {
    return emitFail("emitProgram: map op but map type not collected")
  }
  if !exprMap(recvIx, fnIx) {
    return emitFail("emitProgram: map op receiver is not a map")
  }
  if !exprString(keyIx, fnIx) {
    return emitFail("emitProgram: map key is not a string")
  }
  // Resolve the receiver's map SHAPE into the op context. A Set (-2) runs on the
  // mono machinery; an unsupported value type (-3) fails loudly.
  let mshape = mapShapeOfExpr(recvIx, fnIx)
  if mshape == -2 { mshape = -1 }
  if mshape == -3 {
    return emitFail(
      "emitProgram: unsupported map value type (only i32 / boolean / string / struct values)",
    )
  }
  // The receiver expr is emitted OUTSIDE the context (it is map-op-free by
  // construction — an Ident/global/constructor), then the context pins the typed
  // mapRef store. The KEY expr may contain an inner map op (`m[n[k] ?? "d"]`),
  // which clobbers `cmSlot` — re-pin it before the probe.
  if emitExpr(body, recvIx, fnIx) < 0 { return -1 }
  cmSlot = mshape
  setMapRef(body)    // mapRef (the shared mono slot, or this mv frame's)
  if emitExpr(body, keyIx, fnIx) < 0 { return -1 }
  cmSlot = mshape
  setMapScr(body, 1) // keyRef
  emitMapProbe(body)
}

// Lower a map GET `m[k]` with a DEFAULT (`m[k] ?? d`) onto `body`: probe, then if the
// key was found push `vals[entry-1]`, else push the default `d`. The self-host checker
// ALWAYS reads a map through `?? -1` (a total fallback), so this is the primary get.
function emitMapGetOr(
  body: i32[],
  recvIx: i32,
  keyIx: i32,
  defIx: i32,
  fnIx: i32,
) {
  if emitMapPrep(body, recvIx, keyIx, fnIx) < 0 { return -1 }
  if cmSlot >= 0 {
    // REF values: a value-typed `if` would need an interned blocktype functype, so
    // route through the slot's NULLABLE valStash local instead — both arms set it
    // (the hit arm with the (ref null) slot read, the miss arm with the default's
    // non-null value), then `ref.as_non_null` recovers the non-null result the
    // `??` expression's type promises. A live entry's val slot is never null.
    const mslot = cmSlot
    // A SCALAR-valued map (f64/i64) stores the value directly; its default is emitted in
    // the value's rep and it needs no `ref.as_non_null`. A ref value (string/struct) does.
    const scalarVK = mvScalarValKind(mslot)
    pushMapScr(body, 5)          // entry
    fbIf(64)                     // if (entry != 0 → found), void
    pushMapVals(body)
    fbStructGet(cmValsWrap(), 0) // vals backing
    pushMapScr(body, 5)          // entry
    fbI32Const(1)
    fbI32Bin(107)                // i32.sub (entry - 1)
    fbArrayGet(cmValsBack())     // scalar (f64/i64) / (ref null <elem>) slot read
    fbLocalSet(fnMvValStashLocal(mslot))
    fbElse()                     // else
    if scalarVK >= 0 {
      if emitScalarValue(body, defIx, fnIx, scalarVK) < 0 { return -1 }
    } else if mslot >= 0 && mvValKind[mslot] == 2 {
      // A UNION-valued map's default is coerced into the shared box, like a stored value — a
      // concrete VARIANT default boxes (`emitUnionBoxArg`), as in a call arg / return.
      if emitUnionBoxArg(body, mvValName[mslot], defIx, fnIx) < 0 { return -1 }
    } else if mslot >= 0 && mvListValKind(mslot) == 5 {
      // A STRUCT-LIST value: hint an empty `[]` default to an empty ref list of the inner
      // struct (`pendingListKind` 1 = struct-element, `pendingListSlot` the inner slot).
      const savedSK = pendingListKind
      const savedSS = pendingListSlot
      pendingListKind = 1
      pendingListSlot = rlSlotByName(refArrElemName(mvValName[mslot]))
      if emitExpr(body, defIx, fnIx) < 0 { return -1 }
      pendingListKind = savedSK
      pendingListSlot = savedSS
    } else {
      // For a non-i32 LIST-valued map, hint an empty `[]` default to the value's list
      // wrapper (`pendingListKind` 3 string / 4 f64 / 6 i64) — an unhinted `[]` defaults to
      // the i32-list wrapper, which the `(ref null <wrapper>)` valStash would reject.
      const savedPLK = pendingListKind
      const lvk = mvListValKind(mslot)
      if lvk == 7 { pendingListKind = 3 }
      else if lvk == 12 { pendingListKind = 4 }
      else if lvk == 20 { pendingListKind = 6 }
      else if lvk == 21 { pendingListKind = 7 }
      if emitExpr(body, defIx, fnIx) < 0 { return -1 }
      pendingListKind = savedPLK
    }
    cmSlot = mslot
    fbLocalSet(fnMvValStashLocal(mslot))
    fbEnd() // end (if)
    fbLocalGet(fnMvValStashLocal(mslot))
    // A scalar f64/i64 result needs no null-recovery; a ref value does (`??` is non-null).
    if scalarVK < 0 { fbRefAsNonNull() }
    return 0
  }
  // if entry != 0 { vals.backing[entry-1] } else { d }  — a value-typed if yielding i32.
  pushMapScr(body, 5) // entry
  fbIf(127)           // if (entry != 0 → found; a nonzero condition is true), 0x7f i32 blocktype
  // vals.backing[entry-1]
  pushMapVals(body)
  fbStructGet(lTypeIdx, 0) // struct.get (vals backing), field 0: backing
  pushMapScr(body, 5)      // entry
  fbI32Const(1)
  fbI32Bin(107)            // 0x6b i32.sub  (entry - 1)
  fbArrayGet(aTypeIdx)     // array.get
  fbElse()                 // else
  if emitExpr(body, defIx, fnIx) < 0 { return -1 }
  fbEnd()                  // end (if)
  0
}

// Lower a bare map GET `m[k]` (no `??`) onto `body`: probe, return `vals[entry-1]` or
// `0` when absent. The checker never uses a bare map get (always `?? -1`); provided for
// completeness so `m[k]` in value position is total (0 default).
function emitMapGet(body: i32[], recvIx: i32, keyIx: i32, fnIx: i32) {
  if emitMapPrep(body, recvIx, keyIx, fnIx) < 0 { return -1 }
  if cmSlot >= 0 {
    // REF values: yield the NULLABLE element — the (ref null <elem>) vals slot on
    // a hit, `ref.null <elem>` on a miss — via the slot's valStash (same
    // blocktype-avoidance as `emitMapGetOr`). The `m[k]` type is `V | null`.
    const mslot = cmSlot
    pushMapScr(body, 5) // entry
    fbIf(64)            // if (entry != 0), void
    pushMapVals(body)
    fbStructGet(cmValsWrap(), 0)
    pushMapScr(body, 5) // entry
    fbI32Const(1)
    fbI32Bin(107)       // i32.sub (entry - 1)
    fbArrayGet(cmValsBack())
    fbLocalSet(fnMvValStashLocal(mslot))
    fbElse()            // else
    // A miss yields the rep's empty value: 0.0 for an f64 map, 0 for an i64 map, else
    // `ref.null` for a ref (string/struct) value.
    if mvValKind[mslot] == 11 { fbF64Const("0") }
    else if mvValKind[mslot] == 10 { fbI64Const(0, 0) }
    else { fbRefNull(mvValElemHeapOf(mslot)) }
    fbLocalSet(fnMvValStashLocal(mslot))
    fbEnd() // end
    fbLocalGet(fnMvValStashLocal(mslot))
    return 0
  }
  pushMapScr(body, 5) // entry
  fbIf(127)           // if (entry != 0), i32 blocktype
  pushMapVals(body)
  fbStructGet(lTypeIdx, 0)
  pushMapScr(body, 5) // entry
  fbI32Const(1)
  fbI32Bin(107)       // i32.sub (entry - 1)
  fbArrayGet(aTypeIdx)
  fbElse()            // else
  fbI32Const(0)       // i32.const 0
  fbEnd()             // end
  0
}

// Lower a map HAS `m.has(k)` / `k in m` onto `body`: probe, push 1 if found else 0.
function emitMapHas(body: i32[], recvIx: i32, keyIx: i32, fnIx: i32) {
  if emitMapPrep(body, recvIx, keyIx, fnIx) < 0 { return -1 }
  pushMapScr(body, 5) // entry
  fbI32Const(0)
  fbI32Bin(71)        // 0x47 i32.ne (entry != 0 → 1, else 0)
  0
}

// Lower `m.keys()` onto `body`, leaving a fresh STRING list (`$mkListIdx`) of the map's
// LIVE keys in insertion order. The ordered keys/live arrays carry tombstoned entries
// after a delete (`live[i] == 0`), so it copies only live keys: `out[j++] = keys[i]` for
// every `i` in `[0, count)` with `live[i] != 0`, then wraps `out` with `len = j`. Uses
// the 6-slot key-list builder frame (`mapKeysBase`). The receiver is re-emitted to read
// each of its three fields (a map op receiver is a simple binding — re-reading is
// effect-free), avoiding a per-shape map-ref local.
function emitMapKeys(body: i32[], recvIx: i32, fnIx: i32) {
  if !slUsed {
    return emitFail("emitProgram: .keys() but string list type not collected")
  }
  if !exprMap(recvIx, fnIx) {
    return emitFail("emitProgram: .keys() receiver is not a map")
  }
  if !fnUsesMapKeys {
    return emitFail("emitProgram: .keys() scratch frame not reserved")
  }
  let shape = mapShapeOfExpr(recvIx, fnIx)
  if shape == -2 {
    shape = -1 // a Set keys() over the mono machinery
  }
  if shape == -3 {
    return emitFail(
      "emitProgram: unsupported map value type (only i32 / boolean / string / struct values)",
    )
  }
  const mapTy = mapTypeIdxOf(shape)
  const outBackL = mapKeysBase + 0
  const keysBackL = mapKeysBase + 1
  const liveL = mapKeysBase + 2
  const iL = mapKeysBase + 3
  const jL = mapKeysBase + 4
  const countL = mapKeysBase + 5
  // keysBack = recv.keys.backing  (field 0 = keys wrapper, its field 0 = backing)
  if emitExpr(body, recvIx, fnIx) < 0 { return -1 }
  fbStructGet(mapTy, 0)
  fbStructGet(mkListIdx, 0)
  fbLocalSet(keysBackL)
  // live = recv.live  (field 2)
  if emitExpr(body, recvIx, fnIx) < 0 { return -1 }
  fbStructGet(mapTy, 2)
  fbLocalSet(liveL)
  // count = recv.count  (field 4 — entries INCLUDING tombstones)
  if emitExpr(body, recvIx, fnIx) < 0 { return -1 }
  fbStructGet(mapTy, 4)
  fbLocalSet(countL)
  // out = array.new_default $mkArrIdx count  (sized at count; `len` set to the live j)
  fbLocalGet(countL)
  fbArrayNewDefault(mkArrIdx)
  fbLocalSet(outBackL)
  // j = 0 ; i = 0
  fbI32Const(0)
  fbLocalSet(jL)
  fbI32Const(0)
  fbLocalSet(iL)
  // loop { if i >= count {} else { if live[i] != 0 { out[j]=keys[i]; j++ } ; i++ ; br } }
  fbLoop(64)
  fbLocalGet(iL)
  fbLocalGet(countL)
  fbI32Bin(78) // 0x4e i32.ge_s (i >= count → done)
  fbIf(64)
  // then: done (empty)
  fbElse()
  // if live[i] != 0
  fbLocalGet(liveL)
  fbLocalGet(iL)
  fbArrayGet(aTypeIdx)
  fbI32Const(0)
  fbI32Bin(71) // 0x47 i32.ne
  fbIf(64)
  // out[j] = keys[i]
  fbLocalGet(outBackL)
  fbLocalGet(jL)
  fbLocalGet(keysBackL)
  fbLocalGet(iL)
  fbArrayGet(mkArrIdx)
  fbArraySet(mkArrIdx)
  // j = j + 1
  fbLocalGet(jL)
  fbI32Const(1)
  fbI32Bin(106) // i32.add
  fbLocalSet(jL)
  fbEnd() // end (live if)
  // i = i + 1
  fbLocalGet(iL)
  fbI32Const(1)
  fbI32Bin(106) // i32.add
  fbLocalSet(iL)
  fbBr(1) // → loop header (else=0, loop=1)
  fbEnd() // end (ge_s if/else)
  fbEnd() // end (loop)
  // wrapper = struct.new $mkListIdx (out, len=j, cap=count)
  fbLocalGet(outBackL)
  fbLocalGet(jL)
  fbLocalGet(countL)
  fbStructNew(mkListIdx)
  0
}

// Lower `m.values()` over a MONO i32 map onto `body`, leaving a fresh i32 list (`$lTypeIdx`)
// of the map's LIVE values in insertion order — the value analogue of `emitMapKeys`, reading
// the ordered VALS list (field 1) instead of keys and skipping tombstoned entries
// (`live[i] == 0`). Other value types (string / struct / f64 / i64 / ref) iterate fine via
// `for v in m.values()` but the BOUND list form here is i32-only for now (the output backing
// type would otherwise vary per value kind). Uses the 6-slot `mapValsBase` frame.
function emitMapValues(body: i32[], recvIx: i32, fnIx: i32) {
  if !exprMap(recvIx, fnIx) {
    return emitFail("emitProgram: .values() receiver is not a map")
  }
  let shape = mapShapeOfExpr(recvIx, fnIx)
  // A SET's `.values()` yields its ELEMENTS (the string keys), built by `emitMapKeys`.
  if shape == -2 { return emitMapKeys(body, recvIx, fnIx) }
  if shape == -3 {
    return emitFail(
      "emitProgram: unsupported map value type (only i32 / boolean / string / struct / f64 / i64 / nested values)",
    )
  }
  if !fnUsesMapVals {
    return emitFail("emitProgram: .values() scratch frame not reserved")
  }
  const mapTy = mapTypeIdxOf(shape)
  const valsWrap = mvValsWrapOf(shape)
  const valsBack = mvValsBackOf(shape)
  // Frame: a MONO map's self-contained `mapValsBase` (all i32-backed), an mv map's per-slot
  // output backing + the mv frame's `valsBk` source + the key-list frame's live/i/j/count.
  let outBackL = mapValsBase + 0
  let valsBackL = mapValsBase + 1
  let liveL = mapValsBase + 2
  let iL = mapValsBase + 3
  let jL = mapValsBase + 4
  let countL = mapValsBase + 5
  if shape >= 0 {
    outBackL = fnMvValsOutLocal(shape)
    valsBackL = fnMvValsBkLocal(shape)
    liveL = mapKeysBase + 2
    iL = mapKeysBase + 3
    jL = mapKeysBase + 4
    countL = mapKeysBase + 5
  }
  // valsBack = recv.vals.backing  (field 1 = vals wrapper, its field 0 = backing)
  if emitExpr(body, recvIx, fnIx) < 0 { return -1 }
  fbStructGet(mapTy, 1)
  fbStructGet(valsWrap, 0)
  fbLocalSet(valsBackL)
  // live = recv.live  (field 2)
  if emitExpr(body, recvIx, fnIx) < 0 { return -1 }
  fbStructGet(mapTy, 2)
  fbLocalSet(liveL)
  // count = recv.count  (field 4 — entries INCLUDING tombstones)
  if emitExpr(body, recvIx, fnIx) < 0 { return -1 }
  fbStructGet(mapTy, 4)
  fbLocalSet(countL)
  // out = array.new_default <valsBack> count
  fbLocalGet(countL)
  fbArrayNewDefault(valsBack)
  fbLocalSet(outBackL)
  fbI32Const(0)
  fbLocalSet(jL)
  fbI32Const(0)
  fbLocalSet(iL)
  // loop { if i >= count {} else { if live[i] != 0 { out[j]=vals[i]; j++ } ; i++ ; br } }
  fbLoop(64)
  fbLocalGet(iL)
  fbLocalGet(countL)
  fbI32Bin(78) // i32.ge_s
  fbIf(64)
  fbElse()
  fbLocalGet(liveL)
  fbLocalGet(iL)
  fbArrayGet(aTypeIdx)
  fbI32Const(0)
  fbI32Bin(71) // i32.ne
  fbIf(64)
  // out[j] = vals[i]
  fbLocalGet(outBackL)
  fbLocalGet(jL)
  fbLocalGet(valsBackL)
  fbLocalGet(iL)
  fbArrayGet(valsBack)
  fbArraySet(valsBack)
  fbLocalGet(jL)
  fbI32Const(1)
  fbI32Bin(106)
  fbLocalSet(jL)
  fbEnd() // end (live if)
  fbLocalGet(iL)
  fbI32Const(1)
  fbI32Bin(106)
  fbLocalSet(iL)
  fbBr(1)
  fbEnd() // end (ge_s if/else)
  fbEnd() // end (loop)
  // wrapper = struct.new <valsWrap> (out, len=j, cap=count)
  fbLocalGet(outBackL)
  fbLocalGet(jL)
  fbLocalGet(countL)
  fbStructNew(valsWrap)
  0
}

// REHASH primitive: with `mapRef` in slot 0 and the target capacity in slot 4
// (`newCap`), allocate a fresh `index` of `newCap` slots and REBUILD it from the LIVE
// entries — for each entry `i` in `[0, count)` with `live[i] != 0`, RE-PLACE from the
// STORED `hashes[i]` (no key re-hashing — mirrors the host's `mapRehashFn`) and
// linear-probe to a free slot, writing `i+1`. The ordered keys/vals/live/hashes are
// UNTOUCHED (insertion order preserved); only `index` is rebuilt. Scratch use (all
// free after the probe/append): 4 newCap, 3 entry cursor `i`, 10 new index backing, 11
// inner probe slot. Used by `emitMapResize` (load-factor grow, newCap = 2×cap) and
// `emitMapCompact` (shrink to a live-count-based cap).
function emitMapRehashTo(body: i32[]) {
  // idxBk = array.new_default $aTypeIdx newCap  (zero-filled)
  pushMapScr(body, 4) // newCap (slot 4, set by the caller)
  fbArrayNewDefault(aTypeIdx)
  setMapScr(body, 10) // idxBk (slot 10)
  // i = 0
  fbI32Const(0)
  setMapScr(body, 3) // i (slot 3)
  // loop { if i >= count {} else { rebuild entry i ; i++ ; br } }
  fbLoop(64)          // loop, void
  pushMapScr(body, 3) // i
  pushMapCount(body)
  fbI32Bin(78)        // i32.ge_s (i >= count → done)
  fbIf(64)            // if, void
  // then: done (empty)
  fbElse() // else
  // Skip tombstoned entries — only LIVE entries get re-placed in the new index (mirror
  // the host's `mapRehashFn` `if live[i] != 0`). `live` is all-1s in a delete-free
  // program, so this `if` is always taken (behavior-preserving).
  pushMapLive(body)
  pushMapScr(body, 3)  // i
  fbArrayGet(aTypeIdx) // array.get live[i]
  fbI32Const(0)
  fbI32Bin(71)         // 0x47 i32.ne (live[i] != 0)
  fbIf(64)             // if, void
  // rslot = hashes[i] % newCap  — RE-PLACE FROM THE STORED HASH (no key re-hashing).
  pushMapHashes(body)
  pushMapScr(body, 3)  // i
  fbArrayGet(aTypeIdx) // array.get hashes[i]
  pushMapScr(body, 4)  // newCap
  fbI32Bin(112)        // i32.rem_u
  setMapScr(body, 11)  // rslot
  // while idxBk[rslot] != 0 { rslot = (rslot + 1) % newCap }
  fbBlock(64) // block (inner probe break), void
  fbLoop(64)  // loop, void
  // if idxBk[rslot] == 0 { br 1 → out of inner block }
  pushMapScr(body, 10) // idxBk
  pushMapScr(body, 11) // rslot
  fbArrayGet(aTypeIdx) // array.get
  fbI32Eqz()           // i32.eqz
  fbBrIf(1)            // br_if depth 1 → out of inner block
  // rslot = (rslot + 1) % newCap
  pushMapScr(body, 11)
  fbI32Const(1)
  fbI32Bin(106)       // i32.add
  pushMapScr(body, 4) // newCap
  fbI32Bin(112)       // i32.rem_u
  setMapScr(body, 11)
  fbBr(0)             // br → inner loop header
  fbEnd()             // end (inner loop)
  fbEnd()             // end (inner block)
  // idxBk[rslot] = i + 1
  pushMapScr(body, 10) // idxBk
  pushMapScr(body, 11) // rslot
  pushMapScr(body, 3)  // i
  fbI32Const(1)
  fbI32Bin(106)        // i32.add (i + 1)
  fbArraySet(aTypeIdx) // array.set
  fbEnd()              // end (live[i] != 0 if)
  // i = i + 1
  pushMapScr(body, 3)
  fbI32Const(1)
  fbI32Bin(106) // i32.add
  setMapScr(body, 3)
  fbBr(1)       // br → outer loop header
  fbEnd()       // end (ge_s if)
  fbEnd()       // end (outer loop)
  // M.index = idxBk
  pushMapRef(body)          // mapRef
  pushMapScr(body, 10)      // idxBk
  fbStructSet(cmMapTy(), 3) // struct.set field 3: index
  0
}

// Resize the `index` when the load factor (size / cap) crosses 1/2: pick newCap =
// 2×cap and rebuild via `emitMapRehashTo`. The ordered entry lists are untouched.
function emitMapResize(body: i32[]) {
  // if size * 2 >= len(index) { rehash to 2 * len(index) }
  pushMapSize(body)
  fbI32Const(2)
  fbI32Bin(108) // i32.mul (size * 2)
  pushMapIndex(body)
  fbArrayLen()  // array.len
  fbI32Bin(79)  // 0x4f i32.ge_u (size*2 >= cap)
  fbIf(64)      // if, void
  // newCap = 2 * len(index)
  pushMapIndex(body)
  fbArrayLen()       // array.len
  fbI32Const(2)
  fbI32Bin(108)      // i32.mul
  setMapScr(body, 4) // newCap (slot 4)
  if emitMapRehashTo(body) < 0 { return -1 }
  fbEnd()            // end (resize if)
  0
}

// `emitMapCompact` (mirror of the host's `mapCompactFn`): reclaim tombstones. Rebuild
// keys/vals/live/hashes from the LIVE entries only (dropping deleted ones, preserving
// insertion order), set `count = size`, then rebuild the index at a live-count-based
// capacity (next pow2 ≥ 2×size, floored at INITIAL_CAP*2 = 16). This bounds `count`
// and the entry+index arrays under add/delete churn. `mapRef` in slot 0. Scratch:
//   6 nk (ref $mkArrIdx), 7 nv (ref $aTypeIdx), 10 nl (ref $aTypeIdx),
//   13 nh (ref $aTypeIdx) — the rebuilt entry arrays; 8 = i (read cursor),
//   9 = j (write cursor), 11 = target cap; 4 = newCap for `emitMapRehashTo`.
function emitMapCompact(body: i32[]) {
  // Fresh entry arrays sized to the OLD entry capacity (keeps spare room; lengths are
  // irrelevant to iteration — count/size bound it). Mirrors the host's `array.new_default
  // (len(oldArr))`.
  // nk = new keys backing (slot 6)
  pushMapKeysBacking(body)
  fbArrayLen()
  fbArrayNewDefault(mkArrIdx)
  setMapScrKB(body) // nk (slot 6)
  // nv = new vals backing (the valsBk scratch — slot 7 mono, the mv frame else)
  pushMapValsBacking(body)
  fbArrayLen()
  fbArrayNewDefault(cmValsBack())
  setMapScrVB(body) // nv
  // nl = new live backing (slot 10)
  pushMapLive(body)
  fbArrayLen()
  fbArrayNewDefault(aTypeIdx)
  setMapScr(body, 10) // nl (slot 10)
  // nh = new hashes backing (slot 13)
  pushMapHashes(body)
  fbArrayLen()
  fbArrayNewDefault(aTypeIdx)
  setMapScrHB(body) // nh (slot 13)
  // i = 0 ; j = 0
  fbI32Const(0)
  setMapScr(body, 8) // i (read cursor)
  fbI32Const(0)
  setMapScr(body, 9) // j (write cursor)
  // Copy the live entries down, compacting out tombstones (order kept).
  // loop { if i >= count {} else { if live[i] != 0 { copy i->j ; j++ } ; i++ ; br } }
  fbLoop(64)          // loop, void
  pushMapScr(body, 8) // i
  pushMapCount(body)
  fbI32Bin(78)        // i32.ge_s (i >= count → done)
  fbIf(64)            // if, void
  // then: done (empty)
  fbElse()             // else
  pushMapLive(body)
  pushMapScr(body, 8)  // i
  fbArrayGet(aTypeIdx) // live[i]
  fbI32Const(0)
  fbI32Bin(71)         // i32.ne (live[i] != 0)
  fbIf(64)             // if, void
  // nk[j] = keys.backing[i]
  pushMapScrKB(body)   // nk
  pushMapScr(body, 9)  // j
  pushMapKeysBacking(body)
  pushMapScr(body, 8)  // i
  fbArrayGet(mkArrIdx) // keys.backing[i] (nullable string ref)
  fbArraySet(mkArrIdx)
  // nv[j] = vals.backing[i]
  pushMapScrVB(body)       // nv
  pushMapScr(body, 9)      // j
  pushMapValsBacking(body)
  pushMapScr(body, 8)      // i
  fbArrayGet(cmValsBack()) // vals.backing[i]
  fbArraySet(cmValsBack())
  // nl[j] = 1
  pushMapScr(body, 10) // nl
  pushMapScr(body, 9)  // j
  fbI32Const(1)
  fbArraySet(aTypeIdx)
  // nh[j] = hashes[i]
  pushMapScrHB(body)   // nh
  pushMapScr(body, 9)  // j
  pushMapHashes(body)
  pushMapScr(body, 8)  // i
  fbArrayGet(aTypeIdx) // hashes[i]
  fbArraySet(aTypeIdx)
  // j = j + 1
  pushMapScr(body, 9)
  fbI32Const(1)
  fbI32Bin(106)
  setMapScr(body, 9)
  fbEnd() // end (live[i] != 0 if)
  // i = i + 1
  pushMapScr(body, 8)
  fbI32Const(1)
  fbI32Bin(106)
  setMapScr(body, 8)
  fbBr(1) // br → loop header
  fbEnd() // end (ge_s if)
  fbEnd() // end (loop)
  // Swap the rebuilt entry arrays into the keys/vals list wrappers + the struct.
  // keys.backing = nk ; keys.len = size ; keys.cap = len(nk)
  pushMapKeys(body)
  pushMapScrKB(body)
  fbStructSet(mkListIdx, 0) // keys.backing = nk
  pushMapKeys(body)
  pushMapSize(body)
  fbStructSet(mkListIdx, 1) // keys.len = size
  pushMapKeys(body)
  pushMapScrKB(body)
  fbArrayLen()
  fbStructSet(mkListIdx, 2) // keys.cap = len(nk)
  // vals.backing = nv ; vals.len = size ; vals.cap = len(nv)
  pushMapVals(body)
  pushMapScrVB(body)
  fbStructSet(cmValsWrap(), 0) // vals.backing = nv
  pushMapVals(body)
  pushMapSize(body)
  fbStructSet(cmValsWrap(), 1) // vals.len = size
  pushMapVals(body)
  pushMapScrVB(body)
  fbArrayLen()
  fbStructSet(cmValsWrap(), 2) // vals.cap = len(nv)
  // M.live = nl ; M.hashes = nh
  pushMapRef(body)
  pushMapScr(body, 10)      // nl
  fbStructSet(cmMapTy(), 2) // live = nl
  pushMapRef(body)
  pushMapScrHB(body)        // nh
  fbStructSet(cmMapTy(), 6) // hashes = nh
  // count = size (no tombstones remain)
  pushMapRef(body)
  pushMapSize(body)
  fbStructSet(cmMapTy(), 4) // count = size
  // Target index cap: next pow2 ≥ 2×size, floored at INITIAL_CAP*2 = 16. cap in slot 11.
  fbI32Const(16)
  setMapScr(body, 11) // cap
  // while cap < 2*size { cap = cap * 2 }
  fbLoop(64)           // loop, void
  pushMapScr(body, 11) // cap
  pushMapSize(body)
  fbI32Const(2)
  fbI32Bin(108)        // size * 2
  fbI32Bin(79)         // 0x4f i32.ge_u (cap >= 2*size → done)
  fbIf(64)             // if, void
  // then: done (empty)
  fbElse()      // else
  pushMapScr(body, 11)
  fbI32Const(2)
  fbI32Bin(108) // cap * 2
  setMapScr(body, 11)
  fbBr(1)       // br → loop header
  fbEnd()       // end (ge_u if)
  fbEnd()       // end (loop)
  // Rebuild the index at the chosen cap.
  pushMapScr(body, 11) // cap
  setMapScr(body, 4)   // newCap (for emitMapRehashTo)
  if emitMapRehashTo(body) < 0 { return -1 }
  0
}

// Lower a map DELETE `m.delete(k): boolean` onto `body` (mirror of the host's
// `mapDeleteFn`): probe to the entry; if `index[slot] == 0` push 0 (absent), else
// tombstone `live[entry-1] = 0`, `size -= 1`, amortized-`compact` when dead entries
// (`count - size`) exceed `size + INITIAL_CAP`, and push 1. Leaves a 0/1 i32 on the
// stack (consumed as a boolean expression, or dropped as a bare statement).
function emitMapDelete(body: i32[], recvIx: i32, keyIx: i32, fnIx: i32) {
  if emitMapPrep(body, recvIx, keyIx, fnIx) < 0 { return -1 }
  // if entry == 0 { 0 } else { tombstone ; size-- ; maybe-compact ; 1 }
  pushMapScr(body, 5) // entry
  fbIf(127)           // if (entry != 0), 0x7f i32 blocktype
  // live[entry-1] = 0  (tombstone; keeps the entry's insertion-order position)
  pushMapLive(body)
  pushMapScr(body, 5)  // entry
  fbI32Const(1)
  fbI32Bin(107)        // i32.sub (entry - 1)
  fbI32Const(0)
  fbArraySet(aTypeIdx) // array.set live[entry-1] = 0
  // size = size - 1
  pushMapRef(body)          // mapRef
  pushMapSize(body)
  fbI32Const(1)
  fbI32Bin(107)             // i32.sub
  fbStructSet(cmMapTy(), 5) // struct.set field 5: size
  // Amortized compaction: if (count - size) > (size + INITIAL_CAP) { compact }.
  pushMapCount(body)
  pushMapSize(body)
  fbI32Bin(107) // i32.sub (count - size)
  pushMapSize(body)
  fbI32Const(8) // INITIAL_CAP
  fbI32Bin(106) // i32.add (size + INITIAL_CAP)
  fbI32Bin(75)  // 0x4b i32.gt_u ((count-size) > (size+INITIAL_CAP))
  fbIf(64)      // if, void
  if emitMapCompact(body) < 0 { return -1 }
  fbEnd()       // end (compact if)
  // result = 1 (a key was removed)
  fbI32Const(1)
  fbElse() // else
  // result = 0 (absent)
  fbI32Const(0)
  fbEnd() // end (entry if)
  0
}

// Lower a map SET `m[k] = v` onto `body`: probe; on a HIT (`entry != 0`) overwrite
// `vals.backing[entry-1] = v`, else APPEND a new entry — link the index slot, push the
// key + value onto the ordered entry lists, bump `count`/`size`, and resize the index
// if the load factor crossed 1/2. The append reuses the inline list-grow push over the
// keys (string-ref) and vals (i32) lists. Run from `emitAssign` (a statement).
//
// Ordering matters: `index[slot] = count+1` is written BEFORE the two pushes, because
// `emitMapPushKey`/`emitMapPushVal` clobber the probe slot (slot 3) and cap (slot 4).
// `m[k] = v` / `m.set(k, v)`. The Set form `s.add(k)` reuses this exact lowering with
// `valConst1 = true`: the stored value is the constant boolean `1` (true) instead of an
// evaluated value expression (and `valIx` is ignored). EXISTING callers pass
// `valConst1 = false` so their emitted bytes stay byte-identical.
function emitMapSetV(
  body: i32[],
  recvIx: i32,
  keyIx: i32,
  valIx: i32,
  fnIx: i32,
  valConst1: boolean,
) {
  // A MONO (i32/boolean-valued) map cannot store a REF value (a string / struct /
  // list ref into an i32 array is invalid wasm) — fail loudly. A ref-valued map
  // (mv slot) stores string/struct values through its own typed vals list. (A
  // constant-true Set value is always a valid i32 boolean.) The shape is resolved
  // here only for the GATE; `emitMapPrep` re-resolves it into the op context.
  if valConst1 == false {
    if mapShapeOfExpr(recvIx, fnIx) < 0 {
      if (
        exprString(valIx, fnIx) ||
        exprStruct(valIx, fnIx) ||
        exprArray(valIx, fnIx) ||
        exprRefArray(valIx, fnIx) ||
        exprStringArray(valIx, fnIx)
      ) {
        return emitFail("emitProgram: map values must be i32 / boolean")
      }
    }
  }
  if emitMapPrep(body, recvIx, keyIx, fnIx) < 0 { return -1 }
  const mslot = cmSlot
  pushMapScr(body, 5) // entry
  fbIf(64)            // if (entry != 0 → overwrite), void
  // OVERWRITE: vals.backing[entry-1] = v
  pushMapVals(body)
  fbStructGet(cmValsWrap(), 0) // struct.get (vals backing), field 0: backing
  pushMapScr(body, 5)          // entry
  fbI32Const(1)
  fbI32Bin(107)                // i32.sub (entry - 1)
  if valConst1 {
    fbI32Const(1) // Set value: constant boolean true
  } else if mvScalarValKind(mslot) >= 0 {
    // A SCALAR-valued map (f64/i64): emit the value coerced to the element rep.
    if emitScalarValue(body, valIx, fnIx, mvScalarValKind(mslot)) < 0 {
      return -1
    }
    cmSlot = mslot
  } else if mslot >= 0 && mvValKind[mslot] == 2 {
    // A UNION-valued map: box the overwrite value into the shared union box (a concrete
    // VARIANT value boxes via `emitUnionBoxArg`, like a call arg / return).
    if emitUnionBoxArg(body, mvValName[mslot], valIx, fnIx) < 0 { return -1 }
    cmSlot = mslot
  } else {
    // Seed a non-i32 scalar-LIST value's inner list kind (as the append path / `?? default`
    // read do) so an overwrite `m[k] = [1,2,3]` builds the i64/f64/string list wrapper, not
    // the default i32-list that would mismatch the typed element slot.
    const savedPLK = pendingListKind
    const savedPLS = pendingListSlot
    const lvk = mvListValKind(mslot)
    if lvk == 7 {
      pendingListKind = 3
    } else if lvk == 12 {
      pendingListKind = 4
    } else if lvk == 20 {
      pendingListKind = 6
    } else if lvk == 21 {
      pendingListKind = 7
    } else if mslot >= 0 && nameIsRefArray(mvValName[mslot]) {
      // A REF-list value (`S[]` / `(C|D)[]` / a nested `S[][]` / a closure list): seed the value's
      // ref-list slot (keyed by its element name) so the value literal builds as that list — its
      // inner elements recurse through the literal build. Mirrors the array-binding ref-list seed.
      pendingListKind = 5
      pendingListSlot = rlSlotByName(refArrElemName(mvValName[mslot]))
    }
    if emitExpr(body, valIx, fnIx) < 0 {
      return -1 // value
    }
    pendingListKind = savedPLK
    pendingListSlot = savedPLS
    cmSlot = mslot
  }
  fbArraySet(cmValsBack()) // array.set
  fbElse()                 // else
  // APPEND. index[slot] = count + 1  (the new entry's position + 1).
  pushMapIndex(body)
  pushMapScr(body, 3)  // slot
  pushMapCount(body)
  fbI32Const(1)
  fbI32Bin(106)        // i32.add (count + 1)
  fbArraySet(aTypeIdx) // array.set
  // keys.push(keyRef) ; vals.push(v)  (clobbers slots 3/4 — already linked above).
  if emitMapPushKey(body) < 0 { return -1 }
  if emitMapPushValV(body, valIx, fnIx, valConst1) < 0 { return -1 }
  // count = count + 1
  pushMapRef(body)          // mapRef (struct.set receiver)
  pushMapCount(body)
  fbI32Const(1)
  fbI32Bin(106)             // i32.add
  fbStructSet(cmMapTy(), 4) // struct.set field 4: count
  // size = size + 1
  pushMapRef(body)          // mapRef
  pushMapSize(body)
  fbI32Const(1)
  fbI32Bin(106)             // i32.add
  fbStructSet(cmMapTy(), 5) // struct.set field 5: size
  if emitMapResize(body) < 0 { return -1 }
  fbEnd()                   // end (if)
  0
}

// Thin BYTE-IDENTICAL wrappers preserving the original arities — existing callers of
// `emitMapSet` / `emitMapPushVal` emit exactly the same bytes (the non-constant value
// path). The `s.add(k)` Set form calls the `*V` variants with `valConst1 = true`.
function emitMapSet(
  body: i32[],
  recvIx: i32,
  keyIx: i32,
  valIx: i32,
  fnIx: i32,
) {
  emitMapSetV(body, recvIx, keyIx, valIx, fnIx, false)
}

// Inline list-grow append of the scratch `keyRef` (slot 1) onto `M.keys` (the
// string-ref list). The keys list backing is `(array (mut (ref null $aTypeIdx)))`,
// so grow uses `array.new_default`/`array.copy` over `$mkArrIdx`, and the value
// written is the (non-null) key string ref — reusing the map scratch frame's spare
// i32 slots (4 = newCap, 3 = char cursor is free here) and a fresh backing local.
// To keep it self-contained, the new backing is built/stored via `M.keys.backing`
// directly (no extra ref local): grow path mirrors `emitPush`.
function emitMapPushKey(body: i32[]) {
  // if keys.len == keys.cap { grow }
  pushMapKeysLen(body)
  pushMapKeysCap(body)
  fbI32Bin(70) // i32.eq
  fbIf(64)     // if, void
  // newCap = cap == 0 ? 4 : cap*2   (slot 4)
  pushMapKeysCap(body)
  fbI32Eqz()         // i32.eqz
  fbIf(127)          // if, i32 blocktype
  fbI32Const(4)
  fbElse()           // else
  pushMapKeysCap(body)
  fbI32Const(2)
  fbI32Bin(108)      // i32.mul
  fbEnd()            // end
  setMapScr(body, 4) // newCap
  // keys.backing = copy of old into a fresh array.new_default(newCap), keys.cap=newCap
  // newBacking on stack: array.new_default $mkArrIdx newCap
  pushMapScr(body, 4) // newCap
  fbArrayNewDefault(mkArrIdx)
  // stash newBacking into curRef? curRef is a (ref $aTypeIdx) string ref — WRONG type.
  // Instead copy directly: keep newBacking on stack, but array.copy needs it as an
  // operand twice (dest for copy, then store into keys.backing). Use the keys list:
  // 1) set keys.backing = newBacking, 2) array.copy newBacking 0 (re-read old via a
  // saved ref). Simpler: array.copy first (dest = newBacking on stack is consumed),
  // so duplicate by storing into keys.backing FIRST, then copy from a SECOND fresh
  // read of the (now-updated) backing — but the old elements are gone. So we must
  // copy BEFORE swapping. We therefore need a ref local for newBacking.
  // Store newBacking into keys.backing AFTER copying from the OLD backing. To do that
  // without a typed ref local, we copy old→new while new is still only on the stack is
  // impossible (copy consumes operands). Fall back: set keys.backing, copy old→new is
  // lost. ==> use the dedicated newKeysBacking local (slot 6).
  setMapScrKB(body) // newKeysBacking (slot 6)
  // array.copy newBacking 0 oldBacking 0 len
  pushMapScrKB(body)              // dest
  fbI32Const(0)
  pushMapKeysBacking(body)        // src (old)
  fbI32Const(0)
  pushMapKeysLen(body)            // count
  fbArrayCopy(mkArrIdx, mkArrIdx) // array.copy (dest type, src type)
  // keys.backing = newBacking
  pushMapKeys(body)
  pushMapScrKB(body)
  fbStructSet(mkListIdx, 0) // struct.set field 0: backing
  // keys.cap = newCap
  pushMapKeys(body)
  pushMapScr(body, 4)
  fbStructSet(mkListIdx, 2) // struct.set field 2: cap
  // live grows in LOCKSTEP with the keys backing (entry-parallel): allocate a fresh
  // `(ref $aTypeIdx)` of newCap (slot 12), copy the live region `[0, keys.len)` over,
  // and store it back into M.live (field 2). `keys.len` is still the pre-append count
  // here. Mirrors the host's grow of its entry-parallel arrays.
  pushMapScr(body, 4)             // newCap
  fbArrayNewDefault(aTypeIdx)
  setMapScrLB(body)               // newLiveBacking (slot 12)
  pushMapScrLB(body)              // dest
  fbI32Const(0)
  pushMapLive(body)               // src (old live)
  fbI32Const(0)
  pushMapKeysLen(body)            // count (entries copied)
  fbArrayCopy(aTypeIdx, aTypeIdx) // array.copy (dest type, src type)
  pushMapRef(body)                // mapRef
  pushMapScrLB(body)
  fbStructSet(cmMapTy(), 2)       // struct.set field 2: live
  // hashes grows in LOCKSTEP too (entry-parallel): fresh `(ref $aTypeIdx)` of newCap
  // (slot 13), copy `[0, keys.len)` over, store back into M.hashes (field 6). Mirrors
  // the host's grow of its entry-parallel `hashes` array.
  pushMapScr(body, 4)             // newCap
  fbArrayNewDefault(aTypeIdx)
  setMapScrHB(body)               // newHashBacking (slot 13)
  pushMapScrHB(body)              // dest
  fbI32Const(0)
  pushMapHashes(body)             // src (old hashes)
  fbI32Const(0)
  pushMapKeysLen(body)            // count (entries copied)
  fbArrayCopy(aTypeIdx, aTypeIdx) // array.copy (dest type, src type)
  pushMapRef(body)                // mapRef
  pushMapScrHB(body)
  fbStructSet(cmMapTy(), 6)       // struct.set field 6: hashes
  fbEnd()                         // end (grow if)
  // live[keys.len] = 1  (the new entry is live).
  pushMapLive(body)
  pushMapKeysLen(body) // entry index (== count, pre-append)
  fbI32Const(1)
  fbArraySet(aTypeIdx) // array.set
  // hashes[keys.len] = hash(keyRef)  — cache the key's FNV hash parallel to the entry
  // so resize/compact re-place it without re-hashing (mirrors the host's `mapSetFn`
  // append, which stores `m.call(hash, [key()])`). `emitMapHashOf` uses slots 8/9
  // (free here) internally and leaves the masked hash on the stack.
  pushMapHashes(body)
  pushMapKeysLen(body) // entry index (== count, pre-append)
  if emitMapHashOf(body, 1) < 0 {
    return -1 // hash(keyRef), masked, on the stack
  }
  fbArraySet(aTypeIdx) // array.set
  // keys.backing[keys.len] = keyRef
  pushMapKeysBacking(body)
  pushMapKeysLen(body)
  pushMapScr(body, 1)  // keyRef
  fbArraySet(mkArrIdx) // array.set
  // keys.len = keys.len + 1
  pushMapKeys(body)
  pushMapKeysLen(body)
  fbI32Const(1)
  fbI32Bin(106)             // i32.add
  fbStructSet(mkListIdx, 1) // struct.set field 1: len
  0
}

function emitMapPushValV(
  body: i32[],
  valIx: i32,
  fnIx: i32,
  valConst1: boolean,
) {
  // newVal first — the mono i32 stash (slot 3, free after the scan/keys push), or
  // the mv slot's TYPED valStash (an i32 local cannot hold a ref value). The value
  // expr may contain an inner map op, so re-pin the context after it.
  const mslot = cmSlot
  if valConst1 {
    fbI32Const(1) // Set value: constant boolean true
  } else if mvScalarValKind(mslot) >= 0 {
    // A SCALAR-valued map (f64/i64): emit the appended value in the element rep.
    if emitScalarValue(body, valIx, fnIx, mvScalarValKind(mslot)) < 0 {
      return -1
    }
    cmSlot = mslot
  } else if mslot >= 0 && mvValKind[mslot] == 2 {
    // A UNION-valued map: box the appended value into the shared union box before storing (a
    // concrete VARIANT value boxes via `emitUnionBoxArg`, like a call arg / return).
    if emitUnionBoxArg(body, mvValName[mslot], valIx, fnIx) < 0 { return -1 }
    cmSlot = mslot
  } else {
    // A non-i32 scalar-LIST value (`{[string]: i64[]}` / `f64[]` / `string[]`): seed the
    // inner list kind so a bare `[1,2,3]` / empty `[]` literal builds the value's list
    // wrapper, not the default i32-list (whose `(ref $lTypeIdx)` mismatches the typed `(ref
    // null <wrapper>)` element slot) — mirrors the `?? default` READ seeding. Bare integers
    // default to i32, so an i64-list in particular needs this; f64/string self-identify by
    // literal, but seeding is harmless and fixes their empty-`[]` store too.
    const savedPLK = pendingListKind
    const savedPLS = pendingListSlot
    const lvk = mvListValKind(mslot)
    if lvk == 7 {
      pendingListKind = 3
    } else if lvk == 12 {
      pendingListKind = 4
    } else if lvk == 20 {
      pendingListKind = 6
    } else if lvk == 21 {
      pendingListKind = 7
    } else if mslot >= 0 && nameIsRefArray(mvValName[mslot]) {
      // A REF-list value (`S[]` / `(C|D)[]` / nested `S[][]` / closure list): seed the value's
      // ref-list slot so the value literal builds as that list (inner elements recurse).
      pendingListKind = 5
      pendingListSlot = rlSlotByName(refArrElemName(mvValName[mslot]))
    }
    if emitExpr(body, valIx, fnIx) < 0 { return -1 }
    pendingListKind = savedPLK
    pendingListSlot = savedPLS
    cmSlot = mslot
  }
  if mslot >= 0 {
    fbLocalSet(fnMvValStashLocal(mslot))
  } else {
    setMapScr(body, 3)
  }
  // if vals.len == vals.cap { grow }
  pushMapValsLen(body)
  pushMapValsCap(body)
  fbI32Bin(70) // i32.eq
  fbIf(64)     // if, void
  // newCap (slot 4)
  pushMapValsCap(body)
  fbI32Eqz()    // i32.eqz
  fbIf(127)     // if, i32 blocktype
  fbI32Const(4)
  fbElse()      // else
  pushMapValsCap(body)
  fbI32Const(2)
  fbI32Bin(108) // i32.mul
  fbEnd()       // end
  setMapScr(body, 4)
  // newBacking = array.new_default <valsBack> newCap → the valsBk scratch
  pushMapScr(body, 4)
  fbArrayNewDefault(cmValsBack())
  setMapScrVB(body) // newValsBacking
  // array.copy newBacking 0 oldBacking 0 len
  pushMapScrVB(body)
  fbI32Const(0)
  pushMapValsBacking(body)
  fbI32Const(0)
  pushMapValsLen(body)
  fbArrayCopy(cmValsBack(), cmValsBack()) // array.copy (dest type, src type)
  // vals.backing = newBacking
  pushMapVals(body)
  pushMapScrVB(body)
  fbStructSet(cmValsWrap(), 0) // struct.set field 0: backing
  // vals.cap = newCap
  pushMapVals(body)
  pushMapScr(body, 4)
  fbStructSet(cmValsWrap(), 2) // struct.set field 2: cap
  fbEnd()                      // end (grow if)
  // vals.backing[vals.len] = newVal
  pushMapValsBacking(body)
  pushMapValsLen(body)
  if mslot >= 0 {
    fbLocalGet(fnMvValStashLocal(mslot)) // newVal (typed ref)
  } else {
    pushMapScr(body, 3) // newVal
  }
  fbArraySet(cmValsBack()) // array.set
  // vals.len = vals.len + 1
  pushMapVals(body)
  pushMapValsLen(body)
  fbI32Const(1)
  fbI32Bin(106)                // i32.add
  fbStructSet(cmValsWrap(), 1) // struct.set field 1: len
  0
}

// `M.keys.len` / `.cap` / `.backing` field reads (struct.get $mkListIdx 1/2/0).
function pushMapKeysLen(body: i32[]) {
  pushMapKeys(body)
  fbStructGet(mkListIdx, 1)
  0
}
function pushMapKeysCap(body: i32[]) {
  pushMapKeys(body)
  fbStructGet(mkListIdx, 2)
  0
}
function pushMapKeysBacking(body: i32[]) {
  pushMapKeys(body)
  fbStructGet(mkListIdx, 0)
  0
}
// `M.vals.len` / `.cap` / `.backing` field reads (struct.get <valsWrap> 1/2/0 —
// the i32 list wrapper for the mono map, this mv slot's ref-list wrapper else).
function pushMapValsLen(body: i32[]) {
  pushMapVals(body)
  fbStructGet(cmValsWrap(), 1)
  0
}
function pushMapValsCap(body: i32[]) {
  pushMapVals(body)
  fbStructGet(cmValsWrap(), 2)
  0
}
function pushMapValsBacking(body: i32[]) {
  pushMapVals(body)
  fbStructGet(cmValsWrap(), 0)
  0
}

// The two ref scratch locals beyond the 6-slot core frame: a non-null keys backing
// ref (slot 6) and a non-null vals backing ref (slot 7), used by the two grows.
function setMapScrKB(body: i32[]) {
  fbLocalSet(mapScratchBase + 6)
  0
}
function pushMapScrKB(body: i32[]) {
  fbLocalGet(mapScratchBase + 6)
  0
}
function setMapScrVB(body: i32[]) {
  fbLocalSet(cmValsBkLocal())
  0
}
function pushMapScrVB(body: i32[]) {
  fbLocalGet(cmValsBkLocal())
  0
}
// The grown `live` backing ref (slot 12, a non-null `(ref $aTypeIdx)` i32 array),
// used by the keys grow to reallocate `live` in lockstep with the keys backing.
function setMapScrLB(body: i32[]) {
  fbLocalSet(mapScratchBase + 12)
  0
}
function pushMapScrLB(body: i32[]) {
  fbLocalGet(mapScratchBase + 12)
  0
}
// The grown `hashes` backing ref (slot 13, a non-null `(ref $aTypeIdx)` i32 array),
// used by the keys grow to reallocate `hashes` in lockstep with the keys backing, and
// by `compact` as the rebuilt hashes backing.
function setMapScrHB(body: i32[]) {
  fbLocalSet(mapScratchBase + 13)
  0
}
function pushMapScrHB(body: i32[]) {
  fbLocalGet(mapScratchBase + 13)
  0
}

// Lower an index READ `a[i]` onto `body`. The element store is the raw `(array (mut
// i32))` in BOTH cases, but a list receiver carries it inside the wrapper struct:
//   list `a[i]`   → eval `a` (a wrapper ref), `struct.get $lTypeIdx 0` (backing), eval
//                   `i`, then `array.get $aTypeIdx` — the element i32.
//   string `s[i]` → eval `s` (a raw array ref), eval `i`, `array.get $aTypeIdx` — the
//                   i32 CODE POINT (unchanged from the fixed-array string rep).
// `array.get` is `0xfb 0x0b <typeidx>` (the `_s/_u` forms `0x0c/0x0d` are only for
// PACKED arrays; an unpacked i32 array uses `0x0b`).
function emitIndex(body: i32[], idxIx: i32, fnIx: i32) {
  const nd = P.nodes[idxIx]
  if nd is Index {
    // A REF list `xs[i]` → unwrap to its `(ref null $elem)` backing, `array.get`, then
    // `ref.as_non_null` (`0xd4`) to surface the non-null element (a struct ref / union
    // box) — slots in `[0,len)` are always populated, so the cast never traps. (Checked
    // BEFORE the `aUsed` guard: a pure ref-list program uses no i32 array.)
    if exprRefArray(nd.idxArr, fnIx) {
      if !raUsed {
        return emitFail(
          "emitProgram: ref index access but ref array type not collected",
        )
      }
      let rslot = refListSlotOfExpr(nd.idxArr, fnIx)
      if emitExpr(body, nd.idxArr, fnIx) < 0 { return -1 }
      // A NULLABLE ref-array receiver (`t: i32[][] | null`, kind 18, narrowed) reads `(ref null …)` —
      // recover non-null before `struct.get` (the `if t != null` guard makes this safe).
      if exprNullableRefArray(nd.idxArr, fnIx) {
        wU8(212) // 0xd4 ref.as_non_null
      }
      fbStructGet(rlWrapIdx[rslot], 0) // 0xfb 0x02 <ref-list wrapper> field 0: backing
      // The INDEX is always i32 — clear any `pendingF32` an enclosing f32 context set, else a
      // bare index literal emits as `f32.const` (matters for an INNER read `g[i][j]` over an
      // `f32[][]`: the outer f32 read leaves `pendingF32` set while it emits this receiver).
      const savedRlIxF32 = pendingF32
      pendingF32 = false
      if emitExpr(body, nd.idxIndex, fnIx) < 0 { return -1 }
      pendingF32 = savedRlIxF32
      fbArrayGet(rlBackIdx[rslot]) // 0xfb 0x0b <this slot's ref backing array>
      // A NULLABLE-NICHE element legitimately holds null, so the read STAYS `(ref null $elem)` — no
      // `ref.as_non_null` recover (the bound `e` is the niche the caller narrows with `e != null`). The
      // structured `rlElemNullable` bit (set at intern time, kind-discriminated) replaces the old
      // name-based test that conflated a nullable niche with a value-union box.
      if rlElemNullable[rslot] == 1 { return 0 }
      wU8(212) // 0xd4 ref.as_non_null (recover the non-null element)
      return 0
    }
    // A STRING list `xs[i]` → unwrap to its `(ref null $aTypeIdx)` string backing,
    // `array.get $mkArrIdx`, then `ref.as_non_null` to surface the non-null string ref.
    // (Checked before the i32 path: a string element is not an i32.)
    if exprStringArray(nd.idxArr, fnIx) {
      if !slUsed {
        return emitFail(
          "emitProgram: string index access but string list type not collected",
        )
      }
      if emitExpr(body, nd.idxArr, fnIx) < 0 { return -1 }
      fbStructGet(mkListIdx, 0) // 0xfb 0x02 <string-list wrapper> field 0: backing
      if emitExpr(body, nd.idxIndex, fnIx) < 0 { return -1 }
      fbArrayGet(mkArrIdx)      // 0xfb 0x0b <string backing array type index>
      wU8(212)                  // 0xd4 ref.as_non_null (recover the non-null string)
      return 0
    }
    // A SCALAR list `xs[i]` → unwrap to its backing, `array.get <back>` — yielding the
    // element in its valtype rep (i32 / f64 / i64). One descriptor path over all scalar
    // element kinds (f64/i64 checked before i32 since their elements are not i32).
    const ek = scalarListElemKind(nd.idxArr, fnIx)
    if ek >= 0 {
      if !scalarListUsed(ek) {
        return emitFail("emitProgram: index access but list type not collected")
      }
      if emitExpr(body, nd.idxArr, fnIx) < 0 { return -1 }
      fbStructGet(scalarListWrap(ek), 0) // field 0: backing
      // The INDEX is always i32 — clear any f32 coercion signal an enclosing `f32` context
      // set (`pendingF32`), else a bare index literal `xs[0]` would emit as `f32.const`.
      const savedIxF32 = pendingF32
      pendingF32 = false
      if emitExpr(body, nd.idxIndex, fnIx) < 0 { return -1 }
      pendingF32 = savedIxF32
      fbArrayGet(scalarListBack(ek)) // yields the element in its rep
      return 0
    }
    if !aUsed {
      return emitFail("emitProgram: index access but array type not collected")
    }
    if !exprString(nd.idxArr, fnIx) {
      return emitFail("emitProgram: index receiver is not an array or string")
    }
    // A raw string `s[i]` — the `(array i32)` of code points, indexed directly (no unwrap).
    if emitExpr(body, nd.idxArr, fnIx) < 0 { return -1 }
    if emitExpr(body, nd.idxIndex, fnIx) < 0 { return -1 }
    fbArrayGet(aTypeIdx) // 0xfb 0x0b <raw array type index>
    return 0
  }
  emitFail("emitProgram: expected an index access")
}

// Lower a `.length` onto `body`. A list's length is its wrapper's `len` field (NOT the
// backing's physical length, which is `cap`); a string's length is the raw array's
// physical length:
//   list `a.length`   → eval `a`, `struct.get $lTypeIdx 1` (the `len` field) — i32.
//   string `s.length` → eval `s`, `array.len` (`0xfb 0x0f`, NO type-index operand,
//                        unlike `array.get`/`array.set`) — the code-point count.
function emitArrLen(body: i32[], memIx: i32, fnIx: i32) {
  const m = P.nodes[memIx]
  if m is Member {
    // A REF list's `.length` is its wrapper's `len` field (`struct.get $wrap 1`).
    if exprRefArray(m.memObj, fnIx) {
      let rslot = refListSlotOfExpr(m.memObj, fnIx)
      if emitExpr(body, m.memObj, fnIx) < 0 { return -1 }
      fbStructGet(rlWrapIdx[rslot], 1) // 0xfb 0x02 <ref-list wrapper> field 1: len
      return 0
    }
    // A STRING list's `.length` is its wrapper's `len` field (`struct.get $mkListIdx 1`).
    if exprStringArray(m.memObj, fnIx) {
      if emitExpr(body, m.memObj, fnIx) < 0 { return -1 }
      fbStructGet(mkListIdx, 1) // 0xfb 0x02 <string-list wrapper> field 1: len
      return 0
    }
    // A SCALAR list's `.length` is its wrapper's `len` field (`struct.get <wrap> 1`) — an
    // i32, the same shape for every element kind over that kind's wrapper. (f64/i64 before
    // i32 since their elements are not i32.)
    const lek = scalarListElemKind(m.memObj, fnIx)
    if lek == 11 || lek == 10 || lek == 13 {
      if emitExpr(body, m.memObj, fnIx) < 0 { return -1 }
      fbStructGet(scalarListWrap(lek), 1) // field 1: len
      return 0
    }
    const isList = exprArray(m.memObj, fnIx)
    if emitExpr(body, m.memObj, fnIx) < 0 { return -1 }
    if isList {
      fbStructGet(lTypeIdx, 1) // 0xfb 0x02 <list wrapper struct type index> field 1: len
      return 0
    }
    fbArrayLen() // 0xfb 0x0f array.len (no type-index operand)
    return 0
  }
  emitFail("emitProgram: expected a length access")
}

// ── G6: string concatenation / value-equality / slice ────────────────────────
// Strings are WasmGC `(array (mut i32))` of code points, so all three lower to the
// same array machinery the list `.push` uses (`array.new_default`/`array.copy`/
// `array.get`/`array.len`), INLINE — no helper functions. Each routine evaluates
// BOTH operands onto the stack FIRST, then stashes them into the shared string
// scratch frame (`strScratchBase`+0/+1/+2 = string refs A/B/Out; +3/+4/+5/+6 = i32
// temps) — so a NESTED string op (an operand that is itself a `+`/`==`/`.slice`)
// fully completes and leaves its result on the stack BEFORE any scratch `local.set`,
// and the single frame is safe to share. Mirrors `toWasm.ts`'s string `+`/`==`/
// `__string_slice__` shapes, just without the named helper functions.

// `local.get` of string scratch local `n` (0=A, 1=B, 2=Out).
function pushStrScrRef(body: i32[], n: i32) {
  fbLocalGet(strScratchBase + n) // 0x20 local.get
  0
}

// `local.get` of i32 scratch temp `n` (0..3 → frame slots +3..+6).
function pushStrScrI(body: i32[], n: i32) {
  fbLocalGet(strScratchBase + 3 + n) // 0x20 local.get
  0
}

// `local.set` of i32 scratch temp `n`.
function setStrScrI(body: i32[], n: i32) {
  fbLocalSet(strScratchBase + 3 + n) // 0x21 local.set
  0
}

// Lower `toString(x)` onto `body`, leaving a fresh string ref on the stack. An i32
// renders its decimal digits (a negative value gets a leading '-'); a BOOLEAN-
// classified argument renders the literal text "true" / "false". Uses the string-op
// scratch frame (Out = the built string; I0 = remaining value, I1 = sign flag,
// I2 = digit count, I3 = count copy, then the write cursor) — `exprHasStrOp`
// reserves the frame for any `toString(..)` call. The argument is evaluated FULLY
// before the first scratch write (nested-op-safe, like every string op).
function emitToString(body: i32[], callIx: i32, fnIx: i32) {
  let c = P.nodes[callIx]
  if c is Call {
    if c.callArgs.length != 1 {
      return emitFail("emitProgram: toString takes exactly one argument")
    }
    if !aUsed {
      return emitFail("emitProgram: toString but array type not collected")
    }
    const argIx = c.callArgs[0]
    if exprIsBool(argIx, fnIx) {
      // Typed `select`: build BOTH literal strings, then pick by the condition.
      // (An if/else that `local.set`s a NON-defaultable ref local does not count
      // as initialization past the `end`, so the branchless select is the valid
      // shape — and both allocations are tiny constants.)
      fbI32Const(116) // 't'
      fbI32Const(114) // 'r'
      fbI32Const(117) // 'u'
      fbI32Const(101) // 'e'
      fbArrayNewFixed(aTypeIdx, 4)
      fbI32Const(102) // 'f'
      fbI32Const(97)  // 'a'
      fbI32Const(108) // 'l'
      fbI32Const(115) // 's'
      fbI32Const(101) // 'e'
      fbArrayNewFixed(aTypeIdx, 5)
      if emitExpr(body, argIx, fnIx) < 0 { return -1 }
      wU8(28)         // 0x1c select_t
      wU8(1)          // one valtype
      wU8(100)        // 0x64 (ref ht) — non-null string ref
      wSLEB(aTypeIdx)
      return 0
    }
    // The value rides in NEGATIVE space (a positive x negates to -x) so i32 MIN
    // needs no overflowing flip; digits come from the negative remainder.
    // I0 = x; I1 = (x < 0)
    if emitExpr(body, argIx, fnIx) < 0 { return -1 }
    setStrScrI(body, 0)
    pushStrScrI(body, 0)
    fbI32Const(0)
    fbI32Bin(72) // 0x48 i32.lt_s
    setStrScrI(body, 1)
    // if I0 > 0 { I0 = 0 - I0 }  — now I0 <= 0
    pushStrScrI(body, 0)
    fbI32Const(0)
    fbI32Bin(74)  // 0x4a i32.gt_s
    fbIf(64)
    fbI32Const(0)
    pushStrScrI(body, 0)
    fbI32Bin(107) // 0x6b i32.sub
    setStrScrI(body, 0)
    fbEnd()
    // digit count: I3 = I0; I2 = 1; while I3 <= -10 { I3 = I3 / 10; I2 = I2 + 1 }
    pushStrScrI(body, 0)
    setStrScrI(body, 3)
    fbI32Const(1)
    setStrScrI(body, 2)
    fbBlock(64)   // 0x02 block, void
    fbLoop(64)    // 0x03 loop, void
    pushStrScrI(body, 3)
    fbI32Const(-10)
    fbI32Bin(74)  // i32.gt_s — exit when I3 > -10
    fbBrIf(1)
    pushStrScrI(body, 3)
    fbI32Const(10)
    fbI32Bin(109) // 0x6d i32.div_s (truncates toward zero)
    setStrScrI(body, 3)
    pushStrScrI(body, 2)
    fbI32Const(1)
    fbI32Bin(106) // 0x6a i32.add
    setStrScrI(body, 2)
    fbBr(0)
    fbEnd()       // end loop
    fbEnd()       // end block
    // Out = array.new_default (len = I2 + I1)
    pushStrScrI(body, 2)
    pushStrScrI(body, 1)
    fbI32Bin(106) // i32.add
    fbArrayNewDefault(aTypeIdx)
    fbLocalSet(strScratchBase + 2)
    // if I1 { Out[0] = '-' }
    pushStrScrI(body, 1)
    fbIf(64)
    pushStrScrRef(body, 2)
    fbI32Const(0)
    fbI32Const(45) // '-'
    fbArraySet(aTypeIdx)
    fbEnd()
    // write cursor I3 = I1 + I2 - 1 (the last index)
    pushStrScrI(body, 1)
    pushStrScrI(body, 2)
    fbI32Bin(106) // i32.add
    fbI32Const(1)
    fbI32Bin(107) // i32.sub
    setStrScrI(body, 3)
    // do { Out[I3] = 48 - (I0 % 10); I0 = I0 / 10; I3 = I3 - 1 } while I0 != 0
    // (a do-while so the value 0 still writes its single '0' digit; the remainder
    // of the negative-space value is <= 0, so SUBTRACTING it yields the digit)
    fbBlock(64)
    fbLoop(64)
    pushStrScrRef(body, 2)
    pushStrScrI(body, 3)
    fbI32Const(48)         // '0'
    pushStrScrI(body, 0)
    fbI32Const(10)
    fbI32Bin(111)          // 0x6f i32.rem_s (negative for a negative I0)
    fbI32Bin(107)          // 0x6b i32.sub — 48 - (-d) = 48 + d
    fbArraySet(aTypeIdx)
    pushStrScrI(body, 0)
    fbI32Const(10)
    fbI32Bin(109)          // i32.div_s
    setStrScrI(body, 0)
    pushStrScrI(body, 3)
    fbI32Const(1)
    fbI32Bin(107)          // i32.sub
    setStrScrI(body, 3)
    pushStrScrI(body, 0)
    fbI32Eqz()             // 0x45 — exit when I0 == 0
    fbBrIf(1)
    fbBr(0)
    fbEnd()                // end loop
    fbEnd()                // end block
    pushStrScrRef(body, 2) // the built string
    return 0
  }
  emitFail("emitProgram: expected a toString call")
}

// Lower a string concatenation `a + b` onto `body`, leaving the new string ref on
// the stack. Allocate a fresh `(array i32)` of `len(a)+len(b)` (`array.new_default`,
// which zero-inits — every slot is then overwritten), `array.copy` a's code points
// into `[0,lenA)` and b's into `[lenA, lenA+lenB)`. Both operands are evaluated
// first, then stashed (nested-op-safe). `array.copy` is `0xfb 0x11 <dest> <src>`.
function emitStrConcat(body: i32[], binIx: i32, fnIx: i32) {
  if !aUsed {
    return emitFail("emitProgram: string concat but array type not collected")
  }
  const e = P.nodes[binIx]
  if e is BinExpr {
    // Eval BOTH operands onto the stack first (nested string ops complete here),
    // then pop into the scratch refs (B first — it is on top). A literal-union atom
    // operand widens to its member string (`emitStrValue`) before the scratch stash.
    if emitStrValue(body, e.binLeft, fnIx) < 0 { return -1 }
    if emitStrValue(body, e.binRight, fnIx) < 0 { return -1 }
    fbLocalSet(strScratchBase + 1) // local.set strScrB
    fbLocalSet(strScratchBase + 0) // local.set strScrA
    // I0 = lenA = array.len(A)
    pushStrScrRef(body, 0)
    fbArrayLen() // 0xfb 0x0f array.len
    setStrScrI(body, 0)
    // I1 = lenB = array.len(B)
    pushStrScrRef(body, 1)
    fbArrayLen() // array.len
    setStrScrI(body, 1)
    // Out = array.new_default $aTypeIdx (lenA + lenB)
    pushStrScrI(body, 0)
    pushStrScrI(body, 1)
    fbI32Bin(106)                  // 0x6a i32.add
    fbArrayNewDefault(aTypeIdx)    // 0xfb 0x07 array.new_default <typeidx>
    fbLocalSet(strScratchBase + 2) // local.set strScrOut
    // array.copy Out 0 A 0 lenA
    pushStrScrRef(body, 2)          // dest
    fbI32Const(0)                   // i32.const 0 (dest offset)
    pushStrScrRef(body, 0)          // src A
    fbI32Const(0)                   // i32.const 0 (src offset)
    pushStrScrI(body, 0)            // count lenA
    fbArrayCopy(aTypeIdx, aTypeIdx) // 0xfb 0x11 array.copy (dest type, src type)
    // array.copy Out lenA B 0 lenB
    pushStrScrRef(body, 2)          // dest
    pushStrScrI(body, 0)            // dest offset = lenA
    pushStrScrRef(body, 1)          // src B
    fbI32Const(0)                   // i32.const 0 (src offset)
    pushStrScrI(body, 1)            // count lenB
    fbArrayCopy(aTypeIdx, aTypeIdx) // array.copy (dest type, src type)
    // Result: the new string ref.
    pushStrScrRef(body, 2)
    return 0
  }
  emitFail("emitProgram: expected a string concatenation")
}

// Lower a string VALUE-equality `a == b` (or `a != b`) onto `body`, leaving a 0/1
// i32 on the stack. This is ELEMENT-WISE, NOT ref identity: `false` if the lengths
// differ, else loop `i in [0,len)` comparing `a[i] == b[i]`; all-equal → 1. `!=`
// negates the result with `i32.eqz`. Lowered as a value-typed `block`/`loop`:
//   block i32 {                 ; yields the 0/1 result
//     A=..; B=..                 ; stash operands (nested-op-safe)
//     I0 = len(A)
//     if I0 != len(B) { (i32.const 0) br 0 }   ; length mismatch → 0
//     I1 = 0                                     ; loop index
//     loop {                                     ; void loop
//       if I1 >= I0 { }            ; fall through past loop when done
//       else {
//         if A[I1] != B[I1] { (i32.const 0) br 1 }   ; mismatch → 0, exit block
//         I1 = I1 + 1
//         br <loop>
//       }
//     }
//     (i32.const 1)               ; every element matched
//   }
function emitStrEq(body: i32[], binIx: i32, fnIx: i32) {
  if !aUsed {
    return emitFail("emitProgram: string equality but array type not collected")
  }
  const e = P.nodes[binIx]
  if e is BinExpr {
    const isNe = e.binOp == "!="
    // Eval both operands, then stash (B on top → set B first).
    if emitExpr(body, e.binLeft, fnIx) < 0 { return -1 }
    if emitExpr(body, e.binRight, fnIx) < 0 { return -1 }
    if emitStrEqCore(body) < 0 { return -1 }
    if isNe {
      fbI32Eqz() // 0x45 i32.eqz  (`!=` negates value-equality)
    }
    return 0
  }
  emitFail("emitProgram: expected a string equality")
}

// Lower a string ORDERING comparison (`<`/`>`/`<=`/`>=`) onto `body`, leaving a 0/1.
// Built on ONE primitive — `emitStrLessCore`, "first operand lexicographically < second":
//   A <  B  ≡  less(A, B)
//   A >  B  ≡  less(B, A)             (swap)
//   A <= B  ≡  !less(B, A)            (swap + negate)
//   A >= B  ≡  !less(A, B)            (negate)
// The core sets B (stack top) then A (below), so the lower operand is its first arg.
function emitStrOrder(body: i32[], binIx: i32, fnIx: i32) {
  if !aUsed {
    return emitFail("emitProgram: string ordering but array type not collected")
  }
  const e = P.nodes[binIx]
  if e is BinExpr {
    const op = e.binOp
    let swap = false
    let neg = false
    if op == ">" {
      swap = true
    } else if op == "<=" {
      swap = true
      neg = true
    } else if op == ">=" {
      neg = true
    } else if op != "<" {
      return emitFail("emitProgram: expected a string ordering operator")
    }
    // Push the core's first arg (lower on stack) then its second arg.
    if swap {
      if emitExpr(body, e.binRight, fnIx) < 0 { return -1 }
      if emitExpr(body, e.binLeft, fnIx) < 0 { return -1 }
    } else {
      if emitExpr(body, e.binLeft, fnIx) < 0 { return -1 }
      if emitExpr(body, e.binRight, fnIx) < 0 { return -1 }
    }
    if emitStrLessCore(body) < 0 { return -1 }
    if neg {
      fbI32Eqz() // 0x45 i32.eqz — `<=`/`>=` negate the strict-less result
    }
    return 0
  }
  emitFail("emitProgram: expected a string ordering")
}

// The string strict-LESS core: expects the two string refs already ON THE STACK (first
// below second), leaves 1 iff the first is lexicographically less than the second, else
// 0. Compares code points (unsigned) up to the shorter length; on the first mismatch the
// result is `a[i] < b[i]`; if one is a prefix of the other the shorter is less. Mirrors
// `emitStrEqCore`'s frame/block/loop/br structure. Frame: refs A(0)/B(1); i32 temps
// lenA(0)/lenB(1)/n(2)/i(3).
function emitStrLessCore(body: i32[]) {
  fbLocalSet(strScratchBase + 1) // B (stack top)
  fbLocalSet(strScratchBase + 0) // A
  fbBlock(127)                   // 0x02 block, 0x7f i32 blocktype → the 0/1 result
  // lenA = len(A) ; lenB = len(B)
  pushStrScrRef(body, 0)
  fbArrayLen()
  setStrScrI(body, 0) // lenA
  pushStrScrRef(body, 1)
  fbArrayLen()
  setStrScrI(body, 1) // lenB
  // n = min(lenA, lenB):  n = lenA ; if lenB < lenA { n = lenB }
  pushStrScrI(body, 0)
  setStrScrI(body, 2)
  pushStrScrI(body, 1)
  pushStrScrI(body, 0)
  fbI32Bin(73)        // 0x49 i32.lt_u (lenB < lenA)
  fbIf(64)            // 0x04 if, void
  pushStrScrI(body, 1)
  setStrScrI(body, 2) // n = lenB
  fbEnd()
  // i = 0
  fbI32Const(0)
  setStrScrI(body, 3)
  // loop { if i >= n {} else { compare; i++; br } }
  fbLoop(64)           // 0x03 loop, void
  pushStrScrI(body, 3) // i
  pushStrScrI(body, 2) // n
  fbI32Bin(78)         // 0x4e i32.ge_s (i >= n → common prefix done)
  fbIf(64)             // then: fall through (empty)
  fbElse()
  // if A[i] != B[i] { push (A[i] <_u B[i]) ; br out of block }
  pushStrScrRef(body, 0)
  pushStrScrI(body, 3)
  fbArrayGet(aTypeIdx) // A[i]
  pushStrScrRef(body, 1)
  pushStrScrI(body, 3)
  fbArrayGet(aTypeIdx) // B[i]
  fbI32Bin(71)         // 0x47 i32.ne
  fbIf(64)
  pushStrScrRef(body, 0)
  pushStrScrI(body, 3)
  fbArrayGet(aTypeIdx) // A[i]
  pushStrScrRef(body, 1)
  pushStrScrI(body, 3)
  fbArrayGet(aTypeIdx) // B[i]
  fbI32Bin(73)         // 0x49 i32.lt_u (A[i] < B[i] → the answer at the first diff)
  fbBr(3)              // 0x0c br depth 3 → out of: if(0)·else(1)·loop(2)·block(3)
  fbEnd()              // end (mismatch if)
  // i = i + 1
  pushStrScrI(body, 3)
  fbI32Const(1)
  fbI32Bin(106) // 0x6a i32.add
  setStrScrI(body, 3)
  fbBr(1)       // 0x0c br depth 1 → loop header (else=0, loop=1)
  fbEnd()       // end (ge_s if/else)
  fbEnd()       // end (loop)
  // Common prefix equal → the shorter string is less:  lenA < lenB.
  pushStrScrI(body, 0)
  pushStrScrI(body, 1)
  fbI32Bin(73) // 0x49 i32.lt_u (lenA < lenB)
  fbEnd()      // end (block) — leaves the 0/1 result
  0
}

// The string value-equality CORE: expects the two string refs already ON THE
// STACK (left below right), leaves the 0/1 result. Shared by `emitStrEq` and the
// struct-equality field compare (which pushes field chains as operands).
function emitStrEqCore(body: i32[]) {
  if true {
    fbLocalSet(strScratchBase + 1) // local.set strScrB
    fbLocalSet(strScratchBase + 0) // local.set strScrA
    // block i32 { ... }  — yields the 0/1 result.
    fbBlock(127) // 0x02 block, 0x7f i32 blocktype
    // I0 = len(A)
    pushStrScrRef(body, 0)
    fbArrayLen() // array.len
    setStrScrI(body, 0)
    // if I0 != len(B) { push 0 ; br 0 (out of block) }
    pushStrScrI(body, 0)
    pushStrScrRef(body, 1)
    fbArrayLen()  // array.len(B)
    fbI32Bin(71)  // 0x47 i32.ne
    fbIf(64)      // 0x04 if, 0x40 void blocktype
    fbI32Const(0) // i32.const 0
    fbBr(1)       // 0x0c br depth 1 → out of the i32 block (this `if` is depth 0)
    fbEnd()       // 0x0b end (if)
    // I1 = 0
    fbI32Const(0)
    setStrScrI(body, 1)
    // loop (void) { if I1 >= I0 {} else { compare; I1++; br loop } }
    fbLoop(64)           // 0x03 loop, 0x40 void blocktype
    pushStrScrI(body, 1) // I1
    pushStrScrI(body, 0) // I0
    fbI32Bin(78)         // 0x4e i32.ge_s  (I1 >= I0 → done)
    fbIf(64)             // 0x04 if, 0x40 void blocktype
    // then: done — fall through (empty)
    fbElse() // 0x05 else
    // A[I1] != B[I1] ?
    pushStrScrRef(body, 0)
    pushStrScrI(body, 1)
    fbArrayGet(aTypeIdx) // 0xfb 0x0b array.get
    pushStrScrRef(body, 1)
    pushStrScrI(body, 1)
    fbArrayGet(aTypeIdx) // array.get
    fbI32Bin(71)         // 0x47 i32.ne
    fbIf(64)             // 0x04 if (mismatch → 0, exit block), 0x40 void blocktype
    fbI32Const(0)        // i32.const 0
    fbBr(3)              // 0x0c br depth 3 → out of: if(0)·else(1)·loop(2)·block(3)
    fbEnd()              // 0x0b end (mismatch if)
    // I1 = I1 + 1
    pushStrScrI(body, 1)
    fbI32Const(1)
    fbI32Bin(106) // i32.add
    setStrScrI(body, 1)
    fbBr(1)       // 0x0c br depth 1 → back to the loop header (else=0, loop=1)
    fbEnd()       // 0x0b end (else's if — i.e. the ge_s if)
    fbEnd()       // 0x0b end (loop)
    // Every element matched → 1.
    fbI32Const(1) // i32.const 1
    fbEnd()       // 0x0b end (block) — leaves the 0/1 result
    return 0
  }
  0
}

// ── list value-equality + concat cores (collections-design §VL.4/§VL.6) ───────
// Each core expects its two list WRAPPER refs already ON THE STACK (left below
// right) and leaves a 0/1 (equality) or the new wrapper (concat). The loop
// structure mirrors `emitStrEqCore` exactly (same block/loop/br depths); only
// the length source (the wrapper's `len` field, NOT `array.len` — the backing
// has spare capacity) and the element compare differ per kind.

// i32-list `==`: length + element compare over the LEQI frame.
function emitListEqICore(body: i32[]) {
  const bA = leqIScratchBase
  fbLocalSet(bA + 1)       // B
  fbLocalSet(bA + 0)       // A
  fbBlock(127)             // block i32
  fbLocalGet(bA + 0)
  fbStructGet(lTypeIdx, 1) // lenA
  fbLocalSet(bA + 3)       // n = lenA
  fbLocalGet(bA + 3)
  fbLocalGet(bA + 1)
  fbStructGet(lTypeIdx, 1) // lenB
  fbI32Bin(71)             // i32.ne
  fbIf(64)
  fbI32Const(0)
  fbBr(1)
  fbEnd()
  fbI32Const(0)
  fbLocalSet(bA + 4)       // i = 0
  fbLoop(64)
  fbLocalGet(bA + 4)
  fbLocalGet(bA + 3)
  fbI32Bin(78)             // i >= n → done
  fbIf(64)
  fbElse()
  fbLocalGet(bA + 0)
  fbStructGet(lTypeIdx, 0) // backing A
  fbLocalGet(bA + 4)
  fbArrayGet(aTypeIdx)
  fbLocalGet(bA + 1)
  fbStructGet(lTypeIdx, 0) // backing B
  fbLocalGet(bA + 4)
  fbArrayGet(aTypeIdx)
  fbI32Bin(71)             // element i32.ne
  fbIf(64)
  fbI32Const(0)
  fbBr(3)                  // mismatch → 0, exit block
  fbEnd()
  fbLocalGet(bA + 4)
  fbI32Const(1)
  fbI32Bin(106)            // i + 1
  fbLocalSet(bA + 4)
  fbBr(1)                  // back to loop
  fbEnd()                  // end (ge_s if/else)
  fbEnd()                  // end (loop)
  fbI32Const(1)
  fbEnd()                  // end (block)
  0
}

// String-list `==`: outer loop over the LEQS frame; each element pair rides
// `emitStrEqCore` (the string-op frame — disjoint locals, safe to nest).
function emitListEqSCore(body: i32[]) {
  const bA = leqSScratchBase
  fbLocalSet(bA + 1)        // B
  fbLocalSet(bA + 0)        // A
  fbBlock(127)              // block i32
  fbLocalGet(bA + 0)
  fbStructGet(mkListIdx, 1) // lenA
  fbLocalSet(bA + 2)        // n
  fbLocalGet(bA + 2)
  fbLocalGet(bA + 1)
  fbStructGet(mkListIdx, 1)
  fbI32Bin(71)              // i32.ne
  fbIf(64)
  fbI32Const(0)
  fbBr(1)
  fbEnd()
  fbI32Const(0)
  fbLocalSet(bA + 3)        // i = 0
  fbLoop(64)
  fbLocalGet(bA + 3)
  fbLocalGet(bA + 2)
  fbI32Bin(78)
  fbIf(64)
  fbElse()
  // push elem A, elem B (non-null string refs), compare via the string core
  fbLocalGet(bA + 0)
  fbStructGet(mkListIdx, 0)
  fbLocalGet(bA + 3)
  fbArrayGet(mkArrIdx)
  fbRefAsNonNull()
  fbLocalGet(bA + 1)
  fbStructGet(mkListIdx, 0)
  fbLocalGet(bA + 3)
  fbArrayGet(mkArrIdx)
  fbRefAsNonNull()
  if emitStrEqCore(body) < 0 { return -1 }
  fbI32Eqz() // 1 = mismatch
  fbIf(64)
  fbI32Const(0)
  fbBr(3)
  fbEnd()
  fbLocalGet(bA + 3)
  fbI32Const(1)
  fbI32Bin(106)
  fbLocalSet(bA + 3)
  fbBr(1)
  fbEnd()
  fbEnd()
  fbI32Const(1)
  fbEnd()
  0
}

// `i32[][]` `==`: outer loop over the slot's LEQR frame; each element pair (two
// inner i32-list wrappers) recurses through `emitListEqICore` (disjoint frame).
function emitListEqRCore(body: i32[], slot: i32, base: i32) {
  fbLocalSet(base + 1) // B
  fbLocalSet(base + 0) // A
  fbBlock(127)         // block i32
  fbLocalGet(base + 0)
  fbStructGet(rlWrapIdx[slot], 1)
  fbLocalSet(base + 2) // n
  fbLocalGet(base + 2)
  fbLocalGet(base + 1)
  fbStructGet(rlWrapIdx[slot], 1)
  fbI32Bin(71)
  fbIf(64)
  fbI32Const(0)
  fbBr(1)
  fbEnd()
  fbI32Const(0)
  fbLocalSet(base + 3) // i = 0
  fbLoop(64)
  fbLocalGet(base + 3)
  fbLocalGet(base + 2)
  fbI32Bin(78)
  fbIf(64)
  fbElse()
  fbLocalGet(base + 0)
  fbStructGet(rlWrapIdx[slot], 0)
  fbLocalGet(base + 3)
  fbArrayGet(rlBackIdx[slot])
  fbRefAsNonNull()
  fbLocalGet(base + 1)
  fbStructGet(rlWrapIdx[slot], 0)
  fbLocalGet(base + 3)
  fbArrayGet(rlBackIdx[slot])
  fbRefAsNonNull()
  if emitListEqICore(body) < 0 { return -1 }
  fbI32Eqz()
  fbIf(64)
  fbI32Const(0)
  fbBr(3)
  fbEnd()
  fbLocalGet(base + 3)
  fbI32Const(1)
  fbI32Bin(106)
  fbLocalSet(base + 3)
  fbBr(1)
  fbEnd()
  fbEnd()
  fbI32Const(1)
  fbEnd()
  0
}

// The reserved LEQR frame base for ref-list slot `slot`, or -1.
function leqRBaseOfSlot(slot: i32) {
  let i = 0
  while i < fnListEqRSlots.length {
    if fnListEqRSlots[i] == slot { return leqRBases[i] }
    i = i + 1
  }
  -1
}

// i32-list CONCAT `a + b`: a NEW list sized exactly lenA + lenB (one backing
// allocation, two bulk `array.copy`s) — the host's §VL.4 lowering. The operands
// are evaluated once into the LEQI frame; the result wrapper is left on the stack.
function emitListConcatI(body: i32[], leftIx: i32, rightIx: i32, fnIx: i32) {
  const bA = leqIScratchBase
  if emitExpr(body, leftIx, fnIx) < 0 { return -1 }
  // A NARROWED nullable-list operand (`i32[] | null`, kind 15) keeps its nullable
  // slot; the LEQI scratch slot is non-null, so recover before the store (the
  // checker proved the operand guarded — the cast can never trap).
  if exprNullableList(leftIx, fnIx) {
    wU8(212) // 0xd4 ref.as_non_null
  }
  fbLocalSet(bA + 0) // A
  if emitExpr(body, rightIx, fnIx) < 0 { return -1 }
  if exprNullableList(rightIx, fnIx) {
    wU8(212) // 0xd4 ref.as_non_null
  }
  fbLocalSet(bA + 1)       // B
  fbLocalGet(bA + 0)
  fbStructGet(lTypeIdx, 1) // lenA
  fbLocalGet(bA + 1)
  fbStructGet(lTypeIdx, 1) // lenB
  fbI32Bin(106)            // i32.add
  fbLocalSet(bA + 3)       // n = lenA + lenB
  fbLocalGet(bA + 3)
  fbArrayNewDefault(aTypeIdx)
  fbLocalSet(bA + 2)       // out backing
  // array.copy out 0 backingA 0 lenA
  fbLocalGet(bA + 2)
  fbI32Const(0)
  fbLocalGet(bA + 0)
  fbStructGet(lTypeIdx, 0)
  fbI32Const(0)
  fbLocalGet(bA + 0)
  fbStructGet(lTypeIdx, 1)
  fbArrayCopy(aTypeIdx, aTypeIdx)
  // array.copy out lenA backingB 0 lenB
  fbLocalGet(bA + 2)
  fbLocalGet(bA + 0)
  fbStructGet(lTypeIdx, 1)
  fbLocalGet(bA + 1)
  fbStructGet(lTypeIdx, 0)
  fbI32Const(0)
  fbLocalGet(bA + 1)
  fbStructGet(lTypeIdx, 1)
  fbArrayCopy(aTypeIdx, aTypeIdx)
  // the result wrapper { out, n, n }
  fbLocalGet(bA + 2)
  fbLocalGet(bA + 3)
  fbLocalGet(bA + 3)
  fbStructNew(lTypeIdx)
  0
}

// Re-evaluate the field ACCESS CHAIN `root.f1.f2…` onto `body`: the root
// expression, then one `struct.get` per (struct, field) pair in the path arrays.
// Every step is a pure re-read (the equality compare re-walks chains per field).
function emitChainRead(
  body: i32[],
  rootIx: i32,
  pathSi: i32[],
  pathFi: i32[],
  fnIx: i32,
) {
  if emitExpr(body, rootIx, fnIx) < 0 { return -1 }
  let k = 0
  while k < pathSi.length {
    fbStructGet(sHeapIdx[pathSi[k]], pathFi[k]) // 0xfb 0x02 <struct ht> <field>
    k = k + 1
  }
  0
}

// Compare two closure fat-pointers already on the stack (left below right), leaving
// a 0/1 i32 — function IDENTITY: the same lifted function (id, field 2) AND the same
// captured env (`ref.eq` over field 1; two null envs are equal, two separately
// CREATED envs of the same function are not). Stages both operands in the 2-slot
// closure-eq frame (`cloEqScratchBase`, reserved by `cloEqNoteBin`'s scan). Mirrors
// the host's function-identity `==` (same table index AND same env).
function emitCloEqCore(body: i32[]) {
  fbLocalSet(cloEqScratchBase + 1) // B = right operand
  fbLocalSet(cloEqScratchBase + 0) // A = left operand
  fbLocalGet(cloEqScratchBase + 0)
  fbStructGet(cloStructIdx, 2)     // A.id
  fbLocalGet(cloEqScratchBase + 1)
  fbStructGet(cloStructIdx, 2)     // B.id
  fbI32Bin(70)                     // 0x46 i32.eq
  fbLocalGet(cloEqScratchBase + 0)
  fbStructGet(cloStructIdx, 1)     // A.env
  fbLocalGet(cloEqScratchBase + 1)
  fbStructGet(cloStructIdx, 1)     // B.env
  wU8(211)                         // 0xd3 ref.eq (null == null → 1)
  fbI32Bin(113)                    // 0x71 i32.and
  0
}

// Lower a STRUCTURAL struct equality `a == b` (or `!=`) onto `body`, leaving a 0/1
// i32 — field-wise compare mirroring the host's `valueEq`: native compares for
// scalars, the string-eq loop for string fields, a length+element loop for `i32[]`
// fields, and recursion through NESTED struct fields (code 15). Both operands must
// be PURE re-reads (names / field chains): every field compare re-evaluates the
// full chain from its root. The two shapes match (same struct table index) — the
// checker proved the operands comparable.
function emitStructEq(body: i32[], binIx: i32, fnIx: i32) {
  const e = P.nodes[binIx]
  if e is BinExpr {
    let si = structIndexOfExpr(e.binLeft, fnIx)
    if si < 0 {
      return emitFail("emitProgram: struct equality over a non-struct operand")
    }
    const pathSi: i32[] = []
    const pathFi: i32[] = []
    if (
      emitStructEqRec(body, e.binLeft, e.binRight, si, pathSi, pathFi, fnIx) <
      0
    ) {
      return -1
    }
    if e.binOp == "!=" {
      fbI32Eqz() // 0x45 i32.eqz — negate value-equality
    }
    return 0
  }
  emitFail("emitProgram: expected a struct equality")
}

// One struct SHAPE's field-wise compare at path (`pathSi`/`pathFi` from the roots),
// leaving 0/1: an and-chain of per-field compares lowered as nested value-typed
// `if`s (compare; if → next field … ; else → 0), so a first mismatch short-circuits.
function emitStructEqRec(
  body: i32[],
  lRoot: i32,
  rRoot: i32,
  si: i32,
  pathSi: i32[],
  pathFi: i32[],
  fnIx: i32,
) {
  let cnt = sFieldCount[si]
  if cnt == 0 {
    fbI32Const(1)
    return 0
  }
  let fi = 0
  while fi < cnt {
    if emitStructEqField(body, lRoot, rRoot, si, fi, pathSi, pathFi, fnIx) < 0 {
      return -1
    }
    if fi < cnt - 1 {
      fbIf(127) // 0x04 if, 0x7f i32 blocktype — chain the next field
      ctrlEnter()
    }
    fi = fi + 1
  }
  // Close the chain: each opened `if` gets `else (i32.const 0) end`.
  let k = cnt - 1
  while k > 0 {
    fbElse() // 0x05 else
    fbI32Const(0)
    fbEnd()  // 0x0b end
    ctrlLeave()
    k = k - 1
  }
  0
}

// Compare ONE field at (si, fi) across the two chains, leaving 0/1. The path
// push/pop frames the inner compare so chains rewind for the next sibling field.
function emitStructEqField(
  body: i32[],
  lRoot: i32,
  rRoot: i32,
  si: i32,
  fi: i32,
  pathSi: i32[],
  pathFi: i32[],
  fnIx: i32,
) {
  pathSi.push(si)
  pathFi.push(fi)
  let r = emitStructEqFieldInner(body, lRoot, rRoot, si, fi, pathSi, pathFi, fnIx)
  pathSi.pop()
  pathFi.pop()
  r
}

function emitStructEqFieldInner(
  body: i32[],
  lRoot: i32,
  rRoot: i32,
  si: i32,
  fi: i32,
  pathSi: i32[],
  pathFi: i32[],
  fnIx: i32,
) {
  let code = sFieldTypeAt(si, fi)
  if code == 0 {
    // Scalar (i32 / boolean): a native compare.
    if emitChainRead(body, lRoot, pathSi, pathFi, fnIx) < 0 { return -1 }
    if emitChainRead(body, rRoot, pathSi, pathFi, fnIx) < 0 { return -1 }
    fbI32Bin(70) // 0x46 i32.eq
    return 0
  }
  if code == 17 {
    // f64 scalar field: a native f64 compare (i32 0/1 result).
    if emitChainRead(body, lRoot, pathSi, pathFi, fnIx) < 0 { return -1 }
    if emitChainRead(body, rRoot, pathSi, pathFi, fnIx) < 0 { return -1 }
    fbI32Bin(97) // 0x61 f64.eq
    return 0
  }
  if code == 3 {
    // String: the element-wise string-eq loop over the two field refs.
    if !aUsed {
      return emitFail(
        "emitProgram: string field equality but array type not collected",
      )
    }
    if emitChainRead(body, lRoot, pathSi, pathFi, fnIx) < 0 { return -1 }
    if emitChainRead(body, rRoot, pathSi, pathFi, fnIx) < 0 { return -1 }
    return emitStrEqCore(body)
  }
  if code == 15 {
    // Nested struct: recurse one level deeper along the chain.
    const nsi = structIndexByName(sFieldElemNameAt(si, fi))
    if nsi < 0 {
      return emitFail(
        "emitProgram: nested struct field equality with no interned shape",
      )
    }
    return emitStructEqRec(body, lRoot, rRoot, nsi, pathSi, pathFi, fnIx)
  }
  if code == 4 {
    // `i32[]` list: lengths equal AND element-wise equal — `len` from the WRAPPER
    // (field 1, the logical size; the backing may be longer), elements off the
    // backings (stashed in the string-op frame refs, the same `(array i32)` type).
    if !lUsed {
      return emitFail("emitProgram: i32[] field equality but list type not collected")
    }
    // lenL != lenR → 0, else the element loop.
    if emitChainRead(body, lRoot, pathSi, pathFi, fnIx) < 0 { return -1 }
    fbStructGet(lTypeIdx, 1) // wrapper field 1: len
    if emitChainRead(body, rRoot, pathSi, pathFi, fnIx) < 0 { return -1 }
    fbStructGet(lTypeIdx, 1)
    fbI32Bin(71)             // 0x47 i32.ne
    fbIf(127)                // 0x04 if, 0x7f i32 blocktype
    ctrlEnter()
    fbI32Const(0)            // length mismatch → 0
    fbElse()                 // 0x05 else — the element loop, like emitStrEqCore
    // A = backing(L.f); B = backing(R.f); I0 = len; I1 = 0
    if emitChainRead(body, lRoot, pathSi, pathFi, fnIx) < 0 { return -1 }
    fbStructGet(lTypeIdx, 0) // backing
    fbLocalSet(strScratchBase + 0)
    if emitChainRead(body, rRoot, pathSi, pathFi, fnIx) < 0 { return -1 }
    fbStructGet(lTypeIdx, 0)
    fbLocalSet(strScratchBase + 1)
    if emitChainRead(body, lRoot, pathSi, pathFi, fnIx) < 0 { return -1 }
    fbStructGet(lTypeIdx, 1) // len
    setStrScrI(body, 0)
    fbBlock(127)             // 0x02 block, 0x7f i32 — yields the 0/1 result
    fbI32Const(0)
    setStrScrI(body, 1)      // I1 = 0
    fbLoop(64)               // 0x03 loop, void
    pushStrScrI(body, 1)
    pushStrScrI(body, 0)
    fbI32Bin(78)             // 0x4e i32.ge_s — done?
    fbIf(64)                 // then: fall through (all matched)
    fbElse()
    pushStrScrRef(body, 0)
    pushStrScrI(body, 1)
    fbArrayGet(aTypeIdx)
    pushStrScrRef(body, 1)
    pushStrScrI(body, 1)
    fbArrayGet(aTypeIdx)
    fbI32Bin(71)             // 0x47 i32.ne
    fbIf(64)                 // mismatch → 0, exit the result block
    fbI32Const(0)
    fbBr(3)                  // depths: if(0)·else(1)·loop(2)·block(3)
    fbEnd()
    pushStrScrI(body, 1)
    fbI32Const(1)
    fbI32Bin(106)            // i32.add
    setStrScrI(body, 1)
    fbBr(1)                  // continue the loop
    fbEnd()                  // end (else's if)
    fbEnd()                  // end (loop)
    fbI32Const(1)            // every element matched
    fbEnd()                  // end (result block)
    fbEnd()                  // end (length if/else)
    ctrlLeave()
    return 0
  }
  if code == 14 {
    // Function-valued field: identity compare (id + env) via the closure-eq frame.
    if emitChainRead(body, lRoot, pathSi, pathFi, fnIx) < 0 { return -1 }
    if emitChainRead(body, rRoot, pathSi, pathFi, fnIx) < 0 { return -1 }
    return emitCloEqCore(body)
  }
  emitFail("emitProgram: unsupported struct field type in equality")
}

// Emit `clamp(idx, len)` where `idx` is in i32 temp `idxSlot` and `len` in temp
// `lenSlot`, leaving the clamped value on the stack. JS slice semantics: a negative
// index counts from the end (`len + idx`, floored at 0), a non-negative index is
// capped at `len` — `idx < 0 ? max(len+idx, 0) : min(idx, len)`. Built from `select`
// (`0x1b`: `[a, b, cond] -> a if cond else b`).
function emitClampIdx(body: i32[], idxSlot: i32, lenSlot: i32) {
  // negCase = max(len+idx, 0) = select( len+idx, 0, (len+idx) > 0 )
  pushStrScrI(body, lenSlot)
  pushStrScrI(body, idxSlot)
  fbI32Bin(106) // i32.add → (len+idx)  [the `a` value]
  fbI32Const(0) // i32.const 0          [the `b` value]
  pushStrScrI(body, lenSlot)
  pushStrScrI(body, idxSlot)
  fbI32Bin(106) // i32.add → (len+idx)
  fbI32Const(0) // i32.const 0
  fbI32Bin(74)  // 0x4a i32.gt_s → (len+idx) > 0   [cond]
  wU8(27)       // 0x1b select → negCase on stack
  // nonNegCase = min(idx, len) = select( idx, len, idx < len )
  pushStrScrI(body, idxSlot) // a = idx
  pushStrScrI(body, lenSlot) // b = len
  pushStrScrI(body, idxSlot)
  pushStrScrI(body, lenSlot)
  fbI32Bin(72)               // 0x48 i32.lt_s → idx < len   [cond]
  wU8(27)                    // select → nonNegCase on stack
  // result = select( negCase, nonNegCase, idx < 0 )
  // Stack currently: [negCase, nonNegCase]; push cond then select.
  pushStrScrI(body, idxSlot)
  fbI32Const(0) // i32.const 0
  fbI32Bin(72)  // 0x48 i32.lt_s → idx < 0
  wU8(27)       // select → clamped value
  0
}

// Lower a string `s.slice(start, end)` onto `body`, leaving the new string ref on
// the stack — a fresh `(array i32)` over the half-open clamped range `[start, end)`.
// JS semantics (mirroring `__string_slice__`): each bound clamps via `emitClampIdx`,
// the out length is `max(end - start, 0)`, then one `array.copy` from `s[start]`.
// i32 temps: I0 = clamped start, I1 = clamped end, I2 = len(s), I3 = out length.
function emitStrSlice(body: i32[], callIx: i32, fnIx: i32) {
  if !aUsed {
    return emitFail("emitProgram: string slice but array type not collected")
  }
  let c = P.nodes[callIx]
  if c is Call {
    if c.callArgs.length != 2 {
      return emitFail(
        "emitProgram: string .slice takes exactly two arguments (start, end)",
      )
    }
    const callee = P.nodes[c.callFn]
    if callee is Member {
      // Eval receiver + both args onto the stack first (nested string ops complete),
      // then stash: end on top → I1, then start → I0, then receiver → strScrA.
      if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
      if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
      if emitExpr(body, c.callArgs[1], fnIx) < 0 { return -1 }
      setStrScrI(body, 1)            // raw end → I1
      setStrScrI(body, 0)            // raw start → I0
      fbLocalSet(strScratchBase + 0) // local.set strScrA (receiver)
      // I2 = len(s)
      pushStrScrRef(body, 0)
      fbArrayLen() // array.len
      setStrScrI(body, 2)
      // I0 = clamp(rawStart, len)
      if emitClampIdx(body, 0, 2) < 0 { return -1 }
      setStrScrI(body, 0)
      // I1 = clamp(rawEnd, len)
      if emitClampIdx(body, 1, 2) < 0 { return -1 }
      setStrScrI(body, 1)
      // I3 = out length = max(end - start, 0) = select( end-start, 0, end > start )
      pushStrScrI(body, 1)
      pushStrScrI(body, 0)
      fbI32Bin(107) // 0x6b i32.sub → end - start   [a]
      fbI32Const(0) // i32.const 0                  [b]
      pushStrScrI(body, 1)
      pushStrScrI(body, 0)
      fbI32Bin(74)  // 0x4a i32.gt_s → end > start  [cond]
      wU8(27)       // 0x1b select
      setStrScrI(body, 3)
      // Out = array.new_default $aTypeIdx I3
      pushStrScrI(body, 3)
      fbArrayNewDefault(aTypeIdx)    // 0xfb 0x07 array.new_default <typeidx>
      fbLocalSet(strScratchBase + 2) // local.set strScrOut
      // array.copy Out 0 s start n
      pushStrScrRef(body, 2)          // dest
      fbI32Const(0)                   // i32.const 0 (dest offset)
      pushStrScrRef(body, 0)          // src s
      pushStrScrI(body, 0)            // src offset = clamped start
      pushStrScrI(body, 3)            // count = n
      fbArrayCopy(aTypeIdx, aTypeIdx) // array.copy (dest type, src type)
      // Result: the new string ref.
      pushStrScrRef(body, 2)
      return 0
    }
    return emitFail("emitProgram: string .slice receiver is not a member access")
  }
  emitFail("emitProgram: expected a string slice call")
}

// Lower `s.indexOf(sub)` (or `s.includes(sub)`) onto `body`, leaving an i32: the
// first index of `sub` in `s`, or -1 (an empty `sub` yields 0, the JS convention);
// `includes` is `indexOf != -1`. Mirrors the host's `__string_index_of__` naive
// O(n*m) scan (compiler/builtins/strings.ts), inlined here like `emitStrEq`.
// Scratch: refs A = s, B = sub; i32 temps I0 = i (outer), I1 = j (inner),
// I2 = len(s), I3 = len(sub).
//   block i32 {
//     I0 = 0
//     loop {                                  ; outer: candidate starts
//       if I0 > I2 - I3 { }                   ; past last start → fall out → -1
//       else {
//         I1 = 0
//         loop {                              ; inner: match scan at I0
//           if I1 >= I3 { (I0) br <block> }   ; full match → yield I0
//           if A[I0+I1] != B[I1] { I0 = I0 + 1; br <outer> }
//           I1 = I1 + 1
//           br <inner>
//         }
//       }
//     }
//     (i32.const -1)
//   }
function emitStrIndexOf(body: i32[], callIx: i32, fnIx: i32) {
  if !aUsed {
    return emitFail("emitProgram: string indexOf but array type not collected")
  }
  let c = P.nodes[callIx]
  if c is Call {
    if c.callArgs.length != 1 {
      return emitFail("emitProgram: string .indexOf takes exactly one argument")
    }
    const callee = P.nodes[c.callFn]
    if callee is Member {
      const isIncludes = callee.memProp == "includes"
      // Eval receiver + needle onto the stack first (nested string ops complete),
      // then stash: needle on top → B, then receiver → A.
      if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
      if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
      fbLocalSet(strScratchBase + 1) // local.set strScrB (sub)
      fbLocalSet(strScratchBase + 0) // local.set strScrA (s)
      // I2 = len(s); I3 = len(sub)
      pushStrScrRef(body, 0)
      fbArrayLen()        // array.len
      setStrScrI(body, 2)
      pushStrScrRef(body, 1)
      fbArrayLen()        // array.len
      setStrScrI(body, 3)
      fbBlock(127)        // 0x02 block, 0x7f i32 blocktype — yields index / -1
      fbI32Const(0)
      setStrScrI(body, 0) // I0 = 0
      fbLoop(64)          // 0x03 loop (outer), 0x40 void blocktype
      // Past the last possible start (I0 > I2 - I3) → done, fall out (no match).
      pushStrScrI(body, 0)
      pushStrScrI(body, 2)
      pushStrScrI(body, 3)
      fbI32Bin(107) // 0x6b i32.sub → len(s) - len(sub)
      fbI32Bin(74)  // 0x4a i32.gt_s
      fbIf(64)      // 0x04 if, 0x40 void blocktype
      // then: done — fall through (empty)
      fbElse()            // 0x05 else
      fbI32Const(0)
      setStrScrI(body, 1) // I1 = 0
      fbLoop(64)          // 0x03 loop (inner), 0x40 void blocktype
      // I1 >= len(sub) → full match at I0: yield I0 out of the i32 block.
      pushStrScrI(body, 1)
      pushStrScrI(body, 3)
      fbI32Bin(78) // 0x4e i32.ge_s
      fbIf(64)     // 0x04 if, 0x40 void blocktype
      pushStrScrI(body, 0)
      fbBr(4)      // depths: if(0)·inner loop(1)·else(2)·outer loop(3)·block(4)
      fbEnd()      // 0x0b end (match if)
      // A[I0+I1] != B[I1] → mismatch: advance I0, continue the outer loop.
      pushStrScrRef(body, 0)
      pushStrScrI(body, 0)
      pushStrScrI(body, 1)
      fbI32Bin(106)        // 0x6a i32.add
      fbArrayGet(aTypeIdx) // 0xfb 0x0b array.get
      pushStrScrRef(body, 1)
      pushStrScrI(body, 1)
      fbArrayGet(aTypeIdx) // array.get
      fbI32Bin(71)         // 0x47 i32.ne
      fbIf(64)             // 0x04 if, 0x40 void blocktype
      pushStrScrI(body, 0)
      fbI32Const(1)
      fbI32Bin(106)        // i32.add
      setStrScrI(body, 0)  // I0 = I0 + 1
      fbBr(3)              // 0x0c br depth 3 → outer loop header (continue)
      fbEnd()              // 0x0b end (mismatch if)
      // I1 = I1 + 1; br inner loop
      pushStrScrI(body, 1)
      fbI32Const(1)
      fbI32Bin(106)  // i32.add
      setStrScrI(body, 1)
      fbBr(0)        // 0x0c br depth 0 → inner loop header
      fbEnd()        // 0x0b end (inner loop)
      fbEnd()        // 0x0b end (outer if/else)
      fbEnd()        // 0x0b end (outer loop)
      fbI32Const(-1) // no match → -1
      fbEnd()        // 0x0b end (block) — leaves the i32 result
      if isIncludes {
        fbI32Const(-1)
        fbI32Bin(71) // 0x47 i32.ne — `includes` ≡ `indexOf(sub) != -1`
      }
      return 0
    }
    return emitFail("emitProgram: string .indexOf receiver is not a member access")
  }
  emitFail("emitProgram: expected a string indexOf call")
}

// Lower `s.charCodeAt(i)` onto `body`, leaving the char code i32. A direct
// `array.get` over the code-point array — an out-of-range index TRAPS, matching
// the host (`s[i]` semantics, no JS NaN; compiler/builtins/strings.ts).
function emitStrCharCode(body: i32[], callIx: i32, fnIx: i32) {
  if !aUsed {
    return emitFail("emitProgram: string charCodeAt but array type not collected")
  }
  let c = P.nodes[callIx]
  if c is Call {
    if c.callArgs.length != 1 {
      return emitFail("emitProgram: string .charCodeAt takes exactly one argument")
    }
    const callee = P.nodes[c.callFn]
    if callee is Member {
      if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
      if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
      fbArrayGet(aTypeIdx) // 0xfb 0x0b array.get
      return 0
    }
    return emitFail(
      "emitProgram: string .charCodeAt receiver is not a member access",
    )
  }
  emitFail("emitProgram: expected a string charCodeAt call")
}

function emitExpr(body: i32[], exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return emitFail("emitProgram: missing expression") }
  const e = P.nodes[exprIx]
  if e is NumLit {
    // A FLOAT literal (lexeme carries a `.`) in f32 CONTEXT (`pendingF32` — an `: f32`
    // binding/param/return) lowers as `f32.const`. Checked before the default f64 path
    // so a float literal re-encodes at single precision in an f32 slot (never demoted
    // from f64). Outside f32 context a `.` literal stays f64, byte-identical. (Slice 5.)
    if numTextIsFloat(e.numText) {
      if pendingF32 {
        fbF32Const(e.numText)
        return 0
      }
      fbF64Const(e.numText)
      return 0
    }
    // An integer literal in f32 CONTEXT lowers DIRECTLY as `f32.const` (re-encoded at
    // single precision — `f32Bytes` parses an integer lexeme as `mant/10^0`), so it is a
    // valid constexpr in a const-global init (a convert op is not). (Slice 5.)
    if pendingF32 {
      fbF32Const(e.numText)
      return 0
    }
    // An integer literal in f64 CONTEXT (const-global init) lowers directly as
    // `f64.const`, keeping the global init a constexpr (`const b: f64 = 5`). (Slice 5.)
    if pendingF64 {
      fbF64Const(e.numText)
      return 0
    }
    // An integer literal in i64 CONTEXT (`pendingI64`) lowers as `i64.const` over the
    // 64-bit (hi, lo) pair parsed from its lexeme — so a value past the i32 range
    // (`9000000000`, `0xFFFFFFFFFF`) survives. Otherwise the default i32 path is
    // byte-identical to before (bare integer literals stay i32 — Slice 1 invariant).
    if pendingI64 {
      const pr = parseI64Pair(e.numText)
      fbI64Const(pr[0], pr[1])
      return 0
    }
    // An integer literal past the i32 range is TYPED i64 by the checker (the host's
    // `defaultIntegerType` magnitude rule), so it lowers as `i64.const` even with no
    // i64 context — the old default `i32.const` silently wrapped (0xDEAD_BEEF).
    if !numLexFitsI32(e.numText) {
      const pr = parseI64Pair(e.numText)
      fbI64Const(pr[0], pr[1])
      return 0
    }
    fbI32Const(parseI32(e.numText))
    return 0
  }
  if e is BoolLit {
    // `boolean` rides in an i32: true=1, false=0 (already decoded into `boolVal`).
    fbI32Const(e.boolVal)
    return 0
  }
  if e is CharLit {
    // A char literal IS its single Unicode code point as an i32. `charText` is the RAW
    // lexeme (quotes kept, escapes unresolved), so decode it the SAME way string
    // literals decode (`decodeStr` strips the quotes + resolves escapes); a well-formed
    // char yields exactly one code point.
    const cps = decodeStr(strToCps(e.charText))
    if cps.length != 1 {
      return emitFail("emitProgram: char literal must denote exactly one code point")
    }
    fbI32Const(cps[0])
    return 0
  }
  if e is Ident {
    // A CAPTURED variable (a free var of a capturing lifted function): read it from the
    // env struct threaded as the leading param (local 0) —
    // `struct.get $env <fieldIdx> (ref.cast (local.get 0) (ref $env))`. Checked FIRST so
    // a capture shadows nothing (it is neither a param/local of this function nor a
    // global). Only fires inside a capturing lifted function.
    if emitCapturedRead(body, e.identName, fnIx) == 1 { return 0 }
    // A VALUE-union binding narrowed to ONE scalar atom reads UNBOXED: push the
    // box, recover the `anyref` payload, cast it, and (for a scalar atom) read
    // the value-box field — `if u is i32 { print(u) }` yields the raw i32.
    const vAtom = narrowedValueAtomOf(e.identName)
    if vAtom != "" {
      if unionNameOfIdent(e.identName, fnIx) != "" {
        return emitValueUnionUnboxRead(body, e.identName, vAtom, fnIx)
      }
    }
    // A name resolves to a param (locals 0..p-1) or a declared local (locals p..).
    const idx = localIndexOf(fnIx, e.identName)
    if idx < 0 {
      // A bare top-level/lifted function NAME in value position constructs a function
      // value (closure fat-pointer). `fnIndexOf` IS the `fnStmts` position (the function
      // index), exactly what `emitClosureValue` expects — passed directly (a top-level
      // function never captures, so its env is null; a captured lifted function reads its
      // captures live in the enclosing frame `fnIx`). Scope-aware so a nested function
      // sharing a name with another maker's nested function resolves to THIS frame's.
      let fe = fnIndexOfInScope(e.identName, fnIx)
      if fe >= 0 { return emitClosureValue(body, fe, fnIx) }
      // Not a local — a module global? Read it with `global.get` (0x23 <globalidx>).
      const gIdx = globalIndexOf(e.identName)
      if gIdx >= 0 {
        fbGlobalGet(gIdx)
        const gck0 = globalCellKind(globalLetOf(e.identName))
        // A `string | null` cell (kind 16) is ALWAYS a NULLABLE ref — const OR not (a
        // const can still be initialized to `null`). So a VALUE read recovers the non-null
        // string ref (`ref.as_non_null`, 0xd4 — the checker narrowed it non-null at every
        // value read) INDEPENDENTLY of const-ness; the `!= null` null-check keeps the raw
        // nullable ref (`pendingRawNullRead`). Without this a top-level `string | null`
        // value read (`x ?? d`, `!= null`) left a `(ref null $array)` where a `(ref $array)`
        // is expected (a function-scope local already recovers via the local path below).
        if gck0 == 16 {
          if !pendingRawNullRead {
            wU8(212) // 0xd4 ref.as_non_null
          }
          return 0
        }
        // A NON-const ref global rides in a NULLABLE cell (zero-initialized with
        // `ref.null`, set by the start function before any code runs). Recover the
        // non-null value type the rest of codegen expects with `ref.as_non_null`
        // (0xd4); the cell is always initialized first, so the cast never traps. A
        // const global keeps its non-null cell, so no cast (goldens unchanged). A
        // scalar (i32/boolean) global needs no cast either.
        if globalNameIsNonConst(e.identName) {
          // A NULLABLE-struct cell (kind 9) legitimately holds null — its reads
          // stay nullable (the member-access path recovers non-null at use); a
          // nullable-LIST cell (kind 15) and a nullable-CLOSURE cell (kind 19)
          // likewise (the `!= null` check reads raw, the narrowed call recovers
          // non-null at the call site). A SCALAR numeric cell (i32 0 / i64 10 /
          // f64 11 / f32 13 / boolean) is not a ref, so it takes no
          // `ref.as_non_null` either. (Slice 5 adds f32/i64/f64 scalars.)
          if (
            gck0 != 0 &&
            gck0 != 9 &&
            gck0 != 10 &&
            gck0 != 11 &&
            gck0 != 13 &&
            gck0 != 15 &&
            gck0 != 19
          ) {
            wU8(212) // 0xd4 ref.as_non_null
          }
        }
        return 0
      }
      return emitFail("emitProgram: identifier is not a parameter, local, or global")
    }
    fbLocalGet(idx)
    // A `string | null` (kind 16) param/local read AS A VALUE recovers the non-null
    // string ref — the checker narrowed it non-null at every such read. The `!= null`
    // null-check sets `pendingRawNullRead` to keep the raw nullable ref for `ref.is_null`.
    // A NULLABLE-string TARGET (`pendingNulString` — `const t: string | null = s`, `t = s`,
    // a `string | null` arg/return) likewise keeps the raw nullable ref: recovering it would
    // `ref.as_non_null` a value that may legitimately be null and trap. Mirrors the kind-15
    // list read, which never eagerly recovers.
    if !pendingRawNullRead && !pendingNulString {
      if paramNulString(fnIx, e.identName) || declaredNulString(e.identName) {
        fbRefAsNonNull() // 0xd4
      }
    }
    return 0
  }
  if e is Paren { return emitExpr(body, e.parInner, fnIx) }
  if e is Unary {
    // Logical not `!a`: a boolean rides in an i32 (0/1), so `i32.eqz` (0x45) maps
    // 0→1 and any non-zero→0 — exactly `a == 0`. Push the operand, then eqz.
    if e.unOp == "!" {
      if emitExpr(body, e.unArg, fnIx) < 0 { return -1 }
      fbI32Eqz() // 0x45 i32.eqz
      return 0
    }
    // Postfix `x++` / `x--` in EXPRESSION position yields the OLD value. `unArg` is
    // the increment assignment `x = x ± 1`, which as an expression yields the NEW
    // value (store-then-re-read); undo the step (new ∓ 1) to recover the pre-
    // increment value. (In STATEMENT position `emitStmt` unwraps to the bare
    // assignment, so this adjustment is only paid when the value is actually used.)
    if e.unOp == "p+" || e.unOp == "p-" {
      if emitExpr(body, e.unArg, fnIx) < 0 { return -1 }
      fbI32Const(1)
      if e.unOp == "p+" {
        fbI32Bin(107) // 0x6b i32.sub: (x+1) - 1
      } else {
        fbI32Bin(106) // 0x6a i32.add: (x-1) + 1
      }
      return 0
    }
    // Bitwise NOT `~x` == `x ^ -1` (flip every bit). The all-ones mask is an i64
    // `-1` when the operand is i64, an i32 `-1` otherwise; the XOR opcode follows
    // suit. (Slice 2 — the i64 path; the i32 path is the same shape over i32 ops.)
    if e.unOp == "~" {
      if exprIsI64(e.unArg, fnIx) {
        if emitExpr(body, e.unArg, fnIx) < 0 { return -1 }
        fbI64Const(-1, -1) // i64 -1 (all ones)
        fbI32Bin(133)      // 0x85 i64.xor
        return 0
      }
      if emitExpr(body, e.unArg, fnIx) < 0 { return -1 }
      fbI32Const(-1) // i32 -1 (all ones)
      fbI32Bin(115)  // 0x73 i32.xor
      return 0
    }
    // Integer negation: `-x` == `0 - x`, so push 0, the operand, then sub. For an
    // i64 operand the zero and the subtract are i64 (Slice 2).
    if e.unOp != "-" {
      return emitFail("emitProgram: unsupported unary operator")
    }
    // f32 negation uses the dedicated `f32.neg` (0x8c) — flips the sign bit. Checked
    // before f64 (an f32 expr is never `exprIsF64`, but this keeps the float cases
    // grouped and explicit). (Slice 5.)
    if exprIsF32(e.unArg, fnIx) {
      if emitExpr(body, e.unArg, fnIx) < 0 { return -1 }
      wU8(140) // 0x8c f32.neg
      return 0
    }
    // f64 negation uses the dedicated `f64.neg` (0x9a) — flips the sign bit (Slice 3).
    if exprIsF64(e.unArg, fnIx) {
      if emitExpr(body, e.unArg, fnIx) < 0 { return -1 }
      wU8(154) // 0x9a f64.neg
      return 0
    }
    // A negated magnitude-2^31 INTEGER literal (`-2147483648`) is i32 (the host
    // folds the sign in before defaulting), but the bare operand lexeme is one
    // past I32_MAX, so the `exprIsI64(e.unArg)` branch below would lower it as
    // an i64 negation. Lower it directly as a WRAPPING i32 negation instead:
    // `parseI32` folds 0x80000000 to I32_MIN, and `0 - I32_MIN` wraps back to
    // I32_MIN — the right value. Checked BEFORE the operand i64 classification.
    const negInner = unwrapParen(e.unArg)
    const negNode = P.nodes[negInner]
    if negNode is NumLit {
      if !numTextIsFloat(negNode.numText) {
        if numLexIs2Pow31(negNode.numText) {
          fbI32Const(0)
          fbI32Const(parseI32(negNode.numText))
          fbI32Bin(107) // 0x6b i32.sub
          return 0
        }
      }
    }
    if exprIsI64(e.unArg, fnIx) {
      fbI64Const(0, 0) // i64 0
      if emitExpr(body, e.unArg, fnIx) < 0 { return -1 }
      fbI32Bin(125)    // 0x7d i64.sub
      return 0
    }
    fbI32Const(0)
    if emitExpr(body, e.unArg, fnIx) < 0 { return -1 }
    fbI32Bin(107) // 0x6b i32.sub
    return 0
  }
  if e is Call {
    // G6: `s.slice(start, end)` over a string receiver is an intrinsic — a new
    // `(array i32)` over the clamped half-open range. Other member-calls in value
    // position are out of scope (the only member-call STATEMENT is `.push`).
    if exprIsStrSlice(exprIx, fnIx) { return emitStrSlice(body, exprIx, fnIx) }
    // An array `xs.slice(start, end?)` over a LIST receiver — a same-element-kind
    // sublist (`emitArrSlice`). Checked before the string slice's siblings so it does
    // not fall into a struct member-call path.
    if callIsArrSlice(exprIx, fnIx) { return emitArrSlice(body, exprIx, fnIx) }
    // `s.indexOf(sub)` / `s.includes(sub)` / `s.charCodeAt(i)` over a string
    // receiver are intrinsics too (A7), each yielding an i32.
    if exprIsStrIndexOf(exprIx, fnIx) {
      return emitStrIndexOf(body, exprIx, fnIx)
    }
    if exprIsStrCharCode(exprIx, fnIx) {
      return emitStrCharCode(body, exprIx, fnIx)
    }
    // G8: the `Map()` builtin constructs an empty string-keyed map. `Set()` is a
    // boolean-valued string map over the SAME 7-field struct, so it emits the
    // IDENTICAL empty-map construction.
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if callee.identName == "Map" || callee.identName == "Set" {
        return emitMapNew(body)
      }
    }
    // G8: a map `m.has(k)` member-call yields a 0/1 i32 (linear scan).
    if callee is Member {
      if callee.memProp == "has" {
        if exprMap(callee.memObj, fnIx) {
          if e.callArgs.length != 1 {
            return emitFail("emitProgram: .has takes exactly one argument")
          }
          return emitMapHas(body, callee.memObj, e.callArgs[0], fnIx)
        }
      }
      // G8: a map `m.delete(k)` member-call in VALUE position yields a 0/1 boolean
      // (whether a key was removed). The same lowering serves the bare-statement form.
      if callee.memProp == "delete" {
        if exprMap(callee.memObj, fnIx) {
          if e.callArgs.length != 1 {
            return emitFail("emitProgram: .delete takes exactly one argument")
          }
          return emitMapDelete(body, callee.memObj, e.callArgs[0], fnIx)
        }
      }
      // `m.keys()` over a map yields a fresh string list of its LIVE keys.
      if callee.memProp == "keys" {
        if exprMap(callee.memObj, fnIx) {
          if e.callArgs.length != 0 {
            return emitFail("emitProgram: .keys() takes no arguments")
          }
          return emitMapKeys(body, callee.memObj, fnIx)
        }
      }
      // `m.values()` over a mono i32 map yields a fresh i32 list of its LIVE values.
      if callee.memProp == "values" {
        if exprMap(callee.memObj, fnIx) {
          if e.callArgs.length != 0 {
            return emitFail("emitProgram: .values() takes no arguments")
          }
          return emitMapValues(body, callee.memObj, fnIx)
        }
      }
      // `xs.pop()` removes + returns the last list element (any list kind).
      if callee.memProp == "pop" { return emitPop(body, exprIx, fnIx) }
      // `xs.get(i)` over a STRUCT-element ref list: the checked nullable read —
      // in-bounds yields the (still nullable) element slot, out-of-bounds `ref.null $S`.
      if callee.memProp == "get" {
        if structListPopGetElem(exprIx, fnIx) >= 0 {
          return emitListGet(body, exprIx, fnIx)
        }
      }
      // `xs.map(f)` / `xs.filter(p)` over a LIST receiver lower to the inline
      // closure-calling loop (Slices 3–4). A non-list receiver falls through (a
      // function-valued struct FIELD named `map` is a `call_ref` member call).
      if callee.memProp == "map" || callee.memProp == "filter" {
        if mfRecvKindOf(callee.memObj, fnIx) >= 0 {
          return emitMapFilter(body, exprIx, fnIx)
        }
      }
    }
    return emitCall(body, exprIx, fnIx)
  }
  if e is IsExpr { return emitIs(body, exprIx, fnIx) }
  if e is NullLit {
    // `null` in a `boolean|null` NICHE context is the scalar sentinel 2 (an i32,
    // not a ref) — checked before the struct seed.
    if pendingNulBool {
      fbI32Const(2)
      return 0
    }
    // `null` in a `string | null` (kind 16) context — `ref.null $aTypeIdx` (the raw
    // string array made nullable). Checked before the struct seed (a string is not a
    // struct). Seeded at the param-arg / assignment / return boundaries.
    if pendingNulString {
      wU8(208) // 0xd0 ref.null
      wSLEB(aTypeIdx)
      return 0
    }
    // `null` in a nullable FUNCTION-VALUE (`fn | null`, kind 19) context — `ref.null
    // $cloStruct` (the closure fat-pointer made nullable). Checked before the struct seed.
    if pendingNulClosure {
      wU8(208) // 0xd0 ref.null
      wSLEB(cloStructIdx)
      return 0
    }
    // `null` as a NULLABLE-i32-LIST element of a `(i32[] | null)[]` literal — `ref.null $lTypeIdx`.
    if pendingNulList {
      wU8(208) // 0xd0 ref.null
      wSLEB(lTypeIdx)
      return 0
    }
    // `null` as a NULLABLE-REF-ARRAY element of a `(<ref-array> | null)[]` literal — `ref.null
    // $innerWrapper` (the seeded inner ref-list wrapper heap type). Reset the seed after consuming it so it
    // never persists past this `null` (a stray non-(-1) value would mis-type a later bare `null`).
    if pendingNulRefHeap >= 0 {
      const nrh = pendingNulRefHeap
      pendingNulRefHeap = -1
      wU8(208) // 0xd0 ref.null
      wSLEB(nrh)
      return 0
    }
    // A bare `null` VALUE: its target struct comes from the binding/argument/
    // return seed (`pendingStructIdx`) — `ref.null $S`. With no seed it cannot
    // be typed here; fail loudly.
    if pendingStructIdx >= 0 {
      if pendingStructIdx < sHeapIdx.length {
        wU8(208) // 0xd0 ref.null
        wSLEB(sHeapIdx[pendingStructIdx])
        return 0
      }
    }
    return emitFail("emitProgram: bare null needs a struct-typed context")
  }
  if e is ObjLit {
    // A CONTEXT that expects a CONCRETE variant (`const c: Cat = { … }`, a `Cat[]`
    // element) constructs the BARE variant struct `(ref $(uVarIdx + vi))` — NOT a union
    // box. `pendingVariantIdx` is the variant; consume it so a nested literal doesn't
    // inherit the hint.
    if pendingVariantIdx >= 0 {
      const pvi = pendingVariantIdx
      pendingVariantIdx = -1
      return emitVariantStruct(body, exprIx, pvi, fnIx)
    }
    // A literal whose field-set matches a STANDALONE struct constructs that struct
    // directly (even alongside a union — `ast.vl`'s `Tok`/`Diag` coexist with `Node`).
    // Otherwise, in a union program, it is a union variant: box it `{tag, value}`.
    if structIndexOfObj(exprIx) >= 0 { return emitObj(body, exprIx, fnIx) }
    if uDeclared { return emitUnionBox(body, exprIx, fnIx) }
    return emitObj(body, exprIx, fnIx)
  }
  if e is StrLit {
    // A literal-union MEMBER in atom context (`pendingLitUnion`) lowers as its interned i32 id.
    if pendingLitUnion == 1 {
      fbI32Const(internAtom(e.strText))
      return 0
    }
    return emitStr(body, exprIx, fnIx)
  }
  if e is ArrayLit { return emitArr(body, exprIx, fnIx) }
  if e is Index {
    // G8: a map GET `m[k]` (no `??`) — scan, value or 0. A `??` get is fused in the
    // BinExpr branch below (it carries the default).
    if exprMap(e.idxArr, fnIx) {
      return emitMapGet(body, e.idxArr, e.idxIndex, fnIx)
    }
    return emitIndex(body, exprIx, fnIx)
  }
  if e is Member {
    // `a.length` on an array OR string receiver is `array.len` (a string is the SAME
    // `array i32` of code points, so `.length` is the code-point count); every other
    // member access is a struct field read. `length` over a non-array/non-string
    // receiver falls through to the struct path (which fails loudly if no such field),
    // matching the slice's scope.
    if e.memProp == "length" {
      if (
        exprArray(e.memObj, fnIx) ||
        exprString(e.memObj, fnIx) ||
        exprRefArray(e.memObj, fnIx) ||
        exprStringArray(e.memObj, fnIx) ||
        exprF64Array(e.memObj, fnIx) ||
        exprI64Array(e.memObj, fnIx) ||
        exprF32Array(e.memObj, fnIx)
      ) {
        return emitArrLen(body, exprIx, fnIx)
      }
      // G8: `m.length` on a MAP is the LIVE entry count — struct field 5 (`size`),
      // maintained by set/delete (NOT `count`, which includes tombstones).
      if exprMap(e.memObj, fnIx) {
        if emitExpr(body, e.memObj, fnIx) < 0 { return -1 }
        let lsl = mapShapeOfExpr(e.memObj, fnIx)
        if lsl == -2 || lsl == -3 { lsl = -1 }
        fbStructGet(mapTypeIdxOf(lsl), 5) // 0xfb 0x02: field 5 `size`
        return 0
      }
    }
    // `m.size` on a MAP / Set is the same live-entry count as `m.length` (field 5) — the
    // JS Map/Set name. (`.size` is not valid on arrays/strings; they fall through.)
    if e.memProp == "size" {
      if exprMap(e.memObj, fnIx) {
        if emitExpr(body, e.memObj, fnIx) < 0 { return -1 }
        let ssl = mapShapeOfExpr(e.memObj, fnIx)
        if ssl == -2 || ssl == -3 { ssl = -1 }
        fbStructGet(mapTypeIdxOf(ssl), 5) // 0xfb 0x02: field 5 `size`
        return 0
      }
    }
    return emitMem(body, exprIx, fnIx)
  }
  if e is BinExpr {
    // Assignment (`=`) is a STATEMENT, not a value expression in this slice: it has
    // no result on the stack (it `local.set`s). It is lowered by `emitAssign` from
    // `emitStmt`, so seeing it as an operand here is an unsupported nested-assignment.
    if e.binOp == "=" {
      // Assignment is an EXPRESSION yielding its right-hand side (DECISIONS:
      // assignment-as-expression): `b = (a = 5)`, `while (a = a - 1) > 0`, and a
      // trailing `count = count + 1` returning the new value. Lowered as
      // STORE-then-RE-READ — `emitAssign` stores, then the target re-reads through
      // the normal Ident path (which carries the non-const-ref re-cast logic).
      // Ident targets only (a local or module global); an Index/Member assignment
      // in VALUE position is out of this slice.
      const tgt = P.nodes[e.binLeft]
      if tgt is Ident {
        if emitAssign(body, exprIx, fnIx) < 0 { return -1 }
        return emitExpr(body, e.binLeft, fnIx)
      }
      return emitFail(
        "emitProgram: only an identifier assignment is a value expression",
      )
    }
    // G8: nullish-coalescing `m[k] ?? d` — a FUSED map get-with-default: scan `m` for
    // `k`, push `vals[hit]` on a hit else the default `d`. The self-host checker reads
    // every scope map through `?? -1`. The LHS must be a map index in this slice.
    if e.binOp == "??" {
      // Unwrap a parenthesized LHS so `(m[k]) ?? d` / `(m.get(k)) ?? d` take the same fused
      // map-get path as the bare forms — parens must not change `??` semantics. `lhsIx` is the
      // unwrapped place every structural branch below dispatches on and emits; the generic niche
      // paths re-evaluate `e.binLeft` directly (and `emitExpr` / `exprNullableString` already peel
      // parens), so they are unaffected.
      const lhsIx = unwrapParen(e.binLeft)
      const lhs = P.nodes[lhsIx]
      // `a ?? b ?? d` parses LEFT-associative (`(a ?? b) ?? d`); `??` is
      // associative, so RE-ASSOCIATE to `a ?? (b ?? d)` — the inner coalesce
      // becomes the outer's default and each LHS is again a plain place the
      // single-step lowerings below handle (host: same chained-coalesce value).
      if lhs is BinExpr {
        if lhs.binOp == "??" {
          return emitExpr(
            body,
            mkBinary(
              "??",
              lhs.binLeft,
              mkBinary("??", lhs.binRight, e.binRight, -1),
              -1,
            ),
            fnIx,
          )
        }
      }
      if lhs is Index {
        if exprMap(lhs.idxArr, fnIx) {
          return emitMapGetOr(body, lhs.idxArr, lhs.idxIndex, e.binRight, fnIx)
        }
      }
      // The METHOD form `recv.get(k) ?? d` over a map receiver is the SAME fused
      // get-with-default as `recv[k] ?? d` — lower it identically. (The LIST `.get`
      // at ~6890 is a distinct struct-element get and is NOT a map; `exprMap` gates
      // this to map receivers only.)
      if lhs is Call {
        const lcallee = P.nodes[lhs.callFn]
        if lcallee is Member {
          if lcallee.memProp == "get" {
            if exprMap(lcallee.memObj, fnIx) {
              if lhs.callArgs.length != 1 {
                return emitFail("emitProgram: map .get takes exactly one argument")
              }
              return emitMapGetOr(body, lcallee.memObj, lhs.callArgs[0], e.binRight, fnIx)
            }
            // `xs.get(i) ?? d` over a SCALAR-element list (i32 / boolean / f64) is
            // the FUSED checked read-with-default (B6) — one bounds compare.
            if (
              exprF64Array(lcallee.memObj, fnIx) ||
              exprArray(lcallee.memObj, fnIx)
            ) {
              return emitListGetOr(body, lhsIx, e.binRight, fnIx)
            }
          }
          // `xs.pop() ?? d` over a SCALAR-element list is the FUSED checked
          // pop-with-default: `len != 0` selects decrement-and-read or `d`.
          if lcallee.memProp == "pop" {
            if exprArray(lcallee.memObj, fnIx) {
              if (
                !exprRefArray(lcallee.memObj, fnIx) &&
                !exprStringArray(lcallee.memObj, fnIx) &&
                !exprF64Array(lcallee.memObj, fnIx)
              ) {
                return emitPopOr(body, lhsIx, e.binRight, fnIx)
              }
            }
          }
        }
      }
      // These generic niche `??` paths RE-EVALUATE `e.binLeft` (twice for the bool select,
      // and in the else arm for the string), so they apply only to an effect-free place —
      // an ident binding or a struct FIELD. A CALL lhs (`f() ?? d`) cannot be re-evaluated
      // and is handled by the stash-based call path in the `lhs is Call` block below.
      let lhsReEval = true
      if lhs is Call { lhsReEval = false }
      // `<e> ?? d` over a `boolean | null` NICHE (an ident binding OR a `boolean | null`
      // struct FIELD, code 21) — the i32 cell holds 0/1 or the sentinel 2 (`null`); select
      // the default on 2. Generic in `e.binLeft`, so it covers a member field read too.
      if lhsReEval && exprNulBool(e.binLeft, fnIx) {
        if emitExpr(body, e.binRight, fnIx) < 0 {
          return -1 // d   [a]
        }
        if emitExpr(body, e.binLeft, fnIx) < 0 {
          return -1 // x   [b]
        }
        if emitExpr(body, e.binLeft, fnIx) < 0 { return -1 }
        fbI32Const(2)
        fbI32Bin(70) // 0x46 i32.eq → x == 2 (null)      [cond]
        wU8(27)      // 0x1b select → d if null else x
        return 0
      }
      // `<e> ?? d` over a `string | null` NICHE (an ident binding OR a `string | null`
      // struct FIELD, code 20): the nullable raw-array ref — a VALUE-typed `if` on
      // `ref.is_null` (the else arm reads `e` as a non-null value). `pendingRawNullRead`
      // keeps the test read raw. Generic in `e.binLeft`, so it covers a member field too.
      if lhsReEval && exprNullableString(e.binLeft, fnIx) {
        const savedRawN = pendingRawNullRead
        pendingRawNullRead = true
        const treN = emitExpr(body, e.binLeft, fnIx) // the raw nullable ref
        pendingRawNullRead = savedRawN
        if treN < 0 { return -1 }
        wU8(209)                                     // 0xd1 ref.is_null → 1 if null
        wU8(4)                                       // 0x04 if
        wU8(100)                                     // blocktype: (ref $aTypeIdx) — non-null string result
        wSLEB(aTypeIdx)
        ctrlEnter()
        if emitExpr(body, e.binRight, fnIx) < 0 {
          return -1 // d (a string)
        }
        fbElse() // 0x05 else
        if emitExpr(body, e.binLeft, fnIx) < 0 {
          return -1 // e recovered non-null
        }
        fbEnd() // 0x0b end
        ctrlLeave()
        return 0
      }
      // `x ?? d` over a binding seeded by a BOOLEAN-list `.pop()`: the i32 cell
      // holds 0/1 or the niche sentinel 2 (`null`) — select the default on 2.
      if lhs is Ident {
        if identNullableBoolPop(lhs.identName, fnIx) {
          if emitExpr(body, e.binRight, fnIx) < 0 {
            return -1 // d   [a]
          }
          if emitExpr(body, e.binLeft, fnIx) < 0 {
            return -1 // x   [b]
          }
          if emitExpr(body, e.binLeft, fnIx) < 0 { return -1 }
          fbI32Const(2)
          fbI32Bin(70) // 0x46 i32.eq → x == 2 (null)      [cond]
          wU8(27)      // 0x1b select → d if null else x
          return 0
        }
        // `x ?? d` over a BOXED value union containing `null` (`i32 | null`):
        // the value-level dual of the null guard — read the box tag; the null
        // tag selects the default, anything else unboxes the SINGLE remaining
        // scalar atom (the host's `??` result is the non-null base type). The
        // receiver is a pure name, re-read in the non-null arm. Scalar atoms
        // only (the value-typed `if` blocktype carries the unboxed rep).
        const cunm = unionNameOfIdent(lhs.identName, fnIx)
        if cunm != "" {
          if isValueUnionName(cunm) && unionHasAtom(cunm, "null") {
            const crest = removeAtomFrom(currentNarrowSetOf(lhs.identName, fnIx), "null")
            const cak = valueAtomKind(crest)
            if cak >= 0 && cak != 6 {
              if cak == 2 {
                return emitFail(
                  "emitProgram: `??` over a string|null union is not supported yet",
                )
              }
              if emitExpr(body, e.binLeft, fnIx) < 0 {
                return -1 // the box
              }
              fbStructGet(uBoxIdx, 0) // field 0: tag
              fbI32Const(scalarTagOf("null"))
              fbI32Bin(70)            // 0x46 i32.eq → null?
              let cbt = 127           // 0x7f i32 (boolean shares it)
              if cak == 3 {
                cbt = 126 // 0x7e i64
              }
              if cak == 4 {
                cbt = 124 // 0x7c f64
              }
              if cak == 5 {
                cbt = 125 // 0x7d f32
              }
              fbIf(cbt) // 0x04 if, value blocktype
              ctrlEnter()
              if cak == 3 {
                if emitExprAsI64(body, e.binRight, fnIx) < 0 { return -1 }
              } else if cak == 4 {
                if emitExprAsF64(body, e.binRight, fnIx) < 0 { return -1 }
              } else if cak == 5 {
                if emitExprAsF32(body, e.binRight, fnIx) < 0 { return -1 }
              } else {
                if emitExpr(body, e.binRight, fnIx) < 0 { return -1 }
              }
              fbElse() // 0x05 else — present → unbox
              if emitValueUnionUnboxRead(body, lhs.identName, crest, fnIx) < 0 {
                return -1
              }
              fbEnd() // 0x0b end
              ctrlLeave()
              return 0
            }
          }
        }
      }
      // `f(x) ?? d` over a CALL returning a value union with `null` (`i32 | null`,
      // …): a call CANNOT be re-evaluated (effects + cost) the way the ident/field
      // paths above re-read their place, so STASH the box once in the coalesce-call
      // slot, then test the tag and unbox off that single evaluation. Scalar atoms
      // only (the value-typed `if` blocktype); a `string | null` call result is
      // deferred like the ident/field forms. One slot is sound across nesting: each
      // `??` sets-tests-uses within its own evaluation, and the null arm never reads
      // the box again (so a nested call-LHS `??` in the default may reuse the slot).
      if lhs is Call {
        const kunm = unionNameOfExpr(e.binLeft, fnIx)
        if kunm != "" {
          if isValueUnionName(kunm) && unionHasAtom(kunm, "null") {
            const krest = removeAtomFrom(kunm, "null")
            const kak = valueAtomKind(krest)
            if kak >= 0 && kak != 6 {
              if kak == 2 {
                return emitFail(
                  "emitProgram: `??` over a string|null call result is not supported yet",
                )
              }
              if emitExpr(body, e.binLeft, fnIx) < 0 {
                return -1 // the box, evaluated ONCE
              }
              fbLocalSet(coalesceCallSlot)
              fbLocalGet(coalesceCallSlot)
              fbStructGet(uBoxIdx, 0) // field 0: tag
              fbI32Const(scalarTagOf("null"))
              fbI32Bin(70)            // 0x46 i32.eq → null?
              let kbt = 127           // 0x7f i32 (boolean shares it)
              if kak == 3 {
                kbt = 126 // 0x7e i64
              }
              if kak == 4 {
                kbt = 124 // 0x7c f64
              }
              if kak == 5 {
                kbt = 125 // 0x7d f32
              }
              fbIf(kbt) // 0x04 if, value blocktype
              ctrlEnter()
              if kak == 3 {
                if emitExprAsI64(body, e.binRight, fnIx) < 0 { return -1 }
              } else if kak == 4 {
                if emitExprAsF64(body, e.binRight, fnIx) < 0 { return -1 }
              } else if kak == 5 {
                if emitExprAsF32(body, e.binRight, fnIx) < 0 { return -1 }
              } else {
                if emitExpr(body, e.binRight, fnIx) < 0 { return -1 }
              }
              fbElse()                // 0x05 else — present → unbox the stash
              fbLocalGet(coalesceCallSlot)
              fbStructGet(uBoxIdx, 1) // field 1: value (anyref)
              const kvb = vbHeapIdxOfAtom(krest)
              if kvb < 0 {
                return emitFail("emitProgram: union call atom has no value box")
              }
              fbRefCast(kvb)
              fbStructGet(kvb, 0) // the scalar payload
              fbEnd()             // 0x0b end
              ctrlLeave()
              return 0
            }
          }
        }
        // `f() ?? d` over a CALL returning `boolean | null` (the i32 niche): a call
        // cannot be re-read, so STASH the single evaluation in the bool slot, then select
        // `d` on the sentinel 2 — the call analogue of the `boolean | null` ident path.
        if exprNulBool(e.binLeft, fnIx) {
          if emitExpr(body, e.binLeft, fnIx) < 0 {
            return -1 // the niche i32, evaluated ONCE
          }
          fbLocalSet(coalesceCallBoolSlot)
          if emitExpr(body, e.binRight, fnIx) < 0 {
            return -1 // d                                       [val1]
          }
          fbLocalGet(coalesceCallBoolSlot) // x                  [val2]
          fbLocalGet(coalesceCallBoolSlot)
          fbI32Const(2)
          fbI32Bin(70)                     // 0x46 i32.eq → x == 2 (null)            [cond]
          wU8(27)                          // 0x1b select → d if null else x
          return 0
        }
        // `f() ?? d` over a CALL returning `string | null` (kind 16): STASH the nullable
        // ref once (raw, via `pendingRawNullRead`), then a value-typed `if` on
        // `ref.is_null` selects `d` or the recovered non-null string — the call analogue
        // of the `string | null` ident path.
        if exprNullableString(e.binLeft, fnIx) {
          const savedRaw = pendingRawNullRead
          pendingRawNullRead = true
          const tre = emitExpr(body, e.binLeft, fnIx) // the raw nullable ref, ONCE
          pendingRawNullRead = savedRaw
          if tre < 0 { return -1 }
          fbLocalSet(coalesceCallStrSlot)
          fbLocalGet(coalesceCallStrSlot)
          wU8(209)                                    // 0xd1 ref.is_null → 1 if null
          wU8(4)                                      // 0x04 if
          wU8(100)                                    // blocktype: (ref $aTypeIdx) — non-null string result
          wSLEB(aTypeIdx)
          ctrlEnter()
          if emitExpr(body, e.binRight, fnIx) < 0 {
            return -1 // d (a string)
          }
          fbElse()         // 0x05 else
          fbLocalGet(coalesceCallStrSlot)
          fbRefAsNonNull() // 0xd4 recover the non-null string the slot holds
          fbEnd()          // 0x0b end
          ctrlLeave()
          return 0
        }
      }
      // `o.v ?? d` over a VALUE-UNION struct field (`v: i32 | null`, code 16):
      // the field-read dual of the boxed-union name path above — read the box
      // off the field, test its tag for `null`, and select the default or the
      // unboxed single remaining scalar atom. The receiver re-reads in the
      // non-null arm (a name/field chain, like the nullable-struct `?.` path).
      if lhs is Member {
        const msi = structIndexOfExpr(lhs.memObj, fnIx)
        if msi >= 0 {
          let mfi = sFieldIndex(msi, lhs.memProp)
          if mfi >= 0 {
            if sFieldTypeAt(msi, mfi) == 16 {
              const munm = sFieldElemNameAt(msi, mfi)
              if isValueUnionName(munm) && unionHasAtom(munm, "null") {
                const mrest = removeAtomFrom(munm, "null")
                const mak = valueAtomKind(mrest)
                if mak >= 0 && mak != 6 {
                  if mak == 2 {
                    return emitFail(
                      "emitProgram: `??` over a string|null union field is not supported yet",
                    )
                  }
                  if emitExpr(body, lhs.memObj, fnIx) < 0 { return -1 }
                  fbStructGet(sHeapIdx[msi], mfi) // the union box
                  fbStructGet(uBoxIdx, 0)         // field 0: tag
                  fbI32Const(scalarTagOf("null"))
                  fbI32Bin(70)                    // 0x46 i32.eq → null?
                  let mbt = 127                   // 0x7f i32 (boolean shares it)
                  if mak == 3 {
                    mbt = 126 // 0x7e i64
                  }
                  if mak == 4 {
                    mbt = 124 // 0x7c f64
                  }
                  if mak == 5 {
                    mbt = 125 // 0x7d f32
                  }
                  fbIf(mbt) // 0x04 if, value blocktype
                  ctrlEnter()
                  if mak == 3 {
                    if emitExprAsI64(body, e.binRight, fnIx) < 0 { return -1 }
                  } else if mak == 4 {
                    if emitExprAsF64(body, e.binRight, fnIx) < 0 { return -1 }
                  } else if mak == 5 {
                    if emitExprAsF32(body, e.binRight, fnIx) < 0 { return -1 }
                  } else {
                    if emitExpr(body, e.binRight, fnIx) < 0 { return -1 }
                  }
                  fbElse()                // 0x05 else — present → unbox
                  if emitExpr(body, lhs.memObj, fnIx) < 0 { return -1 }
                  fbStructGet(sHeapIdx[msi], mfi)
                  fbStructGet(uBoxIdx, 1) // field 1: value (anyref)
                  const mvb = vbHeapIdxOfAtom(mrest)
                  if mvb < 0 {
                    return emitFail("emitProgram: union field atom has no value box")
                  }
                  fbRefCast(mvb)
                  fbStructGet(mvb, 0) // the scalar payload
                  fbEnd()             // 0x0b end
                  ctrlLeave()
                  return 0
                }
              }
            }
          }
        }
      }
      // The null-safe field read `m[k]?.f ?? d` over a STRUCT-VALUED map is the
      // FUSED form: probe; on a hit read the field off the (non-null) value
      // struct, else push the default. A live entry's value slot is never null,
      // so the `?.` null test coincides with the probe's hit test — no
      // intermediate nullable materializes. Scalar (i32/boolean) fields only (a
      // value-typed `if` blocktype carries them; ref fields would need an
      // interned blocktype functype).
      if lhs is OptMember {
        const omInner = P.nodes[lhs.omObj]
        if omInner is Index {
          if exprMap(omInner.idxArr, fnIx) {
            const omSl = mapShapeOfExpr(omInner.idxArr, fnIx)
            if omSl >= 0 {
              if mvValKind[omSl] != 1 {
                return emitFail("emitProgram: `?.` needs a struct-valued map")
              }
              const omSi = mvValStructIdx[omSl]
              const omFi = sFieldIndex(omSi, lhs.omProp)
              if omFi < 0 {
                return emitFail("emitProgram: `?.` field is not on the map's value struct")
              }
              if sFieldTypeAt(omSi, omFi) != 0 {
                return emitFail(
                  "emitProgram: `?.` over a map read supports only i32/boolean fields",
                )
              }
              if emitMapPrep(body, omInner.idxArr, omInner.idxIndex, fnIx) < 0 {
                return -1
              }
              pushMapScr(body, 5)               // entry
              fbIf(127)                         // if (entry != 0 → hit), i32 blocktype
              pushMapVals(body)
              fbStructGet(cmValsWrap(), 0)      // vals backing
              pushMapScr(body, 5)               // entry
              fbI32Const(1)
              fbI32Bin(107)                     // i32.sub (entry - 1)
              fbArrayGet(cmValsBack())          // (ref null <value struct>)
              fbRefAsNonNull()                  // a live entry's value is non-null
              fbStructGet(sHeapIdx[omSi], omFi) // .f
              fbElse()                          // else
              if emitExpr(body, e.binRight, fnIx) < 0 { return -1 }
              fbEnd()                           // end (if)
              return 0
            }
          }
        }
        // `p?.f ?? d` over a NULLABLE-STRUCT receiver (`p: S | null`, OR a nullable-struct
        // FIELD read `n.next`): null → the default, else the field read off the (non-null)
        // struct. The receiver is a re-readable PLACE (a name, or a member chain of names —
        // an effect-free `struct.get`), re-read in the non-null branch. Scalar fields only
        // (the value-typed `if` blocktype carries them).
        if optRecvReReadable(lhs.omObj) {
          if exprNullableStruct(lhs.omObj, fnIx) {
            const nsi = structIndexOfExpr(lhs.omObj, fnIx)
            if nsi >= 0 {
              const nfi = sFieldIndex(nsi, lhs.omProp)
              if nfi < 0 {
                return emitFail("emitProgram: `?.` field is not on the struct")
              }
              if sFieldTypeAt(nsi, nfi) != 0 {
                return emitFail(
                  "emitProgram: `?.` over a nullable struct supports only i32/boolean fields",
                )
              }
              if emitExpr(body, lhs.omObj, fnIx) < 0 { return -1 }
              wU8(209)  // 0xd1 ref.is_null
              fbIf(127) // 0x04 if, 0x7f i32 blocktype — null → default
              ctrlEnter()
              if emitExpr(body, e.binRight, fnIx) < 0 { return -1 }
              fbElse()  // 0x05 else — present → the field
              if emitExpr(body, lhs.omObj, fnIx) < 0 { return -1 }
              fbStructGet(sHeapIdx[nsi], nfi)
              fbEnd()   // 0x0b end
              ctrlLeave()
              return 0
            }
          }
        }
        // A NESTED optional chain `o?.inner?.v ?? d` (niche nullable links): any
        // null link selects the default; otherwise the chain reads through
        // non-null refs (each `S|null` link recovers `ref.as_non_null`). The
        // links are effect-free places, re-evaluated in the value arm. Scalar
        // (i32/boolean) leaf fields only (the value-typed `if` blocktype).
        const omDeep = P.nodes[unwrapParen(lhs.omObj)]
        if omDeep is OptMember {
          const dsi = optChainStructIdxOf(lhs.omObj, fnIx)
          if dsi >= 0 {
            const dfi = sFieldIndex(dsi, lhs.omProp)
            if dfi >= 0 {
              if sFieldTypeAt(dsi, dfi) != 0 {
                return emitFail("emitProgram: `?.` chain supports only i32/boolean leaf fields")
              }
              if emitOptChainIsNull(body, lhs.omObj, fnIx) < 0 { return -1 }
              fbIf(127) // 0x04 if, i32 result — a null link → default
              ctrlEnter()
              if emitExpr(body, e.binRight, fnIx) < 0 { return -1 }
              fbElse()  // 0x05 else — every link present → the leaf
              if emitOptChainValue(body, lhs.omObj, fnIx) < 0 { return -1 }
              fbStructGet(sHeapIdx[dsi], dfi)
              fbEnd()   // 0x0b end
              ctrlLeave()
              return 0
            }
          }
        }
        // `xs.get(i)?.f ?? d` over a STRUCT-element ref list is the FUSED form:
        // one bounds compare; in range read the field off the (non-null) element,
        // else the default. A live in-range element is never null (pushes store
        // non-null), so the `?.` null test coincides with the bounds test —
        // mirroring the map `m[k]?.f ?? d` path above. Scalar fields only.
        const omGet = P.nodes[unwrapParen(lhs.omObj)]
        if omGet is Call {
          const gCallee = P.nodes[omGet.callFn]
          if gCallee is Member {
            if gCallee.memProp == "get" {
              const gSi = structListPopGetElem(unwrapParen(lhs.omObj), fnIx)
              if gSi >= 0 && rlUsed {
                if omGet.callArgs.length != 1 {
                  return emitFail("emitProgram: .get takes exactly one argument")
                }
                const gFi = sFieldIndex(gSi, lhs.omProp)
                if gFi < 0 {
                  return emitFail("emitProgram: `?.` field is not on the list's element struct")
                }
                if sFieldTypeAt(gSi, gFi) != 0 {
                  return emitFail(
                    "emitProgram: `?.` over a list .get supports only i32/boolean fields",
                  )
                }
                const gRecvN = P.nodes[unwrapParen(gCallee.memObj)]
                let gOkRecv = false
                if gRecvN is Ident { gOkRecv = true }
                if !gOkRecv {
                  return emitFail("emitProgram: .get receiver must be a named list binding")
                }
                const gIdxN = P.nodes[unwrapParen(omGet.callArgs[0])]
                let gOkIdx = false
                if gIdxN is NumLit { gOkIdx = true }
                if gIdxN is Ident { gOkIdx = true }
                if !gOkIdx {
                  return emitFail("emitProgram: .get index must be a literal or a name")
                }
                const gSlot = refListSlotOfExpr(gCallee.memObj, fnIx)
                // cond: idx u< len
                if emitExpr(body, omGet.callArgs[0], fnIx) < 0 { return -1 }
                if emitExpr(body, gCallee.memObj, fnIx) < 0 { return -1 }
                fbStructGet(rlWrapIdx[gSlot], 1) // field 1: len
                fbI32Bin(73)                     // 0x49 i32.lt_u
                fbIf(127)                        // 0x04 if, 0x7f i32 result blocktype
                ctrlEnter()
                if emitExpr(body, gCallee.memObj, fnIx) < 0 { return -1 }
                fbStructGet(rlWrapIdx[gSlot], 0) // field 0: backing
                if emitExpr(body, omGet.callArgs[0], fnIx) < 0 { return -1 }
                fbArrayGet(rlBackIdx[gSlot])     // → (ref null $elem)
                fbRefAsNonNull()                 // a live in-range element is non-null
                fbStructGet(sHeapIdx[gSi], gFi)  // .f
                fbElse()                         // 0x05 else
                if emitExpr(body, e.binRight, fnIx) < 0 { return -1 }
                fbEnd()                          // 0x0b end
                ctrlLeave()
                return 0
              }
            }
          }
        }
      }
      // GENERIC nullable-STRUCT `??`: a `S | null` value — an ident / param binding, a struct FIELD,
      // OR a closure / factory CALL (`arr[i](x) ?? d`) — coalesced with a struct default. Evaluated
      // ONCE: `br_on_non_null` keeps the non-null struct or falls through to the default, so it needs
      // NEITHER a re-eval (the ident / field forms) NOR a per-struct stash slot (the call form) — one
      // path for every source, unlike the `string | null` paths split into re-eval + stash. The
      // closing piece of nullable-struct closures (#655/#656): `structIndexOfExpr` resolves the inner
      // struct (incl. an indexed closure-array / factory call via the checker-type fallback) for the
      // block's result type. (A `string | null` LHS is handled by its own paths above.)
      if exprNullableStruct(e.binLeft, fnIx) {
        const csi = structIndexOfExpr(e.binLeft, fnIx)
        if csi >= 0 && csi < sHeapIdx.length {
          wU8(2)   // 0x02 block
          wU8(100) // blocktype: (ref $struct) — the non-null result
          wSLEB(sHeapIdx[csi])
          ctrlEnter()
          if emitExpr(body, e.binLeft, fnIx) < 0 {
            return -1 // the nullable struct ref, evaluated ONCE
          }
          wU8(214) // 0xd6 br_on_non_null
          wULEB(0) //   non-null → branch to the block end with the (ref $struct)
          // null path: emit the default, seeding an ObjLit default to this struct.
          const savedPsi = pendingStructIdx
          pendingStructIdx = csi
          const dres = emitExpr(body, e.binRight, fnIx)
          pendingStructIdx = savedPsi
          if dres < 0 { return -1 }
          wU8(11) // 0x0b end
          ctrlLeave()
          return 0
        }
      }
      return emitFail("emitProgram: `??` is only supported on a map index get")
    }
    // Short-circuit logical operators lower to a VALUE-TYPED `if` (blocktype 0x7f),
    // an `if` expression that leaves one i32 on the stack — both arms push an i32:
    //   `a && b`  ≡  if (a) { b } else { 0 }   (skip b when a is false → 0)
    //   `a || b`  ≡  if (a) { 1 } else { b }   (skip b when a is true  → 1)
    // The condition `a` is evaluated first, then `if 0x04` with i32 result-type
    // blocktype `0x7f`; the then-branch, `else 0x05`, the else-branch, then `end 0x0b`.
    if e.binOp == "&&" || e.binOp == "||" {
      if emitExpr(body, e.binLeft, fnIx) < 0 {
        return -1 // condition `a`
      }
      fbIf(127) // 0x04 if, 0x7f i32 result-type blocktype (yields an i32)
      if e.binOp == "&&" {
        // then = b, else = 0
        if emitExpr(body, e.binRight, fnIx) < 0 { return -1 }
        fbElse() // 0x05 else
        fbI32Const(0)
      } else {
        // then = 1, else = b
        fbI32Const(1)
        fbElse() // 0x05 else
        if emitExpr(body, e.binRight, fnIx) < 0 { return -1 }
      }
      fbEnd() // 0x0b end
      return 0
    }
    // Structural `==`/`!=` with a still-BOXED value-union operand (either side,
    // or both — equality is symmetric). Checked BEFORE the string-eq routing (a
    // union box compared against a string would otherwise misclassify as a bare
    // string compare) and SKIPS `null` literals — the box-tag null compare below
    // owns `v == null` (the host's `variantTag(info, null)` path).
    if e.binOp == "==" || e.binOp == "!=" {
      const uql = P.nodes[unwrapParen(e.binLeft)]
      const uqr = P.nodes[unwrapParen(e.binRight)]
      let uqNull = false
      if uql is NullLit { uqNull = true }
      if uqr is NullLit { uqNull = true }
      const uqLit = exprIsLitAtom(e.binLeft, fnIx) || exprIsLitAtom(e.binRight, fnIx)
      if !uqNull && !uqLit {
        const uqL = exprUnion(e.binLeft, fnIx)
        const uqR = exprUnion(e.binRight, fnIx)
        if uqL && uqR {
          return emitUnionUnionEq(body, e.binLeft, e.binRight, e.binOp == "!=", fnIx)
        }
        if uqL {
          return emitUnionConcreteEq(body, e.binLeft, e.binRight, e.binOp == "!=", fnIx)
        }
        if uqR {
          return emitUnionConcreteEq(body, e.binRight, e.binLeft, e.binOp == "!=", fnIx)
        }
      }
    }
    // A literal-union ATOM compare (`k == "a"`, `k1 == k2`): both operands are i32 ids. Emit them as atoms
    // (a member StrLit -> its id; a litunion var -> its i32 value) and i32-compare. BEFORE the string-eq
    // path, which would otherwise treat the member literal as a string.
    if e.binOp == "==" || e.binOp == "!=" {
      if exprIsLitAtom(e.binLeft, fnIx) || exprIsLitAtom(e.binRight, fnIx) {
        const savedLU = pendingLitUnion
        pendingLitUnion = 1
        if emitExpr(body, e.binLeft, fnIx) < 0 { return -1 }
        if emitExpr(body, e.binRight, fnIx) < 0 { return -1 }
        pendingLitUnion = savedLU
        fbI32Bin(70) // 0x46 i32.eq
        if e.binOp == "!=" {
          fbI32Eqz() // 0x45 i32.eqz -> `!=`
        }
        return 0
      }
    }
    // G6 string operators (a string is a `(array i32)` of code points): `+` is a NEW
    // concatenated array; `==`/`!=` are ELEMENT-WISE value-equality, NOT ref identity
    // — so they take their own inline lowering BEFORE the i32 `binOpcode` path (which
    // would emit `i32.eq` = ref identity, the WRONG answer for strings). Only string-
    // typed operands route here; i32/other-type `+`/`==`/`!=` are unchanged.
    if exprIsStrConcat(exprIx, fnIx) {
      return emitStrConcat(body, exprIx, fnIx)
    }
    if exprIsStrEq(exprIx, fnIx) { return emitStrEq(body, exprIx, fnIx) }
    if exprIsStrOrder(exprIx, fnIx) { return emitStrOrder(body, exprIx, fnIx) }
    // List `==`/`!=` (length + element value-compare, recursive through nested
    // lists / string elements) and list `+` (concat) — collections-design
    // §VL.4/§VL.6, the host's `listEqFn`/concat lowerings, inlined.
    const lopK = listOpKindOfBin(exprIx, fnIx)
    if lopK >= 0 {
      if e.binOp == "+" {
        if lopK != 0 {
          return emitFail(
            "emitProgram: list concat over this element kind is not supported",
          )
        }
        return emitListConcatI(body, e.binLeft, e.binRight, fnIx)
      }
      if emitExpr(body, e.binLeft, fnIx) < 0 { return -1 }
      if emitExpr(body, e.binRight, fnIx) < 0 { return -1 }
      if lopK == 0 {
        if emitListEqICore(body) < 0 { return -1 }
      } else if lopK == 3 {
        if emitListEqSCore(body) < 0 { return -1 }
      } else {
        const lslot = refListSlotOfExpr(e.binLeft, fnIx)
        const lbase = leqRBaseOfSlot(lslot)
        if lbase < 0 {
          return emitFail("emitProgram: ref-list compare frame not reserved")
        }
        if emitListEqRCore(body, lslot, lbase) < 0 { return -1 }
      }
      if e.binOp == "!=" {
        fbI32Eqz() // 0x45 i32.eqz (`!=` negates value-equality)
      }
      return 0
    }
    // `p == null` / `p != null` over a NULLABLE struct ref: `ref.is_null`
    // (inverted with `eqz` for `!=`) — never the i32 compare.
    if e.binOp == "==" || e.binOp == "!=" {
      const nlhs = P.nodes[e.binLeft]
      const nrhs = P.nodes[e.binRight]
      let nref = -1
      if nrhs is NullLit { nref = e.binLeft }
      if nlhs is NullLit { nref = e.binRight }
      if nref >= 0 {
        // `x == null` over a `boolean|null` NICHE value is a SENTINEL compare
        // (`x == 2`) — the i32 never holds a ref. Checked before the struct path.
        if exprNulBool(nref, fnIx) {
          if emitExpr(body, nref, fnIx) < 0 { return -1 }
          fbI32Const(2)
          if e.binOp == "!=" {
            fbI32Bin(71) // 0x47 i32.ne
          } else {
            fbI32Bin(70) // 0x46 i32.eq
          }
          return 0
        }
        // `<opt-chain> == null` / `!= null` (`o?.y != null`): any null LINK makes
        // the chain's value null (the host's OptionalAccess folds null through),
        // so the compare IS the chain's null test (inverted for `!=`).
        const ncN = P.nodes[unwrapParen(nref)]
        if ncN is OptMember {
          if emitOptChainIsNull(body, nref, fnIx) < 0 { return -1 }
          if e.binOp == "!=" {
            fbI32Eqz() // 0x45 invert: the chain value is present
          }
          return 0
        }
        // `x == null` / `x != null` over a BOXED union (`i32 | null`,
        // `A | B | null`): the box itself is never null — the null VARIANT rides
        // in the TAG — so compare the box tag against the global null tag (the
        // host's `variantTag(info, null)` path), never `ref.is_null`.
        if exprUnion(nref, fnIx) {
          if emitExpr(body, nref, fnIx) < 0 { return -1 }
          fbStructGet(uBoxIdx, 0) // box field 0: tag
          fbI32Const(scalarTagOf("null"))
          if e.binOp == "!=" {
            fbI32Bin(71) // 0x47 i32.ne
          } else {
            fbI32Bin(70) // 0x46 i32.eq
          }
          return 0
        }
        if exprNullableStruct(nref, fnIx) {
          if emitExpr(body, nref, fnIx) < 0 { return -1 }
          wU8(209) // 0xd1 ref.is_null
          if e.binOp == "!=" {
            fbI32Eqz() // invert: non-null
          }
          return 0
        }
        // `c == null` / `c != null` over a NULLABLE function value (`fn | null`, kind 19):
        // the same `ref.is_null` lowering as the nullable struct.
        if exprNulClosure(nref, fnIx) {
          if emitExpr(body, nref, fnIx) < 0 { return -1 }
          wU8(209) // 0xd1 ref.is_null
          if e.binOp == "!=" {
            fbI32Eqz() // invert: non-null
          }
          return 0
        }
        // `xs == null` / `xs != null` over a NULLABLE i32 list (`i32[] | null`,
        // kind 15): the same `ref.is_null` lowering as the nullable struct.
        if exprNullableList(nref, fnIx) {
          if emitExpr(body, nref, fnIx) < 0 { return -1 }
          wU8(209) // 0xd1 ref.is_null
          if e.binOp == "!=" {
            fbI32Eqz() // invert: non-null
          }
          return 0
        }
        // `t == null` / `t != null` over a NULLABLE ref array (`i32[][] | null`, kind 18) — same
        // `ref.is_null` lowering (the `(ref null $innerWrapper)` niche).
        if exprNullableRefArray(nref, fnIx) {
          if emitExpr(body, nref, fnIx) < 0 { return -1 }
          wU8(209) // 0xd1 ref.is_null
          if e.binOp == "!=" {
            fbI32Eqz() // invert: non-null
          }
          return 0
        }
        // `s == null` / `s != null` over a `string | null` (kind 16): the nullable raw
        // array ref — same `ref.is_null` lowering. Checked before the structural string
        // equality below (which would element-compare a non-null string). The receiver
        // is read RAW (`pendingRawNullRead`) so the kind-16 ident keeps its nullable ref
        // instead of being recovered to non-null (which would make `ref.is_null` const 0).
        if exprNullableString(nref, fnIx) {
          const savedRaw = pendingRawNullRead
          pendingRawNullRead = true
          const re = emitExpr(body, nref, fnIx)
          pendingRawNullRead = savedRaw
          if re < 0 { return -1 }
          wU8(209) // 0xd1 ref.is_null
          if e.binOp == "!=" {
            fbI32Eqz() // invert: non-null
          }
          return 0
        }
      }
      // STRUCTURAL struct equality: same-shape operands compare field-wise
      // (`emitStructEq` — scalars native, strings via the eq loop, `i32[]` via a
      // length+element loop, nested structs recursively, function-valued fields
      // by identity via `emitCloEqCore`).
      const eqLsi = structIndexOfExpr(e.binLeft, fnIx)
      const eqRsi = structIndexOfExpr(e.binRight, fnIx)
      if eqLsi >= 0 || eqRsi >= 0 {
        if eqLsi >= 0 && eqLsi == eqRsi {
          return emitStructEq(body, exprIx, fnIx)
        }
        return emitFail("emitProgram: struct equality is not supported yet")
      }
      // Function-value `==`/`!=`: IDENTITY — the same lifted function (the id
      // field) AND the same captured env (`ref.eq`). Mirrors the host (same
      // table index AND same env; null == null envs are equal).
      if exprIsClosure(e.binLeft, fnIx) || exprIsClosure(e.binRight, fnIx) {
        if emitExpr(body, e.binLeft, fnIx) < 0 { return -1 }
        if emitExpr(body, e.binRight, fnIx) < 0 { return -1 }
        if emitCloEqCore(body) < 0 { return -1 }
        if e.binOp == "!=" {
          fbI32Eqz() // 0x45 i32.eqz — negate identity-equality
        }
        return 0
      }
    }
    // Slice 5 — f32 operators. If EITHER operand is f32, emit the f32 instruction
    // variant and coerce the other operand (an i32 or a float LITERAL) to f32 first
    // (`emitExprAsF32`). Covers arithmetic (f32 result) AND comparisons (i32 bool
    // result, COMPARE consumes two f32). Checked BEFORE f64 because a float literal is
    // `exprIsF64` too — so `x + 4.0` with `x: f32` must route here, not to f64. Keyed on
    // operand kind, so an i32-only program never enters it (i32 path stays byte-identical).
    const lF32 = exprIsF32(e.binLeft, fnIx)
    const rF32 = exprIsF32(e.binRight, fnIx)
    // A GENUINE (non-literal) f64 operand makes the op f64 — the f32 side widens (`f32 + f64var`),
    // so route to the f64 slice below instead of demoting the f64 here (which trapped). A float
    // literal still adapts DOWN to the f32 operand, so `f32 + 1.0` stays on the f32 slice.
    if (lF32 || rF32) && !binMixHardF64(e.binLeft, e.binRight, fnIx) {
      const opcF32 = binOpcodeF32(e.binOp)
      if opcF32 >= 0 {
        if emitExprAsF32(body, e.binLeft, fnIx) < 0 { return -1 }
        if emitExprAsF32(body, e.binRight, fnIx) < 0 { return -1 }
        fbI32Bin(opcF32)
        return 0
      }
    }
    // Slice 3 — f64 operators. If EITHER operand is f64, emit the f64 instruction
    // variant and widen the i32 operand (if any) to f64 first (`emitExprAsF64`). Covers
    // arithmetic (f64 result) AND comparisons (i32 bool result, COMPARE consumes two
    // f64). Checked BEFORE i64 since a float operand is never i64. Keyed on operand kind,
    // so an i32-only program never enters it — the i32 path below is byte-identical.
    const lF64 = exprIsF64(e.binLeft, fnIx)
    const rF64 = exprIsF64(e.binRight, fnIx)
    if lF64 || rF64 {
      const opcF = binOpcodeF64(e.binOp)
      if opcF >= 0 {
        if emitExprAsF64(body, e.binLeft, fnIx) < 0 { return -1 }
        if emitExprAsF64(body, e.binRight, fnIx) < 0 { return -1 }
        fbI32Bin(opcF)
        return 0
      }
    }
    // Slice 2 — i64 operators. If EITHER operand is i64, emit the i64 instruction
    // variant and widen the i32 operand (if any) to i64 first (`emitExprAsI64`). This
    // covers arithmetic/bitwise/shift (i64 result) AND comparisons (i32 bool result,
    // but the COMPARE consumes two i64). The whole branch is keyed on operand kind, so
    // an i32-only program never enters it — the i32 path below is byte-identical.
    const lI64 = exprIsI64(e.binLeft, fnIx)
    const rI64 = exprIsI64(e.binRight, fnIx)
    if lI64 || rI64 {
      const opc64 = binOpcodeI64(e.binOp)
      if opc64 >= 0 {
        if emitExprAsI64(body, e.binLeft, fnIx) < 0 { return -1 }
        if emitExprAsI64(body, e.binRight, fnIx) < 0 { return -1 }
        fbI32Bin(opc64)
        return 0
      }
    }
    const opcode = binOpcode(e.binOp)
    if opcode < 0 {
      return emitFail("emitProgram: unsupported binary operator")
    }
    // Operands first (left then right), then the operator — wasm's stack order.
    if emitExpr(body, e.binLeft, fnIx) < 0 { return -1 }
    if emitExpr(body, e.binRight, fnIx) < 0 { return -1 }
    fbI32Bin(opcode)
    return 0
  }
  if e is FuncDecl {
    // An anonymous `function(...)` literal in value position (it was lifted to a
    // top-level function by `collectFns`, keeping its name). Construct its closure value.
    let fe = fnStmtsPosOf(exprIx)
    if fe >= 0 { return emitClosureValue(body, fe, fnIx) }
    return emitFail("emitProgram: function literal not lifted")
  }
  if e is IfStmt {
    // An IF-EXPRESSION in value position (`if c then 7 else 9` — the parser wraps
    // each arm as a one-statement Block; an `else if` chain nests an IfStmt in the
    // else slot). Lowered as `if (result i32)` over the arm VALUES.
    return emitIfExpr(body, exprIx, fnIx)
  }
  emitFail("emitProgram: unsupported expression in return")
}

// Lower an if-EXPRESSION (`if c then a else b` in value position) onto `body`:
// cond, `if (result <kind>)`, the then-arm VALUE, `else`, the else-arm VALUE (an
// `else if` chain recurses), `end`. Each arm applies the same condition narrowing
// the statement form does. The blocktype is the SCALAR rep the branch-join produced —
// i32 (127, the default), i64 (126), f32 (125), or f64 (124) — all single-byte
// valtypes; both arms are emitted COERCED to that rep so a mixed `then 1 else 2.5`
// widens its i32 arm to f64. A REF-typed join (string / struct / array — NOT a value
// union or concrete variant, which `emitUnionIfValue`/`emitVariantIfValue` already
// handle at their coerce sites) routes to `emitIfExprRef`, which writes the multi-byte
// `(ref $ht)` blocktype via `fbValtype`. A missing else / non-value arm fails loudly —
// the checker already proved both arms exist and agree.
function emitIfExpr(body: i32[], ifIx: i32, fnIx: i32) {
  const rk = ifExprRefKind(ifIx, fnIx)
  if rk >= 0 {
    return emitIfExprRef(body, ifIx, fnIx, rk, ifExprRefSlot(ifIx, fnIx, rk))
  }
  emitIfExprAs(body, ifIx, fnIx, ifExprValtype(ifIx, fnIx))
}

// The single tail-value expression of an if-expression's THEN arm (the parser wraps
// `then <expr>` as a one-statement Block), or -1. The arms share the checker's join
// type, so the then arm's rep classifies the whole if-expression.
function ifThenValueIx(ifIx: i32) {
  const s = P.nodes[ifIx]
  if s is IfStmt {
    const b = P.nodes[s.ifThen]
    if b is Block {
      const stmts = b.blkStmts
      if stmts.length == 1 { return stmts[0] }
    }
  }
  -1
}

// The `fbValtype` KIND of a REF-typed if-expression join — string (3), string-list (7),
// f64-list (12), ref-list (5), i32-list (2), or struct (1) — classified from the THEN
// arm's tail value. -1 for a numeric join (the single-byte path) and for a value-union /
// concrete-variant join (handled by `emitUnionIfValue` / `emitVariantIfValue` upstream).
// The array predicates run BEFORE the i32-list `exprArray` (which would also claim a
// string/ref/f64 list via its typed-IR fast path).
function ifExprRefKind(ifIx: i32, fnIx: i32) {
  const tv = ifThenValueIx(ifIx)
  if tv < 0 { return -1 }
  // A CLOSURE join (`if c then (x) => x + 1 else (x) => x - 1`) — kind 14, `(ref $cloStruct)`.
  // Checked FIRST: a bare lambda arm is a function value, not a string/array/struct. Each arm
  // emits via `emitClosureValue` (the default `emitRefIfArm` path), and the binding/return
  // classifies as a closure (`exprIsClosure` / `fnReturnsClosure`).
  if exprIsClosure(tv, fnIx) { return 14 }
  if exprString(tv, fnIx) { return 3 }
  if exprStringArray(tv, fnIx) { return 7 }
  if exprF64Array(tv, fnIx) { return 12 }
  if exprRefArray(tv, fnIx) { return 5 }
  if exprArray(tv, fnIx) { return 2 }
  if structIndexOfExpr(tv, fnIx) >= 0 { return 1 }
  // An object LITERAL arm in a struct-typed CONTEXT (return / binding seeds
  // `pendingStructIdx`) — it has no self-derivable struct index.
  const tn = P.nodes[tv]
  if tn is ObjLit {
    if pendingStructIdx >= 0 { return 1 }
  }
  // A NULLABLE-struct join whose THEN arm is `null` (its rep doesn't classify) — the checker typed the
  // whole if `S | null`. Return the struct kind so the nullable blocktype + struct/null arms lower; the
  // struct index resolves from the checker's inner struct in `ifExprRefSlot`. (The null-in-ELSE case is
  // already caught above via the THEN arm's struct rep.)
  if nodeTyIsNullableStruct(ifIx) { return 1 }
  -1
}

// The `fbValtype` SLOT (second arg) for a REF-typed if-expression join of `kind`: the
// struct table index (kind 1) or the ref-list wrapper slot (kind 5); the other ref kinds
// (string/string-list/f64-list/i32-list) ignore the slot. Prefers the pending context
// seed (a struct/list RETURN or binding) over the then-arm's own derivation.
function ifExprRefSlot(ifIx: i32, fnIx: i32, kind: i32) {
  const tv = ifThenValueIx(ifIx)
  if kind == 1 {
    const si = structIndexOfExpr(tv, fnIx)
    if si >= 0 { return si }
    if pendingStructIdx >= 0 { return pendingStructIdx }
    // THEN arm is `null` with no binding seed — resolve the struct from the checker's nullable join
    // type (`P | null` → its inner `P`), so the arm rep + nullable blocktype find the layout.
    const inn = nodeNulStructInnerName(ifIx)
    if inn != "" { return structIndexOfTypeName(inn) }
    return pendingStructIdx
  }
  if kind == 5 {
    if pendingListKind == 5 { return pendingListSlot }
    return refListSlotOfExpr(tv, fnIx)
  }
  -1
}

// Lower a REF-typed if-expression join (string / struct / array) as a value-typed `if`
// with the multi-byte `(ref $ht)` blocktype (`fbValtype`), each arm emitted in that rep.
// Mirrors `emitIfExprAs` (narrowing save/restore, `else if` recursion) but the blocktype
// is an interned reftype rather than a single numeric byte. The arm emitter re-seeds the
// per-arm construction context so an `ObjLit` / list-literal arm builds the right shape.
function emitIfExprRef(
  body: i32[],
  ifIx: i32,
  fnIx: i32,
  kind: i32,
  slot: i32,
) {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    if s.ifElse < 0 {
      return emitFail("emitProgram: if-expression requires an else arm")
    }
    if emitExpr(body, s.ifCond, fnIx) < 0 { return -1 }
    wU8(4) // 0x04 if
    // A struct join the checker typed `S | null` (one arm is `null` → `(ref null $S)`, the other a
    // `(ref $S)`) needs a NULLABLE blocktype, else the null arm's `(ref null $S)` mismatches the
    // non-null `(ref $S)` result. `nodeTyIsNullableStruct` reads the checker's recorded join type — the
    // generic signal — rather than re-deriving from the arms. (A non-nullable struct join, or a binding
    // annotated `S | null` whose arms are both non-null, stays non-null: the value widens on store.)
    if kind == 1 && nodeTyIsNullableStruct(ifIx) {
      fbValtypeNullable(kind, slot) // `(ref null $S)` result blocktype
    } else {
      fbValtype(kind, slot) // ref result blocktype `(ref $ht)`
    }
    const savedTop = narrowTop
    const narrowed = setNarrowFromCond(s.ifCond, fnIx)
    const rcT = emitRefIfArm(body, s.ifThen, fnIx, kind, slot)
    if narrowed { restoreNarrow(savedTop) }
    if rcT < 0 { return -1 }
    fbElse() // 0x05 else
    const savedElseTop = narrowTop
    const narrowedElse = setNarrowFromCondElse(s.ifCond, fnIx)
    const els = P.nodes[s.ifElse]
    let rc = 0
    if els is IfStmt {
      rc = emitIfExprRef(body, s.ifElse, fnIx, kind, slot)
    } else {
      rc = emitRefIfArm(body, s.ifElse, fnIx, kind, slot)
    }
    if narrowedElse { restoreNarrow(savedElseTop) }
    if rc < 0 { return -1 }
    fbEnd() // 0x0b end
    return 0
  }
  emitFail("emitProgram: expected an if expression")
}

// True if the single statement `stmtIx` is usable as an if-expression ARM value: a plain tail value
// (`stmtIsTailValue`), OR a NESTED if-EXPRESSION (an `IfStmt` with an else + value arms, emitted via
// `emitExpr` → `emitIfExpr`). Kept SEPARATE from `stmtIsTailValue` so the function-tail nullable path —
// which gates on `stmtIsTailValue` and routes an else-ful nullable tail through `emitIfTail` — is
// untouched; only the if-expression arm emitters opt into nesting.
function ifArmIsValue(stmtIx: i32, fnIx: i32) {
  if stmtIsTailValue(stmtIx, fnIx) { return true }
  const s = P.nodes[stmtIx]
  if s is IfStmt { return ifTailIsValue(stmtIx, fnIx) }
  false
}

// One arm of a REF-typed if-expression: its single tail-value statement, emitted in the
// join rep. Re-seeds `pendingStructIdx` (struct arms) / `pendingListKind`+`pendingListSlot`
// (ref-list arms) first, since the previous arm's emit consumed the pending seed.
function emitRefIfArm(
  body: i32[],
  blockIx: i32,
  fnIx: i32,
  kind: i32,
  slot: i32,
) {
  let b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    if stmts.length == 1 {
      if ifArmIsValue(stmts[0], fnIx) {
        if kind == 1 { pendingStructIdx = slot }
        if kind == 5 {
          pendingListKind = 5
          pendingListSlot = slot
        }
        return emitExpr(body, stmts[0], fnIx)
      }
    }
    return emitFail("emitProgram: if-expression arm is not a single value")
  }
  emitFail("emitProgram: if-expression arm is not a block")
}

// The single-byte blocktype valtype for a value-position if-expression: the widest
// numeric rep across its arms (checked f64 → f32 → i64, else the i32 default).
function ifExprValtype(ifIx: i32, fnIx: i32) {
  if exprIsF64(ifIx, fnIx) {
    return 124 // 0x7c f64
  }
  if exprIsF32(ifIx, fnIx) {
    return 125 // 0x7d f32
  }
  if exprIsI64(ifIx, fnIx) {
    return 126 // 0x7e i64
  }
  127 // 0x7f i32
}

// Lower the if-expression at `ifIx` with a known blocktype byte `kind`, threading it
// through the `else if` recursion so the whole chain shares one result rep.
function emitIfExprAs(body: i32[], ifIx: i32, fnIx: i32, kind: i32) {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    if s.ifElse < 0 {
      return emitFail("emitProgram: if-expression requires an else arm")
    }
    if emitExpr(body, s.ifCond, fnIx) < 0 { return -1 }
    fbIf(kind) // 0x04 if, <kind> result blocktype
    const savedTop = narrowTop
    const narrowed = setNarrowFromCond(s.ifCond, fnIx)
    const rcT = emitBlockValueAs(body, s.ifThen, fnIx, kind)
    if narrowed { restoreNarrow(savedTop) }
    if rcT < 0 { return -1 }
    fbElse()   // 0x05 else
    const savedElseTop = narrowTop
    const narrowedElse = setNarrowFromCondElse(s.ifCond, fnIx)
    const els = P.nodes[s.ifElse]
    let rc = 0
    if els is IfStmt {
      rc = emitIfExprAs(body, s.ifElse, fnIx, kind)
    } else {
      rc = emitBlockValueAs(body, s.ifElse, fnIx, kind)
    }
    if narrowedElse { restoreNarrow(savedElseTop) }
    if rc < 0 { return -1 }
    fbEnd() // 0x0b end
    return 0
  }
  emitFail("emitProgram: expected an if expression")
}

// The VALUE of an if-expression arm (the parser wraps `then <expr>` as a Block of
// ONE statement): its single tail-value statement, emitted as an expression COERCED to
// the if-expression's result rep `kind` (so an i32-literal arm widens into an f64/f32/
// i64 join). The i32 default emits the value as-is.
function emitBlockValueAs(body: i32[], blockIx: i32, fnIx: i32, kind: i32) {
  let b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    if stmts.length == 1 {
      if ifArmIsValue(stmts[0], fnIx) {
        if kind == 124 { return emitExprAsF64(body, stmts[0], fnIx) }
        if kind == 125 { return emitExprAsF32(body, stmts[0], fnIx) }
        if kind == 126 { return emitExprAsI64(body, stmts[0], fnIx) }
        return emitExpr(body, stmts[0], fnIx)
      }
    }
    return emitFail("emitProgram: if-expression arm is not a single value")
  }
  emitFail("emitProgram: if-expression arm is not a block")
}

// ── nullable / value-union if-EXPRESSION in BINDING-INIT position ──────────────
// `const x: i32 | null = if c then 5 else null` (and `else if` chains) lowers as a
// VOID `if` whose every arm writes the binding's OWN local — so no value-typed-if
// blocktype (an interned functype) and no scratch slot are needed: the destination
// local IS the stash. Each arm emits its value in the binding's nullable rep (`rep`:
// 0 the value-union box, 1 a `string | null` ref) then `local.set`s it; a bare `null`
// arm / an else-less false path writes the rep's null. This is the binding-position
// counterpart of the return-tail `emitIfTail`/`emitNullForRet` lowering (#484/#489).
// A `boolean | null` local is not yet a supported rep at all (a separate pre-existing
// gap), so it is not handled here.

// Emit ONE arm value (`valIx`) in the binding's nullable rep, then `local.set idx`.
function emitNulArmToLocal(
  body: i32[],
  valIx: i32,
  idx: i32,
  rep: i32,
  unionName: string,
  fnIx: i32,
) {
  if valIx < 0 {
    return emitFail("emitProgram: if-expression arm is not a value")
  }
  if rep == 0 {
    // The binding's local is the union BOX `(ref $uBox)`, so a CONCRETE-VARIANT arm (`x`, a
    // kind-8 `(ref $variant)` — `let a: Animal = if c then x else y`) must be BOXED to match,
    // exactly as in `emitUnionIfArm` / a variant return. `emitUnionBoxArg` boxes a variant ref
    // and defers every other shape (object literal, passthrough union, scalar) to
    // `emitUnionCoerce` — plain `emitUnionCoerce` stored the raw variant ref (invalid wasm).
    if emitUnionBoxArg(body, unionName, valIx, fnIx) < 0 { return -1 }
  } else if rep == 1 {
    // rep 1: a `string | null` arm — a non-null string passes through, a bare `null`
    // lowers as `ref.null $aTypeIdx` (`pendingNulString`).
    const saved = pendingNulString
    pendingNulString = true
    let rc = emitExpr(body, valIx, fnIx)
    pendingNulString = saved
    if rc < 0 { return -1 }
  } else {
    // rep 2: a `boolean | null` arm — a non-null boolean rides its i32 0/1; a bare
    // `null` lowers as the niche sentinel 2 (`pendingNulBool`).
    const saved = pendingNulBool
    pendingNulBool = true
    let rc = emitExpr(body, valIx, fnIx)
    pendingNulBool = saved
    if rc < 0 { return -1 }
  }
  fbLocalSet(idx)
  0
}

// Emit the rep's NULL (the else-less false path / a synthesized null arm), then
// `local.set idx`: the value-union null-tagged box (rep 0), or `ref.null $aTypeIdx`
// for a `string | null` (rep 1).
function emitNulNullToLocal(body: i32[], idx: i32, rep: i32) {
  if rep == 0 {
    fbI32Const(scalarTagOf("null"))
    fbRefNullNone() // the payload slot is unread under the null tag
    fbStructNew(uBoxIdx)
  } else if rep == 1 {
    wU8(208) // 0xd0 ref.null
    wSLEB(aTypeIdx)
  } else {
    // rep 2: a `boolean | null` else-less / explicit-null path — the niche sentinel 2.
    fbI32Const(2)
  }
  fbLocalSet(idx)
  0
}

// Lower a nullable/value-union if-EXPRESSION binding init at `ifIx` into local `idx`:
// a void `if` whose then-arm writes the binding (narrowed by the condition), and whose
// else writes the else-arm value, a nested `else if` (recurse), or — when there is no
// else — the rep's null.
function emitNullableIfBinding(
  body: i32[],
  ifIx: i32,
  idx: i32,
  rep: i32,
  unionName: string,
  fnIx: i32,
) {
  let s = P.nodes[unwrapParen(ifIx)]
  if s is IfStmt {
    if emitExpr(body, s.ifCond, fnIx) < 0 { return -1 }
    fbIf(64) // 0x04 if, 0x40 void blocktype
    const savedTop = narrowTop
    const narrowed = setNarrowFromCond(s.ifCond, fnIx)
    let rc = emitNulArmToLocal(
      body,
      ifArmValueExpr(s.ifThen),
      idx,
      rep,
      unionName,
      fnIx,
    )
    if narrowed { restoreNarrow(savedTop) }
    if rc < 0 { return -1 }
    fbElse() // 0x05 else
    const savedElseTop = narrowTop
    const narrowedElse = setNarrowFromCondElse(s.ifCond, fnIx)
    let erc = 0
    if s.ifElse < 0 {
      erc = emitNulNullToLocal(body, idx, rep)
    } else {
      const els = P.nodes[s.ifElse]
      if els is IfStmt {
        erc = emitNullableIfBinding(body, s.ifElse, idx, rep, unionName, fnIx)
      } else {
        erc = emitNulArmToLocal(
          body,
          ifArmValueExpr(s.ifElse),
          idx,
          rep,
          unionName,
          fnIx,
        )
      }
    }
    if narrowedElse { restoreNarrow(savedElseTop) }
    if erc < 0 { return -1 }
    fbEnd() // 0x0b end
    return 0
  }
  emitFail("emitProgram: expected an if expression")
}

// Emit the expression at `exprIx` as an i64 value (Slice 2). If it already yields
// i64 (`exprIsI64`) it is emitted as-is. Otherwise it is an i32 expression flowing
// into an i64 op: a bare integer LITERAL is lowered directly as `i64.const` (set
// `pendingI64` so the NumLit path takes the 64-bit form), and any other i32 source
// is emitted then sign-extended with `i64.extend_i32_s` (0xac). This is the i32→i64
// widening for mixed-width operands.
function emitExprAsI64(body: i32[], exprIx: i32, fnIx: i32) {
  if exprIsI64(exprIx, fnIx) { return emitExpr(body, exprIx, fnIx) }
  // Peel parens to find a bare literal we can emit directly as i64.const.
  const inner = unwrapParen(exprIx)
  const innerNode = P.nodes[inner]
  if innerNode is NumLit {
    const saved = pendingI64
    pendingI64 = true
    let r = emitExpr(body, inner, fnIx)
    pendingI64 = saved
    return r
  }
  // Non-literal i32: evaluate, then sign-extend to i64.
  if emitExpr(body, exprIx, fnIx) < 0 { return -1 }
  fbI64ExtendI32S()
  0
}

// Emit the expression at `exprIx` as an f64 value. If it already yields f64
// (`exprIsF64`) it is emitted as-is. Otherwise a narrower numeric source widens to f64
// at the boundary (binding / argument / return / mixed-operand):
//   f32 → f64.promote_f32 (0xbb)   i64 → f64.convert_i64_s (0xb9)
//   i32 → f64.convert_i32_s (0xb7) [also covers an integer literal]
// i32→f64 and f32→f64 are the LOSSLESS variable widenings the checker permits.
// i64→f64 (lossy above 2^53) is no longer a permitted variable widening — the
// checker rejects it — so the i64 path here only handles an i64 LITERAL coercing
// into an f64 slot (re-encoded by value). (Slice 3 + Slice 5 widening.)
function emitExprAsF64(body: i32[], exprIx: i32, fnIx: i32) {
  // An f32 source promotes losslessly to f64. Checked BEFORE the f64 fast-path: an arithmetic
  // expression with an f32 operand (`x + 1.0`, `x: f32`) EMITS as f32 — `emitExpr`'s f32 slice fires
  // because a float literal re-encodes to the f32 operand — yet `exprIsF64` ALSO claims it via that
  // literal. Without this the f64 fast-path emits f32 into an f64 slot and traps. (A pure-f64
  // expression is not `exprIsF32`, so it still takes the byte-identical fast-path below.)
  if exprIsF32(exprIx, fnIx) {
    if emitExpr(body, exprIx, fnIx) < 0 { return -1 }
    fbF64PromoteF32()
    return 0
  }
  if exprIsF64(exprIx, fnIx) { return emitExpr(body, exprIx, fnIx) }
  // An i64 source converts (signed) to f64.
  if exprIsI64(exprIx, fnIx) {
    if emitExpr(body, exprIx, fnIx) < 0 { return -1 }
    fbF64ConvertI64S()
    return 0
  }
  // Otherwise an i32 expression (or integer literal): convert (signed) to f64.
  if emitExpr(body, exprIx, fnIx) < 0 { return -1 }
  fbF64ConvertI32S()
  0
}

// True if the DECLARED LOCAL `name` is an i64 slot (kind 10 in the local registry).
function declaredI64(name: string) { declaredKind(name) == 10 }

// True if the module GLOBAL `name` is an i64 cell.
function globalIsI64(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsI64(li, -1)
}

// The unboxed scalar atom KIND of a value-union null-coalesce `lhs ?? d` (where `lhs`
// is an ident or call yielding `T | null` with ONE non-null scalar atom): the result
// of `??` is that atom, so `print`-routing + numeric context coercion classify it by
// the atom (`i64`/`f64`/`f32` need their own import / convert). -1 when the expression
// is not such a `??`, or the union keeps ≥2 non-null atoms (still a box, not a scalar).
function coalesceAtomKind(exprIx: i32, fnIx: i32) {
  const e = P.nodes[unwrapParen(exprIx)]
  if e is BinExpr {
    if e.binOp == "??" {
      const nm = unionNameOfExpr(e.binLeft, fnIx)
      if nm != "" {
        if isValueUnionName(nm) && unionHasAtom(nm, "null") {
          const k = valueAtomKind(removeAtomFrom(nm, "null"))
          if k >= 0 && k != 6 { return k }
        }
      }
    }
  }
  -1
}

// True if evaluating the expression at `exprIx` yields an i64 — a reference to an
// i64 param/local/global, or a parenthesized such. Drives the `print` import choice
// (`__print_i64__`, import 4). Arithmetic/calls returning i64 are Slice 2; here only
// the direct-reference forms (the Slice-1 `print(x)` shape) classify as i64.
function exprIsI64(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  if tyKindOf(nodeTyIxOf(exprIx)) == 10 {
    return true // typed-IR fast path (see exprIsF64)
  }
  if coalesceAtomKind(exprIx, fnIx) == 3 { return true }
  // `m[k] ?? d` over an i64-VALUED map yields an i64 (the value type).
  const cmi = coalesceMvSlot(exprIx, fnIx)
  if cmi >= 0 {
    if mvValKind[cmi] == 10 { return true }
  }
  const e = P.nodes[exprIx]
  if e is Paren { return exprIsI64(e.parInner, fnIx) }
  // A field read `s.x` whose struct field is an i64 slot (code 23) yields an i64.
  if e is Member { return memFieldTypeCode(exprIx, fnIx) == 23 }
  // A bare `m[k]` read over an i64-valued map yields an i64.
  if e is Index {
    // An indexed read of an i64 list (`xs[i]` over `i64[]`) is an i64 — the syntactic dual of
    // `exprIsF64`'s Index case. Needed for a SYNTHETIC `c[0]` (e.g. a captured-mutation box) that
    // carries no checker-recorded type for the typed-IR fast path above.
    if exprI64Array(e.idxArr, fnIx) { return true }
    const mri = mapReadMvSlot(exprIx, fnIx)
    if mri >= 0 {
      if mvValKind[mri] == 10 { return true }
    }
  }
  // A bare INTEGER literal past the i32 range is typed i64 by the checker (the
  // host's `defaultIntegerType` magnitude rule) and lowers as `i64.const`, so it
  // classifies as i64 here too (a float `.` literal is f64, never i64).
  if e is NumLit {
    if numTextIsFloat(e.numText) { return false }
    return !numLexFitsI32(e.numText)
  }
  if e is Ident {
    // A VALUE-union ident classifies by its narrowed atom (the read unboxes to
    // that rep); an un-narrowed union ident is the box, never a scalar.
    const uk = unionIdentReadKind(exprIx, fnIx)
    if uk != -3 { return uk == 3 }
    if paramIsI64(fnIx, e.identName) { return true }
    if declaredI64(e.identName) { return true }
    return globalIsI64(e.identName)
  }
  // Slice 2: an ARITHMETIC / BITWISE / SHIFT op yields i64 when EITHER operand is i64
  // (the i32 side widens). COMPARISONS (`==` `!=` `<` `>` `<=` `>=`) and logical
  // connectives produce an i32 BOOL even over i64 operands, so they are NOT i64.
  if e is BinExpr {
    const op = e.binOp
    if (
      op == "+" ||
      op == "-" ||
      op == "*" ||
      op == "/" ||
      op == "%" ||
      op == "&" ||
      op == "|" ||
      op == "^" ||
      op == "<<" ||
      op == ">>" ||
      op == ">>>"
    ) {
      if exprIsI64(e.binLeft, fnIx) { return true }
      return exprIsI64(e.binRight, fnIx)
    }
    return false
  }
  // Unary negation `-x` / bitwise NOT `~x` preserve the operand's i64-ness. (`!`
  // is a bool, never i64; `p+`/`p-` ride their operand but are statement-level.)
  if e is Unary {
    if e.unOp == "-" || e.unOp == "~" {
      // EXCEPT `-2147483648`: the host folds the sign into the literal before
      // defaulting, so a NEGATED magnitude-2^31 literal is i32 (it sits at
      // I32_MIN) even though the bare operand literal classifies i64 above.
      if e.unOp == "-" {
        const negInner = P.nodes[unwrapParen(e.unArg)]
        if negInner is NumLit {
          if !numTextIsFloat(negInner.numText) {
            if numLexIs2Pow31(negInner.numText) { return false }
          }
        }
      }
      return exprIsI64(e.unArg, fnIx)
    }
    return false
  }
  // A call to an i64-returning function yields i64.
  if e is Call {
    // An INDEXED closure call `fs[i](x)` whose element signature returns i64.
    if cloArrCallRetKind(exprIx, fnIx) == 10 { return true }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const target = fnIndexOf(callee.identName)
      if target >= 0 { return fRetI64[target] == 1 }
      // An i64-returning function VALUE (a binding / `(…) => i64` param callee).
      return calleeReturnsI64(callee.identName, fnIx)
    }
    // An i64-returning FIELD-closure call (`o.f(x)` over an `(…) => i64` field).
    if callee is Member {
      const ffe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
      if ffe >= 0 { return fRetI64[ffe] == 1 }
    }
    return false
  }
  // A value-position if-EXPRESSION is i64 when either arm's value is i64.
  if e is IfStmt { return ifExprArmIsKind(exprIx, fnIx, 126) }
  false
}

// True if the DECLARED LOCAL `name` is an f32 slot (kind 13 in the local registry).
function declaredF32(name: string) { declaredKind(name) == 13 }

// True if the UN-annotated `LetDecl` at `letIx` should INFER an f32 slot — its initializer
// already yields an f32 (`exprIsF32`: an f32 field/index/param/local read, an f32-returning
// call, or f32 arithmetic). f32 is the checker's weak spot (no f32 typed-IR), so `letIsF32`
// is annotation-only; without this an un-annotated `let y = s.x` over an f32 source would
// default to an i32 slot and store an f32 into it (invalid wasm). This is the f32 analogue of
// the init fallback `letIsF64`/`letIsI64` already carry. A BARE float literal init stays f64
// (it is not `exprIsF32`), so `let y = 1.5` is unaffected.
function letInfersF32(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 { return false }
    if d.letInit < 0 { return false }
    return exprIsF32(d.letInit, fnIx)
  }
  false
}

// True if the module GLOBAL `name` is an f32 cell. (Slice 5.)
function globalIsF32(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsF32(li)
}

// True if evaluating the expression at `exprIx` yields an f32: a reference to an f32
// param/local/global, f32 arithmetic (either operand f32 — the other side, an i32 or a
// float LITERAL, coerces to f32), or unary `-`/parens over such. A BARE float literal is
// NOT f32 (it defaults f64 — `exprIsF64`); it becomes f32 only as the operand of an f32
// op or the init of an `: f32` binding. Checked BEFORE `exprIsF64` at every dispatch so
// a mixed f32/float-literal expression routes to the f32 instructions. (Slice 5.)
// Is the expression at `exprIx` (peeling parens) a FLOAT number literal (`2.5`)? A float literal is
// polymorphic across the float types — it adapts DOWN to an f32 operand — so it does NOT force f64
// the way a genuine f64 reference/result/variable does.
function exprIsFloatLit(exprIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[unwrapParen(exprIx)]
  if e is NumLit { return numTextIsFloat(e.numText) }
  false
}

// Does a binary op over `leftIx`/`rightIx` have a GENUINE (non-literal) f64 operand? Such an operand
// makes the whole op f64 — an f32 / i32 / float-literal side widens to it (`f32var + f64var` is f64,
// computed in f64). A float LITERAL is NOT genuine f64 (it adapts down to an f32 operand), so it does
// not trigger this. Drives both the `exprIsF32` classification and the f32 emit slice: when true,
// the op is f64 (the f64 slice), not f32 — without which the f32 slice demoted the f64 and trapped.
function binMixHardF64(leftIx: i32, rightIx: i32, fnIx: i32) {
  if exprIsF64(leftIx, fnIx) {
    if !exprIsFloatLit(leftIx) { return true }
  }
  if exprIsF64(rightIx, fnIx) {
    if !exprIsFloatLit(rightIx) { return true }
  }
  false
}

function exprIsF32(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  if tyKindOf(nodeTyIxOf(exprIx)) == 13 {
    return true // typed-IR fast path (see exprIsF64)
  }
  if coalesceAtomKind(exprIx, fnIx) == 5 { return true }
  const e = P.nodes[exprIx]
  if e is Paren { return exprIsF32(e.parInner, fnIx) }
  // An index read `xs[i]` over an `f32[]` yields an f32 element.
  if e is Index {
    if exprF32Array(e.idxArr, fnIx) { return true }
  }
  // A field read `s.x` whose struct field is an f32 slot (code 24) yields an f32.
  if e is Member { return memFieldTypeCode(exprIx, fnIx) == 24 }
  if e is Ident {
    // A VALUE-union ident classifies by its narrowed atom (see exprIsI64).
    const uk = unionIdentReadKind(exprIx, fnIx)
    if uk != -3 { return uk == 5 }
    if paramIsF32(fnIx, e.identName) { return true }
    if declaredF32(e.identName) { return true }
    return globalIsF32(e.identName)
  }
  // Arithmetic yields f32 when EITHER operand is f32. Comparisons / logical connectives
  // produce an i32 BOOL even over f32 operands, so they are NOT f32.
  if e is BinExpr {
    const op = e.binOp
    if op == "+" || op == "-" || op == "*" || op == "/" {
      // f32 arithmetic yields f32 only when NO operand is a genuine f64 — a genuine f64 side makes
      // the op f64 (the f32 side widens). A float literal does not count (it adapts down to f32).
      if binMixHardF64(e.binLeft, e.binRight, fnIx) { return false }
      if exprIsF32(e.binLeft, fnIx) { return true }
      return exprIsF32(e.binRight, fnIx)
    }
    return false
  }
  if e is Unary {
    if e.unOp == "-" { return exprIsF32(e.unArg, fnIx) }
    return false
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const target = fnIndexOf(callee.identName)
      if target >= 0 { return fRetF32[target] == 1 }
    }
    return false
  }
  // A value-position if-EXPRESSION is f32 when either arm's value is f32.
  if e is IfStmt { return ifExprArmIsKind(exprIx, fnIx, 125) }
  false
}

// True if a value-position if-EXPRESSION (`ifIx`) carries the numeric rep named by the
// blocktype byte `kind` (124 f64 / 125 f32 / 126 i64): either arm's tail value is of
// that kind, recursing through an `else if` chain in the else slot. Drives both the
// whole-expression classification (`exprIsF64`/`exprIsF32`/`exprIsI64` above, so print
// routing and context coercion see the joined type) and the blocktype `emitIfExpr`
// picks. A bare i32-arm if-expression matches none of these and stays the i32 default.
function ifExprArmIsKind(ifIx: i32, fnIx: i32, kind: i32) {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    if s.ifElse < 0 { return false }
    const thenV = ifArmValueExpr(s.ifThen)
    if armValueIsKind(thenV, fnIx, kind) { return true }
    const els = P.nodes[s.ifElse]
    if els is IfStmt { return ifExprArmIsKind(s.ifElse, fnIx, kind) }
    return armValueIsKind(ifArmValueExpr(s.ifElse), fnIx, kind)
  }
  false
}

// Classify a single arm-value expression against a blocktype `kind` byte.
function armValueIsKind(exprIx: i32, fnIx: i32, kind: i32) {
  if kind == 124 { return exprIsF64(exprIx, fnIx) }
  if kind == 125 { return exprIsF32(exprIx, fnIx) }
  if kind == 126 { return exprIsI64(exprIx, fnIx) }
  false
}

// Emit the expression at `exprIx` as an f32 value (Slice 5). If it already yields f32
// (`exprIsF32`) it is emitted as-is. A bare float LITERAL is lowered directly as
// `f32.const` (re-encoded at single precision, never demoted from f64). Otherwise it is
// an i32 LITERAL flowing into an f32 op: evaluate as i32, then convert with
// `f32.convert_i32_s` (0xb2). An i32 *variable* never reaches here — the checker
// rejects i32→f32 as lossy (above 2^24 the i32 would round to the nearest f32), so
// only a literal (exact by construction within the op's value range) takes this path.
function emitExprAsF32(body: i32[], exprIx: i32, fnIx: i32) {
  if exprIsF32(exprIx, fnIx) { return emitExpr(body, exprIx, fnIx) }
  // Peel parens to find a bare float literal we can emit directly as f32.const.
  const inner = unwrapParen(exprIx)
  const innerNode = P.nodes[inner]
  if innerNode is NumLit {
    if numTextIsFloat(innerNode.numText) {
      fbF32Const(innerNode.numText)
      return 0
    }
    // A bare INTEGER literal in f32 context: push it as i32, then convert to f32.
    fbI32Const(parseI32(innerNode.numText))
    fbF32ConvertI32S()
    return 0
  }
  // A unary-minus over a literal (`-1.5` / `-3`) in f32 context: `f32Bytes` parses the
  // leading `-` so a negated float re-encodes directly as `f32.const -1.5` (no `f32.neg`
  // op, no lossy f64 round-trip); a negated integer converts the negated i32. (The
  // exprIsF32 guard above already handles `-x` where x is an f32 value.)
  if innerNode is Unary {
    if innerNode.unOp == "-" {
      const negArg = P.nodes[unwrapParen(innerNode.unArg)]
      if negArg is NumLit {
        if numTextIsFloat(negArg.numText) {
          fbF32Const("-" + negArg.numText)
          return 0
        }
        fbI32Const(0 - parseI32(negArg.numText))
        fbF32ConvertI32S()
        return 0
      }
    }
  }
  // Non-literal i32: evaluate, then convert to f32.
  if emitExpr(body, exprIx, fnIx) < 0 { return -1 }
  fbF32ConvertI32S()
  0
}

// True if the DECLARED LOCAL `name` is an f64 slot (kind 11 in the local registry).
function declaredF64(name: string) { declaredKind(name) == 11 }

// True if the module GLOBAL `name` is an f64 cell. (Slice 3.)
function globalIsF64(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsF64(li, -1)
}

// True if evaluating the expression at `exprIx` yields an f64: a float `.` literal,
// a reference to an f64 param/local/global, f64 arithmetic (either operand f64 — the
// i32 side widens via `f64.convert_i32_s`), unary `-`/parens over such, or a call to
// an f64-returning function. Drives the `print` import choice (`__print_f64__`) and the
// per-operand opcode selection in the BinExpr path. (Slice 3.)
function exprIsF64(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  // Typed-IR fast path through the single `tyKindOf` mapping (additive — only turns false
  // into true, so the flow/union-narrowed cases below still apply; a node with no recorded
  // type, e.g. a monomorphized instance body, reads -1 and falls through to the syntactic
  // derivation).
  if tyKindOf(nodeTyIxOf(exprIx)) == 11 { return true }
  if coalesceAtomKind(exprIx, fnIx) == 4 { return true }
  // `m[k] ?? d` / `m.get(k) ?? d` over an f64-VALUED map yields an f64 (the value type).
  const cmf = coalesceMvSlot(exprIx, fnIx)
  if cmf >= 0 {
    if mvValKind[cmf] == 11 { return true }
  }
  const e = P.nodes[exprIx]
  if e is NumLit { return numTextIsFloat(e.numText) }
  if e is Paren { return exprIsF64(e.parInner, fnIx) }
  // An index read into an `f64[]` yields an f64 element (Slice 4) — so it routes to
  // `__print_f64__` and participates in f64 arithmetic. A bare `m[k]` read over an
  // f64-valued map likewise yields an f64.
  if e is Index {
    if exprF64Array(e.idxArr, fnIx) { return true }
    const mrs = mapReadMvSlot(exprIx, fnIx)
    if mrs >= 0 {
      if mvValKind[mrs] == 11 { return true }
    }
    return false
  }
  if e is Ident {
    // A VALUE-union ident classifies by its narrowed atom (see exprIsI64).
    const uk = unionIdentReadKind(exprIx, fnIx)
    if uk != -3 { return uk == 4 }
    if paramIsF64(fnIx, e.identName) { return true }
    if declaredF64(e.identName) { return true }
    return globalIsF64(e.identName)
  }
  // Arithmetic yields f64 when EITHER operand is f64. Comparisons / logical connectives
  // produce an i32 BOOL even over f64 operands, so they are NOT f64.
  if e is BinExpr {
    const op = e.binOp
    if op == "+" || op == "-" || op == "*" || op == "/" {
      if exprIsF64(e.binLeft, fnIx) { return true }
      return exprIsF64(e.binRight, fnIx)
    }
    // `xs.get(i) ?? d` over an f64 list yields an f64 (the fused checked read);
    // the default `d` shares the element type, so classify by the right side.
    if op == "??" {
      const lhs = P.nodes[unwrapParen(e.binLeft)]
      if lhs is Call {
        const lcallee = P.nodes[lhs.callFn]
        if lcallee is Member {
          if lcallee.memProp == "get" || lcallee.memProp == "pop" {
            if exprF64Array(lcallee.memObj, fnIx) { return true }
          }
        }
      }
      return false
    }
    return false
  }
  // Unary negation `-x` preserves f64-ness (`~` is integer-only; `!` is bool).
  if e is Unary {
    if e.unOp == "-" { return exprIsF64(e.unArg, fnIx) }
    return false
  }
  if e is Call {
    // An INDEXED closure call `fs[i](x)` whose element signature returns f64.
    if cloArrCallRetKind(exprIx, fnIx) == 11 { return true }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const target = fnIndexOf(callee.identName)
      if target >= 0 { return fRetF64[target] == 1 }
      // A function-VALUE (closure) callee returning f64 — its result routes as f64.
      return calleeReturnsF64(callee.identName, fnIx)
    }
    // A FIELD-closure call `t.op(x)` whose field function returns f64.
    if callee is Member {
      const ffe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
      if ffe >= 0 { return cloRetKindOf(ffe) == 11 }
    }
    return false
  }
  // A field read `p.x` whose struct field is an f64 slot (code 17) yields an f64.
  if e is Member { return memFieldTypeCode(exprIx, fnIx) == 17 }
  // A value-position if-EXPRESSION is f64 when either arm's value is f64 (the
  // branch-join widens to f64); an `else if` chain recurses through the else slot.
  if e is IfStmt { return ifExprArmIsKind(exprIx, fnIx, 124) }
  false
}

function exprIsBool(ix: i32, fnIx: i32) {
  if ix < 0 { return false }
  const e = P.nodes[ix]
  if e is BoolLit { return true }
  if e is IsExpr { return true }
  if e is Paren { return exprIsBool(e.parInner, fnIx) }
  if e is Index {
    // An element read over a BOOLEAN-element list prints as true/false: a `.map` result
    // whose callback returns boolean (`xs.map(function(n: i32) n > 2)[i]`), OR a directly
    // declared `boolean[]` (`bs[i]`). Any other index read keeps its i32 classification.
    if mfArrElemIsBool(e.idxArr, fnIx) { return true }
    return listElemIsBool(e.idxArr, fnIx)
  }
  if e is Unary { return e.unOp == "!" }
  if e is Ident {
    // A VALUE-union ident narrowed to `boolean` unboxes to the bool rep and
    // prints true/false (see exprIsI64 for the classification rule).
    const uk = unionIdentReadKind(ix, fnIx)
    if uk != -3 { return uk == 1 }
    // A `boolean|null` NICHE binding read (narrowed non-null in its branch)
    // prints true/false. Plain `boolean` idents stay unclassified (existing rule).
    if exprNulBool(ix, fnIx) { return true }
    // A CAPTURED boolean (a closure returning its maker's `x: boolean` param,
    // e.g. a monomorphized `wrap(true)` index-trap instance) — so the closure's
    // inferred return kind (`fRetBool`) sees the bool-ness through the env.
    if capturedIsBool(fnIx, e.identName) { return true }
    // A plain boolean local/param/global — recovered from the binding's annotation
    // or initializer, since a boolean local registers identically to an i32.
    if boundBoolByName(e.identName, fnIx) { return true }
  }
  if e is BinExpr {
    const op = e.binOp
    if op == "==" || op == "!=" { return true }
    if op == "<" || op == ">" || op == "<=" || op == ">=" { return true }
    if op == "&&" || op == "||" { return true }
    // `lhs ?? d` over a BOOLEAN-list `.get`/`.pop` (or a binding seeded by one)
    // yields a boolean — render true/false. Other `??` reads keep i32 (map gets).
    if op == "??" {
      const lhs = P.nodes[unwrapParen(e.binLeft)]
      if lhs is Call {
        const lcallee = P.nodes[lhs.callFn]
        if lcallee is Member {
          if lcallee.memProp == "get" || lcallee.memProp == "pop" {
            if !exprMap(lcallee.memObj, fnIx) {
              return listElemIsBool(lcallee.memObj, fnIx)
            }
          }
        }
      }
      if lhs is Ident { return identNullableBoolPop(lhs.identName, fnIx) }
    }
    return false
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    // A FIELD-CLOSURE call (`(wb."[]")(0)` — an index-trap dispatch) classifies
    // by the field function's return: the receiver's ORIGIN resolves the exact
    // monomorphized MAKER instance, so `wrap(true)`'s trap prints true while
    // `wrap(99)`'s prints 99 (the instances SHARE the closure body — bool-ness
    // lives in the instance's pinned param annotation, not the shared closure).
    if callee is Member {
      if (
        drwFieldClosure(structIndexOfExpr(callee.memObj, fnIx), callee.memProp)
      ) {
        return fieldCloCallIsBool(callee.memObj, callee.memProp, fnIx)
      }
    }
    if callee is Ident {
      const target = fnIndexOf(callee.identName)
      if target >= 0 {
        const fn = P.nodes[fnStmts[target]]
        if fn is FuncDecl {
          if fn.fnRet >= 0 {
            const rt = P.nodes[fn.fnRet]
            if rt is TypeRef { return rt.tyName == "boolean" }
          } else {
            // Un-annotated: `computeRetInference` has classified the callee's first
            // valued return into `fRetBool` (fixed point, so a mutually-recursive
            // group resolves).
            return fRetBool[target] == 1
          }
        }
      }
    }
    // G8: a map membership test `m.has(k)` and a `m.delete(k)` both yield a boolean
    // (print true/false): `.has` = is-present, `.delete` = was-present-and-removed.
    if callee is Member {
      if callee.memProp == "has" { return exprMap(callee.memObj, fnIx) }
      if callee.memProp == "delete" { return exprMap(callee.memObj, fnIx) }
      // A string `s.includes(sub)` yields a boolean (print true/false).
      if callee.memProp == "includes" { return exprString(callee.memObj, fnIx) }
    }
  }
  false
}

// Node shapes read: Call { callFn: i32, callArgs: i32[] }, callee Ident { identName }.
function emitCall(body: i32[], callIx: i32, fnIx: i32) {
  let c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Ident {
      // `fromCodePoint(code)` is a compiler builtin (H2): construct a single-character
      // VL string from an i32 code point. A VL string IS the shared `(array i32)` of
      // code points (`aTypeIdx`), so this is a length-1 array — push the one i32 arg,
      // then `array.new_fixed $aTypeIdx 1`. Mirrors toWasm's `fromCodePoint` lowering.
      // BEFORE the `fnIndexOf` lookup, which would fail ("unknown function").
      // `toString(x)` is a compiler builtin: an i32 renders its decimal digits, a
      // BOOLEAN-classified argument the literal text "true"/"false" — both as a
      // fresh string (array of code points).
      if callee.identName == "toString" {
        return emitToString(body, callIx, fnIx)
      }
      // `fromCodePoints(xs)` (H2): bulk string construction — ONE array.copy of
      // the list's live elements into an exact-length string array, instead of
      // per-char concat (quadratic churn). Uses the string-op scratch frame
      // (I0 = len, Out = the result) — `exprHasStrOp` reserves it. The list is
      // re-read per use, so the argument must be a NAME (param/local/global);
      // an arbitrary expression would need a list-typed temp slot.
      if callee.identName == "fromCodePoints" {
        if !aUsed || !lUsed {
          return emitFail(
            "emitProgram: fromCodePoints but array/list types not collected",
          )
        }
        if c.callArgs.length != 1 {
          return emitFail("emitProgram: fromCodePoints takes exactly one argument")
        }
        let fcpArg = c.callArgs[0]
        const fcpN0 = P.nodes[fcpArg]
        if fcpN0 is Paren { fcpArg = fcpN0.parInner }
        const fcpNode = P.nodes[fcpArg]
        if fcpNode is Ident {
          // I0 = xs.len
          if emitExpr(body, fcpArg, fnIx) < 0 { return -1 }
          fbStructGet(lTypeIdx, 1)
          setStrScrI(body, 0)
          // Out = array.new_default(I0)
          pushStrScrI(body, 0)
          fbArrayNewDefault(aTypeIdx)
          fbLocalSet(strScratchBase + 2)
          // array.copy Out 0 xs.backing 0 I0
          pushStrScrRef(body, 2)
          fbI32Const(0)
          if emitExpr(body, fcpArg, fnIx) < 0 { return -1 }
          fbStructGet(lTypeIdx, 0)
          fbI32Const(0)
          pushStrScrI(body, 0)
          fbArrayCopy(aTypeIdx, aTypeIdx)
          pushStrScrRef(body, 2)
          return 0
        }
        return emitFail(
          "emitProgram: fromCodePoints argument must be a named i32[] binding",
        )
      }
      if callee.identName == "fromCodePoint" {
        if !aUsed {
          return emitFail("emitProgram: fromCodePoint but array type not collected")
        }
        if c.callArgs.length != 1 {
          return emitFail("emitProgram: fromCodePoint takes exactly one argument")
        }
        if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
        fbArrayNewFixed(aTypeIdx, 1) // 0xfb 0x08 <typeidx> 1; type shared with i32[]
        return 0
      }
      // `print(x)` is a compiler builtin lowered to the host's import family:
      // a BOOLEAN-classified arg calls `__print_bool__` (import 1, renders
      // true/false), anything else i32-ish calls `__print_i32__` (import 0).
      // Strings are a later slice. The call yields NOTHING (void import) — the
      // statement path knows not to drop.
      if callee.identName == "print" {
        if c.callArgs.length != 1 {
          return emitFail("emitProgram: print takes exactly one argument")
        }
        if exprString(c.callArgs[0], fnIx) {
          return emitPrintStrExpr(body, c.callArgs[0], fnIx)
        }
        // print(literal-union ATOM): WIDEN it to its member STRING — a per-member `if id == <id> { print
        // "<name>" }` chain (exactly one matches, so at most one prints). The atom→string widening in
        // statement form; the value form (concat / string arg / return) is a follow-up.
        if exprIsLitAtom(c.callArgs[0], fnIx) {
          const lpTexts = nodeLitUnionMemberTexts(c.callArgs[0])
          let lpi = 0
          while lpi < lpTexts.length {
            const lpQ = quoteLex(lpTexts[lpi])
            if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
            fbI32Const(internAtom(lpQ))
            fbI32Bin(70) // 0x46 i32.eq
            fbIf(64)     // if (void)
            ctrlEnter()
            const lpSyn = mkStr(lpQ, -1)
            if emitPrintStrExpr(body, lpSyn, fnIx) < 0 { return -1 }
            fbEnd()
            ctrlLeave()
            lpi = lpi + 1
          }
          return 0
        }
        // An i64-typed argument lowers to `i64.const`/`local.get` of an i64 slot, so it
        // must route to `__print_i64__` (import 4) — its functype is `(i64)->()`, so the
        // i32/bool imports would fail to typecheck the call. Checked before bool/i32.
        // An f64 argument routes to `__print_f64__` (import `gF64PrintIdx`, a `(f64)->()`
        // functype) — checked first since a float literal/operand is never i64/bool/i32.
        // An f32 argument routes to `__print_f32__` (import `gF32PrintIdx`, a `(f32)->()`
        // functype) — checked BEFORE f64 since an f32 expression (`x`, `x + 4.0`) is
        // `exprIsF32`, and a mixed f32/float-literal expression must print as f32.
        const argF32 = exprIsF32(c.callArgs[0], fnIx)
        const argI64 = exprIsI64(c.callArgs[0], fnIx)
        const argF64 = exprIsF64(c.callArgs[0], fnIx)
        if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
        if argF32 {
          fbCall(gF32PrintIdx) // 0x10 call __print_f32__
        } else if argF64 {
          fbCall(gF64PrintIdx) // 0x10 call __print_f64__
        } else if argI64 {
          fbCall(4) // 0x10 call __print_i64__ (import index 4)
        } else if exprIsBool(c.callArgs[0], fnIx) {
          fbCall(1) // 0x10 call __print_bool__ (import index 1)
        } else {
          fbCall(0) // 0x10 call __print_i32__ (import index 0)
        }
        return 0
      }
      // The linear-memory intrinsics, lowered INLINE (the host defines `__store_i32__`/
      // `__load_i32__` as one-instruction wasm functions — same instruction, no call):
      // store → `i32.store`, load → `i32.load`, `__log__` → call the synthetic
      // in-module decoder at `gMemLogIdx` (the host imports `__log__` instead; the
      // native runner provides no such import — see `emitMemLogFnCode`).
      if callee.identName == "__store_i32__" {
        if c.callArgs.length != 2 {
          return emitFail("emitProgram: __store_i32__ takes exactly two arguments")
        }
        if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
        if emitExpr(body, c.callArgs[1], fnIx) < 0 { return -1 }
        fbI32Store()
        return 0
      }
      if callee.identName == "__load_i32__" {
        if c.callArgs.length != 1 {
          return emitFail("emitProgram: __load_i32__ takes exactly one argument")
        }
        if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
        fbI32Load()
        return 0
      }
      if callee.identName == "__log__" {
        if c.callArgs.length != 2 {
          return emitFail("emitProgram: __log__ takes exactly two arguments")
        }
        if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
        if emitExpr(body, c.callArgs[1], fnIx) < 0 { return -1 }
        fbCall(gMemLogIdx)
        return 0
      }
      // The array-intrinsic floor (std-design D1 / collections-design §LS.2),
      // lowered INLINE — host parity: toWasm.ts lowers the same names to single
      // WasmGC instructions (array.new / array.new_default / array.copy /
      // unreachable). `__trap__()` is the deliberate abort primitive.
      if callee.identName == "__trap__" {
        if c.callArgs.length != 0 {
          return emitFail("emitProgram: __trap__ takes no arguments")
        }
        fbUnreachable()
        return 0
      }
      // `__array_new__(n, fill)` → `array.new` (every slot set to `fill`);
      // `__array_new_default__(n)` → `array.new_default` (slots zeroed). Both
      // yield the `{backing, len: n, cap: n}` list wrapper — the runtime-length
      // sibling of the array literal. The length is staged in the 1-slot arrNew
      // scratch local (it feeds the allocation size and both wrapper fields).
      // Native element coverage: the i32 list (i32/boolean) and, for
      // `__array_new__`, the f64 list via an f64 fill; ref/string elements are
      // emitter long tail — fail loudly, never emit wrong bytes.
      if (
        callee.identName == "__array_new__" ||
        callee.identName == "__array_new_default__"
      ) {
        const anIsNew = callee.identName == "__array_new__"
        let anWant = 1
        if anIsNew { anWant = 2 }
        if c.callArgs.length != anWant {
          return emitFail(
            "emitProgram: " +
              callee.identName +
              " takes exactly " +
              i32ToStr(anWant) +
              " argument(s)",
          )
        }
        let anBack = aTypeIdx
        let anWrap = lTypeIdx
        // The element struct for a kind-3 (ref) fill — seeds `pendingStructIdx`
        // so the `{…}` fill emits as the list's declared element struct.
        let anElemStructIdx = -1
        const ank = arrNewIntrKind(callIx, fnIx)
        if ank == 1 {
          if !fa64Used {
            return emitFail(
              "emitProgram: __array_new__ f64 fill but f64 list types not collected",
            )
          }
          anBack = fa64TypeIdx
          anWrap = fl64TypeIdx
        } else if ank == 2 {
          // STRING fill → the string list (`array.new` of the shared string-ref
          // backing; a non-null string ref stores into the nullable slot directly).
          if !slUsed {
            return emitFail(
              "emitProgram: __array_new__ string fill but string list types not collected",
            )
          }
          anBack = mkArrIdx
          anWrap = mkListIdx
        } else if ank == 3 {
          // STRUCT fill → the ref list of the element struct (its interned slot).
          if !rlUsed {
            return emitFail(
              "emitProgram: __array_new__ struct fill but ref list types not collected",
            )
          }
          const anSlot = refListSlotOfExpr(callIx, fnIx)
          anBack = rlBackIdx[anSlot]
          anWrap = rlWrapIdx[anSlot]
          anElemStructIdx = structIdxOfElemName(rlElemName[anSlot])
        } else {
          if !aUsed || !lUsed {
            return emitFail("emitProgram: array intrinsic but list types not collected")
          }
          if anIsNew {
            const anFill = c.callArgs[1]
            const anFillNode = P.nodes[anFill]
            // No i64[] / f32[] backing exists yet (only i32/f64/string/ref lists),
            // so an i64 / f32 fill would otherwise store into the i32 backing and
            // emit INVALID wasm — fail loudly instead (never wrong bytes).
            if exprIsI64(anFill, fnIx) {
              return emitFail(
                "emitProgram: __array_new__ i64 fill — i64-element arrays are not supported yet",
              )
            }
            if exprIsF32(anFill, fnIx) {
              return emitFail(
                "emitProgram: __array_new__ f32 fill — f32-element arrays are not supported yet",
              )
            }
            let anFillRef = false
            if anFillNode is ObjLit { anFillRef = true }
            if exprIsClosure(anFill, fnIx) { anFillRef = true }
            if exprArray(anFill, fnIx) { anFillRef = true }
            if exprRefArray(anFill, fnIx) { anFillRef = true }
            if exprStringArray(anFill, fnIx) { anFillRef = true }
            if exprMap(anFill, fnIx) { anFillRef = true }
            if anFillRef {
              // Remaining ref-fill long tail: closures / nested arrays / maps.
              return emitFail(
                "emitProgram: __array_new__ fill type not yet supported natively",
              )
            }
          }
        }
        if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
        fbLocalSet(arrNewScratchBase)
        if anIsNew {
          pendingStructIdx = anElemStructIdx
          if emitExpr(body, c.callArgs[1], fnIx) < 0 { return -1 }
          pendingStructIdx = -1
          fbLocalGet(arrNewScratchBase)
          fbArrayNew(anBack)
        } else {
          fbLocalGet(arrNewScratchBase)
          fbArrayNewDefault(anBack)
        }
        fbLocalGet(arrNewScratchBase)
        fbLocalGet(arrNewScratchBase)
        fbStructNew(anWrap)
        return 0
      }
      // `__array_copy__(dst, dstAt, src, srcAt, count)` → `array.copy` over the
      // two lists' backings: bulk-move `count` elements from `src[srcAt..]` into
      // `dst[dstAt..]` (memmove semantics; OOB spans trap — the instruction's
      // own check). Operand order matches the instruction's stack shape, so no
      // scratch is needed.
      if callee.identName == "__array_copy__" {
        if c.callArgs.length != 5 {
          return emitFail("emitProgram: __array_copy__ takes exactly five arguments")
        }
        const acDstF64 = exprF64Array(c.callArgs[0], fnIx)
        const acSrcF64 = exprF64Array(c.callArgs[2], fnIx)
        if acDstF64 != acSrcF64 {
          return emitFail(
            "emitProgram: __array_copy__ dst and src must share one element type",
          )
        }
        let acBack = aTypeIdx
        let acWrap = lTypeIdx
        if acDstF64 {
          if !fa64Used {
            return emitFail(
              "emitProgram: __array_copy__ f64 lists but f64 list types not collected",
            )
          }
          acBack = fa64TypeIdx
          acWrap = fl64TypeIdx
        } else {
          if (
            exprRefArray(c.callArgs[0], fnIx) ||
            exprStringArray(c.callArgs[0], fnIx) ||
            exprRefArray(c.callArgs[2], fnIx) ||
            exprStringArray(c.callArgs[2], fnIx)
          ) {
            return emitFail(
              "emitProgram: __array_copy__ supports i32/boolean/f64 lists natively",
            )
          }
          if (
            !exprArray(c.callArgs[0], fnIx) ||
            !exprArray(c.callArgs[2], fnIx)
          ) {
            return emitFail("emitProgram: __array_copy__ expects list (T[]) operands")
          }
          if !aUsed || !lUsed {
            return emitFail("emitProgram: array intrinsic but list types not collected")
          }
        }
        if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
        fbStructGet(acWrap, 0)
        if emitExpr(body, c.callArgs[1], fnIx) < 0 { return -1 }
        if emitExpr(body, c.callArgs[2], fnIx) < 0 { return -1 }
        fbStructGet(acWrap, 0)
        if emitExpr(body, c.callArgs[3], fnIx) < 0 { return -1 }
        if emitExpr(body, c.callArgs[4], fnIx) < 0 { return -1 }
        fbArrayCopy(acBack, acBack)
        return 0
      }
      const target = fnIndexOf(callee.identName)
      if target < 0 {
        // Not a known function name — a CLOSURE-VALUED callee (a let/param/global holding
        // a function value, or a higher-order call result). Emit a `call_ref` over the
        // closure fat-pointer: push env, push args, push code, `call_ref $fnsig`.
        if exprIsClosure(c.callFn, fnIx) {
          return emitCallRef(body, callIx, fnIx)
        }
        return emitFail("emitProgram: call to unknown function")
      }
      // A direct call to a CAPTURING lifted function (`add(10)` where `add` captures `n`
      // from the enclosing frame): build its closure value (reading the captures live)
      // and `call_ref` it — a plain `call` would pass a null env and lose the captures.
      // Gated on `fnValUsed` so a no-lambda module never enters this path (and capture
      // analysis, which can false-positive on a forward reference, is never consulted).
      if fnValUsed && captureCountOf(target) > 0 {
        // Stash the freshly-built closure, then call_ref it (same shape as emitCallRef
        // but the callee is a value we synthesize here, not an existing binding).
        if emitClosureValue(body, target, fnIx) < 0 { return -1 }
        fbLocalSet(callRefSlot)
        fbLocalGet(callRefSlot)
        fbStructGet(cloStructIdx, 1) // env
        // Parameter-order args (named-call reorder; see the direct path below).
        const cargs = orderedDirectArgs(callIx, target)
        if directArgsBad(cargs, callIx) {
          return emitFail("emitProgram: named argument does not match a parameter")
        }
        let cai = 0
        while cai < cargs.length {
          if emitExpr(body, cargs[cai], fnIx) < 0 { return -1 }
          cai = cai + 1
        }
        const csig = fnSigIdxForArity(cargs.length)
        if csig < 0 {
          return emitFail("emitProgram: captured call arity has no interned signature")
        }
        fbLocalGet(callRefSlot)
        fbStructGet(cloStructIdx, 0) // code (funcref)
        fbRefCast(csig)
        fbCallRef(csig)
        return 0
      }
      // The callee's FuncDecl lives at `fnStmts[target]` (the function index IS the
      // fnStmts position). Its parameter list lets a struct-literal argument construct as
      // the callee's DECLARED param struct type rather than a field-name guess — the fix
      // for passing a struct value into a forward-referenced / mutually-recursive callee
      // whose param struct shares field names with another struct.
      const cFn = P.nodes[fnStmts[target]]
      // Arguments in PARAMETER order (host parity: `orderArgumentsByParameters`
      // + operands built per-parameter). A call with no named args keeps its
      // source list untouched; a named call (`f(b: 1, a: 2)`) reorders here so
      // each emitted operand lands on (and is typed by) its declared parameter
      // — including EVALUATION order, which follows parameter order as the
      // host's per-parameter operand build does.
      const args = orderedDirectArgs(callIx, target)
      if directArgsBad(args, callIx) {
        return emitFail("emitProgram: named argument does not match a parameter")
      }
      // When a function value exists module-wide, EVERY callee carries a hidden leading
      // `structref env` param. A direct call to a top-level function (never capturing)
      // passes a null env. Pushed BEFORE the args, matching the env-leading signature.
      if fnValUsed { fbRefNullStruct() }
      let i = 0
      while i < args.length {
        // If this argument position is a struct-typed parameter, hint `emitObj` with the
        // callee's struct index (consumed by the immediately-following object-literal
        // lowering; a non-literal argument simply ignores it). Default -1 = infer.
        pendingStructIdx = -1
        pendingListKind = 0
        pendingListSlot = 0
        pendingI64 = false
        // A VARIANT-typed param position (kind 8): the callee wants the CONCRETE variant
        // struct ref, but a union-valued argument (a narrowed local/param, a union-
        // returning call) is the BOX `{tag, value}`. Bridge the boundary by unboxing the
        // arg to the param's variant struct — `struct.get $box 1 ; ref.cast (ref $var)`
        // (gap #2). The cast is statically safe: control reached this call only with the
        // arg narrowed to this variant.
        let cVi = -1
        // A NON-NULL struct param position (kind 1, `(ref $S)`): a nullable-REP
        // argument needs `ref.as_non_null` at the boundary (see below).
        let cParamStruct = false
        // A UNION-typed param position (kind 4): the callee wants the box, so a raw
        // scalar/string/null argument is COERCED into the union representation
        // (`emitUnionCoerce` — the host's call-boundary `coerceUnion`). The param's
        // union NAME carries the atom set for the tag choice.
        let cUNm = ""
        // A `boolean | null` NICHE param position: a `null` argument is the i32
        // sentinel 2 (seed `pendingNulBool`); a boolean argument is untouched.
        let cParamNulBool = false
        // A `string | null` param position: a `null` argument is `ref.null $aTypeIdx`.
        let cParamNulString = false
        // A `fn | null` param position (kind 19): a `null` argument is `ref.null $cloStruct`.
        let cParamNulClosure = false
        // An `i32[] | null` param position (kind 15): a `null` argument is `ref.null $lTypeIdx`.
        let cParamNulList = false
        // A literal-union param position: a member-literal argument lowers as its interned i32 id.
        let cParamLitUnion = false
        // A `string` param position (kind 3): a literal-union atom ARGUMENT widens to its member
        // string at the boundary (the atom-as-string-subtype edge).
        let cParamStr = false
        if cFn is FuncDecl {
          const cParams = cFn.fnParams
          if i < cParams.length {
            const cpnb = P.nodes[cParams[i]]
            if cpnb is Param {
              if tyIsNulBool(cpnb.parType) { cParamNulBool = true }
              if retNulStringFlag(cpnb.parType) == 1 { cParamNulString = true }
              if nulCloFlag(cpnb.parType) == 1 { cParamNulClosure = true }
              if retNulListFlag(cpnb.parType) == 1 { cParamNulList = true }
              if nameIsLitUnionType(tyNameOf(cpnb.parType)) {
                cParamLitUnion = true
              }
            }
            if vtKindOfParam(cParams[i]) == 3 { cParamStr = true }
            if (
              vtKindOfParam(cParams[i]) == 1 ||
              vtKindOfParam(cParams[i]) == 9
            ) {
              pendingStructIdx = paramStructIdxOf(cParams[i])
            }
            if vtKindOfParam(cParams[i]) == 1 { cParamStruct = true }
            if vtKindOfParam(cParams[i]) == 8 {
              cVi = paramStructIdxOf(cParams[i])
            }
            if vtKindOfParam(cParams[i]) == 4 {
              const cp4 = P.nodes[cParams[i]]
              if cp4 is Param { cUNm = tyNameOf(cp4.parType) }
            }
            // A ref-array param position (`take(xs: B[])`): seed the list context from the
            // param's annotation so a non-empty `B[]` LITERAL argument builds the param's
            // declared element type, not the first-element field-shape guess. Mirrors the
            // let / return / global seeding (consumed by `emitArr`).
            let cp = P.nodes[cParams[i]]
            if cp is Param {
              pendingListKind = tyAnnRefListKind(cp.parType)
              pendingListSlot = tyAnnRefListSlot(cp.parType)
            }
            // An i64 param position lowers an integer-literal argument as `i64.const`.
            if vtKindOfParam(cParams[i]) == 10 { pendingI64 = true }
          }
        }
        // An f64 / f32 param position lowers the argument coerced to that float type
        // (a float literal re-encodes; an i32/i64/f32 source converts via the lattice
        // helper). (Slice 3 f64; Slice 5 f32.)
        let cParamF64 = false
        let cParamF32 = false
        // An i64 param position widens a narrower (i32) argument at the call
        // boundary via `i64.extend_i32_s` — `emitExprAsI64` (a literal lowers as
        // `i64.const`; an i32 VARIABLE sign-extends). The value-preserving edge
        // the checker permits, mirroring the let / return widenings.
        let cParamI64 = false
        if cFn is FuncDecl {
          const cParams2 = cFn.fnParams
          if i < cParams2.length {
            if vtKindOfParam(cParams2[i]) == 11 { cParamF64 = true }
            if vtKindOfParam(cParams2[i]) == 13 { cParamF32 = true }
            if vtKindOfParam(cParams2[i]) == 10 { cParamI64 = true }
          }
        }
        if cParamF32 {
          const savedF32 = pendingF32
          pendingF32 = true
          if emitExprAsF32(body, args[i], fnIx) < 0 { return -1 }
          pendingF32 = savedF32
          pendingStructIdx = -1
          pendingListKind = 0
          pendingListSlot = 0
          pendingI64 = false
          i = i + 1
        } else if cParamF64 {
          if emitExprAsF64(body, args[i], fnIx) < 0 { return -1 }
          pendingStructIdx = -1
          pendingListKind = 0
          pendingListSlot = 0
          pendingI64 = false
          i = i + 1
        } else if cParamI64 {
          if emitExprAsI64(body, args[i], fnIx) < 0 { return -1 }
          pendingStructIdx = -1
          pendingListKind = 0
          pendingListSlot = 0
          pendingI64 = false
          i = i + 1
        } else {
          if cParamStr && exprIsLitAtom(args[i], fnIx) {
            // A literal-union atom flowing into a `string` param widens to its member string.
            // (Shared tail below resets the `pending*` hints and advances `i`.)
            if emitAtomToStr(body, args[i], fnIx) < 0 { return -1 }
          } else if cUNm != "" {
            // `cUNm` is set only for a kind-4 union-BOX param (see above), so a concrete
            // variant ARGUMENT (`area(s)` where `s: S`, param `C | S`) is boxed here.
            if emitUnionBoxArg(body, cUNm, args[i], fnIx) < 0 { return -1 }
          } else {
            const savedCNB = pendingNulBool
            const savedCNS = pendingNulString
            const savedCNC = pendingNulClosure
            const savedCNL = pendingNulList
            const savedCLU = pendingLitUnion
            if cParamNulBool { pendingNulBool = true }
            if cParamNulString { pendingNulString = true }
            if cParamNulClosure { pendingNulClosure = true }
            if cParamNulList { pendingNulList = true }
            if cParamLitUnion { pendingLitUnion = 1 }
            // A variant-PARAM position (`loud(c: Cat)`): seed the variant index so an object
            // LITERAL argument builds the bare variant struct (kind 8). A variant/union VALUE
            // argument ignores the hint (the union-unbox cast below handles a boxed value).
            if cVi >= 0 { pendingVariantIdx = cVi }
            if emitExpr(body, args[i], fnIx) < 0 { return -1 }
            pendingVariantIdx = -1
            pendingNulBool = savedCNB
            pendingNulString = savedCNS
            pendingNulClosure = savedCNC
            pendingNulList = savedCNL
            pendingLitUnion = savedCLU
            // A nullable-REP value (a null-narrowed `S | null` param/local, or a
            // recursive `S | null` field read whose wasm slot stays `(ref null $S)`)
            // flowing into a NON-NULL `(ref $S)` param: recover the non-null ref at
            // the call boundary. The checker proved the value non-null on this path
            // (the call sits under its null guard), so the cast never traps —
            // narrowing is type-level only and the stack value keeps the nullable
            // rep, which a `(ref $S)` param does not accept.
            if cParamStruct {
              if exprNullableStruct(args[i], fnIx) {
                fbRefAsNonNull() // 0xd4
              }
            }
          }
          if cVi >= 0 {
            if exprUnion(args[i], fnIx) {
              fbStructGet(uBoxIdx, 1)  // 0xfb 0x02 <box ht> field 1: value (anyref)
              fbRefCast(uVarIdx + cVi) // 0xfb 0x16 <variant struct> ref.cast (non-null)
            }
          }
          pendingStructIdx = -1
          pendingListKind = 0
          pendingListSlot = 0
          pendingI64 = false
          i = i + 1
        }
      }
      fbCall(gImports + target) // 0x10 call (imports occupy indices 0..gImports-1)
      return 0
    }
    // A non-Ident callee yielding a function value (`o.go(10)`, `(expr)(args)`):
    // `call_ref` over the closure fat-pointer.
    if exprIsClosure(c.callFn, fnIx) { return emitCallRef(body, callIx, fnIx) }
    // A UFCS `self`-method call (the host parser's rule, parser.ts case 2):
    // `o.f(args)` where `f` is a free function whose FIRST parameter is named
    // `self` (and arity matches) lowers to the direct call `f(o, args)`. The
    // callable-FIELD case won above (`exprIsClosure` → `call_ref`), mirroring the
    // host's precedence. Lowered by building the direct-call node in the arena and
    // re-lowering it, so every direct-call coercion path (struct hints, union
    // boxing, nullable bridging, widening) is shared rather than duplicated.
    const um = P.nodes[c.callFn]
    if um is Member {
      // A UFCS member-call normally lowers to a direct `Ident` call in
      // `dispatchRewrite`/`drwWalk` before emission; this fallback re-derives the
      // same direct call should it reach emit unrewritten. The merge mangles the
      // free `self`-function but leaves the property plain, so resolve through the
      // alias (identity single-file).
      const uName = ufcsAliasOf(um.memProp)
      const uTarget = fnIndexOf(uName)
      if uTarget >= 0 {
        const uFn = P.nodes[fnStmts[uTarget]]
        if uFn is FuncDecl {
          const uParams = uFn.fnParams
          if uParams.length == c.callArgs.length + 1 {
            const uP0 = P.nodes[uParams[0]]
            if uP0 is Param {
              if uP0.parName == "self" {
                const uArgs: i32[] = []
                uArgs.push(um.memObj)
                let ua = 0
                while ua < c.callArgs.length {
                  uArgs.push(c.callArgs[ua])
                  ua = ua + 1
                }
                // The injected receiver is an UNNAMED slot-0 positional; any
                // named args shift right with it ("" rides slot 0) so the
                // rebuilt direct call reorders them around the receiver
                // exactly as the host does.
                const uNames: string[] = []
                if hasNamedArgs(c.callArgNames) {
                  uNames.push("")
                  let un = 0
                  while un < c.callArgNames.length {
                    uNames.push(c.callArgNames[un])
                    un = un + 1
                  }
                }
                return emitCall(body, mkCallN(mkIdent(uName, -1), uArgs, uNames, -1), fnIx)
              }
            }
          }
        }
      }
    }
    return emitFail("emitProgram: callee is not a function name")
  }
  emitFail("emitProgram: expected a call expression")
}

// The argument VALUE nodes of the call at `callIx`, bound into PARAMETER order
// for a direct call to the function at fnStmts position `target` — the host's
// `orderArgumentsByParameters` applied at the emission boundary. An
// all-positional call returns its source list untouched (byte-identical to the
// pre-named-args emitter); a named call reorders by the callee FuncDecl's
// parameter names. A binding failure surfaces as a -1 slot / surplus entry,
// which `directArgsBad` detects (the checker already diagnosed it; the emitter
// just refuses to emit a mis-mapped call).
function orderedDirectArgs(callIx: i32, target: i32) {
  const none: i32[] = []
  let c = P.nodes[callIx]
  if c is Call {
    if !hasNamedArgs(c.callArgNames) { return c.callArgs }
    const pNames: string[] = []
    let d = P.nodes[fnStmts[target]]
    if d is FuncDecl {
      const ps = d.fnParams
      let i = 0
      while i < ps.length {
        const p = P.nodes[ps[i]]
        if p is Param { pNames.push(p.parName) }
        i = i + 1
      }
    }
    return orderArgsByParamNames(pNames, c.callArgs, c.callArgNames)
  }
  none
}

// Lower a function-VALUE call `f(args)` via `call_ref` over the closure fat-pointer.
// The closure is evaluated ONCE into a scratch local, then: push its env
// (`struct.get 1`), push the args, push its code funcref (`struct.get 0`), and
// `call_ref $fnsig`. Mirrors the host's `indirectCall` (adapted to `call_ref`).
// A NAMED argument needs the callee's parameter names, which a function VALUE
// (its `TyFunc`) does not carry — fail loudly rather than mis-map positionally.
// The closure `$fnsig` KEY for the elements of a closure-element ref list (kind 5): the
// slot's element type-NAME is the parenthesized function type `((i32) => i32)`; strip the
// grouping parens to `(i32) => i32` and read its signature key (`annSigKey`, which agrees
// byte-for-byte with `fnSigKeyOf`/`cloSigKeyExt`). "" for a non-closure slot or an
// un-keyable signature. Lets an INDEXED closure call (`fs[i](x)`) cast to the ELEMENT's
// real functype instead of the all-i32 arity fallback — which a non-i32-signature array
// (`((f64) => f64)[]`) doesn't even have interned.
function cloArrSlotSigKey(slot: i32) {
  if slot < 0 || slot >= rlElemName.length { return "" }
  if rlElemKindTbl[slot] != 5 { return "" }
  const nm = rlElemName[slot]
  if nm.length < 2 { return "" }
  if nm[0] != '(' || nm[nm.length - 1] != ')' { return "" }
  return annSigKey(nm.slice(1, nm.length - 1))
}

// The SCALAR-coercion kind of parameter `idx` read from a `$fnsig` KEY's param-token spine: `10`
// (i64, token `I`), `11` (f64, `d`), `13` (f32, `f`), or `-1` (i32 / a ref kind — no coercion). The
// tokens are `cloParamTok`'s: single-char scalars, or `s<idx>;` / `V<idx>;` / `r<idx>;` ref tokens
// terminated by `;`. Lets a value CALL widen an i32-literal argument into an i64 / f32 / f64
// parameter, exactly as a direct call does — without it the `call_ref` pushes an i32 and traps.
function sigParamCoerceKind(key: string, idx: i32) {
  let i = 0
  let p = 0
  while i < key.length {
    const c = key[i]
    if c == '>' { return -1 }
    if p == idx {
      if c == 'I' { return 10 }
      if c == 'd' { return 11 }
      if c == 'f' { return 13 }
      return -1
    }
    if c == 's' || c == 'V' || c == 'r' {
      while i < key.length && key[i] != ';' { i = i + 1 }
      i = i + 1
    } else {
      i = i + 1
    }
    p = p + 1
  }
  -1
}

// The callee's interned `$fnsig` KEY for a value call (`f(x)`, `(o.field)(x)`, `fs[i](x)`), or "" —
// the param tokens drive argument coercion and the key resolves the functype the `call_ref` casts to.
function cloCallSigKey(callIx: i32, fnIx: i32) {
  const c = P.nodes[callIx]
  if c is Call {
    const cre = P.nodes[c.callFn]
    // The syntactic resolvers — fast (no type render): a function-typed binding/param Ident, a struct
    // field closure, an indexed closure-array element.
    if cre is Ident {
      const k = calleeCloSigKey(cre.identName, fnIx)
      if k != "" { return k }
    }
    if cre is Member {
      const mfe = fieldClosureFeOfRecv(cre.memObj, cre.memProp, fnIx)
      if mfe >= 0 { return cloSigKeyExt(mfe) }
    }
    if cre is Index {
      if exprRefArray(cre.idxArr, fnIx) {
        const k = cloArrSlotSigKey(refListSlotOfExpr(cre.idxArr, fnIx))
        if k != "" { return k }
      }
    }
    // GENERAL FALLBACK — derive the key from the callee's CHECKER type, uniformly for ANY callee the
    // syntactic resolvers miss (an indexed closure-array element returning a struct/union, a value
    // INFERRED from a factory call `const g = mk()`). `nodeTyName` renders the closure's `(params)=>ret`
    // name (the checker proved its TyFunc), then the SAME `annSigKey` the annotation path uses produces
    // a byte-identical key — so the call-site `ref.cast` resolves the functype the lambda interned, with
    // no per-position sig producer. Off the hot path: reached only after the syntactic resolvers, so a
    // common closure call (annotated binding/param) never renders.
    const tn = nodeTyName(c.callFn)
    if tn != "" {
      if annArrowAt(tn) >= 0 { return annSigKey(tn) }
    }
  }
  ""
}

function emitCallRef(body: i32[], callIx: i32, fnIx: i32) {
  let c = P.nodes[callIx]
  if c is Call {
    if hasNamedArgs(c.callArgNames) {
      return emitFail("emitProgram: named arguments require a declared function")
    }
    // Evaluate the closure once into the call-ref scratch local (`callRefSlot`).
    if emitExpr(body, c.callFn, fnIx) < 0 { return -1 }
    // A NULLABLE function value (`fn | null`, kind 19) loads as `(ref null $cloStruct)`;
    // the scratch slot is non-null, and the checker proved it non-null here (the `if c !=
    // null` narrowing), so recover to non-null.
    if exprNulClosure(c.callFn, fnIx) {
      wU8(212) // 0xd4 ref.as_non_null
    }
    fbLocalSet(callRefSlot)
    // The callee's interned `$fnsig` KEY — a function-typed param/local/global annotation, an
    // inferred binding's underlying sig, a field closure's, or an indexed closure-array element's.
    // Its param tokens drive ARGUMENT coercion below, and it resolves the functype to `ref.cast` to
    // (a non-all-i32 shape like `(f64,f64)->f64` casts to the right functype; "" falls back to the
    // all-i32 arity sig).
    const ckey = cloCallSigKey(callIx, fnIx)
    // env = closure.env (field 1).
    fbLocalGet(callRefSlot)
    fbStructGet(cloStructIdx, 1)
    // args, each COERCED to its parameter's scalar valtype (an i32 literal widened into an i64 / f64
    // / f32 param) — the `call_ref` functype demands the exact valtype, exactly as a direct call.
    const args = c.callArgs
    let i = 0
    while i < args.length {
      const pck = sigParamCoerceKind(ckey, i)
      if pck == 10 {
        if emitExprAsI64(body, args[i], fnIx) < 0 { return -1 }
      } else if pck == 11 {
        if emitExprAsF64(body, args[i], fnIx) < 0 { return -1 }
      } else if pck == 13 {
        if emitExprAsF32(body, args[i], fnIx) < 0 { return -1 }
      } else {
        if emitExpr(body, args[i], fnIx) < 0 { return -1 }
      }
      i = i + 1
    }
    // code = closure.code (field 0) — a generic funcref. ref.cast it to the concrete `$fnsig`.
    let sig = -1
    if ckey != "" {
      const cp = cloSigPosOfKey(ckey)
      if cp >= 0 { sig = cloSigBase + cp }
    }
    if sig < 0 { sig = fnSigIdxForArity(args.length) }
    if sig < 0 {
      return emitFail(
        "emitProgram: function-value call arity has no interned signature",
      )
    }
    fbLocalGet(callRefSlot)
    fbStructGet(cloStructIdx, 0)
    fbRefCast(sig) // 0xfb 0x16 <fnsig> ref.cast funcref -> (ref $fnsig)
    fbCallRef(sig)
    return 0
  }
  emitFail("emitProgram: expected a call expression")
}

// ── statement-sequence lowering ──────────────────────────────────────────────
// A function body is a SEQUENCE of statements, lowered onto `body` in order. Only
// `return` and `if` are handled; `else if` chains fall out naturally because an
// `IfStmt`'s `ifElse` may itself be an `IfStmt` (lowered recursively). Control flow
// is kept simple by relying on explicit `return`s rather than block result types:
// a `return` leaves its value and emits the `return` instruction (0x0f), and an
// `if` is a VOID structured block (blocktype 0x40) whose branches `return` on their
// own — so the `if` never has to yield a value, and no block result type is needed.

// Lower an assignment `target = value` (a `BinExpr` whose `binOp` is `"="`) onto
// `body`: emit the value expression, then `local.set <index>` for the target local.
// The target must be a bare `Ident` naming a param or declared local (no member /
// indexed assignment in this slice). `local.set` consumes the value and leaves no
// result, so an assignment statement contributes nothing to the stack. Returns 0,
// or -1 (via `emitFail`) on a non-local / unsupported target.
//
// Node shapes read: BinExpr { binOp, binLeft, binRight }, target Ident { identName }.
function emitAssign(body: i32[], binIx: i32, fnIx: i32) {
  const a = P.nodes[binIx]
  if a is BinExpr {
    const target = P.nodes[a.binLeft]
    if target is Ident {
      const idx = localIndexOf(fnIx, target.identName)
      if idx < 0 {
        // Not a local — a module global? Store with `global.set` (0x24 <globalidx>).
        const gIdx = globalIndexOf(target.identName)
        if gIdx >= 0 {
          // Seed the assigned global's declared type context so the RHS literal builds the
          // SAME wasm type the cell expects (e.g. `globalNames = []` builds a STRING-list
          // wrapper, not the default i32-list; a struct global gets its annotated struct) —
          // mirroring the global-INIT seeding in the global section.
          const gLet = globalStmts[gIdx]
          if globalCellKind(gLet) == 1 {
            pendingStructIdx = globalCellStructIdx(gLet)
          }
          pendingListKind = letAnnRefListKind(gLet)
          pendingListSlot = letAnnRefListSlot(gLet)
          // A UNION-typed global (kind 4) coerces a raw assigned value into the
          // box (`w = 5` over `let w: string | i32` boxes the 5).
          const gUNm = letUnionNameOf(gLet, -1)
          if gUNm != "" {
            if emitUnionCoerce(body, gUNm, a.binRight, fnIx) < 0 { return -1 }
          } else if (
            exprString(a.binLeft, fnIx) &&
            exprIsLitAtom(a.binRight, fnIx)
          ) {
            // A literal-union atom assigned to a `string` global widens to its member string.
            if emitAtomToStr(body, a.binRight, fnIx) < 0 { return -1 }
          } else {
            // A `boolean | null` NICHE global: seed the sentinel for a `null` RHS; a
            // `string | null` global seeds the nullable-array ref; a nullable-CLOSURE
            // global (kind 19) seeds `ref.null $cloStruct` for a `null` RHS.
            const savedGNB = pendingNulBool
            const savedGNS = pendingNulString
            const savedGNC = pendingNulClosure
            if exprNulBool(a.binLeft, fnIx) { pendingNulBool = true }
            if exprNullableString(a.binLeft, fnIx) { pendingNulString = true }
            if exprNulClosure(a.binLeft, fnIx) { pendingNulClosure = true }
            if emitExpr(body, a.binRight, fnIx) < 0 { return -1 }
            pendingNulBool = savedGNB
            pendingNulString = savedGNS
            pendingNulClosure = savedGNC
          }
          pendingListKind = 0
          pendingListSlot = 0
          fbGlobalSet(gIdx) // 0x24 global.set
          return 0
        }
        return emitFail(
          "emitProgram: assignment target is not a parameter, local, or global",
        )
      }
      // A UNION-typed local (kind 4) coerces a raw assigned value into the box
      // (`u = 3.5` over `let u: i32 | f64` boxes the f64); a union-valued RHS
      // passes through unchanged. Value first, then store it into the slot.
      const aUNm = unionNameOfIdent(target.identName, fnIx)
      if aUNm != "" && !nameIsLitUnionType(aUNm) {
        // (a literal-union target is an i32 ATOM, not a value-union box — it falls through to the seed
        // block below, where the member RHS lowers as its interned id.)
        // A kind-4 union-BOX local boxes a concrete variant RHS (`u = s` where `u: C | S`,
        // `s: S`), exactly like a call arg / return — `emitUnionBoxArg` boxes a variant and
        // defers every other shape to `emitUnionCoerce`. A kind-8 variant-init local (`let u:
        // C | S = someVariant`) keeps the RAW variant rep, so it must NOT box — use the plain
        // coerce there.
        if declaredKind(target.identName) == 4 {
          if emitUnionBoxArg(body, aUNm, a.binRight, fnIx) < 0 { return -1 }
        } else {
          if emitUnionCoerce(body, aUNm, a.binRight, fnIx) < 0 { return -1 }
        }
      } else if exprIsI64(a.binLeft, fnIx) {
        // An i64 target (`x = 0` over `let x: i64`) widens an i32 RHS to i64 — without this the
        // bare `i32.const` clashes with the i64 slot (the checker accepts the assignment, so it
        // is a soundness hole). `emitExprAsI64` is a no-op for an already-i64 RHS.
        if emitExprAsI64(body, a.binRight, fnIx) < 0 { return -1 }
      } else if exprIsF64(a.binLeft, fnIx) {
        // An f64 target (`y = 3` over `let y: f64`) widens an i32 RHS to f64, same rationale.
        if emitExprAsF64(body, a.binRight, fnIx) < 0 { return -1 }
      } else if exprString(a.binLeft, fnIx) && exprIsLitAtom(a.binRight, fnIx) {
        // A literal-union atom assigned to a `string` local widens to its member string.
        if emitAtomToStr(body, a.binRight, fnIx) < 0 { return -1 }
      } else {
        // A `boolean | null` NICHE local (`x = null` / `x = b`): the i32 cell holds
        // 0/1 or the sentinel 2 — seed `pendingNulBool` so a `null` RHS emits the
        // sentinel (a boolean RHS is a `BoolLit`, untouched). A `string | null` local
        // seeds `pendingNulString` so a `null` RHS is `ref.null $aTypeIdx`. A nullable-
        // CLOSURE local (kind 19) seeds `pendingNulClosure` so a `null` RHS is
        // `ref.null $cloStruct` (a function RHS builds the non-null closure value).
        const savedNB = pendingNulBool
        const savedNS = pendingNulString
        const savedNC = pendingNulClosure
        const savedNL = pendingNulList
        const savedALU = pendingLitUnion
        if exprNulBool(a.binLeft, fnIx) { pendingNulBool = true }
        if exprNullableString(a.binLeft, fnIx) { pendingNulString = true }
        if exprNulClosure(a.binLeft, fnIx) { pendingNulClosure = true }
        if exprNullableList(a.binLeft, fnIx) { pendingNulList = true }
        // A literal-union local (`k = "b"`): the member RHS lowers as its interned i32 id.
        if exprIsLitAtom(a.binLeft, fnIx) { pendingLitUnion = 1 }
        if emitExpr(body, a.binRight, fnIx) < 0 { return -1 }
        pendingNulBool = savedNB
        pendingNulString = savedNS
        pendingNulClosure = savedNC
        pendingNulList = savedNL
        pendingLitUnion = savedALU
      }
      fbLocalSet(idx) // 0x21 local.set
      return 0
    }
    if target is Index {
      // G8: a map store `m[k] = v` — scan for `k`; overwrite `vals[hit]` on a hit, else
      // append `keys.push(k); vals.push(v)`. Checked BEFORE the list path (a map index
      // is not an array index).
      if exprMap(target.idxArr, fnIx) {
        return emitMapSet(body, target.idxArr, target.idxIndex, a.binRight, fnIx)
      }
      // Indexed store `a[i] = v`: unwrap the list to its backing (`struct.get $lTy 0`),
      // push the index, then the value, then `array.set $aTy` (`0xfb 0x0e <typeidx>`). A
      // REF list (G7-ref) stores a struct ref / union box (a subtype of the `(ref null
      // $elem)` slot) over the ref list/backing indices; an i32 list stores an i32.
      const isRef = exprRefArray(target.idxArr, fnIx)
      const isStr = exprStringArray(target.idxArr, fnIx)
      // The scalar non-i32 lists (`f64[]`/`i64[]`/`f32[]`): the SAME unwrap+`array.set` spine over
      // their own wrapper/backing, with the value coerced to the element valtype.
      const isF64 = exprF64Array(target.idxArr, fnIx)
      const isI64 = exprI64Array(target.idxArr, fnIx)
      const isF32 = exprF32Array(target.idxArr, fnIx)
      let lTy = lTypeIdx
      let aTy = aTypeIdx
      // A ref list of STRUCT elements (kind 1) types the stored value literal as the
      // list's declared element struct — seed `pendingStructIdx` (consumed by `emitObj`)
      // so `xs[i] = { … }` builds the element struct over a first-field-name match.
      let storeStructIdx = -1
      // A UNION-box element list (`(C | S)[]`, kind 2): the stored value boxes into the
      // shared `{tag, payload}` rep (`emitUnionBoxArg`), a variant widening like a call arg.
      let storeUnionNm = ""
      if isRef {
        if !rlUsed {
          return emitFail(
            "emitProgram: ref indexed assignment but ref list type not collected",
          )
        }
        let rslot = refListSlotOfExpr(target.idxArr, fnIx)
        lTy = rlWrapIdx[rslot]
        aTy = rlBackIdx[rslot]
        if rlElemKindTbl[rslot] == 1 {
          storeStructIdx = structIdxOfElemName(rlElemName[rslot])
        }
        if rlElemKindTbl[rslot] == 2 { storeUnionNm = rlElemName[rslot] }
      } else if isStr {
        // A STRING list `xs[i] = s`: unwrap to its `(ref null $aTypeIdx)` string backing
        // (`mkListIdx`/`mkArrIdx`) and store the string ref — mirroring `emitIndex`'s
        // string path. Without this branch a string-list target (e.g. the `string[]`
        // global `narrowNames[i] = name`) falls into the i32-list case below and
        // `struct.get`s the WRONG wrapper type (`lTypeIdx` instead of `mkListIdx`).
        if !slUsed {
          return emitFail(
            "emitProgram: string indexed assignment but string list type not collected",
          )
        }
        lTy = mkListIdx
        aTy = mkArrIdx
      } else if isF64 {
        if !fa64Used {
          return emitFail(
            "emitProgram: f64 indexed assignment but f64 list type not collected",
          )
        }
        lTy = fl64TypeIdx
        aTy = fa64TypeIdx
      } else if isI64 {
        if !ia64Used {
          return emitFail(
            "emitProgram: i64 indexed assignment but i64 list type not collected",
          )
        }
        lTy = il64TypeIdx
        aTy = ia64TypeIdx
      } else if isF32 {
        if !fa32Used {
          return emitFail(
            "emitProgram: f32 indexed assignment but f32 list type not collected",
          )
        }
        lTy = fl32TypeIdx
        aTy = fa32TypeIdx
      } else {
        if !lUsed {
          return emitFail("emitProgram: indexed assignment but list type not collected")
        }
        if !exprArray(target.idxArr, fnIx) {
          return emitFail("emitProgram: indexed-assignment target is not an array")
        }
      }
      if emitExpr(body, target.idxArr, fnIx) < 0 { return -1 }
      fbStructGet(lTy, 0) // 0xfb 0x02 <list wrapper struct type index> field 0: backing
      if emitExpr(body, target.idxIndex, fnIx) < 0 { return -1 }
      pendingStructIdx = storeStructIdx
      if storeUnionNm != "" {
        if emitUnionBoxArg(body, storeUnionNm, a.binRight, fnIx) < 0 {
          return -1
        }
      } else if isF64 {
        // The stored value re-encodes at the element valtype (a bare-int / int-literal value
        // widens into the f64 slot, exactly as a binding / push does).
        if emitExprAsF64(body, a.binRight, fnIx) < 0 { return -1 }
      } else if isI64 {
        if emitExprAsI64(body, a.binRight, fnIx) < 0 { return -1 }
      } else if isF32 {
        const savedPF32 = pendingF32
        pendingF32 = true
        if emitExprAsF32(body, a.binRight, fnIx) < 0 { return -1 }
        pendingF32 = savedPF32
      } else {
        if emitExpr(body, a.binRight, fnIx) < 0 { return -1 }
      }
      pendingStructIdx = -1
      fbArraySet(aTy) // 0xfb 0x0e <backing array type index>
      return 0
    }
    if target is Member {
      // A field WRITE on a NARROWED union identifier (`if v is M { v.field = x }`)
      // downcasts through the box like the READ path (`emitNarrowedMem`): push the
      // box ref, unbox to the variant struct (`ref.cast`), push the value, then
      // `struct.set` the variant field. The mutation hits the SHARED arena object
      // (the in-place hole-filling `typecheck.vl` relies on).
      if memIsNarrowed(a.binLeft) {
        const nvi = memNarrowVariantIndex(a.binLeft)
        if nvi < 0 {
          return emitFail(
            "emitProgram: narrowed field-assignment receiver names no variant",
          )
        }
        let nm = P.nodes[a.binLeft]
        if nm is Member {
          const nfi = variantFieldIndex(nvi, nm.memProp)
          if nfi < 0 {
            return emitFail(
              "emitProgram: unknown variant field in narrowed field assignment",
            )
          }
          if emitExpr(body, nm.memObj, fnIx) < 0 { return -1 }
          fbStructGet(uBoxIdx, 1)  // box field 1: value (anyref)
          fbRefCast(uVarIdx + nvi) // ref.cast to the variant struct
          if emitExpr(body, a.binRight, fnIx) < 0 { return -1 }
          fbStructSet(uVarIdx + nvi, nfi)
          return 0
        }
      }
      // A field WRITE on a VARIANT-TYPED PARAM (`o: TyObj`) writes the variant struct
      // directly (the param IS the unboxed variant ref — no box unwrap).
      const pwvi = exprVariantIndex(target.memObj, fnIx)
      if pwvi >= 0 {
        let m1 = P.nodes[a.binLeft]
        if m1 is Member {
          const pwfi = variantFieldIndex(pwvi, m1.memProp)
          if pwfi < 0 {
            return emitFail("emitProgram: unknown variant field in field assignment")
          }
          if emitExpr(body, m1.memObj, fnIx) < 0 { return -1 }
          if emitExpr(body, a.binRight, fnIx) < 0 { return -1 }
          fbStructSet(uVarIdx + pwvi, pwfi)
          return 0
        }
      }
      // Field WRITE `recv.field = v` → `struct.set $0 <fieldidx>` (`0xfb 0x05`). The
      // single declared struct lives at WasmGC type index 0 (matching `emitMem`'s read
      // path). Operand order is load-bearing: push the struct REF first, then the value,
      // then the `fb 05` opcode pops `[ref, value]` (same shape `emitPush` uses for the
      // list `backing`/`len`/`cap` field stores).
      if !sDeclared {
        return emitFail("emitProgram: field assignment but no struct type declared")
      }
      let si = structIndexOfExpr(target.memObj, fnIx)
      if si < 0 {
        return emitFail("emitProgram: field-assignment receiver is not a struct")
      }
      const fieldIdx = sFieldIndex(si, target.memProp)
      if fieldIdx < 0 {
        return emitFail("emitProgram: unknown struct field in field assignment")
      }
      if emitExpr(body, target.memObj, fnIx) < 0 {
        return -1 // struct ref first
      }
      // An empty `[]` for an array-typed field needs its element kind threaded so the
      // wrapper matches the field's declared type — the same `pendingListKind` an
      // annotated `let xs: T[] = []` or an object-literal array field uses (else the
      // empty literal defaults to the i32-list wrapper and the `struct.set` rejects it).
      pendingListKind = 0
      pendingListSlot = 0
      const fscode = sFieldTypeAt(si, fieldIdx)
      if fscode == 5 {
        let faslot = sFieldRefSlot(si, fieldIdx)
        if faslot < 0 { faslot = 0 }
        pendingListSlot = faslot
        if rlElemKindTbl[faslot] == 2 {
          pendingListKind = 2
        } else {
          pendingListKind = 1
        }
      } else if fscode == 6 {
        pendingListKind = 3
      }
      // A BOX-union field (code 16) coerces a raw scalar/struct/null RHS into the box; the
      // niche fields seed the null rep for a bare `null` RHS (`string | null` → `ref.null
      // $aTypeIdx`, `boolean | null` → the i32 sentinel 2). A non-null value passes through.
      if fscode == 16 {
        if (
          emitUnionCoerce(
            body,
            sFieldElemNameAt(si, fieldIdx),
            a.binRight,
            fnIx,
          ) <
          0
        ) {
          return -1
        }
      } else if fscode == 3 && exprIsLitAtom(a.binRight, fnIx) {
        // A literal-union atom assigned to a `string` field (code 3) widens to its member string.
        if emitAtomToStr(body, a.binRight, fnIx) < 0 { return -1 }
      } else {
        const savedWNS = pendingNulString
        const savedWNB = pendingNulBool
        if fscode == 20 { pendingNulString = true }
        if fscode == 21 { pendingNulBool = true }
        const rcW = emitExpr(body, a.binRight, fnIx) // then the value
        pendingNulString = savedWNS
        pendingNulBool = savedWNB
        if rcW < 0 { return -1 }
      }
      pendingListKind = 0
      fbStructSet(sHeapIdx[si], fieldIdx) // 0xfb 0x05 <struct ht> <field index>
      return 0
    }
    return emitFail("emitProgram: assignment target is not a simple name")
  }
  emitFail("emitProgram: expected an assignment expression")
}

// Lower a `recv.push(x)` member-call statement onto `body` — the growable-list append
// (mirroring `toWasm.ts`'s `__list_grow__`/`__list_push__`, but INLINED). `recv` must be
// a bare `Ident` naming a LIST local/param (so its `local.get` is side-effect-free and
// can be re-read), and the call takes exactly one i32 argument.
//
// The sequence, with `L` = the list local index and scratch locals `pushVal` (V),
// `pushNewCap` (NC), `pushNewBacking` (NB):
//   V = x                                              ; stash the value
//   if len(L) == cap(L) {                              ; grow when full
//     NC = (cap(L) == 0) ? 4 : cap(L) * 2              ; 2× growth, floor 4 (§VL.2)
//     NB = array.new_default $aTypeIdx NC              ; zero-init spare slots
//     array.copy NB 0 backing(L) 0 len(L)              ; copy the live elements
//     L.backing = NB ; L.cap = NC                      ; swap in the larger backing
//   }
//   backing(L)[len(L)] = V                             ; write at the end
//   L.len = len(L) + 1                                 ; bump the length
// `len`/`cap`/`backing` are `struct.get $lTy` of fields 1/2/0; the field setters are
// `struct.set $lTy`. `array.copy` is `0xfb 0x11 <dest> <src>` (both the backing array).
//
// G7-ref: a REF-list `.push` runs the IDENTICAL sequence over the ref list/backing type
// indices + ref scratch triple (`lTy = rlTypeIdx`, `aTy = raTypeIdx`, scratch base
// `refPushScratchBase`). The value is a struct ref / union box (emitted by the SAME
// `emitExpr`); `array.new_default` over the `(ref null $elem)` backing zero-inits spare
// slots to null, and `array.set` writes the non-null value (a subtype of the slot).
function emitPush(body: i32[], callIx: i32, fnIx: i32) {
  let c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      const recv = P.nodes[callee.memObj]
      // The receiver must PRODUCE a list — either a bare list local/param (`xs.push`) or
      // a struct-FIELD array read (`P.nodes.push`, gap #3). Both `exprArray`/`exprRefArray`
      // already classify a `Member` array-field read, so the only extra work for a field
      // receiver is to materialize its wrapper ref into the `recvRef` scratch slot.
      const isRef = exprRefArray(callee.memObj, fnIx)
      const isStr = exprStringArray(callee.memObj, fnIx)
      const isF64 = exprF64Array(callee.memObj, fnIx)
      const isI64 = exprI64Array(callee.memObj, fnIx)
      const isF32 = exprF32Array(callee.memObj, fnIx)
      if (
        !isRef &&
        !isStr &&
        !isF64 &&
        !isI64 &&
        !isF32 &&
        !exprArray(callee.memObj, fnIx)
      ) {
        return emitFail("emitProgram: .push receiver is not a list")
      }
      // Pick the list/backing type indices + scratch base for this push kind. A string
      // list (`string[]`) runs the IDENTICAL grow/append sequence over its wrapper/backing
      // (`mkListIdx`/`mkArrIdx`) + the string-push quad: `array.new_default` over the
      // `(ref null $aTypeIdx)` backing zero-inits spare slots to null, and `array.set`
      // writes the non-null string ref (a subtype of the slot).
      let lTy = lTypeIdx
      let aTy = aTypeIdx
      let base = pushScratchBase
      // A ref list of STRUCT elements (kind 1) types the pushed value literal as the
      // list's declared element struct — seed `pendingStructIdx` (consumed by `emitObj`)
      // so `xs.push({ … })` builds the element struct over a first-field-name match.
      let pushStructIdx = -1
      // A UNION-box element list (`(C | S)[]`, kind 2): the pushed value is boxed into the
      // shared `{tag, payload}` rep (`emitUnionBoxArg`) — a concrete variant widens like a
      // call arg, a literal boxes via `emitUnionBox`. "" for a non-union element.
      let pushUnionNm = ""
      if isRef {
        if !rlUsed {
          return emitFail("emitProgram: ref .push but ref list type not collected")
        }
        let rslot = refListSlotOfExpr(callee.memObj, fnIx)
        lTy = rlWrapIdx[rslot]
        aTy = rlBackIdx[rslot]
        base = refPushScratchBaseFor(rslot)
        if rlElemKindTbl[rslot] == 1 {
          pushStructIdx = structIdxOfElemName(rlElemName[rslot])
        }
        if rlElemKindTbl[rslot] == 2 { pushUnionNm = rlElemName[rslot] }
      } else if isStr {
        if !slUsed {
          return emitFail("emitProgram: string .push but string list type not collected")
        }
        lTy = mkListIdx
        aTy = mkArrIdx
        base = strPushScratchBase
      } else if isF64 {
        // An f64-list push runs the SAME grow/append over the f64 wrapper/backing,
        // staged in the f64-typed push quad (`pushF64Val` is an f64 local).
        if !fa64Used {
          return emitFail("emitProgram: f64 .push but f64 list type not collected")
        }
        lTy = fl64TypeIdx
        aTy = fa64TypeIdx
        base = f64PushScratchBase
      } else if isI64 {
        // An i64-list push: the SAME grow/append over the i64 wrapper/backing, staged in
        // the i64-typed push quad (`pushI64Val` is an i64 local).
        if !ia64Used {
          return emitFail("emitProgram: i64 .push but i64 list type not collected")
        }
        lTy = il64TypeIdx
        aTy = ia64TypeIdx
        base = i64PushScratchBase
      } else if isF32 {
        // An f32-list push: the SAME grow/append over the f32 wrapper/backing, staged in
        // the f32-typed push quad (`pushF32Val` is an f32 local).
        if !fa32Used {
          return emitFail("emitProgram: f32 .push but f32 list type not collected")
        }
        lTy = fl32TypeIdx
        aTy = fa32TypeIdx
        base = f32PushScratchBase
      } else if !lUsed {
        return emitFail("emitProgram: .push but list type not collected")
      }
      // Resolve the receiver to a wasm local index holding the list-wrapper ref. A bare
      // identifier IS such a local. A struct-FIELD receiver (`P.nodes`) is evaluated once
      // into the `recvRef` scratch slot (`base + 3`); because the wrapper is mutated IN
      // PLACE by reference, pushing through the scratch local also mutates the field's
      // list — no write-back needed.
      let lIdx = -1
      if recv is Ident {
        lIdx = localIndexOf(fnIx, recv.identName)
        if lIdx < 0 {
          // Not a local — a module-GLOBAL list ident? Materialize its wrapper ref into
          // the `recvRef` scratch slot (`base + 3`), IDENTICALLY to the Member path:
          // `emitExpr` on the receiver runs the existing Ident→global read (`global.get`
          // + `ref.as_non_null` for a non-const ref cell). Because the list wrapper is
          // mutated IN PLACE by reference, pushing through the scratch local also mutates
          // the global's list — and growth swaps the backing on the shared wrapper — so
          // no write-back to the global is needed.
          if globalIndexOf(recv.identName) < 0 {
            return emitFail("emitProgram: .push receiver is not a list local")
          }
          if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
          fbLocalSet(base + 3) // local.set recvRef
          lIdx = base + 3
        }
      } else if recv is Member {
        if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
        fbLocalSet(base + 3) // local.set recvRef
        lIdx = base + 3
      } else if recv is Index {
        // An INDEXED receiver (`g[0].push(x)` — push onto an INNER list of a nested array, or onto a
        // list read from a list-valued map). Evaluate the indexed wrapper ref once into the `recvRef`
        // scratch slot, exactly like the struct-field path: the wrapper is mutated IN PLACE (and a
        // growth swaps the backing on that same shared wrapper), so the mutation is visible through
        // the outer array / map with no write-back. The classifiers above already recognize a nested
        // `g[i]` read as its inner list, so `lTy`/`aTy`/`base` are the inner list's.
        if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
        fbLocalSet(base + 3) // local.set recvRef
        lIdx = base + 3
      } else {
        return emitFail(
          "emitProgram: .push receiver must be a local, struct field, or index",
        )
      }
      if true {
        if c.callArgs.length != 1 {
          return emitFail("emitProgram: .push takes exactly one argument")
        }
        const valIdx = base
        const capIdx = base + 1
        const backIdx = base + 2
        // V = x  (an f64-list push coerces/encodes the value as f64)
        pendingStructIdx = pushStructIdx
        if isF64 {
          if emitExprAsF64(body, c.callArgs[0], fnIx) < 0 { return -1 }
        } else if isI64 {
          if emitExprAsI64(body, c.callArgs[0], fnIx) < 0 { return -1 }
        } else if isF32 {
          // an f32-list push coerces/encodes the value as f32 (a float literal re-encodes).
          const savedPF32 = pendingF32
          pendingF32 = true
          if emitExprAsF32(body, c.callArgs[0], fnIx) < 0 { return -1 }
          pendingF32 = savedPF32
        } else if pushUnionNm != "" {
          if emitUnionBoxArg(body, pushUnionNm, c.callArgs[0], fnIx) < 0 {
            return -1
          }
        } else {
          if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
        }
        pendingStructIdx = -1
        fbLocalSet(valIdx) // local.set
        // if len(L) == cap(L)
        pushListLen(body, lIdx, lTy)
        pushListCap(body, lIdx, lTy)
        fbI32Bin(70) // 0x46 i32.eq
        fbIf(64)     // 0x04 if, 0x40 void blocktype
        // NC = (cap(L) == 0) ? 4 : cap(L) * 2   — via if/else yielding i32
        pushListCap(body, lIdx, lTy)
        fbI32Eqz()         // 0x45 i32.eqz  (cap == 0)
        fbIf(127)          // 0x04 if, 0x7f i32 blocktype (yields an i32)
        fbI32Const(4)      // i32.const 4
        fbElse()           // 0x05 else
        pushListCap(body, lIdx, lTy)
        fbI32Const(2)      // i32.const 2
        fbI32Bin(108)      // 0x6c i32.mul
        fbEnd()            // 0x0b end (if/else)
        fbLocalSet(capIdx) // local.set NC
        // NB = array.new_default $aTy NC
        fbLocalGet(capIdx)     // local.get NC
        fbArrayNewDefault(aTy) // 0xfb 0x07 <aTy>
        fbLocalSet(backIdx)    // local.set NB
        // array.copy NB 0 backing(L) 0 len(L)
        fbLocalGet(backIdx)              // local.get NB (dest)
        fbI32Const(0)                    // i32.const 0 (dest offset)
        pushListBacking(body, lIdx, lTy) // src
        fbI32Const(0)                    // i32.const 0 (src offset)
        pushListLen(body, lIdx, lTy)     // count
        fbArrayCopy(aTy, aTy)            // 0xfb 0x11 <dest type> <src type>
        // L.backing = NB
        fbLocalGet(lIdx)    // local.get L
        fbLocalGet(backIdx) // local.get NB
        fbStructSet(lTy, 0) // 0xfb 0x05 <lTy> field 0: backing
        // L.cap = NC
        fbLocalGet(lIdx)    // local.get L
        fbLocalGet(capIdx)  // local.get NC
        fbStructSet(lTy, 2) // 0xfb 0x05 <lTy> field 2: cap
        fbEnd()             // 0x0b end (if)
        // backing(L)[len(L)] = V
        pushListBacking(body, lIdx, lTy)
        pushListLen(body, lIdx, lTy)
        fbLocalGet(valIdx) // local.get V
        fbArraySet(aTy)    // 0xfb 0x0e <aTy>
        // L.len = len(L) + 1
        fbLocalGet(lIdx)    // local.get L
        pushListLen(body, lIdx, lTy)
        fbI32Const(1)       // i32.const 1
        fbI32Bin(106)       // 0x6a i32.add
        fbStructSet(lTy, 1) // 0xfb 0x05 <lTy> field 1: len
        return 0
      }
    }
  }
  emitFail("emitProgram: expected a .push call")
}

// Lower a `.pop()` value-position call onto `body`: remove + return the list's last
// element. Generic over the list kind — picks the wrapper/backing type indices the same
// way `.push` does (i32 list, REF list `T[]`/`N[]`/`{[string]:i32}[]`, or string list).
// Sequence (no scratch — the receiver is a bare local, referenced repeatedly):
//   L.len = len - 1            (decrement first, so the new len IS the popped index)
//   push backing[L.len]        (the removed element; `ref.as_non_null` for a ref/string
//                               element so a non-null struct/union/map/string surfaces)
// The receiver must be a bare list local. An empty-list pop is the caller's contract
// (reading `backing[-1]` would trap) — matched to the host semantics of `.pop()`.
function emitPop(body: i32[], callIx: i32, fnIx: i32) {
  let c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      const recv = P.nodes[callee.memObj]
      if c.callArgs.length != 0 {
        return emitFail("emitProgram: .pop takes no arguments")
      }
      const isRef = exprRefArray(callee.memObj, fnIx)
      const isStr = exprStringArray(callee.memObj, fnIx)
      if !isRef && !isStr && !exprArray(callee.memObj, fnIx) {
        return emitFail("emitProgram: .pop receiver is not a list")
      }
      // The popped element is a REF (struct / union box / map struct / string) for a
      // ref or string list — surface it non-null; an i32 list yields a raw i32. `base` is
      // the scratch frame whose `+3` `recvRef` slot holds a struct-FIELD receiver's wrapper
      // ref (same frame `.push` uses) — used only for a Member receiver.
      let lTy = lTypeIdx
      let aTy = aTypeIdx
      let base = pushScratchBase
      let elemIsRef = false
      if isRef {
        if !rlUsed {
          return emitFail("emitProgram: ref .pop but ref list type not collected")
        }
        let rslot = refListSlotOfExpr(callee.memObj, fnIx)
        lTy = rlWrapIdx[rslot]
        aTy = rlBackIdx[rslot]
        base = refPushScratchBaseFor(rslot)
        elemIsRef = true
      } else if isStr {
        if !slUsed {
          return emitFail("emitProgram: string .pop but string list type not collected")
        }
        lTy = mkListIdx
        aTy = mkArrIdx
        base = strPushScratchBase
        elemIsRef = true
      } else if !lUsed {
        return emitFail("emitProgram: .pop but list type not collected")
      }
      // Resolve the receiver to a wasm local holding the list-wrapper ref. A bare local IS
      // that local; a struct-FIELD receiver (`T.scopes`) is evaluated ONCE into the frame's
      // `recvRef` scratch (`base + 3`) — the wrapper is mutated in place by reference, so no
      // write-back is needed (mirrors `emitPush`).
      let lIdx = -1
      if recv is Ident {
        lIdx = localIndexOf(fnIx, recv.identName)
        if lIdx < 0 {
          // Not a local — a module-GLOBAL list ident? Materialize its wrapper ref into
          // the `recvRef` scratch slot (`base + 3`), IDENTICALLY to the Member path (and
          // to `emitPush`): `emitExpr` runs the existing Ident→global read; the wrapper is
          // mutated in place by reference, so no write-back to the global is needed.
          if globalIndexOf(recv.identName) < 0 {
            return emitFail("emitProgram: .pop receiver is not a list local")
          }
          if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
          fbLocalSet(base + 3) // local.set recvRef
          lIdx = base + 3
        }
      } else if recv is Member {
        if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
        fbLocalSet(base + 3) // local.set recvRef
        lIdx = base + 3
      } else {
        return emitFail("emitProgram: .pop receiver must be a local or struct field")
      }
      if true {
        // A BOOLEAN-element list pops CHECKED: `boolean | null` rides the i32
        // niche (true=1 / false=0 / null=2), so an empty pop yields the sentinel
        // 2 instead of trapping — mirroring the host's nullable `.pop()` (B6).
        if !elemIsRef {
          if listElemIsBool(callee.memObj, fnIx) {
            pushListLen(body, lIdx, lTy) // cond: len != 0
            fbIf(127)                    // 0x04 if, 0x7f i32 result blocktype
            ctrlEnter()
            fbLocalGet(lIdx)             // L.len = len - 1
            pushListLen(body, lIdx, lTy)
            fbI32Const(1)
            fbI32Bin(107)                // 0x6b i32.sub
            fbStructSet(lTy, 1)          // field 1: len
            pushListBacking(body, lIdx, lTy)
            pushListLen(body, lIdx, lTy)
            fbArrayGet(aTy)              // the popped element (0/1)
            fbElse()                     // 0x05 else — empty → the null sentinel
            fbI32Const(2)
            fbEnd()                      // 0x0b end
            ctrlLeave()
            return 0
          }
        }
        // L.len = len - 1
        fbLocalGet(lIdx)    // local.get L
        pushListLen(body, lIdx, lTy)
        fbI32Const(1)       // i32.const 1
        fbI32Bin(107)       // 0x6b i32.sub
        fbStructSet(lTy, 1) // 0xfb 0x05 <lTy> field 1: len
        // backing[L.len]  (the just-decremented len is the popped element's index)
        pushListBacking(body, lIdx, lTy)
        pushListLen(body, lIdx, lTy)
        fbArrayGet(aTy) // 0xfb 0x0b <aTy>
        if elemIsRef {
          wU8(212) // 0xd4 ref.as_non_null
        }
        return 0
      }
    }
  }
  emitFail("emitProgram: expected a .pop call")
}

// Lower a `.clear()` STATEMENT onto `body`: reset the list's logical length to 0,
// RETAINING the backing (a refill reuses it; cap is untouched) — mirroring the
// host's `.clear()` (B6). Generic over the list kind, with `emitPop`'s receiver
// resolution (bare local, module global, or struct field via the `recvRef` scratch).
function emitClear(body: i32[], callIx: i32, fnIx: i32) {
  let c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      if c.callArgs.length != 0 {
        return emitFail("emitProgram: .clear takes no arguments")
      }
      const recv = P.nodes[callee.memObj]
      const isRef = exprRefArray(callee.memObj, fnIx)
      const isStr = exprStringArray(callee.memObj, fnIx)
      if !isRef && !isStr && !exprArray(callee.memObj, fnIx) {
        return emitFail("emitProgram: .clear receiver is not a list")
      }
      let lTy = lTypeIdx
      let base = pushScratchBase
      if isRef {
        if !rlUsed {
          return emitFail("emitProgram: ref .clear but ref list type not collected")
        }
        let rslot = refListSlotOfExpr(callee.memObj, fnIx)
        lTy = rlWrapIdx[rslot]
        base = refPushScratchBaseFor(rslot)
      } else if isStr {
        if !slUsed {
          return emitFail("emitProgram: string .clear but string list type not collected")
        }
        lTy = mkListIdx
        base = strPushScratchBase
      } else if !lUsed {
        return emitFail("emitProgram: .clear but list type not collected")
      }
      let lIdx = -1
      if recv is Ident {
        lIdx = localIndexOf(fnIx, recv.identName)
        if lIdx < 0 {
          if globalIndexOf(recv.identName) < 0 {
            return emitFail("emitProgram: .clear receiver is not a list local")
          }
          if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
          fbLocalSet(base + 3) // local.set recvRef
          lIdx = base + 3
        }
      } else if recv is Member {
        if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
        fbLocalSet(base + 3) // local.set recvRef
        lIdx = base + 3
      } else {
        return emitFail("emitProgram: .clear receiver must be a local or struct field")
      }
      // L.len = 0
      fbLocalGet(lIdx)
      fbI32Const(0)
      fbStructSet(lTy, 1) // 0xfb 0x05 <lTy> field 1: len
      return 0
    }
  }
  emitFail("emitProgram: expected a .clear call")
}

// Lower a checked `.get(i)` over a STRUCT-element ref list onto `body`, leaving a
// `(ref null $S)` on the stack: in-bounds yields the backing slot as-is (already
// nullable-widened), out-of-bounds `ref.null $S` — `xs.get(9)` is `null`, mirroring
// the host's checked list read. ONE unsigned compare (`idx u< len`) covers both the
// negative and the past-len cases. The receiver and index are each emitted twice
// (the bounds check + the read), so both must be PURE re-reads: a bare name receiver
// and a literal/name index — anything else fails loudly.
function emitListGet(body: i32[], callIx: i32, fnIx: i32) {
  let c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      if c.callArgs.length != 1 {
        return emitFail("emitProgram: .get takes exactly one argument")
      }
      if structListPopGetElem(callIx, fnIx) < 0 || !rlUsed {
        return emitFail("emitProgram: .get receiver is not a struct list")
      }
      let rslot = refListSlotOfExpr(callee.memObj, fnIx)
      const elemHeap = rlElemHeap[rslot]
      const recvN = P.nodes[unwrapParen(callee.memObj)]
      let okRecv = false
      if recvN is Ident { okRecv = true }
      if !okRecv {
        return emitFail("emitProgram: .get receiver must be a named list binding")
      }
      const idxN = P.nodes[unwrapParen(c.callArgs[0])]
      let okIdx = false
      if idxN is NumLit { okIdx = true }
      if idxN is Ident { okIdx = true }
      if !okIdx {
        return emitFail("emitProgram: .get index must be a literal or a name")
      }
      // cond: idx u< len
      if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
      if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
      fbStructGet(rlWrapIdx[rslot], 1) // field 1: len
      fbI32Bin(73)                     // 0x49 i32.lt_u
      // if (result (ref null $elem))
      wU8(4)                           // 0x04 if
      wU8(99)                          // 0x63 (ref null ht) result blocktype
      wSLEB(elemHeap)
      ctrlEnter()
      if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
      fbStructGet(rlWrapIdx[rslot], 0) // field 0: backing
      if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
      fbArrayGet(rlBackIdx[rslot])     // -> (ref null $elem)
      fbElse()                         // 0x05 else
      wU8(208)                         // 0xd0 ref.null
      wSLEB(elemHeap)
      fbEnd()                          // 0x0b end
      ctrlLeave()
      return 0
    }
  }
  emitFail("emitProgram: expected a .get call")
}

// True if the list at `arrIx` carries BOOLEAN elements: a `[true, ...]` literal, a
// `boolean[]` annotation, a name tracing to either (local let or module global), or
// a `.map`/`.filter` result whose callback returns boolean (`mfArrElemIsBool`).
// Boolean elements ride the i32 list rep (0/1), with the spare value 2 encoding the
// `boolean | null` of a checked `.pop()` — the niche sentinel, mirroring the host.
function listElemIsBool(arrIx: i32, fnIx: i32) {
  if arrIx < 0 { return false }
  const inner = unwrapParen(arrIx)
  const e = P.nodes[inner]
  if e is ArrayLit {
    if e.arrElems.length > 0 { return exprIsBool(e.arrElems[0], fnIx) }
    return false
  }
  if e is Ident {
    let li = -1
    if fnIx >= 0 {
      const fn = P.nodes[fnIx]
      if fn is FuncDecl { li = parentLetOf(fn.fnBody, e.identName) }
    }
    if li < 0 { li = globalLetOf(e.identName) }
    if li >= 0 {
      let d = P.nodes[li]
      if d is LetDecl {
        if d.letType >= 0 {
          const lt = P.nodes[d.letType]
          if lt is TypeRef {
            if lt.tyName == "boolean[]" { return true }
          }
        }
        if d.letInit >= 0 {
          if unwrapParen(d.letInit) != inner {
            return listElemIsBool(d.letInit, fnIx)
          }
        }
      }
    }
    return false
  }
  mfArrElemIsBool(arrIx, fnIx)
}

// True if `name` is a binding whose initializer is a checked `.pop()` over a
// BOOLEAN-element list — its i32 cell holds 0/1 or the niche sentinel 2 (`null`),
// so a later `name ?? d` must compare against 2, not test a ref.
function identNullableBoolPop(name: string, fnIx: i32) {
  let li = -1
  if fnIx >= 0 {
    const fn = P.nodes[fnIx]
    if fn is FuncDecl { li = parentLetOf(fn.fnBody, name) }
  }
  if li < 0 { li = globalLetOf(name) }
  if li >= 0 {
    let d = P.nodes[li]
    if d is LetDecl {
      if d.letInit >= 0 {
        const ini = P.nodes[unwrapParen(d.letInit)]
        if ini is Call {
          const callee = P.nodes[ini.callFn]
          if callee is Member {
            if callee.memProp == "pop" {
              return listElemIsBool(callee.memObj, fnIx)
            }
          }
        }
      }
    }
  }
  false
}

// Lower a FUSED `xs.get(i) ?? d` over a SCALAR-element list (i32 / boolean / f64)
// onto `body`: ONE unsigned bounds compare (`i u< len`) selects the element read or
// the default — the `T | null` intermediate never materializes (the host's checked
// `.get` composed with `??` reduces to the same branch). The receiver must be a
// bare name and the index a literal/name — both are re-read (bounds check + read).
function emitListGetOr(body: i32[], getIx: i32, defIx: i32, fnIx: i32) {
  let c = P.nodes[getIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      if c.callArgs.length != 1 {
        return emitFail("emitProgram: .get takes exactly one argument")
      }
      // The scalar element kind (i32 / f64 / i64) selects the list types + read rep — one
      // descriptor lookup instead of an `isF64 ? … : …` fork (so i64 is a descriptor arm).
      const ek = scalarListElemKind(callee.memObj, fnIx)
      if ek < 0 {
        return emitFail("emitProgram: .get receiver is not a scalar list")
      }
      if !scalarListUsed(ek) {
        return emitFail("emitProgram: .get but list type not collected")
      }
      const lTy = scalarListWrap(ek)
      const aTy = scalarListBack(ek)
      const recvN = P.nodes[unwrapParen(callee.memObj)]
      let okRecv = false
      if recvN is Ident { okRecv = true }
      if !okRecv {
        return emitFail("emitProgram: .get receiver must be a named list binding")
      }
      const idxN = P.nodes[unwrapParen(c.callArgs[0])]
      let okIdx = false
      if idxN is NumLit { okIdx = true }
      if idxN is Ident { okIdx = true }
      if idxN is Unary {
        // A NEGATIVE literal index (`xs.get(-1)`) is pure too — the unsigned
        // bounds compare maps it past `len`, so it takes the default branch.
        if idxN.unOp == "-" {
          const idxArgN = P.nodes[unwrapParen(idxN.unArg)]
          if idxArgN is NumLit { okIdx = true }
        }
      }
      if !okIdx {
        return emitFail("emitProgram: .get index must be a literal or a name")
      }
      // cond: idx u< len  (one unsigned compare covers negative + past-len)
      if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
      if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
      fbStructGet(lTy, 1)           // field 1: len
      fbI32Bin(73)                  // 0x49 i32.lt_u
      fbIf(scalarListBlocktype(ek)) // 0x04 if, the element's result blocktype
      ctrlEnter()
      if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
      fbStructGet(lTy, 0)           // field 0: backing
      if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
      fbArrayGet(aTy)               // 0xfb 0x0b array.get — the element
      fbElse()                      // 0x05 else
      if emitScalarValue(body, defIx, fnIx, ek) < 0 { return -1 }
      fbEnd()                       // 0x0b end
      ctrlLeave()
      return 0
    }
  }
  emitFail("emitProgram: expected a list .get call")
}

// Lower a FUSED `xs.pop() ?? d` over a SCALAR-element (i32 / boolean) list onto
// `body`: `len != 0` selects the decrement-and-read (the popped element) or the
// default. The receiver resolves like `emitPop` (bare local, module global, or
// struct field — the latter two staged into the push frame's `recvRef` scratch).
function emitPopOr(body: i32[], popIx: i32, defIx: i32, fnIx: i32) {
  let c = P.nodes[popIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      if c.callArgs.length != 0 {
        return emitFail("emitProgram: .pop takes no arguments")
      }
      if !lUsed {
        return emitFail("emitProgram: .pop but list type not collected")
      }
      const recv = P.nodes[callee.memObj]
      let lTy = lTypeIdx
      let aTy = aTypeIdx
      let base = pushScratchBase
      let lIdx = -1
      if recv is Ident {
        lIdx = localIndexOf(fnIx, recv.identName)
        if lIdx < 0 {
          if globalIndexOf(recv.identName) < 0 {
            return emitFail("emitProgram: .pop receiver is not a list local")
          }
          if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
          fbLocalSet(base + 3) // local.set recvRef
          lIdx = base + 3
        }
      } else if recv is Member {
        if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
        fbLocalSet(base + 3) // local.set recvRef
        lIdx = base + 3
      } else {
        return emitFail("emitProgram: .pop receiver must be a local or struct field")
      }
      // cond: len != 0 (len is never negative)
      pushListLen(body, lIdx, lTy)
      fbIf(127) // 0x04 if, 0x7f i32 result blocktype
      ctrlEnter()
      // L.len = len - 1; backing[L.len]
      fbLocalGet(lIdx)
      pushListLen(body, lIdx, lTy)
      fbI32Const(1)
      fbI32Bin(107)       // 0x6b i32.sub
      fbStructSet(lTy, 1) // field 1: len
      pushListBacking(body, lIdx, lTy)
      pushListLen(body, lIdx, lTy)
      fbArrayGet(aTy)     // the popped element
      fbElse()            // 0x05 else — empty list → the default
      if emitExpr(body, defIx, fnIx) < 0 { return -1 }
      fbEnd()             // 0x0b end
      ctrlLeave()
      return 0
    }
  }
  emitFail("emitProgram: expected a list .pop call")
}

// Lower a `.map`/`.filter` HOF call onto `body`, leaving the RESULT list wrapper ref
// on the stack. Mirrors the host's `lowerMapMethodCall` (`toWasm.ts:2143–2245`) over
// the `call_ref` closure ABI — the generic closure-calling loop ONLY (the inline
// desugar of single-expression callbacks is a documented non-goal; `vl build -O`
// devirtualizes + inlines it):
//   map:    n = len(src); back = array.new_default(<outElemArr>, n)
//           for i in 0..n:  back[i] = call_ref(clo, [elem(i)])
//           result = wrapper{ back, n, n }
//   filter: n = len(src); back = array.new_default(<elemArr>, n); j = 0
//           for i in 0..n:  if call_ref(clo, [elem(i)]): back[j] = elem(i); j++
//           result = wrapper{ back, j, n }          // len = j, cap = n
// The receiver is evaluated ONCE into the typed src slot; the callback's closure
// value is built ONCE before the loop (an inline literal / named function emits
// `emitClosureValue`; a let-bound value reads its binding). `filter` re-reads
// `elem(i)` off the src backing for the survivor store (a pure re-read — the host
// materializes it the same way). The result element kind is the callback's RETURN
// kind for `map` (an i32→bool callback yields a bool/i32-element list; an f64
// callback the f64 backing + wrapper), the receiver's element kind for `filter`.
// The interned `$fnsig` KEY of a `.map`/`.filter` callback that is a CLOSURE VALUE — a function-typed
// param or binding (`xs.map(f)` with `f: (i32) => i32`), NOT a literal lambda / named function (those
// resolve a lifted `mfCallbackFe`). "" otherwise. Lets `.map`/`.filter` accept a runtime callback (the
// `call_ref` loop already does), so a higher-order function can forward a callback to `.map`.
function mfCallbackCloKey(cbIx: i32, fnIx: i32) {
  const cb = P.nodes[unwrapParen(cbIx)]
  if cb is Ident {
    if fnIndexOf(cb.identName) >= 0 {
      return "" // a named fn — uses the lifted-fe path
    }
    return calleeCloSigKey(cb.identName, fnIx)
  }
  ""
}

// Map a closure SIG-RETURN kind (`sigKeyRetKind`) to a `.map` RESULT element kind (`mfResultKindOf`'s
// codes), for a closure-value callback. A STRUCT return (1) maps to a ref-list result (2) — its slot
// comes from `mfResultSlotOf`'s closure-value branch. -1 for a void / still-unwired ref kind.
function mfResKindFromSigRet(k: i32) {
  if k == 0 {
    return 0 // i32
  }
  if k == 11 {
    return 1 // f64 (mf result kind 1)
  }
  if k == 10 {
    return 4 // i64 (mf result kind 4)
  }
  if k == 3 {
    return 3 // string
  }
  if k == 1 {
    return 2 // struct → a NEW ref list of the result struct (slot via `mfResultSlotOf`)
  }
  -1
}

// The struct-TABLE index in a closure sig key's `>s<idx>;` result token (a struct-returning callback),
// or -1. The struct dual of `sigKeyRetSlot` (which parses the `>r<slot>;` ref-list token).
function sigKeyRetStructIdx(k: string) {
  const n = k.length
  let gt = -1
  let i = 0
  while i < n {
    if k[i] == '>' { gt = i }
    i = i + 1
  }
  if gt < 0 || gt + 2 >= n { return -1 }
  if k[gt + 1] != 's' { return -1 }
  let j = gt + 2
  let acc = 0
  let saw = false
  while j < n && k[j] != ';' {
    const d = k[j]
    if d < '0' || d > '9' { return -1 }
    acc = acc * 10 + (d - '0')
    saw = true
    j = j + 1
  }
  if !saw { return -1 }
  acc
}

function emitMapFilter(body: i32[], callIx: i32, fnIx: i32) {
  let c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      const isMap = callee.memProp == "map"
      if c.callArgs.length != 1 {
        return emitFail("emitProgram: .map/.filter takes exactly one callback argument")
      }
      const recvK = mfRecvKindOf(callee.memObj, fnIx)
      if recvK < 0 {
        return emitFail("emitProgram: .map/.filter receiver is not a supported list")
      }
      const resK = mfResultKindOf(callIx, fnIx)
      if resK < 0 {
        return emitFail("emitProgram: unsupported .map/.filter element type")
      }
      // The ref-list slot for a kind-2 result (`.filter` over a struct array) — picks the
      // result backing/wrapper + the matching dst scratch local. -1 for a non-ref result.
      const dstSlot = mfResultSlotOf(callIx, fnIx)
      const cbFe = mfCallbackFe(c.callArgs[0], fnIx)
      let sig = -1
      if cbFe >= 0 {
        sig = fnSigIdxOfFn(cbFe)
      } else {
        // A CLOSURE-VALUE callback (a function-typed param/binding — `xs.map(f)` where
        // `f: (i32) => i32`): no lifted fe to inline, so resolve the interned sig from the closure's
        // own `$fnsig` key. The loop `call_ref`s the closure value (emitted into `cL` below via the
        // Ident path) exactly as for a named-function callback — enabling callback-passing HOFs.
        const ck = mfCallbackCloKey(c.callArgs[0], fnIx)
        if ck != "" {
          const cp = cloSigPosOfKey(ck)
          if cp >= 0 { sig = cloSigBase + cp }
        }
      }
      if sig < 0 {
        return emitFail("emitProgram: .map/.filter callback signature is not interned")
      }
      // The SOURCE wrapper/backing heap types (+ whether the element is a ref that
      // needs `ref.as_non_null` after `array.get`).
      let srcWrap = lTypeIdx
      let srcBack = aTypeIdx
      let srcElemRef = false
      let srcSlot = -1
      if recvK == 1 {
        if !fa64Used {
          return emitFail(
            "emitProgram: .map/.filter over f64[] but f64 list type not collected",
          )
        }
        srcWrap = fl64TypeIdx
        srcBack = fa64TypeIdx
      } else if recvK == 4 {
        if !ia64Used {
          return emitFail(
            "emitProgram: .map/.filter over i64[] but i64 list type not collected",
          )
        }
        srcWrap = il64TypeIdx
        srcBack = ia64TypeIdx
      } else if recvK == 13 {
        if !fa32Used {
          return emitFail(
            "emitProgram: .map/.filter over f32[] but f32 list type not collected",
          )
        }
        srcWrap = fl32TypeIdx
        srcBack = fa32TypeIdx
      } else if recvK == 2 {
        if !rlUsed {
          return emitFail(
            "emitProgram: .map/.filter over a ref list but ref list type not collected",
          )
        }
        srcSlot = refListSlotOfExpr(callee.memObj, fnIx)
        srcWrap = rlWrapIdx[srcSlot]
        srcBack = rlBackIdx[srcSlot]
        srcElemRef = true
      } else if recvK == 3 {
        // A STRING list: wrapper `$mkListIdx`, backing `$mkArrIdx` (the array of string
        // refs). The element is itself a ref (an `array i32` of code points), so it needs
        // `ref.as_non_null` after `array.get`, exactly like a ref-list element.
        if !slUsed {
          return emitFail(
            "emitProgram: .map/.filter over string[] but string list type not collected",
          )
        }
        srcWrap = mkListIdx
        srcBack = mkArrIdx
        srcElemRef = true
      } else if !lUsed || !aUsed {
        return emitFail("emitProgram: .map/.filter but list type not collected")
      }
      // The RESULT wrapper/backing heap types.
      let dstWrap = lTypeIdx
      let dstBack = aTypeIdx
      if resK == 1 {
        if !fa64Used {
          return emitFail(
            "emitProgram: .map result is f64[] but f64 list type not collected",
          )
        }
        dstWrap = fl64TypeIdx
        dstBack = fa64TypeIdx
      } else if resK == 4 {
        if !ia64Used {
          return emitFail(
            "emitProgram: .map result is i64[] but i64 list type not collected",
          )
        }
        dstWrap = il64TypeIdx
        dstBack = ia64TypeIdx
      } else if resK == 13 {
        if !fa32Used {
          return emitFail(
            "emitProgram: .map result is f32[] but f32 list type not collected",
          )
        }
        dstWrap = fl32TypeIdx
        dstBack = fa32TypeIdx
      } else if resK == 3 {
        // A STRING-list result: a `.filter` over a string list, or a `.map` whose callback
        // returns a string. The backing `$mkArrIdx` holds string refs; `array.set` stores
        // the callback's (non-null) string result directly.
        if !slUsed {
          return emitFail(
            "emitProgram: .map/.filter result is string[] but string list type not collected",
          )
        }
        dstWrap = mkListIdx
        dstBack = mkArrIdx
      } else if resK == 2 {
        // A REF-list result (a `.filter` over a struct/union array preserves the element type):
        // the result is the SAME ref list as the source, so its wrapper/backing come from the
        // result slot (== the source slot for `.filter`).
        if !rlUsed {
          return emitFail(
            "emitProgram: .filter result is a ref list but ref list type not collected",
          )
        }
        dstWrap = rlWrapIdx[dstSlot]
        dstBack = rlBackIdx[dstSlot]
      } else if !lUsed || !aUsed {
        return emitFail("emitProgram: .map/.filter result but list type not collected")
      }
      const srcL = mfSrcLocalFor(recvK, srcSlot)
      const dstL = mfDstLocalFor(resK, dstSlot)
      if !fnUsesMapFilter || srcL < 0 || dstL < 0 {
        return emitFail("emitProgram: .map/.filter scratch frame not reserved")
      }
      const iL = mfScratchBase
      const nL = mfScratchBase + 1
      const jL = mfScratchBase + 2
      const cL = mfScratchBase + 3
      // src = <receiver>, evaluated ONCE. (Any nested `.map`/`.filter` in the
      // receiver chain completes — including its result wrapper — before this store,
      // so the shared frame slots are free to reuse.)
      if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
      // A NARROWED nullable-list receiver keeps its nullable slot; the src
      // scratch slot is non-null, so recover first (checker-guarded, never traps).
      if exprNullableList(callee.memObj, fnIx) {
        wU8(212) // 0xd4 ref.as_non_null
      }
      fbLocalSet(srcL)
      // clo = the callback's closure value, built ONCE before the loop. An inline
      // literal / named function constructs it directly; a let-bound value reads its
      // binding (an `Ident` read — it cannot itself contain a HOF site, so the frame
      // slots written above stay live).
      const cbNode = P.nodes[unwrapParen(c.callArgs[0])]
      if cbNode is FuncDecl {
        if emitClosureValue(body, cbFe, fnIx) < 0 { return -1 }
      } else if cbNode is Ident {
        if fnIndexOf(cbNode.identName) >= 0 {
          if emitClosureValue(body, cbFe, fnIx) < 0 { return -1 }
        } else if emitExpr(body, c.callArgs[0], fnIx) < 0 {
          return -1
        }
      } else {
        return emitFail("emitProgram: unsupported .map/.filter callback")
      }
      fbLocalSet(cL)
      // n = src.len
      fbLocalGet(srcL)
      fbStructGet(srcWrap, 1) // field 1: len
      fbLocalSet(nL)
      // back = array.new_default <dstBack> n
      fbLocalGet(nL)
      fbArrayNewDefault(dstBack)
      fbLocalSet(dstL)
      // i = 0 (and j = 0 for filter)
      fbI32Const(0)
      fbLocalSet(iL)
      if !isMap {
        fbI32Const(0)
        fbLocalSet(jL)
      }
      // block { loop { if i >= n br 1; <element step>; i++; br 0 } }
      fbBlock(64)  // 0x02 block (void)
      ctrlEnter()
      fbLoop(64)   // 0x03 loop (void)
      ctrlEnter()
      fbLocalGet(iL)
      fbLocalGet(nL)
      fbI32Bin(78) // 0x4e i32.ge_s — i >= n?
      fbBrIf(1)    // exit the block
      if isMap {
        // back[i] = call_ref(clo, [elem(i)])
        fbLocalGet(dstL)
        fbLocalGet(iL)
        if (
          emitMfInvoke(body, cL, srcL, iL, srcWrap, srcBack, srcElemRef, sig) <
          0
        ) {
          return -1
        }
        fbArraySet(dstBack) // 0xfb 0x0e <dstBack>
      } else {
        // if call_ref(clo, [elem(i)]): back[j] = elem(i); j++
        if (
          emitMfInvoke(body, cL, srcL, iL, srcWrap, srcBack, srcElemRef, sig) <
          0
        ) {
          return -1
        }
        fbIf(64)      // 0x04 if (void)
        ctrlEnter()
        fbLocalGet(dstL)
        fbLocalGet(jL)
        emitMfElem(body, srcL, iL, srcWrap, srcBack, srcElemRef)
        fbArraySet(dstBack)
        fbLocalGet(jL)
        fbI32Const(1)
        fbI32Bin(106) // 0x6a i32.add
        fbLocalSet(jL)
        fbEnd()
        ctrlLeave()
      }
      fbLocalGet(iL)
      fbI32Const(1)
      fbI32Bin(106) // 0x6a i32.add
      fbLocalSet(iL)
      fbBr(0)       // continue the loop
      fbEnd()       // end loop
      ctrlLeave()
      fbEnd()       // end block
      ctrlLeave()
      // result = wrapper{ back, len, cap }: len = n (map) / j (filter), cap = n.
      fbLocalGet(dstL)
      if isMap { fbLocalGet(nL) } else { fbLocalGet(jL) }
      fbLocalGet(nL)
      fbStructNew(dstWrap)
      return 0
    }
  }
  emitFail("emitProgram: expected a .map/.filter call")
}

// `emitClampIdx`'s dual over plain wasm i32 LOCALS (not the string-op frame): emit
// `clamp(idx, len)` reading `idx` from local `idxL`, `len` from `lenL`, leaving the
// clamped value on the stack. Same JS slice semantics (`idx < 0 ? max(len+idx, 0) :
// min(idx, len)`) built from `select`.
function emitClampLocal(body: i32[], idxL: i32, lenL: i32) {
  // negCase = max(len+idx, 0) = select( len+idx, 0, (len+idx) > 0 )
  fbLocalGet(lenL)
  fbLocalGet(idxL)
  fbI32Bin(106) // i32.add → (len+idx)  [a]
  fbI32Const(0) // [b]
  fbLocalGet(lenL)
  fbLocalGet(idxL)
  fbI32Bin(106)
  fbI32Const(0)
  fbI32Bin(74)  // 0x4a i32.gt_s → (len+idx) > 0  [cond]
  wU8(27)       // 0x1b select → negCase
  // nonNegCase = min(idx, len) = select( idx, len, idx < len )
  fbLocalGet(idxL)
  fbLocalGet(lenL)
  fbLocalGet(idxL)
  fbLocalGet(lenL)
  fbI32Bin(72) // 0x48 i32.lt_s → idx < len  [cond]
  wU8(27)      // select → nonNegCase
  // result = select( negCase, nonNegCase, idx < 0 )
  fbLocalGet(idxL)
  fbI32Const(0)
  fbI32Bin(72) // 0x48 i32.lt_s → idx < 0
  wU8(27)      // select → clamped
  0
}

// Lower an array `xs.slice(start, end?)` onto `body`, leaving a NEW list wrapper of the
// SAME element kind over the half-open clamped range `[start, end)` (JS semantics: a
// missing `end` defaults to the length, negatives count from the end, the out length is
// `max(end - start, 0)`). Rides the `.map`/`.filter` scratch frame — `srcL` (the source
// wrapper, reserved by `mfScan`'s slice branch), `dstL` (the fresh backing), and the four
// i32 temps `mfScratchBase + 0..3` as start/end/len/outLen — then one `array.copy`. The
// receiver is evaluated ONCE into `srcL`; works for i32/boolean (kind 0), f64 (1), ref
// (2), and string (3) lists.
function emitArrSlice(body: i32[], callIx: i32, fnIx: i32) {
  let c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      const recvK = mfRecvKindOf(callee.memObj, fnIx)
      if recvK < 0 {
        return emitFail("emitProgram: .slice receiver is not a supported list")
      }
      let srcSlot = -1
      if recvK == 2 { srcSlot = refListSlotOfExpr(callee.memObj, fnIx) }
      // The element kind's wrapper + backing heap types.
      let wrap = lTypeIdx
      let back = aTypeIdx
      if recvK == 1 {
        if !fa64Used {
          return emitFail(
            "emitProgram: .slice over f64[] but f64 list type not collected",
          )
        }
        wrap = fl64TypeIdx
        back = fa64TypeIdx
      } else if recvK == 4 {
        if !ia64Used {
          return emitFail(
            "emitProgram: .slice over i64[] but i64 list type not collected",
          )
        }
        wrap = il64TypeIdx
        back = ia64TypeIdx
      } else if recvK == 13 {
        if !fa32Used {
          return emitFail(
            "emitProgram: .slice over f32[] but f32 list type not collected",
          )
        }
        wrap = fl32TypeIdx
        back = fa32TypeIdx
      } else if recvK == 2 {
        if !rlUsed {
          return emitFail(
            "emitProgram: .slice over a ref list but ref list type not collected",
          )
        }
        wrap = rlWrapIdx[srcSlot]
        back = rlBackIdx[srcSlot]
      } else if recvK == 3 {
        if !slUsed {
          return emitFail(
            "emitProgram: .slice over string[] but string list type not collected",
          )
        }
        wrap = mkListIdx
        back = mkArrIdx
      } else if !lUsed || !aUsed {
        return emitFail("emitProgram: .slice but list type not collected")
      }
      const srcL = mfSrcLocalFor(recvK, srcSlot)
      const dstL = mfDstLocalFor(recvK, srcSlot)
      if !fnUsesMapFilter || srcL < 0 || dstL < 0 {
        return emitFail("emitProgram: .slice scratch frame not reserved")
      }
      // The `.map`/`.filter` frame's first 3 slots are i32 (i, n, j); slot +3 is a
      // closure ref. So slice has THREE i32 temps: `startL`, `endL`, and `auxL` which
      // holds the length during clamping then is reused for the out length.
      const startL = mfScratchBase + 0
      const endL = mfScratchBase + 1
      const auxL = mfScratchBase + 2
      // src = <receiver>, evaluated ONCE (a NARROWED nullable i32 list recovers non-null).
      if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
      if recvK == 0 {
        if exprNullableList(callee.memObj, fnIx) {
          wU8(212) // 0xd4 ref.as_non_null
        }
      }
      fbLocalSet(srcL)
      // auxL = src.len (the wrapper's logical length, field 1)
      fbLocalGet(srcL)
      fbStructGet(wrap, 1)
      fbLocalSet(auxL)
      // start = clamp(rawStart, len)
      if emitExpr(body, c.callArgs[0], fnIx) < 0 { return -1 }
      fbLocalSet(startL)
      emitClampLocal(body, startL, auxL)
      fbLocalSet(startL)
      // end = clamp(rawEnd, len), or len when omitted (the 1-arg form slices to the end)
      if c.callArgs.length == 2 {
        if emitExpr(body, c.callArgs[1], fnIx) < 0 { return -1 }
        fbLocalSet(endL)
        emitClampLocal(body, endL, auxL)
        fbLocalSet(endL)
      } else {
        fbLocalGet(auxL)
        fbLocalSet(endL)
      }
      // auxL (len now dead) = outLen = max(end - start, 0) = select(end-start, 0, end>start)
      fbLocalGet(endL)
      fbLocalGet(startL)
      fbI32Bin(107) // i32.sub → end - start  [a]
      fbI32Const(0) // [b]
      fbLocalGet(endL)
      fbLocalGet(startL)
      fbI32Bin(74)  // 0x4a i32.gt_s → end > start  [cond]
      wU8(27)       // 0x1b select
      fbLocalSet(auxL)
      // dst backing = array.new_default <back> outLen
      fbLocalGet(auxL)
      fbArrayNewDefault(back)
      fbLocalSet(dstL)
      // result wrapper = struct.new <wrap> (dstBacking, outLen, outLen) — pushed FIRST so
      // it remains on the stack after the trailing `array.copy` consumes its own operands.
      fbLocalGet(dstL)
      fbLocalGet(auxL)
      fbLocalGet(auxL)
      fbStructNew(wrap)
      // array.copy dst 0 src.backing start outLen
      fbLocalGet(dstL)        // dest backing
      fbI32Const(0)           // dest offset
      fbLocalGet(srcL)
      fbStructGet(wrap, 0)    // src backing
      fbLocalGet(startL)      // src offset
      fbLocalGet(auxL)        // count
      fbArrayCopy(back, back) // array.copy (dest type, src type)
      // The result wrapper from `struct.new` above is the value left on the stack.
      return 0
    }
    return emitFail("emitProgram: .slice receiver is not a member access")
  }
  emitFail("emitProgram: expected an array slice call")
}

// Push `elem(i)` — `src.backing[i]` — onto the stack (`ref.as_non_null` for a ref
// element, surfacing the non-null struct/union box).
function emitMfElem(
  body: i32[],
  srcL: i32,
  iL: i32,
  srcWrap: i32,
  srcBack: i32,
  srcElemRef: boolean,
) {
  fbLocalGet(srcL)
  fbStructGet(srcWrap, 0) // field 0: backing
  fbLocalGet(iL)
  fbArrayGet(srcBack)     // 0xfb 0x0b <srcBack>
  if srcElemRef {
    wU8(212) // 0xd4 ref.as_non_null
  }
  0
}

// Invoke the callback closure (stashed in local `cL`) on `elem(i)`: push its env
// (field 1), the element, its code funcref (field 0) cast to the concrete `$fnsig`,
// then `call_ref $fnsig` — leaving the callback's result on the stack.
function emitMfInvoke(
  body: i32[],
  cL: i32,
  srcL: i32,
  iL: i32,
  srcWrap: i32,
  srcBack: i32,
  srcElemRef: boolean,
  sig: i32,
) {
  fbLocalGet(cL)
  fbStructGet(cloStructIdx, 1) // env
  emitMfElem(body, srcL, iL, srcWrap, srcBack, srcElemRef)
  fbLocalGet(cL)
  fbStructGet(cloStructIdx, 0) // code (funcref)
  fbRefCast(sig)               // 0xfb 0x16 <fnsig>
  fbCallRef(sig)               // 0x14 <fnsig>
  0
}

// `local.get L ; struct.get $lTy 1` — push the list's `len` field onto `body`.
function pushListLen(body: i32[], lIdx: i32, lTy: i32) {
  fbLocalGet(lIdx)    // local.get
  fbStructGet(lTy, 1) // 0xfb 0x02 <lTy> field 1: len
  0
}

// `local.get L ; struct.get $lTy 2` — push the list's `cap` field onto `body`.
function pushListCap(body: i32[], lIdx: i32, lTy: i32) {
  fbLocalGet(lIdx)    // local.get
  fbStructGet(lTy, 2) // 0xfb 0x02 <lTy> field 2: cap
  0
}

// `local.get L ; struct.get $lTy 0` — push the list's `backing` ref onto `body`.
function pushListBacking(body: i32[], lIdx: i32, lTy: i32) {
  fbLocalGet(lIdx)    // local.get
  fbStructGet(lTy, 0) // 0xfb 0x02 <lTy> field 0: backing
  0
}

// If the `if` condition at `condIx` is `n is Variant` over a bare union identifier
// `n`, PUSH the narrowing (`narrowNames`/`narrowVariants`) so the then-branch's
// `n.field` reads downcast through the box, and return true. Otherwise leave the
// narrowing stack untouched and return false. A non-identifier receiver (e.g. `f(x) is
// A`) is not narrowable (no stable name to re-read) and is left un-narrowed. The caller
// saves the stack length and truncates back on branch exit (`restoreNarrow`).
function setNarrowFromCond(condIx: i32, fnIx: i32) {
  let c = P.nodes[condIx]
  if c is IsExpr {
    const recv = P.nodes[c.isObj]
    if recv is Ident {
      if exprUnion(c.isObj, fnIx) {
        pushNarrow(recv.identName, c.isVariant)
        return true
      }
    }
    // `o.y is T` over a UNION-typed struct FIELD narrows the member PATH (the
    // narrowing key is the path string `o.y`; `emitMem` unboxes under it).
    const mrecv = P.nodes[unwrapParen(c.isObj)]
    if mrecv is Member {
      if memberUnionFieldName(unwrapParen(c.isObj), fnIx) != "" {
        const mk = memberPathKeyOf(unwrapParen(c.isObj))
        if mk != "" {
          pushNarrow(mk, c.isVariant)
          return true
        }
      }
    }
    // `x?.y is T` narrows the member PATH exactly like `x.y is T` — the then-arm
    // only runs when every chain link held AND the union field matched, so the
    // plain `x.y` reads inside it unbox under the same path key.
    if mrecv is OptMember {
      const omSi = optChainStructIdxOf(mrecv.omObj, fnIx)
      if omSi >= 0 {
        const omFi = sFieldIndex(omSi, mrecv.omProp)
        if omFi >= 0 {
          if sFieldTypeAt(omSi, omFi) == 16 {
            const omRoot = P.nodes[unwrapParen(mrecv.omObj)]
            if omRoot is Ident {
              pushNarrow(omRoot.identName + "." + mrecv.omProp, c.isVariant)
              return true
            }
          }
        }
      }
    }
  }
  // `a && b` composes: the then-branch sees BOTH conjuncts' narrowings (the
  // host's A5 — the RHS is even CHECKED under the LHS's narrowing). The pushes
  // stack; the caller's save/restore of `narrowTop` unwinds them together.
  if c is BinExpr {
    if c.binOp == "&&" {
      const nl = setNarrowFromCond(c.binLeft, fnIx)
      const nr = setNarrowFromCond(c.binRight, fnIx)
      return nl || nr
    }
  }
  // `!cond` swaps the branch senses: the then-arm of `if !(x is A) { … }` sees the
  // ELSE-narrowing of the inner condition (the host's negation complement).
  if c is Unary {
    if c.unOp == "!" {
      return setNarrowFromCondElse(unwrapParen(c.unArg), fnIx)
    }
  }
  // `x == null` / `x != null` over a BOXED VALUE union narrows the THEN-branch:
  // `==` pins `x` to the `null` member; `!=` strips `null` from the current set
  // (so `i32 | null` fully unboxes to `i32` in the non-null branch).
  let nm = valueUnionNullCmpName(condIx, fnIx)
  if nm != "" {
    const cn = P.nodes[condIx]
    if cn is BinExpr {
      if cn.binOp == "==" {
        pushNarrow(nm, "null")
        return true
      }
      const rest = removeAtomFrom(currentNarrowSetOf(nm, fnIx), "null")
      if rest != "" {
        pushNarrow(nm, rest)
        return true
      }
    }
  }
  // The same null-compare narrowing over a BOXED STRUCT union with a `null` member
  // (`v: A | B | null`): `!=` strips `null` (so an inner `is`/else chain subtracts
  // toward a single variant), `==` pins `null`. The 1-struct niche (`S | null`) is
  // excluded — it is a nullable REF, not a box, and keeps its existing lowering.
  const snm = structUnionNullCmpName(condIx, fnIx)
  if snm != "" {
    const scn = P.nodes[condIx]
    if scn is BinExpr {
      if scn.binOp == "==" {
        pushNarrow(snm, "null")
        return true
      }
      const srest = removeAtomFrom(currentStructNarrowSetOf(snm, fnIx), "null")
      if srest != "" {
        pushNarrow(snm, srest)
        return true
      }
    }
  }
  false
}

// The receiver NAME when the condition at `condIx` is `<ident> == null` /
// `<ident> != null` over a BOXED STRUCT union (2+ struct variants plus a `null`
// member), else "". The value-union and 1-struct-niche forms are excluded (each
// keeps its own narrowing path).
function structUnionNullCmpName(condIx: i32, fnIx: i32) {
  let c = P.nodes[condIx]
  if c is BinExpr {
    if c.binOp == "==" || c.binOp == "!=" {
      const lhs = P.nodes[unwrapParen(c.binLeft)]
      const rhs = P.nodes[unwrapParen(c.binRight)]
      let refIx = -1
      if rhs is NullLit { refIx = unwrapParen(c.binLeft) }
      if lhs is NullLit { refIx = unwrapParen(c.binRight) }
      if refIx >= 0 {
        let r = P.nodes[refIx]
        if r is Ident {
          let un = unionNameOfIdent(r.identName, fnIx)
          if un != "" {
            if !isValueUnionName(un) {
              const uset = unionMemberSetOf(un)
              if unionHasAtom(uset, "null") && nonNullMemberCountOf(uset) >= 2 {
                return r.identName
              }
            }
          }
        }
      }
    }
  }
  ""
}

// The receiver NAME when the condition at `condIx` is `<ident> == null` /
// `<ident> != null` over a boxed VALUE union, else "". (A struct union / niche
// nullable keeps its existing lowering and narrowing behavior.)
function valueUnionNullCmpName(condIx: i32, fnIx: i32) {
  let c = P.nodes[condIx]
  if c is BinExpr {
    if c.binOp == "==" || c.binOp == "!=" {
      const lhs = P.nodes[unwrapParen(c.binLeft)]
      const rhs = P.nodes[unwrapParen(c.binRight)]
      let refIx = -1
      if rhs is NullLit { refIx = unwrapParen(c.binLeft) }
      if lhs is NullLit { refIx = unwrapParen(c.binRight) }
      if refIx >= 0 {
        let r = P.nodes[refIx]
        if r is Ident {
          let un = unionNameOfIdent(r.identName, fnIx)
          if un != "" {
            if isValueUnionName(un) { return r.identName }
          }
        }
      }
    }
  }
  ""
}

// The ELSE-branch dual of `setNarrowFromCond`, for VALUE unions only: the guard
// was FALSE there, so `is T` strips `T` from the current set (a 2-member union
// fully discriminates — `string | i32` minus `i32` is `string`, which unboxes),
// `== null` strips `null`, and `!= null` pins `null`. Struct unions keep their
// existing (no else-narrowing) behavior — their member reads must not change.
function setNarrowFromCondElse(condIx: i32, fnIx: i32) {
  let c = P.nodes[condIx]
  if c is IsExpr {
    if valueAtomKind(c.isVariant) >= 0 {
      const recv = P.nodes[unwrapParen(c.isObj)]
      if recv is Ident {
        let un = unionNameOfIdent(recv.identName, fnIx)
        if un != "" {
          if isValueUnionName(un) {
            const rest = removeAtomFrom(
              currentNarrowSetOf(recv.identName, fnIx),
              c.isVariant,
            )
            if rest != "" {
              pushNarrow(recv.identName, rest)
              return true
            }
          }
        }
      }
      // `o.y is T` over a UNION-typed struct FIELD: the guard was FALSE there, so
      // `T` is stripped from the path's current set — a 2-member field union fully
      // discriminates (`string | i32` minus `i32` reads as `string`), unboxing the
      // else-arm's `o.y` under the same path key `setNarrowFromCond` pushes.
      if recv is Member {
        const mun = memberUnionFieldName(unwrapParen(c.isObj), fnIx)
        if mun != "" {
          const mk = memberPathKeyOf(unwrapParen(c.isObj))
          if mk != "" {
            let mcur = unionMemberSetOf(mun)
            const mNar = narrowVariantFor(mk)
            if mNar != "" { mcur = mNar }
            const mrest = removeAtomFrom(mcur, c.isVariant)
            if mrest != "" {
              pushNarrow(mk, mrest)
              return true
            }
          }
        }
      }
      return false
    }
    // STRUCT-union complement (host flow narrowing): the guard was FALSE, so the
    // tested VARIANT is stripped from the receiver's current set. When one member
    // remains, the else-arm fully discriminates (`if v is A {…} else { v.y }`
    // reads `v` as the `B` variant); a multi-member rest ("N2|N3") keeps a later
    // `else if` arm subtracting toward its own singleton. Only a BOXED struct
    // union narrows (`exprUnion` — the 1-struct niche is a nullable ref, whose
    // member reads must not change).
    const srecv = P.nodes[unwrapParen(c.isObj)]
    if srecv is Ident {
      if exprUnion(c.isObj, fnIx) {
        const srest = removeAtomFrom(
          currentStructNarrowSetOf(srecv.identName, fnIx),
          c.isVariant,
        )
        if srest != "" {
          pushNarrow(srecv.identName, srest)
          return true
        }
      }
    }
    return false
  }
  // `!cond` in the ELSE-arm: the inner condition was TRUE there, so the else sees
  // the inner condition's THEN-narrowing (`if !(n is Program) {…} else { n.progStmts }`).
  if c is Unary {
    if c.unOp == "!" { return setNarrowFromCond(unwrapParen(c.unArg), fnIx) }
  }
  let nm = valueUnionNullCmpName(condIx, fnIx)
  if nm != "" {
    const cn = P.nodes[condIx]
    if cn is BinExpr {
      if cn.binOp == "!=" {
        pushNarrow(nm, "null")
        return true
      }
      const rest = removeAtomFrom(currentNarrowSetOf(nm, fnIx), "null")
      if rest != "" {
        pushNarrow(nm, rest)
        return true
      }
    }
  }
  // The struct-union dual: in the else of `v != null` the value IS `null`; in the
  // else of `v == null` it is the non-null variant set.
  const snm = structUnionNullCmpName(condIx, fnIx)
  if snm != "" {
    const scn = P.nodes[condIx]
    if scn is BinExpr {
      if scn.binOp == "!=" {
        pushNarrow(snm, "null")
        return true
      }
      const srest = removeAtomFrom(currentStructNarrowSetOf(snm, fnIx), "null")
      if srest != "" {
        pushNarrow(snm, srest)
        return true
      }
    }
  }
  false
}

// Rewind the narrowing stack depth back to `n` (drop bindings a branch pushed). The
// arrays keep their backing slots — only the logical depth changes, so no `.pop()`.
function restoreNarrow(n: i32) {
  narrowTop = n
  0
}

// After a GUARD `if` — one with NO else whose then-branch always returns — the
// rest of the enclosing block only runs when the guard was FALSE, so it sees
// the same complement narrowing an explicit else-arm would (the host's flow
// narrowing after an early return): `if x is boolean { return 0 } return x`
// reads `x` as the unboxed `i32` below the guard. Pushes via
// `setNarrowFromCondElse` (VALUE unions only — struct unions keep their
// no-else-narrowing behavior); the CALLER restores the depth at block exit.
function pushPostGuardNarrow(stmtIx: i32, fnIx: i32) {
  let s = P.nodes[stmtIx]
  if s is IfStmt {
    if s.ifElse < 0 {
      if blockAlwaysReturns(s.ifThen) { setNarrowFromCondElse(s.ifCond, fnIx) }
    }
  }
  // ASSIGNMENT narrowing (A-infer-null, the host's `assignmentNarrowing`): a
  // straight-line `x = <non-null expr>` over a null-bearing VALUE union makes
  // `x` provably non-null for the REST of the enclosing block — `let x = null;
  // x = 5; x + 1` reads the unboxed i32 with no null tax. Emitted only for a
  // plain `=` to a bare name whose RHS is itself non-null (a `x = maybeNull()`
  // RHS, or a bare `null`, leaves `x` un-narrowed). The CALLER restores the
  // depth at block exit, so a branch-local assignment never leaks past the join.
  if s is BinExpr {
    if s.binOp == "=" {
      const tgt = P.nodes[s.binLeft]
      if tgt is Ident {
        let un = unionNameOfIdent(tgt.identName, fnIx)
        if un != "" && isValueUnionName(un) && unionHasAtom(un, "null") {
          const rhs = P.nodes[unwrapParen(s.binRight)]
          let rhsNullable = false
          if rhs is NullLit { rhsNullable = true }
          const rn = unionNameOfExpr(s.binRight, fnIx)
          if rn != "" {
            if unionHasAtom(rn, "null") { rhsNullable = true }
          }
          if !rhsNullable {
            pushNarrow(tgt.identName, removeAtomFrom(un, "null"))
          }
        }
      }
    }
  }
  0
}

// The ELEMENT kind of a `for v in <iter>` iterable: `0` = i32 (an `i32[]` list, a
// map `.values()`), `3` = string (a `string[]` list, a map `.keys()`), `1` = struct
// (a `S[]` ref list whose element is a struct), or -1 (an unsupported iterable — the
// caller fails loudly). The returned kind doubles as the loop var's LOCAL code, so a
// struct element binds a code-`1` struct local (member access on `v` then resolves).
// The map forms read the map's insertion-ordered keys/vals lists directly (no delete
// exists in the op set yet, so every entry is live).
function forInElemKind(iterIx: i32, fnIx: i32) {
  const e = P.nodes[iterIx]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if exprMap(callee.memObj, fnIx) {
        if callee.memProp == "keys" { return 3 }
        if callee.memProp == "values" {
          // A SET's `.values()` yields its ELEMENTS — the string keys (kind 3),
          // not the i32 membership booleans. A map's yields its VALUES: i32 for
          // the mono map, the value's kind for a ref-valued map (string 3 /
          // struct 1 — the loop var binds that kind).
          if mapIsSetExpr(callee.memObj, fnIx) { return 3 }
          const vsl = mapShapeOfExpr(callee.memObj, fnIx)
          if vsl >= 0 {
            if mvValKind[vsl] == 3 {
              return 3 // string value
            }
            if mvValKind[vsl] == 11 {
              return 11 // f64 value (scalar local)
            }
            if mvValKind[vsl] == 10 {
              return 10 // i64 value (scalar local)
            }
            if mvValKind[vsl] == 13 {
              return 13 // f32 value (scalar local)
            }
            if mvValKind[vsl] == 14 {
              return 14 // closure value (`{[string]: (i32) => i32}` — loop var calls each)
            }
            // A LIST value (`{[string]: i32[]}` / `f64[]` / `S[]` …): the loop var binds the inner
            // VALUE LIST, exactly as a nested-array `for row in g` over `i32[][]` does — its
            // loop-var kind is the value-list's rep (`mvListValKind` → 2/7/12/20/21, or 5 for a
            // struct/ref list). The `#l` temp is the vals ref-list wrapper (`forInMapValsSlot`).
            if mvValKind[vsl] == 6 { return mvListValKind(vsl) }
            return 1 // struct value
          }
          return 0
        }
      }
    }
  }
  // A bare MAP iterable (`for k in m`) iterates its KEYS — like `m.keys()` (kind 3).
  if exprMap(iterIx, fnIx) { return 3 }
  if exprStringArray(iterIx, fnIx) { return 3 }
  // A STRUCT-element ref list (`S[]`): the element is a struct ref, so bind the loop
  // var as a code-`1` struct local. (Union-box (`2`) / map-array ref lists are not
  // yet supported here — they fall through to the unsupported -1.)
  if exprRefArray(iterIx, fnIx) {
    let rslot = refListSlotOfExpr(iterIx, fnIx)
    if rlElemKindTbl[rslot] == 1 {
      // A NULLABLE-struct element ref list (`(P | null)[]`, slot key "P | null"): the loop var
      // binds as a kind-9 niche (`for e in xs { if e != null { … e.v … } }`), and the element
      // read stays nullable (no `ref.as_non_null`). A plain `S[]` is the non-null kind 1.
      if nullablePartOf(rlElemName[rslot]) != "" { return 9 }
      return 1
    }
    // A UNION-box element ref list (`(C | S)[]`, kind 2): the loop var binds as a kind-4
    // union-box local (the element-kind code IS the loop-var local kind, as struct's `1` is),
    // so `for x in arr { … x is S … }` narrows each element. The `#l` temp is the ref-list
    // wrapper (code 5), same as the struct case.
    if rlElemKindTbl[rslot] == 2 { return 4 }
    // A NESTED-ARRAY element ref list (`i32[][]`/`string[][]`/`f64[][]`/`i64[][]`, element kind
    // 4/6/7/8 = the inner list wrapper): the loop var binds the INNER LIST — a list local of
    // kind 2/7/12/20 (i32/string/f64/i64 list). The element read is a ref (the inner wrapper,
    // recovered non-null), like the struct case; the `#l` temp is the outer ref-list wrapper.
    if rlElemKindTbl[rslot] == 4 { return 2 }
    if rlElemKindTbl[rslot] == 6 { return 7 }
    if rlElemKindTbl[rslot] == 7 { return 12 }
    if rlElemKindTbl[rslot] == 8 { return 20 }
    if rlElemKindTbl[rslot] == 10 {
      return 21 // f32-inner list -> an f32-list local (kind 21)
    }
    // A CLOSURE-element ref list (`((i32) => i32)[]`, element kind 5): the loop var binds as a
    // kind-14 closure local — `for f in fs { … f(x) … }` calls each via `call_ref`. The element
    // read recovers the closure ref non-null (like a struct); the `#l` temp is the ref-list
    // wrapper (code 5).
    if rlElemKindTbl[rslot] == 5 { return 14 }
    // A NESTED REF array (`S[][]`/`(C|D)[][]`/`S[][][]`, element kind 9): the loop var binds the
    // INNER REF LIST — a kind-5 ref-list local carrying the inner slot. `for row in g { … row[j]
    // … }` then indexes/iterates it. The element read recovers the inner wrapper non-null; the
    // `#l` temp is the outer ref-list wrapper. Recurses (the inner slot may itself be kind 9).
    if rlElemKindTbl[rslot] == 9 { return 5 }
    return -1
  }
  // An f64 element list (`f64[]`): the loop var binds as a scalar f64 local (code 11, the
  // same code a `let x: f64` uses, so `fbValtype` types it `0x7c` automatically), and the
  // `#l` temp is the f64-list (code 12). Recognized through `exprF64Array`, which trusts the
  // checker's recorded type, so an `f64[]`-returning call iterates too. Checked before the
  // i32 default (an f64 element is not an i32).
  // An f32 element list (`f32[]`): the loop var binds as a scalar f32 local (code 13).
  if exprF32Array(iterIx, fnIx) { return 13 }
  if exprF64Array(iterIx, fnIx) { return 11 }
  // An i64 element list (`i64[]`): the loop var binds as a scalar i64 local (code 10), and
  // the `#l` temp is the i64-list (code 20).
  if exprI64Array(iterIx, fnIx) { return 10 }
  // A STRING iterable (`for ch in s`): each code unit is an i32 (loop-var code 0, same as an
  // `i32[]`), but the source is the RAW i32 array — the `#l` temp is the string itself (code 3),
  // and the length/element reads skip the list-wrapper `struct.get`. `forInStringSrc` flags it
  // at the temp-kind and emit sites. Checked before `exprArray` (a string is not an i32 list).
  if exprString(iterIx, fnIx) { return 0 }
  if exprArray(iterIx, fnIx) { return 0 }
  -1
}

// Whether a `for v in <iter>` iterable is a STRING (`for ch in s`) — the i32-code-unit walk over
// the raw array, distinct from an `i32[]` (code 0 too) whose backing hides behind a list wrapper.
function forInStringSrc(iterIx: i32, fnIx: i32) {
  if forInElemKind(iterIx, fnIx) != 0 { return false }
  exprString(iterIx, fnIx)
}

// The mv SLOT of a `for v in m.values()` walk over a REF-VALUED map, or -1 (not a
// map walk / a mono map / a set). The values walk then types its loop var + list
// temp off the slot's value type instead of a ref-array's element.
function forInMapValsSlot(iterIx: i32, fnIx: i32) {
  const e = P.nodes[iterIx]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "values" {
        if exprMap(callee.memObj, fnIx) {
          if mapIsSetExpr(callee.memObj, fnIx) { return -1 }
          const sl = mapShapeOfExpr(callee.memObj, fnIx)
          if sl >= 0 { return sl }
        }
      }
    }
  }
  -1
}

// The element struct TABLE INDEX of a `for v in <S[]>` iterable (the struct that the
// code-`1` loop var binds), or -1 when the iterable is not a struct ref list. Mirrors
// the index-read resolution (`structIndexOfExpr` over `xs[i]`): the element name comes
// from the ref-list slot, then its struct table index. A STRUCT-VALUED map's
// `.values()` walk binds the slot's value struct.
function forInRefArrayStructIdx(iterIx: i32, fnIx: i32) {
  let mvs = forInMapValsSlot(iterIx, fnIx)
  if mvs >= 0 {
    if mvValKind[mvs] == 1 { return mvValStructIdx[mvs] }
    return -1
  }
  if !exprRefArray(iterIx, fnIx) { return -1 }
  // Strip a `| null` niche suffix (`(P | null)[]` → "P") so the nullable-struct loop var
  // carries P's struct index.
  structIdxOfElemName(refListElemNameOfExpr(iterIx, fnIx))
}

// True if the map-typed expression at `exprIx` is a SET (`Set()`-seeded binding or
// the constructor itself). Consulted by the `.values()` paths: a set's `.values()`
// yields its ELEMENTS (the keys list), not the membership booleans in `vals` —
// mirroring the checker (`typecheck.vl`: a set's values() returns `mKey[]`).
// Params have no Set-distinguishing annotation, so a set passed as a parameter is
// out of scope (the checker's surface gating keeps `.values()` calls on it valid
// only for sets, but the flavor bit can't cross the call boundary yet).
function mapIsSetExpr(exprIx: i32, fnIx: i32) {
  mapShapeOfExpr(exprIx, fnIx) == -2
}

// The mv SLOT a map READ expression resolves to: `m[k]` (Index over a ref-valued
// map) or `m.get(k)` (the method form), else -1. The chokepoint the expression-kind
// resolvers (`exprString` / struct resolution / `??` lowering) consult so a
// ref-valued `m[k] ?? d` classifies as its VALUE type.
function mapReadMvSlot(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return -1 }
  const e = P.nodes[exprIx]
  if e is Index {
    if exprMap(e.idxArr, fnIx) {
      const sl = mapShapeOfExpr(e.idxArr, fnIx)
      if sl >= 0 { return sl }
    }
    return -1
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "get" {
        if exprMap(callee.memObj, fnIx) {
          const sl = mapShapeOfExpr(callee.memObj, fnIx)
          if sl >= 0 { return sl }
        }
      }
    }
  }
  -1
}

// The mv slot of a `lhs ?? d` READ-WITH-DEFAULT over a ref-valued map, else -1. Parens are peeled on
// BOTH the whole expression and the LHS so a `(m[k]) ?? d` classifies its VALUE type identically to
// the bare form — the classifier must agree with the `??` emit (which also peels parens), else a
// parenthesized string/f64/struct map-get is emitted as its real type but the print/coerce routing
// defaults it to i32 (invalid wasm).
function coalesceMvSlot(exprIx: i32, fnIx: i32) {
  const e = P.nodes[unwrapParen(exprIx)]
  if e is BinExpr {
    if e.binOp == "??" { return mapReadMvSlot(unwrapParen(e.binLeft), fnIx) }
  }
  -1
}

// The list-element rep (2/7/12/20 — see `mvListValKind`) of a bare `m[k]` or `m[k] ?? d`
// read over a list-VALUED map, else -1. The single classifier hook each `expr*Array` uses to
// claim a list-valued-map read of its own element type.
function mapReadListKind(exprIx: i32, fnIx: i32) {
  const cm = coalesceMvSlot(exprIx, fnIx)
  if cm >= 0 { return mvListValKind(cm) }
  return mvListValKind(mapReadMvSlot(exprIx, fnIx))
}

// The map RECEIVER arena index of a `for v in m.keys()` / `m.values()` iterable, or -1
// when the iterable is not a map keys/values walk. Drives the tombstone-aware skip in
// the for-in loop (the map's `live` array is consulted per entry).
function forInMapRecv(iterIx: i32, fnIx: i32) {
  const e = P.nodes[iterIx]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "keys" || callee.memProp == "values" {
        if exprMap(callee.memObj, fnIx) { return callee.memObj }
      }
    }
  }
  // A bare map iterable (`for k in m`) IS its own receiver — the live-skip walks it.
  if exprMap(iterIx, fnIx) { return iterIx }
  -1
}

// Push the LIST ref a `for v in <iter>` iterates: a map `.keys()`/`.values()`
// reads the map struct's ordered list field (0 = keys, 1 = vals); any other
// supported iterable is the list value itself.
//
// DELETE-AWARE ITERATION: the keys/vals LIST WRAPPER is decoupled from the map struct
// (its `len` counts appended entries == `count`), so a straight len-walk would VISIT
// tombstoned entries. The for-in loop therefore stashes the MAP ref in the map scratch
// frame (slot 0) and, per entry `i`, SKIPS when `M.live[i] == 0` — a map-struct-aware
// walk over `[0, count)` matching the host's iteration semantics (order + skipping).
// For a delete-free map `live` is all-1s, so the skip never fires (behavior-preserving).
function emitForInList(body: i32[], iterIx: i32, fnIx: i32) {
  const e = P.nodes[iterIx]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if exprMap(callee.memObj, fnIx) {
        let fsl = mapShapeOfExpr(callee.memObj, fnIx)
        if fsl == -2 || fsl == -3 { fsl = -1 }
        if callee.memProp == "keys" {
          if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
          fbStructGet(mapTypeIdxOf(fsl), 0) // field 0: ordered keys list
          return 0
        }
        if callee.memProp == "values" {
          if emitExpr(body, callee.memObj, fnIx) < 0 { return -1 }
          // A SET's `.values()` walks the ordered KEYS (its elements); a map's
          // walks the ordered vals.
          if mapIsSetExpr(callee.memObj, fnIx) {
            fbStructGet(mapTypeIdxOf(fsl), 0) // field 0: ordered keys list
          } else {
            fbStructGet(mapTypeIdxOf(fsl), 1) // field 1: ordered vals list
          }
          return 0
        }
      }
    }
  }
  // A bare map iterable (`for k in m`) walks its ordered keys list (field 0) — the same
  // tombstone-aware loop as `m.keys()`, no intermediate key list built.
  if exprMap(iterIx, fnIx) {
    let bsl = mapShapeOfExpr(iterIx, fnIx)
    if bsl == -2 || bsl == -3 { bsl = -1 }
    if emitExpr(body, iterIx, fnIx) < 0 { return -1 }
    fbStructGet(mapTypeIdxOf(bsl), 0) // field 0: ordered keys list
    return 0
  }
  emitExpr(body, iterIx, fnIx)
}

// Lower a single statement at `stmtIx` onto `body`, resolving identifiers/params
// against function `fnIx`. Returns 0, or -1 (via `emitFail`) on an unsupported shape.
//
// Node shapes read (all from `compiler/ast.vl`):
//   LetDecl { letName, letType, letInit }         — `let`/`const` local declaration.
//   RetStmt { retArg: i32 }                       — `retArg` -1 means a bare return.
//   IfStmt  { ifCond: i32, ifThen: i32, ifElse: i32 }
//   BinExpr { binOp, binLeft, binRight }          — an assignment expression statement.
//   Call    { callFn, callArgs }                  — a `recv.push(x)` member-call.
//   Block   { blkStmts: i32[] }
// Lower a RETURN-VALUE expression `retArg` for function `fnIx`: seed the return context
// from the function's return type (struct / ref-list / union / nullable-niche / numeric
// widening), emit the value through the matching helper, then reset the pending seeds.
// Does NOT emit the `return` instruction — the caller appends `fbReturn` (an explicit
// `RetStmt`) or leaves it (the value flows on as an if-tail arm's stack result). This
// unifies explicit `return e` with IMPLICIT (tail-position) returns, so a trailing `null`
// or a nullable `if/else`-tail arm gets the SAME box/sentinel/`ref.null` seeding as
// `return null` — without it the tail paths emitted a bare `null` and failed codegen.
// The numeric (f32/f64/i64) literal WIDENING applies to BOTH explicit `return e` and the
// IMPLICIT-return tail: a narrower literal (`1.5` → f32, `5` → i64) promotes to the
// declared float/i64 return through `emitExprAs*`, which is a no-op pass-through on a value
// ALREADY of the right type (`exprIsF64`/`exprIsF32`/`exprIsI64` recognize a closure
// `call_ref` result, a variable, etc., so an already-correct tail is never mis-widened).
// Without this, a bare-expression body returning a narrower literal (`function f(): i64 5`,
// `(): f32 => 1.5`) emitted the literal at its default type and trapped wasm validation.
function emitReturnValue(body: i32[], retArg: i32, fnIx: i32) {
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    const rsi = retStructIndex(fn.fnRet)
    if rsi >= 0 {
      if retTRFlag(fn.fnRet) == 1 { pendingStructIdx = rsi }
      if retNulRefFlag(fn.fnRet) == 1 { pendingStructIdx = rsi }
    }
    // A `: Cat` variant return: seed the variant index so a `return { … }` object literal
    // builds the bare variant struct (kind 8) instead of boxing into the union.
    if retVariantFlag(fn.fnRet) == 1 {
      pendingVariantIdx = variantIndexOf(tyNameOf(fn.fnRet))
    }
    // An INFERRED variant return (a `.map` lambda collapsing to one variant): seed it from
    // the checker's recorded return shape so the else-arm's `{ … }` literal builds the bare
    // variant too, matching the then-arm's narrowed variant rep.
    if fn.fnRet < 0 {
      const rvi = cbRetVariantIdx(fnStmtsPosOf(fnIx))
      if rvi >= 0 { pendingVariantIdx = rvi }
    }
    pendingListKind = tyAnnRefListKind(fn.fnRet)
    pendingListSlot = tyAnnRefListSlot(fn.fnRet)
  }
  let retF32 = false
  let retF64 = false
  let retI64 = false
  let retNulBool = false
  let retNulString = false
  let retNulList = false
  let retLitUnion = false
  // A `string`-returning function whose `return` value is a literal-union atom: widen the
  // atom to its member string at the return boundary (the atom-as-string-subtype edge).
  let retStrWiden = false
  let retUNm = ""
  let retVi = -1
  if fn is FuncDecl {
    // A concrete-variant return (annotated `: Cat`, or a collapsed inferred lambda).
    if retVariantFlag(fn.fnRet) == 1 {
      retVi = variantIndexOf(tyNameOf(fn.fnRet))
    }
    if fn.fnRet < 0 {
      const rvi2 = cbRetVariantIdx(fnStmtsPosOf(fnIx))
      if rvi2 >= 0 { retVi = rvi2 }
    }
    if retF32Flag(fn.fnRet) == 1 { retF32 = true }
    if retF64Flag(fn.fnRet) == 1 { retF64 = true }
    if retI64Flag(fn.fnRet) == 1 { retI64 = true }
    // An UN-annotated return INFERRED as i64/f64 (the `fRet*` tables the A20 pass fills) widens
    // its value too — without this a `return 0` (an i32 literal) in a function whose other
    // branch returns a big i64 / an f64 expression stays `i32.const`, clashing with the i64/f64
    // functype result the inferred-return path declares (a soundness hole the checker accepts).
    if fn.fnRet < 0 {
      const rfe = fnStmtsPosOf(fnIx)
      if rfe >= 0 {
        if fRetI64[rfe] == 1 { retI64 = true }
        if fRetF64[rfe] == 1 { retF64 = true }
        // The f32 dual: an inferred f32 return whose body carries a float LITERAL (`(v: f32) =>
        // v * 2.0`) emits f64 unless forced — the functype result is f32 (#614), so without this
        // the body clashes with it ("return expected f32, got f64"). `return x` (a bare f32) was
        // already f32; only a literal-bearing f32 expression needed the coercion.
        if fRetF32[rfe] == 1 { retF32 = true }
      }
    }
    // A literal-union return reads as a union NAME but is an i32 ATOM — exclude it from the value-union
    // box return (`emitUnionBoxArg` would `struct.new` the member).
    if retUnionFlag(fn.fnRet) == 1 {
      if !nameIsLitUnionType(tyNameOf(fn.fnRet)) { retUNm = tyNameOf(fn.fnRet) }
    }
    if fn.fnRet < 0 {
      const im = inferRetNameOf(fn.fnName)
      // A VALUE union (`i32 | string`) OR a registered STRUCT-union (`Cat | Dog`) inferred
      // return is a union-BOX return (kind 4): box each concrete-variant / value-atom `return`
      // into the shared `{tag, payload}` rep via `retUNm`. Without the struct-union case an
      // un-annotated `Cat | Dog` return emitted the raw variant ref (invalid wasm) — the
      // annotated `: Cat | Dog` path already boxes (`retUnionFlag` above).
      if isValueUnionName(im) || isUName(im) { retUNm = im }
    }
    // A CONCRETE-variant return (`: Cat`, or a collapsed-to-one-variant inferred lambda):
    // route the value through `emitVariantCoerce` so a mixed-rep value-`if` (a narrowed
    // union arm + a literal arm) lands in ONE variant rep. Overrides the `pendingVariantIdx`
    // literal seeding above — `emitVariantCoerce` builds the literal itself.
    if retVi >= 0 { pendingVariantIdx = -1 }
    if tyIsNulBool(fn.fnRet) { retNulBool = true }
    if retNulStringFlag(fn.fnRet) == 1 { retNulString = true }
    if retNulListFlag(fn.fnRet) == 1 { retNulList = true }
    if nameIsLitUnionType(tyNameOf(fn.fnRet)) { retLitUnion = true }
    if tyNameOf(fn.fnRet) == "string" {
      if exprIsLitAtom(retArg, fnIx) { retStrWiden = true }
    }
    // Inferred niche nullable (un-annotated): seed the niche from the A20 name so a
    // `return null` / `return <bool|string>` lowers as the sentinel / `ref.null` rep.
    if fn.fnRet < 0 {
      const nn = inferNicheNullByName(fn.fnName)
      if nn == "boolean|null" { retNulBool = true }
      if nn == "string|null" { retNulString = true }
    }
  }
  if retF32 {
    const savedF32 = pendingF32
    pendingF32 = true
    if emitExprAsF32(body, retArg, fnIx) < 0 { return -1 }
    pendingF32 = savedF32
  } else if retF64 {
    if emitExprAsF64(body, retArg, fnIx) < 0 { return -1 }
  } else if retI64 {
    if emitExprAsI64(body, retArg, fnIx) < 0 { return -1 }
  } else if retVi >= 0 {
    if emitVariantCoerce(body, retVi, retArg, fnIx) < 0 { return -1 }
  } else if retUNm != "" {
    // `retUNm` is the union-BOX return (kind 4); a concrete variant `return s` (where `s: S`
    // and the return type is `C | S`) is boxed into the shared `{tag, payload}` rep here.
    if emitUnionBoxArg(body, retUNm, retArg, fnIx) < 0 { return -1 }
  } else if retStrWiden {
    // A literal-union atom returned from a `string`-typed function widens to its member string.
    if emitAtomToStr(body, retArg, fnIx) < 0 { return -1 }
  } else {
    const savedRNB = pendingNulBool
    const savedRNS = pendingNulString
    const savedRNL = pendingNulList
    const savedRLU = pendingLitUnion
    if retNulBool { pendingNulBool = true }
    if retNulString { pendingNulString = true }
    if retNulList { pendingNulList = true }
    if retLitUnion { pendingLitUnion = 1 }
    if emitExpr(body, retArg, fnIx) < 0 { return -1 }
    pendingNulBool = savedRNB
    pendingNulString = savedRNS
    pendingNulList = savedRNL
    pendingLitUnion = savedRLU
  }
  pendingStructIdx = -1
  pendingVariantIdx = -1
  pendingListKind = 0
  pendingListSlot = 0
  0
}

function fnRetNullBearing(fnIx: i32) {
  const fn = P.nodes[fnIx]
  if !(fn is FuncDecl) { return false }
  const r = fn.fnRet
  if tyIsNulBool(r) { return true }
  if retNulStringFlag(r) == 1 { return true }
  if retNulRefFlag(r) == 1 { return true }
  if retNulListFlag(r) == 1 { return true }
  if retUnionFlag(r) == 1 { return unionHasAtom(tyNameOf(r), "null") }
  if r < 0 {
    const im = inferRetNameOf(fn.fnName)
    if isValueUnionName(im) { return unionHasAtom(im, "null") }
    if inferNicheNullByName(fn.fnName) != "" { return true }
  }
  false
}

// Emit the `null` value of function `fnIx`'s nullable return rep, leaving it on the
// stack as the function's result (the fall-through path's implicit `return null`).
// Each arm mirrors the `NullLit` lowering for that rep: the `boolean|null` i32 sentinel
// `2`, the `string|null` typed `ref.null $array`, a nullable struct `ref.null $S`, a
// nullable i32-list `ref.null $lTypeIdx`, and the value-union null-tagged box. Guarded
// by `fnRetNullBearing`; an unsupported rep fails loudly.
function emitNullForRet(body: i32[], fnIx: i32) {
  const fn = P.nodes[fnIx]
  if !(fn is FuncDecl) { return emitFail("emitNullForRet: not a function") }
  const r = fn.fnRet
  if tyIsNulBool(r) {
    fbI32Const(2)
    return 0
  }
  if retNulStringFlag(r) == 1 {
    wU8(208) // 0xd0 ref.null
    wSLEB(aTypeIdx)
    return 0
  }
  if retNulRefFlag(r) == 1 {
    const rsi = retNulRefIndex(r)
    if rsi >= 0 && rsi < sHeapIdx.length {
      wU8(208) // 0xd0 ref.null
      wSLEB(sHeapIdx[rsi])
      return 0
    }
  }
  if retNulListFlag(r) == 1 {
    wU8(208) // 0xd0 ref.null
    wSLEB(lTypeIdx)
    return 0
  }
  // Value-union box (annotated `i32 | null`, or an inferred return widened to it): the
  // null-tagged box `{ tag: null, payload: ref.null }` — identical to `emitUnionCoerce`'s
  // bare-`null` path.
  let isU = false
  if retUnionFlag(r) == 1 { isU = true }
  if r < 0 {
    if isValueUnionName(inferRetNameOf(fn.fnName)) { isU = true }
  }
  if isU {
    fbI32Const(scalarTagOf("null"))
    fbRefNullNone() // payload slot unread under the null tag
    fbStructNew(uBoxIdx)
    return 0
  }
  // Inferred NICHE nullable (un-annotated `boolean | null` / `string | null`): same null
  // rep as the annotated niche, recognized by name (no `fn.fnRet` node to read).
  if r < 0 {
    const nn = inferNicheNullByName(fn.fnName)
    if nn == "boolean|null" {
      fbI32Const(2)
      return 0
    }
    if nn == "string|null" {
      wU8(208) // 0xd0 ref.null
      wSLEB(aTypeIdx)
      return 0
    }
  }
  emitFail("emitNullForRet: unsupported nullable return rep")
}

function emitStmt(body: i32[], stmtIx: i32, fnIx: i32) {
  if stmtIx < 0 { return emitFail("emitProgram: missing statement") }
  let s = P.nodes[stmtIx]
  if s is FuncDecl {
    // A NESTED function declaration statement (`function add(x) x + n`): it was lifted to
    // a top-level wasm function by `collectFns`, so it emits no inline code here — just a
    // no-op in its enclosing body. Its name resolves as a closure value when referenced.
    return 0
  }
  if s is LetDecl {
    // `let x = <expr>` / `const x = <expr>`: emit the init, then store it into the
    // local's slot. This `LetDecl`'s slot is the next cursor position (collect allocated
    // slots in this SAME pre-order), so it owns declared-local slot `emitLetCursor` —
    // do NOT name-resolve it (a name lookup would hit an outer same-named binding still
    // in scope here). `paramN + slot` is its wasm local index.
    let slot = emitLetCursor
    emitLetCursor = emitLetCursor + 1
    let paramN = 0
    // The START function (`fnIx == -1`, top-level statements) has no params — and no
    // arena node to read, so the lookup must be guarded.
    if fnIx >= 0 {
      const fn = P.nodes[fnIx]
      if fn is FuncDecl { paramN = fn.fnParams.length + envSlotShift(fnIx) }
    }
    const idx = paramN + slot
    if s.letInit < 0 {
      // UNINITIALIZED scalar local (validated by `checkLocalI32`): nothing to store
      // — the wasm local's implicit zero-init covers the declaration; bind the name
      // so later reads/writes resolve to this slot.
      scopeBind(s.letName, slot)
      return 0
    }
    // VALUE-FLOW MONOMORPHIZATION: a `const g = f` binding to a GENERIC (un-annotated-param)
    // NAMED function, where `g` is used ONLY as a direct-call callee (`g(args)`), is sound.
    // `monomorphize` rewrote each `g(args)` to its per-call instance (the first/i32 shape stays
    // on `f`'s own slot, keeping its un-annotated params for byte-identity), so the closure
    // stored here is `call_ref`'d only at the type its slot was pinned to. The value floor in
    // `emitClosureValue` would reject it on those un-annotated params, so emit through the
    // floor-LESS core. A value-USE of `g` (passed, returned, stored) escapes — `nameUsedAsValueIn`
    // catches it — and falls through to the normal path, where the floor rejects it.
    if fnIx >= 0 {
      const aliasFe = fieldValueFeOf(s.letInit)
      if fnHasUnannotatedParam(aliasFe) {
        if !criFnIsAnonLambda(aliasFe) {
          const encl = P.nodes[fnIx]
          if encl is FuncDecl {
            if !nameUsedAsValueIn(s.letName, encl.fnBody) {
              if emitClosureValueCore(body, aliasFe, fnIx) < 0 { return -1 }
              fbLocalSet(idx) // 0x21 local.set
              scopeBind(s.letName, slot)
              return 0
            }
          }
        }
      }
    }
    // A degenerate UN-ANNOTATED `let x = null` (A-infer-null): when NO later
    // assignment fills the hole (`nliNameOf` recorded nothing), the binding's
    // type is the plain `null` type — it is never read as a non-null value, so
    // its i32 cell just zero-inits. A FILLED hole (`x = 5` later) is a `T|null`
    // value-union binding (kind 4) and takes the union-coerce path below.
    if s.letType < 0 {
      const bareN = P.nodes[unwrapParen(s.letInit)]
      if bareN is NullLit {
        if nliNameOf(stmtIx) == "" {
          fbI32Const(0)
          fbLocalSet(idx) // 0x21 local.set
          scopeBind(s.letName, slot)
          return 0
        }
      }
    }
    // An empty `[]` initializer over a ref-array annotation (`let xs: T[] = []`) needs
    // the element kind to pick the ref-list construction — record it for `emitArr`.
    pendingListKind = letAnnRefListKind(stmtIx)
    pendingListSlot = letAnnRefListSlot(stmtIx)
    // A kind-18 nullable ref-array binding: a bare `null` init lowers as `ref.null $innerWrapper`. The list
    // value seeds above (`pendingListKind`/`Slot`) build a non-null list; this seeds the null arm.
    if localIsRef[slot] == 18 {
      if pendingListSlot >= 0 && pendingListSlot < rlWrapIdx.length {
        pendingNulRefHeap = rlWrapIdx[pendingListSlot]
      }
    }
    // A kind-15 nullable i32-list binding (`i32[] | null = null`): a bare `null` init lowers as
    // `ref.null $lTypeIdx` (the `pendingNulList` arm), the scalar-list analogue of the kind-18 seed above.
    // Without this a literal `= null` init fell through to the bare-null error (the type/narrowing worked,
    // but an actual null value never lowered).
    let letNulList15 = localIsRef[slot] == 15
    // An UN-annotated empty `[]` whose USAGE pins a string element (`const out = [];
    // out.push(self[i])`): seed the string-list kind so `emitArr` builds the string-list
    // wrapper, MATCHING the slot `collectLocals` typed (kind 7, via the same
    // `letInfStrListByUseV`). Without this the inferred `[]` defaults to the i32 list and
    // the slot store mismatches. Unblocks a generic build-loop (`slice`/`reverse`) over
    // `string[]`.
    if pendingListKind == 0 && letInfStrListByUseV(stmtIx, fnIx) {
      pendingListKind = 3
    }
    // A `let b: B = { … }` struct LITERAL must build the annotation's struct, not a
    // first-field-name match — seed `pendingStructIdx` (consumed by `emitObj`) from the
    // annotation when it names a standalone struct, so a same-field-name sibling struct
    // does not win. Mirrors the call-arg / element / return / global seeding. A union
    // annotation names no `sNames` entry (`letAnnStructIdx` is -1) so a variant literal
    // still boxes; a non-struct-literal init ignores the hint.
    pendingStructIdx = letAnnStructIdx(stmtIx)
    // A NULLABLE-struct binding (`let b: P | null = …`, slot kind 9) seeds the SAME struct
    // context from the slot's recorded struct index — a bare `null` init lowers as
    // `ref.null $P` (the union annotation names no `sNames` entry, so `letAnnStructIdx`
    // gave -1), a struct literal builds that struct. Mirrors the global kind-9 cell seeding.
    if pendingStructIdx < 0 {
      if localIsRef[slot] == 9 { pendingStructIdx = localStructIdx[slot] }
    }
    // A `const c: Cat = { … }` variant-typed binding seeds the VARIANT index so the object
    // literal builds the bare variant struct (kind 8) instead of boxing into the union.
    pendingVariantIdx = letAnnVariantIdx(stmtIx)
    // A map-typed binding seeds the map SHAPE so a `Map()` initializer constructs
    // THIS binding's map struct (mono, or the annotation's ref-valued mv slot).
    if letIsMap(stmtIx, fnIx) { pendingMapSlot = letMapShapeOf(stmtIx, fnIx) }
    // Numeric WIDENING at the binding boundary: an `: f64` / `: f32` / `: i64` slot
    // coerces a narrower init value (the lattice convert is inserted by the `emitExprAs*`
    // helpers — i32/i64/f32→f64, i32→f32, i32→i64). A float/integer literal re-encodes in
    // place via `pendingF32`/`pendingI64`. An i32-only binding stays byte-identical.
    // A UNION-annotated binding (kind 4) coerces a raw init value into the box
    // (`let u: boolean | i32 = 5` boxes the 5 with its atom tag); an already-union
    // init (a union-returning call) and a struct-union object literal pass through
    // `emitUnionCoerce` unchanged.
    let letUNm = ""
    let letAnnNm = ""
    if s.letType >= 0 { letAnnNm = tyNameOf(s.letType) }
    // A filled null hole (`let x = null` + later `x = e`, A-infer-null) is its
    // inferred `T|null` value union — coerce the bare `null` init into the box.
    if isUName(letAnnNm) && !nameIsLitUnionType(letAnnNm) {
      // A literal union (`type K = "a" | "b"`) reads as a union NAME but is an i32 ATOM, not a value-union
      // box — so it must NOT take the `emitUnionCoerce` path (which would `struct.new` the member).
      letUNm = letAnnNm
    } else if !isUName(letAnnNm) {
      letUNm = nliNameOf(stmtIx)
    }
    // A nullable / value-union if-EXPRESSION init (`const x: i32 | null = if c then 5
    // else null`, `else if` chains) lowers by writing the binding's own local in each
    // arm of a void `if` — no value-typed-if blocktype or scratch slot needed (the
    // binding local IS the destination). The slot kind `collectLocals` already chose is
    // the authoritative rep: kind 4 the value-union box (rep 0, needs the union NAME to
    // box each arm's atom — taken from the annotation / `letUNm`), kind 16 a `string |
    // null` ref (rep 1), kind 17 a `boolean | null` niche i32 (rep 2, sentinel 2 = null).
    if exprIsIfStmt(s.letInit) {
      const slotKind = localIsRef[slot]
      let nulRep = -1
      let nulNm = ""
      if slotKind == 4 {
        if letUNm != "" { nulNm = letUNm }
        else if s.letType >= 0 { nulNm = tyNameOf(s.letType) }
        if nulNm != "" { nulRep = 0 }
      } else if slotKind == 16 {
        nulRep = 1
      } else if slotKind == 17 {
        nulRep = 2
      }
      if nulRep >= 0 {
        // The value-union box local (kind 4) is a NON-null `(ref $uBoxIdx)` — non-
        // defaultable, so the validator needs it definitely assigned. Both arms below
        // set it, but a void-`if` merge does not satisfy V8's local-init check; pre-seed
        // the rep's null first (overwritten by every arm). The `string | null` (nullable
        // ref) rep is defaultable and needs no pre-seed.
        if nulRep == 0 {
          if emitNulNullToLocal(body, idx, 0) < 0 { return -1 }
        }
        if (
          emitNullableIfBinding(body, s.letInit, idx, nulRep, nulNm, fnIx) <
          0
        ) {
          return -1
        }
        scopeBind(s.letName, slot)
        return 0
      }
    }
    if localIsRef[slot] == 19 {
      // A NULLABLE function-value binding (`let c: ((i32) => i32) | null = …`): the slot is
      // `(ref null $cloStruct)`. A bare `null` init lowers as `ref.null $cloStruct`
      // (`pendingNulClosure`); a function init stores its closure ref directly. Takes
      // priority over the union-coerce path (the `fn | null` annotation reads as a union
      // NAME, but this is a niche nullable ref, not a box).
      const savedNC = pendingNulClosure
      pendingNulClosure = true
      if emitExpr(body, s.letInit, fnIx) < 0 { return -1 }
      pendingNulClosure = savedNC
    } else if letUNm != "" {
      if emitUnionCoerce(body, letUNm, s.letInit, fnIx) < 0 { return -1 }
    } else if letIsF32(stmtIx) {
      const savedF32 = pendingF32
      pendingF32 = true
      if emitExprAsF32(body, s.letInit, fnIx) < 0 { return -1 }
      pendingF32 = savedF32
    } else if letIsF64(stmtIx, fnIx) {
      if emitExprAsF64(body, s.letInit, fnIx) < 0 { return -1 }
    } else if letIsI64(stmtIx, fnIx) {
      if emitExprAsI64(body, s.letInit, fnIx) < 0 { return -1 }
    } else if letAnnNm == "string" && exprIsLitAtom(s.letInit, fnIx) {
      // A literal-union atom initializing a `string` local widens to its member string.
      if emitAtomToStr(body, s.letInit, fnIx) < 0 { return -1 }
    } else {
      // A `boolean|null` NICHE binding lowers a bare `null` init as the sentinel 2; a
      // `string|null` binding lowers it as `ref.null $aTypeIdx`. `letNulBool` (not just
      // the annotation) so an INFERRED niche binding (`const r = f()` where `f` returns
      // `boolean | null`) seeds the sentinel too.
      pendingNulBool = letNulBool(stmtIx, fnIx)
      pendingNulString = letIsNulString(stmtIx, fnIx)
      if s.letType >= 0 {
        if nameIsLitUnionType(tyNameOf(s.letType)) { pendingLitUnion = 1 }
      }
      const savedNulList = pendingNulList
      if letNulList15 { pendingNulList = true }
      if emitExpr(body, s.letInit, fnIx) < 0 { return -1 }
      pendingNulBool = false
      pendingNulString = false
      pendingNulList = savedNulList
      pendingLitUnion = 0
    }
    pendingI64 = false
    pendingStructIdx = -1
    pendingVariantIdx = -1
    pendingListKind = 0
    pendingListSlot = 0
    pendingMapSlot = -1
    pendingNulRefHeap = -1
    fbLocalSet(idx) // 0x21 local.set
    // Bind `name → slot` in the current emit-time frame AFTER emitting the init (so the
    // init resolved any same-named OUTER binding), making this binding live for the rest
    // of the block — mirrors the collect pass so resolution matches slot allocation.
    scopeBind(s.letName, slot)
    return 0
  }
  if s is BinExpr {
    // A bare `BinExpr` statement is an assignment (`x = <expr>`); any OTHER operator
    // in statement position is a DISCARDED value (`1 + 1` as a tail statement of a
    // void function) — evaluate it for effect, then `drop` the value it leaves.
    if s.binOp == "=" { return emitAssign(body, stmtIx, fnIx) }
    if emitExpr(body, stmtIx, fnIx) < 0 { return -1 }
    fbDrop() // 0x1a drop
    return 0
  }
  if s is Unary {
    // Postfix `x++` / `x--` in STATEMENT position: the OLD-value result is discarded,
    // so emit just the inner increment assignment (`x = x ± 1`) — byte-identical to a
    // plain assignment statement, with no value left on the stack.
    if s.unOp == "p+" || s.unOp == "p-" {
      return emitAssign(body, s.unArg, fnIx)
    }
    return emitFail("emitProgram: unsupported unary statement")
  }
  if s is Call {
    // The only call STATEMENT this slice lowers is a list append `recv.push(x)` (a
    // `Call` whose `callFn` is a `Member`). A bare top-level call statement (a function
    // call whose value is discarded) is out of scope.
    const callee = P.nodes[s.callFn]
    if callee is Member {
      if callee.memProp == "push" { return emitPush(body, stmtIx, fnIx) }
      // A `.pop()` STATEMENT discards the popped element — emit the pop, then `drop`
      // the value it leaves on the stack.
      if callee.memProp == "pop" {
        if emitPop(body, stmtIx, fnIx) < 0 { return -1 }
        fbDrop() // 0x1a drop
        return 0
      }
      // A `.clear()` STATEMENT resets the list's length to 0 (backing retained).
      if callee.memProp == "clear" {
        if (
          exprArray(callee.memObj, fnIx) ||
          exprRefArray(callee.memObj, fnIx) ||
          exprStringArray(callee.memObj, fnIx)
        ) {
          return emitClear(body, stmtIx, fnIx)
        }
      }
      // G8: a map `m.set(k, v)` STATEMENT is the method form of `m[k] = v` — the
      // same scan/overwrite-or-append lowering.
      if callee.memProp == "set" {
        if exprMap(callee.memObj, fnIx) {
          if s.callArgs.length != 2 {
            return emitFail("emitProgram: map set takes exactly two arguments")
          }
          return emitMapSet(body, callee.memObj, s.callArgs[0], s.callArgs[1], fnIx)
        }
      }
      // A Set `s.add(k)` STATEMENT is the membership-insert form of `s[k] = true` — the
      // SAME scan/overwrite-or-append lowering as `emitMapSet`, but storing the constant
      // boolean `1` (true) as the value (the Set vals-list carries true for live keys).
      // It takes EXACTLY one arg; the result (if any) is discarded.
      if callee.memProp == "add" {
        if exprMap(callee.memObj, fnIx) {
          if s.callArgs.length != 1 {
            return emitFail("emitProgram: set add takes exactly one argument")
          }
          return emitMapSetV(body, callee.memObj, s.callArgs[0], -1, fnIx, true)
        }
      }
      // G8: a bare `m.delete(k)` STATEMENT discards the boolean result — emit the
      // delete, then `drop` the 0/1 it leaves on the stack.
      if callee.memProp == "delete" {
        if exprMap(callee.memObj, fnIx) {
          if s.callArgs.length != 1 {
            return emitFail("emitProgram: map delete takes exactly one argument")
          }
          if emitMapDelete(body, callee.memObj, s.callArgs[0], fnIx) < 0 {
            return -1
          }
          fbDrop() // 0x1a drop (discard the boolean result)
          return 0
        }
      }
      // A CLOSURE-FIELD member call STATEMENT (`(o."[]=")(k, v)` — the rewritten
      // index WRITE trap, or any function-valued field invoked for effect):
      // `call_ref` it; drop the result unless the field's function is void.
      if exprIsClosure(s.callFn, fnIx) {
        if emitCallRef(body, stmtIx, fnIx) < 0 { return -1 }
        const mcFe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
        let mcVoid = false
        if mcFe >= 0 {
          if fRetVoid[mcFe] == 1 { mcVoid = true }
        }
        if !mcVoid {
          fbDrop() // 0x1a drop (discard the unused result)
        }
        return 0
      }
      return emitFail("emitProgram: unsupported member-call statement")
    }
    if callee is Ident {
      // A bare call whose RESULT is discarded (a helper invoked for its side
      // effects): emit the call, then `drop` the value it leaves — EXCEPT `print`
      // (a void import) and a VOID function (`()->()` leaves nothing).
      if emitCall(body, stmtIx, fnIx) < 0 { return -1 }
      let dropIt = callee.identName != "print"
      // The void memory intrinsics leave nothing on the stack.
      if callee.identName == "__store_i32__" { dropIt = false }
      if callee.identName == "__log__" { dropIt = false }
      // The void array intrinsics: `__array_copy__` leaves nothing; `__trap__`
      // is `unreachable` (no value reaches the drop).
      if callee.identName == "__array_copy__" { dropIt = false }
      if callee.identName == "__trap__" { dropIt = false }
      if dropIt {
        const vt = fnIndexOf(callee.identName)
        if vt >= 0 {
          if fRetVoid[vt] == 1 { dropIt = false }
        } else if calleeReturnsVoid(callee.identName, fnIx) {
          // A closure-VALUE callee (a param / binding, invisible to `fnIndexOf`) whose
          // `$fnsig` is void leaves nothing — no `drop`.
          dropIt = false
        }
      }
      if dropIt {
        fbDrop() // 0x1a drop
      }
      return 0
    }
    return emitFail("emitProgram: bare call statement is not supported")
  }
  if s is RetStmt {
    if s.retArg < 0 {
      return emitFail("emitProgram: bare return is not supported")
    }
    // Seed the return context + emit the value (struct / list / union / nullable /
    // widening) via the shared helper, then the `return` instruction.
    if emitReturnValue(body, s.retArg, fnIx) < 0 { return -1 }
    fbReturn() // 0x0f return
    return 0
  }
  if s is IfStmt {
    // Structured void `if`: push the i32 condition, then `if 0x04` with void
    // blocktype `0x40`. The then-branch's statements run when the condition is
    // non-zero; an optional `else 0x05` branch runs otherwise; `end 0x0b` closes it.
    // Both branches `return` on their own, so the `if` yields no value.
    if emitExpr(body, s.ifCond, fnIx) < 0 { return -1 }
    fbIf(64) // 0x04 if, 0x40 void blocktype
    // The `if` opens ONE control frame (the `else` reuses it, `end` closes it), so a
    // `break`/`continue` nested in either arm sees the right relative `br` depth.
    ctrlEnter()
    // If the condition is `n is Variant` over a bare union identifier, narrow `n` to
    // that variant for the THEN-branch only (so `n.field` downcasts). Save/restore the
    // outer narrowing around the branch so nesting and the else-branch are unaffected.
    const savedTop = narrowTop
    const narrowed = setNarrowFromCond(s.ifCond, fnIx)
    if emitStmts(body, s.ifThen, fnIx) < 0 { return -1 }
    if narrowed { restoreNarrow(savedTop) }
    if s.ifElse >= 0 {
      fbElse() // 0x05 else
      // The else may be a Block or a nested IfStmt (`else if`); both go through
      // `emitStmt` (a lone statement) — a Block re-enters `emitStmts`. The then
      // narrowing does NOT hold in the else-branch (the guard was false there);
      // a VALUE union narrows to the COMPLEMENT set instead (`is T` removes `T`).
      const savedElseTop = narrowTop
      const narrowedElse = setNarrowFromCondElse(s.ifCond, fnIx)
      const els = P.nodes[s.ifElse]
      if els is Block {
        if emitStmts(body, s.ifElse, fnIx) < 0 { return -1 }
      } else {
        if emitStmt(body, s.ifElse, fnIx) < 0 { return -1 }
      }
      if narrowedElse { restoreNarrow(savedElseTop) }
    }
    fbEnd() // 0x0b end
    ctrlLeave()
    return 0
  }
  if s is WhileStmt {
    // Structured while loop: block (void) wrapping a loop (void).
    // The condition is checked at the top; if false (eqz), br_if 1 exits the block;
    // body runs, then br 0 continues the loop. Two `end` bytes close loop then block.
    // Track the two control frames so `break`/`continue` in the body compute their
    // relative `br` depth: the BLOCK is the `break` target (resume after the loop),
    // the LOOP is the `continue` target (re-check the condition). Push the ABSOLUTE
    // `ctrlDepth` of each frame; a branch site at depth D uses `D - <that depth>`.
    fbBlock(64) // 0x02 block, 0x40 void blocktype
    ctrlEnter()
    loopBrkDepth.push(ctrlDepth)
    loopBrkLabel.push(s.whileLabel)
    fbLoop(64)  // 0x03 loop, 0x40 void blocktype
    ctrlEnter()
    loopContDepth.push(ctrlDepth)
    loopContLabel.push(s.whileLabel)
    // condition + eqz: if condition is false (zero), exit block
    if emitExpr(body, s.whileCond, fnIx) < 0 { return -1 }
    fbI32Eqz() // 0x45 i32.eqz (invert: exit if condition was false)
    fbBrIf(1)  // 0x0d br_if, depth 1 = break out of block
    // body statements
    if emitStmts(body, s.whileBody, fnIx) < 0 { return -1 }
    fbBr(0) // 0x0c br, depth 0 = continue loop
    fbEnd() // 0x0b end (loop)
    ctrlLeave()
    loopContDepth.pop()
    loopContLabel.pop()
    fbEnd() // 0x0b end (block)
    ctrlLeave()
    loopBrkDepth.pop()
    loopBrkLabel.pop()
    return 0
  }
  if s is ForRange {
    // `for v in A to B [step K] { body }` — an INCLUSIVE numeric range, lowered to
    // the same block/loop shape as `while`. The loop var `v` and a synthetic bound
    // temp own the next TWO cursor slots (collectLocals allocated them in this same
    // pre-order). The step must be a CONSTANT integer literal (optionally negated);
    // its SIGN picks the exit comparison: ascending exits when v > bound (i32.le_s
    // + eqz), descending when v < bound (i32.ge_s + eqz). The bound is evaluated
    // ONCE into the temp.
    const vSlot = emitLetCursor
    emitLetCursor = emitLetCursor + 1
    const bSlot = emitLetCursor
    emitLetCursor = emitLetCursor + 1
    let paramN = 0
    if fnIx >= 0 {
      const fn = P.nodes[fnIx]
      if fn is FuncDecl { paramN = fn.fnParams.length + envSlotShift(fnIx) }
    }
    const vIdx = paramN + vSlot
    const bIdx = paramN + bSlot
    // Static step: default +1; `step <int>` / `step -<int>`.
    let stepK = 1
    if s.frStep >= 0 {
      const st = P.nodes[s.frStep]
      if st is NumLit {
        stepK = parseI32(st.numText)
      } else if st is Unary {
        if st.unOp == "-" {
          const inner = P.nodes[st.unArg]
          if inner is NumLit {
            stepK = 0 - parseI32(inner.numText)
          } else {
            return emitFail("emitProgram: for-range step must be a constant integer")
          }
        } else {
          return emitFail("emitProgram: for-range step must be a constant integer")
        }
      } else {
        return emitFail("emitProgram: for-range step must be a constant integer")
      }
    }
    if stepK == 0 {
      return emitFail("emitProgram: for-range step must not be zero")
    }
    // v = A; bound = B (each evaluated once, in source order)
    if emitExpr(body, s.frFrom, fnIx) < 0 { return -1 }
    fbLocalSet(vIdx)
    if emitExpr(body, s.frTo, fnIx) < 0 { return -1 }
    fbLocalSet(bIdx)
    // Bind the loop var for the body (mirrors the collect pass's scopeBind).
    scopeBind(s.frVar, vSlot)
    fbBlock(64) // 0x02 block, void
    ctrlEnter()
    loopBrkDepth.push(ctrlDepth)
    loopBrkLabel.push(s.frLabel)
    fbLoop(64)  // 0x03 loop, void
    ctrlEnter()
    loopContDepth.push(ctrlDepth)
    loopContLabel.push(s.frLabel)
    // continue-condition: le_s (ascending) / ge_s (descending), inverted to exit
    fbLocalGet(vIdx)
    fbLocalGet(bIdx)
    if stepK > 0 {
      fbI32Bin(76) // 0x4c i32.le_s
    } else {
      fbI32Bin(78) // 0x4e i32.ge_s
    }
    fbI32Eqz() // 0x45 invert: exit when out of range
    fbBrIf(1)  // 0x0d br_if -> break out of block
    // A body with a `continue` binding to THIS loop (direct, or `continue
    // <label>` from a nested loop) needs an INNER block as the continue
    // target: branching to its END falls into the increment (a branch to the
    // loop header would SKIP the increment — an infinite loop). A body without
    // one keeps the original two-frame shape (goldens pinned on it). The inner
    // block carries the loop's LABEL too, shadowing the header entry, so a
    // binding `continue` lands on the increment.
    const frHasCont = blockHasContinueFor(s.frBody, s.frLabel, false)
    if frHasCont {
      fbBlock(64) // continue block
      ctrlEnter()
      loopContDepth.push(ctrlDepth)
      loopContLabel.push(s.frLabel)
    }
    if emitStmts(body, s.frBody, fnIx) < 0 { return -1 }
    if frHasCont {
      fbEnd() // end continue block — `continue` lands here
      ctrlLeave()
      loopContDepth.pop()
      loopContLabel.pop()
    }
    // v = v + K
    fbLocalGet(vIdx)
    fbI32Const(stepK)
    fbI32Bin(106) // 0x6a i32.add
    fbLocalSet(vIdx)
    fbBr(0)       // continue loop
    fbEnd()       // end loop
    ctrlLeave()
    loopContDepth.pop()
    loopContLabel.pop()
    fbEnd()       // end block
    ctrlLeave()
    loopBrkDepth.pop()
    loopBrkLabel.pop()
    // The loop variable's scope is the loop (see `scopeUnbind`).
    scopeUnbind()
    return 0
  }
  if s is ForIn {
    // `for v in <list> { body }` — iterate an i32 list, a string list, a struct
    // `S[]` ref list, or a map's ordered `.keys()`/`.values()` list. THREE cursor
    // slots in collect pre-order: the element var `v` (i32, a string ref, or a struct
    // ref), a hidden i32 cursor `v#i`, and a hidden list temp `v#l` (the iterable
    // evaluates ONCE). Shape mirrors `while`: block/loop, exit on `cursor >= len`,
    // element read per iteration, cursor++.
    const ek = forInElemKind(s.fiIter, fnIx)
    if ek < 0 { return emitFail("emitProgram: unsupported for-in iterable") }
    // A STRING iterable (`for ch in s`): the `#l` temp IS the raw `(ref $aTypeIdx)` array (no
    // list wrapper), so the length is `array.len` and each element `array.get $aTypeIdx` —
    // skipping the `struct.get wrapTy` the i32-list path uses. The loop var is an i32 code unit.
    const strSrc = forInStringSrc(s.fiIter, fnIx)
    const vSlot = emitLetCursor
    emitLetCursor = emitLetCursor + 1
    const iSlot = emitLetCursor
    emitLetCursor = emitLetCursor + 1
    const lSlot = emitLetCursor
    emitLetCursor = emitLetCursor + 1
    let paramN = 0
    if fnIx >= 0 {
      const fn = P.nodes[fnIx]
      if fn is FuncDecl { paramN = fn.fnParams.length + envSlotShift(fnIx) }
    }
    const vIdx = paramN + vSlot
    const iIdx = paramN + iSlot
    let lIdx = paramN + lSlot
    let wrapTy = lTypeIdx
    let backTy = aTypeIdx
    if ek == 3 {
      wrapTy = mkListIdx
      backTy = mkArrIdx
    } else if (
      ek == 1 ||
      ek == 4 ||
      ek == 9 ||
      ek == 2 ||
      ek == 7 ||
      ek == 12 ||
      ek == 20 ||
      ek == 21 ||
      ek == 14 ||
      ek == 5
    ) {
      // A struct ref list (`S[]`, ek 1), a UNION-box element list (`(C|S)[]`, ek 4), a
      // NULLABLE-struct element list (`(P|null)[]`, ek 9), a CLOSURE element list
      // (`((i32)=>i32)[]`, ek 14), a NESTED-ARRAY scalar inner list (ek 2/7/12/20), or a NESTED
      // REF array whose loop var is the inner REF LIST (`S[][]`, ek 5): the wrapper/backing are
      // THIS ref-list
      // slot's. All recover each element non-null EXCEPT ek 9 (the nullable niche). A
      // STRUCT-VALUED map walk reads its mv slot's vals list instead.
      const fimv = forInMapValsSlot(s.fiIter, fnIx)
      if fimv >= 0 {
        wrapTy = mvValsWrapOf(fimv)
        backTy = mvValsBackOf(fimv)
      } else {
        let rslot = refListSlotOfExpr(s.fiIter, fnIx)
        wrapTy = rlWrapIdx[rslot]
        backTy = rlBackIdx[rslot]
      }
    } else if ek == 11 || ek == 10 || ek == 13 {
      // A scalar f64/i64/f32 element list: the wrapper/backing come from the descriptor, and
      // `array.get <back>` yields the scalar directly (no `ref.as_non_null`).
      wrapTy = scalarListWrap(ek)
      backTy = scalarListBack(ek)
    }
    // For a map `.keys()`/`.values()` walk, stash the MAP ref (mono scratch slot 0,
    // or the mv frame's typed mapRef) so the loop can consult `M.live[cursor]` and
    // SKIP tombstoned entries (host-matching tombstone-aware iteration).
    // `mapRecv >= 0` iff this is a map iteration. The pinned `cmSlot` drives both
    // the stash and the skip's `pushMapLive` struct.get type.
    const mapRecv = forInMapRecv(s.fiIter, fnIx)
    let mwShape = -1
    if mapRecv >= 0 {
      mwShape = mapShapeOfExpr(mapRecv, fnIx)
      if mwShape == -2 || mwShape == -3 { mwShape = -1 }
      if emitExpr(body, mapRecv, fnIx) < 0 { return -1 }
      cmSlot = mwShape
      setMapRef(body) // mapRef
    }
    // list = <iter> (evaluated once); cursor = 0
    if emitForInList(body, s.fiIter, fnIx) < 0 { return -1 }
    // A NARROWED nullable-list iterable (`i32[] | null`, kind 15) keeps its
    // nullable slot; the `#l` temp is non-null, so recover first (checker-guarded).
    if exprNullableList(s.fiIter, fnIx) {
      wU8(212) // 0xd4 ref.as_non_null
    }
    fbLocalSet(lIdx)
    fbI32Const(0)
    fbLocalSet(iIdx)
    scopeBind(s.fiVar, vSlot)
    fbBlock(64) // 0x02 block, void
    ctrlEnter()
    loopBrkDepth.push(ctrlDepth)
    loopBrkLabel.push(s.fiLabel)
    fbLoop(64)  // 0x03 loop, void
    ctrlEnter()
    loopContDepth.push(ctrlDepth)
    loopContLabel.push(s.fiLabel)
    // exit when cursor >= len (the list wrapper's field 1; a STRING is the raw array → array.len)
    fbLocalGet(iIdx)
    fbLocalGet(lIdx)
    if strSrc { fbArrayLen() } else { fbStructGet(wrapTy, 1) }
    fbI32Bin(78) // 0x4e i32.ge_s
    fbBrIf(1)    // 0x0d br_if -> break out of block
    // TOMBSTONE SKIP: if M.live[cursor] == 0, advance the cursor and re-loop WITHOUT
    // binding `v` / running the body — the deleted entry is invisible to iteration
    // (insertion order of the survivors preserved). `br 1` targets the loop header
    // (if-frame is 0, loop is 1). A delete-free map has live all-1s, so never taken.
    if mapRecv >= 0 {
      cmSlot = mwShape
      pushMapLive(body)    // M.live (off the pinned mapRef)
      fbLocalGet(iIdx)
      fbArrayGet(aTypeIdx) // M.live[cursor]
      fbI32Eqz()           // live[cursor] == 0 ?
      fbIf(64)             // 0x04 if, void
      fbLocalGet(iIdx)
      fbI32Const(1)
      fbI32Bin(106)        // cursor + 1
      fbLocalSet(iIdx)
      fbBr(1)              // 0x0c br -> loop header (re-check exit)
      fbEnd()              // 0x0b end (if)
    }
    // v = backing[cursor] (a string element recovers its non-null ref). A STRING source IS the
    // raw array, so index it directly (no list-wrapper `struct.get`); the code unit is an i32.
    fbLocalGet(lIdx)
    if !strSrc { fbStructGet(wrapTy, 0) }
    fbLocalGet(iIdx)
    if strSrc { fbArrayGet(aTypeIdx) } else { fbArrayGet(backTy) }
    if (
      ek == 3 ||
      ek == 1 ||
      ek == 4 ||
      ek == 2 ||
      ek == 7 ||
      ek == 12 ||
      ek == 20 ||
      ek == 21 ||
      ek == 14 ||
      ek == 5
    ) {
      // string / struct / union-box / CLOSURE element, a NESTED-ARRAY inner-list wrapper, or a
      // nested-ref-array inner REF LIST (ek 5) — all are a non-null ref recovered from the
      // `(ref null <elem>)` backing slot.
      wU8(212) // 0xd4 ref.as_non_null
    }
    fbLocalSet(vIdx)
    // Same INNER continue block as for-range: `continue` must still increment.
    const fiHasCont = blockHasContinueFor(s.fiBody, s.fiLabel, false)
    if fiHasCont {
      fbBlock(64) // continue block
      ctrlEnter()
      loopContDepth.push(ctrlDepth)
      loopContLabel.push(s.fiLabel)
    }
    if emitStmts(body, s.fiBody, fnIx) < 0 { return -1 }
    if fiHasCont {
      fbEnd() // end continue block — `continue` lands here
      ctrlLeave()
      loopContDepth.pop()
      loopContLabel.pop()
    }
    // cursor = cursor + 1
    fbLocalGet(iIdx)
    fbI32Const(1)
    fbI32Bin(106) // 0x6a i32.add
    fbLocalSet(iIdx)
    fbBr(0)       // continue loop
    fbEnd()       // end loop
    ctrlLeave()
    loopContDepth.pop()
    loopContLabel.pop()
    fbEnd()       // end block
    ctrlLeave()
    loopBrkDepth.pop()
    loopBrkLabel.pop()
    // The loop variable's scope is the loop (see `scopeUnbind`).
    scopeUnbind()
    return 0
  }
  if s is BreakStmt {
    // `break [label]`: branch out of a loop's wrapping BLOCK, so control resumes
    // after the whole loop. Unlabelled targets the innermost (`loopBrkDepth` top);
    // `break outer` scans the parallel label stack from the top for `outer` —
    // the host's `brkLabel(node.label ?? loopLabels[last])` target selection.
    // The relative `br` operand is the frame distance `ctrlDepth - <block depth>`.
    // A `break` outside any loop / to an unknown label fails loudly, not with a
    // bad `br`.
    if loopBrkDepth.length == 0 {
      return emitFail("emitProgram: `break` outside a loop")
    }
    const brkAt = loopStackFind(loopBrkLabel, s.brkLabel)
    if brkAt < 0 {
      return emitFail("emitProgram: `break` label does not name an enclosing loop")
    }
    const blkDepth = loopBrkDepth[brkAt]
    fbBr(ctrlDepth - blkDepth) // 0x0c br to the loop's wrapping block
    return 0
  }
  if s is ContinueStmt {
    // `continue [label]`: branch to a loop's continue target — the loop header
    // for a `while` (re-check the condition), the inner continue block for a
    // `for` (fall into the increment). Unlabelled targets the innermost;
    // `continue outer` scans the label stack from the top (the labelled for's
    // INNER block shadows its header entry — both carry the label — so a
    // binding `continue` never skips the increment).
    if loopContDepth.length == 0 {
      return emitFail("emitProgram: `continue` outside a loop")
    }
    const contAt = loopStackFind(loopContLabel, s.contLabel)
    if contAt < 0 {
      return emitFail("emitProgram: `continue` label does not name an enclosing loop")
    }
    const loopDepth = loopContDepth[contAt]
    fbBr(ctrlDepth - loopDepth) // 0x0c br to the loop's continue target
    return 0
  }
  emitFail("emitProgram: unsupported statement in body")
}

// True if the statement at `stmtIx` is a BARE VALUE EXPRESSION usable as an IMPLICIT
// RETURN — a VL function whose last statement is an expression (no `return` keyword)
// yields that expression's value (the idiom every `ast.vl` constructor uses:
// `addNode(n)` / `out` as the final line). Recognized: literals, an identifier, a
// unary, a non-assignment `BinExpr`, a paren, a member / index access, an `is` guard,
// an object / array literal, and a value-returning CALL (`f(..)` whose callee is an
// Ident — NOT a `recv.push(x)` member-call, which is void). A `LetDecl`/`RetStmt`/
// `IfStmt`/`WhileStmt`/assignment/`.push` is a STATEMENT, not a tail value, so it is
// lowered normally by `emitStmt`.
function stmtIsTailValue(stmtIx: i32, fnIx: i32) {
  let s = P.nodes[stmtIx]
  // A bare lambda tail `(a) => (b) => …` is an implicit-return VALUE (a closure), so the
  // outer arrow's body — `(b) => …` — emits as the function's result. Without this the tail
  // is mis-read as a statement, the body emits nothing, and the function is just `unreachable`.
  if s is FuncDecl { return true }
  if s is NumLit { return true }
  // A trailing `null` IS an implicit-return value (the function returns null) — seeded
  // per the return type by `emitReturnValue` (`ref.null` / sentinel / boxed null), the
  // same as `return null`. Without this a `{ … null }` tail fell through to the
  // statement path and failed `unsupported statement in body`.
  if s is NullLit { return true }
  if s is StrLit { return true }
  if s is CharLit { return true }
  if s is BoolLit { return true }
  if s is Ident { return true }
  if s is Unary { return true }
  if s is Paren { return true }
  if s is Member { return true }
  if s is Index { return true }
  if s is IsExpr { return true }
  if s is ObjLit { return true }
  if s is ArrayLit { return true }
  if s is BinExpr {
    if s.binOp == "=" {
      // A trailing assignment over an IDENT target IS a tail value — assignment
      // yields its RHS (DECISIONS: assignment-as-expression), so
      // `function bump() { count = count + 1 }` returns the new count. Index/
      // Member-target assignments stay statements (value form not lowered yet).
      const tgt = P.nodes[s.binLeft]
      if tgt is Ident { return true }
      return false
    }
    return true
  }
  if s is Call {
    // A value-returning call `f(..)` is a tail value; a `recv.push(x)` member-call,
    // a `print(...)`, and a call to a VOID function (`fRetVoid`) are statements.
    const callee = P.nodes[s.callFn]
    if callee is Ident {
      if callee.identName == "print" { return false }
      // The void memory intrinsics are statements, never tail values.
      if callee.identName == "__store_i32__" { return false }
      if callee.identName == "__log__" { return false }
      // The void array intrinsics likewise: `__array_copy__` yields nothing;
      // `__trap__` diverges (no value).
      if callee.identName == "__array_copy__" { return false }
      if callee.identName == "__trap__" { return false }
      const target = fnIndexOf(callee.identName)
      if target >= 0 { return fRetVoid[target] == 0 }
      // A CLOSURE-VALUE callee (a `() => void` param / a void-function binding, invisible
      // to `fnIndexOf`): a void one (`>v` sig) yields nothing, so it is a STATEMENT tail,
      // not a value — the signal that makes `run(g: () => void) { g() }` infer void.
      if fnIx >= 0 && calleeReturnsVoid(callee.identName, fnIx) { return false }
      return true
    }
    return false
  }
  false
}

// True if the BLOCK at `blockIx` ends in a bare tail VALUE statement (an implicit
// return), as opposed to an explicit `return`/`while`/etc. — i.e. lowering it in tail
// position would need `emitStmtTail`. A nested `if`/`else` tail recurses (any arm).
function blockTailIsValue(blockIx: i32, fnIx: i32) {
  let b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    let n = stmts.length
    if n == 0 { return false }
    const last = stmts[n - 1]
    let s = P.nodes[last]
    if s is IfStmt { return ifTailIsValue(last, fnIx) }
    return stmtIsTailValue(last, fnIx)
  }
  false
}

// True if the `if`/`else` at `stmtIx` (in tail position) has any arm that ends in a
// bare value expression rather than an explicit `return` — so it must be lowered via
// `emitIfTail`. An `if` WITHOUT an `else` can fall through with no value, so it never
// qualifies (the existing void-if path handles it). Recurses through `else if` chains.
function ifTailIsValue(stmtIx: i32, fnIx: i32) {
  let s = P.nodes[stmtIx]
  if s is IfStmt {
    // An else-less `if` NEVER qualifies here (it can fall through with no value). This is
    // load-bearing: `ifTailIsValue` feeds `blockTailIsValue` → the `fRetVoid` fixpoint in
    // `buildFnMap`, where treating a void procedure's recursive tail `if n>0 { rec(n-1) }`
    // as a value would wrongly keep it non-void. The else-less NULLABLE-return tail
    // (`function f(c) { if c then 5 }` → `i32 | null`) is handled separately at emit time
    // by `elseLessNullableTail` (gated on the FINAL nullable classification).
    if s.ifElse < 0 { return false }
    if blockTailIsValue(s.ifThen, fnIx) { return true }
    const els = P.nodes[s.ifElse]
    if els is Block { return blockTailIsValue(s.ifElse, fnIx) }
    return ifTailIsValue(s.ifElse, fnIx)
  }
  false
}

// True if the statement at `stmtIx` is a body-tail `if`/`else` whose arms yield a
// value (implicit return) and so must be lowered tail-aware by `emitIfTail`.
function lastStmtIsValueIf(stmtIx: i32, fnIx: i32) {
  let s = P.nodes[stmtIx]
  if s is IfStmt { return ifTailIsValue(stmtIx, fnIx) }
  false
}

// True if the body-tail statement at `stmtIx` is an ELSE-LESS `if` whose then-arm yields
// a value AND function `fnIx` returns a NULLABLE type — so the false fall-through is the
// `null` of that nullable (lowered by the function-end `emitNullForRet`), exactly the
// #484 fall-through but written `if c then v` with no else. Distinct from
// `lastStmtIsValueIf`: this is consulted only at EMIT time, where `fRetVoid` is final, so
// it never perturbs the `fRetVoid` fixpoint (a void procedure's `if n>0 { rec(n-1) }`
// stays void — `fnRetNullBearing` is false for it).
function elseLessNullableTail(stmtIx: i32, fnIx: i32) {
  let s = P.nodes[stmtIx]
  if s is IfStmt {
    if s.ifElse >= 0 { return false }
    if !blockTailIsValue(s.ifThen, fnIx) { return false }
    return fnRetNullBearing(fnIx)
  }
  false
}

// Lower a function's TOP-LEVEL body block at `blockIx`: every statement but the last
// is lowered normally; if the LAST statement is a bare value expression (no `return`
// keyword), it is lowered as the function's return value (`emitExpr` + `return`) —
// VL's implicit-return idiom. A last statement that is itself a real statement (a
// `return`, `if`, `while`, assignment, `.push`, or `let`) is lowered unchanged. An
// empty body is left to the existing validation. Returns 0, or -1 (via `emitFail`).
function emitFuncBody(body: i32[], blockIx: i32, fnIx: i32) {
  let b = P.nodes[blockIx]
  if b is Block {
    // Enter the function's top-level lexical scope (mirrors `collectLocals` on the body
    // block). The emit-time scope stack drives same-named-local resolution.
    scopePush()
    const stmts = b.blkStmts
    let n = stmts.length
    // A guard `if` (no else, then-branch always returns) narrows the REST of the
    // body to the guard's complement (the host's post-early-return flow narrowing).
    const savedGuardTop = narrowTop
    let i = 0
    while i < n {
      const isLast = i == n - 1
      if isLast && stmtIsTailValue(stmts[i], fnIx) {
        // Implicit return: seed the return context + push the value (so a trailing
        // `null` / nullable value boxes or sentinels exactly like `return e`), then
        // `return` (0x0f).
        if emitReturnValue(body, stmts[i], fnIx) < 0 {
          scopePop()
          return -1
        }
        fbReturn() // 0x0f return
      } else if isLast && lastStmtIsValueIf(stmts[i], fnIx) {
        // The body ends in an `if`/`else` whose arms each yield a value (implicit
        // return) rather than `return`ing — lower it tail-aware so each arm's trailing
        // value expression becomes the function's return.
        if emitIfTail(body, stmts[i], fnIx) < 0 {
          scopePop()
          return -1
        }
      } else if isLast && elseLessNullableTail(stmts[i], fnIx) {
        // The body ends in an else-less `if` whose then-arm yields a VALUE and whose
        // return type is NULLABLE (`function f(c) { if c then 5 }` → `i32 | null`): lower
        // it tail-aware (the then-arm returns its value); the false fall-through is lowered
        // as `null` by the function-end padding (`emitNullForRet`). Gated on the FINAL
        // `fRetVoid`/nullable classification — unlike `lastStmtIsValueIf`/`ifTailIsValue`,
        // which feed the `fRetVoid` fixpoint in `buildFnMap` and so must NOT treat an
        // else-less recursive tail as a value (a void procedure's `if n>0 { rec(n-1) }`).
        if emitIfTail(body, stmts[i], fnIx) < 0 {
          scopePop()
          return -1
        }
      } else {
        if emitStmt(body, stmts[i], fnIx) < 0 {
          scopePop()
          return -1
        }
      }
      pushPostGuardNarrow(stmts[i], fnIx)
      i = i + 1
    }
    restoreNarrow(savedGuardTop)
    scopePop()
    return 0
  }
  emitFail("emitProgram: function has no block body")
}

// True if the function's TOP-LEVEL body block at `blockIx` ends in an instruction
// that the wasm validator treats as making the function's fallthrough UNREACHABLE —
// i.e. its last statement is an explicit `return` (`RetStmt`) or a bare tail value
// (lowered by `emitFuncBody` as `emitExpr` + `return`). In those cases the function's
// trailing `end` is reached only via the polymorphic post-`return` stack, so no
// padding is needed. Otherwise (the body ends in an `if`/`while`/assignment/`.push`
// whose own `return`s exit from INSIDE a structured block) control structurally falls
// through to `end` with an empty stack — which fails the result-type check unless an
// explicit `unreachable` precedes the `end`. The typechecker has already proven such
// a fallthrough is dynamically dead (every path returns), so the `unreachable` is
// sound padding, never executed.
function bodyEndsInReturn(blockIx: i32, fnIx: i32) {
  let b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    let n = stmts.length
    if n == 0 { return false }
    const last = stmts[n - 1]
    let s = P.nodes[last]
    if s is RetStmt { return true }
    return stmtIsTailValue(last, fnIx)
  }
  false
}

// Lower every statement of the block at `blockIx` onto `body`, in order. Returns 0,
// or -1 (via `emitFail`) on a non-block node or an unsupported statement within.
function emitStmts(body: i32[], blockIx: i32, fnIx: i32) {
  let b = P.nodes[blockIx]
  if b is Block {
    // A nested block (if-then / if-else / while-body) is its own lexical scope (mirrors
    // `collectLocals` recursing into it): push a frame so its `let`s shadow correctly and
    // are dropped on exit.
    scopePush()
    const stmts = b.blkStmts
    // Post-guard complement narrowing (see `emitFuncBody`/`pushPostGuardNarrow`).
    const savedGuardTop = narrowTop
    let i = 0
    while i < stmts.length {
      if emitStmt(body, stmts[i], fnIx) < 0 {
        scopePop()
        return -1
      }
      pushPostGuardNarrow(stmts[i], fnIx)
      i = i + 1
    }
    restoreNarrow(savedGuardTop)
    scopePop()
    return 0
  }
  emitFail("emitProgram: function has no block body")
}

// Lower a block at `blockIx` that sits in TAIL position (its value is the enclosing
// function's return value). Every statement but the last is lowered normally; the
// LAST is lowered tail-aware via `emitStmtTail`, so a bare value expression there
// becomes an implicit return and a nested `if`/`else` recurses with each arm in tail
// position. This is the structured-block analogue of `emitFuncBody`'s top-level
// implicit-return handling, letting a function body like `if c { a } else { b }`
// (each arm an implicit-return expression) lower correctly. Returns 0, or -1.
function emitStmtsTail(body: i32[], blockIx: i32, fnIx: i32) {
  let b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    let n = stmts.length
    if n == 0 { return emitFail("emitProgram: empty block in tail position") }
    // A tail-position nested block is its own lexical scope too (mirrors `collectLocals`).
    scopePush()
    // Post-guard complement narrowing (see `emitFuncBody`/`pushPostGuardNarrow`) —
    // pushed in the loop, active for the TAIL statement, restored on exit.
    const savedGuardTop = narrowTop
    let i = 0
    while i < n - 1 {
      if emitStmt(body, stmts[i], fnIx) < 0 {
        scopePop()
        return -1
      }
      pushPostGuardNarrow(stmts[i], fnIx)
      i = i + 1
    }
    let rc = emitStmtTail(body, stmts[n - 1], fnIx)
    restoreNarrow(savedGuardTop)
    scopePop()
    return rc
  }
  emitFail("emitProgram: function has no block body")
}

// Lower the single statement at `stmtIx` in TAIL position. A bare tail value becomes
// `emitExpr` + `return`; a nested `if`/`else` recurses tail-aware into its arms; any
// other statement (an explicit `return`, a `while`, etc.) is lowered unchanged by
// `emitStmt` (it already exits or falls through on its own). Returns 0, or -1.
function emitStmtTail(body: i32[], stmtIx: i32, fnIx: i32) {
  let s = P.nodes[stmtIx]
  if s is IfStmt { return emitIfTail(body, stmtIx, fnIx) }
  if stmtIsTailValue(stmtIx, fnIx) {
    // An if-tail arm's implicit return — seed the return context (so a `null` arm
    // boxes / sentinels per the function's return type) exactly like `emitFuncBody`.
    if emitReturnValue(body, stmtIx, fnIx) < 0 { return -1 }
    fbReturn() // 0x0f return
    return 0
  }
  emitStmt(body, stmtIx, fnIx)
}

// Lower an `if`/`else` at `stmtIx` whose VALUE is the function's return value (tail
// position): each arm is lowered with its last statement tail-aware (`emitStmtsTail`),
// so an arm ending in a bare value expression returns it. Mirrors `emitStmt`'s void-if
// shape (same `if 0x04`/`else 0x05`/`end 0x0b`, same union narrowing) but routes the
// arm bodies through the tail path. Returns 0, or -1.
function emitIfTail(body: i32[], stmtIx: i32, fnIx: i32) {
  let s = P.nodes[stmtIx]
  if s is IfStmt {
    if emitExpr(body, s.ifCond, fnIx) < 0 { return -1 }
    fbIf(64) // 0x04 if, 0x40 void blocktype
    const savedTop = narrowTop
    const narrowed = setNarrowFromCond(s.ifCond, fnIx)
    if emitStmtsTail(body, s.ifThen, fnIx) < 0 { return -1 }
    if narrowed { restoreNarrow(savedTop) }
    if s.ifElse >= 0 {
      fbElse() // 0x05 else
      // A VALUE union narrows to the COMPLEMENT set in the else-arm (see emitStmt).
      const savedElseTop = narrowTop
      const narrowedElse = setNarrowFromCondElse(s.ifCond, fnIx)
      const els = P.nodes[s.ifElse]
      if els is Block {
        if emitStmtsTail(body, s.ifElse, fnIx) < 0 { return -1 }
      } else {
        // `else if`: a lone nested IfStmt, still in tail position.
        if emitStmtTail(body, s.ifElse, fnIx) < 0 { return -1 }
      }
      if narrowedElse { restoreNarrow(savedElseTop) }
    }
    fbEnd() // 0x0b end
    return 0
  }
  emitFail("emitProgram: emitIfTail: not an if statement")
}

// Verify every parameter of the FuncDecl at `fnIx` is typed `i32` — the only type
// this slice emits. Returns 0 on success or -1 (via `emitFail`) otherwise.
function checkParams(fnIx: i32) {
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    const params = fn.fnParams
    let pi = 0
    while pi < params.length {
      const p = P.nodes[params[pi]]
      if p is Param {
        if p.parType < 0 {
          // An UN-ANNOTATED parameter — a contextually-inferred callback literal
          // (`xs.map(function(n) n * 2)`, Slice 5's checker half). The checker has
          // already pinned its type from the receiver; this emitter's default kind
          // for a missing annotation is i32 (`vtKindOfType(-1)` → 0), which is the
          // only inferred-param receiver element kind in scope. Accepted as-is.
          pi = pi + 1
          continue
        }
        const ty = P.nodes[p.parType]
        if ty is TypeRef {
          // i32, `boolean` (which rides in an i32, 0/1 — encoded as the SAME 0x7f
          // valtype), the declared struct type, a NULLABLE struct (`S | null`), an
          // array (`i32[]`), or `string` (the SAME `array i32` of code points) are
          // allowed; anything else fails.
          // (`collectA` already validated every array annotation is i32[].)
          if tyIsFuncType(p.parType) {
            // a function-typed (closure fat-pointer) param — kind 14
          } else if nulCloFlag(p.parType) == 1 {
            // a NULLABLE function-value param (`((i32) => i32) | null`, kind 19) — its `=>` is
            // NESTED so `tyIsFuncType` (top-level-arrow only) no longer matches it; accept it
            // here explicitly, as `vtKindOfType` already maps it to kind 19.
          } else if retNulRefFlag(p.parType) == 1 {
            // accepted — a `(ref null $S)` param
          } else if retNulListFlag(p.parType) == 1 {
            // accepted — a `(ref null $lTypeIdx)` param (`i32[] | null`, kind 15)
          } else if tyIsNulBool(p.parType) {
            // accepted — a `boolean | null` NICHE param (the i32 sentinel 0/1/2)
          } else if retNulStringFlag(p.parType) == 1 {
            // accepted — a `string | null` param (`(ref null $aTypeIdx)`, kind 16)
          } else if retMapFlag(p.parType) == 1 {
            // accepted — a string-keyed map param (kind 6, `(ref $mapStruct)`). Mono i32/boolean
            // rides shape -1; a `string`-valued map carries its mv slot (`mapAnnShape`) across the
            // boundary. The body's map ops resolve the param via `exprMap`/`paramMap`/
            // `mapShapeOfExpr` (which now reads the param annotation's shape). A struct/f64/i64-
            // valued map is NOT yet supported (`retMapFlag` returns 0) → rejected below.
          } else if nameIsLitUnionType(ty.tyName) {
            // accepted — a literal-union param is an i32-backed interned atom (kind 0).
          } else if ty.tyName != "i32" {
            if ty.tyName != "i64" {
              // i64 rides the 0x7e valtype (Slice 1)
              if ty.tyName != "f64" {
                // f64 rides the 0x7c valtype (Slice 3)
                if ty.tyName != "f32" {
                  // f32 rides the 0x7d valtype (Slice 5)
                  if ty.tyName != "boolean" {
                    if !isSName(ty.tyName) {
                      if !isUName(ty.tyName) {
                        if variantIndexOf(ty.tyName) < 0 {
                          if !nameIsArray(ty.tyName) {
                            if !nameIsString(ty.tyName) {
                              return emitFail(
                                "emitProgram: only i32, i64, f64, f32, boolean, struct, union, array, or string parameters are supported",
                              )
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        } else {
          return emitFail("emitProgram: parameter type is not a type name")
        }
      } else {
        return emitFail("emitProgram: malformed parameter")
      }
      pi = pi + 1
    }
    return 0
  }
  emitFail("emitProgram: not a function declaration")
}

// The per-function mv frame base for mv slot `slot` (valid when `fnUsesMap`).
function fnMvMapRefLocal(slot: i32) { fnMvBase + slot * 3 }
function fnMvValsBkLocal(slot: i32) { fnMvBase + slot * 3 + 1 }
function fnMvValStashLocal(slot: i32) { fnMvBase + slot * 3 + 2 }
// The `m.values()` per-mv-slot OUTPUT backing local for mv slot `slot`.
function fnMvValsOutLocal(slot: i32) { mvValsOutBase + slot }

// The result list REP-kind of a `m.values()` call — `2` i32-list, `7` string-list, `12`
// f64-list, `20` i64-list, `5` ref-list (struct / nested-list / nested-map values) — or -1
// if `exprIx` is not a `.values()` over a map. The result element type IS the map's value
// type, so each `expr*Array` classifier compares against its own rep.
function mapValuesResultKind(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return -1 }
  const e = P.nodes[exprIx]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "values" {
        if exprMap(callee.memObj, fnIx) {
          const sh = mapShapeOfExpr(callee.memObj, fnIx)
          if sh == -1 {
            return 2 // mono i32 map → i32 list
          }
          if sh == -2 {
            return 7 // a Set's values() ARE its string keys
          }
          if sh >= 0 {
            const vk = mvValKind[sh]
            if vk == 3 {
              return 7 // string-valued → string list
            }
            if vk == 11 {
              return 12 // f64-valued → f64 list
            }
            if vk == 10 {
              return 20 // i64-valued → i64 list
            }
            return 5 // struct / nested-list / nested-map → ref list
          }
        }
      }
    }
  }
  -1
}

// ── locals-vector emission (derived, never separately counted) ────────────────
// The locals vector is a sequence of (count, valtype) runs. This emitter uses a
// count of 1 per local — one run per declared local and per scratch slot — so the
// run total equals the local count. The run helpers below stream straight to
// `curBuf` (bind it with `wTarget` first); each emits the `1` count then a valtype.

// Build the size-prefixed code-section body for the FuncDecl at `fnIx`: the locals
// vector (declared locals, all i32 — see `buildLocals`), the body's statement
// instructions, then `end`. The framed bytes are appended onto `out`. Returns 0, or
// -1 (via `emitFail`) on any unsupported shape.
//
// The locals vector groups consecutive locals of the same type into (count, valtype)
// runs. Every declared local is i32 here, so it is a single run `(L, 0x7f)` for
// `L = localNames.length` declared locals (or an empty vector `0` when there are
// none). Params are NOT counted here — they are encoded in the functype, not the
// code body's locals vector.
// The fnStmts POSITION of the FuncDecl at arena index `fnIx`, or -1.
function fnStmtsPosOf(fnIx: i32) {
  let i = 0
  while i < fnStmts.length {
    if fnStmts[i] == fnIx { return i }
    i = i + 1
  }
  // A monomorphized slot was REPLACED in place (a count-0 instance overwrote `fnStmts[fe]`), so the
  // ORIGINAL node — a lambda literal a binding still points at — is no longer found by the scan
  // above. `monoOrigNode[fe]` still records it, so recover the slot from there. (Pure fallback: a
  // non-replaced slot is found above; a non-function node matches neither and stays -1.)
  let j = 0
  while j < monoOrigNode.length {
    if monoOrigNode[j] == fnIx { return j }
    j = j + 1
  }
  -1
}

function emitFuncCode(out: i32[], fnIx: i32) {
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    // Collect + validate declared locals BEFORE lowering, so identifier resolution
    // and the locals vector both see the full per-function set.
    if buildLocals(fnIx) < 0 { return -1 }

    // If this function pushes, reserve three scratch locals after the declared ones.
    // `pushScratchBase` is their first wasm index (= params + declared locals); the
    // inline-push sequence reads `pushScratchBase`+0/+1/+2. Set BEFORE `emitStmts` so a
    // `.push` can resolve its scratch slots.
    fnUsesPush = fnHasPush(fnIx)
    fnUsesRefPush = fnHasRefPush(fnIx)
    fnUsesStrPush = fnHasStrPush(fnIx)
    fnUsesF64Push = fnHasF64Push(fnIx)
    fnUsesI64Push = fnHasI64Push(fnIx)
    fnUsesF32Push = fnHasF32Push(fnIx)
    fnUsesStrOp = fnHasStrOp(fnIx)
    fnUsesArrNew = fnHasArrNew(fnIx)
    fnUsesCoalesceCall = fnHasCoalesceCall(fnIx)
    fnUsesMap = fnHasMap(fnIx)
    // `fnHasMap` only scans LOCALS/params; also reserve the frame when a map op runs
    // on a GLOBAL struct-field map-array element (e.g. `T.scopes[top][k] = v`).
    if !fnUsesMap { fnUsesMap = fnHasGlobalMapOp(fnIx) }
    // A function-value call (`call_ref`) anywhere in the body reserves the closure
    // scratch slot. Only detected when a function value exists module-wide (lambdas).
    fnUsesCallRef = false
    if fnValUsed { fnUsesCallRef = blockHasCallRef(fn.fnBody, fnIx) }
    // Collect the DISTINCT ref-list element-type slots this function pushes onto (each
    // gets its own typed 4-slot scratch frame). Empty unless `fnUsesRefPush`.
    fnRefPushSlots = []
    refPushBaseBySlot = []
    collectRefPushSlots(fn.fnBody, fnIx)
    // A Member-receiver ref-list `.pop` (`T.scopes.pop()`) needs the SAME typed scratch
    // frame as a ref `.push` onto that slot — record its slot too, so a pop-only function
    // reserves the frame whose `recvRef` holds the field's wrapper ref.
    collectMemberPopRefSlots(fn.fnBody, fnIx)
    // Collect the `.map`/`.filter` HOF sites this body lowers (each reserves the
    // shared 4-slot frame + one typed src/dst slot per distinct receiver/result type).
    fnUsesMapFilter = false
    fnUsesMapKeys = false
    fnUsesMapVals = false
    fnUsesMapVals = false
    mfSrcKinds = []
    mfSrcSlots = []
    mfSrcBases = []
    mfDstKinds = []
    mfDstSlots = []
    mfDstBases = []
    mfScan(fn.fnBody, fnIx)
    // List `==`/`!=`/`+` frames (collections-design §VL.4/§VL.6). May also flip
    // `fnUsesStrOp` (a string-list compare rides the string-op frame), so it
    // runs AFTER the `fnHasStrOp` assignment above.
    fnUsesListEqI = false
    fnUsesListEqS = false
    fnListEqRSlots = []
    fnUsesCloEq = false
    leqScanBlock(fn.fnBody, fnIx)
    const nLocals = localNames.length
    // Lay out every scratch frame after the params + declared locals via the
    // FuncBuilder cursor (Phase H), which sets `pushScratchBase` /
    // `refPushScratchBase` / `refPushBaseBySlot` / `strPushScratchBase` /
    // `strScratchBase` / `mapScratchBase` from ONE running offset in frame order.
    // Scratch frames land after the params AND the hidden env param (local 0) when a
    // function value exists module-wide, so the cursor starts past `envSlotShift`.
    fbBeginFunc(fn.fnParams.length + envSlotShift(fnIx), nLocals)

    const bodyExpr: i32[] = []
    // Bind the writer at `bodyExpr` so the `fb*` opcode methods (which append to
    // `curBuf`) write the function-body instructions; the recursive lowering threads
    // the SAME `bodyExpr` as its `body` arg, so `curBuf == body` throughout and the
    // not-yet-converted raw `body.push(...)` sites interleave identically. Restore
    // the previous target afterwards.
    const exprPrev = wTarget(bodyExpr)
    // Reset the emit-time scope stack + slot cursor; `emitFuncBody` re-walks the body
    // in collect's pre-order, so the n-th `LetDecl` it emits re-derives declared-local
    // slot `n` and binds it for in-scope resolution.
    scopeNames = []
    scopeSlots = []
    scopeFrames = []
    emitLetCursor = 0
    // Reset the loop control-frame tracking (`break`/`continue` branch-depth state)
    // so a previous function's open frames never leak into this one.
    ctrlDepth = 0
    loopContDepth = []
    loopBrkDepth = []
    loopContLabel = []
    loopBrkLabel = []
    if emitFuncBody(bodyExpr, fn.fnBody, fnIx) < 0 { return -1 }
    wTarget(exprPrev)

    const body: i32[] = []
    // Locals vector: one (count=1, valtype) run per DECLARED local, then the scratch
    // frames in `fbBeginFunc`'s layout order. Derived from the local set + scratch
    // flags by the FuncBuilder (Phase H) — the run count and every valtype come from
    // ONE place, so they cannot desync from the frame layout above.
    if fbEmitLocalsVec(body, nLocals) < 0 { return -1 }
    appendAll(body, bodyExpr)
    // Bind the writer at `body` (the framed code entry) for the trailing padding/end
    // opcodes emitted via the `fb*` methods.
    const endPrev = wTarget(body)
    // If the body does NOT end in an explicit `return` / tail value, control
    // structurally falls through to the function `end` with an empty stack (e.g. a
    // body ending in `if c { return a } else { return b }`, whose `return`s exit from
    // inside the structured `if`). The validator requires the function's result type
    // at fallthrough, so something must occupy it. Two cases:
    //   • NULLABLE return — the fall-through is a LIVE path that yields `null` (the
    //     checker permits it precisely because `null` is in the return type), so emit
    //     that null value (`emitNullForRet`) as the function's result.
    //   • non-nullable return — the typechecker has proven the fallthrough is DEAD
    //     (every path returns), so `unreachable` (0x00) is sound padding, never run.
    const fnPos = fnStmtsPosOf(fnIx)
    let isVoidFn = false
    if fnPos >= 0 {
      if fRetVoid[fnPos] == 1 { isVoidFn = true }
    }
    if !isVoidFn && !bodyEndsInReturn(fn.fnBody, fnIx) {
      if fnRetNullBearing(fnIx) {
        if emitNullForRet(body, fnIx) < 0 { return -1 }
      } else {
        fbUnreachable() // 0x00 unreachable (dead padding for the result type)
      }
    }
    fbEnd() // 0x0b end
    wTarget(endPrev)
    // Stream the size-prefixed code entry onto `out` (the code-section payload). Bind
    // the writer at `out` explicitly: the caller restores `curBuf` off the payload
    // before this loop, so `curBuf` is NOT `out` on entry here.
    const outPrev = wTarget(out)
    wULEB(body.length)
    wBytes(body)
    wTarget(outPrev)
    return 0
  }
  emitFail("emitProgram: not a function declaration")
}

// The struct table index a type NAME names: a declared struct name directly, or an
// INLINE object-shape name (`{x:i32,y:i32}`) matched by field-name SET against the
// interned shapes (the anonymous literals interned the same sets). -1 if neither.
function structIndexOfTypeName(name: string) {
  let si = structIndexByName(name)
  if si >= 0 { return si }
  // Only a SINGLE shape spanning the WHOLE name is a bare struct — a composite (`{…}|null`,
  // `{…}|{…}`, `{…}[]`) is not, so its first `{`'s matching `}` must be the LAST char. Without this
  // guard a nullable-struct name (`{x:i32}|null`) mis-matches its LEADING shape as the bare struct,
  // silently masking the `| null` (e.g. `annRetKind` would key a nullable result `>s` instead of
  // `>n`, breaking a nullable-returning closure value call).
  let spanOk = false
  if name.length >= 2 && name[0] == '{' && name[1] != '[' {
    let d0 = 0
    let closeAt = -1
    let q = 0
    while q < name.length {
      const cc = name[q]
      if cc == '{' {
        d0 = d0 + 1
      } else if cc == '}' {
        d0 = d0 - 1
        if d0 == 0 && closeAt < 0 { closeAt = q }
      }
      q = q + 1
    }
    if closeAt == name.length - 1 { spanOk = true }
  }
  if spanOk {
    // Collect the top-level FIELD NAMES: a name run starts after `{` or a
    // depth-0 `,` and ends at the depth-0 `:` (nested `{…}`/`[…]` skipped).
    const fnames: string[] = []
    let cur = ""
    let depth = 0
    let collecting = true
    let i = 1
    while i < name.length - 1 {
      let c = name[i]
      if c == '{' || c == '[' {
        depth = depth + 1
      } else if c == '}' || c == ']' {
        depth = depth - 1
      } else if depth == 0 && c == ':' {
        if collecting {
          fnames.push(cur)
          cur = ""
          collecting = false
        }
      } else if depth == 0 && c == ',' {
        collecting = true
      } else if depth == 0 && collecting && c != ' ' {
        // Skip the space after `, ` (`tyToStr` renders `{x: i32, y: i32}` with a separator
        // space) — a field name is a bare identifier, so an embedded space is never part of it.
        // Without this the 2nd+ field name collects as `" y"` and the field-set match fails.
        cur = cur + fromCodePoint(c)
      }
      i = i + 1
    }
    let si2 = 0
    while si2 < sNames.length {
      if sFieldCount[si2] == fnames.length {
        let ok = true
        let k = 0
        while k < fnames.length {
          if sFieldIndex(si2, fnames[k]) < 0 { ok = false }
          k = k + 1
        }
        if ok { return si2 }
      }
      si2 = si2 + 1
    }
  }
  -1
}

// The union-VARIANT table index whose field-set matches a `{meow: i32}` SHAPE name (a
// collapsed `.map` callback return the checker rendered structurally) — the variant
// analogue of `structIndexOfTypeName`. -1 if no variant matches. A NAME that is already a
// variant alias resolves directly. Field-name parsing mirrors `structIndexOfTypeName`.
function variantIndexOfTypeName(name: string) {
  const direct = variantIndexOf(name)
  if direct >= 0 { return direct }
  if name.length >= 2 && name[0] == '{' && name[1] != '[' {
    const fnames: string[] = []
    let cur = ""
    let depth = 0
    let collecting = true
    let i = 1
    while i < name.length - 1 {
      let c = name[i]
      if c == '{' || c == '[' {
        depth = depth + 1
      } else if c == '}' || c == ']' {
        depth = depth - 1
      } else if depth == 0 && c == ':' {
        if collecting {
          fnames.push(cur)
          cur = ""
          collecting = false
        }
      } else if depth == 0 && c == ',' {
        collecting = true
      } else if depth == 0 && collecting && c != ' ' {
        cur = cur + fromCodePoint(c)
      }
      i = i + 1
    }
    let vi = 0
    while vi < uVariants.length {
      if uFieldCount[vi] == fnames.length {
        let ok = true
        let k = 0
        while k < fnames.length {
          if variantFieldIndex(vi, fnames[k]) < 0 { ok = false }
          k = k + 1
        }
        if ok { return vi }
      }
      vi = vi + 1
    }
  }
  -1
}

// The union-VARIANT index a lifted callback `fe` returns when it COLLAPSES to a single
// variant (`(a) => if a is Cat { a } else { catShape }`), read from the checker's recorded
// node-keyed return shape, or -1. Lets `.map`/`.filter` classify the result as the variant
// ref list (the checker types it `Cat[]`, but the emitter's syntactic union inference would
// otherwise widen the narrowed receiver to the box).
function cbRetVariantIdx(fe: i32) {
  if fe < 0 || fe >= fnStmts.length { return -1 }
  return variantIndexOfTypeName(inferRetNameByNode(fnStmts[fe]))
}

// True if the expression is a NAME (param / local / module global) annotated
// `boolean|null` — the niche scalar nullable.
function exprNulBool(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[unwrapParen(exprIx)]
  // A CALL of a function annotated `: boolean | null` — its result is the niche i32.
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const t = fnIndexOf(callee.identName)
      if t >= 0 {
        const cfn = P.nodes[fnStmts[t]]
        if cfn is FuncDecl {
          if tyIsNulBool(cfn.fnRet) { return true }
          // ...or an UN-ANNOTATED function whose return INFERS to `boolean | null`.
          if cfn.fnRet < 0 {
            if inferNicheNullByName(callee.identName) == "boolean|null" {
              return true
            }
          }
          return false
        }
      }
    }
    return false
  }
  if e is Ident {
    if fnIx >= 0 {
      const fn = P.nodes[fnIx]
      if fn is FuncDecl {
        const params = fn.fnParams
        let i = 0
        while i < params.length {
          const p = P.nodes[params[i]]
          if p is Param {
            if p.parName == e.identName { return tyIsNulBool(p.parType) }
          }
          i = i + 1
        }
        let li = parentLetOf(fn.fnBody, e.identName)
        if li >= 0 { return letNulBool(li, fnIx) }
      }
    }
    const gi = globalLetOf(e.identName)
    if gi >= 0 { return letNulBool(gi, -1) }
    return false
  }
  // A `boolean | null` struct FIELD read (`a.v`, code 21) is the niche i32 sentinel.
  if e is Member { return memberFieldCode(exprIx, fnIx) == 21 }
  // A chained `a ?? b` over `boolean | null` is itself `boolean | null` when the default
  // `b` is also nullable — the left-associative `(f() ?? g()) ?? d` shape (see the
  // `exprNullableString` companion). Keeps `??` print-routing consistent with the rep.
  if e is BinExpr {
    if e.binOp == "??" {
      if exprNulBool(e.binLeft, fnIx) { return exprNulBool(e.binRight, fnIx) }
    }
  }
  false
}

// A `let`/`const` binding is `boolean | null` if it is so ANNOTATED, or (un-annotated)
// its initializer is a `boolean | null` value — e.g. `const r = f()` where `f` returns
// the niche. Mirrors `letUnionNameOf`'s annotation-or-init resolution for value unions.
function letNulBool(letIx: i32, fnIx: i32) {
  if letIx < 0 { return false }
  if letIsNulBoolAnn(letIx) { return true }
  // An un-annotated `const x = if c then true else null` infers `boolean | null` (a
  // niche the emitter can't statically derive from the if-expr arms). The CHECKER
  // typed it and exported the binding by node index; consult that before the init probe.
  if isInferLetNulBool(letIx) { return true }
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType < 0 { return exprNulBool(d.letInit, fnIx) }
  }
  false
}

// True if `name` resolves (param / local / module global) to a BOOLEAN binding:
// either a `: boolean`/`: bool` annotation, or an un-annotated `const`/`let` whose
// initializer is itself boolean. A boolean local registers as kind 0 (== i32), so
// bool-ness must be recovered from the binding here, not the local registry.
function boundBoolByName(name: string, fnIx: i32) {
  if fnIx >= 0 {
    const fn = P.nodes[fnIx]
    if fn is FuncDecl {
      const params = fn.fnParams
      let i = 0
      while i < params.length {
        const p = P.nodes[params[i]]
        if p is Param {
          if p.parName == name { return tyIsBool(p.parType) }
        }
        i = i + 1
      }
      let li = parentLetOf(fn.fnBody, name)
      if li >= 0 {
        let d = P.nodes[li]
        if d is LetDecl {
          if d.letType >= 0 { return tyIsBool(d.letType) }
          return exprIsBool(d.letInit, fnIx)
        }
      }
    }
  }
  let gi = globalLetOf(name)
  if gi >= 0 {
    const g = P.nodes[gi]
    if g is LetDecl {
      if g.letType >= 0 { return tyIsBool(g.letType) }
      return exprIsBool(g.letInit, -1)
    }
  }
  false
}

function retNulRefFlag(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      let base = nullablePartOf(ty.tyName)
      // `string` is the raw i32 array, NOT a struct — `string | null` is the kind-16
      // nullable-string ref (`retNulStringFlag`), never a nullable struct. Exclude it
      // here so it isn't mis-claimed as kind 9 (which would read the box as a struct).
      if base == "string" { return 0 }
      if base != "" {
        if structIndexOfTypeName(base) >= 0 { return 1 }
      }
    }
  }
  0
}

// The base struct table index of a `S | null` annotation at `tyIx`, or -1.
function retNulRefIndex(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      let base = nullablePartOf(ty.tyName)
      if base != "" { return structIndexOfTypeName(base) }
    }
  }
  -1
}

// `1` if the type-annotation node at `tyIx` names the struct, else `0` (i32 / none).
// Used for functype param/result valtypes and the `fRetRef` table. Returning the
// flag (not pushing bytes) keeps each call free of a `0→1` local reassignment, which
// pins a `let x = 0` to the literal `0` type and fails to typecheck.
function retTRFlag(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      if isSName(ty.tyName) { return 1 }
    }
  }
  0
}

// The struct table index named by the type-annotation node at `tyIx`, or -1 if it
// names no declared struct.
function retStructIndex(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      let si = structIndexByName(ty.tyName)
      if si >= 0 { return si }
      // A union-variant name carries its VARIANT index here (consumed by `pushVT`'s
      // `kind == 8` variant-struct case); not a standalone struct, so it is -1 above.
      let vi = variantIndexOf(ty.tyName)
      if vi >= 0 { return vi }
      // A `S | null` annotation resolves to its BASE struct's index — the single
      // chokepoint the param/local/return struct lookups read, so a nullable-struct
      // binding's member layout resolves without separate plumbing.
      let base = nullablePartOf(ty.tyName)
      if base != "" { return structIndexOfTypeName(base) }
      return -1
    }
  }
  -1
}

// The `pendingListKind` a type-annotation node at `tyIx` names (1 = struct/MAP ref list,
// 2 = union box ref list, 3 = string list), or 0 when it is not a list annotation. Shared
// by the let / return / call-arg / global seeding so each position threads the SAME
// annotation-derived list context into `emitArr` (so a non-empty `B[]` literal in a return
// or argument position builds B's list, not the first-element field-shape guess). A
// `LetDecl`-specific wrapper (`letAnnRefListKind`) forwards its `letType` here.
function tyAnnRefListKind(tyIx: i32) {
  if tyIx >= 0 {
    const lt = P.nodes[tyIx]
    if lt is TypeRef {
      // A NULLABLE ref-array annotation (`S[] | null`, kind 18) threads the same kind as its non-null ref
      // array, so the value literal builds the list (a value-union inner -> kind 2 boxes its bare scalars).
      let rln = lt.tyName
      const rnp = nullablePartOf(rln)
      if rnp != "" && nameIsRefArray(rnp) { rln = rnp }
      if nameIsRefArray(rln) {
        if refArrElemKind(rln) == 2 { return 2 }
        // A closure-element ref list (`((i32) => i32)[]`, kind 5) threads kind 5 so
        // `emitArr` builds the closure backing (not a struct-shape guess).
        if refArrElemKind(rln) == 5 { return 5 }
        return 1
      }
      if nameIsStringArray(lt.tyName) { return 3 }
      // An `f64[]` annotation: an empty `[]` builds the f64-list wrapper (kind 4).
      if nameIsF64Array(lt.tyName) { return 4 }
      // An `i64[]` annotation: an empty `[]` builds the i64-list wrapper (kind 6).
      if nameIsI64Array(lt.tyName) { return 6 }
      // An `f32[]` annotation (kind 7): threads even for a NON-empty literal, since a bare
      // `[1.5]` does not self-identify as f32 (it defaults to f64).
      if nameIsF32Array(lt.tyName) { return 7 }
    }
  }
  0
}

// The ref-list TABLE SLOT a type-annotation node at `tyIx` names (`Tok[]` → the `Tok`
// slot), or 0 when it is not a ref-array annotation. Mirror of `tyAnnRefListKind` for the
// slot; threads `pendingListSlot` so a ref-list literal builds the annotation's distinct
// element type.
function tyAnnRefListSlot(tyIx: i32) {
  if tyIx >= 0 {
    const lt = P.nodes[tyIx]
    if lt is TypeRef {
      let rln = lt.tyName
      const rnp = nullablePartOf(rln)
      if rnp != "" && nameIsRefArray(rnp) { rln = rnp }
      if nameIsRefArray(rln) {
        let s = rlSlotByName(refArrElemName(rln))
        if s >= 0 { return s }
      }
    }
  }
  0
}

// `1` if the type-annotation node at `tyIx` is a REF array (`S[]`/`N[]`), else `0`.
// Feeds the `kind == 5` (ref list) branch of `pushVT`.
function retRefArrFlag(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      if nameIsRefArray(ty.tyName) { return 1 }
    }
  }
  0
}

// The folded LIST-rep code of a function RETURN annotation `tyIx`: `2` i32-list, `5`
// ref-list, `7` string-list, `12` f64-list, or `0` (not a list). The four `nameIs*Array`
// predicates are mutually exclusive by name, so the priority order is immaterial. Drives
// the single `fRetListKind` table (was `retArrFlag`/`retRefArrFlag`/`retStrArrFlag`/
// `retF64ArrFlag` into four parallel boolean tables).
function retListKindFlag(tyIx: i32) {
  if retArrFlag(tyIx) == 1 { return 2 }
  if retRefArrFlag(tyIx) == 1 { return 5 }
  if retStrArrFlag(tyIx) == 1 { return 7 }
  if retF64ArrFlag(tyIx) == 1 { return 12 }
  0
}

// The ref-list element type-NAME of a function RETURN type node `tyIx` (an `S[]`/`N[]`),
// or "". Populates `fRetRArrElem`.
function retRefArrElemName(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      if nameIsRefArray(ty.tyName) { return refArrElemName(ty.tyName) }
    }
  }
  ""
}

function vtKindOfType(tyIx: i32) {
  // A literal-union annotation (`type K = "a" | "b"`) is an i32-backed interned atom (kind 0), NOT a
  // value-union box — checked first (it IS a `TyUnion`, so `retUnionFlag` would claim it).
  if nameIsLitUnionType(tyNameOf(tyIx)) { return 0 }
  // A NULLABLE function `(fn) | null` is the closure fat-pointer made nullable, kind 19 —
  // checked BEFORE `tyIsFuncType` (whose `=>` test would otherwise claim it as the non-null
  // kind 14). The non-null part is a function, but the `| null` makes the slot nullable.
  if nulCloFlag(tyIx) == 1 { return 19 }
  // An ARRAY OF FUNCTIONS (`((i32) => i32)[]`) is a closure-element REF LIST (kind 5),
  // NOT a single closure — checked BEFORE `tyIsFuncType`, whose `=>` substring test would
  // otherwise claim the whole array as kind 14. The element arrow is NESTED; a TOP-LEVEL
  // arrow with a trailing `[]` (`(i32) => i32[]`, a function RETURNING a list) is a real
  // closure value and stays kind 14 below.
  if nameIsClosureArrayTy(tyIx) == 1 { return 5 }
  // A function-typed annotation (a name carrying `=>` — incl. the synthetic
  // `"=>sigkey"` a monomorphized closure param is pinned with) is the closure
  // fat-pointer, kind 14. Checked first; no other name contains an arrow.
  if tyIsFuncType(tyIx) { return 14 }
  // A string-keyed MAP annotation (`{[string]: V}`) is the map struct ref, kind 6 — checked
  // before the struct/object arms (an inline `{[…]:…}` is not a field-struct shape). Its
  // `fbValtype` arg is the map shape slot (mono i32 ⇒ -1, via `paramStructIdxOf`/`retStructIndex`).
  if retMapFlag(tyIx) == 1 { return 6 }
  if retNulRefFlag(tyIx) == 1 { return 9 }
  if retNulStringFlag(tyIx) == 1 { return 16 }
  if retNulListFlag(tyIx) == 1 { return 15 }
  if retStrArrFlag(tyIx) == 1 { return 7 }
  if retF64ArrFlag(tyIx) == 1 { return 12 }
  if retI64ArrFlag(tyIx) == 1 { return 20 }
  if retF32ArrFlag(tyIx) == 1 { return 21 }
  if retRefArrFlag(tyIx) == 1 { return 5 }
  if retUnionFlag(tyIx) == 1 { return 4 }
  if retVariantFlag(tyIx) == 1 { return 8 }
  if retTRFlag(tyIx) == 1 { return 1 }
  if retArrFlag(tyIx) == 1 { return 2 }
  if retStrFlag(tyIx) == 1 { return 3 }
  if retI64Flag(tyIx) == 1 { return 10 }
  if retF64Flag(tyIx) == 1 { return 11 }
  if retF32Flag(tyIx) == 1 { return 13 }
  0
}

// `1` if the type-annotation node at `tyIx` is a string-keyed map (`{[string]: V}`), else `0`.
// Feeds the `kind == 6` (map struct ref) branch of `vtKindOfType`, so a map can be a param /
// return / functype valtype (the `(ref $mapStruct)` cell), not only a local.
function retMapFlag(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      // A string-keyed map crosses a call boundary as kind 6 (`(ref $mapStruct)`). Its
      // `fbValtype` arg is the map SHAPE (`mapAnnShape`): -1 for the mono i32/boolean map, or
      // the per-value-type mv slot for a `string`- or STRUCT-valued map (the value type's
      // interned mv slot carries its `$mapStruct` across the boundary). An f64/i64-valued map
      // has deeper local-level gaps, so it stays a clean rejection.
      if nameIsMap(ty.tyName) {
        const vn = mapValNameOf(ty.tyName)
        if vn == "i32" || vn == "boolean" || vn == "string" { return 1 }
        if structIndexByValName(vn) >= 0 { return 1 }
        // A ref-LIST value (`S[]`, `i32[]`, a nested `S[][]`, a closure / union list) or a NESTED
        // map value: its `mvShapeOfValName` slot carries the value's `$mapStruct` across the call
        // boundary like a struct value does, and the recursive ref-list machinery makes the
        // value store/read fall out — so a list-valued map RETURNS the same as it binds locally.
        if nameIsArray(vn) || nameIsMap(vn) { return 1 }
      }
    }
  }
  0
}

// The map SHAPE (`fbValtype`/`mapTypeIdxOf` second arg) of a string-keyed map type annotation:
// -1 for the mono i32/boolean map (rides the shared `$mapStruct`), or the value type's interned
// mv slot for a `string`-valued map. A non-map / un-interned value type yields -1 (the mono
// shape) — safe, since `retMapFlag` only lets the supported value types reach kind 6. Shared by
// the param valtype (`paramStructIdxOf`), the return valtype, and the body shape resolution
// (`mapShapeOfExpr`) so all three agree on which `$mapStruct` a map param/return is.
function mapAnnShape(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      if nameIsMap(ty.tyName) {
        const vn = mapValNameOf(ty.tyName)
        if vn == "i32" || vn == "boolean" { return -1 }
        let i = 0
        while i < mvValName.length {
          if mvValName[i] == vn { return i }
          i = i + 1
        }
      }
    }
  }
  -1
}

// The map SHAPE of the map PARAM `name` of function `fnIx` (its annotation's value type),
// or -1. Lets `mapShapeOfExpr` resolve a map param's VALUE type instead of assuming mono i32.
function paramMapShape(fnIx: i32, name: string) {
  if fnIx < 0 { return -1 }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    const params = fn.fnParams
    let i = 0
    while i < params.length {
      const p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name { return mapAnnShape(p.parType) }
      }
      i = i + 1
    }
  }
  -1
}

// The map SHAPE a function `name` RETURNS (its return annotation's value type), or -1 (the mono
// map / an un-annotated return whose shape is not annotation-derived). Lets a caller resolve the
// VALUE type of `mk()[k]` over a `string`-valued map factory.
function fnRetMapShape(name: string) {
  const fe = fnIndexOf(name)
  if fe >= 0 {
    const fn = P.nodes[fnStmts[fe]]
    if fn is FuncDecl {
      if fn.fnRet >= 0 { return mapAnnShape(fn.fnRet) }
      // An UN-annotated map return (`function passthru(m) { return m }`): derive the shape from
      // the returned expression (a map param/local/`Map()`), so a caller of a `string`-valued
      // map factory resolves the value type.
      const rx = fnRetExprOf(fnStmts[fe])
      if rx >= 0 { return mapRetExprShape(rx, fnStmts[fe]) }
    }
  }
  -1
}

// `1` if the type-annotation node at `tyIx` names a union VARIANT struct (e.g. `TyObj`
// of `Ty`), else `0`. Feeds the `kind == 8` (concrete variant struct ref) branch of
// `pushVT`. A variant-struct param/result is the unboxed variant ref directly — gap #2.
function retVariantFlag(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      if variantIndexOf(ty.tyName) >= 0 { return 1 }
    }
  }
  0
}

// `1` if the type-annotation node at `tyIx` names the declared union alias, else `0`.
// Feeds the `kind == 4` (union box) branch of `pushVT`.
function retUnionFlag(tyIx: i32) {
  if tyIx >= 0 {
    const ty = P.nodes[tyIx]
    if ty is TypeRef {
      if isUName(ty.tyName) { return 1 }
    }
  }
  0
}

// The `pushVT` `kind` for a parameter node at `paramIx` (`1` struct, `2` array, `3`
// string, `0` i32).
function vtKindOfParam(paramIx: i32) {
  const p = P.nodes[paramIx]
  if p is Param { return vtKindOfType(p.parType) }
  0
}

// The second `fbValtype` arg for the parameter node at `paramIx` (from its annotation).
// For a STRUCT param (kind 1) this is its struct table index (or -1); for a REF-ARRAY
// param (kind 5) it is the ref-list TABLE SLOT for the element type (`B[]` → B's slot)
// — `fbValtype`'s kind-5 arm now indexes `rlWrapIdx[slot]`, so it must NOT collapse to
// -1/slot 0. Mirrors `tyAnnRefListSlot` (how `let`/return annotations resolve `T[]`).
function paramStructIdxOf(paramIx: i32) {
  const p = P.nodes[paramIx]
  if p is Param {
    if retRefArrFlag(p.parType) == 1 { return tyAnnRefListSlot(p.parType) }
    // A string-keyed MAP param's second `fbValtype` arg is the map SHAPE (mono ⇒ -1, or the
    // value type's mv slot for a `string`-valued map), so the param valtype selects THIS map's
    // `$mapStruct`.
    if retMapFlag(p.parType) == 1 { return mapAnnShape(p.parType) }
    // A concrete-VARIANT param (kind 8) — its `fbValtype` slot is the VARIANT index
    // (`uVarIdx + vi`), which `retStructIndex` (standalone structs) misses.
    if retVariantFlag(p.parType) == 1 {
      const ptv = P.nodes[p.parType]
      if ptv is TypeRef { return variantIndexOf(ptv.tyName) }
    }
    return retStructIndex(p.parType)
  }
  -1
}

// The `pushVT` `kind` for a module global from its literal INITIALIZER at `initIx`:
// `1` struct ref (object literal), `2` list ref (array literal), `3` string ref (string
// literal), else `0` i32. The global's valtype must match the init's wasm type so the
// constexpr validates; the literal cases are the only ones in scope (a non-literal init
// fails loudly when `emitExpr` lowers it as a constexpr with `fnIx = -1`).
function globalKind(initIx: i32) {
  if initIx < 0 { return 0 }
  const e = P.nodes[initIx]
  // A function-literal init (`const add = function(...)...`) — or a bare reference to a
  // top-level function name in value position — is a closure fat-pointer cell (kind 14).
  if e is FuncDecl { return 14 }
  if e is Ident {
    if fnIndexOf(e.identName) >= 0 { return 14 }
  }
  // An un-annotated float `.` literal init (`const a = 1.5`) is an f64 cell (kind 11),
  // lowered as `f64.const`. (Slice 3 — additive; bare integer globals stay kind 0.)
  if e is NumLit {
    if numTextIsFloat(e.numText) { return 11 }
  }
  if e is ObjLit {
    // A literal matching a standalone struct is that struct ref (kind 1) — even in a
    // union program. Otherwise, in a union program it boxes into the union (kind 4).
    if structIndexOfObj(initIx) >= 0 { return 1 }
    if uDeclared { return 4 }
    return 1
  }
  if e is ArrayLit {
    // A ref-element array literal is a ref list (kind 5); a STRING-element literal
    // is the string list (kind 7); an f64-element literal is the f64 list (kind 12,
    // Slice 4); an i32/empty literal is the i32 list (kind 2). A module-global empty
    // `[]` over a ref type is out of scope (a global ref-list constexpr needs the
    // binding annotation — deferred).
    if arrLitIsRef(initIx) { return 5 }
    if arrLitIsStr(initIx, -1) { return 7 }
    if arrLitIsF64(initIx, -1) { return 12 }
    return 2
  }
  if e is StrLit { return 3 }
  // A NON-LITERAL initializer (a concat `"a" + "b"`, a `fromCodePoint(...)` or
  // user-function call, a reference to another global): classify via the expression
  // family with no enclosing function (`fnIx = -1`) — the same predicates the local
  // `letIs*` ladder uses. The cell zero-inits (`ref.null` via the non-const path)
  // and the start function `global.set`s the computed value. An i32-producing
  // expression matches none of these and stays kind 0 — programs without ref-typed
  // global expressions emit byte-identical bytes.
  // A non-literal init that evaluates to a function value — a call returning a closure
  // (`const f = makeAdder(5)`) or a member read of a function-valued field (`const h =
  // o.go`) — is a closure fat-pointer cell (kind 14). Checked FIRST among the
  // expression-family cases (it never overlaps the others, and only fires in a program
  // that uses function values, so non-closure globals stay byte-identical).
  if exprIsClosure(initIx, -1) { return 14 }
  if exprNullableStruct(initIx, -1) { return 9 }
  if exprMap(initIx, -1) { return 6 }
  if exprString(initIx, -1) { return 3 }
  if exprStringArray(initIx, -1) { return 7 }
  if exprRefArray(initIx, -1) { return 5 }
  if exprF64Array(initIx, -1) { return 12 }
  if exprUnion(initIx, -1) { return 4 }
  if exprStruct(initIx, -1) { return 1 }
  if exprArray(initIx, -1) { return 2 }
  // A SCALAR f64 / i64 non-literal init (f64 / i64 ARITHMETIC `2.0 + 4.5`, or an
  // f64-returning call `dbl(2.0)`) — kind 11 / 10, the module-scope analogue of the local
  // `letIsF64` / `letIsI64` inference (which is gated to inside a function). A single
  // float literal already classifies above; this covers the COMPOSITE init. (`exprIsF64`
  // /`exprIsI64` may recurse into another global, terminating for an acyclic program — the
  // same shape the `exprString` / `exprStruct` cases above already rely on.)
  if exprIsF64(initIx, -1) { return 11 }
  if exprIsI64(initIx, -1) { return 10 }
  0
}

// Whether the module global `name` has a non-const initializer — used at READ sites
// (`global.get`) to decide whether the (nullable) cell needs a `ref.as_non_null`.
function globalNameIsNonConst(name: string) {
  globalIsNonConst(globalLetOf(name))
}

// The `fbValtype` kind for a module global's CELL. When the binding has a TYPE
// ANNOTATION (const init OR not), the kind is derived from that annotation via the
// `letIs*` ladder — so a global agrees with a same-typed local/param/field on its
// valtype (kind + struct index). Only an UN-annotated const global (`let g = { … }`,
// no `: T`) falls back to the literal-initializer kind (`globalKind`); the `g_globals`
// golden's struct global IS annotated, and its annotation names the SAME struct its
// literal infers, so the emitted bytes are unchanged. A non-const init's literal kind is
// meaningless (member/index/call), so it likewise rides the annotation ladder. Mirrors
// `buildLocals`' annotation→kind ladder (map 6, string-array 7, ref-array 5, struct 1,
// array 2, string 3, else i32 0).
function globalCellKind(letIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if globalHasTypeAnn(letIx) {
      // A NULLABLE-function global (`let g: ((i32) => i32) | null = inc`) is a nullable
      // closure cell (kind 19) — checked BEFORE the bare-function kind 14, mirroring
      // `vtKindOfType` / `fieldTypeCode`: `((i32) => i32) | null` is a nullable function,
      // whereas `(i32) => i32 | null` is a function returning a nullable.
      if nulCloFlag(d.letType) == 1 { return 19 }
      // A function-typed global (`const g: (i32) => i32 = inc`) is a closure fat-pointer
      // cell (kind 14), like a function-valued local.
      if tyIsFuncType(d.letType) { return 14 }
      if letIsNulRef(letIx, -1) { return 9 }
      if letIsNulList(letIx, -1) { return 15 }
      if letIsMap(letIx, -1) { return 6 }
      // A UNION-annotated global cell is the box ref (kind 4), exactly as `buildLocals`
      // classifies a union local — BEFORE the struct/string/scalar-list cases (a `string |
      // i32` / `f64[] | string` annotation is none of those, and a scalar-list INIT must not
      // claim the cell). `S | null` / `boolean | null` never register as union names (they
      // keep their niche kinds above).
      if letIsLitUnion(letIx) { return 0 }
      if letIsLitUnion(letIx) { return 0 }
      if letIsUnion(letIx, -1) { return 4 }
      if letIsStringArray(letIx, -1) { return 7 }
      if letIsRefArray(letIx, -1) { return 5 }
      if letIsF32Array(letIx, -1) { return 21 }
      if letIsF64Array(letIx, -1) { return 12 }
      if letIsI64Array(letIx, -1) { return 20 }
      if letIsStruct(letIx, -1) { return 1 }
      if letIsArray(letIx, -1) { return 2 }
      if letIsNulString(letIx, -1) { return 16 }
      if letIsString(letIx, -1) { return 3 }
      if letIsI64(letIx, -1) { return 10 }
      if letIsF64(letIx, -1) { return 11 }
      if letIsF32(letIx) { return 13 }
      return 0
    }
    // No annotation: a const literal init types itself; a non-const un-annotated init is
    // out of scope (no annotation to derive from) and `globalKind` returns its best guess.
    // An empty `[]` whose PUSHES infer a string element is the string list (kind 7).
    if letInfStrListByUse(letIx) { return 7 }
    // An un-annotated global whose init PRODUCES a union (`const a = make(42)` with
    // a union-returning `make`) carries the box (kind 4), as a local would.
    if letIsUnion(letIx, -1) { return 4 }
    // An un-annotated global bound to a `string | null`-returning call (`const r = f()`)
    // carries the kind-16 nullable-string cell, as a local would.
    if letIsNulString(letIx, -1) { return 16 }
    return globalKind(d.letInit)
  }
  0
}

// The struct table index for a global cell of kind 1 (struct ref), else -1. When the
// binding has a struct ANNOTATION the index comes from THAT annotation (`structIndexOfLet`,
// which prefers the annotation over the init) — so a struct global agrees with a same-
// typed local/param/field. An un-annotated const struct global infers from its literal.
function globalCellStructIdx(letIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if globalHasTypeAnn(letIx) { return structIndexOfLet(letIx, -1) }
    return structIndexOfExpr(d.letInit, -1)
  }
  -1
}

// Reset the interning counter (call once per module, before assigning indices).
function mResetTypeIntern() {
  mNextType = 0
  0
}

// Allocate the next heap-type index (interning in emit order): return the current
// counter, then advance it by one. This is the single auditable place a type index
// is minted — every `mIntern*` below funnels through here.
function mAllocType() {
  const idx = mNextType
  mNextType = mNextType + 1
  idx
}

// The Phase-G safety assert (risk R2): the interned index MUST equal the value the
// old offset formula computes. On divergence, fail loudly (drops the buffer so a
// mis-indexed module never reaches instantiation) — never silence it. Retained as
// a cheap debug check for one release after the old arithmetic is deleted.
function mAssertIdx(got: i32, want: i32, who: string) {
  if got != want {
    return emitFail("emitProgram: Phase G type-index drift in " + who)
  }
  0
}

// Walk the type-section emit order with the `mAllocType` counter, assigning each
// type's heap index into the module-global index state (`sHeapIdx`/`uVarIdx`/
// `uBoxIdx`/`aTypeIdx`/`lTypeIdx`/`rlBackIdx`/`rlWrapIdx`/`mkArrIdx`/`mkListIdx`/
// `mStructIdx`) and asserting each equals the old offset formula. Returns the
// functype base index (`typeOffset` — where the first functype lands), or -1 on a
// drift (via `mAssertIdx`/`emitFail`). The order MUST match the type-section
// emission below EXACTLY: standalone structs → union variants → union box → raw
// i32 array → i32-list wrapper → ref-list (backing, wrapper) pairs → string-list
// (backing, wrapper) → map struct → functypes.
function mAssignTypeIndices(n: i32) {
  mResetTypeIntern()

  // ── the OLD offset formulas (kept as the Phase-G debug-assert oracle) ──
  const structOffset = sNames.length
  let oldUnionOffset = 0
  const oldUVarIdx = structOffset
  const oldUBoxIdx = structOffset + uVariants.length
  // The per-rep VALUE BOXES (value unions) land right after the union box; every
  // later offset formula shifts by however many are interned.
  let vbTotal = 0
  if vbI32Used { vbTotal = vbTotal + 1 }
  if vbI64Used { vbTotal = vbTotal + 1 }
  if vbF32Used { vbTotal = vbTotal + 1 }
  if vbF64Used { vbTotal = vbTotal + 1 }
  if uDeclared { oldUnionOffset = uVariants.length + 1 + vbTotal }
  const preTypes = structOffset + oldUnionOffset
  let arrayOffset = 0
  if aUsed { arrayOffset = 1 }
  let listOffset = 0
  if lUsed { listOffset = 1 }
  const oldATypeIdx = preTypes
  const oldLTypeIdx = preTypes + arrayOffset
  const refPairBase = preTypes + arrayOffset + listOffset
  const refPairsTotal = rlElemName.length * 2
  const preMap = refPairBase + refPairsTotal
  const oldMkArrIdx = preMap
  const oldMkListIdx = preMap + 1
  const oldMStructIdx = preMap + 2

  // ── the NEW interned assignment (the single auditable counter) ──
  // Standalone structs occupy the first `sNames.length` indices (decl order).
  sHeapIdx = []
  let shi = 0
  while shi < sNames.length {
    let si = mAllocType()
    if mAssertIdx(si, shi, "struct") < 0 { return -1 }
    sHeapIdx.push(si)
    shi = shi + 1
  }
  // Union variant structs (nv of them) then the union box.
  if uDeclared {
    uVarIdx = mNextType
    if mAssertIdx(uVarIdx, oldUVarIdx, "uVarIdx") < 0 { return -1 }
    let vi = 0
    while vi < uVariants.length {
      mAllocType()
      vi = vi + 1
    }
    uBoxIdx = mAllocType()
    if mAssertIdx(uBoxIdx, oldUBoxIdx, "uBoxIdx") < 0 { return -1 }
    // The per-rep VALUE BOXES (`{ i32 }` / `{ i64 }` / `{ f32 }` / `{ f64 }`),
    // in this fixed rep order — only the reps a registered value union uses.
    if vbI32Used { vbI32Idx = mAllocType() }
    if vbI64Used { vbI64Idx = mAllocType() }
    if vbF32Used { vbF32Idx = mAllocType() }
    if vbF64Used { vbF64Idx = mAllocType() }
  }
  // The raw i32 array (string rep + list/map backing), then the i32-list wrapper.
  if aUsed {
    aTypeIdx = mAllocType()
    if mAssertIdx(aTypeIdx, oldATypeIdx, "aTypeIdx") < 0 { return -1 }
  } else {
    aTypeIdx = oldATypeIdx
  }
  if lUsed {
    lTypeIdx = mAllocType()
    if mAssertIdx(lTypeIdx, oldLTypeIdx, "lTypeIdx") < 0 { return -1 }
  } else {
    lTypeIdx = oldLTypeIdx
  }
  // The map struct index is needed BELOW to resolve a map-array ref-list element
  // (it references `(ref null $mStructIdx)`), yet the map struct lands AFTER the ref
  // pairs + string-list. It is computable up front from the counter: it follows the
  // `refPairsTotal` ref-pair slots plus the 2 string-list slots.
  const mStructIdxPre = mNextType + refPairsTotal + 2
  // One (backing, wrapper) pair per distinct ref-list element type, interleaved.
  let rs = 0
  while rs < rlElemName.length {
    const back = mAllocType()
    const wrap = mAllocType()
    if mAssertIdx(back, refPairBase + rs * 2, "rlBackIdx") < 0 { return -1 }
    if mAssertIdx(wrap, refPairBase + rs * 2 + 1, "rlWrapIdx") < 0 { return -1 }
    rlBackIdx[rs] = back
    rlWrapIdx[rs] = wrap
    if rlElemKindTbl[rs] == 2 {
      rlElemHeap[rs] = uBoxIdx
    } else if rlElemKindTbl[rs] == 3 {
      rlElemHeap[rs] = mStructIdxPre
    } else if rlElemKindTbl[rs] == 4 {
      // An `i32[][]` slot's element is the i32-list WRAPPER (interned just above,
      // so `lTypeIdx` is already assigned).
      rlElemHeap[rs] = lTypeIdx
    } else if (
      rlElemKindTbl[rs] == 6 ||
      rlElemKindTbl[rs] == 7 ||
      rlElemKindTbl[rs] == 8 ||
      rlElemKindTbl[rs] == 10
    ) {
      // string[][] / f64[][] / i64[][]: the element is the inner list's WRAPPER
      // (`mkListIdx` / `fl64TypeIdx` / `il64TypeIdx`) — but those wrappers are allocated AFTER
      // this loop, so a second pass (below) fills these heaps once they exist.
      rlElemHeap[rs] = 0
    } else if rlElemKindTbl[rs] == 9 {
      // A struct-LIST value (`S[]`): the element is the inner struct-list WRAPPER, the ref-list
      // wrapper of the inner `S` slot (interned at a LOWER index, so its `rlWrapIdx` is set).
      rlElemHeap[rs] = rlWrapIdx[rlSlotByName(refArrElemName(rlElemName[rs]))]
    } else {
      // A NULLABLE-struct element (`(P | null)[]`, slot key "P | null"): the backing is a
      // `(ref null $P)` over the bare struct — strip the `| null` to resolve P's heap.
      let rsen = rlElemName[rs]
      const rsnn = nullablePartOf(rsen)
      if rsnn != "" { rsen = rsnn }
      const esi = structIndexByName(rsen)
      if esi >= 0 {
        rlElemHeap[rs] = sHeapIdx[esi]
      } else {
        // A concrete-VARIANT element (`Cat[]`): the element heap is the variant struct
        // `uVarIdx + vi` (no standalone `sNames` entry — variants ride the union's structs).
        const evi = variantIndexOf(rsen)
        if evi >= 0 {
          rlElemHeap[rs] = uVarIdx + evi
        } else {
          rlElemHeap[rs] = 0
        }
      }
    }
    rs = rs + 1
  }
  // The legacy singletons alias slot 0 (or the next index when no ref list).
  if rlElemName.length >= 1 {
    raTypeIdx = rlBackIdx[0]
    rlTypeIdx = rlWrapIdx[0]
  } else {
    raTypeIdx = mNextType
    rlTypeIdx = mNextType
    if mAssertIdx(raTypeIdx, refPairBase, "raTypeIdx") < 0 { return -1 }
  }
  // The string-ref list (keys backing + keys wrapper), shared by the map's keys
  // list AND any `string[]` field (present when `slUsed || mUsed`).
  if slUsed || mUsed {
    mkArrIdx = mAllocType()
    mkListIdx = mAllocType()
    if mAssertIdx(mkArrIdx, oldMkArrIdx, "mkArrIdx") < 0 { return -1 }
    if mAssertIdx(mkListIdx, oldMkListIdx, "mkListIdx") < 0 { return -1 }
  } else {
    mkArrIdx = oldMkArrIdx
    mkListIdx = oldMkListIdx
  }
  // The map struct (present only when `mUsed`).
  if mUsed {
    mStructIdx = mAllocType()
    if mAssertIdx(mStructIdx, oldMStructIdx, "mStructIdx") < 0 { return -1 }
    if mAssertIdx(mStructIdx, mStructIdxPre, "mStructIdxPre") < 0 { return -1 }
  } else {
    mStructIdx = oldMStructIdx
  }
  // The f64 array + list-wrapper pair (Slice 4), interned LAST among the heap types so no
  // existing index shifts. The `(array (mut f64))` backing first, then its `{backing,len,
  // cap}` wrapper struct (which references the backing). Present only when `fa64Used`.
  const oldFa64Idx = preMap + strListOffsetOf() + mapStructOffsetOf()
  if fa64Used {
    fa64TypeIdx = mAllocType()
    fl64TypeIdx = mAllocType()
    if mAssertIdx(fa64TypeIdx, oldFa64Idx, "fa64TypeIdx") < 0 { return -1 }
    if mAssertIdx(fl64TypeIdx, oldFa64Idx + 1, "fl64TypeIdx") < 0 { return -1 }
  } else {
    fa64TypeIdx = oldFa64Idx
    fl64TypeIdx = oldFa64Idx + 1
  }
  // The i64-list pair, immediately after the f64 pair (same "interned late so no existing
  // index shifts" discipline): the `(array (mut i64))` backing then its `{backing,len,cap}`
  // wrapper. Present only when `ia64Used`; aliases its slots otherwise (zero types minted).
  const oldIa64Idx = oldFa64Idx + f64ListOffsetOf()
  if ia64Used {
    ia64TypeIdx = mAllocType()
    il64TypeIdx = mAllocType()
    if mAssertIdx(ia64TypeIdx, oldIa64Idx, "ia64TypeIdx") < 0 { return -1 }
    if mAssertIdx(il64TypeIdx, oldIa64Idx + 1, "il64TypeIdx") < 0 { return -1 }
  } else {
    ia64TypeIdx = oldIa64Idx
    il64TypeIdx = oldIa64Idx + 1
  }
  // The f32-list pair, immediately after the i64 pair (same "interned late" discipline): the
  // `(array (mut f32))` backing then its `{backing,len,cap}` wrapper. Present only when
  // `fa32Used`; aliases its slots otherwise (zero types minted).
  const oldFa32Idx = oldIa64Idx + i64ListOffsetOf()
  if fa32Used {
    fa32TypeIdx = mAllocType()
    fl32TypeIdx = mAllocType()
    if mAssertIdx(fa32TypeIdx, oldFa32Idx, "fa32TypeIdx") < 0 { return -1 }
    if mAssertIdx(fl32TypeIdx, oldFa32Idx + 1, "fl32TypeIdx") < 0 { return -1 }
  } else {
    fa32TypeIdx = oldFa32Idx
    fl32TypeIdx = oldFa32Idx + 1
  }
  // Second pass: fill the NON-i32 nested-list ref-list element heaps now that the inner
  // string/f64/i64 list wrappers exist (a `string[]`/`f64[]`/`i64[]`-VALUED map's vals
  // ref-list — kinds 6/7/8). The wrappers are forced by `mvShapeOfValName` (slUsed / fa64Used
  // / ia64Used), so the index is real here.
  let rsfix = 0
  while rsfix < rlElemName.length {
    if rlElemKindTbl[rsfix] == 6 { rlElemHeap[rsfix] = mkListIdx }
    else if rlElemKindTbl[rsfix] == 7 { rlElemHeap[rsfix] = fl64TypeIdx }
    else if rlElemKindTbl[rsfix] == 10 { rlElemHeap[rsfix] = fl32TypeIdx }
    else if rlElemKindTbl[rsfix] == 8 { rlElemHeap[rsfix] = il64TypeIdx }
    rsfix = rsfix + 1
  }
  // The function-value closure types (lambdas), interned LAST among the heap types so no
  // existing index shifts. The closure fat-pointer struct `{ code: (ref $fnsig), env:
  // structref }` first, then the env-leading functype `$fnsig` `(structref, i32...) ->
  // i32`. Both reference each other (mutually recursive in the one rec group). Then one
  // env struct per CAPTURING lifted function (capture order = field order), interned
  // after `$fnsig`. Present only when `fnValUsed`; zero types minted otherwise.
  const oldCloIdx = oldFa32Idx + f32ListOffsetOf()
  fnEnvIdx = []
  if fnValUsed {
    cloStructIdx = mAllocType()
    if mAssertIdx(cloStructIdx, oldCloIdx, "cloStructIdx") < 0 { return -1 }
    // A CLOSURE-element ref-list slot (kind 5, `((i32) => i32)[]`) backs onto the closure
    // fat-pointer struct. `cloStructIdx` is interned HERE (after the ref-pair loop above),
    // so backfill those slots' element heap type now — the backing array `(array (mut (ref
    // null $cloStructIdx)))` forward-references it within the shared rec group.
    let rcs = 0
    while rcs < rlElemName.length {
      if rlElemKindTbl[rcs] == 5 { rlElemHeap[rcs] = cloStructIdx }
      rcs = rcs + 1
    }
    // One `$fnsig` functype per distinct value-call signature (`cloSigKeys`).
    cloSigBase = mNextType
    let sa = 0
    while sa < cloSigKeys.length {
      mAllocType()
      sa = sa + 1
    }
    // One env struct per capturing lifted function (in `fnStmts` order). A
    // non-capturing function gets `-1` (its closure env is `ref.null structref`).
    let fe = 0
    while fe < fnStmts.length {
      const ncap = captureCountOf(fe)
      if ncap > 0 { fnEnvIdx.push(mAllocType()) } else { fnEnvIdx.push(-1) }
      fe = fe + 1
    }
  } else {
    cloStructIdx = oldCloIdx
    cloSigBase = oldCloIdx + 1
  }
  // The ref-valued map structs (one 7-field map struct per mv slot), interned LAST
  // among the heap types so no existing index shifts; zero types when no ref-valued
  // map exists (`mvOffsetOf` = 0 → byte-identical output for every existing program).
  const oldMvIdx = oldCloIdx + fnClosureOffsetOf()
  let mvi = 0
  while mvi < mvValName.length {
    mvMapTypeIdx[mvi] = mAllocType()
    if mAssertIdx(mvMapTypeIdx[mvi], oldMvIdx + mvi, "mvMapTypeIdx") < 0 {
      return -1
    }
    mvi = mvi + 1
  }
  // The functypes follow; the first lands at the current counter (`typeOffset`).
  const typeOffset = mNextType
  const oldTypeOffset = preMap +
    strListOffsetOf() +
    mapStructOffsetOf() +
    f64ListOffsetOf() +
    i64ListOffsetOf() +
    f32ListOffsetOf() +
    fnClosureOffsetOf() +
    mvOffsetOf()
  if mAssertIdx(typeOffset, oldTypeOffset, "typeOffset") < 0 { return -1 }
  typeOffset
}

// The ref-valued-map struct count: one map struct per interned mv slot.
function mvOffsetOf() { mvValName.length }

// The closure-type count interned ahead of the functypes: the closure struct + the
// `$fnsig` functype (2) plus one env struct per capturing lifted function, or 0 when
// no function value exists. Mirrors `f64ListOffsetOf` — keeps `typeOffset`'s oracle
// formula in step with the live counter.
function fnClosureOffsetOf() {
  if !fnValUsed { return 0 }
  // 1 closure struct + one `$fnsig` per distinct value-call signature + one env struct
  // per capturing lifted function.
  let total = 1 + cloSigKeys.length
  let fe = 0
  while fe < fnStmts.length {
    if captureCountOf(fe) > 0 { total = total + 1 }
    fe = fe + 1
  }
  total
}

// The f64-list type count (backing + wrapper): 2 when present, else 0.
function f64ListOffsetOf() {
  if fa64Used { return 2 }
  0
}

// The i64-list type count (backing + wrapper): 2 when present, else 0.
function i64ListOffsetOf() {
  if ia64Used { return 2 }
  0
}

// The f32-list type count (backing + wrapper): 2 when present, else 0.
function f32ListOffsetOf() {
  if fa32Used { return 2 }
  0
}

// The string-list type count (keys backing + wrapper): 2 when present, else 0.
function strListOffsetOf() {
  if slUsed || mUsed { return 2 }
  0
}

// The map-struct type count: 1 when a map is used, else 0.
function mapStructOffsetOf() {
  if mUsed { return 1 }
  0
}

// Detect, over the SET of non-const global init expressions, the scratch frames the
// start function's body needs — the start-fn analogue of `emitFuncCode`'s per-function
// `fnHas*` detection. A `.push` is a statement-level void call (never in an init VALUE
// position), so the i32/ref/string-push frames are driven by Member-receiver `.pop`s
// (which DO appear in value position, `let x = T.scopes.pop()` shape) via
// `exprHasMemberPopKind`; string ops and map ops are detected over the same exprs. Sets
// the `fnUses*` flags + `fnRefPushSlots`/`refPushBaseBySlot` exactly as `emitFuncCode`
// does, so the shared `fbBeginFunc`/`fbEmitLocalsVec` lay out an identical frame. For
// the common `curBuf = W.bytes` shape (a plain `global.get`+`struct.get`) every flag is
// false and the locals vector is empty.
// Record the ref-list slot of a bare top-level `recv.push(x)` statement (the
// block-level collector handles pushes nested in loop/if bodies).
function recordStartRefPushSlot(stmtIx: i32) {
  let s = P.nodes[stmtIx]
  if s is Call {
    const callee = P.nodes[s.callFn]
    if callee is Member {
      if callee.memProp == "push" {
        recordRefPushSlot(refListSlotOfExpr(callee.memObj, -1))
      }
    }
  }
  0
}

// Run every scratch-detection walker over one start-fn BLOCK (a loop body, an if
// arm), feeding the `fnUses*` flags + the ref-push slot recorders. BOTH push
// walkers feed the push flags, mirroring `fnHasPush`: a `.push` (the push walker)
// and a Member-receiver `.pop` (the pop walker, which reuses the push frame's
// slots) each need the scratch quad.
function startScanBlock(blockIx: i32) {
  if blockHasPushKind(blockIx, -1, 0) { fnUsesPush = true }
  if blockHasPushKind(blockIx, -1, 1) { fnUsesRefPush = true }
  if blockHasPushKind(blockIx, -1, 2) { fnUsesStrPush = true }
  if blockHasPushKind(blockIx, -1, 3) { fnUsesF64Push = true }
  if blockHasPushKind(blockIx, -1, 5) { fnUsesF32Push = true }
  if blockHasPushKind(blockIx, -1, 4) { fnUsesI64Push = true }
  if blockHasMemberPopKind(blockIx, -1, 0) { fnUsesPush = true }
  if blockHasMemberPopKind(blockIx, -1, 1) { fnUsesRefPush = true }
  if blockHasMemberPopKind(blockIx, -1, 2) { fnUsesStrPush = true }
  if blockHasMemberPopKind(blockIx, -1, 3) { fnUsesF64Push = true }
  if blockHasMemberPopKind(blockIx, -1, 5) { fnUsesF32Push = true }
  if blockHasMemberPopKind(blockIx, -1, 4) { fnUsesI64Push = true }
  if blockHasStrOp(blockIx, -1) { fnUsesStrOp = true }
  if blockHasArrNew(blockIx) { fnUsesArrNew = true }
  if blockHasCoalesceCall(blockIx) { fnUsesCoalesceCall = true }
  if blockHasMapOp(blockIx, -1) { fnUsesMap = true }
  collectRefPushSlots(blockIx, -1)
  collectMemberPopRefSlots(blockIx, -1)
  0
}

// Scan a TOP-LEVEL `if` chain: the condition expression plus every arm's block
// (an `else if` recurses through this function).
function startScanIf(ifIx: i32) {
  const st = P.nodes[ifIx]
  if st is IfStmt {
    if exprHasStrOp(st.ifCond, -1) { fnUsesStrOp = true }
    if exprHasArrNew(st.ifCond) { fnUsesArrNew = true }
    if exprHasCoalesceCall(st.ifCond) { fnUsesCoalesceCall = true }
    if exprHasMapOp(st.ifCond, -1) { fnUsesMap = true }
    if exprHasMemberPopKind(st.ifCond, -1, 0) { fnUsesPush = true }
    if exprHasMemberPopKind(st.ifCond, -1, 1) { fnUsesRefPush = true }
    if exprHasMemberPopKind(st.ifCond, -1, 2) { fnUsesStrPush = true }
    if exprHasMemberPopKind(st.ifCond, -1, 3) { fnUsesF64Push = true }
    if exprHasMemberPopKind(st.ifCond, -1, 5) { fnUsesF32Push = true }
    if exprHasMemberPopKind(st.ifCond, -1, 4) { fnUsesI64Push = true }
    // Narrow across each arm (mirroring `ifChainHasStrOp` / `emitStmt`): the
    // then-branch sees the guard's narrowing, the else-branch sees a VALUE
    // union's complement — so a top-level `if w is string { print(w) }`
    // reserves the string scratch frame in the start function.
    const savedTop = narrowTop
    const narrowed = setNarrowFromCond(st.ifCond, -1)
    startScanBlock(st.ifThen)
    if narrowed { restoreNarrow(savedTop) }
    if st.ifElse >= 0 {
      const savedElseTop = narrowTop
      const narrowedElse = setNarrowFromCondElse(st.ifCond, -1)
      const els = P.nodes[st.ifElse]
      if els is Block { startScanBlock(st.ifElse) }
      if els is IfStmt { startScanIf(st.ifElse) }
      if narrowedElse { restoreNarrow(savedElseTop) }
    }
  }
  0
}

function startFnDetectScratch() {
  fnUsesPush = false
  fnUsesRefPush = false
  fnUsesStrPush = false
  fnUsesF64Push = false
  fnUsesF32Push = false
  fnUsesI64Push = false
  fnUsesStrOp = false
  fnUsesArrNew = false
  fnUsesCoalesceCall = false
  fnUsesMap = false
  fnUsesCallRef = false
  fnRefPushSlots = []
  refPushBaseBySlot = []
  fnUsesMapFilter = false
  fnUsesMapKeys = false
  mfSrcKinds = []
  mfSrcSlots = []
  mfSrcBases = []
  mfDstKinds = []
  mfDstSlots = []
  mfDstBases = []
  let gi = 0
  while gi < globalStmts.length {
    if globalIsNonConst(globalStmts[gi]) {
      const g = P.nodes[globalStmts[gi]]
      if g is LetDecl {
        const ix = g.letInit
        if exprHasMemberPopKind(ix, -1, 0) { fnUsesPush = true }
        if exprHasMemberPopKind(ix, -1, 1) { fnUsesRefPush = true }
        if exprHasMemberPopKind(ix, -1, 2) { fnUsesStrPush = true }
        if exprHasMemberPopKind(ix, -1, 3) { fnUsesF64Push = true }
        if exprHasMemberPopKind(ix, -1, 5) { fnUsesF32Push = true }
        if exprHasMemberPopKind(ix, -1, 4) { fnUsesI64Push = true }
        if exprHasStrOp(ix, -1) { fnUsesStrOp = true }
        // A `string` global initialized with a literal-union atom widens via the runtime tower
        // (`emitAtomToStr`), which stages the atom id in the string-op scratch frame.
        if globalInitWidensAtomToStr(globalStmts[gi]) { fnUsesStrOp = true }
        if exprHasArrNew(ix) { fnUsesArrNew = true }
        if exprHasCoalesceCall(ix) { fnUsesCoalesceCall = true }
        if exprHasMapOp(ix, -1) { fnUsesMap = true }
        if fnValUsed {
          if blockHasCallRef(ix, -1) { fnUsesCallRef = true }
        }
        collectMemberPopRefSlotsExpr(ix, -1)
        // A `.map`/`.filter` in a non-const global initializer (`const ys =
        // xs.map(...)`) runs in the start function — reserve its HOF frame here.
        mfScan(ix, -1)
      }
    }
    gi = gi + 1
  }
  // `.map`/`.filter` sites in top-level STATEMENTS (`print(e.map(...).length)`)
  // also run in the start function; `mfScan` recurses every statement shape itself.
  let mfi = 0
  while mfi < startStmts.length {
    mfScan(startStmts[mfi], -1)
    mfi = mfi + 1
  }
  // Top-level STATEMENTS may also need scratch (a `.push` / string op / map op in a
  // top-level `for`/`while`/`if` body or a bare call). Scan each through the same
  // walkers (which recurse into for/while/if bodies). `startScanBlock` runs every
  // block walker over one body; `startScanIf` descends an if/else-if chain.
  let si = 0
  while si < startStmts.length {
    const st = P.nodes[startStmts[si]]
    if st is ForRange {
      startScanBlock(st.frBody)
    } else if st is ForIn {
      startScanBlock(st.fiBody)
      if exprHasStrOp(st.fiIter, -1) { fnUsesStrOp = true }
      if exprHasArrNew(st.fiIter) { fnUsesArrNew = true }
      if exprHasCoalesceCall(st.fiIter) { fnUsesCoalesceCall = true }
      if exprHasMapOp(st.fiIter, -1) { fnUsesMap = true }
    } else if st is WhileStmt {
      startScanBlock(st.whileBody)
    } else if st is IfStmt {
      startScanIf(startStmts[si])
    } else {
      // expression statements (a bare call / assignment): the per-statement push
      // detector plus the expr walkers
      if stmtIsPushKind(startStmts[si], -1, 0) { fnUsesPush = true }
      if stmtIsPushKind(startStmts[si], -1, 1) { fnUsesRefPush = true }
      if stmtIsPushKind(startStmts[si], -1, 2) { fnUsesStrPush = true }
      if stmtIsPushKind(startStmts[si], -1, 3) { fnUsesF64Push = true }
      if stmtIsPushKind(startStmts[si], -1, 5) { fnUsesF32Push = true }
      if stmtIsPushKind(startStmts[si], -1, 4) { fnUsesI64Push = true }
      if exprHasMemberPopKind(startStmts[si], -1, 0) { fnUsesPush = true }
      if exprHasMemberPopKind(startStmts[si], -1, 1) { fnUsesRefPush = true }
      if exprHasMemberPopKind(startStmts[si], -1, 2) { fnUsesStrPush = true }
      if exprHasMemberPopKind(startStmts[si], -1, 3) { fnUsesF64Push = true }
      if exprHasMemberPopKind(startStmts[si], -1, 5) { fnUsesF32Push = true }
      if exprHasMemberPopKind(startStmts[si], -1, 4) { fnUsesI64Push = true }
      if exprHasStrOp(startStmts[si], -1) { fnUsesStrOp = true }
      if exprHasArrNew(startStmts[si]) { fnUsesArrNew = true }
      if exprHasCoalesceCall(startStmts[si]) { fnUsesCoalesceCall = true }
      if exprHasMapOp(startStmts[si], -1) { fnUsesMap = true }
      if fnValUsed {
        if blockHasCallRef(startStmts[si], -1) { fnUsesCallRef = true }
      }
      if stmtIsPushKind(startStmts[si], -1, 1) {
        recordStartRefPushSlot(startStmts[si])
      }
      collectMemberPopRefSlotsExpr(startStmts[si], -1)
    }
    si = si + 1
  }
  // List `==`/`!=`/`+` frames (collections-design §VL.4/§VL.6) — non-const
  // global inits and every top-level statement run in the start function.
  fnUsesListEqI = false
  fnUsesListEqS = false
  fnListEqRSlots = []
  fnUsesCloEq = false
  let lgi = 0
  while lgi < globalStmts.length {
    if globalIsNonConst(globalStmts[lgi]) {
      const lg = P.nodes[globalStmts[lgi]]
      if lg is LetDecl { leqScanExpr(lg.letInit, -1) }
    }
    lgi = lgi + 1
  }
  let lsi = 0
  while lsi < startStmts.length {
    leqScanStmt(startStmts[lsi], -1)
    lsi = lsi + 1
  }
  0
}

// Emit the synthetic start function's size-prefixed code entry onto `out` (the code
// section payload). The body runs every NON-const global initializer in declaration
// order — `emitExpr(body, letInit, -1)` (module scope, `fnIx = -1`) then `global.set gi`
// — so each cell holds its real value before any other code runs. Mirrors
// `emitFuncCode`'s framing: detect scratch frames, lay out locals via `fbBeginFunc`,
// emit the locals vector (`fbEmitLocalsVec`) with NO declared locals, then the body and
// the `end`, size-prefixed. Returns 0, or -1 (via `emitFail`).
// Collect the start function's DECLARED locals from the top-level statements: a
// `for` range loop's var+bound pair (and any `let`s nested in loop/if bodies, via
// the same collectLocals walkers user functions use, with the module-level
// `fnIx = -1`). Resets the local registry + scope stack like `buildLocals`.
function collectStartLocals() {
  localNames = []
  localIsRef = []
  localStructIdx = []
  localLoopVar = []
  localLitUnion = []
  scopeNames = []
  scopeSlots = []
  scopeFrames = []
  scopePush()
  let i = 0
  while i < startStmts.length {
    let s = P.nodes[startStmts[i]]
    if s is ForRange {
      const fvSlot = addLocalName(s.frVar, 0, -1)
      markLoopVarSlot(fvSlot)
      scopeBind(s.frVar, fvSlot)
      addLocalName(s.frVar + "#b", 0, -1)
      if collectLocals(s.frBody, -1) < 0 {
        scopePop()
        return -1
      }
      // The loop variable's scope is the loop (see `scopeUnbind`).
      scopeUnbind()
    } else if s is ForIn {
      const fiEk = forInElemKind(s.fiIter, -1)
      if fiEk < 0 {
        scopePop()
        return emitFail("emitProgram: unsupported for-in iterable")
      }
      // A struct element (`S[]`, code 1) binds the loop var as a struct local carrying
      // the element struct table index; the `#l` temp holds the ref-list WRAPPER
      // (code 5 + the ref-list slot). i32/string elements keep their slots.
      let fiVarIdx = -1
      let fiLk = 2
      if fiEk == 1 {
        fiVarIdx = forInRefArrayStructIdx(s.fiIter, -1)
        fiLk = 5
      } else if fiEk == 3 {
        fiLk = 7
      } else if fiEk == 11 {
        fiLk = 12 // f64 element → f64-list `#l` temp
      } else if fiEk == 10 {
        fiLk = 20 // i64 element → i64-list `#l` temp
      }
      const fiSlot = addLocalName(s.fiVar, fiEk, fiVarIdx)
      markLoopVarSlot(fiSlot)
      scopeBind(s.fiVar, fiSlot)
      addLocalName(s.fiVar + "#i", 0, -1)
      let fiLs = -1
      if fiEk == 1 { fiLs = refListSlotOfExpr(s.fiIter, -1) }
      addLocalName(s.fiVar + "#l", fiLk, fiLs)
      if collectLocals(s.fiBody, -1) < 0 {
        scopePop()
        return -1
      }
      // The loop variable's scope is the loop (see `scopeUnbind`).
      scopeUnbind()
    } else if s is WhileStmt {
      if collectLocals(s.whileBody, -1) < 0 {
        scopePop()
        return -1
      }
    } else if s is IfStmt {
      if collectLocalsIf(startStmts[i], -1) < 0 {
        scopePop()
        return -1
      }
    }
    i = i + 1
  }
  scopePop()
  localNames.length
}

function emitStartFnCode(out: i32[]) {
  // Locals FIRST, detection SECOND: the scratch detectors classify expressions
  // through the declared-locals registry (`declaredString(k)` for a `print(k)` over
  // a for-in string element), so the registry must be populated before they run —
  // `declaredSlotOf` falls back to the flat `localNames` scan when no scope frame
  // is active, exactly for detection passes. Then the frames follow the locals.
  const nStartLocals = collectStartLocals()
  if nStartLocals < 0 { return -1 }
  startFnDetectScratch()
  fbBeginFunc(0, nStartLocals)

  const bodyExpr: i32[] = []
  const exprPrev = wTarget(bodyExpr)
  // Reset the emit-time scope/loop bookkeeping (the start fn has its own empty frame),
  // mirroring `emitFuncCode` — no leak from the last user function.
  scopeNames = []
  scopeSlots = []
  scopeFrames = []
  emitLetCursor = 0
  ctrlDepth = 0
  loopContDepth = []
  loopBrkDepth = []
  loopContLabel = []
  loopBrkLabel = []
  // Non-const global initializers and top-level STATEMENTS run INTERLEAVED in source
  // order (merged on arena index — top-level statements are parsed sequentially, so
  // arena order IS source order): `xs.push(1)` before `const ys = xs.map(f)` must
  // execute before that init. A program with only inits, or only statements, emits
  // the exact same order as the previous inits-then-statements split (every golden
  // has at most one of the two, so the bytes are unchanged). The emit context is
  // module-level (`fnIx = -1`): identifier reads/writes resolve to globals.
  let gi = 0
  let si = 0
  // Post-statement narrowing for the top-level statement list (the assignment
  // narrowing of `pushPostGuardNarrow` — a top-level guard `if` cannot
  // `return`, so only the assignment arm ever fires here). Restored at loop end.
  const savedStartNarrowTop = narrowTop
  while gi < globalStmts.length || si < startStmts.length {
    let takeGlobal = gi < globalStmts.length
    if takeGlobal && si < startStmts.length {
      if startStmts[si] < globalStmts[gi] { takeGlobal = false }
    }
    if takeGlobal {
      if globalIsNonConst(globalStmts[gi]) {
        const g = P.nodes[globalStmts[gi]]
        if g is LetDecl {
          // Numeric WIDENING at the global-init boundary (a non-const `: f64`/`: f32`/`: i64`
          // global whose init is a narrower numeric — e.g. `const b: f64 = a` with `a: i32`):
          // the `emitExprAs*` helper inserts the lattice convert so the start-fn `global.set`
          // matches the cell valtype. An i32 cell stays byte-identical. (Slice 5 widening.)
          const gck = globalCellKind(globalStmts[gi])
          if gck == 13 {
            const savedF32 = pendingF32
            pendingF32 = true
            if emitExprAsF32(bodyExpr, g.letInit, -1) < 0 {
              wTarget(exprPrev)
              return -1
            }
            pendingF32 = savedF32
          } else if gck == 11 {
            if emitExprAsF64(bodyExpr, g.letInit, -1) < 0 {
              wTarget(exprPrev)
              return -1
            }
          } else if gck == 10 {
            if emitExprAsI64(bodyExpr, g.letInit, -1) < 0 {
              wTarget(exprPrev)
              return -1
            }
          } else {
            // A map global's start-fn init seeds the map SHAPE (mirrors the
            // local-`let` seeding) so `Map()` builds THIS global's map struct.
            if gck == 6 { pendingMapSlot = letMapShapeOf(globalStmts[gi], -1) }
            // A struct / nullable-struct cell seeds the struct context so a bare
            // `null` init lowers as `ref.null $S` and a literal builds THIS
            // global's annotated struct (mirrors the const-path seeding).
            if gck == 1 || gck == 9 {
              pendingStructIdx = globalCellStructIdx(globalStmts[gi])
            }
            // A `boolean|null` NICHE global lowers a bare `null` init as the sentinel 2;
            // a `string|null` global lowers it as `ref.null $aTypeIdx` (kind 16).
            pendingNulBool = letIsNulBoolAnn(globalStmts[gi])
            pendingNulString = letIsNulString(globalStmts[gi], -1)
            if letIsLitUnion(globalStmts[gi]) { pendingLitUnion = 1 }
            // A CLOSURE-ARRAY global (kind 5) seeds the ref-list kind/slot so its `[add1, …]`
            // init builds the closure backing+wrapper (its function-ident elements aren't an
            // objlit, so `arrLitIsRef` misses them — the annotation is authoritative, exactly
            // as the const-path and the local-`let` path seed it). Without this the start-fn
            // init falls to the i32-list path and the closure refs mismatch the i32 backing.
            if gck == 5 {
              pendingListKind = letAnnRefListKind(globalStmts[gi])
              pendingListSlot = letAnnRefListSlot(globalStmts[gi])
            }
            // A nullable-CLOSURE global (kind 19) lowers a bare `null` init as
            // `ref.null $cloStruct`; a function init builds the (non-null) closure value.
            const savedSNC = pendingNulClosure
            if gck == 19 { pendingNulClosure = true }
            // A UNION cell (kind 4) coerces a raw init value into the box
            // (`let w: string | i32 = n` boxes the i32 read) — a union-valued
            // init (a union-returning call) passes through unchanged.
            let gun = ""
            if gck == 4 { gun = letUnionNameOf(globalStmts[gi], -1) }
            if gun != "" {
              if emitUnionCoerce(bodyExpr, gun, g.letInit, -1) < 0 {
                wTarget(exprPrev)
                return -1
              }
            } else if (
              (gck == 3 || gck == 16) &&
              globalInitIsLitAtom(g.letInit)
            ) {
              // A literal-union atom initializing a `string` global widens to its member string.
              // The start fn is a real function, so the runtime widening tower runs here (unlike a
              // CONST global, whose constexpr init has no `select`/scratch).
              if emitAtomToStr(bodyExpr, g.letInit, -1) < 0 {
                wTarget(exprPrev)
                return -1
              }
            } else {
              if emitExpr(bodyExpr, g.letInit, -1) < 0 {
                wTarget(exprPrev)
                return -1
              }
            }
            pendingNulBool = false
            pendingNulString = false
            pendingNulClosure = savedSNC
            pendingMapSlot = -1
            pendingStructIdx = -1
            pendingListKind = 0
            pendingListSlot = 0
            pendingLitUnion = 0
          }
          const setPrev = wTarget(bodyExpr)
          fbGlobalSet(gi)
          wTarget(setPrev)
        }
      }
      gi = gi + 1
    } else {
      if emitStmt(bodyExpr, startStmts[si], -1) < 0 {
        wTarget(exprPrev)
        return -1
      }
      pushPostGuardNarrow(startStmts[si], -1)
      si = si + 1
    }
  }
  restoreNarrow(savedStartNarrowTop)
  wTarget(exprPrev)

  const body: i32[] = []
  // Locals vector: the start fn's declared locals (for-loop vars), then the scratch frames.
  if fbEmitLocalsVec(body, nStartLocals) < 0 { return -1 }
  appendAll(body, bodyExpr)
  const endPrev = wTarget(body)
  fbEnd() // 0x0b end (void → void: stack already empty)
  wTarget(endPrev)

  const outPrev = wTarget(out)
  wULEB(body.length)
  wBytes(body)
  wTarget(outPrev)
  0
}

// The synthetic `__log__(offset, length)` decoder body: walk the tag/value pairs in
// linear memory ([offset, offset+length), 8 bytes per pair) and print each value.
// Mirrors the host runner's `__log__` import (compile.ts `runWasm`): tag 0 = plain
// i32, printed via `__print_i32__` (import 0 — `memLogUsed` forces the print family).
// A non-zero tag (i64/f32/f64 payloads, which span extra words) traps (`unreachable`)
// — no corpus program logs them natively yet, and a silent wrong decode is worse.
// DIVERGENCE (justified): the host joins a multi-pair log into ONE space-separated
// line; this prints one line per pair. Every corpus `__log__` call logs exactly one
// pair, so stdout is identical.
function emitMemLogFnCode(out: i32[]) {
  const body: i32[] = []
  const prev = wTarget(body)
  // Locals vector: params occupy 0 (offset) and 1 (length); local 2 is the cursor.
  wULEB(1)      // 1 locals run
  wULEB(1)      // count 1
  wU8(127)      // 0x7f i32
  fbLocalGet(0)
  fbLocalSet(2) // cursor = offset
  fbBlock(64)   // block (void)
  fbLoop(64)    // loop (void)
  fbLocalGet(2)
  fbLocalGet(0)
  fbLocalGet(1)
  fbI32Bin(106) // 0x6a i32.add — offset + length (the end)
  fbI32Bin(78)  // 0x4e i32.ge_s — cursor >= end?
  fbBrIf(1)     // exit the block
  fbLocalGet(2)
  fbI32Load()   // the pair's TAG
  fbIf(64)      // tag != 0 → unsupported payload kind
  fbUnreachable()
  fbEnd()
  fbLocalGet(2)
  fbI32Const(4)
  fbI32Bin(106) // i32.add — the value word
  fbI32Load()
  fbCall(0)     // __print_i32__ (import 0)
  fbLocalGet(2)
  fbI32Const(8)
  fbI32Bin(106) // i32.add
  fbLocalSet(2) // cursor += 8
  fbBr(0)       // next pair
  fbEnd()       // end loop
  fbEnd()       // end block
  fbEnd()       // 0x0b end (void function: stack empty)
  wTarget(prev)
  const outPrev = wTarget(out)
  wULEB(body.length)
  wBytes(body)
  wTarget(outPrev)
  0
}

// Emit the wasm "name" custom section (section id 0, name "name") so a wasmtime
// trap backtrace shows real function names instead of `<wasm function N>`. GATED
// on `gEmitNames` — a no-op when off, so the default emit path (goldens +
// fixpoints) is byte-identical. `n` is the user-function count (`fnStmts.length`)
// and `gImports` the imported-function count (0 or 4); the imports occupy wasm
// indices 0..gImports-1 (the print family), the user functions gImports..gImports+n-1.
//
// Layout (per the WebAssembly name-section appendix):
//   section: id 0, ULEB(size), wName("name"), <subsections>
//   module-name  subsection (id 0): ULEB(size), wName("vl")
//   function-name subsection (id 1): ULEB(size), namemap
//     namemap = ULEB(count), then count * { ULEB(funcidx), wName(name) }
//   indices MUST be strictly increasing — we emit imports (0..3) then user
//   functions in their natural index order, so the sequence is already sorted.
function emitNameSection(n: i32) {
  if gEmitNames == 0 { return 0 }

  // ── function-name subsection (id 1) ──────────────────────────────────────────
  // Build the namemap (count + entries) into a temp buffer, then frame it as the
  // subsection payload. The print imports (if present) are named first at their
  // hardcoded indices 0..3, then each user function at `gImports + i`.
  const fnameMap: i32[] = []
  const mapPrev = wTarget(fnameMap)
  let count = gImports + n
  wULEB(count)
  if gImports > 0 {
    wULEB(0)
    wName("__print_i32__")
    wULEB(1)
    wName("__print_bool__")
    wULEB(2)
    wName("__print_char__")
    wULEB(3)
    wName("__print_str_flush__")
    // The 5th import (index 4) is named only when an i64 program prints.
    if gNeedsI64Print {
      wULEB(4)
      wName("__print_i64__")
    }
    // The `__print_f64__` import is named at its computed index (`gF64PrintIdx`, 4 or 5).
    if gNeedsF64Print {
      wULEB(gF64PrintIdx)
      wName("__print_f64__")
    }
    // The `__print_f32__` import is named at its computed index (`gF32PrintIdx`, 4/5/6).
    if gNeedsF32Print {
      wULEB(gF32PrintIdx)
      wName("__print_f32__")
    }
  }
  let fi = 0
  while fi < n {
    const fn = P.nodes[fnStmts[fi]]
    if fn is FuncDecl {
      wULEB(gImports + fi)
      // Prefer a lambda's DEBUG display name (its binding, `const foo = …` → "foo")
      // over the synthesized `__lambda_N`, so a trap backtrace reads `foo`.
      const disp = fnDispNames[fi]
      if disp.length > 0 { wName(disp) } else { wName(fn.fnName) }
    }
    fi = fi + 1
  }
  wTarget(mapPrev)

  // ── assemble the section payload: wName("name") + the two subsections ─────────
  const namePayload: i32[] = []
  const npPrev = wTarget(namePayload)
  wName("name")
  // module-name subsection (id 0): a single name. Its payload is a length-prefixed
  // name, built into a temp so the subsection-size ULEB frames the right length.
  const modName: i32[] = []
  const mnPrev = wTarget(modName)
  wName("vl")
  wTarget(mnPrev)
  wU8(0) // subsection id 0: module name
  wULEB(modName.length)
  wBytes(modName)
  // function-name subsection (id 1): the namemap built above.
  wU8(1) // subsection id 1: function names
  wULEB(fnameMap.length)
  wBytes(fnameMap)
  wTarget(npPrev)

  wSection(0, namePayload) // custom section id 0
  0
}

// Emit the complete module for the top-level functions in `fnStmts` (each a FuncDecl,
// validated by `collectFns`/`buildFnMap`/`checkParams`). If a struct `type` was
// declared, its WasmGC struct type is emitted FIRST (type index 0) and the functypes
// follow (1..N); otherwise functypes start at 0. Struct-typed params/results encode
// as `(ref $0)`. The function section binds func i to its functype, an export per
// function under its own name, and one code body per function — every section framed
// through the SAME LEB/section helpers the fixed builders use.
function emitModule(stmts: i32[]) {
  emitReset()
  emitHeader()

  let n = fnStmts.length

  // ── Start-function model (non-const module-global initializers) ──────────────
  // A module global whose initializer is NOT a WasmGC constant expression (a member
  // access like `curBuf = W.bytes`, a reference to another global, a call, …) cannot
  // be emitted inline in the global section. Its cell is zero-initialized there
  // (nullable `ref.null` / `i32.const 0`) and a SINGLE synthetic start function — the
  // LAST function index, so no user index shifts — runs every such init via
  // `global.set` before any other code. Count them up front; the count drives one
  // extra `()->()` functype, one extra function-section + code-section entry, and the
  // start section (id 8). When zero (the case for EVERY golden), nothing below
  // changes, so the module stays byte-identical.
  let nNonConst = 0
  let gci = 0
  while gci < globalStmts.length {
    if globalIsNonConst(globalStmts[gci]) { nNonConst = nNonConst + 1 }
    gci = gci + 1
  }
  let hasStart = 0
  if nNonConst > 0 { hasStart = 1 }
  if startStmts.length > 0 { hasStart = 1 }
  // The synthetic start function's index (last, after all `n` user functions, which
  // themselves sit after any imports) and its `()->()` functype index (one past the
  // user functypes). Both unused when no start.
  const startFnIdx = gImports + n
  // The synthetic `__log__` decoder (memory intrinsics) is the LAST function index —
  // after the imports, the user functions, AND the start fn — so no other function
  // index shifts. `memFn` (0 or 1) feeds the function/code section counts.
  let memFn = 0
  if memLogUsed { memFn = 1 }
  gMemLogIdx = gImports + n + hasStart

  // Heap-type indices, in type-section order: standalone structs at 0..ns-1, then
  // (for the union path) the variant structs + box, then the raw i32 array, the
  // i32-list wrapper, each ref-list (backing, wrapper) pair, the string-list
  // (backing, wrapper), the map struct, and finally the functypes. Every index is
  // minted by the centralized `mIntern*` counter inside `mAssignTypeIndices`, which
  // assigns the module-global index state (`sHeapIdx`/`uVarIdx`/`uBoxIdx`/`aTypeIdx`/
  // `lTypeIdx`/`rlBackIdx`/`rlWrapIdx`/`raTypeIdx`/`rlTypeIdx`/`mkArrIdx`/`mkListIdx`/
  // `mStructIdx`) in that order and ALSO asserts each equals the old offset formula
  // (risk R2 — index drift; the formulas survive as the assert oracle, scheduled for
  // deletion one release after Phase G). It returns the functype base index
  // (`typeOffset` — where the first functype lands), or -1 on a drift. All types are
  // emitted inside ONE recursion group below, so a type may reference one that lands
  // later (a string field's `(ref $aTypeIdx)`).
  const typeOffset = mAssignTypeIndices(n)
  if typeOffset < 0 { return -1 }

  // Type section (id 1): the struct type (if any) at index 0 — `0x5f` struct form,
  // field count, then each field's storagetype (`0x7f` i32) + mutability (`0x01`);
  // the raw i32 array type (if used) next — `0x5e` array form, `0x7f` i32 storagetype,
  // `0x01` mutable (derived from binaryen: `5e 7f 01`); the growable-list wrapper struct
  // (if used) next — `0x5f` struct of three mutable fields `{ backing: (ref $aTypeIdx),
  // len: i32, cap: i32 }` (verified against binaryen's `listType`); then one functype
  // per function (`(i32|ref)* -> i32|ref`).
  // The type section is a vector of rectypes. We emit ALL types inside ONE recursion
  // group (`0x4e <count>`), so every type index is mutually visible — a struct field
  // can reference the raw array type that lands AFTER it (a string field's `(ref
  // $aTypeIdx)`), which a non-grouped section's strictly-earlier-only index rule would
  // reject. (binaryen emits the same single rec group; functypes inside it are valid.)
  // So the section's rectype count is 1 (the rec group), and the rec group holds the
  // `n + typeOffset` actual type definitions.
  const typePayload: i32[] = []
  // Bind the writer at `typePayload` for the WHOLE type-section payload build, so the
  // raw framing bytes, `pushFieldStorage`, and `fbValtype` all stream to `curBuf ==
  // typePayload` identically. Restored just before `wSection` frames it (below).
  const tyPrev = wTarget(typePayload)
  // The print-import functypes are emitted as STANDALONE rectypes AFTER the rec group,
  // NOT inside it: a rec-group-member functype carries nominal rec-group identity that
  // a strict WasmGC host (wasmtime) refuses to match against a host-provided function,
  // so `__print_i32__` & co. fail to instantiate. A standalone functype matches
  // structurally. (V8 accepted either; this makes the emitted output portable.) The
  // print functype INDICES are unchanged — they still trail every rec-group type — so
  // the import-section references and the print-FREE goldens/fixpoint (nPrintTypes == 0,
  // section rectype count stays 1, rec-group count unchanged) are byte-identical.
  let nPrintTypes = 0
  if gImports > 0 {
    nPrintTypes = 2 // (i32)->() and ()->() for the print imports
  }
  if gNeedsI64Print {
    nPrintTypes = nPrintTypes + 1 // + (i64)->() for __print_i64__
  }
  if gNeedsF64Print {
    nPrintTypes = nPrintTypes + 1 // + (f64)->() for __print_f64__
  }
  if gNeedsF32Print {
    nPrintTypes = nPrintTypes + 1 // + (f32)->() for __print_f32__
  }
  wULEB(1 + nPrintTypes + memFn)   // rectypes: the rec group + the standalone print/(log) functypes
  wU8(78)                          // 0x4e rec group
  wULEB(n + typeOffset + hasStart) // types inside the rec group (print functypes excluded)
  if sDeclared {
    // One `0x5f` struct per declared type (declaration order = heap-type index),
    // each a struct of its fields in declaration order. A field is `0x7f` i32
    // (`sFieldTypes == 0`) or, for a string field (`== 3`), a non-null `(ref
    // $aTypeIdx)` (`0x64 <aTypeIdx>` — the raw `(array i32)` string rep); both mutable.
    let si = 0
    while si < sNames.length {
      wU8(95) // 0x5f struct
      let cnt = sFieldCount[si]
      wULEB(cnt)
      let fj = 0
      while fj < cnt {
        const fjCode = sFieldTypeAt(si, fj)
        let fjSlot = sFieldRefSlot(si, fj)
        // A NESTED-STRUCT field (code 15) passes its TARGET struct table index.
        if fjCode == 15 { fjSlot = structIndexByName(sFieldElemNameAt(si, fj)) }
        // A MAP-typed field (code 19) passes its value type's mv SLOT.
        if fjCode == 19 {
          fjSlot = mvSlotOfValNameFind(sFieldElemNameAt(si, fj))
        }
        pushFieldStorage(fjCode, fjSlot)
        wU8(1) // mutable
        fj = fj + 1
      }
      si = si + 1
    }
  }
  if uDeclared {
    // The `nv` variant structs FIRST (heap types 0..nv-1), each a struct of its i32
    // fields in declaration order (`0x5f` struct, count, then `0x7f 0x01` per field —
    // mutable i32). Then the union BOX `{ tag: i32, value: anyref }` at index `nv`:
    // `0x5f` struct, 2 fields — `0x7f 0x00` (i32, IMMUTABLE tag) and `0x6e 0x00`
    // (`anyref` abbreviation, IMMUTABLE value) — mirroring binaryen's `5f 02 7f 00
    // 6e 00` (verified against `toWasm.ts`'s `unionStruct`).
    let vi = 0
    while vi < uVariants.length {
      wU8(95) // 0x5f struct
      let cnt = uFieldCount[vi]
      wULEB(cnt)
      let fj = 0
      while fj < cnt {
        const vjCode = variantFieldTypeAt(vi, fj)
        let vjSlot = variantFieldRefSlot(vi, fj)
        // A NESTED-STRUCT variant field (code 15) passes its struct table index.
        if vjCode == 15 {
          vjSlot = structIndexByName(uFieldElemName[uFieldStart[vi] + fj])
        }
        // A MAP-typed variant field (code 19) passes its value type's mv SLOT.
        if vjCode == 19 {
          vjSlot = mvSlotOfValNameFind(uFieldElemName[uFieldStart[vi] + fj])
        }
        pushFieldStorage(vjCode, vjSlot)
        wU8(1) // mutable
        fj = fj + 1
      }
      vi = vi + 1
    }
    wU8(95)  // 0x5f struct (union box)
    wU8(2)   // 2 fields
    wU8(127) // field 0 tag: 0x7f i32
    wU8(0)   // immutable
    wU8(110) // field 1 value: 0x6e anyref
    wU8(0)   // immutable
    // The per-rep VALUE BOXES — each a one-field immutable struct `{ rep }` that
    // carries a scalar value-union payload behind the box's `anyref` slot
    // (mirroring `toWasm.ts`'s `valueBoxStruct`). Emitted in the SAME fixed order
    // `mAssignTypeIndices` interned them (i32, i64, f32, f64).
    if vbI32Used {
      wU8(95)  // 0x5f struct (i32 value box — boolean shares it)
      wU8(1)
      wU8(127) // 0x7f i32
      wU8(0)   // immutable
    }
    if vbI64Used {
      wU8(95)  // 0x5f struct (i64 value box)
      wU8(1)
      wU8(126) // 0x7e i64
      wU8(0)   // immutable
    }
    if vbF32Used {
      wU8(95)  // 0x5f struct (f32 value box)
      wU8(1)
      wU8(125) // 0x7d f32
      wU8(0)   // immutable
    }
    if vbF64Used {
      wU8(95)  // 0x5f struct (f64 value box)
      wU8(1)
      wU8(124) // 0x7c f64
      wU8(0)   // immutable
    }
  }
  if aUsed {
    wU8(94)  // 0x5e array
    wU8(127) // 0x7f i32 storagetype
    wU8(1)   // mutable
  }
  if lUsed {
    wU8(95)         // 0x5f struct
    wU8(3)          // 3 fields
    wU8(100)        // field 0 backing: 0x64 (ref ht) — non-null
    wSLEB(aTypeIdx) // ...to the raw array heap type
    wU8(1)          // mutable
    wU8(127)        // field 1 len: 0x7f i32
    wU8(1)          // mutable
    wU8(127)        // field 2 cap: 0x7f i32
    wU8(1)          // mutable
  }
  // One (backing, wrapper) PAIR per distinct ref-list element type, interleaved so each
  // wrapper immediately follows (and references) its own backing — the heap indices laid
  // out above. Each backing is `(array (mut (ref null $elem)))` over the slot's element
  // (struct heap idx / union box); each wrapper is `{ backing: (ref $back), len, cap }`.
  let rti = 0
  while rti < rlElemName.length {
    wU8(94)               // 0x5e array (ref backing)
    wU8(99)               // 0x63 (ref null ht) — nullable element ref
    wSLEB(rlElemHeap[rti])
    wU8(1)                // mutable
    wU8(95)               // 0x5f struct (ref-list wrapper)
    wU8(3)                // 3 fields
    wU8(100)              // field 0 backing: 0x64 (ref ht) — non-null
    wSLEB(rlBackIdx[rti]) // ...to THIS slot's ref backing
    wU8(1)                // mutable
    wU8(127)              // field 1 len: 0x7f i32
    wU8(1)                // mutable
    wU8(127)              // field 2 cap: 0x7f i32
    wU8(1)                // mutable
    rti = rti + 1
  }
  if slUsed || mUsed {
    // The STRING-REF list types, shared by the map's keys list and any `string[]`
    // field. (1) the backing array `(array (mut (ref null $aTypeIdx)))` — element is a
    // NULLABLE string ref (`0x63 <aTypeIdx>`) so `array.new_default` defaults spare
    // slots to null; an element read recovers the non-null string. (2) the list wrapper
    // `{ backing: (ref $mkArrIdx), len, cap }` — the same `{backing,len,cap}` triple as
    // the i32 list, over the string backing.
    wU8(94)  // 0x5e array (keys/string backing)
    wU8(99)  // 0x63 (ref null ht) — nullable string ref
    wSLEB(aTypeIdx)
    wU8(1)   // mutable
    wU8(95)  // 0x5f struct (string-list wrapper)
    wU8(3)   // 3 fields
    wU8(100) // field 0 backing: 0x64 (ref ht) — non-null
    wSLEB(mkArrIdx)
    wU8(1)   // mutable
    wU8(127) // field 1 len: 0x7f i32
    wU8(1)   // mutable
    wU8(127) // field 2 cap: 0x7f i32
    wU8(1)   // mutable
  }
  if mUsed {
    // The MAP struct `{ keys: (ref $mkListIdx), vals: (ref $lTypeIdx), live: (ref
    // $aTypeIdx), index: (ref $aTypeIdx), count, size, hashes: (ref $aTypeIdx) }` — two
    // non-null list refs (the keys string-list + the i32 vals list), the i32 `live`
    // tombstone array, the i32 `index` hash-slot array, the `count`/`size` counters, and
    // the i32 `hashes` per-entry FNV cache. FIELD ORDER + COUNT now match the host's
    // 7-field general-purpose rep EXACTLY (`compiler/builtins/maps.ts`, `MAP_HASHES = 6`):
    // the cached per-entry hash lets resize/compact RE-PLACE entries without re-hashing
    // keys and gates the (string) key comparison on a hash mismatch — justified for
    // large/long-key maps, not a compiler-symbol-table-narrow optimization. live is at
    // index 2, index/count/size at 3/4/5, hashes at 6.
    wU8(95)  // 0x5f struct (map)
    wU8(7)   // 7 fields (open-addressing hash map, host-aligned)
    wU8(100) // field 0 keys: 0x64 (ref $mkListIdx) — non-null
    wSLEB(mkListIdx)
    wU8(1)   // mutable
    wU8(100) // field 1 vals: 0x64 (ref $lTypeIdx) — non-null
    wSLEB(lTypeIdx)
    wU8(1)   // mutable
    wU8(100) // field 2 live: 0x64 (ref $aTypeIdx) — non-null i32 array
    wSLEB(aTypeIdx)
    wU8(1)   // mutable
    wU8(100) // field 3 index: 0x64 (ref $aTypeIdx) — non-null i32 array
    wSLEB(aTypeIdx)
    wU8(1)   // mutable
    wU8(127) // field 4 count: 0x7f i32
    wU8(1)   // mutable
    wU8(127) // field 5 size: 0x7f i32
    wU8(1)   // mutable
    wU8(100) // field 6 hashes: 0x64 (ref $aTypeIdx) — non-null i32 array
    wSLEB(aTypeIdx)
    wU8(1)   // mutable
  }
  if fa64Used {
    // The f64 array `(array (mut f64))` (Slice 4): `0x5e` array form, `0x7c` f64
    // storagetype, `0x01` mutable — the f64 analogue of the `5e 7f 01` i32 array.
    wU8(94)  // 0x5e array
    wU8(124) // 0x7c f64 storagetype
    wU8(1)   // mutable
    // The f64-list wrapper `{ backing: (ref $fa64TypeIdx), len: i32, cap: i32 }` — the
    // same `{backing,len,cap}` triple as the i32 list, over the f64 backing.
    wU8(95)            // 0x5f struct
    wU8(3)             // 3 fields
    wU8(100)           // field 0 backing: 0x64 (ref ht) — non-null
    wSLEB(fa64TypeIdx) // ...to the f64 array heap type
    wU8(1)             // mutable
    wU8(127)           // field 1 len: 0x7f i32
    wU8(1)             // mutable
    wU8(127)           // field 2 cap: 0x7f i32
    wU8(1)             // mutable
  }
  if ia64Used {
    // The i64 array `(array (mut i64))` — `0x5e` array form, `0x7e` i64 storagetype,
    // `0x01` mutable (the i64 sibling of the `5e 7c 01` f64 array). Emitted right after the
    // f64 pair, matching the type-index allocation order.
    wU8(94)  // 0x5e array
    wU8(126) // 0x7e i64 storagetype
    wU8(1)   // mutable
    // The i64-list wrapper `{ backing: (ref $ia64TypeIdx), len: i32, cap: i32 }`.
    wU8(95)            // 0x5f struct
    wU8(3)             // 3 fields
    wU8(100)           // field 0 backing: 0x64 (ref ht) — non-null
    wSLEB(ia64TypeIdx) // ...to the i64 array heap type
    wU8(1)             // mutable
    wU8(127)           // field 1 len: 0x7f i32
    wU8(1)             // mutable
    wU8(127)           // field 2 cap: 0x7f i32
    wU8(1)             // mutable
  }
  if fa32Used {
    // The f32 array `(array (mut f32))` — `0x5e` array form, `0x7d` f32 storagetype, `0x01`
    // mutable (the f32 sibling of the `5e 7c 01` f64 / `5e 7e 01` i64 arrays). Emitted right
    // after the i64 pair, matching the type-index allocation order.
    wU8(94)  // 0x5e array
    wU8(125) // 0x7d f32 storagetype
    wU8(1)   // mutable
    // The f32-list wrapper `{ backing: (ref $fa32TypeIdx), len: i32, cap: i32 }`.
    wU8(95)            // 0x5f struct
    wU8(3)             // 3 fields
    wU8(100)           // field 0 backing: 0x64 (ref ht) — non-null
    wSLEB(fa32TypeIdx) // ...to the f32 array heap type
    wU8(1)             // mutable
    wU8(127)           // field 1 len: 0x7f i32
    wU8(1)             // mutable
    wU8(127)           // field 2 cap: 0x7f i32
    wU8(1)             // mutable
  }
  if fnValUsed {
    // The closure fat-pointer struct `{ code: funcref, env: (ref null struct),
    // id: i32 }` (lambdas) — field 0 a GENERIC `funcref` (so ONE closure struct
    // serves every function arity), field 1 a nullable `structref` env (null when
    // non-capturing), field 2 the lifted function's wasm INDEX (`gImports + fe`) —
    // the identity token for `==` (funcrefs admit no `ref.eq`). All IMMUTABLE. At a
    // `call_ref` site the funcref is `ref.cast` to the concrete env-leading `$fnsig`
    // for that call's arity, then `call_ref`. The interned `$fnsig` functypes (one
    // per distinct value-call arity) follow.
    wU8(95)  // 0x5f struct
    wU8(3)   // 3 fields
    wU8(99)  // field 0 code: 0x63 (ref null) funcref
    wU8(112) // ...the abstract `func` heaptype (0x70 funcref)
    wU8(0)   // immutable
    wU8(99)  // field 1 env: 0x63 (ref null ht)
    wU8(107) // ...to the abstract `struct` heaptype (structref)
    wU8(0)   // immutable
    wU8(127) // field 2 id: 0x7f i32 — the function-identity token
    wU8(0)   // immutable
    // One env-leading `$fnsig` functype per distinct eligible SIGNATURE, in
    // `cloSigKeys` order: `(structref, params...) -> ret`, the param/result valtypes
    // read off the representative function (`cloSigRepFn` — every function sharing
    // the key has byte-identical kinds, by construction of the key).
    let sai = 0
    while sai < cloSigKeys.length {
      const repFe = cloSigRepFn[sai]
      const rep = P.nodes[fnStmts[repFe]]
      if rep is FuncDecl {
        const rparams = rep.fnParams
        wU8(96)                   // 0x60 func
        wULEB(rparams.length + 1) // env + declared params
        wU8(107)                  // param 0 env: structref (0x6b)
        let pj = 0
        while pj < rparams.length {
          fbValtype(vtKindOfParam(rparams[pj]), paramStructIdxOf(rparams[pj]))
          pj = pj + 1
        }
        // The RESULT must byte-match the rep function's own functype result so
        // the call-site `ref.cast` to this `$fnsig` accepts the callee funcref:
        // a VOID field-closure sig (`>v`) has 0 results; a STRUCT-returning one
        // (`>sN;`) yields the struct ref exactly as the function functype does.
        if fRetVoid[repFe] == 1 {
          wU8(0) // 0 results — the `>v` write-trap sig
        } else {
          wU8(1) // 1 result
          // The result valtype the rep function's OWN functype emits — scalar (i32/f64/
          // i64), string, an i32/string/f64 list, a union box, a nullable scalar/struct,
          // or a struct ref (`cloRetValKind`/`cloRetValSlot`, the shared mapping).
          fbValtype(cloRetValKind(repFe), cloRetValSlot(repFe))
        }
      }
      sai = sai + 1
    }
    // One env struct per CAPTURING lifted function (`fnEnvIdx[fe] >= 0`), in `fnStmts`
    // order — the order `mAssignTypeIndices` minted them. Each is a struct of one
    // IMMUTABLE i32 field per captured variable (capture order = field order). The
    // corpus captures are all i32 (and one struct-ref capture in `closure.vl`'s
    // `sumPoint`, handled by emitting the captured ref's valtype).
    let fe = 0
    while fe < fnStmts.length {
      if fnEnvIdxOf(fe) >= 0 {
        const caps = captureNamesOf(fe)
        wU8(95) // 0x5f struct
        wULEB(caps.length)
        let ci = 0
        while ci < caps.length {
          fbValtype(captureValKind(fe, caps[ci]), captureValStructIdx(fe, caps[ci]))
          wU8(0) // immutable
          ci = ci + 1
        }
      }
      fe = fe + 1
    }
  }
  // The ref-valued map structs (one per mv slot), in `mvMapTypeIdx` mint order —
  // the SAME 7-field shape as the mono map struct, with `vals` referencing this
  // slot's ref-list wrapper (the string-list pair for string values, the element's
  // `rlWrapIdx` for struct values). Keys/live/index/count/size/hashes are identical
  // across all map structs, so the shared probe/rehash/compact bytes apply as-is.
  let mvs = 0
  while mvs < mvValName.length {
    wU8(95)  // 0x5f struct (ref-valued map)
    wU8(7)   // 7 fields (host-aligned open-addressing hash map)
    wU8(100) // field 0 keys: 0x64 (ref $mkListIdx) — non-null
    wSLEB(mkListIdx)
    wU8(1)   // mutable
    wU8(100) // field 1 vals: 0x64 (ref <this slot's wrapper>)
    wSLEB(mvValsWrapOf(mvs))
    wU8(1)   // mutable
    wU8(100) // field 2 live: 0x64 (ref $aTypeIdx) — non-null i32 array
    wSLEB(aTypeIdx)
    wU8(1)   // mutable
    wU8(100) // field 3 index: 0x64 (ref $aTypeIdx) — non-null i32 array
    wSLEB(aTypeIdx)
    wU8(1)   // mutable
    wU8(127) // field 4 count: 0x7f i32
    wU8(1)   // mutable
    wU8(127) // field 5 size: 0x7f i32
    wU8(1)   // mutable
    wU8(100) // field 6 hashes: 0x64 (ref $aTypeIdx) — non-null i32 array
    wSLEB(aTypeIdx)
    wU8(1)   // mutable
    mvs = mvs + 1
  }
  // The functype param/result valtypes (`fbValtype`) stream to `curBuf == typePayload`,
  // interleaved identically with the surrounding raw framing bytes (the `wTarget` bind
  // covering this whole payload build was established above).
  let ti = 0
  while ti < n {
    const fn = P.nodes[fnStmts[ti]]
    if fn is FuncDecl {
      const params = fn.fnParams
      const nParams = params.length
      wU8(96) // 0x60 func
      // When a function value exists module-wide, EVERY function carries a hidden
      // leading `structref env` param (local 0). The declared params follow at 1..p.
      // A non-capturing function ignores its env; a capturing one `ref.cast`s + reads
      // it. Gated on `fnValUsed` so a no-lambda module's functypes are byte-identical.
      if fnValUsed {
        wULEB(nParams + 1) // param count incl. the env param
        wU8(107)           // env param: structref (0x6b)
      } else {
        wULEB(nParams) // param count
      }
      let pi = 0
      while pi < nParams {
        fbValtype(vtKindOfParam(params[pi]), paramStructIdxOf(params[pi]))
        pi = pi + 1
      }
      if fRetVoid[ti] == 1 {
        wU8(0) // 0 results — a VOID function (`()->()`)
      } else if fn.fnRet < 0 && fnReturnsClosure(ti) {
        // A function VALUE return (un-annotated; its tail is a function value) — kind 14.
        wU8(1)
        fbValtype(14, -1)
      } else if fn.fnRet < 0 {
        // UN-ANNOTATED return: the INFERRED kind (computeRetInference set the same
        // fRet* tables the annotation path fills). i32 when nothing matched.
        wU8(1) // 1 result
        // The inferred result KIND from the single shared mapping (`inferredRetKindCore`) — so
        // this site and `cloRetValKind` can't drift on a scalar/list/ref kind (the f32/f64/i64
        // inferred-return holes were each one site missing what the other had). The SLOT follows
        // the kind: struct index for a struct / nullable-struct ref (1 / 9), the element wrapper
        // for a ref list (5, via the recorded element name), the map shape for a map (6); every
        // other kind (string / scalar list / scalars) needs no per-function slot.
        const infKind = inferredRetKindCore(ti)
        let infSlot = -1
        if infKind == 1 || infKind == 9 { infSlot = fRetStructIdx[ti] }
        if infKind == 5 { infSlot = rlSlotByName(fRetRArrElem[ti]) }
        if infKind == 6 {
          const mrx = fnRetExprOf(fnStmts[ti])
          if mrx >= 0 { infSlot = mapRetExprShape(mrx, fnStmts[ti]) }
        }
        fbValtype(infKind, infSlot)
      } else {
        wU8(1) // 1 result
        // A `T[]` return is kind 5 — its second `fbValtype` arg is the ref-list TABLE
        // SLOT for the element type (`retStructIndex` is -1 for a ref array), so the
        // result valtype selects THIS function's element wrapper, not slot 0's.
        let retSlot = retStructIndex(fn.fnRet)
        if retRefArrFlag(fn.fnRet) == 1 { retSlot = tyAnnRefListSlot(fn.fnRet) }
        // A string-keyed MAP return's slot is the map SHAPE (mono ⇒ -1, or the value type's mv
        // slot for a `string`-valued map), so the result valtype selects THIS map's `$mapStruct`.
        if retMapFlag(fn.fnRet) == 1 { retSlot = mapAnnShape(fn.fnRet) }
        // A `: Cat` concrete-variant return is kind 8 — its `fbValtype` slot is the VARIANT
        // index (`uVarIdx + vi`), which `retStructIndex` (standalone structs only) misses.
        if retVariantFlag(fn.fnRet) == 1 {
          retSlot = variantIndexOf(tyNameOf(fn.fnRet))
        }
        fbValtype(vtKindOfType(fn.fnRet), retSlot)
      }
    }
    ti = ti + 1
  }
  // The synthetic start function's `()->()` functype (lands at index `typeOffset + n`,
  // AFTER every user functype — so no user type index shifts and the Phase-G assert is
  // untouched). `0x60` func, 0 params, 0 results.
  if hasStart == 1 {
    wU8(96) // 0x60 func
    wU8(0)  // 0 params
    wU8(0)  // 0 results
  }
  // The print-import functypes (only when a `print` exists): `(i32)->()` at index
  // `typeOffset + n + hasStart` (shared by __print_i32__/__print_bool__/__print_char__)
  // and `()->()` at +1 (__print_str_flush__). Emitted LAST and as STANDALONE rectypes
  // (the rec-group count above excludes them) so a strict-GC host can match the import
  // against a host function; no user/start functype index shifts.
  if gImports > 0 {
    wU8(96)  // 0x60 func
    wU8(1)   // 1 param
    wU8(127) // 0x7f i32
    wU8(0)   // 0 results
    wU8(96)  // 0x60 func
    wU8(0)   // 0 params
    wU8(0)   // 0 results
  }
  // The `(i64)->()` functype for `__print_i64__` (only when an i64 program prints),
  // standalone AFTER the two existing print functypes — its index is `ftVoid + 1`,
  // so no existing functype index shifts.
  if gNeedsI64Print {
    wU8(96)  // 0x60 func
    wU8(1)   // 1 param
    wU8(126) // 0x7e i64
    wU8(0)   // 0 results
  }
  // The `(f64)->()` functype for `__print_f64__`, standalone AFTER the i64 one (if any),
  // so no existing functype index shifts. (Slice 3.)
  if gNeedsF64Print {
    wU8(96)  // 0x60 func
    wU8(1)   // 1 param
    wU8(124) // 0x7c f64
    wU8(0)   // 0 results
  }
  // The `(f32)->()` functype for `__print_f32__`, standalone AFTER the i64/f64 ones (if
  // any), so no existing functype index shifts. (Slice 5.)
  if gNeedsF32Print {
    wU8(96)  // 0x60 func
    wU8(1)   // 1 param
    wU8(125) // 0x7d f32
    wU8(0)   // 0 results
  }
  // The `(i32, i32) -> ()` functype for the synthetic `__log__` decoder, standalone
  // LAST (after every print functype) so no existing functype index shifts. Its
  // index is `typeOffset + n + hasStart + nPrintTypes`.
  if memLogUsed {
    wU8(96)  // 0x60 func
    wU8(2)   // 2 params
    wU8(127) // 0x7f i32 (offset)
    wU8(127) // 0x7f i32 (length)
    wU8(0)   // 0 results
  }
  wTarget(tyPrev)
  wSection(1, typePayload)

  // Import section (id 2, between type and function): the 4-entry print family from
  // the host's `"imports"` module, occupying function indices 0..3 in this exact
  // order (the call lowering hardcodes them): __print_i32__, __print_bool__,
  // __print_char__ (all `(i32)->()`), __print_str_flush__ (`()->()`).
  if gImports > 0 {
    const ftI32 = typeOffset + n + hasStart
    const ftVoid = ftI32 + 1
    const ftI64 = ftVoid + 1
    // The `(f64)->()` functype index trails the i64 one when present, else the void one.
    let ftF64 = ftVoid + 1
    if gNeedsI64Print { ftF64 = ftI64 + 1 }
    // The `(f32)->()` functype index trails the f64 one when present, else wherever the
    // f64 index would be (the standalone functypes are emitted i64 → f64 → f32 in order).
    let ftF32 = ftF64
    if gNeedsF64Print { ftF32 = ftF64 + 1 }
    const importPayload: i32[] = []
    const imPrev = wTarget(importPayload)
    // 4 imports normally; +1 each for `__print_i64__` / `__print_f64__` / `__print_f32__`.
    let nImports = 4
    if gNeedsI64Print { nImports = nImports + 1 }
    if gNeedsF64Print { nImports = nImports + 1 }
    if gNeedsF32Print { nImports = nImports + 1 }
    wULEB(nImports)
    wName("imports")
    wName("__print_i32__")
    wU8(0) // import kind: func
    wULEB(ftI32)
    wName("imports")
    wName("__print_bool__")
    wU8(0)
    wULEB(ftI32)
    wName("imports")
    wName("__print_char__")
    wU8(0)
    wULEB(ftI32)
    wName("imports")
    wName("__print_str_flush__")
    wU8(0)
    wULEB(ftVoid)
    // `__print_i64__` LAST, at function index 4 (`fbCall(4)` in the print router), so
    // the existing imports keep indices 0..3 and only this entry is conditionally added.
    if gNeedsI64Print {
      wName("imports")
      wName("__print_i64__")
      wU8(0)
      wULEB(ftI64)
    }
    // `__print_f64__` LAST, at function index `gF64PrintIdx` (4 or 5). (Slice 3.)
    if gNeedsF64Print {
      wName("imports")
      wName("__print_f64__")
      wU8(0)
      wULEB(ftF64)
    }
    // `__print_f32__` LAST, at function index `gF32PrintIdx` (4/5/6). (Slice 5.)
    if gNeedsF32Print {
      wName("imports")
      wName("__print_f32__")
      wU8(0)
      wULEB(ftF32)
    }
    wTarget(imPrev)
    wSection(2, importPayload)
  }

  // Function section (id 3): N functions; func i uses functype `typeOffset + i`. The
  // synthetic start function (if any) is the LAST entry — function index `n` — using
  // the `()->()` functype at index `typeOffset + n`.
  const funcPayload: i32[] = []
  const fnPrev = wTarget(funcPayload)
  wULEB(n + hasStart + memFn)
  let fi = 0
  while fi < n {
    // A function whose env-leading signature matches an interned `$fnsig` is declared
    // with that `$fnsig` functype, so `ref.func` of it produces a value the call_ref
    // site's `ref.cast` to `$fnsig` accepts (its ACTUAL type IS `$fnsig`). Others keep
    // their own functype. Only when `fnValUsed`. (Lambdas.)
    if fnValUsed && fnSigIsClosure(fi) {
      wULEB(fnSigIdxOfFn(fi))
    } else {
      wULEB(typeOffset + fi) // functype index
    }
    fi = fi + 1
  }
  if hasStart == 1 {
    wULEB(typeOffset + n) // start fn functype index
  }
  if memLogUsed {
    // The synthetic `__log__` decoder uses the standalone `(i32,i32)->()` functype
    // emitted after the print functypes.
    wULEB(typeOffset + n + hasStart + nPrintTypes)
  }
  wTarget(fnPrev)
  wSection(3, funcPayload)

  // Memory section (id 5, between function (3) and global (6)): ONE module-DEFINED
  // memory, min 1 page (64 KiB — ample for the corpus' tag/value scratch region), no
  // max. The host IMPORTS `imports.memory` instead; the native runner provides no
  // memory import, so the module defines its own (same observable behavior). Emitted
  // only when a memory intrinsic is used — byte-identical output otherwise.
  if memUsed {
    const memPayload: i32[] = []
    const memPrev = wTarget(memPayload)
    wULEB(1) // 1 memory
    wU8(0)   // limits flag 0x00: min only
    wULEB(1) // min: 1 page
    wTarget(memPrev)
    wSection(5, memPayload)
  }

  // Global section (id 6): one mutable global per top-level `let`/`const`, in
  // declaration order (that order IS the global index `global.get`/`global.set` use).
  // Each entry is `<valtype> 0x01 <init constexpr> 0x0b`. The valtype mirrors `pushVT`'s
  // kind for the initializer (i32 / struct ref / list ref / string ref); the init reuses
  // the ordinary `emitExpr` literal lowering — `i32.const`, `struct.new`, and
  // `array.new_fixed` are all valid WasmGC constant expressions, so no start function is
  // needed for the literal initializers in scope. A non-constexpr init (a reference to a
  // local/param) fails loudly via `emitExpr(fnIx = -1)` (start-fn fallback deferred).
  const ng = globalStmts.length
  if ng > 0 {
    const globalPayload: i32[] = []
    // Bind the writer at `globalPayload` for the WHOLE global-section payload build, so
    // the count, each entry's valtype (`fbValtype`), mutability flag, and init constexpr
    // (`fb*` opcodes) all stream to `curBuf == globalPayload`. Restored before framing.
    const gPrev = wTarget(globalPayload)
    wULEB(ng)
    let gi = 0
    while gi < ng {
      const g = P.nodes[globalStmts[gi]]
      if g is LetDecl {
        if g.letInit < 0 {
          return emitFail("emitProgram: module global has no initializer")
        }
        if globalIsNonConst(globalStmts[gi]) {
          // A non-constexpr init (`curBuf = W.bytes` — a `global.get`+`struct.get`, a
          // reference to another global, a call, etc.) cannot be a WasmGC constant
          // expression. Declare the cell NULLABLE and zero-init it (`i32.const 0` for a
          // scalar, `ref.null` for a ref); the synthetic start function below runs the
          // real init via `global.set` before any other code, so reads never see the
          // zero. The cell stays mutable.
          const ck = globalCellKind(globalStmts[gi])
          // For a ref-array cell (kind 5) the second `fbValtype`/`fbRefNullForKind` arg is
          // the ref-list TABLE SLOT (`globalCellStructIdx` is -1 for a ref array), so the
          // cell valtype and its `ref.null` zero select THIS global's element wrapper.
          let cs = globalCellStructIdx(globalStmts[gi])
          if ck == 5 { cs = letAnnRefListSlot(globalStmts[gi]) }
          // A map cell (kind 6) passes its map SHAPE (mv slot / -1 mono / -2 set)
          // so the cell valtype + ref.null zero select THIS map's struct type.
          if ck == 6 { cs = letMapShapeOf(globalStmts[gi], -1) }
          fbValtypeNullable(ck, cs) // nullable valtype
          wU8(1)                    // 0x01 mutable
          if ck == 0 {
            fbI32Const(0) // i32 scalar zero
          } else if ck == 10 {
            fbI64Const(0, 0) // i64 scalar zero (Slice 1)
          } else if ck == 11 {
            fbF64Const("0.0") // f64 scalar zero (Slice 3)
          } else if ck == 13 {
            fbF32Const("0.0") // f32 scalar zero (Slice 5)
          } else {
            fbRefNullForKind(ck, cs) // ref.null zero
          }
          fbEnd() // 0x0b end of init expr
        } else {
          // The cell's valtype comes from the binding's ANNOTATION when present (so a
          // global agrees with a same-typed local/param/field on its struct table index),
          // falling back to the literal-init kind for an un-annotated global. The init
          // constexpr (`emitExpr`) lowers the literal — and must build the SAME wasm type:
          // `pendingStructIdx` seeds an `ObjLit` to the annotated struct (not the first
          // field-name match), and `pendingListKind`/`pendingListSlot` seed an empty `[]`
          // to the annotation's ref/string list (not the i32-list the bare literal infers),
          // exactly as the local-`let` path threads them.
          const gck = globalCellKind(globalStmts[gi])
          let gcs = globalCellStructIdx(globalStmts[gi])
          if gck == 1 { pendingStructIdx = gcs }
          // A NULLABLE-struct cell (kind 9) seeds the same struct context: a bare
          // `null` init lowers as `ref.null $S` (a valid constexpr), a struct
          // literal as that struct.
          if gck == 9 { pendingStructIdx = gcs }
          pendingListKind = letAnnRefListKind(globalStmts[gi])
          pendingListSlot = letAnnRefListSlot(globalStmts[gi])
          // A ref-array cell (kind 5) passes the ref-list TABLE SLOT as `fbValtype`'s
          // second arg (`globalCellStructIdx` is -1 for a ref array) so the cell valtype
          // selects THIS global's element wrapper, not slot 0's.
          if gck == 5 { gcs = letAnnRefListSlot(globalStmts[gi]) }
          // A map cell (kind 6): the map SHAPE picks the struct type; the
          // `pendingMapSlot` seed makes the `Map()` init constexpr build it.
          if gck == 6 {
            gcs = letMapShapeOf(globalStmts[gi], -1)
            pendingMapSlot = gcs
          }
          fbValtype(gck, gcs) // valtype
          wU8(1)              // 0x01 mutable
          // An `: i64` global lowers its literal init as `i64.const` (kind 10 / 0x7e);
          // an `: f32`/`: f64` global as `f32.const`/`f64.const` (kind 13 / 0x7d, 11 /
          // 0x7c) — re-encoding an integer literal directly so the init stays a valid
          // constexpr (no convert op). (Slice 5.)
          pendingI64 = (gck == 10)
          pendingF32 = (gck == 13)
          pendingF64 = (gck == 11)
          // A literal-union const global (`const D: K = "a"`) lowers its member init as `i32.const <id>`
          // (a valid constexpr).
          if letIsLitUnion(globalStmts[gi]) { pendingLitUnion = 1 }
          // A UNION cell (kind 4) with a CONST init boxes it in the constexpr —
          // `struct.new` / `array.new_fixed` / `i32.const` are all constant in
          // WasmGC, so `let w: string | i32 = "a"` builds the box inline.
          let gun2 = ""
          if gck == 4 { gun2 = letUnionNameOf(globalStmts[gi], -1) }
          if gun2 != "" {
            if emitUnionCoerce(globalPayload, gun2, g.letInit, -1) < 0 {
              return -1
            }
          } else {
            if emitExpr(globalPayload, g.letInit, -1) < 0 {
              return -1 // init constexpr
            }
          }
          pendingI64 = false
          pendingF32 = false
          pendingF64 = false
          pendingListKind = 0
          pendingListSlot = 0
          pendingLitUnion = 0
          fbEnd() // 0x0b end of init expr
        }
      }
      gi = gi + 1
    }
    wTarget(gPrev)
    wSection(6, globalPayload)
  }

  // Export section (id 7): export each function under its own name. A name is a
  // UTF-8 byte vec; for an ASCII identifier each `name[i]` char code IS its byte.
  // RE-EXPORTS (`export { name } from "dep"`) add ALIAS entries: the bare public name
  // mapped to the (merged, mangled) target function's index, so a module graph can
  // present a STABLE wasm ABI (`compileSrc`, not `compileSrc$mN`). Resolved entries
  // are gathered first so the section count is exact.
  const reExpEi: i32[] = [] // the target function's `fnStmts` position, parallel to its public name
  const reExpNm: string[] = []
  let rxi = 0
  while rxi < reExpName.length {
    let tj = 0
    let hit = -1
    while tj < fnStmts.length && hit < 0 {
      const tfn = P.nodes[fnStmts[tj]]
      if tfn is FuncDecl {
        if tfn.fnName == reExpTarget[rxi] { hit = tj }
      }
      tj = tj + 1
    }
    if hit >= 0 {
      reExpNm.push(reExpName[rxi])
      reExpEi.push(hit)
    }
    rxi = rxi + 1
  }
  const exportPayload: i32[] = []
  const exPrev = wTarget(exportPayload)
  wULEB(n + reExpNm.length)
  // Export names must be UNIQUE. Lifted nested functions keep their source name, so two
  // makers each declaring a nested `add` would both export `add` (a duplicate-name
  // validation error). Disambiguate a repeat by suffixing its `fnStmts` position
  // (`add#3`) — the FIRST occurrence keeps the bare name. No golden program has a
  // repeated function name, so their export bytes are unchanged.
  const usedExportNames: string[] = []
  let ei = 0
  while ei < n {
    const fn = P.nodes[fnStmts[ei]]
    if fn is FuncDecl {
      let exName = fn.fnName
      if capHas(usedExportNames, exName) {
        exName = exName + "#" + i32ToStr(ei)
      }
      usedExportNames.push(exName)
      wName(exName)
      wU8(0)               // export kind: func
      wULEB(gImports + ei) // func index (imports occupy 0..gImports-1)
    }
    ei = ei + 1
  }
  // The re-export ALIAS entries — a bare public name pointing at the target's func index.
  let rei = 0
  while rei < reExpNm.length {
    wName(reExpNm[rei])
    wU8(0) // export kind: func
    wULEB(gImports + reExpEi[rei])
    rei = rei + 1
  }
  wTarget(exPrev)
  wSection(7, exportPayload)

  // Start section (id 8): names the function the runtime invokes once at instantiation,
  // before any export is callable — here the synthetic start fn that runs the non-const
  // global initializers. Per the section-id order it sits AFTER the export section (7)
  // and BEFORE the code section (10). Omitted entirely when no non-const global exists
  // (so EVERY golden, which has only const globals, emits no start section).
  if hasStart == 1 {
    const startPayload: i32[] = []
    const stPrev = wTarget(startPayload)
    wULEB(startFnIdx)
    wTarget(stPrev)
    wSection(8, startPayload)
  }

  // Element section (id 9): a single DECLARATIVE elem segment declaring every user
  // function as `ref.func`-referenceable (lambdas). `ref.func` requires its target be
  // forward-declared; with no table we use a declarative segment (flags 0x03, elemkind
  // 0x00 funcref, then the func-index vec). Emitted ONLY when a function value exists
  // (`fnValUsed`), so a no-lambda module emits no section 9 and stays byte-identical —
  // mirroring the start-section conditional. Sits AFTER start (8), BEFORE code (10).
  if fnValUsed {
    const elemPayload: i32[] = []
    const elPrev = wTarget(elemPayload)
    wULEB(1) // 1 element segment
    wU8(3)   // flags 0x03: declarative, elemkind + func-index vec
    wU8(0)   // elemkind 0x00 — funcref
    wULEB(n) // count of declared funcs
    let di = 0
    while di < n {
      wULEB(gImports + di) // func index (imports occupy 0..gImports-1)
      di = di + 1
    }
    wTarget(elPrev)
    wSection(9, elemPayload)
  }

  // Code section (id 10): one size-prefixed body per function, in index order, then
  // (if any) the synthetic start function's body LAST.
  const codePayload: i32[] = []
  const codePrev = wTarget(codePayload)
  wULEB(n + hasStart + memFn)
  wTarget(codePrev)
  let ci = 0
  while ci < n {
    if emitFuncCode(codePayload, fnStmts[ci]) < 0 { return -1 }
    ci = ci + 1
  }
  if hasStart == 1 {
    if emitStartFnCode(codePayload) < 0 { return -1 }
  }
  if memLogUsed {
    if emitMemLogFnCode(codePayload) < 0 { return -1 }
  }
  wSection(10, codePayload)

  // Custom "name" section LAST (after the code section, where it conventionally
  // lives). A no-op unless `gEmitNames` is set, so the default emit path is
  // byte-identical to every golden.
  emitNameSection(n)
  0
}

// Walk the arena from `rootIx` and emit a module for ALL top-level functions of the
// form:
//
//   function NAME(p0: i32, …): i32 { <stmt>* }
//
// where each <stmt> is a `let`/`const` i32 local declaration, an assignment
// `x = <expr>`, a `return <expr>`, or an `if <cond> { <stmt>* } [else …]`, and
// <expr> is built from integer literals, parameter / local references, calls to any
// top-level function (recursion included), the `+`/`-`/`*` arithmetic operators, the
// six signed i32 comparisons, and unary negation. Declared locals get wasm slots
// AFTER the params (see `buildLocals`). Each function is exported under its own NAME.
// Returns 0 on success; on any unsupported shape it calls `emitFail` (leaving
// `emitErr` set and the buffer empty) and returns -1.
//
// Node shapes read (all from `compiler/ast.vl`):
//   Program  { progStmts: i32[] }   — top-level statements; the functions.
//   FuncDecl { fnName, fnParams: i32[], fnRet: i32, fnBody: i32 }
//   Param    { parName: string, parType: i32 }
//   Block    { blkStmts: i32[] }    — a function body / branch.
//   LetDecl  { letName, letType, letInit }   — a local declaration.
//   RetStmt  { retArg: i32 } ; IfStmt { ifCond, ifThen, ifElse }
//   BinExpr  { binOp, binLeft, binRight }    — `binOp == "="` is an assignment.

// ── struct-type collection + struct-typedness of expressions ─────────────────
// `isSName` tells whether a type-name refers to the declared struct; `collectS`
// records the program's single struct type; the rest decide whether a given
// expression / param / local PRODUCES the struct (a `(ref $0)`) rather than an i32.

// True if the type-name `name` refers to one of the declared struct types.
function isSName(name: string) { structIndexByName(name) >= 0 }

// The struct-table index for a ref-list element NAME, stripping a `| null` niche suffix first
// (a NULLABLE-struct array's slot keys on the full `"P | null"`, but the struct it stores/reads
// is the bare `P`). For a plain `"P"` this is just `structIndexByName`.
function structIdxOfElemName(name: string) {
  let n = name
  const nn = nullablePartOf(name)
  if nn != "" { n = nn }
  structIndexByName(n)
}

// The non-null STRUCT name of a NULLABLE-struct array element (`(P | null)[]` → "P"), or "".
// `P | null` is a nullable-struct NICHE (a `(ref null $P)` slot), NOT a union box — so it is a
// struct ref-list whose elements legitimately hold null (its backing is already nullable). The
// SLOT keys on the full `"P | null"` so a read can tell it from a non-null `P[]` (different slot)
// and skip the `ref.as_non_null` recover. A value-niche element (`(i32 | null)[]`) is excluded —
// its non-null part is not a declared struct, so it stays the value-union-box path.
function nullStructArrElem(name: string) {
  const elem = parenUnionArrElemName(name)
  if elem == "" { return "" }
  const nn = nullablePartOf(elem)
  if nn == "" { return "" }
  if structIndexByName(nn) >= 0 { return nn }
  ""
}

// The inner-list element of a `(<list> | null)[]` nullable-LIST array — `(i32[] | null)[]` → `i32[]`,
// else "". Such an array reuses the `i32[][]` (kind 4) rep: a ref list over a `(ref null $lTypeIdx)`
// backing (already nullable, so the `| null` element rides for free). It differs from `i32[][]` ONLY by
// its slot key keeping the `| null` (so the index READ stays nullable — no `ref.as_non_null` — for the
// `e != null` narrow). The inner array reuses its NON-nullable rep RECURSIVELY (kind 4 i32-list inner, or
// kind 9 a nested ref-array inner — `(i32[][]|null)[]`, `({f:i32}[]|null)[]`, …); the structured
// `rlElemNullable` bit drives the nullable read-skip + null-element generically over the inner kind.
function nullArrayArrElem(name: string) {
  const elem = parenUnionArrElemName(name)
  if elem == "" { return "" }
  const nn = nullablePartOf(elem)
  if nn == "" { return "" }
  if !nameIsArray(nn) { return "" }
  const ik = refArrElemKind(nn + "[]")
  if ik == 4 || ik == 9 { return nn }
  ""
}

// True if the array type-name `name` is a REF-element list — `S[]` over a declared
// struct, `N[]` over the declared union alias (the box-ref element), or `{[string]:i32}[]`
// (a map-struct element). Either lowers to the `{ backing: (ref $raTypeIdx), len, cap }`
// wrapper over a `(ref null $elem)` backing (G7-ref). A non-`[]` name or an `i32[]` is
// NOT a ref array. The element name is recovered by checking each declared struct/union
// name + `"[]"` (a `string + string` concat; a `string + i32` would be a type error).
function nameIsRefArray(name: string) {
  // A `(P | null)[]` nullable-struct array is a (struct) ref list — checked before the
  // value/struct-union element test so its niche element is not mis-read as a union box.
  if nullStructArrElem(name) != "" { return true }
  // A `(i32[] | null)[]` nullable-LIST array is a ref list (kind-4 i32[][] rep) — likewise checked
  // before the union test so `i32[] | null` is not mis-read as a value union.
  if nullArrayArrElem(name) != "" { return true }
  // A NESTED `i32[][]` is a ref list whose elements are the i32-list wrapper
  // (element kind 4) — the existing ref-pair machinery serves it; only the
  // element heap type differs (`lTypeIdx`).
  if name == "i32[][]" { return true }
  // A nested NON-i32 scalar / string 2D array (`i64[][]` / `f64[][]` / `string[][]`): the
  // element is the inner list's WRAPPER (kinds 8 / 7 / 6 — the same the LIST-valued map vals
  // ref-list uses). `refArrElemKind` already maps these names; recognize them here so a direct
  // 2D array (not only a map value) is a supported ref list.
  if (
    name == "i64[][]" ||
    name == "f64[][]" ||
    name == "f32[][]" ||
    name == "string[][]"
  ) {
    return true
  }
  // A NESTED REF array (`S[][]`, `(C|D)[][]`, `((i32)=>i32)[][]`, `S[][][]`, …): the element is
  // ITSELF a ref array. Recurses to the leaf (a struct / union / closure / scalar-2D ref array),
  // so any DEPTH and any ref leaf falls out — the outer element's heap is the inner list's
  // wrapper (`refArrElemKind` → 9), resolved through the recursively-interned inner slot.
  if nameIsArray(name) && nameIsRefArray(refArrElemName(name)) { return true }
  // A `(string|i32)[]` annotation — a VALUE-union element list. The element
  // slots hold the same `{tag, value}` boxes a bare union binding does (the
  // host stores the coerced union value), so it is a kind-2 ref list.
  if parenUnionArrElemName(name) != "" { return true }
  if nameIsMapArray(name) { return true }
  // An ARRAY OF FUNCTIONS (`((i32) => i32)[]`) — a closure-element ref list (kind 5).
  if nameIsClosureArray(name) { return true }
  // Otherwise a `<Struct>[]` / `<Union>[]`: strip the trailing `[]` ONCE and match the bare
  // element NAME against the struct/union tables. (The old form compared `name` to
  // `sNames[i] + "[]"` — a fresh string allocation PER struct PER call; on a struct-heavy
  // program this `O(structs)` garbage dominated emit time + GC. The strip-once form does the
  // same match with no per-iteration allocation.)
  const n = name.length
  if n >= 3 && name[n - 2] == '[' && name[n - 1] == ']' {
    const base = name.slice(0, n - 2)
    if structIndexByName(base) >= 0 { return true }
    // A `Cat[]` over a concrete union VARIANT — a ref list of bare variant structs.
    if variantIndexOf(base) >= 0 { return true }
    let u = 0
    while u < unNames.length {
      if base == unNames[u] { return true }
      u = u + 1
    }
  }
  false
}

// The ref-element kind for an array type-name (assumes `nameIsRefArray(name)`):
// `1` = a struct element, `2` = a union-box element (`uBoxIdx`), `3` = a map-struct
// element (`mStructIdx`, the scope-chain `{[string]:i32}[]`).
// Intern the ref-list slot whose ELEMENT type is `elemName`, recursively interning a nested
// inner list's element slot FIRST — so the inner wrapper lands at a LOWER type index and the
// outer element heap (`rlElemHeap`, kind 9) resolves to it. The DRY core that makes arbitrary
// `X[]…[]` nesting of any ref leaf (struct / union / closure) fall out: interning is inner-first,
// recursively, bottoming out at the leaf array (whose element is not itself a ref array, k != 9).
function ensureRefElem(elemName: string) {
  if elemName == "" { return -1 }
  // Re-form the element's ARRAY name to read its kind. A nullable-LIST element (`i32[] | null`) needs its
  // grouping parens back (`(elem)[]`) — without them `refArrElemKind` mis-reads `i32[] | null[]` as a
  // plain struct element (kind 1) instead of the kind-4 nullable-i32-list element. Scoped to a nullable
  // element whose non-null part is an ARRAY, so value-union (`i32 | null`) / nullable-struct (`P | null`)
  // elements keep their existing (munged-name) kind and are unaffected.
  let arrName = elemName + "[]"
  const enp = nullablePartOf(elemName)
  if enp != "" && nameIsArray(enp) { arrName = "(" + elemName + ")[]" }
  const k = refArrElemKind(arrName)
  if k == 9 { ensureRefElem(refArrElemName(elemName)) }
  // Force the leaf list-type wrapper `Used` flags for a SCALAR inner-list element, so its
  // singleton wrapper (`lTypeIdx` / `mkListIdx` / `fl64TypeIdx` / `il64TypeIdx`) is allocated. A
  // ref inner list (k 9) forces these in the recursion above; a struct / union / closure element
  // (k 1/2/5) needs none. Lets BOTH the array path and the map-value path share this one helper.
  if k == 4 {
    lUsed = true
    aUsed = true
  } else if k == 6 {
    slUsed = true
    aUsed = true
  } else if k == 7 {
    fa64Used = true
  } else if k == 8 {
    ia64Used = true
  } else if k == 10 {
    fa32Used = true
  }
  rlInternName(elemName, k)
}

function refArrElemKind(name: string) {
  if name == "i32[][]" { return 4 }
  // Nested lists of a NON-i32 scalar/string element — the element is that inner list's
  // WRAPPER (kinds 6/7/8 → `mkListIdx` / `fl64TypeIdx` / `il64TypeIdx`). Used for a
  // string[]/f64[]/i64[]-VALUED map's vals ref-list (the value analogue of `i32[][]` kind 4).
  if name == "string[][]" { return 6 }
  if name == "f64[][]" { return 7 }
  if name == "i64[][]" { return 8 }
  if name == "f32[][]" {
    return 10 // f32 inner list (element is the `$fl32TypeIdx` wrapper)
  }
  // A NESTED REF array (`S[][]`, `(C|D)[][]`, `((i32)=>i32)[][]`, `S[][][]`, …): the element is
  // itself a ref array, stored as the inner list's WRAPPER — kind 9. Recurses to any depth via
  // the interned inner slots. The scalar-leaf 2D names above are NOT ref arrays at the inner
  // level (a scalar inner list is a singleton wrapper), so they keep their explicit kinds.
  if nameIsArray(name) && nameIsRefArray(refArrElemName(name)) { return 9 }
  if nameIsMapArray(name) { return 3 }
  // A `(P | null)[]` nullable-struct array is a STRUCT ref list (kind 1) — its element is a
  // `(ref null $P)` niche, not a union box. Checked before the value-union test below.
  if nullStructArrElem(name) != "" { return 1 }
  // A `(i32[] | null)[]` nullable-LIST array is the i32[][] rep (kind 4) — its element is a
  // `(ref null $lTypeIdx)` i32-list niche, not a union box. Checked before the value-union test.
  if nullArrayArrElem(name) != "" {
    return refArrElemKind(nullArrayArrElem(name) + "[]")
  }
  // A `(string|i32)[]` value-union element list is a union-box list (kind 2).
  if parenUnionArrElemName(name) != "" { return 2 }
  // An `((i32) => i32)[]` array of functions is a closure-element list (kind 5).
  if nameIsClosureArray(name) { return 5 }
  // A `<Union>[]` element list is kind 2 — strip the `[]` once and match the bare union name
  // (no per-iteration `+ "[]"` concat). Anything else (a struct array) is kind 1.
  const n = name.length
  if n >= 3 && name[n - 2] == '[' && name[n - 1] == ']' {
    const base = name.slice(0, n - 2)
    let u = 0
    while u < unNames.length {
      if base == unNames[u] { return 2 }
      u = u + 1
    }
  }
  1
}

// The per-field wasm-type code for a struct / union-variant field whose type node is
// `tyIx` (a `TypeRef`). Mirrors the inline classifier `collectS`/`collectVariantFields`
// used to use, EXTENDED with array-typed fields (gap #5): a field of array type stores a
// REF to a list wrapper, so its code records WHICH wrapper:
//   `0` = i32 / boolean   (`0x7f`)
//   `3` = string          (`(ref $aTypeIdx)`)
//   `4` = i32 list  `i32[]`         (`(ref $lTypeIdx)`)
//   `5` = ref list  `T[]` / `N[]`   (`(ref $rlTypeIdx)`)
// An `X[]` whose element `X` is not `i32` is a REF list (`5`) — its element is a struct
// or the union box; the element-kind (`rElemKind`) is fixed globally by `collectA`, so it
// is not stored per-field. An unsupported field type yields `-1` (caller fails loudly).
// (`string[]` is NOT yet supported — it would need a string-ref list distinct from the
// struct/union ref backing — so it falls through to `-1`.)
// Force the backing+wrapper type pair for a SCALAR-LIST field code (25 = f64[], 26 = i64[], 27 = f32[]),
// so the wrapper heap type exists whenever a struct/inline-shape field uses it — the field analogue of a
// ref-list field forcing `rlUsed`. A scalar-list LOCAL forces this via its annotation scan; a field-only
// program must force it here (the field's own TypeRef scan is not guaranteed to set the flag).
function forceScalarListField(code: i32) {
  if code == 25 { fa64Used = true }
  if code == 26 { ia64Used = true }
  if code == 27 { fa32Used = true }
  0
}

// True if `name` is a `<ref-list> | null` — a NULLABLE ref-list field/local (`S[] | null`, `(i32|null)[] |
// null`, `{g:i32}[] | null`), the ref-list analogue of `nameIsNulI32List`. Its non-null part is a ref array
// (a struct / union / nested-array element list). NOT an `i32[] | null` (that is code 18, kind 15).
function nameIsNulRefList(name: string) {
  const np = nullablePartOf(name)
  if np == "" { return false }
  return nameIsRefArray(np)
}

function fieldTypeCode(tyIx: i32) {
  if tyIx < 0 { return -1 }
  // A NULLABLE-function field (`op: ((i32) => i32) | null`) stores a NULLABLE closure
  // fat-pointer (code 22) — the field analogue of a kind-19 local. Checked BEFORE the
  // bare-function test (and before `tyIsFuncType`, exactly as `vtKindOfType` orders it):
  // `((i32) => i32) | null` is a nullable function (arrow nested under a top-level `|`),
  // whereas `(i32) => i32 | null` is a function RETURNING a nullable (handled elsewhere).
  if nulCloFlag(tyIx) == 1 { return 22 }
  // A function-typed field (`op: (i32) => i32`) stores the closure fat-pointer (code 14),
  // the field analogue of a function-valued local. Checked first (a `=>` name).
  if tyIsFuncType(tyIx) { return 14 }
  const ty = P.nodes[tyIx]
  if ty is TypeRef {
    if ty.tyName == "i32" { return 0 }
    if ty.tyName == "boolean" { return 0 }
    // An f64 field (`x: f64`) stores a raw f64 valtype slot — code 17. An i64 / f32 field is
    // the same idea in the other scalar valtypes — codes 23 / 24 (0x7e / 0x7d storage).
    if ty.tyName == "f64" { return 17 }
    if ty.tyName == "i64" { return 23 }
    if ty.tyName == "f32" { return 24 }
    if nameIsString(ty.tyName) { return 3 }
    if nameIsArray(ty.tyName) {
      if nameIsI32Array(ty.tyName) { return 4 }
      // A `string[]` field is a string-ref list (code `6`) — it reuses the map keys
      // list types (`mkListIdx`/`mkArrIdx`). Any OTHER `X[]` is a struct/union ref list.
      if nameIsStringArray(ty.tyName) { return 6 }
      // A SCALAR-element list field stores its scalar-list wrapper (code 25/26/27), NOT a ref-list
      // wrapper (code 5 is for struct/union/closure elements only — returning 5 here emitted the wrong
      // heap type, the invalid-wasm hole).
      if nameIsF64Array(ty.tyName) { return 25 }
      if nameIsI64Array(ty.tyName) { return 26 }
      if nameIsF32Array(ty.tyName) { return 27 }
      return 5
    }
    // A NULLABLE i32-list field (`rest: i32[] | null`) stores a NULLABLE ref to
    // the same wrapper as code 4 — code 18 (`0x63 lTypeIdx`). Checked before the
    // value-union test (`i32[]` is not a value atom, so 16 never claims it).
    if nameIsNulI32List(ty.tyName) { return 18 }
    if nameIsNulRefList(ty.tyName) { return 28 }
    // A MAP-typed field (`children: {[string]: Tree}`) stores a non-null ref to
    // its value-type's map struct — code 19. The mv SLOT is interned by
    // `collectA`'s arena TypeRef scan (this same annotation node), so emission
    // re-finds it by the value name (`fieldRefElemName`). A NULLABLE map field
    // (`{[…]}|null`) stays unsupported (falls through to -1).
    if nameIsMap(ty.tyName) { return 19 }
    // A `string | null` niche field — `(ref null $aTypeIdx)`, code 20. Checked before
    // the value-union test (it is NOT a value union — a single ref + null is a niche).
    if nameIsNulString(ty.tyName) { return 20 }
    // A `boolean | null` niche field — i32 sentinel, code 21.
    if nameIsNulBool(ty.tyName) { return 21 }
    // A BOX-union field — a VALUE union (`v: i32 | null`, `y: string | i32`) OR a
    // registered STRUCT / HETEROGENEOUS union (`v: A | B`, `v: A | i32`) — stores the
    // shared union BOX ref (code 16). Checked BEFORE the nullable-struct strip, exactly
    // like `nameFieldCode` (the annotation-shape path), so a declared `type Opt = { v:
    // i32 | null }` carries the same rep as the inline `{v:i32|null}` annotation.
    if isValueUnionName(ty.tyName) { return 16 }
    if isUName(ty.tyName) { return 16 }
    // A field naming ANOTHER STRUCT (`inner: Inner`) or a NULLABLE struct
    // (`next: Node|null`) stores a `(ref null $S)` — code 15. Resolved via the
    // DECLARATION scan (not the incrementally-built struct table) so a forward /
    // mutually-recursive reference ties in the shared rec group.
    let base = ty.tyName
    const nb = nullablePartOf(base)
    if nb != "" { base = nb }
    if nameIsStructDecl(base) { return 15 }
    // An INLINE-SHAPE struct field (`inner: {x:i32}`) — not a declared name, so resolve it
    // STRUCTURALLY to its interned struct (pre-interned by `collectNestedFieldShapes`). The
    // structural→nominal bridge applied at field classification, the dual of a nominal `inner: Inner`.
    // GUARD against an array base (`{x:i32}[]` of a `{x:i32}[] | null` field): `structIndexOfTypeName`
    // ignores the trailing `[]` and would match the element shape, mis-coding a NULLABLE STRUCT-LIST
    // field as a nullable struct (code 15) — invalid wasm. A nominal `Node[] | null` already falls to
    // -1 (clean reject); this brings the inline form to par until nullable ref-list fields are repped.
    if !nameIsArray(base) && structIndexOfTypeName(base) >= 0 { return 15 }
    return -1
  }
  -1
}

// True if `name` is a STANDALONE struct `type` declaration's name — independent of
// the (incrementally-built) struct table, so a struct field may reference a LATER
// struct declaration. Union aliases and union variants are excluded (their fields
// ride the variant tables, not the struct table).
function nameIsStructDecl(name: string) {
  if name == "" { return false }
  if isUName(name) { return false }
  if variantIndexOf(name) >= 0 { return false }
  let i = 0
  while i < P.nodes.length {
    const nd = P.nodes[i]
    if nd is TypeDecl {
      if nd.tdName == name { return true }
    }
    i = i + 1
  }
  false
}

// The ref-list ELEMENT type-NAME of a field whose type node is `tyIx` — the table key
// into `rlElemName` — when `fieldTypeCode(tyIx) == 5` (a struct/union ref list); "" for
// any other field. Strips the trailing `"[]"` directly so it does NOT depend on `sNames`
// being fully populated (collectS builds it incrementally; a field may reference a
// later-declared struct). Used to fill `sFieldElemName`/`uFieldElemName`.
function fieldRefElemName(tyIx: i32) {
  let code = fieldTypeCode(tyIx)
  // A VALUE-UNION field (code 16) records its union NAME — the key into the
  // atom-set tables (and `registerValueUnionName` interns its box reps at the
  // collection site).
  if code == 16 {
    const ty16 = P.nodes[tyIx]
    if ty16 is TypeRef { return ty16.tyName }
    return ""
  }
  // A NESTED-STRUCT field (code 15) records its TARGET struct name (the `S` of
  // `inner: S` / `next: S|null`) — resolved to a struct table index at use sites.
  if code == 15 {
    const ty15 = P.nodes[tyIx]
    if ty15 is TypeRef {
      let base = nullablePartOf(ty15.tyName)
      if base == "" { base = ty15.tyName }
      // An INLINE-SHAPE field (`inner: {x:i32}`) records the NOMINAL name of its interned struct
      // (`structIndexOfTypeName` resolves the shape — to its own `{x:i32}` key, or a matching declared
      // struct), so every nominal-keyed use site (`structIndexByName`) resolves it like `inner: Inner`.
      const idx = structIndexOfTypeName(base)
      if idx >= 0 { return sNames[idx] }
      return base
    }
    return ""
  }
  // A MAP-typed field (code 19) records its VALUE type-name (`Tree` of
  // `{[string]: Tree}`) — the mv-slot interning key (`mvValName`).
  if code == 19 {
    const ty19 = P.nodes[tyIx]
    if ty19 is TypeRef { return mapValNameOf(ty19.tyName) }
    return ""
  }
  // A NULLABLE REF-LIST field (code 28, `S[] | null`): its element is the ref-array element of the
  // non-null part (`refArrElemName(nullablePartOf(name))` — `S[]|null` -> `S`, `(i32|null)[]|null` ->
  // `i32|null`), so `sFieldRefSlot` (`rlSlotByName`) finds the element's interned slot.
  if code == 28 {
    const ty28 = P.nodes[tyIx]
    if ty28 is TypeRef { return refArrElemName(nullablePartOf(ty28.tyName)) }
    return ""
  }
  if code != 5 { return "" }
  const ty = P.nodes[tyIx]
  if ty is TypeRef { return ty.tyName.slice(0, ty.tyName.length - 2) }
  ""
}

// Validate an array type-name as a supported element type: `i32[]` (the value list),
// or a REF list `S[]`/`N[]` over the declared struct / union alias (G7-ref). A nested
// `i32[][]` or an array of an unknown / unsupported element fails loudly. Returns 0 on
// success, or -1 (via `emitFail`).
function checkArrName(name: string) {
  if nameIsI32Array(name) { return 0 }
  if nameIsRefArray(name) { return 0 }
  emitFail(
    "emitProgram: only i32[] arrays and struct/union element arrays are supported",
  )
}

// True when `name` is `T[]` for some declared FuncDecl type parameter `T`.
function genTyParamArr(name: string) {
  if genTyParamNames.length == 0 { return false }
  let n = name.length
  if n < 2 { return false }
  if name[n - 2] != '[' { return false }
  if name[n - 1] != ']' { return false }
  let base = name.slice(0, n - 2)
  let i = 0
  while i < genTyParamNames.length {
    if genTyParamNames[i] == base { return true }
    i = i + 1
  }
  false
}

// stable: it fixes whether the program needs the array heap type BEFORE the type
// section is emitted. Each `[]` annotation is validated as `i32[]` here, so a non-i32
// element array (e.g. `string[]`) fails loudly up-front. Returns 0, or -1 (via
// `emitFail`).
function collectA(stmts: i32[]) {
  // Gather every FuncDecl TYPE-PARAMETER name first (a separate cheap pass — a
  // `T[]` annotation node precedes its FuncDecl in the arena, so the main walk
  // below would see it too early). Consulted by `genTyParamArr` to skip a
  // generic original's `T[]` annotation. Empty for any program without `<T>`
  // declarations — zero behavior change.
  genTyParamNames = []
  let gtp = 0
  while gtp < P.nodes.length {
    const gnd = P.nodes[gtp]
    if gnd is FuncDecl {
      const gtps = gnd.fnTyParams
      let gj = 0
      while gj < gtps.length {
        genTyParamNames.push(gtps[gj])
        gj = gj + 1
      }
    }
    gtp = gtp + 1
  }
  aUsed = false
  lUsed = false
  raUsed = false
  rlUsed = false
  rElemKind = 0
  rlElemName = []
  rlElemHeap = []
  rlBackIdx = []
  rlWrapIdx = []
  rlElemKindTbl = []
  rlElemNullable = []
  pendingNulRefHeap = -1
  mUsed = false
  slUsed = false
  fa64Used = false
  mvValName = []
  mvValKind = []
  mvValStructIdx = []
  mvRlSlot = []
  mvMapTypeIdx = []
  let i = 0
  while i < P.nodes.length {
    const nd = P.nodes[i]
    if nd is ArrayLit {
      // A `[…]` literal is a growable list. A literal with struct/union-variant
      // elements is a REF list (its backing is `(ref null $elem)`); an i32-element
      // or EMPTY literal contributes the i32 list (an empty `[]` over a REF type is
      // typed by its binding's annotation, collected via the TypeRef branch — so the
      // i32 list types it also forces are harmless presence, never wrong bytes).
      if arrLitIsRef(i) {
        rlUsed = true
        raUsed = true
        rElemKind = arrLitElemKind(i)
        rlInternName(arrLitElemName(i), arrLitElemKind(i))
        // A nested `[[…]]` literal's elements are i32-list wrappers — force the
        // i32 list + raw array types for them.
        if arrLitElemKind(i) == 4 {
          lUsed = true
          aUsed = true
        }
      } else if arrLitIsStr(i, -1) {
        // A STRING-element literal is a string-ref list — the same wrapper/backing
        // a `string[]` annotation forces.
        slUsed = true
        aUsed = true
      } else if arrLitIsF64(i, -1) {
        // An f64-element literal is an f64 list — its own `(array (mut f64))` backing +
        // wrapper. Does NOT force `aUsed`/`lUsed` (those are the i32 array/list). (Slice 4.)
        fa64Used = true
      } else {
        lUsed = true
        aUsed = true
      }
    } else if nd is StrLit {
      aUsed = true
    } else if nd is Call {
      // A `fromCodePoint(code)` call (H2) constructs a length-1 VL string — the shared
      // `(array i32)` heap type — so it forces `aUsed` just like a string literal, even
      // in a program with no other string. The callee is a bare `Ident`.
      const cf = P.nodes[nd.callFn]
      // `m.keys()` builds a fresh STRING list of the map's keys — force the string-list
      // wrapper/backing (`mkListIdx`/`mkArrIdx`) + the shared `(array i32)`. `.keys()` is
      // only valid on a map (checker-enforced), so any such call contributes the type.
      if cf is Member {
        if cf.memProp == "keys" {
          slUsed = true
          aUsed = true
        }
      }
      if cf is Ident {
        if cf.identName == "fromCodePoint" { aUsed = true }
        // `toString(x)` builds a fresh string (decimal digits / "true"/"false").
        if cf.identName == "toString" { aUsed = true }
        // `fromCodePoints(xs)` builds a fresh string from an i32 list.
        if cf.identName == "fromCodePoints" {
          aUsed = true
          lUsed = true
        }
        // An un-annotated `Map()` (usage-inferred binding) still constructs the map
        // struct — force the same types a `{[string]: i32}` annotation does. `Set()`
        // is the same 7-field map struct, so it forces the IDENTICAL types.
        if cf.identName == "Map" || cf.identName == "Set" {
          mUsed = true
          lUsed = true
          aUsed = true
        }
        // The array-intrinsic allocators (std-design D1) construct a list even
        // with no literal/annotation in sight: an f64 FILL forces the f64
        // array+wrapper pair, anything else the i32 list (wrapper + backing).
        if (
          cf.identName == "__array_new__" ||
          cf.identName == "__array_new_default__"
        ) {
          const ank = arrNewIntrKind(i, -1)
          if ank == 1 {
            fa64Used = true
          } else if ank == 2 {
            // String fill → the string list (wrapper/backing shared with `string[]`).
            slUsed = true
            aUsed = true
          } else if ank == 3 {
            // Struct fill → the ref list of the element struct (intern its slot).
            rlUsed = true
            raUsed = true
            rlInternName(refListElemNameOfExpr(i, -1), 1)
          } else {
            lUsed = true
            aUsed = true
          }
        }
      }
      // A `<recv>.push("…")` (string-LITERAL argument) appends to a STRING list:
      // the usage-driven inference for an un-annotated empty `[]` binding makes
      // its receiver a `string[]`, so force the string-list types. Idempotent
      // when an annotation already forced them (a string push onto a non-string
      // list is a checker error, so this never fires spuriously).
      if cf is Member {
        if cf.memProp == "push" {
          if nd.callArgs.length == 1 {
            const spArg = P.nodes[nd.callArgs[0]]
            if spArg is StrLit {
              slUsed = true
              aUsed = true
            }
          }
        }
      }
    } else if nd is TypeRef {
      if annArrowAt(nd.tyName) >= 0 {
        // A TOP-LEVEL function-type annotation (`(i32) => R`): the function-type name
        // itself needs no array/list type, but its RETURN `R` may (an `i32[]`/`string[]`/
        // `f64[]` result list, or a `string`). Force the return's backing types so the
        // closure `$fnsig` result valtype resolves even when the only `i32[]` in the
        // module rides this annotation. The arrow is TOP-LEVEL, so `((i32) => i32)[]` (a
        // NESTED arrow — an array OF functions) is NOT caught here; it falls through to
        // the array branches below. Checked FIRST so the trailing `[]` of a list-returning
        // function type (`(i32) => i32[]`) is never mis-read as an array name.
        const fra = annArrowAt(nd.tyName)
        const frRet = nd.tyName.slice(fra + 2, nd.tyName.length)
        if frRet == "i32[]" {
          lUsed = true
          aUsed = true
        } else if nameIsStringArray(frRet) {
          slUsed = true
          aUsed = true
        } else if nameIsF64Array(frRet) {
          fa64Used = true
        } else if nameIsString(frRet) {
          aUsed = true
        }
      } else if nameIsMap(nd.tyName) {
        // A `{[string]: i32}` annotation (G8) is a string-keyed map: the map struct
        // + the keys list (string-ref backing) + the i32 VALS list (the existing
        // `lTypeIdx`/`aTypeIdx`). So it forces `aUsed` (string backing + vals backing)
        // and `lUsed` (the vals wrapper) alongside the three dedicated map types.
        mUsed = true
        lUsed = true
        aUsed = true
        // A REF value type (`{[string]: string}` / `{[string]: {x:i32}}`) interns a
        // per-value-type map slot (its own map struct over a ref vals list). All mv
        // interning happens HERE (collect scans every TypeRef), so the type-index
        // assignment in `emitModule` sees the full slot set; later resolutions are
        // idempotent lookups.
        mvShapeOfValName(mapValNameOf(nd.tyName))
      } else if nameIsStringArray(nd.tyName) {
        // A `string[]` annotation is a string-ref list — the SAME wrapper/backing as
        // the map keys list. Force the keys list types (`slUsed`) + the string backing
        // (`aUsed`, since the elements are `(ref null $aTypeIdx)`).
        slUsed = true
        aUsed = true
      } else if nameIsRefArray(nd.tyName) || nameIsNulRefList(nd.tyName) {
        // A `S[]`/`N[]` annotation is a ref list (wrapper + `(ref null $elem)` backing) — and so is its
        // NULLABLE form `S[] | null` (kind 18): force the wrapper/backing on the NON-null ref-array name,
        // so a bare local whose value does not self-collect the element (e.g. `(i32|null)[] | null = [5]`)
        // still emits the element's ref-list type.
        let ran = nd.tyName
        const ranp = nullablePartOf(ran)
        if ranp != "" && nameIsRefArray(ranp) { ran = ranp }
        rlUsed = true
        raUsed = true
        rElemKind = refArrElemKind(ran)
        ensureRefElem(refArrElemName(ran))
        // An `i32[][]` annotation's ELEMENTS are i32-list wrappers — force the
        // i32 list + raw array so `lTypeIdx`/`aTypeIdx` exist for the elements.
        if refArrElemKind(ran) == 4 {
          lUsed = true
          aUsed = true
        }
        // A nested NON-i32 scalar / string 2D array (`string[][]`/`f64[][]`/`i64[][]`, element
        // kinds 6/7/8) forces its INNER list's backing+wrapper, as the LIST-valued map path
        // does — else the element wrapper heap (`mkListIdx`/`fl64`/`il64`) is never allocated.
        if refArrElemKind(ran) == 6 {
          slUsed = true
          aUsed = true
        }
        if refArrElemKind(ran) == 7 { fa64Used = true }
        if refArrElemKind(ran) == 10 { fa32Used = true }
        if refArrElemKind(ran) == 8 { ia64Used = true }
        if nameIsMapArray(ran) {
          mUsed = true
          lUsed = true
          aUsed = true
        }
      } else if nameIsF64Array(nd.tyName) {
        // An `f64[]` annotation forces the f64 array + wrapper pair (Slice 4) — its own
        // `(array (mut f64))` backing, independent of the i32 array/list.
        fa64Used = true
      } else if nameIsI64Array(nd.tyName) {
        // An `i64[]` annotation forces the i64 array + wrapper pair (`ia64`/`il64`).
        ia64Used = true
      } else if nameIsF32Array(nd.tyName) {
        // An `f32[]` annotation forces the f32 array + wrapper pair (`fa32`/`fl32`).
        fa32Used = true
      } else if genTyParamArr(nd.tyName) {
        // A `T[]` over a FuncDecl TYPE PARAMETER — a generic ORIGINAL's
        // annotation. Its monomorphized instances carry concrete pinned names
        // (collected when `monomorphize` re-runs this pass); the original is
        // replaced by its first instance and never emitted, so nothing is
        // forced or validated here.
      } else if nameIsArray(nd.tyName) {
        if checkArrName(nd.tyName) < 0 { return -1 }
        // An `i32[]` annotation is a list (wrapper struct + raw-array backing).
        lUsed = true
        aUsed = true
      } else if nameIsString(nd.tyName) {
        aUsed = true
      } else if nameIsNulString(nd.tyName) {
        // A `string | null` annotation (kind 16) is a `(ref null $aTypeIdx)` slot — it still needs the
        // string backing forced, exactly like a plain `string`. Without this a bare `string | null = null`
        // (no other string in the module to force `aUsed`) left `$aTypeIdx` unallocated, so the slot
        // valtype + `ref.null` referenced a stale type index → invalid wasm at the read.
        aUsed = true
      } else if nameIsNulI32List(nd.tyName) {
        // An `i32[] | null` annotation still constructs/reads the i32 list — the
        // nullable wrapper changes only the slot's valtype, not the types needed.
        lUsed = true
        aUsed = true
      } else if nameIsLitUnionType(nd.tyName) {
        // A literal-union annotation (`: K`): an atom WIDENS to its member `string` (`print(k)` etc.), so
        // force the string backing even when the module has no other string literal.
        aUsed = true
      }
    }
    i = i + 1
  }
  // Inline-struct MAP FIELDS (`const s: { m: {[string]: V} }`): `collectAnnShapes` registered
  // them as code-19 fields with the value name in `sFieldElemName`, but their inner map is
  // not a standalone TypeRef the scan above sees (the whole `{m:{[string]:V}}` is ONE name).
  // Intern each code-19 field's mv slot here so emit resolves it. Idempotent (mvShapeOfValName
  // dedupes), so a named struct's already-interned field is a no-op — byte-identical for any
  // program without an inline map-valued field.
  let sfi = 0
  while sfi < sFieldTypes.length {
    if sFieldTypes[sfi] == 19 { mvShapeOfValName(sFieldElemName[sfi]) }
    // A REF-LIST field (code 5): intern its element so `sFieldRefSlot` (`rlSlotByName`) resolves. An
    // INLINE-shape ref-list field's element is NEVER a standalone TypeRef the scan above sees (only the
    // whole `{f:N[]}`), so intern it from the struct table here — this runs after the rl-table reset, so
    // the slot persists. A NOMINAL field's element is already interned via its own TypeRef; `ensureRefElem`
    // dedupes, so this is byte-identical for programs with no inline ref-list field.
    if sFieldTypes[sfi] == 5 || sFieldTypes[sfi] == 28 {
      rlUsed = true
      raUsed = true
      ensureRefElem(sFieldElemName[sfi])
    }
    // A `string | null` FIELD (code 20) is a `(ref null $aTypeIdx)` slot — force the string backing, like
    // the standalone `string | null` annotation above. An inline `{ f: string | null }` field's inner type
    // is never a standalone TypeRef the scan sees, so without this a `{ f: null }` (no other string in the
    // module) left `$aTypeIdx` unallocated and the field read referenced a stale type → invalid wasm.
    if sFieldTypes[sfi] == 20 { aUsed = true }
    sfi = sfi + 1
  }
  0
}

// True if the array literal at `arrIx` has ref ELEMENTS — its first element is a
// struct object literal (a `T[]` element) or a union-variant object literal (an
// `N[]` element). An empty literal is NOT detectable here (it has no elements); its
// kind comes from the binding annotation (`pendingListKind`).
function arrLitIsRef(arrIx: i32) {
  const a = P.nodes[arrIx]
  if a is ArrayLit {
    if a.arrElems.length < 1 { return false }
    // A literal of FUNCTION VALUES the checker typed as a closure array (`[add, mul]`,
    // `[inc, (x) => x]`): its element name carries a `=>`. Checker-driven (not a first-element
    // `fnIndexOf` guess), so a local shadowing a function name is never mis-claimed — and it
    // subsumes the lambda-literal case below for any closure array the checker concretely typed.
    const cen = nodeArrayElemName(arrIx)
    if cen != "" {
      if strContains(cen, "=>") { return true }
    }
    const e0 = P.nodes[a.arrElems[0]]
    if e0 is ObjLit { return true }
    // A CLOSURE-element literal (`[(x) => x + 1]`) is a ref list (element kind 5), NOT an i32
    // list — without this `exprArray` claims it (its `!arrLitIsRef` default), the inferred-return
    // scan mints a `>a` (i32-list) closure sig, and a closure VALUE returning it miscompiles. As a
    // ref list it routes through `exprRefArray` (kind 5) like a struct-element literal.
    if e0 is FuncDecl { return true }
    // A NESTED array literal (`[[1, 2], [3, 4]]`) whose inner elements are
    // i32-ish is an `i32[][]` ref list (element kind 4). String / f64 / ref
    // inner elements stay unsupported (loud failure downstream).
    if e0 is ArrayLit {
      if (
        !arrLitIsStr(a.arrElems[0], -1) &&
        !arrLitIsF64(a.arrElems[0], -1) &&
        !arrLitIsRef(a.arrElems[0])
      ) {
        return true
      }
    }
  }
  false
}

// True if the array literal at `arrIx` has STRING elements — its first element is a
// string-typed expression (a `"…"` literal, or a string-returning call / string
// param/local). An empty literal is NOT detectable here; its kind comes from the
// binding/field annotation (`pendingListKind == 3`).
function arrLitIsStr(arrIx: i32, fnIx: i32) {
  const a = P.nodes[arrIx]
  if a is ArrayLit {
    if a.arrElems.length < 1 { return false }
    return exprString(a.arrElems[0], fnIx)
  }
  false
}

// True if the array literal at `arrIx` has f64 ELEMENTS — its first element is an
// f64-typed expression (a `.` float literal, or an f64-returning expression). An empty
// literal is NOT detectable here; its kind comes from the binding annotation
// (`pendingListKind == 4`). (Slice 4.)
function arrLitIsF64(arrIx: i32, fnIx: i32) {
  const a = P.nodes[arrIx]
  if a is ArrayLit {
    if a.arrElems.length < 1 { return false }
    return exprIsF64(a.arrElems[0], fnIx)
  }
  false
}

// The ref-element kind of the array literal at `arrIx` (assumes `arrLitIsRef`): `2`
// when the FIRST element is a union variant (boxes into the union), else `1` (a direct
// struct element). Per-element-type: a `Tok[]` literal whose element is a plain struct
// is kind `1` even in a program that ALSO declares a union (which `Node[]` uses).
function arrLitElemKind(arrIx: i32) {
  const a = P.nodes[arrIx]
  if a is ArrayLit {
    // A closure-element literal (the checker typed the element as a function type) is kind 5.
    const cen = nodeArrayElemName(arrIx)
    if cen != "" {
      if strContains(cen, "=>") { return 5 }
    }
    if a.arrElems.length >= 1 {
      const e0 = P.nodes[a.arrElems[0]]
      if e0 is ArrayLit { return 4 }
      if e0 is ObjLit {
        // A union-variant element boxes into the union (kind 2); a plain struct is kind 1.
        if uDeclared {
          if objVariantName(a.arrElems[0]) != "" { return 2 }
        }
        return 1
      }
    }
  }
  if uDeclared { return 2 }
  1
}

// The ref-list ELEMENT type-NAME of the array literal at `arrIx` (assumes `arrLitIsRef`):
// the union alias name for a union-variant element, else the matched struct's name. This
// is the table key (`rlElemName`) the per-element-type interning uses.
function arrLitElemName(arrIx: i32) {
  const a = P.nodes[arrIx]
  if a is ArrayLit {
    // A closure-element literal: the parenthesized function-type table key the checker recorded.
    const cen = nodeArrayElemName(arrIx)
    if cen != "" {
      if strContains(cen, "=>") { return cen }
    }
    if a.arrElems.length >= 1 {
      const e0 = P.nodes[a.arrElems[0]]
      if e0 is ArrayLit { return "i32[]" }
      if e0 is ObjLit {
        if uDeclared {
          const vn = objVariantName(a.arrElems[0])
          if vn != "" { return unionNameOfVariant(variantIndexOf(vn)) }
        }
        let si = structIndexOfObj(a.arrElems[0])
        if si >= 0 { return sNames[si] }
      }
    }
  }
  ""
}

// The element type-NAME for a ref-array type-name (assumes `nameIsRefArray(name)`): the
// element is `name` with the trailing `"[]"` removed — i.e. the struct / union alias
// name. Mirrors `refArrElemKind` but yields the table key.
function refArrElemName(name: string) {
  const ranp = nullablePartOf(name)
  if ranp != "" && nameIsArray(ranp) { return refArrElemName(ranp) }
  if name == "i32[][]" { return "i32[]" }
  // A nested NON-i32 scalar / string 2D array — the inner list's name is the slot key (kind
  // 8 / 7 / 6 element), mirroring `i32[][]` → `i32[]`.
  if name == "i64[][]" { return "i64[]" }
  if name == "f64[][]" { return "f64[]" }
  if name == "f32[][]" { return "f32[]" }
  if name == "string[][]" { return "string[]" }
  if nameIsMapArray(name) { return name.slice(0, name.length - 2) }
  // `(string|i32)[]` → `string|i32` (the parens are annotation grouping only —
  // the TABLE key is the bare atom-set name every other union position uses).
  const pun = parenUnionArrElemName(name)
  if pun != "" { return pun }
  // `((i32) => i32)[]` → `((i32) => i32)` (the parenthesized function-type element, the
  // table key for the closure-element slot — all such slots share `cloStructIdx`).
  if nameIsClosureArray(name) { return name.slice(0, name.length - 2) }
  // A `<Union>[]` / `<Struct>[]`: strip the trailing `[]` ONCE and confirm the bare name is a
  // registered union/struct (the stripped base IS the table key — no per-iteration `+ "[]"`
  // concat, which allocated a string per struct/union per call).
  const n = name.length
  if n >= 3 && name[n - 2] == '[' && name[n - 1] == ']' {
    const base = name.slice(0, n - 2)
    let u = 0
    while u < unNames.length {
      if base == unNames[u] { return base }
      u = u + 1
    }
    if structIndexByName(base) >= 0 { return base }
    // A `Cat[]` concrete-variant element list — the bare variant name is the table key.
    if variantIndexOf(base) >= 0 { return base }
    // A NESTED ref array (`Cell[]` as the element of `Cell[][]`): the base is itself a ref array
    // — the inner list's name keys its slot. Recurses to the leaf struct/union/closure array.
    if nameIsRefArray(base) { return base }
  }
  ""
}

// Intern a ref-list element type-NAME into the per-element-type table, returning its
// SLOT index (existing slot if already present). `kind` is 1 (struct) or 2 (union box).
// Heap/backing/wrapper indices are filled later in `emitModule`.
// A ref-list element is a NULLABLE NICHE (the index read leaves it `(ref null $elem)`) iff it is a
// niche-bearing KIND — a struct (1) or an i32-list (4) — AND its name carries `| null`. A value-union BOX
// (kind 2) is NOT a niche even though `i32 | null` also has `| null` (its null is a tag inside a non-null
// box). The KIND is the discriminator; recording it once here keeps the read/build sites kind-agnostic.
function rlElemNicheNullable(kind: i32, name: string) {
  if kind != 1 && kind != 4 && kind != 9 { return false }
  return nullablePartOf(name) != ""
}

function rlInternName(name: string, kind: i32) {
  if name == "" { return -1 }
  let i = 0
  while i < rlElemName.length {
    if rlElemName[i] == name { return i }
    i = i + 1
  }
  rlElemName.push(name)
  rlElemHeap.push(0)
  rlBackIdx.push(0)
  rlWrapIdx.push(0)
  rlElemKindTbl.push(kind)
  if rlElemNicheNullable(kind, name) {
    rlElemNullable.push(1)
  } else {
    rlElemNullable.push(0)
  }
  rlElemName.length - 1
}

// The table SLOT for a ref-list element type-NAME, or -1 if not interned.
function rlSlotByName(name: string) {
  let i = 0
  while i < rlElemName.length {
    if rlElemName[i] == name { return i }
    i = i + 1
  }
  -1
}

// The struct field-type CODE for an ANONYMOUS-shape field, from its literal VALUE
// (an anonymous literal has no `type` annotation to read): a number/boolean is i32
// (`0`), a string literal is a string ref (`3`), a function VALUE is a closure
// fat-pointer (`14` — a `(ref $cloStruct)`, the same kind #306 uses for a closure
// cell). A function value is either a FuncDecl literal (an inline lambda) or a bare
// Ident naming a function. Anything else (a nested literal, a call, …) returns -1 —
// the whole shape is then left un-interned and the literal fails loudly downstream.
function anonFieldCode(valIx: i32) {
  if valIx < 0 { return -1 }
  const e = P.nodes[valIx]
  if e is NumLit {
    // A float `.` literal field (`x: 1.5`) is an f64 slot (code 17).
    if numTextIsFloat(e.numText) { return 17 }
    return 0
  }
  if e is BoolLit { return 0 }
  if e is StrLit { return 3 }
  if e is FuncDecl { return 14 }
  if e is Ident {
    if nameNamesFunction(e.identName) { return 14 }
    return -1
  }
  // An ARITHMETIC field value (`x: x * s` — an operator-overload maker scaling
  // its params) is i32 too; a `+` whose operand is a string literal is a concat
  // (not classifiable here).
  if e is BinExpr {
    const bop = e.binOp
    if bop == "-" || bop == "*" || bop == "/" || bop == "%" { return 0 }
    if bop == "+" {
      const bl = P.nodes[unwrapParen(e.binLeft)]
      const br = P.nodes[unwrapParen(e.binRight)]
      let strSide = false
      if bl is StrLit { strSide = true }
      if br is StrLit { strSide = true }
      if !strSide { return 0 }
      return -1
    }
    return -1
  }
  // An i32-element array literal field (`tags: [1, 2, 3]`) is an i32 list (code 4).
  if e is ArrayLit {
    if e.arrElems.length > 0 {
      const ae = P.nodes[e.arrElems[0]]
      if ae is NumLit { return 4 }
    }
    return -1
  }
  // A NESTED object-literal field (`pos: { x: 1 }`) is a nested-struct ref (code
  // 15) once the inner literal's shape resolves — the parser interns children
  // before parents (lower arena indices), so a linear collect sees it.
  if e is ObjLit {
    if structIndexOfObj(valIx) >= 0 { return 15 }
    return -1
  }
  -1
}

// The `sFieldElemName` entry for an ANONYMOUS-shape field: the nested struct's
// table NAME for a code-15 field (`pos: { x: 1 }` → the inner shape's synthetic
// name), "" otherwise.
function anonFieldElemName(valIx: i32, code: i32) {
  if code != 15 { return "" }
  let si = structIndexOfObj(valIx)
  if si >= 0 { return sNames[si] }
  ""
}

// The per-field wasm-type code an INLINE OBJECT-TYPE annotation member names
// (`x:i32` → 0, `name:string` → 3, `tags:i32[]` → 4, …) — the NAME-level mirror
// of `fieldTypeCode` (which reads a TypeRef node).
function nameFieldCode(t: string) {
  // A function-typed field name (`(i32)=>i32` — carries `=>`) is the closure rep, code 14.
  if strContains(t, "=>") { return 14 }
  if t == "i32" { return 0 }
  if t == "boolean" { return 0 }
  if t == "f64" { return 17 }
  if t == "i64" { return 23 }
  if t == "f32" { return 24 }

  if nameIsString(t) { return 3 }
  if nameIsArray(t) {
    if nameIsI32Array(t) { return 4 }
    if nameIsStringArray(t) { return 6 }
    // Scalar-element list fields (code 25/26/27), same as `fieldTypeCode`.
    if nameIsF64Array(t) { return 25 }
    if nameIsI64Array(t) { return 26 }
    if nameIsF32Array(t) { return 27 }
    return 5
  }
  // A MAP-typed field (`m: {[string]: i32}`) — code 19, the name-level mirror of the
  // `fieldTypeCode` map case. Its mv SLOT is resolved at emit by the value name recorded in
  // `sFieldElemName` (see `internInlineShape`/`internShapeAs`).
  if nameIsMap(t) { return 19 }
  // A NULLABLE i32-list field (`rest: i32[] | null`) — code 18 (see fieldTypeCode).
  if nameIsNulI32List(t) { return 18 }
  if nameIsNulRefList(t) { return 28 }
  // The niche FIELDS: `string | null` (`(ref null $aTypeIdx)`, code 20) and
  // `boolean | null` (i32 sentinel, code 21) — before the value-union test (a single
  // ref/scalar + null is a niche, not a box).
  if nameIsNulString(t) { return 20 }
  if nameIsNulBool(t) { return 21 }
  // A BOX-union field — a VALUE union (`y: string | i32`) OR a registered STRUCT /
  // HETEROGENEOUS union (`v: A | B`, `v: A | i32`) — stores the union BOX ref (code 16);
  // its union name rides `sFieldElemName` (the tag set + value-box / variant reps).
  // Checked before the nullable-struct strip (`i32|null` is a value union, not a
  // nullable struct name).
  if isValueUnionName(t) { return 16 }
  if isUName(t) { return 16 }
  let base = t
  const nb = nullablePartOf(base)
  if nb != "" { base = nb }
  if nameIsStructDecl(base) { return 15 }
  -1
}

// Intern every INLINE OBJECT-TYPE annotation (`(p: { x: i32 })`, `: { x: i32 } |
// null` — the synthetic `{x:i32}` TypeRef names) as an anonymous struct shape, so
// a literal with the same field-name SET (`{ x: n }`, even one whose field VALUES
// are param reads `anonFieldCode` cannot classify) matches it via
// `structIndexOfObj`, and `S|null` returns/params resolve their base shape.
// Idempotent per field-name set; a module with no inline object annotation interns
// nothing (byte-identical goldens).
// Recursively peel the COMPOSITION wrappers off a type name — grouping parens, a trailing `| null`, and
// trailing `[]` suffixes, in any order and to any depth — interning the inline-shape STRUCT reached at the
// bottom (`internInlineShape` then recurses into the shape's own fields). Reaches a shape however deeply it
// is nested under arrays / nullables / groupings: `({g:i32}[] | null)[]` -> `{g:i32}`, `{f:i32}[][]` ->
// `{f:i32}`. A non-shape leaf (`i32`, a named type, a map) interns as a no-op.
function internShapeDeep(nm: string) {
  if nm.length < 2 { return 0 }
  if nm[0] == '(' && nm[nm.length - 1] == ')' {
    return internShapeDeep(nm.slice(1, nm.length - 1))
  }
  // A VALUE UNION leaf (`i32 | null`, `string | i32`) — register its box reps. Do NOT peel its `| null`:
  // here the null is a union ATOM (a tag in a non-null box), NOT a nullable-niche wrapper. Checked AFTER
  // the parens peel (so `(i32|null)` reaches here) but BEFORE the `| null` peel (which would lose the atom).
  if isValueUnionName(nm) {
    registerValueUnionName(nm)
    return 0
  }
  const np = nullablePartOf(nm)
  if np != "" { return internShapeDeep(np) }
  if nm.length > 2 && nm[nm.length - 2] == '[' && nm[nm.length - 1] == ']' {
    return internShapeDeep(nm.slice(0, nm.length - 2))
  }
  internInlineShape(nm) // no-op for any non-shape leaf
  0
}

function collectAnnShapes() {
  let ti = 0
  while ti < P.nodes.length {
    const tn = P.nodes[ti]
    if tn is TypeRef { internShapeDeep(tn.tyName) }
    ti = ti + 1
  }
  0
}

// Intern the inline object-shape TEXT `nm` (`{x:i32}`, `{v:{x:i32}|null}`) as an
// anonymous struct shape, returning its struct table index — or -1 when `nm` is
// not an internable shape (a map `{[…]}`, a named type, a field with no code).
// A field whose type is itself an inline shape (`v:{x:i32}` / `v:{x:i32}|null`)
// RECURSES: the nested shape interns first, the field takes a nullable struct
// ref on it (code 15) — only a nested text with no code fails the whole shape.
// Idempotent per field-name+code set (`annShapeIndexOf`), so a literal-interned
// twin (`collectAnonShapes`) and a re-visited annotation share one entry.
function internInlineShape(nm: string) {
  if nm.length < 2 { return -1 }
  if nm[0] != '{' || nm[1] == '[' || nm[nm.length - 1] != '}' { return -1 }
  const inner = nm.slice(1, nm.length - 1)
  // Split `x:i32,y:string` into names + codes at depth 0. `texts` keeps each
  // field's type TEXT (a code-16 union field interns its union and records the
  // name in `sFieldElemName`; a code-15 nested field records its base shape).
  const names: string[] = []
  const codes: i32[] = []
  const texts: string[] = []
  let ok = true
  let depth = 0
  let start = 0
  let k = 0
  while k <= inner.length {
    const atEnd = k == inner.length
    let brk = false
    if !atEnd {
      if inner[k] == '{' || inner[k] == '[' || inner[k] == '(' {
        depth = depth + 1
      }
      if inner[k] == '}' || inner[k] == ']' || inner[k] == ')' {
        depth = depth - 1
      }
      if inner[k] == ',' && depth == 0 { brk = true }
    } else {
      brk = true
    }
    if brk {
      const part = inner.slice(start, k)
      // part is `name:type` — split at the first `:`.
      let ci = part.indexOf(":")
      if ci <= 0 {
        ok = false
      } else {
        let ftxt = part.slice(ci + 1, part.length)
        // PRE-INTERN any inline shape / value union buried in the field type BEFORE classifying. A
        // nullable ref-list field (`{g:i32}[] | null` / `(i32|null)[] | null`, code 28) needs its element
        // shape interned (or value-union registered) for `nameFieldCode` to even recognize the non-null
        // part as a ref array. `internShapeDeep` peels array / nullable / grouping wrappers to the leaf and
        // interns/registers it; a no-op for a scalar / nominal / map field. MUST be the parse loop (the
        // outer shape is pushed to `sNames` only after this, so the flat `sField*` arrays aren't corrupted).
        internShapeDeep(ftxt)
        let fc = nameFieldCode(ftxt)
        if fc < 0 {
          // A NESTED inline-shape field: intern the nested shape (its `|null`
          // wrapper stripped) and store a struct ref on it.
          let base = ftxt
          const fnb = nullablePartOf(base)
          if fnb != "" { base = fnb }
          if internInlineShape(base) >= 0 {
            fc = 15
            ftxt = base
          }
        }
        if fc < 0 { ok = false }
        names.push(part.slice(0, ci))
        codes.push(fc)
        texts.push(ftxt)
      }
      start = k + 1
    }
    k = k + 1
  }
  if !ok || names.length == 0 { return -1 }
  const existing = annShapeIndexOf(names, codes, texts)
  if existing >= 0 { return existing }
  sDeclared = true
  // Interned under the ANNOTATION TEXT itself (`{v:i32}`) — a real key, so
  // `structIndexByName` on the annotation (or on a ref-list element name
  // `{v:i32}[]` → `{v:i32}`) resolves directly.
  sNames.push(nm)
  sFieldStart.push(sFieldNames.length)
  sFieldCount.push(codes.length)
  let pi = 0
  while pi < codes.length {
    sFieldNames.push(names[pi])
    sFieldTypes.push(codes[pi])
    forceScalarListField(codes[pi])
    if codes[pi] == 16 {
      // The union FIELD's name keys its atom set; registering it interns the
      // shared box + the value-box reps it needs (this runs after `collectU`,
      // but before any type-index math).
      sFieldElemName.push(texts[pi])
      registerValueUnionName(texts[pi])
    } else if codes[pi] == 15 {
      // The nested-struct field's TARGET name (`|null` stripped) — `emitObj`
      // seeds a nested literal to it, `structIndexByName`-resolvable.
      let b15 = texts[pi]
      const nb15 = nullablePartOf(b15)
      if nb15 != "" { b15 = nb15 }
      sFieldElemName.push(b15)
    } else if codes[pi] == 19 {
      // A MAP field records its VALUE type-name (`i32` of `{[string]: i32}`) — the mv-slot
      // interning key. The slot itself is interned in `collectA` (which resets `mvValName`,
      // so interning here would be wiped); the inner map of an inline `{m:{[string]:V}}` is
      // not a standalone TypeRef that `collectA`'s scan sees, so it interns code-19 FIELDS.
      sFieldElemName.push(mapValNameOf(texts[pi]))
    } else if codes[pi] == 5 {
      // A REF-LIST field (`f: N[]` / `f: (i32|null)[]`): record its element name (the CANONICAL ref-array
      // element name — parens stripped for a value-union element so it keys the same slot every other
      // union position uses), so `sFieldRefSlot` (`rlSlotByName`) finds the element's interned slot.
      // Without this an inline-shape ref-list field stored "" and the read failed to resolve the element.
      // A value-union element additionally interns its box reps here (the code-16 field parity).
      let e5 = refArrElemName(texts[pi])
      // A ref-list element that is itself an INLINE SHAPE (`{g:i32}[]`) is invisible to `refArrElemName`
      // until the shape is interned, so it returns "". The shape was pre-interned by
      // `collectNestedFieldShapes` (interning mid-field-loop would corrupt the flat `sField*` arrays), so
      // here just key it by its stripped text. A nominal / union / scalar element keeps `refArrElemName`.
      if e5 == "" {
        const raw5 = texts[pi].slice(0, texts[pi].length - 2)
        if structIndexByName(raw5) >= 0 { e5 = raw5 }
      }
      sFieldElemName.push(e5)
      if isValueUnionName(e5) { registerValueUnionName(e5) }
    } else if codes[pi] == 28 {
      // A NULLABLE ref-list field (`f: S[] | null`): its element name is the ref-array element of the
      // non-null part; the element shape/union was pre-interned in the parse loop (`internShapeDeep`).
      let e28 = refArrElemName(nullablePartOf(texts[pi]))
      if e28 == "" {
        let raw28 = nullablePartOf(texts[pi])
        if raw28.length > 2 { raw28 = raw28.slice(0, raw28.length - 2) }
        if structIndexByName(raw28) >= 0 { e28 = raw28 }
      }
      sFieldElemName.push(e28)
      if isValueUnionName(e28) { registerValueUnionName(e28) }
    } else {
      sFieldElemName.push("")
    }
    pi = pi + 1
  }
  sNames.length - 1
}

// Intern the inline shape name `nm` (`{a:i32,b:i32}`) as the NAMED struct
// `key` — the same field parsing as `collectAnnShapes`, but keyed under the
// alias name so `structIndexByName(key)` resolves params/locals/literals.
function internShapeAs(key: string, nm: string) {
  const inner = nm.slice(1, nm.length - 1)
  const names: string[] = []
  const codes: i32[] = []
  let depth = 0
  let start = 0
  let k = 0
  while k <= inner.length {
    const atEnd = k == inner.length
    let brk = false
    if !atEnd {
      if inner[k] == '{' || inner[k] == '[' || inner[k] == '(' {
        depth = depth + 1
      }
      if inner[k] == '}' || inner[k] == ']' || inner[k] == ')' {
        depth = depth - 1
      }
      if inner[k] == ',' && depth == 0 { brk = true }
    } else {
      brk = true
    }
    if brk {
      const part = inner.slice(start, k)
      let ci = part.indexOf(":")
      if ci <= 0 { return emitFail("emitProgram: malformed struct field") }
      let fc = nameFieldCode(part.slice(ci + 1, part.length))
      if fc < 0 {
        return emitFail(
          "emitProgram: only i32 / boolean / string / array struct fields are supported",
        )
      }
      names.push(part.slice(0, ci))
      codes.push(fc)
      start = k + 1
    }
    k = k + 1
  }
  if names.length == 0 {
    return emitFail("emitProgram: empty struct alias shape")
  }
  sDeclared = true
  sNames.push(key)
  sFieldStart.push(sFieldNames.length)
  sFieldCount.push(codes.length)
  let pi = 0
  while pi < codes.length {
    sFieldNames.push(names[pi])
    sFieldTypes.push(codes[pi])
    sFieldElemName.push("")
    pi = pi + 1
  }
  0
}

// The struct table index whose field-name SET matches `names` exactly, or -1.
function annShapeIndexOf(names: string[], codes: i32[], texts: string[]) {
  let si = 0
  while si < sNames.length {
    if sFieldCount[si] == names.length {
      let allIn = true
      let i = 0
      while i < names.length {
        let fi = sFieldIndex(si, names[i])
        if fi < 0 {
          allIn = false
        } else if sFieldTypeAt(si, fi) != codes[i] {
          // The same field-NAME set with a DIFFERENT field type (`{y:i32}` vs
          // `{y:string|i32}`) is a DISTINCT shape — intern it separately so each
          // annotation resolves its own struct (host: structural interning).
          allIn = false
        } else {
          // Same field name AND code, but a REF field (nested struct / union / …) with a DIFFERENT
          // ELEMENT type is STILL a distinct shape. Without this, `{f:{f:i32}}` and `{f:{f:{f:i32}}}`
          // — both field `f`, code 15 — wrongly dedup (the recursion produces identical name+code at
          // every level when field names repeat). Compare the stored element name to this field's
          // element text (code 15 strips the `|null` wrapper exactly as the interner stores it).
          const en = sFieldElemNameAt(si, fi)
          if en != "" {
            let bi = texts[i]
            if codes[i] == 15 {
              const nbi = nullablePartOf(bi)
              if nbi != "" { bi = nbi }
            }
            if en != bi { allIn = false }
          }
        }
        i = i + 1
      }
      if allIn { return si }
    }
    si = si + 1
  }
  -1
}

// ANONYMOUS shapes: an object literal naming NO declared struct and NO union variant
// still constructs a WasmGC struct (`const p = { y: 4, x: 3 }` with no `type` in
// sight — the host interns every shape). Intern each distinct field-name SET as an
// unnamed struct (name "", field order = literal order, field types from the literal
// values), APPENDED after every declared struct so declared indices are unchanged —
// a program with no anonymous literal emits byte-identical bytes. A later literal
// with the same name set matches the interned shape via `structIndexOfObj`. A field
// value `anonFieldCode` can't type leaves the whole shape un-interned; that literal
// then fails loudly downstream (never a trap). Must run AFTER `collectU` (variant
// shapes are the union's, not standalone structs).
function collectAnonShapes() {
  let ai = 0
  while ai < P.nodes.length {
    const an = P.nodes[ai]
    if an is ObjLit {
      if structIndexOfObj(ai) < 0 && objVariantName(ai) == "" {
        const fields = an.objFields
        // Does this literal carry a FUNCTION-valued field? An operator/index
        // TRAP MAKER (`{ "*": fn, x: x, y: y }`) mixes closures with plain
        // ident fields — classify the idents as i32 there (the host types them
        // exactly; a mis-typed non-i32 binding fails loudly at the validator).
        // A literal with NO function field keeps idents unclassifiable, so a
        // generic's structural-return literal (`{ first: b, second: a }`) stays
        // un-interned here and matches its instance-pinned ANNOTATION shape.
        let hasFnField = false
        let ffi = 0
        while ffi < fields.length {
          const ff = P.nodes[fields[ffi]]
          if ff is FieldInit {
            // (Direct node checks, not `fieldValueFeOf` — `fnStmts` is not yet
            // populated when `collectS`/`collectAnonShapes` run.)
            const fv = P.nodes[ff.fiValue]
            if fv is FuncDecl { hasFnField = true }
            if fv is Ident {
              if nameNamesFunction(fv.identName) { hasFnField = true }
            }
          }
          ffi = ffi + 1
        }
        const codes: i32[] = []
        const names: string[] = []
        const elemNames: string[] = []
        let ok = true
        let fi = 0
        while fi < fields.length {
          const f = P.nodes[fields[fi]]
          if f is FieldInit {
            let code = anonFieldCode(f.fiValue)
            if code < 0 && hasFnField {
              const iv = P.nodes[f.fiValue]
              if iv is Ident {
                if !nameNamesFunction(iv.identName) { code = 0 }
              }
            }
            if code < 0 { ok = false }
            codes.push(code)
            names.push(f.fiName)
            elemNames.push(anonFieldElemName(f.fiValue, code))
          } else {
            ok = false
          }
          fi = fi + 1
        }
        if ok && codes.length > 0 {
          sDeclared = true
          // A synthetic UNIQUE name (the `#` prefix can never collide with a user
          // identifier or annotation) — a real key, so a ref LIST of this element
          // shape interns a per-element-type slot (`rlInternName` treats the empty
          // string as its "not a ref element" sentinel).
          sNames.push("#anon" + i32ToStr(sNames.length))
          sFieldStart.push(sFieldNames.length)
          sFieldCount.push(codes.length)
          let pi = 0
          while pi < codes.length {
            sFieldNames.push(names[pi])
            sFieldTypes.push(codes[pi])
            sFieldElemName.push(elemNames[pi])
            // A function-valued field (code 14) interns a closure cell `(ref
            // $cloStruct)`; flag the module so the closure rec-group types are
            // emitted even when no lambda is otherwise lifted (e.g. a top-level
            // function used purely as a struct-field value, `{ f: inc }`).
            if codes[pi] == 14 { fnValUsed = true }
            // (A code-4 i32-list field always rides an ArrayLit value, which the
            // later `collectA` arena scan classifies — `lUsed`/`aUsed` set there.)
            pi = pi + 1
          }
        }
      }
    }
    ai = ai + 1
  }
  0
}

// The registry slot of generic-alias base `name`, or -1.
function gaeIndexOf(name: string) {
  let i = 0
  while i < gaeBases.length {
    if gaeBases[i] == name { return i }
    i = i + 1
  }
  -1
}

// Record every generic-alias declaration into the registry.
function gaeCollectDecls(stmts: i32[]) {
  gaeBases = []
  gaeParams = []
  gaeFieldStart = []
  gaeFieldCount = []
  gaeFieldNames = []
  gaeFieldTyNames = []
  let i = 0
  while i < stmts.length {
    let s = P.nodes[stmts[i]]
    if s is TypeDecl {
      const lt = gaeLtAt(s.tdName)
      if lt > 0 && s.tdName[s.tdName.length - 1] == '>' {
        gaeBases.push(s.tdName.slice(0, lt))
        gaeParams.push(s.tdName.slice(lt + 1, s.tdName.length - 1))
        gaeFieldStart.push(gaeFieldNames.length)
        let cnt = 0
        const fields = s.tdFields
        let fi = 0
        while fi < fields.length {
          const fnode = P.nodes[fields[fi]]
          if fnode is FieldDef {
            let tname = ""
            if fnode.fdType >= 0 {
              const ftn = P.nodes[fnode.fdType]
              if ftn is TypeRef { tname = ftn.tyName }
            }
            gaeFieldNames.push(fnode.fdName)
            gaeFieldTyNames.push(tname)
            cnt = cnt + 1
          }
          fi = fi + 1
        }
        gaeFieldCount.push(cnt)
      }
    }
    i = i + 1
  }
  0
}

// Intern the application `name` ("Box<i32>") as a struct shape, once. A field
// the emitter cannot type (an unbound param, an unsupported shape) leaves the
// application un-interned — its use then fails loudly downstream, never a trap.
function gaeEnsure(name: string) {
  if name.length < 3 { return 0 }
  if name[name.length - 1] != '>' { return 0 }
  const ltAt = gaeLtAt(name)
  if ltAt <= 0 { return 0 }
  if structIndexByName(name) >= 0 { return 0 }
  let gi = gaeIndexOf(name.slice(0, ltAt))
  if gi < 0 { return 0 }
  const pnames: string[] = []
  gaeSplitArgs(gaeParams[gi], pnames)
  const args: string[] = []
  gaeSplitArgs(name.slice(ltAt + 1, name.length - 1), args)
  if args.length != pnames.length { return 0 }
  const names: string[] = []
  const codes: i32[] = []
  const elems: string[] = []
  let ok = true
  const fs = gaeFieldStart[gi]
  let fc = gaeFieldCount[gi]
  let fi = 0
  while fi < fc {
    const tn = gaeApplyFieldTy(gaeFieldTyNames[fs + fi], pnames, args)
    // A field that is ITSELF an application (or an array of one) interns
    // depth-first, so the ref/elem lookups below resolve.
    let base = tn
    while (
      base.length > 2 &&
      base[base.length - 2] == '[' &&
      base[base.length - 1] == ']'
    ) {
      base = base.slice(0, base.length - 2)
    }
    gaeEnsure(base)
    let code = nameFieldCode(tn)
    let elem = ""
    if code < 0 {
      // An interned application name is a struct-ref field (`nameFieldCode`
      // only consults TypeDecl names, which an application is not).
      if structIndexByName(tn) >= 0 {
        code = 15
        elem = tn
      }
    } else if code == 15 {
      const nb = nullablePartOf(tn)
      if nb != "" { elem = nb } else { elem = tn }
    } else if code == 5 {
      elem = tn.slice(0, tn.length - 2)
    } else if code == 16 {
      elem = tn
      registerValueUnionName(tn)
    }
    if code < 0 { ok = false }
    names.push(gaeFieldNames[fs + fi])
    codes.push(code)
    elems.push(elem)
    fi = fi + 1
  }
  if !ok { return 0 }
  if names.length == 0 { return 0 }
  sDeclared = true
  sNames.push(name)
  sFieldStart.push(sFieldNames.length)
  sFieldCount.push(codes.length)
  let pi = 0
  while pi < codes.length {
    sFieldNames.push(names[pi])
    sFieldTypes.push(codes[pi])
    sFieldElemName.push(elems[pi])
    pi = pi + 1
  }
  0
}

// Scan every TypeRef in the arena for generic-alias applications (behind
// `|null` and `[]` wrappers) and intern each one.
function collectGenAliasShapes() {
  if gaeBases.length == 0 { return 0 }
  let ti = 0
  while ti < P.nodes.length {
    const tn = P.nodes[ti]
    if tn is TypeRef {
      let nm = tn.tyName
      const nb = nullablePartOf(nm)
      if nb != "" { nm = nb }
      while (
        nm.length > 2 &&
        nm[nm.length - 2] == '[' &&
        nm[nm.length - 1] == ']'
      ) {
        nm = nm.slice(0, nm.length - 2)
      }
      gaeEnsure(nm)
    }
    ti = ti + 1
  }
  0
}

// Scan the top-level statements for EVERY struct `type` declaration and record each
// into the flat multi-struct table (name + field names in declaration order, plus a
// per-field wasm-type code: `0` = i32 / boolean, `3` = string). Each `type X = {…}`
// interns its own WasmGC struct heap type. A field whose type is neither i32/boolean
// nor string fails loudly. Returns 0 on success, or -1 (via `emitFail`).
// Intern every INLINE-SHAPE struct field type (`type Box = { inner: {x:i32} }`) depth-first BEFORE the
// struct decls that reference it, so `collectS`'s main loop resolves the nested shape (it can't be
// interned mid-loop — `internInlineShape` shares the flat `sField*` arrays). `internInlineShape` is a
// no-op for a non-shape name and idempotent (`annShapeIndexOf`), so a program with NO inline-shape
// fields — like the compiler itself — interns nothing here and its struct layout is unchanged.
function collectNestedFieldShapes(stmts: i32[]) {
  let i = 0
  while i < stmts.length {
    const s = P.nodes[stmts[i]]
    if s is TypeDecl {
      if variantIndexOf(s.tdName) < 0 && gaeLtAt(s.tdName) < 0 {
        const fields = s.tdFields
        let fi = 0
        while fi < fields.length {
          const fnode = P.nodes[fields[fi]]
          if fnode is FieldDef {
            let nm = tyNameOf(fnode.fdType)
            const nb = nullablePartOf(nm)
            if nb != "" { nm = nb }
            while (
              nm.length > 2 &&
              nm[nm.length - 2] == '[' &&
              nm[nm.length - 1] == ']'
            ) {
              nm = nm.slice(0, nm.length - 2)
            }
            internInlineShape(nm)
          }
          fi = fi + 1
        }
      }
    }
    i = i + 1
  }
  0
}

// ── literal-union ATOMS (`type K = "a" | "b"`) ────────────────────────────────
// A literal-union value is an INTERNED i32 id: each distinct member STRING (interned lazily by its raw
// `StrLit` text) gets one id. The literal members come from the CHECKER (which preserves them); the
// emit-side `udVariants` are widened to `"string"` and must NOT be used. Slice 1: scalar atoms + `==`.
let litAtomId: {[string]: i32} = Map()
let litAtomNext: i32 = 0
// Seeded around a literal-union BOUNDARY (binding init / `==` operand) so a member `StrLit` lowers as its
// interned i32 id instead of a string. The atom analogue of `pendingNulString`.
let pendingLitUnion: i32 = 0

// Whether the module uses ANY literal-union type (named or inline). Set ONCE per program by a single
// `P.nodes` scan; every per-node litunion detector (`exprIsLitAtom`, the `*WidensAtomToStr` predicates)
// early-outs on it, so a program with no literal unions — e.g. the self-hosted compiler — pays none of
// the per-node atom-detection cost during the str-op scan / classification.
let gLitUnionUsed: i32 = 0

function resetLitAtoms() {
  litAtomId = Map()
  litAtomNext = 0
  gLitUnionUsed = 0
  if anyLitUnionUsed() { gLitUnionUsed = 1 }
  0
}

function internAtom(text: string) {
  if litAtomId.has(text) {
    const got = litAtomId[text] ?? 0
    return got
  }
  const id = litAtomNext
  litAtomId[text] = id
  litAtomNext = id + 1
  id
}

// True if the binding/global at `letIx` is annotated with a literal-union type (an i32-backed atom).
function letIsLitUnion(letIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const r = nameIsLitUnionType(tyNameOf(d.letType))
      return r
    }
  }
  false
}

// True if `exprIx` is a literal-union ATOM VALUE (an i32 id) — a litunion-flagged local or a litunion-
// annotated param. Distinguishes a real atom from a checker-inferred literal union (which is a string).
function exprIsLitAtom(exprIx: i32, fnIx: i32) {
  if gLitUnionUsed == 0 { return false }
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Ident {
    const slot = declaredSlotOf(e.identName)
    if slot >= 0 && slot < localLitUnion.length {
      if localLitUnion[slot] == 1 { return true }
    }
    const pt = paramTypeNode(fnIx, e.identName)
    if pt >= 0 {
      const r = nameIsLitUnionType(tyNameOf(pt))
      return r
    }
    const gli = globalLetOf(e.identName)
    if gli >= 0 {
      const r = letIsLitUnion(gli)
      return r
    }
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const target = fnIndexOf(callee.identName)
      if target >= 0 {
        const cf = P.nodes[fnStmts[target]]
        if cf is FuncDecl {
          if cf.fnRet >= 0 {
            const r = nameIsLitUnionType(tyNameOf(cf.fnRet))
            return r
          }
        }
      }
    }
  }
  false
}

// The re-quoted source LEXEME for a literal-union member's inner text (`i32` -> `"i32"`) — matches the
// raw `StrLit.strText` so `internAtom` yields the SAME id, and feeds a synthetic `StrLit` for printing.
function quoteLex(inner: string) {
  const q = "\""
  q + inner + q
}

// Emit `print(<string expr>)`: stream each code point through `__print_char__`, then one
// `__print_str_flush__`. Factored from the print handler so the literal-union widening can reuse it.
function emitPrintStrExpr(body: i32[], strExpr: i32, fnIx: i32) {
  if emitExpr(body, strExpr, fnIx) < 0 { return -1 }
  fbLocalSet(strScratchBase + 0)
  fbI32Const(0)
  setStrScrI(body, 0)
  pushStrScrRef(body, 0)
  fbArrayLen()
  setStrScrI(body, 1)
  fbBlock(64)
  ctrlEnter()
  fbLoop(64)
  ctrlEnter()
  pushStrScrI(body, 0)
  pushStrScrI(body, 1)
  fbI32Bin(78) // i32.ge_s
  fbBrIf(1)
  pushStrScrRef(body, 0)
  pushStrScrI(body, 0)
  fbArrayGet(aTypeIdx)
  fbCall(2) // __print_char__
  pushStrScrI(body, 0)
  fbI32Const(1)
  fbI32Bin(106) // i32.add
  setStrScrI(body, 0)
  fbBr(0)
  fbEnd()
  ctrlLeave()
  fbEnd()
  ctrlLeave()
  fbCall(3) // __print_str_flush__
  0
}

// Widen a literal-union ATOM (an i32 id) to a STRING VALUE — a `select` tower mapping each
// member's id to its string constant. Membership is checker-guaranteed, so the LAST member is
// the unconditional default arm. The id is evaluated once into the string-op scratch i32 slot 0
// (`setStrScrI`) and re-read per member; each arm builds a tiny constant string, leaving a
// NON-NULL string ref (the `string` rep, kind 3). The string-subtype analogue of the numeric
// i32->f64 widening — its callers (`emitStrConcat`, the `string` arg / return boundaries)
// reserve the str-op frame via `callWidensAtomToStr` / `retWidensAtomToStr` / `exprIsStrConcat`.
function emitAtomToStr(body: i32[], atomIx: i32, fnIx: i32) {
  const texts = nodeLitUnionMemberTexts(atomIx)
  if texts.length == 0 {
    return emitFail("emitProgram: literal-union string widening with no members")
  }
  if !aUsed {
    return emitFail(
      "emitProgram: literal-union string widening but array type not collected",
    )
  }
  // Evaluate the atom (its i32 id) once, stash in the str-op scratch i32 slot 0.
  const savedLU = pendingLitUnion
  pendingLitUnion = 1
  if emitExpr(body, atomIx, fnIx) < 0 { return -1 }
  pendingLitUnion = savedLU
  setStrScrI(body, 0)
  const r = emitAtomToStrChain(body, texts, 0)
  r
}

// The `select` tower for `emitAtomToStr`: member `i`'s string if its interned id matches the
// stashed atom, else the chain for `i+1`. The last member is the unconditional default arm
// (membership is total, so no compare is needed there).
function emitAtomToStrChain(body: i32[], texts: string[], i: i32) {
  if i >= texts.length - 1 {
    const rd = emitStr(body, mkStr(quoteLex(texts[i]), -1), -1)
    return rd
  }
  // val1 = this member's string constant
  if emitStr(body, mkStr(quoteLex(texts[i]), -1), -1) < 0 { return -1 }
  // val2 = the remaining chain
  if emitAtomToStrChain(body, texts, i + 1) < 0 { return -1 }
  // cond = (stashed id == this member's id)
  pushStrScrI(body, 0)
  fbI32Const(internAtom(quoteLex(texts[i])))
  fbI32Bin(70) // i32.eq
  // select_t typed for a non-null string ref (0x64 $aTypeIdx): val1 if cond else val2
  wU8(28)  // 0x1c select_t
  wU8(1)   // one result valtype
  wU8(100) // 0x64 (ref ht) — non-null
  wSLEB(aTypeIdx)
  0
}

// Emit `ix` as a STRING VALUE: a literal-union atom widens to its member string; anything
// else lowers normally (it is already a string). Used at every `string`-typed boundary that
// can receive an atom — concat operands, a `string` arg position, a `string` return.
function emitStrValue(body: i32[], ix: i32, fnIx: i32) {
  if exprIsLitAtom(ix, fnIx) {
    const rw = emitAtomToStr(body, ix, fnIx)
    return rw
  }
  const re = emitExpr(body, ix, fnIx)
  re
}

function collectS(stmts: i32[]) {
  sDeclared = false
  sNames = []
  sFieldNames = []
  sFieldStart = []
  sFieldCount = []
  sFieldTypes = []
  sFieldElemName = []
  // Nested inline-shape FIELD types intern first, so the struct decls that reference them resolve.
  collectNestedFieldShapes(stmts)
  // A `type X = {…}` that is a UNION VARIANT is collected by `collectU` into its own
  // variant table — it is NOT a standalone struct, so skip it here. Any OTHER struct
  // `type` (e.g. `ast.vl`'s `Tok`/`Diag`, declared alongside the `Node` union) IS a
  // standalone struct and is interned here, so standalone structs coexist with a union.
  let i = 0
  while i < stmts.length {
    let s = P.nodes[stmts[i]]
    // A STRUCT-ALIAS union decl (a canonicalized object intersection — single
    // inline-shape variant) is a plain named struct: intern it here (collectU
    // skipped it).
    if s is UnionDecl {
      const aliasShape = unionStructAliasShape(s.udVariants)
      if aliasShape != "" {
        if internShapeAs(s.udName, aliasShape) < 0 { return -1 }
      }
    }
    // A union variant `TypeDecl` is owned by the variant table, NOT a standalone
    // struct; a GENERIC alias declaration ("Box<T>") has no concrete shape — its
    // APPLICATIONS intern via `collectGenAliasShapes` below.
    if s is TypeDecl {
      if variantIndexOf(s.tdName) < 0 && gaeLtAt(s.tdName) < 0 {
        sDeclared = true
        sNames.push(s.tdName)
        sFieldStart.push(sFieldNames.length)
        const fields = s.tdFields
        let cnt = 0
        let fi = 0
        while fi < fields.length {
          const fnode = P.nodes[fields[fi]]
          if fnode is FieldDef {
            let code = fieldTypeCode(fnode.fdType)
            if code < 0 {
              return emitFail(
                "emitProgram: only i32 / boolean / string / array struct fields are supported",
              )
            }
            sFieldTypes.push(code)
            sFieldElemName.push(fieldRefElemName(fnode.fdType))
            sFieldNames.push(fnode.fdName)
            // A value-union field interns its box reps (collectAnnShapes parity).
            if code == 16 {
              registerValueUnionName(fieldRefElemName(fnode.fdType))
            }
            forceScalarListField(code)
            cnt = cnt + 1
          } else {
            return emitFail("emitProgram: malformed struct field")
          }
          fi = fi + 1
        }
        sFieldCount.push(cnt)
      }
    }
    i = i + 1
  }
  // Generic-alias APPLICATION shapes next (the declared structs they may
  // reference are interned above; their own names then resolve as code-15
  // struct-ref fields and annotation/literal sites).
  gaeCollectDecls(stmts)
  collectGenAliasShapes()
  // Inline object-TYPE annotation shapes first, so a literal whose values are
  // unclassifiable param reads (`{ x: n }`) still matches the annotation's shape.
  collectAnnShapes()
  collectAnonShapes()
}

// ── union collection (G1) ─────────────────────────────────────────────────────
// The struct field names + per-field wasm-type codes (`0` i32/boolean, `3` string) of
// the `TypeDecl` named `name` are recorded into the flat
// `uFieldNames`/`uFieldStart`/`uFieldCount`/`uFieldTypes` table (declaration order =
// wasm field index). The struct must exist among the top-level statements and carry
// only i32/boolean/string fields, else fails loudly. Returns 0, or -1 (via `emitFail`).
// Parse the inline-shape variant `nm` (`{x:i32,y:string}`) into the flat
// union-variant field tables — the variant-table twin of `collectAnnShapes`'s
// field split (same depth-aware `,`/`:` grammar).
function collectShapeVariantFields(nm: string) {
  const inner = nm.slice(1, nm.length - 1)
  uFieldStart.push(uFieldNames.length)
  let cnt = 0
  let depth = 0
  let start = 0
  let k = 0
  while k <= inner.length {
    const atEnd = k == inner.length
    let brk = false
    if !atEnd {
      if inner[k] == '{' || inner[k] == '[' || inner[k] == '(' {
        depth = depth + 1
      }
      if inner[k] == '}' || inner[k] == ']' || inner[k] == ')' {
        depth = depth - 1
      }
      if inner[k] == ',' && depth == 0 { brk = true }
    } else {
      brk = true
    }
    if brk {
      const part = inner.slice(start, k)
      let ci = part.indexOf(":")
      if ci <= 0 {
        return emitFail("emitProgram: malformed inline union-variant shape")
      }
      let ftxt = part.slice(ci + 1, part.length)
      let fc = nameFieldCode(ftxt)
      if fc < 0 {
        return emitFail(
          "emitProgram: only i32 / boolean / string / array union-variant fields are supported",
        )
      }
      uFieldTypes.push(fc)
      uFieldElemName.push(shapeFieldElemName(ftxt, fc))
      uFieldNames.push(part.slice(0, ci))
      cnt = cnt + 1
      start = k + 1
    }
    k = k + 1
  }
  uFieldCount.push(cnt)
  0
}

// The ELEMENT/TARGET name a shape-text field records in `uFieldElemName`: a
// ref-list field its element name, a nested-struct field its (non-null) target
// name, a value-union field its atom-set name; "" otherwise.
function shapeFieldElemName(ftxt: string, code: i32) {
  if code == 5 { return refArrElemName(ftxt) }
  if code == 15 {
    const nb = nullablePartOf(ftxt)
    if nb != "" { return nb }
    return ftxt
  }
  if code == 16 { return ftxt }
  ""
}

function collectVariantFields(stmts: i32[], name: string) {
  // An INLINE-SHAPE variant (`{x:i32}` inside `{x:i32}|{y:i32}`) carries its
  // fields in its own text — parse them (the annotation-shape field grammar)
  // instead of looking for a TypeDecl.
  if name.length >= 2 {
    if name[0] == '{' && name[1] != '[' && name[name.length - 1] == '}' {
      return collectShapeVariantFields(name)
    }
  }
  let i = 0
  while i < stmts.length {
    let s = P.nodes[stmts[i]]
    if s is TypeDecl {
      if s.tdName == name {
        uFieldStart.push(uFieldNames.length)
        const fields = s.tdFields
        let cnt = 0
        let fi = 0
        while fi < fields.length {
          const fnode = P.nodes[fields[fi]]
          if fnode is FieldDef {
            let code = fieldTypeCode(fnode.fdType)
            if code < 0 {
              return emitFail(
                "emitProgram: only i32 / boolean / string / array union-variant fields are supported",
              )
            }
            uFieldTypes.push(code)
            uFieldElemName.push(fieldRefElemName(fnode.fdType))
            uFieldNames.push(fnode.fdName)
            cnt = cnt + 1
          } else {
            return emitFail("emitProgram: malformed union-variant field")
          }
          fi = fi + 1
        }
        uFieldCount.push(cnt)
        return 0
      }
    }
    i = i + 1
  }
  emitFail("emitProgram: union variant names an unknown struct type")
}

// The wasm-type code (`0` i32, `3` string) of variant `vi`'s field at field index `fi`.
function variantFieldTypeAt(vi: i32, fi: i32) {
  uFieldTypes[uFieldStart[vi] + fi]
}

// The ref-list table SLOT of variant `vi`'s ref-list field `fi`, or -1 if not a ref list.
function variantFieldRefSlot(vi: i32, fi: i32) {
  rlSlotByName(uFieldElemName[uFieldStart[vi] + fi])
}

// The structural signature of variant `vi` — its field names joined with `,` (a
// stable per-shape key). Two variants with the same field-name set share a sig (and
// so, under structural typing, are the same variant — `docs/unions.md`); the slice's
// AST-style unions use DISTINCT field-name prefixes per variant, so every sig differs.
function variantSig(vi: i32) {
  let out = ""
  let start = uFieldStart[vi]
  let cnt = uFieldCount[vi]
  let j = 0
  while j < cnt {
    if j > 0 { out = out + "," }
    out = out + uFieldNames[start + j]
    j = j + 1
  }
  out
}

// Assign each variant its GLOBAL tag = its rank when the variants are ordered by
// structural signature (mirroring `toWasm.ts`'s sorted `variantKey` tag assignment).
// `uTags[i]` is variant i's tag: the number of variants whose sig sorts strictly
// before variant i's (sigs are distinct, so this is a dense 0..n-1 permutation).
function assignTags() {
  uTags = []
  let i = 0
  while i < uVariants.length {
    const sigI = variantSig(i)
    let rank = 0
    let j = 0
    while j < uVariants.length {
      if j != i {
        const sigJ = variantSig(j)
        if strLess(sigJ, sigI) { rank = rank + 1 }
      }
      j = j + 1
    }
    uTags.push(rank)
    i = i + 1
  }
  0
}

// The GLOBALLY-stable tag of a value-union atom: every struct variant takes the
// dense ranks `0 .. uVariants.length-1` (`assignTags`), so atom kinds claim the
// fixed slots above them. Stable across every union in the module (mirroring the
// host's interned `tagOf(variantKey)` global table), so a value boxed as
// `string | i32 | boolean` keeps its tag inside the sub-union `string | i32`.
function scalarTagOf(atom: string) { uVariants.length + valueAtomKind(atom) }

// The interned VALUE-BOX heap-type index for a scalar atom (`boolean` shares the
// i32 box — same wasm rep), or -1 for `string`/`null` (no inner box: a string ref
// is already an `anyref` subtype; a null payload is `ref.null`).
function vbHeapIdxOfAtom(atom: string) {
  let k = valueAtomKind(atom)
  if k == 0 || k == 1 { return vbI32Idx }
  if k == 3 { return vbI64Idx }
  if k == 4 { return vbF64Idx }
  if k == 5 { return vbF32Idx }
  -1
}

// Register the VALUE union `name` in the per-union table (no variant structs —
// its atoms tag via `scalarTagOf`, its payloads ride the shared value boxes).
// Idempotent; a non-value-union name is a no-op. Callable from any collection
// phase (it reads no statement table) — `collectAnnShapes` registers a union
// FIELD's atom set through it after `collectU` has run.
function registerValueUnionName(name: string) {
  if isUName(name) { return 0 }
  if !isValueUnionName(name) { return 0 }
  uDeclared = true
  unNames.push(name)
  unMemberSet.push(name)
  unVarStart.push(uVariants.length)
  unVarCount.push(0)
  markValueUnionAtoms(name)
  0
}

// Mark the per-rep value-box usage flags for every scalar atom of the value union
// `name` (registration-time, so `mAssignTypeIndices` interns exactly the used reps).
function markValueUnionAtoms(name: string) {
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  let i = 0
  while i < atoms.length {
    let k = valueAtomKind(atoms[i])
    if k == 0 || k == 1 { vbI32Used = true }
    if k == 3 { vbI64Used = true }
    if k == 4 { vbF64Used = true }
    if k == 5 { vbF32Used = true }
    // A LIST member (codes 7..10) forces its list type so the wrapper heap the box payload
    // rides exists — the union annotation alone may be the only mention of that list type.
    if k == 7 {
      lUsed = true
      aUsed = true
    }
    if k == 8 { fa64Used = true }
    if k == 9 {
      slUsed = true
      aUsed = true
    }
    if k == 10 { ia64Used = true }
    i = i + 1
  }
  0
}

// Register the inline union synthetic name `name` (e.g. `"A|B"`) as a union alias in
// the per-union tables, exactly as `collectU` registers a `UnionDecl`: record the
// name + its variant-slice range, append each member to the GLOBAL `uVariants` list,
// and collect each member's fields into the flat table. A no-op if `name` is already
// a registered union (a named alias OR a previously-seen inline annotation), or if it
// is not an inline struct-variant union. Returns 0, or -1 (via `emitFail`).
function registerInlineUnion(stmts: i32[], name: string) {
  if isUName(name) { return 0 }
  // A VALUE union (`i32 | null`, `string | i32`, `i32 | f64`) registers the name
  // alone — it owns NO variant structs (its members are scalar atoms whose tags
  // come from `scalarTagOf` and whose payloads ride the shared value boxes), so
  // its variant slice is empty. Registering interns the shared box (`uDeclared`)
  // and the per-rep value boxes it needs.
  if isValueUnionName(name) { return registerValueUnionName(name) }
  // A union used ONLY as a COLLECTION element / value (`(C | S)[]`, `{[string]: C | S}`)
  // registers that INNER union — without this a union that never appears in a param /
  // return / let / field annotation (only inside a collection) is never interned, so an
  // `is` over a read element fails ("`is` test but no union type declared"). RECURSE on the
  // inner name through the same dispatch: a VALUE element union → the shared box (the
  // `(string|i32)[]` case `parenUnionArrElemName` already covered), a STRUCT / heterogeneous
  // element union → its variant structs, and a non-union inner (`i32`, a struct, a registered
  // alias) → a self-gated no-op. Map values nest (`{[string]: (C|S)[]}` → `(C|S)[]` → `C|S`).
  const pun = parenUnionArrElemName(name)
  if pun != "" { return registerInlineUnion(stmts, pun) }
  // A NESTED array of an inline union (`(C|D)[][]`, `(C|D)[][][]`): `parenUnionArrElemName` only
  // matches a SINGLE-bracket `(…)[]`, so strip the OUTER `[]` and recurse on the element list,
  // reaching the inner union at any depth — the registration dual of the recursive ref-array
  // interning. Bottoms out at the 1D `(…)[]` (the `pun` path above).
  if nameIsArray(name) {
    const inner = name.slice(0, name.length - 2)
    if nameIsArray(inner) { return registerInlineUnion(stmts, inner) }
  }
  if nameIsMap(name) {
    const mvn = mapValNameOf(name)
    if mvn != "" { return registerInlineUnion(stmts, mvn) }
  }
  // A function-type annotation (`(i32) => C | S`) carries an inline union in its RETURN (a closure
  // value whose result is a union). Register that return union so a value call's result narrows —
  // the function type itself is not a union. Mirrors the array/map element recursion above.
  if name.length > 0 && name[0] == '(' {
    const fra = annArrowAt(name)
    if fra >= 1 {
      return registerInlineUnion(
        stmts,
        monoUnwrapParens(name.slice(fra + 2, name.length)),
      )
    }
  }
  if !isVariantBoxUnion(stmts, name) { return 0 }
  const atoms: string[] = []
  splitUnionAtoms(name, atoms)
  uDeclared = true
  unNames.push(name)
  unMemberSet.push(name)
  unVarStart.push(uVariants.length)
  // Only STRUCT members occupy variant slots (a `null` atom rides the tag, a value-atom
  // tags via `scalarTagOf` and boxes into the shared value boxes). Count + push the
  // struct variants; mark the value-box reps the scalar atoms need (the MIXED case).
  let nStructs = 0
  let cnt = 0
  while cnt < atoms.length {
    if atoms[cnt] != "null" {
      if isStructAtom(stmts, atoms[cnt]) { nStructs = nStructs + 1 }
    }
    cnt = cnt + 1
  }
  unVarCount.push(nStructs)
  let vi = 0
  while vi < atoms.length {
    if atoms[vi] != "null" {
      if isStructAtom(stmts, atoms[vi]) {
        uVariants.push(atoms[vi])
        if collectVariantFields(stmts, atoms[vi]) < 0 { return -1 }
      }
    }
    vi = vi + 1
  }
  // A MIXED union's scalar members box exactly like a value union's — intern their
  // per-rep value boxes (a no-op for an all-struct union: no value atoms).
  markValueUnionAtoms(name)
  0
}

// ── usage-driven `let x = null` nullable-hole inference (A-infer-null) ───────
// The host's hole-bearing `null`: an UN-ANNOTATED `let x = null` is NOT pinned to
// the exact `null` type — a later assignment `x = e` fills the hole's `T`, so `x`
// is the value union `T | null`. The native mirror infers `T` once at collection
// time (the FIRST classifiable assignment in the binding's enclosing statement
// list, descending into branch/loop blocks but NOT nested function bodies — their
// same-named locals are different bindings), registers `T|null` as a value union
// (interning its box reps), and records it per LetDecl arena index so every later
// classifier (`letIsUnion` / `letUnionNameOf` / `globalCellKind`) sees the union.
// (The `nliLetIxs`/`nliNames` tables are declared with the narrowing stack —
// module-level `let`s must precede their first textual use site.)

// The inferred `T|null` union name of the null-init `LetDecl` at `letIx`, or "".
function nliNameOf(letIx: i32) {
  let i = 0
  while i < nliLetIxs.length {
    if nliLetIxs[i] == letIx { return nliNames[i] }
    i = i + 1
  }
  ""
}

// Infer + register the null hole of the un-annotated `let x = null` at
// `walk[i]`, scanning the REST of `walk` for the filling assignment.
function nliInferLet(walk: i32[], i: i32) {
  let s = P.nodes[walk[i]]
  if s is LetDecl {
    if s.letType < 0 && s.letInit >= 0 {
      const ini = P.nodes[s.letInit]
      if ini is NullLit {
        let atom = nliScanStmts(walk, i + 1, s.letName)
        if atom != "" {
          const nn = atom + "|null"
          registerValueUnionName(nn)
          nliLetIxs.push(walk[i])
          nliNames.push(nn)
        }
      }
    }
  }
  0
}

// The value-union NAME an un-annotated if-EXPRESSION binding init carries (`const x =
// if c then 5 else null` → `i32|null`, the else-less `if c then 5` → `i32|null`, `if c
// then 5 else "hi"` → `i32|string`), or "" when it is not a value union the box can hold
// (a non-union `if c then 5 else 6`, a `string | null` niche, or an arm the static pre-
// pass cannot classify). The canonical name is the deduped arm atoms (arm order) with a
// trailing `|null` when any arm / the else-less path is null.
function ifExprNliName(ifIx: i32) {
  const atoms: string[] = []
  const hn = ifExprCollectAtoms(ifIx, atoms)
  if hn == -2 { return "" }
  if atoms.length == 0 { return "" }
  // Mixed NUMERIC arms WIDEN to a single numeric (`i32` + `f64` → `f64`, #490) — they
  // are not a union, and this static atom list cannot do that lattice join. Bail so the
  // numeric value-position-if path (`letIsF64`/`letIsI64`) handles them. A SINGLE numeric
  // scalar (optionally + null, + a non-numeric like `string`) is fine.
  let numCount = 0
  let j = 0
  while j < atoms.length {
    let k = valueAtomKind(atoms[j])
    if k == 0 || k == 3 || k == 4 || k == 5 { numCount = numCount + 1 }
    j = j + 1
  }
  if numCount >= 2 { return "" }
  let nm = ""
  let i = 0
  while i < atoms.length {
    if nm != "" { nm = nm + "|" }
    nm = nm + atoms[i]
    i = i + 1
  }
  if hn == 1 { nm = nm + "|null" }
  // Only a value union the box rep can hold (≥2 non-null atoms, or one NUMERIC scalar +
  // null) registers here — a `string | null` niche / a non-union stay on their own paths.
  if !isValueUnionName(nm) { return "" }
  nm
}

// Infer + register the value union of an un-annotated `const x = <if-expression>` at
// `walk[i]` — the if-expression counterpart of `nliInferLet`. Records it in the same
// `nli` tables so `nliNameOf` drives the slot classification (`letIsUnion` → kind 4 box)
// and the binding-init emit (`emitNullableIfBinding` via `letUNm`), reusing the
// annotated-binding lowering with NO annotation. The union NAME comes from the CHECKER's
// inferred-binding export (`inferLetNameOf`) — which already resolved the arm types
// (so an ident/expression arm `if c then v else null` works) and the numeric-widening
// join (`if c then 1 else 2.5` is f64, not a union) — falling back to a static atom
// derivation (`ifExprNliName`) for any binding the export does not carry.
function nliInferIfLet(walk: i32[], i: i32) {
  let s = P.nodes[walk[i]]
  if s is LetDecl {
    if s.letType < 0 && s.letInit >= 0 {
      if exprIsIfStmt(s.letInit) {
        let nn = inferLetNameOf(walk[i])
        if nn == "" { nn = ifExprNliName(s.letInit) }
        if nn != "" {
          registerValueUnionName(nn)
          nliLetIxs.push(walk[i])
          nliNames.push(nn)
        }
      }
    }
  }
  0
}

// Scan every top-level FuncDecl's parameter + return annotations and every top-level
// `let`/`const` annotation for INLINE union types, registering each as a synthetic
// union alias (so it interns its variant shapes + heap types exactly like a named
// alias). Must run AFTER the `UnionDecl` pass (so an inline name matching a named
// alias is a no-op) and BEFORE `assignTags` (which ranks the FINAL `uVariants` set).
// Returns 0, or -1 (via `emitFail`).
function collectInlineUnions(stmts: i32[]) {
  nliLetIxs = []
  nliNames = []
  collectInlineUnionsIn(stmts, stmts)
}

// The recursive worker: scan the statement list `walk` (registering against the
// TOP-LEVEL `stmts`, where struct `TypeDecl`s live), descending into function
// bodies and branch blocks so a `let v: A | B = …` INSIDE a function (or a nested
// `if`/loop body) registers its inline union too — value unions especially appear
// as local annotations, not just at module scope.
function collectInlineUnionsIn(stmts: i32[], walk: i32[]) {
  let i = 0
  while i < walk.length {
    let s = P.nodes[walk[i]]
    if s is FuncDecl {
      // Read both annotation-bearing fields of the narrowed `s` BEFORE the inner loop
      // introduces a `Param` narrowing (a fresh `is`-narrowing pins its own binding;
      // reading `s.fnRet` after it would no longer see `s`'s FuncDecl narrowing).
      const params = s.fnParams
      const retTy = s.fnRet
      const fnBody = s.fnBody
      if registerInlineUnion(stmts, tyNameOf(retTy)) < 0 { return -1 }
      let pi = 0
      while pi < params.length {
        const p = P.nodes[params[pi]]
        if p is Param {
          if registerInlineUnion(stmts, tyNameOf(p.parType)) < 0 { return -1 }
        }
        pi = pi + 1
      }
      if collectInlineUnionsBlock(stmts, fnBody) < 0 { return -1 }
    } else if s is LetDecl {
      if registerInlineUnion(stmts, tyNameOf(s.letType)) < 0 { return -1 }
      // Usage-driven `let x = null` hole (A-infer-null): infer + register `T|null`.
      nliInferLet(walk, i)
      // An un-annotated `const x = if … then … else …` whose arms join to a value
      // union: register the inferred name so the slot classifies + lowers like an
      // annotated nullable/value-union binding.
      nliInferIfLet(walk, i)
    } else if s is TypeDecl {
      // A struct FIELD annotated with an inline union (`type T = { v: A | B }`,
      // `{ v: A | i32 }`) registers that union here — in `collectU`, BEFORE `collectS`
      // interns the variant heap types — so the field classifies as the kind-16 box
      // (`fieldTypeCode` sees `isUName`). A value-union field is interned at field
      // collection instead; this is the struct/heterogeneous variant-box case.
      const flds = s.tdFields
      let tfi = 0
      while tfi < flds.length {
        if flds[tfi] >= 0 {
          const fdn = P.nodes[flds[tfi]]
          if fdn is FieldDef {
            if registerInlineUnion(stmts, tyNameOf(fdn.fdType)) < 0 {
              return -1
            }
          }
        }
        tfi = tfi + 1
      }
    } else if s is IfStmt {
      const thenB = s.ifThen
      const elseN = s.ifElse
      if collectInlineUnionsBlock(stmts, thenB) < 0 { return -1 }
      if elseN >= 0 {
        const els = P.nodes[elseN]
        if els is Block {
          if collectInlineUnionsBlock(stmts, elseN) < 0 { return -1 }
        } else {
          // `else if`: a lone nested statement — wrap it in a one-shot walk.
          const one: i32[] = []
          one.push(elseN)
          if collectInlineUnionsIn(stmts, one) < 0 { return -1 }
        }
      }
    } else if s is WhileStmt {
      if collectInlineUnionsBlock(stmts, s.whileBody) < 0 { return -1 }
    } else if s is ForRange {
      if collectInlineUnionsBlock(stmts, s.frBody) < 0 { return -1 }
    } else if s is ForIn {
      if collectInlineUnionsBlock(stmts, s.fiBody) < 0 { return -1 }
    }
    i = i + 1
  }
  0
}

// Recurse into a Block node's statement list (a function body / branch arm).
function collectInlineUnionsBlock(stmts: i32[], blockIx: i32) {
  if blockIx < 0 { return 0 }
  let b = P.nodes[blockIx]
  if b is Block { return collectInlineUnionsIn(stmts, b.blkStmts) }
  0
}

// Scan the top-level statements for EVERY union alias `type N = A | B | …` (a
// `UnionDecl`); for each, record its name + variant-slice range in the per-union table
// (`unNames`/`unVarStart`/`unVarCount`), append its variant struct names to the GLOBAL
// `uVariants` list, collect each variant's i32 fields into the flat table, and finally
// assign globally-unique tags across all variants of all unions. Multiple unions
// coexist (mirroring the multi-struct table). Returns 0, or -1 (via `emitFail`).
function collectU(stmts: i32[]) {
  uDeclared = false
  vbI32Used = false
  vbI64Used = false
  vbF32Used = false
  vbF64Used = false
  unNames = []
  unMemberSet = []
  unVarStart = []
  unVarCount = []
  uVariants = []
  uFieldNames = []
  uFieldStart = []
  uFieldCount = []
  uFieldTypes = []
  uFieldElemName = []
  let i = 0
  while i < stmts.length {
    let s = P.nodes[stmts[i]]
    if s is UnionDecl {
      // A STRUCT-ALIAS union (single inline-shape variant — a canonicalized
      // `type AB = {…} & {…}` object intersection) is a named STRUCT, not a
      // union: `collectS` interns it; skip it here.
      if unionStructAliasShape(s.udVariants) != "" {
        i = i + 1
        continue
      }
      uDeclared = true
      const vs = s.udVariants
      if vs.length < 1 {
        return emitFail("emitProgram: union must have at least one variant")
      }
      unNames.push(s.udName)
      // The alias's full member set, pipe-joined (atom members like `null` kept).
      let udSet = ""
      let usj = 0
      while usj < vs.length {
        if udSet != "" { udSet = udSet + "|" }
        udSet = udSet + vs[usj]
        usj = usj + 1
      }
      unMemberSet.push(udSet)
      unVarStart.push(uVariants.length)
      // Only the STRUCT variants get a variant struct + fields; an atom member
      // (`string`/`i32`/…) of a MIXED union (`{x:i32} | string`) boxes through the shared
      // value boxes, exactly as the inline-annotation path registers it. (A pure struct
      // union has every variant a struct, so this stays byte-identical for `Cat | Dog`.)
      let nStructs = 0
      let nc = 0
      while nc < vs.length {
        if vs[nc] != "null" {
          if isStructAtom(stmts, vs[nc]) { nStructs = nStructs + 1 }
        }
        nc = nc + 1
      }
      unVarCount.push(nStructs)
      let vi = 0
      while vi < vs.length {
        if vs[vi] != "null" {
          if isStructAtom(stmts, vs[vi]) {
            uVariants.push(vs[vi])
            if collectVariantFields(stmts, vs[vi]) < 0 { return -1 }
          }
        }
        vi = vi + 1
      }
      // A MIXED union's scalar members intern their per-rep value boxes (no-op for an
      // all-struct union).
      markValueUnionAtoms(udSet)
    }
    i = i + 1
  }
  // Inline union annotations (`v: A | B`) carry no `UnionDecl`; register each as a
  // synthetic alias keyed on its pipe-joined name, so its variant shapes are interned
  // and every name-keyed lookup treats it like a named alias. Runs after the
  // `UnionDecl` pass (so a matching named alias makes the inline form a no-op) and
  // before `assignTags` (which ranks the FINAL variant set).
  if collectInlineUnions(stmts) < 0 { return -1 }
  // Inferred VALUE-union returns (`i32 | string` / `i32 | null`) AND inferred STRUCT-union
  // returns (`Cat | Dog`): register each so its reps intern — even when an inferred
  // return is the program's ONLY union. `registerInlineUnion` dispatches on the name
  // shape (a value union → the shared box; a struct union → its variant structs) and
  // self-gates / dedups (`isUName`), so scalar/array entries and already-declared unions
  // are no-ops.
  let iru = 0
  while iru < inferRetCount() {
    if registerInlineUnion(stmts, inferRetTyAt(iru)) < 0 { return -1 }
    iru = iru + 1
  }
  // Inferred VALUE-union BINDINGS (`const x = if c then v else null`): same treatment,
  // so an inferred binding union's box reps intern even when it is the program's only
  // value union and `nliInferIfLet` is the only consumer. Self-gating, like the returns.
  let ilu = 0
  while ilu < inferLetCount() {
    registerValueUnionName(inferLetTyAt(ilu))
    ilu = ilu + 1
  }
  if uDeclared {
    if assignTags() < 0 { return -1 }
  }
  0
}

// The per-union table index that OWNS global variant `vi` (the union whose variant
// slice contains it), or -1. Mirrors the `structIndexByName`-style resolver.
function unionOfVariant(vi: i32) {
  let u = 0
  while u < unNames.length {
    let start = unVarStart[u]
    if vi >= start && vi < start + unVarCount[u] { return u }
    u = u + 1
  }
  -1
}

// The position of variant struct `name` in `uVariants` (its heap-type is `uVarIdx +
// pos`), or -1 if `name` is not a variant of the declared union.
function variantIndexOf(name: string) {
  let i = 0
  while i < uVariants.length {
    if uVariants[i] == name { return i }
    i = i + 1
  }
  -1
}

// True if the type-name `name` is ANY declared union alias.
function isUName(name: string) {
  let u = 0
  while u < unNames.length {
    if unNames[u] == name { return true }
    u = u + 1
  }
  false
}

// The union alias name that owns global variant `vi` (assumes `vi` is a variant of some
// declared union), or "" if none. Used to intern a ref-list-of-union by the SPECIFIC
// union (so `Node[]` and `Ty[]` are distinct table slots).
function unionNameOfVariant(vi: i32) {
  let u = unionOfVariant(vi)
  if u >= 0 { return unNames[u] }
  ""
}

// The wasm struct field index of `field` within variant `vi` (declaration order), or
// -1 if that variant has no such field.
function variantFieldIndex(vi: i32, field: string) {
  let start = uFieldStart[vi]
  let cnt = uFieldCount[vi]
  let j = 0
  while j < cnt {
    if uFieldNames[start + j] == field { return j }
    j = j + 1
  }
  -1
}

// True if the function `name` declares the struct as its return type (flat lookup
// over the `fRetRef` flags `buildFnMap` recorded — no arena rescan).
function fnRetStruct(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetRef[i] == 1
}

// True if the parameter `name` of function `fnIx` is the struct type.
function paramStruct(fnIx: i32, name: string) {
  isSName(tyNameOf(paramTypeNode(fnIx, name)))
}
// True if evaluating the expression at `exprIx` yields the struct (a `(ref $0)`):
// an object literal (constructs it), a struct-returning call, a struct param/local
// reference, or a parenthesized struct expression. Anything else is an i32 value.
function exprStruct(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is ObjLit { return true }
  if e is Paren { return exprStruct(e.parInner, fnIx) }
  // An if-EXPRESSION whose branch join is a struct — an un-annotated binding classifies kind 1
  // (the THEN arm's rep, the arms agreeing by the checker), matching `structIndexOfExpr`.
  if e is IfStmt {
    const tv = ifThenValueIx(exprIx)
    return tv >= 0 && exprStruct(tv, fnIx)
  }
  // A `m[k] ?? default` over a STRUCT-valued map (`{[string]: S}`) yields the value struct — so a
  // bound `const p = m[k] ?? d` classifies as a struct local and `(m[k] ?? d).x` resolves.
  if e is BinExpr {
    const cms = coalesceMvSlot(exprIx, fnIx)
    if cms >= 0 { return mvValKind[cms] == 1 }
    // A `<S|null> ?? <S>` coalesce yields the non-null struct (the generic nullable-struct `??` emit) —
    // so a bound `const p = r ?? d` classifies struct and `(r ?? d).x` resolves. The left is the
    // nullable struct; the right is a plain struct default.
    if e.binOp == "??" {
      if exprNullableStruct(e.binLeft, fnIx) { return true }
      return exprStruct(e.binRight, fnIx)
    }
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetStruct(callee.identName) { return true }
      // A struct-returning function VALUE (a binding / `(i32) => S` param callee): its
      // resolved `>sN;` sig (mirrors `structIndexOfExpr`'s closure case). Falls through to the
      // per-node-type fallback below when the sig path misses (a factory-inferred value).
      if calleeReturnsStructIdx(callee.identName, fnIx) >= 0 { return true }
    }
    // A FIELD-CLOSURE call (`(a."*")(2)` — a rewritten operator/index trap)
    // yields the field function's return struct (mirrors `structIndexOfExpr`).
    if callee is Member {
      if (
        drwFieldClosure(structIndexOfExpr(callee.memObj, fnIx), callee.memProp)
      ) {
        const cfe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
        if cfe >= 0 {
          if fRetRef[cfe] == 1 { return true }
        }
      }
    }
    // FALLBACK (scoped to a CALL): a struct-returning closure value call whose callee the cases above
    // miss — an INDEXED closure-array element (`arr[i](x)`) or a factory-inferred value. The cheap
    // NO-RENDER `nodeTyIsObj` reads the checker's per-node type. Boolean dual of `structIndexOfExpr`'s
    // fallback, so `letIsStruct` classifies such a binding (kind 1) and its field reads resolve.
    return nodeTyIsObj(exprIx)
  }
  if e is Ident {
    if paramStruct(fnIx, e.identName) { return true }
    if declaredStruct(e.identName) { return true }
    return globalIsStruct(e.identName)
  }
  // `xs[i]` over a STRUCT-element ref list yields the struct (G7-ref). Per-slot: the
  // element kind comes from the receiver's distinct ref-list slot (1 = struct).
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      let slot = refListSlotOfExpr(e.idxArr, fnIx)
      return rlElemKindTbl[slot] == 1
    }
  }
  // A NULLABLE struct value (`S | null`) participates in the struct machinery
  // (member layout resolution); the field-read path inserts the non-null recover.
  exprNullableStruct(exprIx, fnIx)
}

// True if the already-collected declared local `name` is a nullable struct (code 9).
function declaredNulRef(name: string) { declaredKind(name) == 9 }

// True if `name` is a declared NULLABLE function-value local (`fn | null`, kind 19) — the
// closure dual of `declaredNulRef`.
function declaredNulClosure(name: string) { declaredKind(name) == 19 }

// True if the expression at `exprIx` is a NULLABLE function value (`fn | null`, kind 19) —
// currently a kind-19 local ident. Drives the `== null` / `!= null` test (`ref.is_null`)
// and the narrowed-call recover, the closure analogue of `exprNullableStruct`.
function exprNulClosure(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const ux = unwrapParen(exprIx)
  const e = P.nodes[ux]
  if e is Ident {
    if paramNulClosure(fnIx, e.identName) { return true }
    if declaredNulClosure(e.identName) { return true }
    // A module-global nullable-closure cell (kind 19).
    const gl = globalLetOf(e.identName)
    if gl >= 0 { return globalCellKind(gl) == 19 }
    return false
  }
  // A nullable-closure struct FIELD read (`recv.op` over a `((i32) => i32) | null` field,
  // code 22): the raw `(ref null $cloStruct)` — its `!= null` lowers to `ref.is_null` and
  // the narrowed call recovers non-null (`ref.as_non_null`) at the call site.
  if e is Member { return memberFieldCode(ux, fnIx) == 22 }
  // A bare `m[k]` over a FUNCTION-valued map (mv kind 14) reads back a NULLABLE closure
  // `(ref null $cloStruct)` — `const f = m[k]` binds the kind-19 niche, narrowed `if f != null`.
  if e is Index {
    const mrs = mapReadMvSlot(ux, fnIx)
    if mrs >= 0 { return mvValKind[mrs] == 14 }
  }
  false
}

// True if an UN-annotated `const f = <init>` should infer a NULLABLE-closure (kind 19) slot —
// its init reads back a nullable closure (a bare `m[k]` over a function-valued map). The
// annotated form is `letIsNulClosure`; this is its init-driven dual (it lives here, not in
// `emit_query`, because it consults the wasmEmit-side `exprNulClosure`).
function letInfersNulClosure(letIx: i32, fnIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 { return false }
    if d.letInit < 0 { return false }
    return exprNulClosure(d.letInit, fnIx)
  }
  false
}

// True if the already-collected declared local `name` is a nullable i32 list (kind 15).
function declaredNulList(name: string) { declaredKind(name) == 15 }

// True if the already-collected declared local `name` is a struct ref. Resolves to
// the IN-SCOPE binding's slot (so a same-named binding in a sibling/inner block reads
// ITS own valtype, not an unrelated branch's).
function declaredStruct(name: string) { declaredKind(name) == 1 }

// True if the `LetDecl` at `letIx` declares a struct-typed local: its annotation
// names the struct, OR its initializer produces the struct. Picks the local's
// valtype (`(ref $0)` vs i32) in `collectLocals`.
// True if the binding's annotation is a SINGLE inline object shape (`{ … }`, with a trailing `| null`
// stripped) that is NOT interned as a struct — i.e. its shape could not be built (an unsupported field
// type). A map (`{[…]}`) is excluded. Checked only AFTER union / nullable-struct / struct classification,
// so a valid inline-struct binding never reaches it; this catches the un-internable remainder so it
// rejects cleanly instead of mis-emitting its object literal (a soundness guard).
function letAnnIsUninternedShape(letIx: i32) {
  const d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType < 0 { return false }
    let nm = tyNameOf(d.letType)
    const nb = nullablePartOf(nm)
    if nb != "" { nm = nb }
    if nm.length < 2 { return false }
    if nm[0] != '{' || nm[1] == '[' || nm[nm.length - 1] != '}' { return false }
    return structIndexByName(nm) < 0
  }
  false
}

function letIsStruct(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if isSName(lt.tyName) { return true }
      }
    }
    return exprStruct(d.letInit, fnIx)
  }
  false
}

// True if the `LetDecl` at `letIx` binds a CONCRETE union-VARIANT value (`const c: Cat =
// …` where `Cat` is a variant of the declared union) — a kind-8 local `(ref $(uVarIdx +
// vi))`, distinct from the union box (kind 4) and a standalone struct (kind 1). Annotation
// first, else the init's variant value (a variant param/local read). Checked AFTER the
// struct/union local cases so only an explicit variant annotation / variant-valued init
// reaches here.
function letIsVariant(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if variantIndexOf(lt.tyName) >= 0 { return true }
      }
    }
    return exprVariantIndex(d.letInit, fnIx) >= 0
  }
  false
}

// The union-variant table index a variant-typed `LetDecl` binds (annotation first, else
// the init's variant value), or -1.
function variantIndexOfLet(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        const vi = variantIndexOf(lt.tyName)
        if vi >= 0 { return vi }
      }
    }
    return exprVariantIndex(d.letInit, fnIx)
  }
  -1
}

// ── multi-struct index resolution ─────────────────────────────────────────────
// Parallel to the boolean `exprStruct` family, these return the STRUCT TABLE INDEX a
// struct-typed expression / param / local / return produces, so a field read/write
// can resolve the right heap type + field layout. Return -1 when not a struct.

// The struct table index of the param `name` of function `fnIx` (from its annotation),
// or -1.
function paramStructIndex(fnIx: i32, name: string) {
  if fnIx < 0 {
    return -1 // module-scope initializer (no enclosing function)
  }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    const params = fn.fnParams
    let i = 0
    while i < params.length {
      const p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            const ty = P.nodes[p.parType]
            if ty is TypeRef {
              // A plain struct name, or the `S | null` nullable BASE. (NOT a union
              // variant — a variant-typed param rides the gap-#2 path, and its
              // VARIANT index must not leak into the struct tables.)
              const psi = structIndexByName(ty.tyName)
              if psi >= 0 { return psi }
              const pbase = nullablePartOf(ty.tyName)
              if pbase != "" { return structIndexOfTypeName(pbase) }
            }
          }
          return -1
        }
      }
      i = i + 1
    }
  }
  -1
}

// The union-variant table index of the param `name` of function `fnIx` (when its
// annotation names a VARIANT struct of the declared union, e.g. `o: TyObj`), or -1.
// A variant-struct param's value IS the concrete variant struct ref `(ref $(uVarIdx +
// vi))` — already narrowed/unboxed by the caller — so a field read on it reads the
// variant struct directly (no box unwrap), the gap-#2 boundary.
function paramVariantIndex(fnIx: i32, name: string) {
  variantIndexOf(tyNameOf(paramTypeNode(fnIx, name)))
}

// The union-variant table index an expression at `exprIx` yields a CONCRETE variant
// struct ref for (a variant-typed param reference, or a parenthesized one), or -1. The
// receiver shape for a gap-#2 field read `o.field` where `o: TyObj`.
function exprVariantIndex(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return -1 }
  const e = P.nodes[exprIx]
  if e is Paren { return exprVariantIndex(e.parInner, fnIx) }
  if e is Ident {
    const pvi = paramVariantIndex(fnIx, e.identName)
    if pvi >= 0 { return pvi }
    return declaredVariantIndex(e.identName)
  }
  // A call to a `: Cat`-returning function yields the concrete variant ref.
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident { return fnRetVariantIndex(callee.identName) }
  }
  // An index into a `Cat[]` variant-element ref list yields the bare variant struct.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      return variantIndexOf(refListElemNameOfExpr(e.idxArr, fnIx))
    }
  }
  -1
}

// The union-VARIANT table index a function `name` returns (its `: Cat` return
// annotation), or -1.
function fnRetVariantIndex(name: string) {
  const fe = fnIndexOf(name)
  if fe >= 0 {
    const fn = P.nodes[fnStmts[fe]]
    if fn is FuncDecl {
      if fn.fnRet >= 0 {
        const rt = P.nodes[fn.fnRet]
        if rt is TypeRef { return variantIndexOf(rt.tyName) }
      }
    }
  }
  -1
}

// The union-variant table index of the declared local `name` (a kind-8 variant local —
// its `localStructIdx` holds the variant index), or -1.
function declaredVariantIndex(name: string) {
  let slot = declaredSlotOf(name)
  if slot < 0 { return -1 }
  if localIsRef[slot] == 8 { return localStructIdx[slot] }
  -1
}

// The struct table index of the declared local `name` (recorded in `localStructIdx`),
// or -1 if `name` is not a struct local.
function declaredStructIndex(name: string) {
  let slot = declaredSlotOf(name)
  if slot < 0 { return -1 }
  if localIsRef[slot] == 1 { return localStructIdx[slot] }
  if localIsRef[slot] == 9 { return localStructIdx[slot] }
  -1
}

// The struct table index a function `name` returns (recorded in `fRetStructIdx`), or -1.
function fnRetStructIndex(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return -1 }
  fRetStructIdx[i]
}

// The struct table index of a module global `name` (from its annotation/initializer),
// or -1.
function globalStructIndex(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return -1 }
  structIndexOfLet(li, -1)
}

// The struct table index that the expression at `exprIx` produces, or -1 if it is not
// a struct value. Mirrors `exprStruct`'s cases.
// The struct table index of a CAPTURED struct-ref variable `name` of the capturing
// lifted function `fnIx`, or -1 if `name` is not a captured struct of `fnIx`. Mirrors
// `emitCapturedRead`'s guards so a captured struct receiver (`p.x` where `p` is a
// captured `{ … }` in an enclosing frame) resolves to its struct type exactly as a
// param/local/global receiver would — the value itself is read from the env by
// `emitCapturedRead`; this only supplies the heap type so `emitMem` can pick the field.
function capturedStructIndex(fnIx: i32, name: string) {
  if fnIx < 0 { return -1 }
  if !fnValUsed { return -1 }
  let fe = fnStmtsPosOf(fnIx)
  if fe < 0 { return -1 }
  if fnEnvIdxOf(fe) < 0 { return -1 }
  const caps = captureNamesOf(fe)
  let ci = 0
  while ci < caps.length {
    if caps[ci] == name { return captureValStructIdx(fe, name) }
    ci = ci + 1
  }
  -1
}

// True if the CAPTURED variable `name` of the capturing lifted function `fnIx`
// is BOOLEAN-typed in the parent frame (a `boolean` param annotation, a
// `boolean`-annotated let, or a bool-literal init). Bool rides in an i32, so
// `capturedKindOf` cannot carry it — this is the print/`fRetBool` side channel.
function capturedIsBool(fnIx: i32, name: string) {
  if fnIx < 0 { return false }
  if !fnValUsed { return false }
  let fe = fnStmtsPosOf(fnIx)
  if fe < 0 { return false }
  const caps = captureNamesOf(fe)
  let isCap = false
  let ci = 0
  while ci < caps.length {
    if caps[ci] == name { isCap = true }
    ci = ci + 1
  }
  if !isCap { return false }
  let b = parentBindingOf(fe, name)
  if b < 0 { return false }
  const bn = P.nodes[b]
  if bn is Param { return tyNameOf(bn.parType) == "boolean" }
  if bn is LetDecl {
    if bn.letType >= 0 { return tyNameOf(bn.letType) == "boolean" }
    if bn.letInit >= 0 {
      const iv = P.nodes[unwrapParen(bn.letInit)]
      if iv is BoolLit { return true }
    }
  }
  false
}

// The VALUE KIND of a CAPTURED variable `name` of the capturing lifted function
// `fnIx` (the same `fbValtype` codes `captureValKind` types the env field with),
// or -1 if `name` is not a captured variable of `fnIx`. Same guards as
// `capturedStructIndex` — this is the classifier-side mirror, so an expression
// classifier (`exprArray` & co) can type a captured-list/string read exactly as
// a param/local/global receiver would.
function capturedKindOf(fnIx: i32, name: string) {
  if fnIx < 0 { return -1 }
  if !fnValUsed { return -1 }
  let fe = fnStmtsPosOf(fnIx)
  if fe < 0 { return -1 }
  if fnEnvIdxOf(fe) < 0 { return -1 }
  const caps = captureNamesOf(fe)
  let ci = 0
  while ci < caps.length {
    if caps[ci] == name { return captureValKind(fe, name) }
    ci = ci + 1
  }
  -1
}

// The union member-set NAME of a CAPTURED union-box variable `name` (kind 4) of the capturing
// function `fnIx` — resolved from the PARENT frame's binding annotation / init, so `a is Cat`
// narrows a captured `a: Cat | Dog`. "" when `name` is not a captured union. The union-name
// dual of `capturedStructIndex`.
function capturedUnionName(fnIx: i32, name: string) {
  if capturedKindOf(fnIx, name) != 4 { return "" }
  const fe = fnStmtsPosOf(fnIx)
  if fe < 0 { return "" }
  const b = parentBindingOf(fe, name)
  if b < 0 { return "" }
  const bn = P.nodes[b]
  if bn is Param {
    const pn = tyNameOf(bn.parType)
    if isUName(pn) { return pn }
    return ""
  }
  if bn is LetDecl {
    const par = fnParent[fe]
    if par >= 0 { return letUnionNameOf(b, fnStmts[par]) }
  }
  ""
}

function structIndexOfExpr(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return -1 }
  const e = P.nodes[exprIx]
  if e is ObjLit { return structIndexOfObjCtx(exprIx, fnIx) }
  if e is Paren { return structIndexOfExpr(e.parInner, fnIx) }
  // An if-EXPRESSION whose join is a struct (`const b = if c { mk(1) } else { mk(2) }`): the
  // THEN arm's struct index classifies the whole `if` (the checker proved the arms agree), so an
  // un-annotated binding resolves the same struct heap type the `emitIfExprRef` join emits.
  if e is IfStmt {
    const tv = ifThenValueIx(exprIx)
    if tv >= 0 { return structIndexOfExpr(tv, fnIx) }
  }
  // A `m[k] ?? default` over a STRUCT-valued map resolves to the value type's struct index (the
  // mv slot's `mvValStructIdx`), so the field-read layout is found.
  if e is BinExpr {
    const cms = coalesceMvSlot(exprIx, fnIx)
    if cms >= 0 {
      if mvValKind[cms] == 1 { return mvValStructIdx[cms] }
    }
    // A `<S|null> ?? <S>` coalesce resolves to the (inner) struct index — so `(r ?? d).field` finds
    // the layout. The left's nullable struct drives it (its inner struct), else the right default.
    if e.binOp == "??" {
      const ls = structIndexOfExpr(e.binLeft, fnIx)
      if ls >= 0 { return ls }
      return structIndexOfExpr(e.binRight, fnIx)
    }
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const ri = fnRetStructIndex(callee.identName)
      if ri >= 0 { return ri }
      // A struct-returning function VALUE (a binding / `(i32) => S` param callee, invisible
      // to `fnRetStructIndex`): the struct index from its resolved `>sN;` sig. Falls through to the
      // per-node-type fallback below when the sig path misses (a value INFERRED from a factory call —
      // `const g = mk()` — whose `>sN;` the syntactic path can't recover).
      const ci = calleeReturnsStructIdx(callee.identName, fnIx)
      if ci >= 0 { return ci }
    }
    // A FIELD-CLOSURE call (`(a."[]")(i)` — a chained index trap whose "[]"
    // returns another trap object) yields the field function's return struct.
    if callee is Member {
      if (
        drwFieldClosure(structIndexOfExpr(callee.memObj, fnIx), callee.memProp)
      ) {
        const cfe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
        if cfe >= 0 {
          if fRetRef[cfe] == 1 || fRetNul[cfe] == 1 {
            return fRetStructIdx[cfe]
          }
        }
      }
    }
    // `xs.pop()` / `xs.get(i)` over a struct-element ref list yield that list's
    // element struct (as `S | null` — see `structListPopGetElem`).
    const slv = structListPopGetElem(exprIx, fnIx)
    if slv >= 0 { return slv }
    // FALLBACK (scoped to a CALL): a struct-returning closure value call whose callee the cases above
    // miss — an INDEXED closure-array element (`arr[i](x).field`) or a value INFERRED from a factory
    // call (`const g = mk(); g(x).field`). Resolve the struct from the checker's per-node type: gate on
    // the cheap `nodeTyIsObj` (no render), then resolve the rendered inline shape to its declared index
    // by field-set match (`structIndexOfTypeName`). The struct dual of the union `nodeUnionName`
    // fallback, and the consumer half of the `cloCallSigKey` `nodeTyName` producer fallback. Off the
    // hot path — declared / param / field-closure struct receivers resolve syntactically above.
    if nodeTyIsObj(exprIx) {
      const sn = nodeTyName(exprIx)
      if sn != "" { return structIndexOfTypeName(sn) }
    }
    // The NULLABLE-struct dual: a `S | null`-returning closure value call (`arr[i](x)` over a
    // `((i32) => P | null)[]`) resolves to its INNER struct's layout index, so the kind-9 binding's
    // `!= null` narrow and field read find `P`. `nodeNulStructInnerName` renders only the inner shape.
    const nn = nodeNulStructInnerName(exprIx)
    if nn != "" { return structIndexOfTypeName(nn) }
    return -1
  }
  if e is Ident {
    let pi = paramStructIndex(fnIx, e.identName)
    if pi >= 0 { return pi }
    let di = declaredStructIndex(e.identName)
    if di >= 0 { return di }
    let gi = globalStructIndex(e.identName)
    if gi >= 0 { return gi }
    return capturedStructIndex(fnIx, e.identName)
  }
  // `xs[i]` over a STRUCT-element ref list yields that list's element struct. The
  // element struct TABLE INDEX comes from the receiver's per-element-type slot's name
  // (`Tok[]` → `Tok` → its struct index), so distinct struct ref-lists resolve to
  // distinct struct types — not always heap-type 0.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      let nm = refListElemNameOfExpr(e.idxArr, fnIx)
      // A NULLABLE-struct element (`(P | null)[]`, slot key "P | null") resolves to the bare
      // struct `P` — strip the `| null` so a narrowed `xs[i].field` finds P's layout.
      const nmnn = nullablePartOf(nm)
      if nmnn != "" { nm = nmnn }
      let si = structIndexByName(nm)
      if si >= 0 { return si }
    }
    // A BARE `m[k]` over a STRUCT-valued map resolves to the value type's struct index, so a
    // narrowed `(m[k]).field` finds the layout — the Index dual of the `?? default` BinExpr case.
    const mrs = mapReadMvSlot(exprIx, fnIx)
    if mrs >= 0 {
      if mvValKind[mrs] == 1 { return mvValStructIdx[mrs] }
    }
  }
  // A field read `o.inner` whose field is a NESTED STRUCT (code 15) yields the
  // field's target struct — so `o.inner.v` chains and `n.next` re-enters as `S|null`.
  if e is Member {
    const msi = structIndexOfExpr(e.memObj, fnIx)
    if msi >= 0 {
      let mfi = sFieldIndex(msi, e.memProp)
      if mfi >= 0 {
        if sFieldTypeAt(msi, mfi) == 15 {
          return structIndexByName(sFieldElemNameAt(msi, mfi))
        }
      }
    }
  }
  -1
}

// The struct table index a struct-typed `LetDecl` binds: from its annotation if
// present, else inferred from its initializer. -1 if not a struct local.
function structIndexOfLet(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        let si = structIndexByName(lt.tyName)
        if si >= 0 { return si }
        // A NULLABLE annotation (`{n:i32} | null`, `Config | null`) resolves its
        // NON-NULL part — `collectAnnShapes` interns an inline shape under the
        // bare text (the `|null` wrapper stripped), and a named alias interns
        // under its own name. Needed when the initializer is a bare `null` (no
        // struct literal to infer the index from).
        const nb = nullablePartOf(lt.tyName)
        if nb != "" {
          let si2 = structIndexByName(nb)
          if si2 >= 0 { return si2 }
        }
      }
    }
    return structIndexOfExpr(d.letInit, fnIx)
  }
  -1
}

// ── union-typedness of expressions (G1) ───────────────────────────────────────
// Parallel to the struct family: decide whether an expression / param / local / let
// is the declared UNION (a `(ref $uBoxIdx)` boxed value). Unlike structs, an object
// literal's INTRINSIC type is its variant struct, NOT the union — boxing happens at a
// flow boundary (a `let n: U = …`, a union-returning `return`, a union-typed arg). So
// `exprUnion` is true for a union-returning call / union param / union local, but NOT
// a bare object literal (its boxing is driven by the EXPECTED type at the boundary).

// True if function `name` declares the union as its return type.
function fnRetUnion(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetUni[i] == 1
}

// True if the parameter `name` of function `fnIx` is the union type.
function paramUnion(fnIx: i32, name: string) {
  isUName(tyNameOf(paramTypeNode(fnIx, name)))
}

// True if the already-collected declared local `name` is a union ref (code `4`).
function declaredUnion(name: string) { declaredKind(name) == 4 }

// True if evaluating the expression at `exprIx` yields the union box: a union-returning
// call, a union param/local reference, or a parenthesized union expression. (A bare
// object literal is NOT a union here — see the family note.)
function exprUnion(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Paren { return exprUnion(e.parInner, fnIx) }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetUnion(callee.identName) { return true }
      // A union-returning function VALUE (a binding / `(…) => A | B` param callee) — its
      // result is the union box, `>u`.
      return calleeRetKind(callee.identName, fnIx) == 4
    }
    // A union-returning FIELD-closure call.
    if callee is Member {
      const ffe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
      if ffe >= 0 { return fRetUni[ffe] == 1 }
    }
    return nodeTyIsUnion(exprIx)
  }
  if e is Ident {
    // A VALUE-union ident narrowed to ONE scalar atom (`if u is i32 { … u … }`)
    // reads UNBOXED in this scope — it is no longer a union value here (the host's
    // narrowing types it as the member). A sub-union narrowing (2+ atoms) keeps
    // the box.
    if narrowedValueAtomOf(e.identName) != "" { return false }
    if paramUnion(fnIx, e.identName) { return true }
    if declaredUnion(e.identName) { return true }
    // A CAPTURED union box (`const a: C | D = …; () => … a is C …`): the env field is the union
    // box (kind 4). `capturedUnionName` resolves its member set from the parent binding so `is`
    // narrows; here we only need to know it IS a union value.
    if capturedKindOf(fnIx, e.identName) == 4 { return true }
    // A module GLOBAL union binding (a union annotation, or a union-returning
    // init): top-level `const a = make(42)` / `let w: string | i32 = "a"`.
    let gi = globalLetOf(e.identName)
    if gi >= 0 { return letIsUnion(gi, -1) }
    return false
  }
  // `ns[i]` over a UNION-element ref list yields the union box (G7-ref) — so the value
  // is usable with `is`-narrowing (a `let n0 = ns[i]` is a union local). Per-slot: the
  // element kind comes from the receiver's distinct ref-list slot (2 = union box).
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      let slot = refListSlotOfExpr(e.idxArr, fnIx)
      return rlElemKindTbl[slot] == 2
    }
    // A bare `m[k]` over a UNION-valued map yields the value union box.
    const mri = mapReadMvSlot(exprIx, fnIx)
    if mri >= 0 { return mvValKind[mri] == 2 }
  }
  // `m[k] ?? d` over a UNION-valued map yields the value union box.
  if e is BinExpr {
    const cmu = coalesceMvSlot(exprIx, fnIx)
    if cmu >= 0 { return mvValKind[cmu] == 2 }
  }
  // A plain read of a VALUE-UNION struct field (`o.y`, code 16) yields the field's
  // union BOX — a union value usable wherever a union is expected (`return o.y`, a
  // union arg, `const u = o.y`). A read NARROWED to one scalar atom unboxes (mirrors
  // the code-16 read path in emitMem), so it is no longer a union here — same as the
  // narrowed IDENT case above; a sub-union narrowing keeps the box (stays a union).
  if e is Member {
    if memberUnionFieldName(exprIx, fnIx) == "" { return false }
    const mAtom = narrowVariantFor(memberPathKeyOf(exprIx))
    const mk = valueAtomKind(mAtom)
    if mk >= 0 && mk != 6 { return false }
    return true
  }
  false
}

// True if the `LetDecl` at `letIx` declares a union-typed local: its annotation names
// the union, OR its initializer produces the union (a union-returning call etc.). An
// object-literal init under a union annotation is BOXED as the union (`emitStmt`).
function letIsUnion(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        // A literal union (`type K = "a" | "b"`, or an inline `"a" | "b"`) is an interned-i32
        // ATOM, not a value-union box — never classify it kind 4.
        if isUName(lt.tyName) && !nameIsLitUnionType(lt.tyName) { return true }
      }
    }
    // The init's union-ness applies when no annotation pinned the cell — but a literal-union
    // ATOM init (allowed under a `: string` annotation as a subtype) is an atom, not a box, so
    // it must not box the cell (`const b: string = colorAtom` stays a `string` cell).
    if exprUnion(d.letInit, fnIx) && !exprIsLitAtom(d.letInit, fnIx) {
      return true
    }
    // A null-hole binding (`let x = null`, A-infer-null) is its inferred union.
    return nliNameOf(letIx) != ""
  }
  false
}

// ── value-union name resolution (the union a value flows as) ─────────────────
// The registered union NAME a binding `name` carries in function `fnIx` (its param
// annotation, its `let` annotation, an inferred union-returning init, or a module
// global's), or "" when the binding is not union-typed. The name string IS the
// atom set (`"boolean|i32"`), so narrowing complements split it directly.
function unionNameOfIdent(name: string, fnIx: i32) {
  if fnIx >= 0 {
    const fn = P.nodes[fnIx]
    if fn is FuncDecl {
      // Read the body field BEFORE the Param narrowing below pins its own binding.
      const body = fn.fnBody
      const params = fn.fnParams
      let i = 0
      while i < params.length {
        const p = P.nodes[params[i]]
        if p is Param {
          if p.parName == name {
            const pn = tyNameOf(p.parType)
            if isUName(pn) { return pn }
            return ""
          }
        }
        i = i + 1
      }
      let li = parentLetOf(body, name)
      if li >= 0 { return letUnionNameOf(li, fnIx) }
      // A `for <name> in <(C|S)[]>` loop variable is a kind-4 union box but is NOT a
      // `LetDecl`, so `parentLetOf` misses it — resolve its member set from the iterable's
      // union-box element type so `x is C` narrows inside the loop body. GUARDED on the slot
      // already being a kind-4 union box, so a non-union loop var (an f32 `for v in
      // m.values()`, a struct `for s in ss`) never reaches the ref-array reclassification
      // below (which could mis-name it and corrupt its codegen).
      if declaredKind(name) == 4 {
        const iter = forInIterBlock(body, name)
        if iter >= 0 {
          if exprRefArray(iter, fnIx) {
            let slot = refListSlotOfExpr(iter, fnIx)
            if rlElemKindTbl[slot] == 2 { return rlElemName[slot] }
          }
        }
      }
    }
  }
  // A CAPTURED union box — resolve its member set from the parent frame's binding.
  const cun = capturedUnionName(fnIx, name)
  if cun != "" { return cun }
  let gi = globalLetOf(name)
  if gi >= 0 { return letUnionNameOf(gi, -1) }
  ""
}

// The ITERABLE expression node of an enclosing `for <name> in <iter>` loop within the
// statement list `stmts` (recursing into nested if / while / for / for-in bodies), or -1.
// A for-in loop variable is not a `LetDecl`, so `parentLetOf` cannot resolve its type;
// this lets `unionNameOfIdent` recover a union loop var's member set from its iterable.
function forInIterIn(stmts: i32[], name: string) {
  let i = 0
  while i < stmts.length {
    const s = P.nodes[stmts[i]]
    if s is ForIn {
      if s.fiVar == name { return s.fiIter }
      const rf = forInIterBlock(s.fiBody, name)
      if rf >= 0 { return rf }
    } else if s is IfStmt {
      const rt = forInIterBlock(s.ifThen, name)
      if rt >= 0 { return rt }
      if s.ifElse >= 0 {
        const els = P.nodes[s.ifElse]
        if els is Block {
          const re = forInIterBlock(s.ifElse, name)
          if re >= 0 { return re }
        } else {
          const one: i32[] = []
          one.push(s.ifElse)
          const r2 = forInIterIn(one, name)
          if r2 >= 0 { return r2 }
        }
      }
    } else if s is WhileStmt {
      const rw = forInIterBlock(s.whileBody, name)
      if rw >= 0 { return rw }
    } else if s is ForRange {
      const rr = forInIterBlock(s.frBody, name)
      if rr >= 0 { return rr }
    }
    i = i + 1
  }
  -1
}

// Recurse into a Block node's statement list to find a for-in binding `name` (else -1).
function forInIterBlock(blockIx: i32, name: string) {
  if blockIx < 0 { return -1 }
  const b = P.nodes[blockIx]
  if b is Block { return forInIterIn(b.blkStmts, name) }
  -1
}

// The union name of a `LetDecl`: its annotation when that names a union, else the
// union its (un-annotated) initializer produces (`const r = pick(true)`).
function letUnionNameOf(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    const an = tyNameOf(d.letType)
    if isUName(an) { return an }
    if d.letType < 0 {
      const inf = unionNameOfExpr(d.letInit, fnIx)
      if inf != "" { return inf }
      // A null-hole binding (`let x = null` filled by a later `x = e`) carries
      // its inferred `T|null` value union (A-infer-null).
      return nliNameOf(letIx)
    }
  }
  ""
}

// The UNION return of a function-type NAME (`(i32) => A | B` → "A | B", an alias `(i32) => Sh` → its
// member set via `isUName`), or "" when the name is not a function type returning a multi-member union.
function unionRetOfFnType(fnTyName: string) {
  const arrowAt = annArrowAt(fnTyName)
  if arrowAt >= 1 && fnTyName.length > 0 && fnTyName[0] == '(' {
    const ret = monoUnwrapParens(fnTyName.slice(arrowAt + 2, fnTyName.length))
    if isUName(ret) { return ret }
    if isValueUnionName(ret) { return ret }
  }
  ""
}

// The union return-type NAME of a closure-typed PARAM `name` of function `fnIx` (`g: (i32) => A | B`
// → "A | B"), or "" when `name` is not a union-returning closure param. Lets a value call THROUGH a
// closure param (`g(x)` inside a HOF) classify its result union so a narrowed read unboxes.
function paramUnionRetName(fnIx: i32, name: string) {
  if fnIx < 0 { return "" }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    let i = 0
    while i < fn.fnParams.length {
      const p = P.nodes[fn.fnParams[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            const ty = P.nodes[p.parType]
            if ty is TypeRef { return unionRetOfFnType(ty.tyName) }
          }
          return ""
        }
      }
      i = i + 1
    }
  }
  ""
}

// The union NAME the expression at `exprIx` produces (the name-typed mirror of the
// boolean `exprUnion`): a union-returning call's return annotation, a union-typed
// ident, a parenthesized union. "" when the expression is not union-valued.
function unionNameOfExpr(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return "" }
  const e = P.nodes[unwrapParen(exprIx)]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const t = fnIndexOf(callee.identName)
      if t >= 0 {
        const fn = P.nodes[fnStmts[t]]
        if fn is FuncDecl {
          const rn = tyNameOf(fn.fnRet)
          if isUName(rn) { return rn }
          // An UN-annotated function whose returns JOIN to a value union: its inferred
          // name drives the same narrowing/unboxing (`is string` unboxes the box) as an
          // annotation would. Without this an inferred-union binding stays the raw box
          // and a narrowed read mis-types (arrayref vs the union box).
          if fn.fnRet < 0 {
            const im = inferRetNameOf(callee.identName)
            // A value union (`isValueUnionName`) OR a registered struct union (`isUName`
            // — registered from this same inferred name in `collectU`): either drives the
            // binding's narrowing/unboxing exactly as an annotation would.
            if isValueUnionName(im) { return im }
            if im != "" && isUName(im) { return im }
          }
        }
      }
      // A union-returning function VALUE callee (`const f = g; const r = f(7)`): resolve
      // the union name from the underlying lifted function, mirroring the named path above
      // — so a union from a CLOSURE call narrows/unboxes (`if r is i32 { … r … }`), not
      // just one from a named call. Without this the binding keeps the raw box and a
      // narrowed read mis-types (the box ref vs the unboxed scalar).
      const cfe = identClosureFe(callee.identName, fnIx)
      if cfe >= 0 {
        const cfn = P.nodes[fnStmts[cfe]]
        if cfn is FuncDecl {
          const crn = tyNameOf(cfn.fnRet)
          if isUName(crn) { return crn }
          // A VALUE-union annotated return (`i32 | string`, pinned on the lambda by `synthRetAnnots`):
          // `isUName` covers struct unions only, so its narrowed result would not unbox without this.
          if isValueUnionName(crn) { return crn }
          if cfn.fnRet < 0 {
            const cim = inferRetNameOf(cfn.fnName)
            if isValueUnionName(cim) { return cim }
            if cim != "" && isUName(cim) { return cim }
          }
        }
      }
      // A union-returning closure PARAM callee (`callIt(g: (i32) => A | B, x) { … g(x) … }`): resolve
      // the union from the param's function-type annotation, so a narrowed VALUE-union result unboxes
      // inside the HOF body (the struct case reads a field off the variant, so it needs no name).
      const pun = paramUnionRetName(fnIx, callee.identName)
      if pun != "" { return pun }
      // A closure binding whose function-type is INFERRED from a CALL (`const g = mk()` where `mk():
      // (i32) => A | B`): `identClosureFe` can't see through the call result, so recover the closure
      // type from `identFnTypeAnnName` and take its union return.
      const bun = unionRetOfFnType(identFnTypeAnnName(callee.identName, fnIx))
      if bun != "" { return bun }
    }
    // A union-returning FIELD-closure callee (`const r = o.run(7)` over a `(…) => A | B`
    // field) — the Member analogue of the binding case above: resolve the field's lifted
    // function's union name so the result narrows/unboxes.
    if callee is Member {
      const mfe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
      if mfe >= 0 {
        const mfn = P.nodes[fnStmts[mfe]]
        if mfn is FuncDecl {
          const mrn = tyNameOf(mfn.fnRet)
          if isUName(mrn) { return mrn }
          if mfn.fnRet < 0 {
            const mim = inferRetNameOf(mfn.fnName)
            if isValueUnionName(mim) { return mim }
            if mim != "" && isUName(mim) { return mim }
          }
        }
      }
    }
    // FALLBACK (scoped to a CALL — never an if-expr, which has its own union rep path): a union-valued
    // call whose callee the cases above miss (an indexed closure-array element `arr[i](x)`) — render its
    // union from the checker's per-node type, for the value-union UNBOX. The name-typed dual of
    // `exprUnion`'s Call `nodeTyIsUnion` fallback; reached only here, so the costly render is off the
    // hot path (declared / param / binding unions resolve from the cheap annotation above).
    return nodeUnionName(exprIx)
  }
  if e is Ident { return unionNameOfIdent(e.identName, fnIx) }
  // `m[k] ?? d` over a UNION-valued map yields the value union's box — resolve its name (the
  // mv slot's value name) so an un-annotated `const v = m[k] ?? d` narrows/unboxes.
  if e is BinExpr {
    const cmu = coalesceMvSlot(unwrapParen(exprIx), fnIx)
    if cmu >= 0 {
      if mvValKind[cmu] == 2 { return mvValName[cmu] }
    }
  }
  // `ns[i]` over a UNION-element ref list yields the element union's box (the
  // name-typed mirror of `exprUnion`'s Index case) — so an un-annotated
  // `const a = arr[0]` binding resolves its union name for narrowing/unboxing.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      let slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemKindTbl.length {
        if rlElemKindTbl[slot] == 2 { return rlElemName[slot] }
      }
    }
    // A bare `m[k]` over a UNION-valued map (the value union's box).
    const mri = mapReadMvSlot(unwrapParen(exprIx), fnIx)
    if mri >= 0 {
      if mvValKind[mri] == 2 { return mvValName[mri] }
    }
  }
  // The name-typed mirror of `exprUnion`'s Member case: a code-16 field read carries
  // the field's union name (its atom set), unless narrowed to one scalar (unboxed).
  if e is Member {
    const mix = unwrapParen(exprIx)
    const mAtom = narrowVariantFor(memberPathKeyOf(mix))
    const mk = valueAtomKind(mAtom)
    if mk >= 0 && mk != 6 { return "" }
    return memberUnionFieldName(mix, fnIx)
  }
  ""
}

// The single scalar atom a binding `name` is currently narrowed to (`"i32"`,
// `"string"`, `"boolean"`, `"i64"`, `"f64"`, `"f32"`), or "" when it is not
// narrowed / narrowed to a sub-union (a pipe-joined set classifies as no atom) /
// narrowed to `null` / narrowed to a struct variant. A non-"" answer means an
// ident READ unboxes to that atom's rep.
function narrowedValueAtomOf(name: string) {
  let v = narrowVariantFor(name)
  if v == "" { return "" }
  let k = valueAtomKind(v)
  if k >= 0 && k != 6 { return v }
  ""
}

// The atom KIND an IDENT expression currently reads as, for the scalar/string
// classifiers (`exprString`/`exprIsBool`/`exprIsI64`/`exprIsF64`/`exprIsF32`):
// `valueAtomKind` codes when the ident is a union binding narrowed to ONE scalar
// atom (the read unboxes to that atom's rep), -2 when it is a union binding NOT
// narrowed to a single atom (the read is the BOX ref — no scalar classification,
// even if the binding's INIT was a string/bool literal), or -3 when the
// expression is not a union-typed ident at all (the caller keeps its existing
// classification rules).
function unionIdentReadKind(exprIx: i32, fnIx: i32) {
  const e = P.nodes[exprIx]
  if e is Ident {
    if unionNameOfIdent(e.identName, fnIx) != "" {
      const a = narrowedValueAtomOf(e.identName)
      if a != "" { return valueAtomKind(a) }
      return -2
    }
  }
  -3
}

// The member-path dual of `unionIdentReadKind`: the atom KIND a UNION-typed
// struct-FIELD read (`o.y`, field code 16) currently reads as — the narrowed
// single atom's kind when the member PATH is narrowed (the read unboxes to that
// atom's rep), -2 for an un-narrowed box read, -3 when the expression is not a
// union-field member at all.
function memberUnionReadKind(exprIx: i32, fnIx: i32) {
  const e = P.nodes[exprIx]
  if e is Member {
    if memberUnionFieldName(exprIx, fnIx) != "" {
      const a = narrowedValueAtomOf(memberPathKeyOf(exprIx))
      if a != "" { return valueAtomKind(a) }
      return -2
    }
  }
  -3
}

// The CURRENT narrowed atom set of the union binding `name`: its innermost active
// narrowing when one exists (which may already be a sub-union), else its declared
// union's full member set (the union name itself). "" when not a union binding.
function currentNarrowSetOf(name: string, fnIx: i32) {
  let v = narrowVariantFor(name)
  if v != "" { return v }
  unionNameOfIdent(name, fnIx)
}

// The FULL pipe-joined member set of the union named `name`: a registered alias
// returns its `unMemberSet` entry (a declared `type N = A | B` expands to "A|B",
// atom members like `null` kept); an unregistered / already-pipe-joined name
// passes through unchanged. Lets complement narrowing subtract variants from an
// ALIAS-annotated binding's set.
function unionMemberSetOf(name: string) {
  let u = 0
  while u < unNames.length {
    if unNames[u] == name { return unMemberSet[u] }
    u = u + 1
  }
  name
}

// The CURRENT narrowed variant set of a STRUCT-union binding `name`: its innermost
// active narrowing when one exists (which may already be a subtracted sub-set),
// else its declared union's FULL member set (alias names expanded so subtraction
// sees every variant + a `null` member). "" when not a union binding.
function currentStructNarrowSetOf(name: string, fnIx: i32) {
  let v = narrowVariantFor(name)
  if v != "" { return v }
  unionMemberSetOf(unionNameOfIdent(name, fnIx))
}

// The variant struct name an object literal at `objIx` matches: the union variant
// whose field-name set EQUALS the literal's field names (order-independent), or "" if
// none. Used to pick the tag + variant struct when boxing an object literal into the
// union.
function objVariantName(objIx: i32) {
  const o = P.nodes[objIx]
  if o is ObjLit {
    let vi = 0
    while vi < uVariants.length {
      let cnt = uFieldCount[vi]
      if cnt == o.objFields.length {
        let start = uFieldStart[vi]
        let allMatch = true
        let fj = 0
        while fj < cnt {
          if objFieldVal(objIx, uFieldNames[start + fj]) < 0 {
            allMatch = false
          }
          fj = fj + 1
        }
        if allMatch { return uVariants[vi] }
      }
      vi = vi + 1
    }
  }
  ""
}

// ── array-typedness of expressions ───────────────────────────────────────────
// Parallel to the struct family above: decide whether an expression / param / local
// PRODUCES the i32 array (a `(ref $aTypeIdx)`) rather than an i32. An index read
// `a[i]` and `a.length` are i32 (NOT arrays), so they are deliberately absent here.

// True if the function `name` declares an array (`i32[]`) as its return type.
function fnRetArray(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetListKind[i] == 2
}

// True if the already-collected declared local `name` is an i32-array ref (code `2`).
function declaredArray(name: string) { declaredKind(name) == 2 }

// True if evaluating the expression at `exprIx` yields the i32 array: an array
// literal (with i32 / no elements — a ref-element literal is NOT this), an
// array-returning call, an array param/local reference, or a parenthesized array
// The wasm-type code of the struct / variant FIELD a `Member` expression at `memIx`
// reads (`0` i32, `3` string, `4` i32-list, `5` ref-list), or `-1` if `memIx` is not a
// field read of a known struct/variant field. Mirrors `exprString`'s Member dispatch:
// a read on a NARROWED union identifier reads the variant field's type; otherwise the
// receiver's struct field's type. Used by `exprArray`/`exprRefArray` to type array-field
// reads (gap #5) so `.length` / indexing / assignment treat the result as a list.
function memFieldTypeCode(memIx: i32, fnIx: i32) {
  const e = P.nodes[memIx]
  if e is Member {
    if memIsNarrowed(memIx) {
      let vi = memNarrowVariantIndex(memIx)
      if vi >= 0 {
        const vfi = variantFieldIndex(vi, e.memProp)
        if vfi >= 0 { return variantFieldTypeAt(vi, vfi) }
      }
      return -1
    }
    // A field read on a VARIANT-typed param `o.field` (`o: TyObj`) reads the variant
    // struct's field type directly (gap #2) — same table as a narrowed read, but the
    // receiver is the unboxed param, not a `narrowName` ident.
    const pvi = exprVariantIndex(e.memObj, fnIx)
    if pvi >= 0 {
      const pvfi = variantFieldIndex(pvi, e.memProp)
      if pvfi >= 0 { return variantFieldTypeAt(pvi, pvfi) }
    }
    let si = structIndexOfExpr(e.memObj, fnIx)
    if si >= 0 {
      let fi = sFieldIndex(si, e.memProp)
      if fi >= 0 { return sFieldTypeAt(si, fi) }
    }
  }
  -1
}

// expression. An index read / `.length` yields an i32, so neither counts.
function exprArray(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  if tyKindOf(nodeTyIxOf(exprIx)) == 2 {
    return true // typed-IR fast path (see exprIsF64)
  }
  const e = P.nodes[exprIx]
  if e is ArrayLit { return !arrLitIsRef(exprIx) }
  if e is Paren { return exprArray(e.parInner, fnIx) }
  if e is Call {
    // An INDEXED closure call `fs[i](x)` whose element signature returns `i32[]`.
    if cloArrCallRetKind(exprIx, fnIx) == 2 { return true }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      // The intrinsic allocators yield an i32 list unless the fill is f64
      // (`arrNewIntrKind` 1 — then `exprF64Array` claims the call).
      if arrNewIntrKind(exprIx, fnIx) == 0 { return true }
      if fnRetArray(callee.identName) { return true }
      // A closure-VALUE call (`g(x)` with `g: (i32) => i32[]`) whose resolved sig
      // result is the i32 list (`>a`, kind 2) — so `const xs = g(x)` types `xs` as a
      // list and its `.length` / index reads lower through the list machinery.
      return calleeRetKind(callee.identName, fnIx) == 2
    }
    // `xs.map(f)` / `xs.filter(p)` yield a NEW list — the i32 list exactly when the
    // result ELEMENT kind is i32/boolean (map: the callback's return kind; filter:
    // the receiver's element kind).
    if callIsMapFilter(exprIx, fnIx) {
      return mfResultKindOf(exprIx, fnIx) == 0
    }
    // `xs.slice(...)` yields the same list kind as its receiver — an i32 list iff the
    // receiver is one.
    if callIsArrSlice(exprIx, fnIx) { return mfResultKindOf(exprIx, fnIx) == 0 }
    // `m.values()` over an i32-valued map yields an i32 list.
    if mapValuesResultKind(exprIx, fnIx) == 2 { return true }
    return false
  }
  if e is Ident {
    if paramArray(fnIx, e.identName) { return true }
    if declaredArray(e.identName) { return true }
    if globalIsArray(e.identName) { return true }
    // A NULLABLE i32-list binding (`i32[] | null`, kind 15) participates in the
    // list machinery — narrowing is type-level, so every list op classifies the
    // read as a list; the op's read site inserts the `ref.as_non_null` recover.
    if paramNulList(fnIx, e.identName) { return true }
    if declaredNulList(e.identName) { return true }
    if globalIsNulList(e.identName) { return true }
    // A CAPTURED i32-list read (`store[k]` inside a closure capturing `store`).
    return capturedKindOf(fnIx, e.identName) == 2
  }
  // A list CONCAT `a + b` yields a NEW i32 list (collections-design §VL.4).
  if e is BinExpr {
    if e.binOp == "+" {
      if (
        exprArray(e.binLeft, fnIx) &&
        !exprStringArray(e.binLeft, fnIx) &&
        !exprRefArray(e.binLeft, fnIx)
      ) {
        return exprArray(e.binRight, fnIx)
      }
    }
    // `m[k] ?? d` over an i32-LIST-valued map (`{[string]: i32[]}`) yields the value i32 list.
    if e.binOp == "??" {
      if mvListValKind(coalesceMvSlot(exprIx, fnIx)) == 2 { return true }
    }
    return false
  }
  // A field read `p.items` whose struct field is an `i32[]` (code `4`) yields the i32
  // list wrapper ref — so `.length` / indexing / assignment treat it as a list (gap #5).
  // A NULLABLE list field (code 18) classifies the same way (see the Ident rule).
  if e is Member {
    if memFieldTypeCode(exprIx, fnIx) == 4 { return true }
    if memFieldTypeCode(exprIx, fnIx) == 18 { return true }
  }
  // `m[i]` over an `i32[][]` ref list (element kind 4) yields the INNER i32 list,
  // so a chained `m[i][j]` / `m[i].length` treats it as a list.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      let slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemKindTbl.length {
        if rlElemKindTbl[slot] == 4 { return true }
      }
    }
    // A bare `m[k]` over an i32-LIST-valued map yields the value i32 list (`V | null` — the
    // list machinery recovers non-null at the read site).
    if mvListValKind(mapReadMvSlot(exprIx, fnIx)) == 2 { return true }
  }
  false
}

// True if the `LetDecl` at `letIx` declares an array-typed local: its annotation is an
// array type (`i32[]`), OR its initializer produces an array. Picks the local's
// valtype (`(ref $aTypeIdx)` vs i32) in `collectLocals`.
function letIsArray(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsI32Array(lt.tyName) { return true }
      }
    }
    return exprArray(d.letInit, fnIx)
  }
  false
}

// ── ref-array-typedness of expressions (G7-ref) ───────────────────────────────
// Parallel to the i32-array family: decide whether an expression / param / local
// PRODUCES a REF list — `Tok[]` / `Node[]`, a `(ref $rlTypeIdx)`. Its receiver shapes
// mirror `exprArray` but for `S[]`/`N[]` annotations (the index/`.length` reads still
// yield i32 / the element, not the list). `localIsRef` code `5` flags a ref-list local.

// True if function `name` declares a ref array (`S[]`/`N[]`) as its return type.
function fnRetRefArray(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetListKind[i] == 5
}

// True if the parameter `name` of function `fnIx` is a ref-array type.
function paramRefArray(fnIx: i32, name: string) {
  nameIsRefArray(tyNameOf(paramTypeNode(fnIx, name)))
}

// True if the already-collected declared local `name` is a ref-list ref (code `5`).
function declaredRefArray(name: string) { declaredKind(name) == 5 }

// True if evaluating the expression at `exprIx` yields a ref list: a ref-element array
// literal, a ref-array-returning call, a ref-array param/local reference, or a
// parenthesized ref-array expression. An index read / `.length` is NOT a list.
function exprRefArray(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is ArrayLit { return arrLitIsRef(exprIx) }
  if e is Paren { return exprRefArray(e.parInner, fnIx) }
  // `m[k]` / `m[k] ?? d` over a struct-LIST-valued map yields a struct ref list.
  if mapReadListKind(exprIx, fnIx) == 5 { return true }
  if e is Call {
    // `__array_new__(n, {…})` builds a ref list of the element struct (kind 3).
    if arrNewIntrKind(exprIx, fnIx) == 3 { return true }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetRefArray(callee.identName) { return true }
      // A closure-VALUE callee returning a ref list (`mk: () => S[]`) — its resolved `$fnsig`
      // result is the ref-list wrapper (`>r<slot>;`, kind 5), so `mk()[i]` indexes it directly.
      return calleeRetKind(callee.identName, fnIx) == 5
    }
    // A `.filter` over a struct/union array yields the SAME ref list (kind 2).
    if callee is Member {
      if mfResultKindOf(exprIx, fnIx) == 2 { return true }
    }
    // `m.values()` over a struct- / nested-list- / nested-map-valued map yields a ref list.
    if mapValuesResultKind(exprIx, fnIx) == 5 { return true }
    return false
  }
  if e is Ident {
    // A kind-18 NULLABLE ref-array local is a ref array too (narrowed `if t != null`) — so indexing /
    // `.length` reuse the ref-array machinery; the index emit recovers non-null for the niche receiver.
    if declaredKind(e.identName) == 18 { return true }
    if paramRefArray(fnIx, e.identName) { return true }
    if declaredRefArray(e.identName) { return true }
    return globalIsRefArray(e.identName)
  }
  // A field read `p.items` whose struct field is a `T[]`/`N[]` (code `5`) yields the ref
  // list wrapper ref — so `.length` / indexing / assignment treat it as a ref list.
  if e is Member {
    if memFieldTypeCode(exprIx, fnIx) == 5 { return true }
  }
  // Indexing a NESTED ref array (`g[i]` where `g: S[][]`, kind-9 elements): each element IS the
  // inner ref list, so the index yields a ref array. Recurses — `g[i][j]` over `S[][][]` is a ref
  // array too (the inner slot is itself kind 9).
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemKindTbl.length {
        return rlElemKindTbl[slot] == 9
      }
    }
  }
  false
}

// The ref-list ELEMENT type-NAME a ref-array param `name` of function `fnIx` declares
// (`p: Tok[]` → `Tok`), or "" if not a ref-array param.
function paramRefArrayName(fnIx: i32, name: string) {
  if fnIx < 0 {
    return "" // module-scope initializer (no enclosing function)
  }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    const params = fn.fnParams
    let i = 0
    while i < params.length {
      const p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            const ty = P.nodes[p.parType]
            if ty is TypeRef {
              if nameIsRefArray(ty.tyName) { return refArrElemName(ty.tyName) }
            }
          }
          return ""
        }
      }
      i = i + 1
    }
  }
  ""
}

// The ref-list ELEMENT type-NAME a function `name` returns (from its `S[]`/`N[]` return
// annotation, recorded in `fRetRArrElem`), or "".
function fnRetRefArrayName(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return "" }
  fRetRArrElem[i]
}

// The ref-list ELEMENT type-NAME of the declared local `name` (recorded in
// `localStructIdx` as its table SLOT for code-5 locals), or "".
function declaredRefArrayName(name: string) {
  let i = declaredSlotOf(name)
  if i >= 0 {
    if localIsRef[i] == 5 {
      let slot = localStructIdx[i]
      if slot >= 0 {
        if slot < rlElemName.length { return rlElemName[slot] }
      }
    }
  }
  ""
}

// The ref-list ELEMENT type-NAME a module global `name` declares (`S[]`/`N[]`), or "".
function globalRefArrayName(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return "" }
  letRefListElemName(li, -1)
}

// The ref-list ELEMENT type-NAME the expression at `exprIx` produces, or "" if it is not
// a ref list. Mirrors `exprRefArray`'s receiver shapes — used to resolve the per-element-
// type table SLOT (`refListSlotOfExpr`) at every push / index / `.length` / store site.
function refListElemNameOfExpr(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return "" }
  const e = P.nodes[exprIx]
  if e is ArrayLit { return arrLitElemName(exprIx) }
  if e is Paren { return refListElemNameOfExpr(e.parInner, fnIx) }
  // `m[k]` / `m[k] ?? d` over a struct-LIST-valued map — the element is the value's struct.
  const slsMv = mapReadStructListMvSlot(exprIx, fnIx)
  if slsMv >= 0 { return refArrElemName(mvValName[slsMv]) }
  if e is Call {
    // `__array_new__(n, {…})` — the ref-list element name is the fill's struct.
    if arrNewIntrKind(exprIx, fnIx) == 3 {
      const asi = structIndexOfExpr(e.callArgs[1], fnIx)
      if asi >= 0 { return sNames[asi] }
      return ""
    }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const fn = fnRetRefArrayName(callee.identName)
      if fn != "" { return fn }
      // A closure-VALUE callee returning a ref list (`mk: () => S[]`): its element name is the
      // `rlElemName` of the `>r<slot>;` result slot parsed off the callee's resolved `$fnsig`.
      const rs = sigKeyRetSlot(calleeCloSigKey(callee.identName, fnIx))
      if rs >= 0 && rs < rlElemName.length { return rlElemName[rs] }
      return ""
    }
    // A ref-valued `m.values()` yields a ref list whose element is the map's VALUE — read
    // its name off the value's mv ref-list slot (`mvRlSlot`). Checked before the `.filter`
    // result-slot path (a `.values()` is not a `.map`/`.filter`).
    if callee is Member {
      if callee.memProp == "values" {
        if exprMap(callee.memObj, fnIx) {
          const vsh = mapShapeOfExpr(callee.memObj, fnIx)
          if vsh >= 0 {
            const rs = mvRlSlot[vsh]
            if rs >= 0 { return rlElemName[rs] }
          }
        }
      }
      const ms = mfResultSlotOf(exprIx, fnIx)
      if ms >= 0 { return rlElemName[ms] }
    }
    return ""
  }
  if e is Ident {
    // A kind-18 nullable ref-array local stores its INNER ref-list slot in `localStructIdx`; its element
    // name is that inner slot's element name, so `refListSlotOfExpr` round-trips back to the inner slot.
    if declaredKind(e.identName) == 18 {
      const sl18 = declaredSlotOf(e.identName)
      if sl18 >= 0 {
        const is18 = localStructIdx[sl18]
        if is18 >= 0 && is18 < rlElemName.length { return rlElemName[is18] }
      }
    }
    const pn = paramRefArrayName(fnIx, e.identName)
    if pn != "" { return pn }
    const dn = declaredRefArrayName(e.identName)
    if dn != "" { return dn }
    return globalRefArrayName(e.identName)
  }
  if e is Member {
    // A `recv.field` ref-list field read — the field's element name from the receiver's
    // struct / narrowed variant.
    if memIsNarrowed(exprIx) {
      let vi = memNarrowVariantIndex(exprIx)
      if vi >= 0 {
        const vfi = variantFieldIndex(vi, e.memProp)
        if vfi >= 0 { return uFieldElemName[uFieldStart[vi] + vfi] }
      }
      return ""
    }
    let si = structIndexOfExpr(e.memObj, fnIx)
    if si >= 0 {
      let fi = sFieldIndex(si, e.memProp)
      if fi >= 0 { return sFieldElemNameAt(si, fi) }
    }
  }
  // Indexing a NESTED ref array (`g[i]` where `g: S[][]`): the element of `g[i]` is the element
  // of `g`'s element list — strip ONE `[]` off `g`'s element name (`S[]` → `S`). Recurses for
  // deeper nesting (`g[i][j]` over `S[][][]`).
  if e is Index {
    const outer = refListElemNameOfExpr(e.idxArr, fnIx)
    if outer != "" && nameIsArray(outer) { return refArrElemName(outer) }
  }
  ""
}

// The per-element-type ref-list table SLOT the expression at `exprIx` produces, or 0
// (slot fallback) if the element type can't be resolved — every migrated site uses this
// to pick the right backing/wrapper/element indices.
function refListSlotOfExpr(exprIx: i32, fnIx: i32) {
  let nm = refListElemNameOfExpr(exprIx, fnIx)
  let s = rlSlotByName(nm)
  if s < 0 { return 0 }
  s
}

// True if the `LetDecl` at `letIx` declares a ref-list local: its annotation is a ref
// array (`S[]`/`N[]`), OR its initializer produces a ref list. Picks the local's valtype
// (`(ref $rlTypeIdx)`) and the code-`5` flag in `collectLocals`.
function letIsRefArray(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsRefArray(lt.tyName) { return true }
      }
    }
    return exprRefArray(d.letInit, fnIx)
  }
  false
}

// The ref-list ELEMENT type-NAME a ref-list `LetDecl` binds: from its `S[]`/`N[]`
// annotation if present, else inferred from its initializer (`refListElemNameOfExpr`).
// "" if not a ref-list local.
function letRefListElemName(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsRefArray(lt.tyName) { return refArrElemName(lt.tyName) }
      }
    }
    return refListElemNameOfExpr(d.letInit, fnIx)
  }
  ""
}

// The ref-list TABLE SLOT a ref-list `LetDecl` binds (stored in `localStructIdx` for a
// code-5 local so `declaredRefArrayName` can recover its element type), or -1.
function letRefListSlot(letIx: i32, fnIx: i32) {
  rlSlotByName(letRefListElemName(letIx, fnIx))
}

// The ref-list element kind a `LetDecl`'s ANNOTATION declares (`S[]` → 1, `N[]` → 2),
// or `0` when it is not a ref-array annotation. Used to type an empty `[]` initializer
// (a non-empty literal types itself from its elements).
function letAnnRefListKind(letIx: i32) {
  // `pendingListKind` semantics: 1 = struct/MAP ref list (use `pendingListSlot`),
  // 2 = union box ref list, 3 = string list. Delegates to the shared `tyAnnRefListKind`
  // over the let's `letType` so the let / return / call-arg / global seeds agree.
  let d = P.nodes[letIx]
  if d is LetDecl {
    let k = tyAnnRefListKind(d.letType)
    if k == 0 {
      // An UN-ANNOTATED empty `[]` whose pushes infer a string element
      // (`letInfStrListByUse`) seeds the string-list kind, so the empty literal
      // builds the string-list wrapper (not the default i32 list).
      if letInfStrListByUse(letIx) { return 3 }
    }
    return k
  }
  0
}

// The ref-list TABLE SLOT a `LetDecl`'s ref-array annotation names (`let xs: Tok[] = []`
// → the `Tok` slot), or 0 when it is not a ref-array annotation. Threads `pendingListSlot`
// so an empty `[]` initializer builds the annotation's distinct element type.
function letAnnRefListSlot(letIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl { return tyAnnRefListSlot(d.letType) }
  0
}

// The STRUCT TABLE INDEX a `LetDecl`'s annotation names (`let b: B = { … }` → B's index),
// or -1 when the let is un-annotated OR its annotation names a non-struct (a union alias,
// `i32`, an array). Threads `pendingStructIdx` so an annotated struct literal builds the
// annotation's struct over a first-field-name match. An un-annotated `let` is left to the
// literal's own field-shape (-1).
function letAnnStructIdx(letIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef { return structIndexByName(lt.tyName) }
    }
  }
  -1
}

// The union-VARIANT table index a `LetDecl`'s annotation names (`const c: Cat`), or -1.
// Seeds `pendingVariantIdx` so the object-literal init builds the bare variant (kind 8).
function letAnnVariantIdx(letIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef { return variantIndexOf(lt.tyName) }
    }
  }
  -1
}

// ── string-array-typedness of expressions (`string[]`) ────────────────────────
// Parallel to the ref-array family: decide whether an expression / param / local
// PRODUCES a string list — a `(ref $mkListIdx)`. Receiver shapes: a `string[]` literal,
// a `string[]` param/local, a parenthesized string-array, or a `string[]` FIELD read
// (code `6`). An index read `xs[i]` (a string) / `.length` (i32) is NOT a list.

// True if the already-collected declared local `name` is a string-list ref (code `7`).
function declaredStringArray(name: string) { declaredKind(name) == 7 }

// True if function `name` declares (or, un-annotated, infers) a `string[]` return type
// (`fRetListKind` == 7). Mirrors `fnRetArray`/`fnRetRefArray` — lets a `string[]`-returning call
// classify so an untyped `let x = snap()` picks the string-list local kind (code `7`).
function fnRetStringArray(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetListKind[i] == 7
}

// True if function `name` declares (or, un-annotated, infers) an `f64[]` return — the f64
// analogue of `fnRetStringArray`, so an untyped `let x = mk()` / a call argument classifies as
// an f64 list (kind 12) instead of falling through to i32.
function fnRetF64Array(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetListKind[i] == 12
}

// True if function `name` returns a string-keyed mono map (`{[string]: i32}`, annotated or
// inferred — `fRetMap`). Lets `exprMap`/`mapShapeOfExpr` classify a call to it, so
// `const r = mk()` (or `mk()[k]`) routes through the map lowering.
function fnRetMap(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetMap[i] == 1
}

// True if evaluating the expression at `exprIx` yields a string list: a string-element
// array literal, a `string[]`-returning call, a `string[]` param/local reference, a
// parenthesized string-array, or a `string[]` field read (code `6`). An index read /
// `.length` is NOT a list.
function exprStringArray(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  if tyKindOf(nodeTyIxOf(exprIx)) == 7 {
    return true // typed-IR fast path (see exprIsF64)
  }
  // `m[k]` / `m[k] ?? d` over a string[]-VALUED map yields a string list.
  if mapReadListKind(exprIx, fnIx) == 7 { return true }
  const e = P.nodes[exprIx]
  if e is ArrayLit { return arrLitIsStr(exprIx, fnIx) }
  if e is Paren { return exprStringArray(e.parInner, fnIx) }
  if e is Call {
    // `__array_new__(n, "s")` builds a string list (intrinsic kind 2).
    if arrNewIntrKind(exprIx, fnIx) == 2 { return true }
    // An INDEXED closure call `fs[i](x)` whose element signature returns `string[]`.
    if cloArrCallRetKind(exprIx, fnIx) == 7 { return true }
    // `xs.slice(...)` over a string list yields a string list.
    if callIsArrSlice(exprIx, fnIx) { return mfResultKindOf(exprIx, fnIx) == 3 }
    // `m.keys()` over a string-keyed map yields a string list of its keys.
    const kcallee = P.nodes[e.callFn]
    if kcallee is Member {
      if kcallee.memProp == "keys" {
        if exprMap(kcallee.memObj, fnIx) { return true }
      }
    }
    // `m.values()` over a string-valued map (or a Set) yields a string list.
    if mapValuesResultKind(exprIx, fnIx) == 7 { return true }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetStringArray(callee.identName) { return true }
      // A closure-VALUE call (`g(x)` with `g: (i32) => string[]`) whose resolved sig
      // result is the string list (`>A`, kind 7).
      return calleeRetKind(callee.identName, fnIx) == 7
    }
    return false
  }
  if e is Ident {
    if paramStringArray(fnIx, e.identName) { return true }
    if declaredStringArray(e.identName) { return true }
    if globalIsStringArray(e.identName) { return true }
    // A CAPTURED string-list read (incl. a boxed captured-mutated `string` local). Kind 7.
    return capturedKindOf(fnIx, e.identName) == 7
  }
  // A field read `p.names` whose field is a `string[]` (code `6`) yields the string-list
  // wrapper ref — so `.length` / indexing / assignment / `.push` treat it as a string list.
  if e is Member {
    if memFieldTypeCode(exprIx, fnIx) == 6 { return true }
  }
  // `g[i]` over a `string[][]` (ref-list element kind 6 — the inner string-list wrapper)
  // yields a `string[]`, so `g[i][j]` reads the string element.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      let slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemKindTbl.length {
        if rlElemKindTbl[slot] == 6 { return true }
      }
    }
  }
  false
}

// Usage-driven element inference for an un-annotated empty `[]` LOCAL, the richer
// dual of `letInfStrListByUse` (which only sees a string LITERAL push): with the
// enclosing function `fnIx` in hand it also recognises a push of any STRING-typed
// expression — `out.push(self[i])` over a `string[]` param, `out.push(s)` over a
// string local — so a build-loop accumulator (`slice`/`reverse` over `string[]`)
// classifies as `string[]`. The `gStrInfLet` guard breaks the `out.push(out[0])`
// self-reference cycle (the push arg's `exprString` would re-enter this binding).
function letInfStrListByUseV(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 { return false }
    if d.letInit < 0 { return false }
    const ini = P.nodes[unwrapParen(d.letInit)]
    if ini is ArrayLit {
      if ini.arrElems.length != 0 { return false }
      if gStrInfLet == letIx { return false }
      const saved = gStrInfLet
      gStrInfLet = letIx
      let found = false
      let i = 0
      while i < P.nodes.length {
        const nd = P.nodes[i]
        if nd is Call {
          const callee = P.nodes[nd.callFn]
          if callee is Member {
            if callee.memProp == "push" {
              const recv = P.nodes[callee.memObj]
              if recv is Ident {
                if recv.identName == d.letName && nd.callArgs.length == 1 {
                  const argN = P.nodes[unwrapParen(nd.callArgs[0])]
                  if argN is StrLit {
                    found = true
                  } else if fnIx >= 0 && exprString(nd.callArgs[0], fnIx) {
                    found = true
                  }
                }
              }
            }
          }
        }
        i = i + 1
      }
      gStrInfLet = saved
      return found
    }
  }
  false
}

// True if the `LetDecl` at `letIx` declares a `string[]` local: its annotation is
// `string[]`, OR its initializer produces a string list. Picks the local's valtype
// (`(ref $mkListIdx)`) and the code-`7` flag in `collectLocals`.
function letIsStringArray(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsStringArray(lt.tyName) { return true }
      }
    }
    if exprStringArray(d.letInit, fnIx) { return true }
    return letInfStrListByUseV(letIx, fnIx)
  }
  false
}

// ── f64-array-typedness of expressions (Slice 4) ──────────────────────────────
// Parallel to the i32/string-array families: decide whether an expression / param /
// local PRODUCES an `f64[]` list — a `(ref $fl64TypeIdx)`. Drives the index-read
// dispatch (an f64-array `xs[i]` yields an f64 from `array.get $fa64TypeIdx`) and the
// f64-list local/global cell kind (`12`). `localIsRef` code `12` flags an f64-list local.

// True if the already-collected declared local `name` is an f64-list ref (code `12`).
function declaredF64Array(name: string) { declaredKind(name) == 12 }

// True if evaluating the expression at `exprIx` yields an f64 list: an f64-element
// array literal, an f64-array param/local reference, or a parenthesized one.
// THE single typed-IR → emitter-kind mapping (the unification centerpiece): map a checker
// type-arena index to the emitter's local/value KIND code the per-rep predicates speak
// (0 i32 · 3 string · 10 i64 · 11 f64 · 13 f32 · 2 i32-list · 7 string-list · 12 f64-list).
// One place classifies a type; consumers compare the result to a specific kind instead of
// each re-deriving it. Scalars and scalar-element lists resolve fully; a struct / ref / map
// / nullable / closure type returns -1 (its lowering needs a slot/table the kind code alone
// can't carry), and a node with no recorded type (a monomorphized instance body, whose
// shared leaves can't hold a per-instance type) also reads -1 — both keep the syntactic path.
function tyKindOf(tyIx: i32) {
  if tyIx < 0 { return -1 }
  const t = T.tys[tyIx]
  if t is TyPrim {
    const n = t.primName
    if n == "i32" { return 0 }
    if n == "f64" { return 11 }
    if n == "i64" { return 10 }
    if n == "f32" { return 13 }
    if n == "string" { return 3 }
    if n == "boolean" { return 0 }
    return -1
  }
  if t is TyArray {
    if t.aElem < 0 { return -1 }
    const el = T.tys[t.aElem]
    if el is TyPrim {
      const en = el.primName
      if en == "i32" { return 2 }
      if en == "f64" { return 12 }
      if en == "i64" { return 20 }
      if en == "string" { return 7 }
      if en == "boolean" { return 2 }
    }
    return -1 // struct / ref / nested-list element — needs the ref-list slot
  }
  -1
}

// TYPED-IR consumer: is the type the checker recorded for `tyIx` an `f64[]`? Lets the emitter
// recognize an f64 list the SYNTACTIC predicates miss (e.g. an `f64[]`-returning call, which
// `calleeRetKind` doesn't map to a list kind) without a bespoke per-position predicate.
function tyIsF64Array(tyIx: i32) { tyKindOf(tyIx) == 12 }

function exprF64Array(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  // Typed-IR fast path: trust the checker's recorded type when it has one. Emitter-
  // synthesized nodes (monomorphized instance bodies) read back -1 and fall through to the
  // syntactic derivation below, so generic lowering is unaffected.
  if tyIsF64Array(nodeTyIxOf(exprIx)) { return true }
  // `m[k]` / `m[k] ?? d` over an f64[]-VALUED map yields an f64 list.
  if mapReadListKind(exprIx, fnIx) == 12 { return true }
  const e = P.nodes[exprIx]
  if e is ArrayLit { return arrLitIsF64(exprIx, fnIx) }
  if e is Paren { return exprF64Array(e.parInner, fnIx) }
  if e is Ident {
    if paramF64Array(fnIx, e.identName) { return true }
    if declaredF64Array(e.identName) { return true }
    if globalIsF64Array(e.identName) { return true }
    // A CAPTURED f64-list read (`xs[i]` inside a closure capturing `xs` — incl. a boxed
    // captured-mutated `f64` local, lowered to a length-1 `f64[]`). Kind 12 = f64 list.
    return capturedKindOf(fnIx, e.identName) == 12
  }
  // A `.map`/`.filter` whose result ELEMENT kind is f64 yields an f64 list (an f64
  // receiver's filter, or a map whose callback returns f64). (Slices 3–4.)
  if e is Call {
    // `__array_new__(n, <f64 fill>)` yields an f64 list.
    if arrNewIntrKind(exprIx, fnIx) == 1 { return true }
    if callIsMapFilter(exprIx, fnIx) {
      return mfResultKindOf(exprIx, fnIx) == 1
    }
    // `xs.slice(...)` over an f64 list yields an f64 list.
    if callIsArrSlice(exprIx, fnIx) { return mfResultKindOf(exprIx, fnIx) == 1 }
    // An INDEXED closure call `fs[i](x)` whose element signature returns `f64[]`.
    if cloArrCallRetKind(exprIx, fnIx) == 12 { return true }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      // A NAMED function returning `f64[]` (annotated or inferred, `fRetListKind` == 12).
      if fnRetF64Array(callee.identName) { return true }
      // A closure-VALUE call (`g(x)` with `g: (i32) => f64[]`) whose resolved sig
      // result is the f64 list (`>D`, kind 12).
      return calleeRetKind(callee.identName, fnIx) == 12
    }
    return false
  }
  // `g[i]` over an `f64[][]` (ref-list element kind 7 — the inner f64-list wrapper) yields an
  // `f64[]`, so `g[i][j]` reads the f64 scalar.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      let slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemKindTbl.length {
        if rlElemKindTbl[slot] == 7 { return true }
      }
    }
  }
  false
}

// ── f32-array typedness (the f32 sibling of the f64-array family, rep code 21) ──
// f32 is the checker's weak spot (a float literal types f64), so these lean on the SYNTACTIC
// path — an `f32[]` annotation (`nameIsF32Array`) on a let/param/global/return — rather than a
// typed-IR fast path. A bare `[1.5]` literal stays f64 (it is NOT claimed here), so a value is
// f32[] only when its declared type says so.
function tyIsF32Array(tyIx: i32) { tyKindOf(tyIx) == 21 }

function declaredF32Array(name: string) { declaredKind(name) == 21 }

function globalIsF32Array(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsF32Array(li, -1)
}

function fnRetF32Array(name: string) {
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetListKind[i] == 21
}

function letIsF32Array(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsF32Array(lt.tyName) { return true }
      }
    }
    return exprF32Array(d.letInit, fnIx)
  }
  false
}

function exprF32Array(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  if tyIsF32Array(nodeTyIxOf(exprIx)) { return true }
  // A read of an `f32[]`-valued map (`m[k] ?? []`, or a bare `m[k]`) — its value-list rep is the
  // f32 list (`mvListValKind` → 21), the f32 dual of the f64-list (12) case above.
  if mapReadListKind(exprIx, fnIx) == 21 { return true }
  const e = P.nodes[exprIx]
  if e is Paren { return exprF32Array(e.parInner, fnIx) }
  if e is Ident {
    if paramF32Array(fnIx, e.identName) { return true }
    if declaredF32Array(e.identName) { return true }
    if globalIsF32Array(e.identName) { return true }
    // A CAPTURED f32-list read (incl. a boxed captured-mutated `f32` local). Kind 21 = f32 list.
    return capturedKindOf(fnIx, e.identName) == 21
  }
  // A struct-field READ of an `f32[]` field (code 27) — the checker's per-node type does not always
  // carry f32[] through a member, so recognize it directly by the field code (the f64/i64 duals get
  // this from their typed-IR fast path; this keeps f32 fields on par).
  if e is Member {
    if memberFieldCode(exprIx, fnIx) == 27 { return true }
  }
  if e is Call {
    // `xs.map(f)` / `xs.filter(p)` whose result element is f32 (mf-result kind 13) — a `.map`
    // with an f32-returning callback, or a `.filter` over an f32 list (preserves the element).
    if callIsMapFilter(exprIx, fnIx) {
      return mfResultKindOf(exprIx, fnIx) == 13
    }
    // `xs.slice(...)` over an f32 list yields an f32 list.
    if callIsArrSlice(exprIx, fnIx) {
      return mfResultKindOf(exprIx, fnIx) == 13
    }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetF32Array(callee.identName) { return true }
    }
    return false
  }
  // `g[i]` over an `f32[][]` (ref-list element kind 10 — the inner f32-list wrapper) yields an
  // `f32[]`, so `g[i][j]` reads the f32 scalar.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      let slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemKindTbl.length {
        if rlElemKindTbl[slot] == 10 { return true }
      }
    }
  }
  false
}

// ── i64-array typedness (the i64 sibling of the f64-array family) ──────────────
// These mirror the f64 predicates over the i64-list rep (code 20, wrapper `il64TypeIdx`).
// The typed-IR fast path (`tyKindOf == 20`) carries the annotated cases; the syntactic
// fallback covers a monomorphized body whose nodes have no recorded type.
function tyIsI64Array(tyIx: i32) { tyKindOf(tyIx) == 20 }

function declaredI64Array(name: string) { declaredKind(name) == 20 }

function letIsI64Array(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsI64Array(lt.tyName) { return true }
      }
    }
    return exprI64Array(d.letInit, fnIx)
  }
  false
}

function globalIsI64Array(name: string) {
  let li = globalLetOf(name)
  if li < 0 { return false }
  letIsI64Array(li, -1)
}

function arrLitIsI64(arrIx: i32, fnIx: i32) {
  const a = P.nodes[arrIx]
  if a is ArrayLit {
    if a.arrElems.length < 1 { return false }
    return exprIsI64(a.arrElems[0], fnIx)
  }
  false
}

function exprI64Array(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  if tyIsI64Array(nodeTyIxOf(exprIx)) { return true }
  // `m[k]` / `m[k] ?? d` over an i64[]-VALUED map yields an i64 list.
  if mapReadListKind(exprIx, fnIx) == 20 { return true }
  const e = P.nodes[exprIx]
  if e is ArrayLit { return arrLitIsI64(exprIx, fnIx) }
  if e is Paren { return exprI64Array(e.parInner, fnIx) }
  if e is Ident {
    if paramI64Array(fnIx, e.identName) { return true }
    if declaredI64Array(e.identName) { return true }
    if globalIsI64Array(e.identName) { return true }
    // A CAPTURED i64-list read (incl. a boxed captured-mutated `i64` local). Kind 20 = i64 list.
    return capturedKindOf(fnIx, e.identName) == 20
  }
  if e is Call {
    if callIsMapFilter(exprIx, fnIx) {
      return mfResultKindOf(exprIx, fnIx) == 4
    }
    if callIsArrSlice(exprIx, fnIx) { return mfResultKindOf(exprIx, fnIx) == 4 }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      // A function/closure returning `i64[]` is recognized via the checker's recorded
      // type (the typed-IR fast path above) — no per-rep `fRet*` table needed.
      return calleeRetKind(callee.identName, fnIx) == 20
    }
    return false
  }
  // `g[i]` over an `i64[][]` (ref-list element kind 8 — the inner i64-list wrapper) yields an
  // `i64[]`, so `g[i][j]` reads the i64 scalar.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      let slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemKindTbl.length {
        if rlElemKindTbl[slot] == 8 { return true }
      }
    }
  }
  false
}

// True if the `LetDecl` at `letIx` declares an `f64[]` local: its annotation is `f64[]`,
// OR its initializer produces an f64 list. Picks the local's valtype (`(ref $fl64TypeIdx)`)
// and the code-`12` flag in `collectLocals`.
function letIsF64Array(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsF64Array(lt.tyName) { return true }
      }
    }
    return exprF64Array(d.letInit, fnIx)
  }
  false
}

// ── map-typedness of expressions (G8: `{[string]: i32}`) ──────────────────────
// Parallel to the array family: decide whether an expression / param / local PRODUCES
// a string-keyed MAP — a `(ref $mStructIdx)`. The receiver shapes that matter for the
// self-host checker are a map LOCAL (`let m: {[string]: i32} = Map()` → code `6`), a
// map PARAM, and `Map()` itself (the empty-map constructor). An index read `m[k]` /
// `m.has(k)` yields an i32, NOT a map, so neither counts here.

// True if the already-collected declared local `name` is a map ref (code `6`).
function declaredMap(name: string) { declaredKind(name) == 6 }

// True if evaluating the expression at `exprIx` yields a string-keyed map: the
// `Map()` constructor call, a map param/local reference, or a parenthesized map
// expression.
function exprMap(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Paren { return exprMap(e.parInner, fnIx) }
  if e is Call {
    const callee = P.nodes[e.callFn]
    // A `Set()` is a boolean-valued string map — the SAME 7-field struct — so a
    // `Set()`-bound value is treated as a map throughout the emitter. A NAMED function
    // returning a map (`fnRetMap`) yields one too — so `mk()[k]` / `const r = mk()` route
    // through the map lowering.
    if callee is Ident {
      if callee.identName == "Map" || callee.identName == "Set" { return true }
      return fnRetMap(callee.identName)
    }
    // `scopes.pop()` over a map ref list (`{[string]:i32}[]`) yields a Map ref.
    if callee is Member {
      if callee.memProp == "pop" {
        if exprRefArray(callee.memObj, fnIx) {
          let slot = refListSlotOfExpr(callee.memObj, fnIx)
          if slot >= 0 { return rlElemKindTbl[slot] == 3 }
        }
      }
    }
    return false
  }
  if e is Ident {
    if paramMap(fnIx, e.identName) { return true }
    if declaredMap(e.identName) { return true }
    return globalIsMap(e.identName)
  }
  // A MAP-typed struct field read (`node.children`, code 19) yields a Map ref —
  // map member/index ops on it route to the existing map lowering.
  if e is Member {
    if memFieldTypeCode(exprIx, fnIx) == 19 { return true }
  }
  // `outer[k] ?? d` over a NESTED map (value kind 6) yields the inner Map ref — so a
  // chained `(outer[k] ?? d)[j]` routes through the map lowering.
  if e is BinExpr {
    const cmm = coalesceMvSlot(exprIx, fnIx)
    if cmm >= 0 {
      if mvValIsMap(cmm) { return true }
    }
  }
  // `scopes[i]` over a MAP ref list (`{[string]:i32}[]`, element kind 3) yields a Map ref
  // — so map member/index ops on it route to the existing map lowering. Per-slot: the
  // element kind comes from the receiver's distinct ref-list slot. A bare `outer[k]` over a
  // nested map (value kind 6) likewise yields the inner Map.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      let slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 { return rlElemKindTbl[slot] == 3 }
    }
    const mri = mapReadMvSlot(exprIx, fnIx)
    if mri >= 0 {
      if mvValIsMap(mri) { return true }
    }
  }
  false
}

// ── G8: map ops on a GLOBAL struct-field map-array element ─────────────────────
// `fnHasMap` (above) reserves the map scratch frame from map PARAMS / map LOCALS /
// map-array LOCALS (code 5 + element kind 3). But a map op can also run on an
// element of a GLOBAL struct-field map-array — e.g. `T.scopes[top][name] = v` in the
// self-host checker's `declare`, where `T` is a module global struct and `scopes` is
// a `{[string]:i32}[]` field. Such a function has NO map local, so the local scan
// misses it and `mapScratchBase` points past the locals → `invalid local index`.
//
// This walk fires on EXACTLY the four shapes `emitExpr`/`emitStmt` lower as map ops —
// each gated by `exprMap` on the same receiver (`exprMap` already resolves a
// global-field map-array element via `exprRefArray`→`memFieldTypeCode`==5 +
// `rlElemKindTbl`==3): the map GET `recv[k]`, the fused `recv[k] ?? d`, the
// `.has(k)` member-call, and the map SET `recv[k] = v`. Matching the lowered set
// EXACTLY means it never over-reserves: a function with no map-op shape stays
// byte-identical. The map LOCAL / param cases are already handled by `fnHasMap`, so
// this is OR'd in only as the additional global-field coverage.
//
// (No narrowing is applied here — a global-field map-array receiver resolves through
// `structIndexOfExpr` on a global ident, independent of any active variant narrowing,
// and this helper must stay declare-before-use-safe relative to the narrow stack.)

// True if the expression at `exprIx` (recursively) contains a map-op shape whose
// receiver `exprMap` resolves — i.e. a shape the emitter lowers via the map scratch
// frame.
function exprHasMapOp(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Index {
    // Map GET `recv[k]`.
    if exprMap(e.idxArr, fnIx) { return true }
    if exprHasMapOp(e.idxArr, fnIx) { return true }
    return exprHasMapOp(e.idxIndex, fnIx)
  }
  if e is BinExpr {
    // Fused map get-with-default `recv[k] ?? d` (and the method form `recv.get(k) ?? d`).
    if e.binOp == "??" {
      const lhs = P.nodes[e.binLeft]
      if lhs is Index {
        if exprMap(lhs.idxArr, fnIx) { return true }
      }
      if lhs is Call {
        const lcallee = P.nodes[lhs.callFn]
        if lcallee is Member {
          if lcallee.memProp == "get" {
            if exprMap(lcallee.memObj, fnIx) { return true }
          }
        }
      }
    }
    // Map SET `recv[k] = v` (an assignment is a statement, but walk it defensively).
    if e.binOp == "=" {
      const target = P.nodes[e.binLeft]
      if target is Index {
        if exprMap(target.idxArr, fnIx) { return true }
      }
    }
    if exprHasMapOp(e.binLeft, fnIx) { return true }
    return exprHasMapOp(e.binRight, fnIx)
  }
  if e is Call {
    // `recv.has(k)` map membership / `recv.delete(k)` map removal — both touch a map.
    // `m.keys()` / `m.values()` ITERATION also needs the map scratch frame (slot 0
    // holds the map ref for the tombstone-aware `live[i]` skip in the for-in loop).
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "has" {
        if exprMap(callee.memObj, fnIx) { return true }
      }
      if callee.memProp == "delete" {
        if exprMap(callee.memObj, fnIx) { return true }
      }
      if callee.memProp == "keys" || callee.memProp == "values" {
        if exprMap(callee.memObj, fnIx) { return true }
      }
    }
    if exprHasMapOp(e.callFn, fnIx) { return true }
    const args = e.callArgs
    let i = 0
    while i < args.length {
      if exprHasMapOp(args[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  if e is Member { return exprHasMapOp(e.memObj, fnIx) }
  if e is Unary { return exprHasMapOp(e.unArg, fnIx) }
  if e is Paren { return exprHasMapOp(e.parInner, fnIx) }
  if e is IsExpr { return exprHasMapOp(e.isObj, fnIx) }
  if e is ObjLit {
    const fields = e.objFields
    let i = 0
    while i < fields.length {
      const f = P.nodes[fields[i]]
      if f is FieldInit {
        if exprHasMapOp(f.fiValue, fnIx) { return true }
      }
      i = i + 1
    }
    return false
  }
  if e is ArrayLit {
    const elems = e.arrElems
    let i = 0
    while i < elems.length {
      if exprHasMapOp(elems[i], fnIx) { return true }
      i = i + 1
    }
    return false
  }
  false
}

// True if any statement in the block at `blockIx` (descending into if/else branches
// and while bodies) contains a map op. An assignment statement (`recv[k] = v`) is a
// bare `BinExpr` with `binOp == "="` — `exprHasMapOp` recognizes its SET shape.
function blockHasMapOp(blockIx: i32, fnIx: i32) {
  let b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      let s = P.nodes[stmts[i]]
      if s is LetDecl {
        if exprHasMapOp(s.letInit, fnIx) { return true }
      } else if s is RetStmt {
        if exprHasMapOp(s.retArg, fnIx) { return true }
      } else if s is BinExpr {
        if exprHasMapOp(stmts[i], fnIx) { return true }
      } else if s is Call {
        if exprHasMapOp(stmts[i], fnIx) { return true }
      } else if s is IfStmt {
        if ifChainHasMapOp(stmts[i], fnIx) { return true }
      } else if s is WhileStmt {
        if exprHasMapOp(s.whileCond, fnIx) { return true }
        if blockHasMapOp(s.whileBody, fnIx) { return true }
      } else if s is ForIn {
        if exprHasMapOp(s.fiIter, fnIx) { return true }
        if blockHasMapOp(s.fiBody, fnIx) { return true }
      } else if s is ForRange {
        if exprHasMapOp(s.frFrom, fnIx) { return true }
        if exprHasMapOp(s.frTo, fnIx) { return true }
        if blockHasMapOp(s.frBody, fnIx) { return true }
      }
      i = i + 1
    }
  }
  false
}

// True if any arm of the `if` / `else if` chain at `ifIx` contains a map op — its
// condition, then-branch, `else` block, OR (recursively) a chained `else if`.
function ifChainHasMapOp(ifIx: i32, fnIx: i32) {
  let s = P.nodes[ifIx]
  if s is IfStmt {
    if exprHasMapOp(s.ifCond, fnIx) { return true }
    if blockHasMapOp(s.ifThen, fnIx) { return true }
    if s.ifElse >= 0 {
      const els = P.nodes[s.ifElse]
      if els is Block {
        if blockHasMapOp(s.ifElse, fnIx) { return true }
      } else if els is IfStmt {
        if ifChainHasMapOp(s.ifElse, fnIx) { return true }
      }
    }
  }
  false
}

// True if the FuncDecl at `fnIx` performs a map op on a GLOBAL struct-field map-array
// element (or any map-op shape `fnHasMap`'s local scan does not already cover) — so it
// reserves the shared 12-slot map scratch frame. OR'd into `fnUsesMap`.
function fnHasGlobalMapOp(fnIx: i32) {
  const fn = P.nodes[fnIx]
  if fn is FuncDecl { return blockHasMapOp(fn.fnBody, fnIx) }
  false
}

// True if the `LetDecl` at `letIx` declares a map-typed local: its annotation is a map
// type (`{[string]: i32}`), OR its initializer produces a map (`Map()`). Picks the
// local's valtype (`(ref $mStructIdx)`) and the code-`6` flag in `collectLocals`.
function letIsMap(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsMap(lt.tyName) { return true }
      }
    }
    return exprMap(d.letInit, fnIx)
  }
  false
}

// The map SHAPE code of a map-typed `LetDecl`: `-2` a Set, an mv SLOT (>= 0) for a
// ref-valued map (from the annotation's value type-name), `-1` the mono i32 map,
// `-3` an unsupported value type (op sites fail loudly). Annotation-first, else the
// initializer's shape (a `Map()`/`Set()` constructor, or a map-typed passthrough).
function letMapShapeOf(letIx: i32, fnIx: i32) {
  if letIsSet(letIx) { return -2 }
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsMap(lt.tyName) {
          return mvShapeOfValName(mapValNameOf(lt.tyName))
        }
      }
    }
    return mapShapeOfExpr(d.letInit, fnIx)
  }
  -1
}

// The map SHAPE code of a map-typed EXPRESSION (the receiver of a map op): `-2`
// Set, mv slot >= 0, `-1` mono, `-3` unsupported. Mirrors `exprMap`'s resolution
// chain: constructor calls, locals (the kind-6 parallel slot stored by
// `collectLocals`), globals (their `LetDecl`'s shape), and the mono-only map-array
// element / `.pop()` forms. Map-typed PARAMS stay mono-only (no `vtKindOfParam`
// map case exists yet — a ref-valued map cannot cross a call boundary).
function mapShapeOfExpr(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return -1 }
  const e = P.nodes[exprIx]
  if e is Paren { return mapShapeOfExpr(e.parInner, fnIx) }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if callee.identName == "Set" { return -2 }
      // A map-returning function yields its declared map SHAPE (mono ⇒ -1, or a `string`-valued
      // map's mv slot); a `Map()` constructor is the mono map (-1).
      const fe = fnIndexOf(callee.identName)
      if fe >= 0 { return fnRetMapShape(callee.identName) }
      return -1
    }
    return -1
  }
  if e is Ident {
    if declaredMap(e.identName) {
      let slot = declaredSlotOf(e.identName)
      if slot >= 0 { return localStructIdx[slot] }
      return -1
    }
    // A map PARAM's shape is its annotation's value type (mono ⇒ -1, or a `string`-valued
    // map's mv slot) — so the body's map ops resolve the param's VALUE type, not the mono i32
    // assumption a bare `-1` would force.
    if paramMap(fnIx, e.identName) { return paramMapShape(fnIx, e.identName) }
    const gl = globalLetOf(e.identName)
    if gl >= 0 {
      if letIsMap(gl, -1) { return letMapShapeOf(gl, -1) }
    }
  }
  // A MAP-typed struct field read (`node.children`, code 19): the shape is the
  // field's value-type mv slot (-1 = the mono i32 map).
  if e is Member {
    const msi = structIndexOfExpr(e.memObj, fnIx)
    if msi >= 0 {
      let mfi = sFieldIndex(msi, e.memProp)
      if mfi >= 0 {
        if sFieldTypeAt(msi, mfi) == 19 {
          return mvSlotOfValNameFind(sFieldElemNameAt(msi, mfi))
        }
      }
    }
  }
  -1
}

// ── string-typedness of expressions ──────────────────────────────────────────
// Parallel to the array family above: decide whether an expression / param / local
// PRODUCES a `string` (CURRENTLY the same `(array (mut i32))` of code points an array
// is — `docs/strings-design.md`). Used to route `s.length` to `array.len` and `s[i]`
// to `array.get`, and to give string locals/params the array ref valtype. Like the
// array family, a `.length`/index READ yields an i32 (NOT a string), so neither
// counts here. Concatenation (`+`), equality (`==`), and `slice`/`indexOf` are DEFERRED
// (this slice covers only literal construction + `.length` + index read), so no
// binary/call op below produces a string except a `string`-returning call.

// True if the function `name` declares `string` as its return type. The `fromCodePoint`
// compiler builtin (H2) constructs a single-character VL string, so it is `string`-
// returning too — classifying it here (the single chokepoint `exprString` consults for
// a named call) routes `value + fromCodePoint(cp)` to string concat, flags
// `let s = fromCodePoint(n)` as a string local, etc., exactly as a user `string`-
// returning function would be.
function fnRetString(name: string) {
  if name == "fromCodePoint" { return true }
  if name == "fromCodePoints" { return true }
  if name == "toString" { return true }
  const i = fnIndexOf(name)
  if i < 0 { return false }
  fRetStr[i] == 1
}

// True if the parameter `name` of function `fnIx` is `string`-typed.
function paramString(fnIx: i32, name: string) {
  const pt = paramTypeNode(fnIx, name)
  if retNulStringFlag(pt) == 1 { return true }
  nameIsString(tyNameOf(pt))
}

// True if the already-collected declared local `name` is a string ref (code `3`).
function declaredString(name: string) {
  // A `string | null` (kind 16) local reads AS a string for string ops — it is narrowed
  // non-null at every such read (the checker gates string ops on the narrowed branch),
  // and the array ops (`array.len`/`array.get`) accept the nullable ref. The `!= null`
  // null-check reads it through `exprNullableString` FIRST, so this never mis-routes it.
  const dk = declaredKind(name)
  return dk == 3 || dk == 16
}

// True if evaluating the expression at `exprIx` yields a string: a string literal, a
// `string`-returning call, a string param/local reference, or a parenthesized string
// expression. An index read / `.length` yields an i32, so neither counts.
// The wasm-type CODE (`0` i32/bool, `3` string, `4` i32[], `5` ref list, `6` string
// list) of the field a `Member` access `recv.field` reads, resolving the receiver
// through the three field-bearing shapes — a NARROWED union local (`if n is A {…}`),
// a VARIANT-TYPED value/param (`fn f(n: A)`, the `checkXNode(n: Variant)` idiom), or a
// plain declared struct — or -1 when the receiver is none of these. The single place
// the `exprString`/`exprStruct`/`exprArray`/`exprMap` classifiers consult so a field
// read of ANY receiver shape resolves to its declared field type.
function memberFieldCode(memIx: i32, fnIx: i32) {
  const e = P.nodes[memIx]
  if e is Member {
    if memIsNarrowed(memIx) {
      let vi = memNarrowVariantIndex(memIx)
      if vi >= 0 {
        const vfi = variantFieldIndex(vi, e.memProp)
        if vfi >= 0 { return variantFieldTypeAt(vi, vfi) }
      }
      return -1
    }
    const pvi = exprVariantIndex(e.memObj, fnIx)
    if pvi >= 0 {
      const pvfi = variantFieldIndex(pvi, e.memProp)
      if pvfi >= 0 { return variantFieldTypeAt(pvi, pvfi) }
      return -1
    }
    let si = structIndexOfExpr(e.memObj, fnIx)
    if si >= 0 {
      let fi = sFieldIndex(si, e.memProp)
      if fi >= 0 { return sFieldTypeAt(si, fi) }
    }
  }
  -1
}

function exprString(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is StrLit { return true }
  if e is Paren { return exprString(e.parInner, fnIx) }
  // An if-EXPRESSION whose branch join is a STRING (`const b = if c { "x" } else { "y" }`):
  // the value is a string ref, so an UN-annotated binding classifies kind 3 — matching the
  // `(ref $aTypeIdx)` the `emitIfExprRef` join already emits. The checker proved both arms
  // agree, so the THEN arm's rep classifies the whole `if` (the numeric `exprIsF64`/`exprIsI64`
  // duals consult `ifExprArmIsKind` the same way). Without this an un-annotated string if-value
  // bound an i32 local while the `if` yielded a string ref — a wasm type mismatch.
  if e is IfStmt {
    const tv = ifThenValueIx(exprIx)
    return tv >= 0 && exprString(tv, fnIx)
  }
  if e is Call {
    // G6: `s.slice(...)` over a string receiver produces a string. Otherwise a
    // bare call produces a string iff the callee declares a `string` return.
    if exprIsStrSlice(exprIx, fnIx) { return true }
    // An INDEXED closure call `fs[i](x)` whose element signature returns `string`.
    if cloArrCallRetKind(exprIx, fnIx) == 3 { return true }
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      if fnRetString(callee.identName) { return true }
      // A string-returning function VALUE (a binding / `(i32) => string` param callee,
      // invisible to `fnRetString`): its resolved `>S` sig.
      return calleeReturnsString(callee.identName, fnIx)
    }
    // A string-returning FIELD-closure call (`o.label(3)` over a `(i32) => string` field).
    if callee is Member {
      const ffe = fieldClosureFeOfRecv(callee.memObj, callee.memProp, fnIx)
      if ffe >= 0 { return fRetStr[ffe] == 1 }
    }
    return false
  }
  if e is BinExpr {
    // A `m[k] ?? d` / `m.get(k) ?? d` read over a STRING-valued map yields a
    // string ref (the value type).
    const cms = coalesceMvSlot(exprIx, fnIx)
    if cms >= 0 { return mvValKind[cms] == 3 }
    // `r ?? d` over a `string | null` LHS yields a (non-null) string — the coalesce
    // recovers the non-null array ref, so `.length`/`+`/etc. on the result work.
    if e.binOp == "??" {
      if exprNullableString(e.binLeft, fnIx) { return true }
    }
    // G6: string concatenation `a + b` produces a string; no other binary operator
    // does (`==`/`!=` yield an i32).
    return exprIsStrConcat(exprIx, fnIx)
  }
  if e is Ident {
    // A VALUE-union ident is a string ONLY when narrowed to the `string` atom
    // (the unboxed read is the array ref); an un-narrowed union binding is the
    // BOX, even when its init was a string literal (see exprIsI64).
    const uk = unionIdentReadKind(exprIx, fnIx)
    if uk != -3 { return uk == 2 }
    if paramString(fnIx, e.identName) { return true }
    if declaredString(e.identName) { return true }
    // A CAPTURED string (`const s = "…"; () => s.length`): the env field is a string ref (kind
    // 3), so classify it like a string param/local — else `s.length` reads as a struct field.
    if capturedKindOf(fnIx, e.identName) == 3 { return true }
    return globalIsString(e.identName)
  }
  // An index read over a STRING list (`names[i]`, a `string[]` element) yields a
  // string ref. (An index over an i32 list or a string `s[i]` yields an i32 — the
  // string-array check is the only string-producing index form.)
  if e is Index {
    if exprStringArray(e.idxArr, fnIx) { return true }
  }
  // A field read `p.f` where `f` is a STRING struct field yields a string ref (gap #2:
  // `let k = t.kind` must give `k` the string type, not i32).
  if e is Member {
    // A UNION-typed field read narrowed to the `string` atom unboxes to the
    // string ref (the member-path dual of the Ident rule above).
    const muk = memberUnionReadKind(exprIx, fnIx)
    if muk != -3 { return muk == 2 }
    // A field read whose declared field type is `string` (code 3), or a `string | null`
    // niche field (code 20) read as a VALUE (it recovers the non-null string ref) —
    // resolved through the narrowed-local / variant-param / plain-struct shapes by
    // `memberFieldCode`.
    const mfc = memberFieldCode(exprIx, fnIx)
    return mfc == 3 || mfc == 20
  }
  false
}

// True if the `LetDecl` at `letIx` declares a string-typed local: its annotation is
// `string`, OR its initializer produces a string. Picks the local's valtype
// (`(ref $aTypeIdx)` vs i32) in `collectLocals`.
function letIsString(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if nameIsString(lt.tyName) { return true }
      }
    }
    return exprString(d.letInit, fnIx)
  }
  false
}

// True if the `LetDecl`/global at `letIx` declares an `i64` binding. ANNOTATION-ONLY:
// a bare integer literal stays i32 by design (Slice 1 keeps existing programs
// byte-identical), so only an explicit `: i64` annotation selects the i64 slot
// (valtype `0x7e`, kind 10). The initializer literal is then lowered as `i64.const`.
function letIsI64(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if lt.tyName == "i64" { return true }
      }
      return false
    }
    // Un-annotated: infer i64 from the initializer (`const m = n` where `n: i64`, i64
    // arithmetic, an i64-returning call), mirroring the host and `letIsF64`. At MODULE
    // scope (`fnIx < 0`) this recurses through `globalIsI64` for a global-ident operand,
    // terminating for an acyclic program (each global's init is below it) — the same shape
    // `globalKind`'s expression-family classifiers already rely on.
    if d.letInit >= 0 { return exprIsI64(d.letInit, fnIx) }
  }
  false
}

// True if the `LetDecl`/global at `letIx` declares an `f64` binding: an explicit
// `: f64` annotation, OR an UN-annotated binding whose initializer is a float `.`
// literal (e.g. `const a = 1.5`). Such a binding selects the f64 slot (valtype 0x7c,
// kind 11) and lowers its init literal as `f64.const`. An un-annotated float `let`
// was previously a hard error (`checkExprI32` rejects `.`), so accepting it here is
// strictly additive — no existing i32 program changes. (Slice 3.)
function letIsF64(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letType >= 0 {
      const lt = P.nodes[d.letType]
      if lt is TypeRef {
        if lt.tyName == "f64" { return true }
      }
      return false
    }
    if d.letInit >= 0 {
      const ie = P.nodes[d.letInit]
      if ie is NumLit { return numTextIsFloat(ie.numText) }
      // Un-annotated: infer f64 from the initializer (`const r = 1.5 + 2.5` / `const m =
      // x` where `x: f64` / a float-returning call). At MODULE scope (`fnIx < 0`) this
      // recurses through `globalIsF64` for a global-ident operand, which terminates for an
      // acyclic program (each global's init is below it) — the same shape `globalKind`'s
      // expression-family classifiers (`exprString` / `exprStruct` / …) already rely on.
      return exprIsF64(d.letInit, fnIx)
    }
  }
  false
}

// True if the `LetDecl` at `letIx` binds a FUNCTION VALUE (kind 14): its initializer is
// a `function(...)` literal, a bare reference to a top-level/lifted function name, or a
// call returning a function value. The cell is the closure fat-pointer `(ref
// $cloStructIdx)`. (Lambdas.)
function letIsClosure(letIx: i32, fnIx: i32) {
  let d = P.nodes[letIx]
  if d is LetDecl {
    if d.letInit < 0 { return false }
    return exprIsClosure(d.letInit, fnIx)
  }
  false
}

// True if the expression at `exprIx` evaluates to a function value (a closure
// fat-pointer): a `function(...)` literal, a bare reference to a top-level/lifted
// function name, a reference to a closure-typed param/local, or a call returning a
// function value (a function whose body's tail is itself a function value).
function exprIsClosure(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Paren { return exprIsClosure(e.parInner, fnIx) }
  if e is FuncDecl { return true }
  // An if-EXPRESSION whose branch join is a CLOSURE (`const f = if c then g else h`): the value
  // is a closure ref, so an un-annotated binding classifies kind 14 — the THEN arm's rep (the
  // arms agreeing by the checker), matching the `(ref $cloStruct)` `emitIfExprRef` emits.
  if e is IfStmt {
    const tv = ifThenValueIx(exprIx)
    return tv >= 0 && exprIsClosure(tv, fnIx)
  }
  if e is Ident {
    if fnIndexOf(e.identName) >= 0 { return true }
    // A closure-typed param/local (kind 14), or a NULLABLE one (kind 19) — both call via
    // `call_ref`; the nullable cell is recovered to non-null at the call site (after the
    // `if c != null` narrowing the checker requires).
    if paramIsClosure(fnIx, e.identName) { return true }
    if paramNulClosure(fnIx, e.identName) { return true }
    let slot = declaredSlotOf(e.identName)
    if slot >= 0 { return localIsRef[slot] == 14 || localIsRef[slot] == 19 }
    // A module-global closure cell — a bare closure (kind 14) or a NULLABLE one (kind 19).
    const gl = globalLetOf(e.identName)
    if gl >= 0 {
      const gk = globalCellKind(gl)
      return gk == 14 || gk == 19
    }
    return false
  }
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Ident {
      const t = fnIndexOf(callee.identName)
      if t >= 0 { return fnReturnsClosure(t) }
      // A CLOSURE-VALUE callee (`f(4)` where `f: (i32) => ((i32) => i32)`) whose result is
      // itself a closure — resolved from `f`'s `$fnsig` result (`>c`). Lets a curried lambda
      // `const g = f(4)` bind `g` as a closure and call it.
      return calleeRetKind(callee.identName, fnIx) == 14
    }
    return false
  }
  if e is Member {
    // A struct field holding a function value reads back as a closure.
    return memberIsClosure(e.memObj, callMemProp(exprIx), fnIx)
  }
  // An index `xs[i]` into an ARRAY OF FUNCTIONS (`((i32) => i32)[]`, ref-list element
  // kind 5) reads back a closure fat-pointer — callable via `call_ref`.
  if e is Index {
    if exprRefArray(e.idxArr, fnIx) {
      const slot = refListSlotOfExpr(e.idxArr, fnIx)
      if slot >= 0 && slot < rlElemKindTbl.length {
        return rlElemKindTbl[slot] == 5
      }
    }
    // A bare `m[k]` over a FUNCTION-valued map (`{[string]: (i32) => i32}`, mv kind 14) reads
    // back the closure (nullable — narrow with `if f != null`).
    const mrs = mapReadMvSlot(exprIx, fnIx)
    if mrs >= 0 { return mvValKind[mrs] == 14 }
  }
  // `m[k] ?? d` over a function-valued map yields the closure.
  if e is BinExpr {
    const cm = coalesceMvSlot(exprIx, fnIx)
    if cm >= 0 { return mvValKind[cm] == 14 }
  }
  false
}

// The closure-ABI param-kind code for a type NAME — the annotation-string analogue of
// `cloParamTok` (which reads the AST), producing the IDENTICAL token per valtype so a
// value call over an annotated higher-order callee (`g: (string) => i32`) resolves the
// same interned `$fnsig` the passed lambda was minted under. "" for a type outside the
// value-call ABI (the all-i32 arity fallback / soundness floor then applies).
function annParamKind(t: string) {
  if t == "i32" || t == "boolean" { return "i" }
  if t == "f64" { return "d" }
  if t == "i64" {
    return "I" // i64 scalar param (matches `cloParamTok` kind 10)
  }
  if t == "f32" {
    return "f" // f32 scalar param (matches `cloParamTok` kind 13)
  }
  if isUName(t) {
    return "u" // a declared union name (matches `cloParamTok` kind 4)
  }
  if nameIsString(t) { return "S" }
  if nameIsI32Array(t) { return "a" }
  if nameIsStringArray(t) { return "A" }
  if nameIsF64Array(t) { return "D" }
  const si = structIndexByName(t)
  if si >= 0 { return "s" + i32ToStr(si) + ";" }
  // A concrete-variant name (`Cat`) — kind 8, keyed by the variant index (matches `cloParamTok`).
  const vti = variantIndexOf(t)
  if vti >= 0 { return "V" + i32ToStr(vti) + ";" }
  // A ref-LIST param (`S[]`, `(C|D)[]`, a closure / nested list) — token `r<slot>;`, the recursive
  // dual of `annRetKind`'s `>r<slot>;` result and `cloParamTok` kind 5. BEFORE the arrow case so a
  // closure-ELEMENT array's nested `=>` is not misread as a single closure. The slot resolves via
  // the element name — the SAME `rlSlotByName(refArrElemName(...))` the AST producer uses.
  if nameIsRefArray(t) {
    const rs = rlSlotByName(refArrElemName(t))
    if rs >= 0 { return "r" + i32ToStr(rs) + ";" }
  }
  // A FUNCTION-type param (`(i32) => i32`) is the shared closure fat-pointer — token `c`, matching
  // `cloParamTok` kind 14. Without this a higher-order closure param (a callback that itself takes
  // a callback) left the value's `$fnsig` un-interned: the call fell back to the all-i32 arity sig
  // and emitted INVALID WASM. The arrow finder is recursive (a top-level `=>` at paren depth 0).
  if annArrowAt(t) >= 0 { return "c" }
  // A struct param the CHECKER rendered structurally (`{x: i32}`, not a nominal `P`) — the call-site
  // `nodeTyName` fallback in `cloCallSigKey` produces such a name. `structIndexOfTypeName` resolves
  // BOTH a nominal name (above, via `structIndexByName`) and an inline shape (by field-set match), to
  // the SAME struct index the AST producer's `cloParamTok` keys — so the two sig producers agree.
  const sti = structIndexOfTypeName(t)
  if sti >= 0 { return "s" + i32ToStr(sti) + ";" }
  ""
}

function annRetKind(t: string) {
  if t == "i32" || t == "boolean" { return ">i" }
  if t == "f64" { return ">d" }
  if t == "void" { return ">v" }
  if t == "string" { return ">S" }
  if t == "i64" { return ">I" }
  if t == "f32" {
    return ">f" // f32 scalar result (matches `cloRetKeySuffix` kind 13)
  }
  // A LIST return — `i32[]` → `>a`, `string[]` → `>A`, `f64[]` → `>D` (matching
  // `cloRetKeySuffix` for the underlying function), so a `(i32) => i32[]` callback
  // resolves the interned signature and its value call lowers.
  if t == "i32[]" { return ">a" }
  if nameIsStringArray(t) { return ">A" }
  if nameIsF64Array(t) { return ">D" }
  // A REF-LIST return — `S[]` / `((i32) => i32)[]` / a union list → `>r<slot>;`, matching
  // `cloRetKeySuffix`. BEFORE the closure case so a closure-ELEMENT array's nested `=>` is not
  // misread as a single-closure result. The slot resolves via the element name — the SAME
  // `rlSlotByName(refArrElemName(...))` the AST producer's `cloRetValSlot` uses, so the two
  // producers' keys byte-match (else the value-call `ref.cast` to this `$fnsig` traps).
  if nameIsRefArray(t) {
    const rs = rlSlotByName(refArrElemName(t))
    if rs >= 0 { return ">r" + i32ToStr(rs) + ";" }
  }
  // A CLOSURE return — a function-type result (`(i32) => ((i32) => i32)`) → `>c`, matching
  // `cloRetKeySuffix`'s closure-result token so the AST and annotation sig producers agree
  // (a curried lambda's `$fnsig` must byte-match, else the value-call `ref.cast` traps). The
  // result often arrives PARENTHESIZED (`((i32) => i32)` — source groups the arrow result),
  // hiding its arrow one paren-depth down, so peel a single fully-wrapping `(...)` first.
  let tc = t
  if tc.length >= 2 && tc[0] == '(' {
    let depth = 0
    let ci = 0
    let wraps = true
    while ci < tc.length {
      const cch = tc[ci]
      if cch == '(' {
        depth = depth + 1
      } else if cch == ')' {
        depth = depth - 1
        if depth == 0 && ci < tc.length - 1 { wraps = false }
      }
      ci = ci + 1
    }
    if wraps { tc = tc.slice(1, tc.length - 1) }
  }
  if annArrowAt(tc) >= 0 { return ">c" }
  // `structIndexOfTypeName` (not `structIndexByName`) so a struct return the CHECKER rendered as an
  // inline shape (`{x: i32}` — the `cloCallSigKey` `nodeTyName` fallback's form) resolves by field-set
  // to the same index the AST producer's `cloRetValSlot` keys, as well as a nominal `P`.
  const si = structIndexOfTypeName(t)
  if si >= 0 { return ">s" + i32ToStr(si) + ";" }
  // A UNION / NULLABLE return — `string | null` → `>N`, `S | null` → `>nN;`, a 2+-member
  // union → the box `>u` (matching `cloRetKeySuffix` for the underlying function). An
  // `i32 | null` boxed niche and any other shape stay "" (un-resolvable here). A union ALIAS
  // (`type Sh = C | S`) is resolved to its member set first (`unionMemberSetOf`), so a closure
  // returning the alias (`(i32) => Sh`) keys `>u` — matching `cloRetKeySuffix`, which reaches the
  // box via `vtKindOfType` recognizing the alias. (A non-union name passes through unchanged.)
  const parts: string[] = []
  annSplitPipe(unionMemberSetOf(t), parts)
  if parts.length >= 2 {
    const nonNull: string[] = []
    let hasNull = false
    let pi = 0
    while pi < parts.length {
      const p = parts[pi]
      if p == "null" { hasNull = true }
      else if p.length > 0 { nonNull.push(p) }
      pi = pi + 1
    }
    if hasNull && nonNull.length == 1 {
      if nonNull[0] == "string" { return ">N" }
      const msi = structIndexOfTypeName(nonNull[0])
      if msi >= 0 { return ">n" + i32ToStr(msi) + ";" }
      return ""
    }
    if nonNull.length >= 2 { return ">u" }
  }
  ""
}

// The `$fnsig` KEY of a SOURCE function-type annotation `(params)=>ret` — the SAME
// encoding `fnSigKeyOf` produces for a function (`"i>i"`, `"d>d"`, `"s3;>i"`), so a value
// call over an annotated callee resolves the interned signature. "" if any param/return
// type is outside the value-call ABI (the all-i32 arity fallback then applies).
function annSigKey(name: string) {
  const arrowAt = annArrowAt(name)
  if arrowAt < 1 { return "" }
  if name[0] != '(' { return "" }
  if name[arrowAt - 1] != ')' { return "" }
  const paramsStr = name.slice(1, arrowAt - 1)
  const retStr = name.slice(arrowAt + 2, name.length)
  let key = ""
  if paramsStr.length > 0 {
    const parts: string[] = []
    annSplitParams(paramsStr, parts)
    let i = 0
    while i < parts.length {
      const pc = annParamKind(parts[i])
      if pc == "" { return "" }
      key = key + pc
      i = i + 1
    }
  }
  const rc = annRetKind(retStr)
  if rc == "" { return "" }
  key + rc
}

// The lifted-function position (`fnStmts` index) of the function VALUE bound to `let`/
// `const`/global `name` in scope of `fnIx` — `const f = dbl` traces to `dbl`, `const f =
// function(…)…` to the lifted lambda. -1 when `name` is not a binding holding a bare
// function value. Lets a closure call over an INFERRED binding resolve the callee's real
// signature (`fnSigKeyOf`), not the all-i32 arity sig.
function identClosureFe(name: string, fnIx: i32) {
  if fnIx >= 0 {
    const fn = P.nodes[fnIx]
    if fn is FuncDecl {
      const li = parentLetOf(fn.fnBody, name)
      if li >= 0 {
        const d = P.nodes[li]
        if d is LetDecl { return fieldValueFeOf(d.letInit) }
      }
    }
  }
  const gi = globalLetOf(name)
  if gi >= 0 {
    const gd = P.nodes[gi]
    if gd is LetDecl { return fieldValueFeOf(gd.letInit) }
  }
  -1
}

// The function-type ANNOTATION NAME (`(f64)=>f64`) of a `let`/`const`/global `name` in
// scope of `fnIx`, or "" when `name` is not a function-typed binding.
function identFnTypeAnnName(name: string, fnIx: i32) {
  if fnIx >= 0 {
    const fn = P.nodes[fnIx]
    if fn is FuncDecl {
      const li = parentLetOf(fn.fnBody, name)
      if li >= 0 {
        const d = P.nodes[li]
        if d is LetDecl {
          if tyIsFuncType(d.letType) { return tyNameOf(d.letType) }
          // An UN-annotated closure local from a CALL result (`const g = f(4)` where `f`
          // returns a closure): recover the function type from the checker's recorded type of
          // the init, so its `$fnsig` resolves (the intermediate binding of a curried lambda).
          // Restricted to a Call init: for a bare LAMBDA init the authoritative sig is the
          // lifted function's own `cloSigKeyExt` (via `identClosureFe`), and the checker's
          // INFERRED return for that lambda can disagree (an assignment-tail lambda the checker
          // reads as i32-returning but the emitter lowers as void) — which would mis-cast.
          if d.letType < 0 && d.letInit >= 0 {
            const ini = P.nodes[d.letInit]
            if ini is Call {
              const itn = nodeTyName(d.letInit)
              if annArrowAt(itn) >= 0 { return itn }
            }
          }
        }
      }
    }
  }
  const gi = globalLetOf(name)
  if gi >= 0 {
    const gd = P.nodes[gi]
    if gd is LetDecl {
      if tyIsFuncType(gd.letType) { return tyNameOf(gd.letType) }
    }
  }
  ""
}

// The `$fnsig` KEY for a function-VALUE callee Ident `name` (in scope of `fnIx`): a
// function-typed PARAM (its annotation / monomorphized pin), a function-typed LOCAL/GLOBAL
// annotation, or — for an INFERRED binding — the underlying function's own sig. "" → the
// all-i32 arity fallback applies (an unresolved or non-value-ABI signature, incl. void).
function calleeCloSigKey(name: string, fnIx: i32) {
  const pk = paramCloSigKey(fnIx, name)
  if pk != "" { return pk }
  const an = identFnTypeAnnName(name, fnIx)
  if an != "" {
    const ak = annSigKey(an)
    if ak != "" { return ak }
  }
  const fe = identClosureFe(name, fnIx)
  // The EXTENDED key (not just `fnSigKeyOf`) so a VOID-returning binding (`const f = hi`)
  // resolves its `>v` sig — interned above for void function values. A value-eligible
  // (i32/f64) binding takes the same key `fnSigKeyOf` would give.
  if fe >= 0 { return cloSigKeyExt(fe) }
  ""
}

// True if the function-VALUE callee `name` (in scope of `fnIx`) returns f64 — its resolved
// `$fnsig` key ends in `>d`. Drives the closure-call RESULT classification (print routing,
// numeric-context coercion), the value-call analogue of `fRetF64` for a named function.
function calleeReturnsF64(name: string, fnIx: i32) {
  const k = calleeCloSigKey(name, fnIx)
  const n = k.length
  if n < 2 { return false }
  k[n - 2] == '>' && k[n - 1] == 'd'
}

// True if the function-VALUE callee `name` (in scope of `fnIx`) returns void — its
// resolved `$fnsig` key ends in `>v`. A void closure call leaves NOTHING on the stack, so
// its statement form must NOT `drop` (the value-call analogue of `fRetVoid` for a named
// function — which `fnIndexOf` can't see for a param / binding closure value).
function calleeReturnsVoid(name: string, fnIx: i32) {
  const k = calleeCloSigKey(name, fnIx)
  const n = k.length
  if n < 2 { return false }
  k[n - 2] == '>' && k[n - 1] == 'v'
}

// True if the function-VALUE callee `name` (in scope of `fnIx`) returns a string — its
// resolved `$fnsig` key ends in `>S`. The value-call analogue of `fnRetString` for a named
// function — drives the closure-call RESULT's string typing (binding cell, print routing).
function calleeReturnsString(name: string, fnIx: i32) {
  const k = calleeCloSigKey(name, fnIx)
  const n = k.length
  if n < 2 { return false }
  k[n - 2] == '>' && k[n - 1] == 'S'
}

// True if the function-VALUE callee `name` (in scope of `fnIx`) returns i64 — its resolved
// `$fnsig` key ends in `>I`. The value-call analogue of `fRetI64` for a named function —
// drives the closure-call RESULT's i64 typing (print routing, numeric-context coercion).
function calleeReturnsI64(name: string, fnIx: i32) {
  const k = calleeCloSigKey(name, fnIx)
  const n = k.length
  if n < 2 { return false }
  k[n - 2] == '>' && k[n - 1] == 'I'
}

// The struct-table INDEX a function-VALUE callee `name` (in scope of `fnIx`) returns, or
// -1. Its resolved `$fnsig` key ends in the struct-ref return marker `>sN;` (a `S` struct)
// or `>nN;` (an `S | null` nullable struct) — params never contain `>`, so the last `>`
// begins the return. The value-call analogue of `fnRetStructIndex` — drives the closure-
// call RESULT's struct typing (`p.x` over `const p = f(5)`, struct or nullable-struct).
function calleeReturnsStructIdx(name: string, fnIx: i32) {
  const k = calleeCloSigKey(name, fnIx)
  const n = k.length
  if n < 4 { return -1 }
  if k[n - 1] != ';' { return -1 }
  let i = 0
  let gt = -1
  while i < n {
    if k[i] == '>' { gt = i }
    i = i + 1
  }
  if gt < 0 || gt + 2 >= n { return -1 }
  if k[gt + 1] != 's' && k[gt + 1] != 'n' { return -1 }
  let j = gt + 2
  let num = 0
  let any = false
  while j < n && k[j] >= '0' && k[j] <= '9' {
    num = num * 10 + (k[j] - '0')
    any = true
    j = j + 1
  }
  if !any || j != n - 1 { return -1 }
  num
}

// The `cloRetValKind`-style RESULT kind of a function-VALUE callee `name` (in scope of
// `fnIx`), decoded from the trailing `>X` token of its resolved `$fnsig` key — `0` i32,
// `11` f64, `10` i64, `3` string, `2`/`7`/`12` the i32/string/f64 lists, `4` a union box,
// `16` `string | null`, `1` a struct, `9` a nullable struct, `-1` void. `-3` when `name`
// resolves to no value-call sig. Drives the per-kind closure-call RESULT classifiers.
// The RESULT value-KIND encoded in a closure `$fnsig` key (the atom after the final `>`),
// or -3 when the key is empty / malformed. The kind codes match `cloRetValKind` /
// `calleeRetKind`. Shared by the Ident-callee path (`calleeRetKind`) and the indexed-element
// path (`cloArrCallRetKind`).
function sigKeyRetKind(k: string) {
  const n = k.length
  if n < 2 { return -3 }
  let i = 0
  let gt = -1
  while i < n {
    if k[i] == '>' { gt = i }
    i = i + 1
  }
  if gt < 0 || gt + 1 >= n { return -3 }
  const c = k[gt + 1]
  if c == 'i' { return 0 }
  if c == 'd' { return 11 }
  if c == 'I' { return 10 }
  if c == 'S' { return 3 }
  if c == 'a' { return 2 }
  if c == 'A' { return 7 }
  if c == 'D' { return 12 }
  if c == 'u' { return 4 }
  if c == 'N' { return 16 }
  if c == 'v' { return -1 }
  if c == 's' { return 1 }
  if c == 'n' { return 9 }
  if c == 'V' {
    return 8 // a concrete-variant result
  }
  if c == 'c' {
    return 14 // a CLOSURE result (a function returning a function)
  }
  if c == 'r' {
    return 5 // a REF-LIST result (`>r<slot>;` — struct / closure / union list)
  }
  -3
}

// The ref-list SLOT of a `>r<slot>;` result key (the digits between `r` and `;`), or -1 when the
// key's result is not a ref list. Lets a closure-VALUE call result (`mk()` with `mk: () => S[]`)
// recover its element ref-list slot for an index/`.length`/for-in directly off the callee's sig.
function sigKeyRetSlot(k: string) {
  const n = k.length
  let gt = -1
  let i = 0
  while i < n {
    if k[i] == '>' { gt = i }
    i = i + 1
  }
  if gt < 0 || gt + 2 >= n { return -1 }
  if k[gt + 1] != 'r' { return -1 }
  let j = gt + 2
  let acc = 0
  let saw = false
  while j < n && k[j] != ';' {
    const d = k[j]
    if d < '0' || d > '9' { return -1 }
    acc = acc * 10 + (d - '0')
    saw = true
    j = j + 1
  }
  if !saw { return -1 }
  acc
}

function calleeRetKind(name: string, fnIx: i32) {
  return sigKeyRetKind(calleeCloSigKey(name, fnIx))
}

// The RESULT value-KIND of a call whose CALLEE is an INDEX into a closure array
// (`fs[i](x)`): the closure-element signature's return atom (`cloArrSlotSigKey` →
// `sigKeyRetKind`). -3 when the call's callee is not an indexed closure value. The expr
// classifiers (`exprString`/`exprIsF64`/… Call arms) consult this so an indexed closure
// call's result routes to the right print / arithmetic / store path — the dual of the
// call-SIGNATURE resolution `emitCallRef` does for the same shape.
function cloArrCallRetKind(callIx: i32, fnIx: i32) {
  const c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Index {
      if exprRefArray(callee.idxArr, fnIx) {
        return sigKeyRetKind(cloArrSlotSigKey(refListSlotOfExpr(callee.idxArr, fnIx)))
      }
    }
  }
  -3
}

function paramCloSigKey(fnIx: i32, name: string) {
  if fnIx < 0 { return "" }
  const fn = P.nodes[fnIx]
  if fn is FuncDecl {
    const params = fn.fnParams
    let i = 0
    while i < params.length {
      const p = P.nodes[params[i]]
      if p is Param {
        if p.parName == name {
          if p.parType >= 0 {
            const ty = P.nodes[p.parType]
            if ty is TypeRef {
              let nm = ty.tyName
              if nm.length > 2 {
                // A MONOMORPHIZED closure-pinned param carries the bare `"=>sigkey"`.
                if nm[0] == '=' && nm[1] == '>' {
                  return nm.slice(2, nm.length)
                }
                // A SOURCE function-type annotation `(params)=>ret`: derive its sig key,
                // so a non-i32 (e.g. f64) signature casts to the right functype.
                if strContains(nm, "=>") { return annSigKey(nm) }
              }
            }
          }
          return ""
        }
      }
      i = i + 1
    }
  }
  ""
}

// True if the function at `fnStmts` position `t` returns a function value — its body's
// tail expression is itself a function value (a bare function name, a `function(...)`
// literal, or a closure-typed local). Drives `exprIsClosure` for call results
// (`const f = makeAdder(5)` where `makeAdder` returns its inner closure).
function fnReturnsClosure(t: i32) {
  if t < 0 || t >= fnStmts.length { return false }
  const fn = P.nodes[fnStmts[t]]
  if fn is FuncDecl {
    // An ANNOTATED function-type return (`: (i32) => i32`) is a closure result regardless of
    // how the body yields it — e.g. `return f(x)`, a higher-order call the tail scan can't see
    // (`exprIsClosureNoLocal` has no Call case). The annotated result valtype is already kind 14.
    if fn.fnRet >= 0 && tyIsFuncType(fn.fnRet) { return true }
    return blockTailIsClosure(fn.fnBody, fnStmts[t])
  }
  false
}

// True if the block's tail (implicit-return) expression is a function value.
function blockTailIsClosure(blockIx: i32, fnIx: i32) {
  let b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    let n = stmts.length
    if n == 0 { return false }
    const last = stmts[n - 1]
    let s = P.nodes[last]
    if s is RetStmt {
      if s.retArg >= 0 { return exprIsClosureNoLocal(s.retArg, fnIx) }
      return false
    }
    return exprIsClosureNoLocal(last, fnIx)
  }
  false
}

// `exprIsClosure` restricted to forms safe to query during return-kind classification
// (avoids recursion through `declaredSlotOf`, which needs the local registry built):
// a function name, a `function(...)` literal, or an object field. Captures the common
// `return add` / `{ go: add }` escaping-closure tails.
function exprIsClosureNoLocal(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Paren { return exprIsClosureNoLocal(e.parInner, fnIx) }
  if e is FuncDecl { return true }
  if e is Ident { return fnIndexOf(e.identName) >= 0 }
  if e is ObjLit { return false }
  false
}

// True if member access `obj.prop` yields a function value — `prop` is a struct field
// whose declared type is a function type. (For `objects/equality-function-field.vl` and
// `escaping.vl`'s `o.go`.) Resolved against the receiver's struct table fields.
function memberIsClosure(objIx: i32, prop: string, fnIx: i32) {
  let si = structIndexOfExpr(objIx, fnIx)
  if si < 0 { return false }
  return structFieldIsClosure(si, prop)
}

// True if field `prop` of struct table index `si` is a function-valued field — a bare
// closure (code 14) or a NULLABLE closure (code 22). Both read back as a closure and call
// via `call_ref`; the nullable one is recovered to non-null at the call site.
function structFieldIsClosure(si: i32, prop: string) {
  if si < 0 || si >= sNames.length { return false }
  let cnt = sFieldCount[si]
  let start = sFieldStart[si]
  let fj = 0
  while fj < cnt {
    if sFieldNames[start + fj] == prop {
      const fc = sFieldTypeAt(si, fj)
      return fc == 14 || fc == 22
    }
    fj = fj + 1
  }
  false
}

// `xs.pop()` / `xs.get(i)` over a STRUCT-element ref list — the host types both as
// `S | null`. Returns the element STRUCT TABLE INDEX, or -1 when the call is not such
// a read. Restricted to plain-struct elements (`rlElemKindTbl == 1`): map-array
// (`{[string]:i32}[]`, kind 3) and union-element (kind 2) pops keep their existing
// classification (g_maparray's golden bytes depend on it).
function structListPopGetElem(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return -1 }
  const e = P.nodes[exprIx]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "pop" || callee.memProp == "get" {
        if exprRefArray(callee.memObj, fnIx) {
          let slot = refListSlotOfExpr(callee.memObj, fnIx)
          if slot >= 0 && slot < rlElemKindTbl.length {
            if rlElemKindTbl[slot] == 1 {
              return structIdxOfElemName(rlElemName[slot])
            }
          }
        }
      }
    }
  }
  -1
}

// ── `.map` / `.filter` classification (Slices 3–4) ─────────────────────────────

// True if the expression at `exprIx` is a `.map`/`.filter` HOF call over a LIST
// receiver (one callback argument). A member call named `map`/`filter` over a
// NON-list receiver (e.g. a function-valued struct field) is NOT a HOF site.
function callIsMapFilter(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "map" || callee.memProp == "filter" {
        if e.callArgs.length == 1 {
          return mfRecvKindOf(callee.memObj, fnIx) >= 0
        }
      }
    }
  }
  false
}

// True if the expression at `exprIx` is an array `.slice(start, end?)` over a LIST
// receiver — a sublist of the SAME element type. (A string `.slice` is a separate
// `exprIsStrSlice` path; this is the array dual.)
function callIsArrSlice(exprIx: i32, fnIx: i32) {
  if exprIx < 0 { return false }
  const e = P.nodes[exprIx]
  if e is Call {
    const callee = P.nodes[e.callFn]
    if callee is Member {
      if callee.memProp == "slice" {
        if e.callArgs.length == 1 || e.callArgs.length == 2 {
          return mfRecvKindOf(callee.memObj, fnIx) >= 0
        }
      }
    }
  }
  false
}

// The RECEIVER list kind of a `.map`/`.filter` call: `0` (i32/boolean list), `1`
// (f64 list), `2` (struct/union ref list), or -1 (not a supported list — a string
// list or a non-list receiver).
function mfRecvKindOf(recvIx: i32, fnIx: i32) {
  if exprF64Array(recvIx, fnIx) { return 1 }
  // An i64 list (mf-kind 4) / f32 list (mf-kind 13) — the scalar siblings of the f64 list,
  // checked before `exprArray` (the i32 fallback) since their elements are not i32.
  if exprI64Array(recvIx, fnIx) { return 4 }
  if exprF32Array(recvIx, fnIx) { return 13 }
  if exprRefArray(recvIx, fnIx) { return 2 }
  if exprStringArray(recvIx, fnIx) { return 3 }
  if exprArray(recvIx, fnIx) { return 0 }
  -1
}

// The RESULT element kind of the `.map`/`.filter` call at `callIx`: `0` (i32/boolean
// element — an i32 list result), `1` (f64 element — an f64 list result), or -1
// (unsupported). `filter` keeps the receiver's element kind (a ref-list filter is
// out of scope — it fails loudly at emit); `map`'s result element kind IS the
// callback's RETURN kind (`cloRetKindOf`).
function mfResultKindOf(callIx: i32, fnIx: i32) {
  let c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      // `.slice` preserves the element type — its result kind IS the receiver's.
      if callee.memProp == "slice" { return mfRecvKindOf(callee.memObj, fnIx) }
      if callee.memProp == "filter" {
        let rk = mfRecvKindOf(callee.memObj, fnIx)
        if rk == 0 { return 0 }
        if rk == 1 { return 1 }
        // A REF list (struct/union elements) — `.filter` PRESERVES the element type, so the
        // result is the SAME ref list (kind 2). Its backing/wrapper come from the source slot.
        if rk == 2 { return 2 }
        if rk == 3 { return 3 }
        // i64 / f32 lists preserve their element type too (mf-kinds 4 / 13).
        if rk == 4 { return 4 }
        if rk == 13 { return 13 }
        return -1
      }
      if c.callArgs.length == 1 {
        let fe = mfCallbackFe(c.callArgs[0], fnIx)
        if fe < 0 {
          // A CLOSURE-VALUE callback (`xs.map(f)`, `f` a function-typed param/binding) — its result
          // kind comes from the closure's sig RETURN token, not a lifted fe (scalar returns only).
          const ck = mfCallbackCloKey(c.callArgs[0], fnIx)
          if ck != "" { return mfResKindFromSigRet(sigKeyRetKind(ck)) }
          return -1
        }
        // A string-returning callback maps to a string-list result (kind 3) — checked first
        // since `cloRetKindOf` folds string into -1.
        if cloRetIsString(fe) { return 3 }
        // A STRUCT-returning callback maps to a NEW ref list of the result struct (kind 2) —
        // `cloRetKindOf` folds a struct into -1, so consult `cloRetValKind` (which classifies
        // the struct result as kind 1) directly. The result element type DIFFERS from the
        // source (`P[].map((p) => Q-shape)` ⇒ `Q[]`), so the dst slot is the RESULT struct's
        // ref-list slot, not the source's (`mfResultSlotOf`).
        if cloRetValKind(fe) == 1 { return 2 }
        // A concrete-VARIANT-returning callback (a collapse) maps to a ref list of bare
        // variant structs (kind 2, element a variant) — checked before the union case since
        // `cloRetValKind` already prefers the variant.
        if cloRetValKind(fe) == 8 { return 2 }
        // A UNION-returning callback maps to a ref list of union BOXES (kind 2, element kind
        // 2). All unions share `$uBox`, so the result element is the declared union; its box
        // body is produced by the callback's own union-boxing return path.
        if cloRetValKind(fe) == 4 { return 2 }
        // An i64- / f32-returning callback maps to an i64- / f32-list result (mf-kinds 4 / 13).
        // `cloRetKindOf` folds these to -1 (out of the value-CALL ABI), so consult
        // `cloRetValKind` (10 = i64, 13 = f32) directly, as the struct/union cases above do.
        if cloRetValKind(fe) == 10 { return 4 }
        if cloRetValKind(fe) == 13 { return 13 }
        const rk2 = cloRetKindOf(fe)
        if rk2 == 0 { return 0 }
        if rk2 == 11 { return 1 }
      }
      return -1
    }
  }
  -1
}

// The ref-list TABLE SLOT of a kind-2 `.map`/`.filter` result, or -1. `.filter` preserves the
// receiver's element list, so the result slot IS the source ref-list slot.
function mfResultSlotOf(callIx: i32, fnIx: i32) {
  const c = P.nodes[callIx]
  if c is Call {
    const callee = P.nodes[c.callFn]
    if callee is Member {
      // `.slice` preserves the ref-list element — its result slot IS the receiver's.
      if callee.memProp == "slice" {
        if mfRecvKindOf(callee.memObj, fnIx) == 2 {
          return refListSlotOfExpr(callee.memObj, fnIx)
        }
      }
      if callee.memProp == "filter" {
        if mfRecvKindOf(callee.memObj, fnIx) == 2 {
          return refListSlotOfExpr(callee.memObj, fnIx)
        }
      }
      // A STRUCT-returning `.map`: the result is a NEW ref list whose element is the
      // callback's RETURN struct — its ref-list slot (interned by `mfScan`).
      if callee.memProp == "map" && c.callArgs.length == 1 {
        const fe = mfCallbackFe(c.callArgs[0], fnIx)
        if fe >= 0 && cloRetValKind(fe) == 1 {
          const si = cloRetValSlot(fe)
          if si >= 0 && si < sNames.length { return rlSlotByName(sNames[si]) }
        }
        // A struct-returning CLOSURE-VALUE callback (`xs.map(f)`, `f: (i32) => P`): no lifted fe, so the
        // result struct index comes from the closure's `>s<idx>;` sig-return token. Its ref-list slot
        // (`P[]`) is the `.map` result — the closure-value dual of the lifted-fe branch above.
        if fe < 0 {
          const ck = mfCallbackCloKey(c.callArgs[0], fnIx)
          if ck != "" {
            const csi = sigKeyRetStructIdx(ck)
            if csi >= 0 && csi < sNames.length {
              return rlSlotByName(sNames[csi])
            }
          }
        }
        // A concrete-VARIANT `.map`: the result element is the variant — its ref-list slot
        // is keyed by the variant NAME (`uVariants[vi]`).
        if fe >= 0 && cloRetValKind(fe) == 8 {
          const vi = cloRetValSlot(fe)
          if vi >= 0 && vi < uVariants.length {
            return rlSlotByName(uVariants[vi])
          }
        }
        // A UNION-returning `.map`: the result is a ref list of the declared union (all
        // unions share `$uBox`, so the element key is the union alias name).
        if fe >= 0 && cloRetValKind(fe) == 4 && unNames.length > 0 {
          return rlSlotByName(unNames[0])
        }
      }
    }
  }
  -1
}

// Resolve a `.map`/`.filter` CALLBACK argument to its lifted-function position in
// `fnStmts`: an inline `function(...)` literal (lifted by `collectFns`), a named
// function reference, or a let-bound function value whose binding initializer is one
// of those (a local `let` in the enclosing function, else a module global). -1 when
// the callback's target function cannot be statically resolved.
function mfCallbackFe(cbIx: i32, fnIx: i32) {
  if cbIx < 0 { return -1 }
  const inner = unwrapParen(cbIx)
  const e = P.nodes[inner]
  if e is FuncDecl { return fnStmtsPosOf(inner) }
  if e is Ident {
    const t = fnIndexOf(e.identName)
    if t >= 0 { return t }
    let li = -1
    if fnIx >= 0 {
      const fn = P.nodes[fnIx]
      if fn is FuncDecl { li = parentLetOf(fn.fnBody, e.identName) }
    }
    if li < 0 { li = globalLetOf(e.identName) }
    if li >= 0 {
      let d = P.nodes[li]
      if d is LetDecl {
        if d.letInit >= 0 {
          // Guard the degenerate self-referential binding against infinite recursion.
          if unwrapParen(d.letInit) != inner {
            return mfCallbackFe(d.letInit, fnIx)
          }
        }
      }
    }
  }
  -1
}

// True if the lifted callback at `fe` returns a BOOLEAN (its annotation, or the
// inferred `fRetBool`) — the element-bool-ness of a `.map` result, threaded to the
// print import choice (`__print_bool__` renders true/false).
function mfCbRetIsBool(fe: i32) {
  if fe < 0 || fe >= fnStmts.length { return false }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    if fn.fnRet >= 0 {
      const rt = P.nodes[fn.fnRet]
      if rt is TypeRef { return rt.tyName == "boolean" }
      return false
    }
    if fe < fRetBool.length { return fRetBool[fe] == 1 }
  }
  false
}

// True if an INDEX READ over the list at `arrIx` yields a boolean element. Today the
// only boolean-element list producer is a `.map` whose callback returns boolean
// (`xs.map(function(n: i32) n > 2)`); a `.filter` keeps its receiver's element
// bool-ness, and a module-global binding traces through its initializer.
function mfArrElemIsBool(arrIx: i32, fnIx: i32) {
  if arrIx < 0 { return false }
  const inner = unwrapParen(arrIx)
  const e = P.nodes[inner]
  if e is Call {
    if callIsMapFilter(inner, fnIx) {
      const callee = P.nodes[e.callFn]
      if callee is Member {
        if callee.memProp == "filter" {
          return mfArrElemIsBool(callee.memObj, fnIx)
        }
        return mfCbRetIsBool(mfCallbackFe(e.callArgs[0], fnIx))
      }
    }
    return false
  }
  if e is Ident {
    let li = globalLetOf(e.identName)
    if li >= 0 {
      let d = P.nodes[li]
      if d is LetDecl {
        if d.letInit >= 0 {
          if unwrapParen(d.letInit) != inner {
            return mfArrElemIsBool(d.letInit, -1)
          }
        }
      }
    }
  }
  false
}

// Detect `.map`/`.filter` HOF sites up front (one arena scan, mirroring the print
// scan): ANY site makes the program function-value-using (`fnValUsed` — the callback
// is a closure value even when it is a bare named-function reference), and a `.map`
// whose callback returns i32/boolean (f64) forces the i32 (f64) list types for the
// RESULT list — the receiver may be a ref/f64 list that never otherwise touches
// them. `.filter` reuses the receiver's own (already-collected) types. Runs after
// `computeRetInference` (an un-annotated callback's return kind is inferred);
// programs without `.map`/`.filter` set nothing — every golden stays byte-identical.
// True if the expression at `ix` is a bare Ident naming a top-level function —
// a function VALUE use when it sits in a value position (an initializer, an
// assignment's right side, an equality operand).
function exprIsBareFnName(ix: i32) {
  if ix < 0 { return false }
  const e = P.nodes[ix]
  if e is Ident { return fnIndexOf(e.identName) >= 0 }
  false
}

// Detect bare named-function VALUE uses the other flips miss (arena scan): a
// `let`/`const` initialized to a function name (`const f = inc`), a reassignment
// (`x = inc`), a function name as an equality operand (`inc == h`), or a
// function-valued object-literal field (`{ f: inc }` — `collectAnonShapes`' own
// flip is wiped by `collectFns`' reset, which runs after `collectS`; a LAMBDA
// field re-flips during the lift, a named-function field only here). Each such
// cell is a closure fat-pointer (kind 14), so the closure rec-group types must
// intern (`fnValUsed`) even when no lambda/`.map` site otherwise flips it.
// Programs without such uses set nothing — every golden stays byte-identical.
function collectFnValUse() {
  let i = 0
  while i < P.nodes.length {
    const nd = P.nodes[i]
    if nd is LetDecl {
      if exprIsBareFnName(nd.letInit) { fnValUsed = true }
    }
    if nd is BinExpr {
      if nd.binOp == "=" || nd.binOp == "==" || nd.binOp == "!=" {
        if exprIsBareFnName(nd.binLeft) { fnValUsed = true }
        if exprIsBareFnName(nd.binRight) { fnValUsed = true }
      }
    }
    if nd is FieldInit {
      if exprIsBareFnName(nd.fiValue) { fnValUsed = true }
    }
    // A closure if-VALUE whose ARM is a bare named function (`if c then inc else dec`): the
    // named function is used as a VALUE, so flip `fnValUsed` so its `$fnsig` interns (a lambda
    // arm already flips it during lifting). The loop visits every `IfStmt`, so this covers a
    // binding / return / argument if-value alike; an `else if` chain's nested `IfStmt` is its own
    // node, visited the same way, so each arm pair is checked.
    if nd is IfStmt {
      if exprIsBareFnName(ifArmValueExpr(nd.ifThen)) { fnValUsed = true }
      if nd.ifElse >= 0 {
        const el = P.nodes[nd.ifElse]
        if el is Block {
          if exprIsBareFnName(ifArmValueExpr(nd.ifElse)) { fnValUsed = true }
        }
      }
    }
    // A SOURCE function-type ANNOTATION (`f: (i32) => i32`, a `(…)=>…` TypeRef) flips the
    // function-value machinery on — the annotated param/field/binding is a closure
    // fat-pointer (kind 14) whose call site `call_ref`s through it, so its signature must
    // intern (`collectCloSigs`), exactly like a lifted lambda or a monomorphized
    // closure-pinned param.
    if nd is TypeRef {
      if tyIsFuncType(i) { fnValUsed = true }
      // A closure-ARRAY annotation (`((i32) => i32)[]`) ALSO uses function values — its
      // elements are closures stored/indexed/called through the array — so it flips the
      // machinery on too. (`tyIsFuncType` is now top-level-arrow only, so the nested arrow
      // here no longer trips it; without this, an array of functions whose ONLY function-type
      // mention is the array annotation would leave its element signatures un-interned and a
      // `fs[i](x)` call would find no signature.)
      if nameIsClosureArrayTy(i) == 1 { fnValUsed = true }
    }
    // An inferred CLOSURE-element array LITERAL (`const fs = [add, mul]`, no annotation): the
    // checker typed its element as a function type (`=>` in the element name), so its elements are
    // closures stored / indexed / called through the array — flip the machinery on to intern their
    // signatures, exactly as the closure-array ANNOTATION above does.
    if nd is ArrayLit {
      const aen = nodeArrayElemName(i)
      if aen != "" {
        if strContains(aen, "=>") { fnValUsed = true }
      }
    }
    i = i + 1
  }
  0
}

function collectMapFilterUse() {
  let i = 0
  while i < P.nodes.length {
    const nd = P.nodes[i]
    if nd is Call {
      const callee = P.nodes[nd.callFn]
      if callee is Member {
        if callee.memProp == "map" || callee.memProp == "filter" {
          if nd.callArgs.length == 1 {
            fnValUsed = true
            if callee.memProp == "map" {
              let fe = mfCallbackFe(nd.callArgs[0], -1)
              if fe >= 0 && cloRetIsString(fe) {
                // A string-returning callback: the result list is a string list, which may be
                // the program's ONLY one (an i32/struct source mapped to strings) — force its
                // wrapper/backing collection.
                slUsed = true
              } else if fe >= 0 && cloRetValKind(fe) == 1 {
                // A STRUCT-returning callback (`P[].map((p) => Q-shape)`): the result is a NEW
                // ref list of the callback's result struct — intern ITS slot (a `Q` reached only
                // as a map result has no `Q[]` annotation to force it) so `emitModule` assigns its
                // wrapper/backing and `mfResultSlotOf` resolves it. `cloRetKindOf` folds a struct
                // to -1, so consult `cloRetValKind`/`cloRetValSlot` directly.
                const rsi = cloRetValSlot(fe)
                if rsi >= 0 && rsi < sNames.length {
                  rlInternName(sNames[rsi], 1)
                  rlUsed = true
                  raUsed = true
                }
              } else if fe >= 0 && cloRetValKind(fe) == 8 {
                // A concrete-VARIANT-returning callback (a collapse): intern the variant's
                // ref-list slot (kind 1 — its element heap is `uVarIdx + vi`).
                const cvi = cloRetValSlot(fe)
                if cvi >= 0 && cvi < uVariants.length {
                  rlInternName(uVariants[cvi], 1)
                  rlUsed = true
                  raUsed = true
                }
              } else if (
                fe >= 0 &&
                cloRetValKind(fe) == 4 &&
                unNames.length > 0
              ) {
                // A UNION-returning callback (`xs.map((a) => unionVal)`): the result is a ref
                // list of union boxes (element kind 2). Intern the union alias's slot so a map
                // whose source is NOT itself a union array still has a result backing.
                rlInternName(unNames[0], 2)
                rlUsed = true
                raUsed = true
              } else {
                let rk = 0
                if fe >= 0 { rk = cloRetKindOf(fe) }
                if rk == 11 {
                  fa64Used = true
                } else {
                  aUsed = true
                  lUsed = true
                }
              }
            }
          }
        }
      }
    }
    i = i + 1
  }
  0
}

// ── Per-callsite monomorphization (host: toWasm.ts `instantiate`) ────────────
// A GENERIC lifted function — explicit `<T>` type params, or any UN-ANNOTATED
// parameter (an inference hole the checker pins per call site) — has no single
// wasm signature. Mirroring the host's lazy `instantiate`, each DIRECT call to
// one resolves to a concrete INSTANCE: a clone of the declaration whose generic
// param/return annotations are replaced by the call's concrete type NAMES.
// Instances are keyed by `(original decl, pinned-param-names)` — registered
// BEFORE their body is walked, so a recursive self-call at the same shape hits
// the registry instead of looping. The FIRST instance keeps the bare name and
// REPLACES the original's `fnStmts` slot (so every declared function keeps its
// wasm index — the golden-pinned `fnStmts` position); each later DISTINCT shape
// appends a clone `name$N` at the END of `fnStmts` and rewrites that call
// site's callee `Ident` to the clone's name. A program with no generic call
// creates zero instances and emits byte-identical output (usage-gated).
//
// DIVERGENCES from the host, both deliberate: (1) instantiation is an eager
// pre-pass in program order, not lazy mid-emission — the native emitter
// classifies types from annotations in earlier phases (`collectCloSigs`,
// `mAssignTypeIndices`), so instances must exist with concrete annotations
// before those phases run; (2) clones SHARE the original's body arena nodes, so
// a RECURSIVE generic used at multiple shapes would mis-resolve its self-call
// (none exists in the corpus; the first-instance/replacement path is exact).

// The concrete annotation NAME for the argument expression at `ix` inside
// function `fnIx` (-1 = top level) — the same classification ladder the return-
// kind inference runs (`exprString`/`exprArray`/…), rendered back to the
// annotation name an instance's pinned `TypeRef` carries. "" = a kind this pass
// cannot name (the caller fails loudly).
// The RESULT type NAME of lifted function `fe` (`i32`, `string`, `i32[]`, a struct
// name, …) — its declared return annotation, or the inferred kind mapped back to a
// name. Used to build a closure argument's function-type name for generic binding.
function cloRetTypeName(fe: i32) {
  if fe < 0 || fe >= fnStmts.length { return "" }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    if fn.fnRet >= 0 { return tyNameOf(fn.fnRet) }
  }
  const k = cloRetValKind(fe)
  if k == 0 { return "i32" }
  if k == 11 { return "f64" }
  if k == 10 { return "i64" }
  if k == 13 { return "f32" }
  if k == 3 { return "string" }
  if k == 2 { return "i32[]" }
  if k == 7 { return "string[]" }
  if k == 12 { return "f64[]" }
  if k == 1 {
    const slot = cloRetValSlot(fe)
    if slot >= 0 && slot < sNames.length { return sNames[slot] }
  }
  ""
}

// The function-TYPE name `(p1, p2) => ret` of a closure-VALUE argument (a lambda
// literal or a bare top-level function name) — the form `monoBindFromAnn` matches a
// generic closure param `(A, T) => A` against. "" when the argument is not a resolvable
// closure value or a param/return type lies outside the name vocabulary. (Distinct from
// `monoArgTyName`'s `"=>sigkey"` pin, which an UN-annotated closure param wants.)
// Resolve any STRUCTURAL shapes inside a `(params)=>ret` function-type name to their NOMINAL names —
// the single structural→nominal bridge (`resolveShapeToNominal`, which also peels `[]`) applied to each
// param and the return. The checker renders a lambda's struct part as `{x: i32}` / `{x: i32}[]`; the
// monomorphizer's type-param bindings and every nominal-keyed emitter site (`nameIsRefArray`,
// `rlSlotByName`, `structIndexByName`) want `P` / `P[]`. Applied ONCE at the mono boundary so the
// instance is nominal throughout. A non-function name, or one with no resolvable shape, passes through.
function nominalizeFnType(name: string) {
  const at = annArrowAt(name)
  if at < 1 { return name }
  if name[0] != '(' { return name }
  if name[at - 1] != ')' { return name }
  const paramsStr = name.slice(1, at - 1)
  const retStr = name.slice(at + 2, name.length)
  let out = "("
  if paramsStr.length > 0 {
    const parts: string[] = []
    annSplitParams(paramsStr, parts)
    let i = 0
    while i < parts.length {
      if i > 0 { out = out + "," }
      out = out + resolveShapeToNominal(parts[i])
      i = i + 1
    }
  }
  out + ")=>" + resolveShapeToNominal(retStr)
}

function monoArgFnTypeName(argIx: i32, fnIx: i32) {
  const ax = unwrapParen(argIx)
  const an = P.nodes[ax]
  // PREFER the checker's recorded function type: for an UN-annotated lambda arg it inferred the param
  // types from the generic param's (substituted) expected type at the call site — `mapArr<T,R>(xs, f)`
  // called `mapArr([1,2,3], (x) => x*2)` types `f` as `(i32) => i32`, which the syntactic build below
  // CANNOT recover (the lambda param has no annotation). Used only when it yields a complete
  // `(params)=>ret` name; a named-fn arg / a case the checker didn't type falls through. The checker
  // renders a struct part STRUCTURALLY (`(i32) => {x: i32}`); NOMINALIZE it once here so the bound
  // type param (`R = P`) — and thus every downstream site (`R[]` validation, the result ref-list
  // interning, the binding type) — keys on the declared name, rather than each re-bridging the shape.
  const cn = nodeTyName(ax)
  if cn != "" {
    if annArrowAt(cn) >= 0 { return nominalizeFnType(cn) }
  }
  let fe = -1
  if an is FuncDecl { fe = fnStmtsPosOf(ax) }
  else if an is Ident { fe = fnIndexOf(an.identName) }
  if fe < 0 || fe >= fnStmts.length { return "" }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    let nm = "("
    let i = 0
    while i < fn.fnParams.length {
      const p = P.nodes[fn.fnParams[i]]
      if p is Param {
        if p.parType < 0 { return "" }
        const pn = tyNameOf(p.parType)
        if pn == "" { return "" }
        if i > 0 { nm = nm + "," }
        nm = nm + pn
      }
      i = i + 1
    }
    const rn = cloRetTypeName(fe)
    if rn == "" { return "" }
    return nm + ")=>" + rn
  }
  ""
}

// A struct or struct-ARRAY annotation NAME usable as a monomorphization pin during the mono
// pass (when the locals/struct-classification tables are unbuilt): the bare struct `P` (`T`
// binds it), or a struct array `P[]` (`T[]` binds its element). "" for anything else (a scalar
// / list annotation already resolves through the `expr*` classifiers below). One level of `[]`
// — a deeper `P[][]` stays out of scope (falls through to the existing behavior).
function monoStructAnnName(name: string) {
  if isSName(name) { return name }
  const n = name.length
  if n >= 3 && name[n - 2] == '[' && name[n - 1] == ']' {
    if isSName(name.slice(0, n - 2)) { return name }
  }
  ""
}

function monoArgTyName(ix: i32, fnIx: i32) {
  if exprIsClosure(ix, fnIx) {
    // A FUNCTION-VALUE argument pins its param as a CLOSURE (kind 14). The
    // pinned name carries the callee's `$fnsig` KEY (`"=>ii>i"`) so the
    // instance's value-call (`fn(a, b)`) ref-casts to the EXACT signature.
    // Only a bare top-level function name resolves a key here (the HOF shape
    // in scope); any other closure value fails loudly at the caller.
    const ce = P.nodes[unwrapParen(ix)]
    if ce is Ident {
      const cfe = fnIndexOf(ce.identName)
      if cfe >= 0 {
        const ck = fnSigKeyOf(cfe)
        if ck != "" { return "=>" + ck }
      }
    }
    return ""
  }
  // A CALL ARGUMENT whose callee has a CONCRETE return annotation takes that annotation as
  // its type. Needed for a generic call used as an argument (`box(box(7))`): `monoWalk`
  // instantiates the inner call FIRST, but during monomorphization the instance's `fRet*` /
  // struct tables are not built yet (buildFnMap is post-mono), so `exprStruct` /
  // `structIndexOfExpr` cannot classify it and the type param would wrongly default to i32.
  // Reading the instance's (already-substituted) return annotation resolves the nested bind.
  const argN = P.nodes[unwrapParen(ix)]
  if argN is Call {
    const argCallee = P.nodes[argN.callFn]
    if argCallee is Ident {
      const acfe = fnIndexOf(argCallee.identName)
      if acfe >= 0 {
        const acfn = P.nodes[fnStmts[acfe]]
        if acfn is FuncDecl {
          if acfn.fnRet >= 0 {
            const arn = tyNameOf(acfn.fnRet)
            if arn != "" && !monoAnnHasTyParam(arn, acfn.fnTyParams) {
              return arn
            }
          }
        }
      }
    }
  }
  // An IDENT argument bound to a generic-call result (`const inner = box(7); box(inner)`):
  // resolve via its un-annotated `let` INIT, since the local's type table isn't built during
  // monomorphization either. Only adopt a resolved non-i32 type (an i32 local takes the i32
  // default below anyway); a param / non-let ident has no `parentLetOf` and falls through.
  if argN is Ident {
    if fnIx >= 0 {
      const ctxFn = P.nodes[fnIx]
      if ctxFn is FuncDecl {
        const li = parentLetOf(ctxFn.fnBody, argN.identName)
        if li >= 0 {
          const ld = P.nodes[li]
          if ld is LetDecl {
            // A STRUCT- or struct-ARRAY-typed ANNOTATED local (`const p: P`, `const xs: P[]`):
            // read its annotation name directly. During monomorphization the locals table isn't
            // built (buildLocals is post-mono), so the `exprStruct`/`exprRefArray` cases below
            // can't classify it, defaulting the type param to i32 (`id(p).x` → "field access
            // receiver is not a struct"; `first(xs)` → "expected an array argument"). The
            // annotation is the reliable source — the struct DECL table (`sNames`) IS built here.
            if ld.letType >= 0 {
              const ltn = tyNameOf(ld.letType)
              const r = monoStructAnnName(ltn)
              if r != "" { return r }
              // A UNION-typed annotated local (`a: Cat | Dog`, or an alias): bind `T` to the
              // union NAME so the instance's param/return ride the union box. `isUName` covers a
              // registered inline union and a `type … = … | …` alias (both in `unNames`).
              if isUName(ltn) { return ltn }
            }
            if ld.letType < 0 && ld.letInit >= 0 {
              const innerTy = monoArgTyName(ld.letInit, fnIx)
              if innerTy != "" && innerTy != "i32" { return innerTy }
            }
          }
        }
      }
      // A STRUCT-typed PARAM argument (`g(v)` inside a generic body where `v: P`): same as the
      // annotated-local case — read the param annotation, the locals table being unbuilt here.
      const ptn = paramTypeNode(fnIx, argN.identName)
      if ptn >= 0 {
        const pt = P.nodes[ptn]
        if pt is TypeRef {
          const r = monoStructAnnName(pt.tyName)
          if r != "" { return r }
          if isUName(pt.tyName) { return pt.tyName }
        }
      }
    }
  }
  // An INDEXED struct-array element argument (`id(xs[0])` where `xs: P[]`): resolve the array's
  // ELEMENT struct from its annotation (the dual of the struct-array-argument case). The array's
  // own type resolves to `P[]` above; strip the `[]` to the element struct. The locals table is
  // unbuilt mid-mono, so `structIndexOfExpr(xs[0])` below can't classify it (→ i32 default).
  if argN is Index {
    const arrTy = monoArgTyName(argN.idxArr, fnIx)
    const an = arrTy.length
    if an >= 3 && arrTy[an - 2] == '[' && arrTy[an - 1] == ']' {
      const elem = arrTy.slice(0, an - 2)
      if isSName(elem) { return elem }
    }
  }
  // A struct-FIELD argument (`id(o.inner)` where `o: Outer` and `inner: Inner`): resolve the
  // receiver's struct from its annotation, then read the field's struct type-name off the struct
  // table (a nested-struct field is code 15, whose `sFieldElemName` IS its target struct name).
  // The locals table is unbuilt mid-mono, so `structIndexOfExpr(o.inner)` below defaults to i32.
  if argN is Member {
    const recvTy = monoArgTyName(argN.memObj, fnIx)
    const rsi = structIndexByName(recvTy)
    if rsi >= 0 {
      const fi = sFieldIndex(rsi, argN.memProp)
      if fi >= 0 && sFieldTypeAt(rsi, fi) == 15 {
        const fnm = sFieldElemNameAt(rsi, fi)
        if isSName(fnm) { return fnm }
      }
    }
  }
  if exprString(ix, fnIx) { return "string" }
  if exprStringArray(ix, fnIx) { return "string[]" }
  if exprF64Array(ix, fnIx) { return "f64[]" }
  if exprRefArray(ix, fnIx) {
    // A struct/union-element array: only a LITERAL argument names its element
    // type cheaply; other shapes are out of scope for now.
    const nd = P.nodes[ix]
    if nd is ArrayLit { return arrLitElemName(ix) + "[]" }
    return ""
  }
  if exprArray(ix, fnIx) { return "i32[]" }
  if exprUnion(ix, fnIx) { return "" }
  if exprNullableStruct(ix, fnIx) { return "" }
  if exprStruct(ix, fnIx) {
    let si = structIndexOfExpr(ix, fnIx)
    if si >= 0 { return sNames[si] }
    return ""
  }
  if exprIsF64(ix, fnIx) { return "f64" }
  if exprIsI64(ix, fnIx) { return "i64" }
  if exprIsF32(ix, fnIx) { return "f32" }
  if exprIsBool(ix, fnIx) { return "boolean" }
  "i32"
}

// Substitute a `LetDecl` annotation `letType` (a `TypeRef`) through the instance binding,
// returning a fresh `TypeRef` node when a type param substitutes (`T[]` → `f64[]`), else
// the original node index. So a generic body's `const out: T[] = []` / `const x: T` lowers
// against the instance's CONCRETE element type — reusing the (already-working) concrete
// annotated path for EVERY element type, not the per-rep usage inference.
function monoSubstLetType(
  letType: i32,
  typarams: string[],
  tvN: string[],
  tvV: string[],
) {
  if letType < 0 { return letType }
  const tn = P.nodes[letType]
  if tn is TypeRef {
    if monoAnnHasTyParam(tn.tyName, typarams) {
      const sub = monoSubstAnn(tn.tyName, typarams, tvN, tvV)
      if sub != "" && sub != tn.tyName { return mkTypeRef(sub, tn.pos) }
    }
  }
  letType
}

// Clone a monomorphized instance's BODY, substituting every `LetDecl` type-param
// annotation through the binding. Only the STATEMENT SPINE (blocks, control-flow, the
// `LetDecl`s themselves) is rebuilt; every leaf expression — INCLUDING a nested lambda —
// is SHARED unchanged, so no new function node is created (a clone would not be re-lifted,
// `collectFns` having already run) and a `T`-independent body shares its arena wholesale.
// Returns the SAME node index when nothing in the subtree changed, so an instance with no
// annotated body local keeps sharing the original body (byte-identical, usage-gated). A
// lambda that annotates a type param (`(x: T) => …`) is left un-substituted — that case
// is out of scope and stays as it was.
function monoCloneBody(
  ix: i32,
  typarams: string[],
  tvN: string[],
  tvV: string[],
  outName: string,
  outType: string,
) {
  if ix < 0 { return ix }
  const n = P.nodes[ix]
  if n is Block {
    const ns: i32[] = []
    let changed = false
    let i = 0
    while i < n.blkStmts.length {
      const cs = monoCloneBody(n.blkStmts[i], typarams, tvN, tvV, outName, outType)
      ns.push(cs)
      if cs != n.blkStmts[i] { changed = true }
      i = i + 1
    }
    if !changed { return ix }
    return mkBlock(ns, n.pos)
  }
  if n is LetDecl {
    let nt = monoSubstLetType(n.letType, typarams, tvN, tvV)
    // The inferred-list-return local (`const out = []`, element a hole so #543's synthesis is
    // skipped): annotate its empty build with the pinned element type, per instance. Clones
    // ONLY this `LetDecl` (and its enclosing Block), never the shared original.
    if nt < 0 {
      if outName != "" {
        if n.letName == outName { nt = mkTypeRef(outType, -1) }
      }
    }
    if nt == n.letType { return ix }
    return mkLet(n.letKw, n.letName, nt, n.letInit, n.pos)
  }
  if n is WhileStmt {
    const cb = monoCloneBody(n.whileBody, typarams, tvN, tvV, outName, outType)
    if cb == n.whileBody { return ix }
    return mkWhile(n.whileCond, cb, n.whileLabel, n.pos)
  }
  if n is IfStmt {
    const ct = monoCloneBody(n.ifThen, typarams, tvN, tvV, outName, outType)
    const ce = monoCloneBody(n.ifElse, typarams, tvN, tvV, outName, outType)
    if ct == n.ifThen && ce == n.ifElse { return ix }
    return mkIf(n.ifCond, ct, ce, n.pos)
  }
  if n is ForRange {
    const cb = monoCloneBody(n.frBody, typarams, tvN, tvV, outName, outType)
    if cb == n.frBody { return ix }
    return mkForRange(n.frVar, n.frFrom, n.frTo, n.frStep, cb, n.frLabel, n.pos)
  }
  if n is ForIn {
    const cb = monoCloneBody(n.fiBody, typarams, tvN, tvV, outName, outType)
    if cb == n.fiBody { return ix }
    return mkForIn(n.fiVar, n.fiIter, cb, n.fiLabel, n.pos)
  }
  if n is RetStmt {
    // The return value may be a block / `if`-EXPRESSION carrying its own `LetDecl`s.
    const ca = monoCloneBody(n.retArg, typarams, tvN, tvV, outName, outType)
    if ca == n.retArg { return ix }
    return mkReturn(ca, n.pos)
  }
  if n is Paren {
    const ci = monoCloneBody(n.parInner, typarams, tvN, tvV, outName, outType)
    if ci == n.parInner { return ix }
    return mkParen(ci, n.pos)
  }
  // A pure expression / other statement carries no `LetDecl` annotation to rewrite — share.
  ix
}

// Whether an inline `.map` callback PRESERVES the element type — its tail expression is
// arithmetic / concatenation over the element (`x => x * 2`, `s => s + "!"`), so the result
// element type equals the source element. Lets the monomorphizer set a concrete map-result
// return annotation, since the inferred-return path has no f64/string-array map-result form.
function monoLambdaPreservesElem(argIx: i32) {
  const fnNodeIx = unwrapParen(argIx)
  const a = P.nodes[fnNodeIx]
  if a is FuncDecl {
    const tail = fnRetExprOf(fnNodeIx)
    if tail >= 0 {
      const t = P.nodes[unwrapParen(tail)]
      if t is BinExpr {
        const op = t.binOp
        return op == "+" || op == "-" || op == "*" || op == "/"
      }
    }
  }
  false
}

// The element type NAME of an array type name (`"f64[]"` → `"f64"`), or "" if not an array.
function monoArrElemName(name: string) {
  const n = name.length
  if n >= 2 {
    if name[n - 2] == '[' && name[n - 1] == ']' { return name.slice(0, n - 2) }
  }
  ""
}

// The element type of `recvIx` when it is (a paren around) a PARAMETER reference whose pinned
// type is an array — looked up in the instance's (pNames → pElems) map. "" otherwise. Used to
// pin a `.map`/`.filter` callback's element from the concrete receiver of THIS instance.
function monoRecvParamElem(recvIx: i32, pNames: string[], pElems: string[]) {
  const r = P.nodes[unwrapParen(recvIx)]
  if r is Ident {
    let i = 0
    while i < pNames.length {
      if pNames[i] == r.identName { return pElems[i] }
      i = i + 1
    }
  }
  ""
}

// Clone an INLINE `.map`/`.filter` callback lambda with its single un-annotated parameter
// PINNED to `elemType`, lift the clone into `fnStmts`, and return its node index — or -1 when
// the argument is not a cloneable un-annotated 1-param lambda (a named-function callback, an
// already-annotated param, or a different arity all ride their existing paths). The body is
// SHARED with the original: the emitter re-derives every operand type from the (now concrete)
// parameter per function, so one body lowers correctly under each pinned param.
function monoCloneLambdaPinned(argIx: i32, elemType: string) {
  const a = P.nodes[unwrapParen(argIx)]
  if a is FuncDecl {
    if a.fnParams.length == 1 {
      const p0 = P.nodes[a.fnParams[0]]
      if p0 is Param {
        if p0.parType < 0 {
          const np = mkParam(p0.parName, mkTypeRef(elemType, -1), p0.pos)
          const nm = "__lambda_" + i32ToStr(lambdaCtr)
          lambdaCtr = lambdaCtr + 1
          const noTP: string[] = []
          const ps: i32[] = [np]
          const clone = mkFunc(nm, noTP, ps, a.fnRet, a.fnBody, a.pos)
          fnStmts.push(clone)
          fnParent.push(-1)
          fnDispNames.push("")
          fnValUsed = true
          return clone
        }
      }
    }
  }
  -1
}

// Per-instance lambda monomorphization for `.map`/`.filter`. The shared definition body of an
// un-annotated function is checked ONCE with the element as a hole, so an inline callback's
// un-annotated param defaults to i32 at emit (`checkParams`) — correct only for the i32 shape.
// When THIS instance pins the receiver param to a NON-i32 element (`self: f64[]`), clone the
// callback with its param pinned to the element type (`monoCloneLambdaPinned`) and rebuild the
// call to reference the clone, cloning the enclosing spine so sibling instances are untouched.
// The i32 shape (element "i32") is left as-is, so the golden i32 path stays byte-identical.
function monoPinMapLambdas(ix: i32, pNames: string[], pElems: string[]) {
  if ix < 0 { return ix }
  const n = P.nodes[ix]
  if n is Block {
    const ns: i32[] = []
    let changed = false
    let i = 0
    while i < n.blkStmts.length {
      const cs = monoPinMapLambdas(n.blkStmts[i], pNames, pElems)
      ns.push(cs)
      if cs != n.blkStmts[i] { changed = true }
      i = i + 1
    }
    if !changed { return ix }
    return mkBlock(ns, n.pos)
  }
  if n is RetStmt {
    const ca = monoPinMapLambdas(n.retArg, pNames, pElems)
    if ca == n.retArg { return ix }
    return mkReturn(ca, n.pos)
  }
  if n is LetDecl {
    const ci = monoPinMapLambdas(n.letInit, pNames, pElems)
    if ci == n.letInit { return ix }
    return mkLet(n.letKw, n.letName, n.letType, ci, n.pos)
  }
  if n is WhileStmt {
    const cb = monoPinMapLambdas(n.whileBody, pNames, pElems)
    if cb == n.whileBody { return ix }
    return mkWhile(n.whileCond, cb, n.whileLabel, n.pos)
  }
  if n is IfStmt {
    const ct = monoPinMapLambdas(n.ifThen, pNames, pElems)
    const ce = monoPinMapLambdas(n.ifElse, pNames, pElems)
    if ct == n.ifThen && ce == n.ifElse { return ix }
    return mkIf(n.ifCond, ct, ce, n.pos)
  }
  if n is ForRange {
    const cb = monoPinMapLambdas(n.frBody, pNames, pElems)
    if cb == n.frBody { return ix }
    return mkForRange(n.frVar, n.frFrom, n.frTo, n.frStep, cb, n.frLabel, n.pos)
  }
  if n is ForIn {
    const cb = monoPinMapLambdas(n.fiBody, pNames, pElems)
    if cb == n.fiBody { return ix }
    return mkForIn(n.fiVar, n.fiIter, cb, n.fiLabel, n.pos)
  }
  if n is Paren {
    const ci = monoPinMapLambdas(n.parInner, pNames, pElems)
    if ci == n.parInner { return ix }
    return mkParen(ci, n.pos)
  }
  if n is Call {
    let newCallee = n.callFn
    const callee = P.nodes[n.callFn]
    // A `<paramRecv>.map/.filter(<lambda>)` over a concrete NON-i32 element: pin the callback.
    if callee is Member {
      const recvNew = monoPinMapLambdas(callee.memObj, pNames, pElems)
      if recvNew != callee.memObj {
        newCallee = mkMember(recvNew, callee.memProp, callee.pos)
      }
      if callee.memProp == "map" || callee.memProp == "filter" {
        if n.callArgs.length == 1 {
          const elem = monoRecvParamElem(callee.memObj, pNames, pElems)
          if elem != "" && elem != "i32" {
            const cloned = monoCloneLambdaPinned(n.callArgs[0], elem)
            if cloned >= 0 {
              const oneArg: i32[] = [cloned]
              return mkCallN(newCallee, oneArg, n.callArgNames, n.pos)
            }
          }
        }
      }
    }
    // Otherwise recurse into the arguments (a map call may be nested in one).
    const nargs: i32[] = []
    let changed = newCallee != n.callFn
    let ai = 0
    while ai < n.callArgs.length {
      const cca = monoPinMapLambdas(n.callArgs[ai], pNames, pElems)
      nargs.push(cca)
      if cca != n.callArgs[ai] { changed = true }
      ai = ai + 1
    }
    if !changed { return ix }
    return mkCallN(newCallee, nargs, n.callArgNames, n.pos)
  }
  ix
}

// Rebuild the name→index map and the voidness/return-kind inference after a new
// instance lands in `fnStmts`, so later argument classification sees its
// concrete signature. Also re-runs `collectA` (a pinned `string[]`/`f64`
// annotation may force list/array types the original generic name never did).
function monoRebuild() {
  if collectA(monoProgStmts) < 0 { return -1 }
  if buildFnMap(monoProgStmts) < 0 { return -1 }
  computeVoidFns()
  computeRetInference()
  0
}

// The PARAMETER an un-annotated `return <local>` list is built from: a
// `<retName>.push(<param>[<idx>])` statement anywhere in `blockIx` (descending into
// while / if / for bodies). The built list shares the indexed param's array type, so the
// monomorphizer types the un-annotated return as that param's pinned type. "" = none found.
function monoListSrcParam(blockIx: i32, retName: string) {
  const b = P.nodes[blockIx]
  if b is Block {
    const stmts = b.blkStmts
    let i = 0
    while i < stmts.length {
      const r = monoListSrcParamStmt(stmts[i], retName)
      if r != "" { return r }
      i = i + 1
    }
  }
  ""
}

function monoListSrcParamStmt(ix: i32, retName: string) {
  const s = P.nodes[ix]
  if s is Block { return monoListSrcParam(ix, retName) }
  if s is WhileStmt { return monoListSrcParam(s.whileBody, retName) }
  if s is ForRange { return monoListSrcParam(s.frBody, retName) }
  if s is ForIn { return monoListSrcParam(s.fiBody, retName) }
  if s is IfStmt {
    const rt = monoListSrcParam(s.ifThen, retName)
    if rt != "" { return rt }
    if s.ifElse >= 0 { return monoListSrcParamStmt(s.ifElse, retName) }
    return ""
  }
  // A `<retName>.push(<param>[<idx>])` statement: the param is the list's element source.
  if s is Call {
    const callee = P.nodes[s.callFn]
    if callee is Member {
      if callee.memProp == "push" {
        const recv = P.nodes[callee.memObj]
        if recv is Ident {
          if recv.identName == retName {
            if s.callArgs.length == 1 {
              const arg = P.nodes[s.callArgs[0]]
              if arg is Index {
                const ia = P.nodes[arg.idxArr]
                if ia is Ident { return ia.identName }
              }
            }
          }
        }
      }
    }
  }
  ""
}

// CALLBACK SPECIALIZATION (devirtualization): rewrite every call THROUGH a closure-typed param
// `<cbParamNames[k]>(args)` in a cloned instance body into a DIRECT call to the concrete
// non-capturing function `<cbFnNames[k]>` it was instantiated with. The per-element `call_ref`
// through the fat pointer becomes a `call $fn` (the emitter's direct-call path pushes the null
// env a non-capturing callee wants) — measured ~4× on the native host for the allocation-free
// fold/reduce/search family. The closure VALUE is still passed (the param stays in the list), so non-call uses of
// the callback (returning it, threading it through a recursive self-call) keep working through it;
// only the call positions are redirected. Mirrors `monoPinMapLambdas`' clone-if-changed spine so
// sibling instances (and the shared original body) are never mutated. A param with `cbFnNames ==
// ""` (capturing / generic / not a known function) leaves its calls as `call_ref` → byte-identical.
function monoBakeCallback(
  ix: i32,
  cbParamNames: string[],
  cbFnNames: string[],
) {
  if ix < 0 { return ix }
  const n = P.nodes[ix]
  if n is Block {
    const ns: i32[] = []
    let changed = false
    let i = 0
    while i < n.blkStmts.length {
      const cs = monoBakeCallback(n.blkStmts[i], cbParamNames, cbFnNames)
      ns.push(cs)
      if cs != n.blkStmts[i] { changed = true }
      i = i + 1
    }
    if !changed { return ix }
    return mkBlock(ns, n.pos)
  }
  if n is RetStmt {
    const ca = monoBakeCallback(n.retArg, cbParamNames, cbFnNames)
    if ca == n.retArg { return ix }
    return mkReturn(ca, n.pos)
  }
  if n is LetDecl {
    const ci = monoBakeCallback(n.letInit, cbParamNames, cbFnNames)
    if ci == n.letInit { return ix }
    return mkLet(n.letKw, n.letName, n.letType, ci, n.pos)
  }
  if n is WhileStmt {
    const cb = monoBakeCallback(n.whileBody, cbParamNames, cbFnNames)
    if cb == n.whileBody { return ix }
    return mkWhile(n.whileCond, cb, n.whileLabel, n.pos)
  }
  if n is IfStmt {
    const ct = monoBakeCallback(n.ifThen, cbParamNames, cbFnNames)
    const ce = monoBakeCallback(n.ifElse, cbParamNames, cbFnNames)
    if ct == n.ifThen && ce == n.ifElse { return ix }
    return mkIf(n.ifCond, ct, ce, n.pos)
  }
  if n is ForRange {
    const cb = monoBakeCallback(n.frBody, cbParamNames, cbFnNames)
    if cb == n.frBody { return ix }
    return mkForRange(n.frVar, n.frFrom, n.frTo, n.frStep, cb, n.frLabel, n.pos)
  }
  if n is ForIn {
    const cb = monoBakeCallback(n.fiBody, cbParamNames, cbFnNames)
    if cb == n.fiBody { return ix }
    return mkForIn(n.fiVar, n.fiIter, cb, n.fiLabel, n.pos)
  }
  if n is Paren {
    const ci = monoBakeCallback(n.parInner, cbParamNames, cbFnNames)
    if ci == n.parInner { return ix }
    return mkParen(ci, n.pos)
  }
  if n is Call {
    // A call whose callee names a specialized closure param `f(...)` → direct call `cbFn(...)`;
    // its arguments may themselves contain such calls (`f(g(x))`), so recurse there too.
    let newCallee = n.callFn
    const callee = P.nodes[n.callFn]
    if callee is Ident {
      let bk = 0
      while bk < cbParamNames.length {
        if cbFnNames[bk] != "" && callee.identName == cbParamNames[bk] {
          newCallee = mkIdent(cbFnNames[bk], callee.pos)
        }
        bk = bk + 1
      }
    }
    const nargs: i32[] = []
    let changed = newCallee != n.callFn
    let ai = 0
    while ai < n.callArgs.length {
      const cca = monoBakeCallback(n.callArgs[ai], cbParamNames, cbFnNames)
      nargs.push(cca)
      if cca != n.callArgs[ai] { changed = true }
      ai = ai + 1
    }
    if !changed { return ix }
    return mkCallN(newCallee, nargs, n.callArgNames, n.pos)
  }
  if n is BinExpr {
    // Descend into a plain assignment / arithmetic node (`acc = f(acc, x)`, the reduce/fold
    // shape). A COMPOUND-assignment node (`acc += f(x)`, `binCompound != ""`) is left intact —
    // rebuilding it through `mkBinary` would drop its surface tag, and its callback call simply
    // stays a `call_ref` (sound, just unspecialized — a rare shape).
    if n.binCompound != "" { return ix }
    const cl = monoBakeCallback(n.binLeft, cbParamNames, cbFnNames)
    const cr = monoBakeCallback(n.binRight, cbParamNames, cbFnNames)
    if cl == n.binLeft && cr == n.binRight { return ix }
    return mkBinary(n.binOp, cl, cr, n.pos)
  }
  ix
}

// Whether a specialization callback was baked for ANY param (the instance has at least one
// `cbFnNames[k] != ""`) — gates the body rewrite + key extension below.
function monoAnyBakedCallback(cbFnNames: string[]) {
  let i = 0
  while i < cbFnNames.length {
    if cbFnNames[i] != "" { return true }
    i = i + 1
  }
  false
}

// The instance-creation core shared by `monoInstantiate` (call-driven) and `monoInstanceFor`
// (annotation-driven): given the already-built `pinned` param-type names (and any `tvN`/`tvV`
// type-param bindings), clone-or-reuse the instance of generic `origFe` and point the value site
// at it. `calleeIx` is the `Ident` node (a call callee, or a binding init) rewritten to the
// instance name on a registry hit / a `count > 0` append. `annotateI32` annotates an i32-pinned
// param too (so the materialized closure passes the value floor) — `monoInstantiate` keeps it
// false for byte-identity on the all-i32 call path. `cbFnNames` (parallel to params, "" = none)
// bakes a non-capturing concrete callback into the instance as a direct call — see
// `monoBakeCallback`. Returns 0, or -1 via `emitFail`.
function monoMakeInstance(
  origFe: i32,
  pinned: string[],
  tvN: string[],
  tvV: string[],
  calleeIx: i32,
  annotateI32: boolean,
  cbFnNames: string[],
) {
  const fn = P.nodes[monoOrigNode[origFe]]
  if fn is FuncDecl {
    const params = fn.fnParams
    let key = i32ToStr(origFe) + "#"
    let pk = 0
    while pk < pinned.length {
      key = key + pinned[pk] + ","
      pk = pk + 1
    }
    // The baked-callback identities extend the key, so two calls passing the SAME pinned types but
    // DIFFERENT non-capturing callbacks (`reduce(xs, add, …)` vs `reduce(xs, mul, …)`) get distinct
    // instances — each body bakes its own direct call. No baked callback → no `@` suffix → the key
    // (and the resulting instance) is byte-identical to the pre-specialization shape.
    let ck = 0
    while ck < cbFnNames.length {
      if cbFnNames[ck] != "" { key = key + "@" + cbFnNames[ck] + "," }
      ck = ck + 1
    }
    // A closure-pinned param flips the module's function-value machinery on
    // (the instance body `call_ref`s through it; the argument side builds the
    // fat pointer) — the same flag a lifted lambda flips in `liftFnsInExpr`.
    let pv = 0
    while pv < pinned.length {
      const pvn = pinned[pv]
      if pvn.length > 2 {
        if pvn[0] == '=' && pvn[1] == '>' { fnValUsed = true }
      }
      pv = pv + 1
    }
    // Registry hit: point this call site at the existing instance.
    let k = 0
    while k < monoKeys.length {
      if monoKeys[k] == key {
        const cal = P.nodes[calleeIx]
        if cal is Ident {
          // A registry hit on a CAPTURING lambda in the binding's OWN slot (a count-0 instance,
          // `monoInstFe == origFe`) must stay a `call_ref` through that binding — renaming the callee
          // to the lifted instance name would make a by-name call that drops the captured env. A
          // non-capturing instance keeps the by-name rename (a null env is fine), so the
          // named-function path stays byte-identical.
          let keepCallRef = false
          if monoInstFe[k] == origFe {
            if captureCountOf(origFe) > 0 { keepCallRef = true }
          }
          if !keepCallRef {
            if cal.identName != monoInstName[k] {
              cal.identName = monoInstName[k]
            }
          }
        }
        return 0
      }
      k = k + 1
    }
    // New shape: clone the ORIGINAL declaration with pinned annotations. An
    // un-annotated param pinned at plain i32 keeps `parType = -1` (the
    // emitter's default kind — zero new arena nodes on the all-i32 path).
    let count = 0
    let k2 = 0
    while k2 < monoInstOrig.length {
      if monoInstOrig[k2] == origFe { count = count + 1 }
      k2 = k2 + 1
    }
    const nps: i32[] = []
    let pj = 0
    while pj < params.length {
      const p3 = P.nodes[params[pj]]
      if p3 is Param {
        let nt = -1
        if p3.parType >= 0 {
          // The pinned name differs from the written annotation exactly when
          // a type param substituted through it (bare `T`, `T[]`, or a
          // composite like `Box<T>`); a concrete annotation keeps its node.
          if pinned[pj] == tyNameOf(p3.parType) {
            nt = p3.parType
          } else {
            nt = mkTypeRef(pinned[pj], -1)
          }
        } else if annotateI32 || pinned[pj] != "i32" {
          nt = mkTypeRef(pinned[pj], -1)
        }
        nps.push(mkParam(p3.parName, nt, -1))
      }
      pj = pj + 1
    }
    // Substitute a type-param-riding RETURN annotation through the binding —
    // bare `T` / `T[]`, an application (`Box<T>`), or an inline object shape
    // (`{first:B,second:A}`); a concrete annotation passes through unchanged.
    let nret = fn.fnRet
    // A hole-built return list local to annotate in the cloned instance body (so its `[]`
    // build classifies per element type — f64/struct as well as i32/string). Captured from
    // the return trace below, threaded into `monoCloneBody` which clones+annotates just
    // that `LetDecl` per instance (never the shared original).
    let monoOutName = ""
    let monoOutType = ""
    if fn.fnRet >= 0 {
      const rn = tyNameOf(fn.fnRet)
      if monoAnnHasTyParam(rn, fn.fnTyParams) {
        let rs = monoSubstAnn(rn, fn.fnTyParams, tvN, tvV)
        if rs == "" {
          return emitFail(
            "emitProgram: monomorphize: a return type parameter of `" +
              fn.fnName +
              "` is not bound by any parameter",
          )
        }
        nret = mkTypeRef(rs, -1)
      }
    }
    // An UN-ANNOTATED return whose return expression is a value-call THROUGH a
    // closure-pinned param takes that signature's RESULT kind as a concrete
    // annotation (`"…>d"` → `f64`): the emitter's return-kind inference has no
    // expression form for a `call_ref` result, so the instance's functype and
    // its callers' classification ride the normal annotation tables instead.
    if nret < 0 {
      const rx2 = fnRetExprOf(monoOrigNode[origFe])
      if rx2 >= 0 {
        const rxe = P.nodes[rx2]
        if rxe is Call {
          const rcal = P.nodes[rxe.callFn]
          if rcal is Ident {
            let pq = 0
            while pq < params.length {
              const pp = P.nodes[params[pq]]
              if pp is Param {
                if pp.parName == rcal.identName {
                  const pn = pinned[pq]
                  if pn.length > 2 {
                    if pn[0] == '=' && pn[1] == '>' {
                      // An UN-annotated closure param's sig-key pin (`=>i>d`): only its f64 result
                      // kind has no expression-form return inference, so type it concretely here.
                      if pn[pn.length - 1] == 'd' {
                        nret = mkTypeRef("f64", -1)
                      }
                    } else if pn[0] == '(' {
                      // An ANNOTATED function-type param pin (`(i32)=>string|null`): the un-annotated
                      // HOF return flows THROUGH the callback (`return g(x)`), so it IS the callback's
                      // return type. Extract that (everything past the top-level `=>`) and pin the
                      // instance's return to it — so a UNION (`i32|string`) / NULLABLE (`string|null`)
                      // / string / i64 result lowers and the caller's `is` / `??` classifies it. The
                      // f64-only branch above missed every non-f64 result (the union case emitted
                      // INVALID WASM, the nullable case a clean `??` reject). A closure-RESULT
                      // (`(i32)=>((i32)=>i32)`) is left as `nret = -1` — closure-returning HOFs are a
                      // separate slice.
                      const arrowAt = annArrowAt(pn)
                      if arrowAt > 0 {
                        const retName = monoUnwrapParens(pn.slice(arrowAt + 2, pn.length))
                        if retName != "" && annArrowAt(retName) < 0 {
                          nret = mkTypeRef(retName, -1)
                        }
                      }
                    }
                  }
                }
              }
              pq = pq + 1
            }
          }
          // `return <param>.map/filter(<lambda>)` over a param this instance pinned to a
          // NON-i32 array: type the un-annotated return as the concrete result list. The
          // inferred-return path has no f64/string-array map/filter-result form, so set it
          // here — `.filter` preserves the element; `.map` preserves it for an element-wise
          // arithmetic/concat callback (`monoLambdaPreservesElem`). i32 keeps `nret = -1`
          // (its inference already handles it) → byte-identical.
          if rcal is Member {
            if rcal.memProp == "map" || rcal.memProp == "filter" {
              if rxe.callArgs.length == 1 {
                const mrecv = P.nodes[rcal.memObj]
                if mrecv is Ident {
                  let pqm = 0
                  while pqm < params.length {
                    const ppm = P.nodes[params[pqm]]
                    if ppm is Param {
                      if ppm.parName == mrecv.identName {
                        const srcElem = monoArrElemName(pinned[pqm])
                        if srcElem != "" && srcElem != "i32" {
                          if rcal.memProp == "filter" {
                            nret = mkTypeRef(srcElem + "[]", -1)
                          } else if monoLambdaPreservesElem(rxe.callArgs[0]) {
                            nret = mkTypeRef(srcElem + "[]", -1)
                          }
                        }
                      }
                    }
                    pqm = pqm + 1
                  }
                }
              }
            }
          }
        }
        if rxe is Index {
          // `return param[i]` where the param pinned to an f64 array yields an f64
          // element — synthesize the concrete `f64` return (the un-annotated-return kind
          // inference has no f64 form for an indexed un-annotated array param). i32/string
          // returns keep `nret = -1` (their inference handles them) → byte-identical.
          const ria = P.nodes[rxe.idxArr]
          if ria is Ident {
            let pqi = 0
            while pqi < params.length {
              const ppi = P.nodes[params[pqi]]
              if ppi is Param {
                if ppi.parName == ria.identName {
                  if pinned[pqi] == "f64[]" { nret = mkTypeRef("f64", -1) }
                }
              }
              pqi = pqi + 1
            }
          }
        }
        if rxe is Ident {
          // `return <local>` where the local is a hole-built list (`const out = [];
          // out.push(self[i])`): the list shares the indexed param's array type, so type
          // the un-annotated return as that param's pinned type. This lowers a fully
          // un-annotated `reverse(self)` end-to-end (the un-annotated-return kind inference
          // can't see a mono instance's inferred list local). No source param found → keep
          // `nret = -1`, so a plain scalar/local return stays byte-identical.
          const srcParam = monoListSrcParam(fn.fnBody, rxe.identName)
          if srcParam != "" {
            let pli = 0
            while pli < params.length {
              const ppl = P.nodes[params[pli]]
              if ppl is Param {
                if ppl.parName == srcParam {
                  if pinned[pli] != "" {
                    nret = mkTypeRef(pinned[pli], -1)
                    monoOutName = rxe.identName
                    monoOutType = pinned[pli]
                  }
                }
              }
              pli = pli + 1
            }
          } else {
            // The pass-through trace found no `out.push(param[idx])` source — the list is
            // built from a NON-TRIVIAL expression over the element (`out.push(self[i] * 2)`).
            // Re-check the body for THIS shape (params pinned concretely) so the checker's
            // own list-element inference resolves the local; that lifts the element-hole
            // ceiling generically (any pushed expression, not just a bare index). "" when it
            // is not an inferred list / stays generic → `nret` stays -1 (byte-identical).
            const listTy = monoInferListElem(monoOrigNode[origFe], pinned, rxe.identName)
            if listTy != "" {
              nret = mkTypeRef(listTy, -1)
              monoOutName = rxe.identName
              monoOutType = listTy
            } else {
              // Not an inferred LIST local — try a SCALAR one (`const t = self[i]; return t`,
              // or a `let acc = ""; acc = acc + self[i]; return acc` fold) whose type derives
              // from a hole-pinned param. The return-kind inference runs before locals are
              // collected and the typed-IR is stale for a hole-derived node, so type the
              // un-annotated return from a re-check with the params pinned concretely. "" for
              // i32 / boolean / non-scalar locals → `nret` stays -1 (byte-identical).
              const scTy = monoInferLocalScalar(monoOrigNode[origFe], pinned, rxe.identName)
              if scTy != "" { nret = mkTypeRef(scTy, -1) }
            }
          }
        }
      }
    }
    let instName = fn.fnName
    let instFe = origFe
    if count > 0 { instName = fn.fnName + "$" + i32ToStr(count) }
    const noTyParams: string[] = []
    // Substitute type-param annotations in the body's `LetDecl`s for this instance (a
    // `const out: T[]` becomes `const out: f64[]`); shares the body wholesale when it has
    // no such annotation.
    const instBody0 = monoCloneBody(
      fn.fnBody,
      fn.fnTyParams,
      tvN,
      tvV,
      monoOutName,
      monoOutType,
    )
    // Pin any `.map`/`.filter` callback lambda whose receiver param this instance bound to a
    // NON-i32 element (`self: f64[]` ⇒ the `(x) => …` callback's `x` is f64): the shared
    // body's un-annotated lambda would otherwise emit as i32. Build the param→element map
    // from the pinned param names, then clone+pin per instance (i32 shapes are left as-is →
    // byte-identical).
    const pElemNames: string[] = []
    const pElemTypes: string[] = []
    let pe = 0
    while pe < params.length {
      const pep = P.nodes[params[pe]]
      if pep is Param {
        pElemNames.push(pep.parName)
      } else {
        pElemNames.push("")
      }
      pElemTypes.push(monoArrElemName(pinned[pe]))
      pe = pe + 1
    }
    const instBody1 = monoPinMapLambdas(instBody0, pElemNames, pElemTypes)
    // Bake any non-capturing concrete callback into a DIRECT call (`pElemNames` already holds the
    // per-position param NAMES, parallel to `cbFnNames`). No baked callback → no rewrite → the body
    // is the same node `monoPinMapLambdas` produced (byte-identical to the pre-specialization path).
    let instBody = instBody1
    if monoAnyBakedCallback(cbFnNames) {
      instBody = monoBakeCallback(instBody1, pElemNames, cbFnNames)
    }
    const nfn = mkFunc(instName, noTyParams, nps, nret, instBody, -1)
    if count == 0 {
      // First instance: keep the bare name and the original's wasm index.
      fnStmts[origFe] = nfn
    } else {
      // A CAPTURING lambda monomorphized at a SECOND type: the binding holds ONE closure whose
      // funcref is the first-type instance, so a second-type call can be neither a `call_ref`
      // through it (wrong functype) nor a by-name call (drops the env). Reject cleanly — value-flow
      // monomorphization of a capturing lambda is single-type for now (annotate it, or use distinct
      // bindings). A non-capturing instance has no env and lowers fine as a by-name call.
      if captureCountOf(origFe) > 0 {
        return emitFail(
          "emitProgram: a capturing lambda used at more than one type is not yet supported — " +
            "annotate its parameters, or bind a separate copy per type",
        )
      }
      fnStmts.push(nfn)
      fnParent.push(-1)
      fnDispNames.push("")
      instFe = fnStmts.length - 1
      const cal2 = P.nodes[calleeIx]
      if cal2 is Ident { cal2.identName = instName }
    }
    // REGISTER before walking the body, so a recursive self-call at the same
    // shape resolves here instead of recursing (the host's discipline).
    monoKeys.push(key)
    monoInstOrig.push(origFe)
    monoInstName.push(instName)
    monoInstFe.push(instFe)
    if monoRebuild() < 0 { return -1 }
    // Walk the instance's body — a nested generic call instantiates its own
    // callee against THIS instance's concrete annotations.
    if monoWalk(fn.fnBody, nfn) < 0 { return -1 }
    if monoRebuild() < 0 { return -1 }
    return 0
  }
  0
}

// The param type NAMES of a function-type NAME (`(f64, f64) => f64` → ["f64", "f64"]), appended to
// `out`. Mirrors `paramCloSigKey`'s parse of the canonical `(params) => ret` name. false when `name`
// is not a function type or is malformed.
function monoFnTypeAnnParamsName(name: string, out: string[]) {
  const arrowAt = annArrowAt(name)
  if arrowAt < 1 { return false }
  if name[0] != '(' { return false }
  if name[arrowAt - 1] != ')' { return false }
  const paramsStr = name.slice(1, arrowAt - 1)
  if paramsStr.length > 0 { annSplitParams(paramsStr, out) }
  true
}

// Strip ONE layer of wrapping parens when they enclose the WHOLE string (`((i32,i32)=>i32)` →
// `(i32,i32)=>i32`, the grouping parens a function type carries as an array element); leaves a name
// whose leading `(` is not the outermost wrapper (`(i32,i32)=>i32`) untouched.
function monoUnwrapParens(s: string) {
  const n = s.length
  if n < 2 { return s }
  if s[0] != '(' { return s }
  if s[n - 1] != ')' { return s }
  let depth = 0
  let i = 0
  while i < n {
    if s[i] == '(' {
      depth = depth + 1
    } else if s[i] == ')' {
      depth = depth - 1
      if depth == 0 {
        if i == n - 1 { return s.slice(1, n - 1) }
        return s
      }
    }
    i = i + 1
  }
  s
}

// Materialize (or reuse) the instance of generic `origFe` for an ANNOTATED function-typed binding
// (`const c: (f64, f64) => f64 = add`): pin each parameter to the annotation's param type NAME and
// create the instance (annotating an i32 param too, so the binding's closure value passes the value
// floor), pointing the binding init `letInitIx` at it. Unlike the call-driven `monoInstantiate`,
// this carries the value its concrete type INDEPENDENT of any call — so a binding that ESCAPES
// (passed to a HOF / returned / stored) is `call_ref`'d at the type its annotation pinned. Restricted
// to a generic whose params are ALL un-annotated holes (the capability-bounded case); a `<T>` or
// annotated-param generic keeps the call-driven path. Returns 0, or -1 via `emitFail`.
function monoInstanceFor(origFe: i32, pinnedNames: string[], letInitIx: i32) {
  const fn = P.nodes[monoOrigNode[origFe]]
  if fn is FuncDecl {
    const params = fn.fnParams
    if params.length != pinnedNames.length { return 0 }
    let i = 0
    while i < params.length {
      const p = P.nodes[params[i]]
      if p is Param {
        if p.parType >= 0 { return 0 }
      }
      i = i + 1
    }
    const pinned: string[] = []
    let j = 0
    while j < pinnedNames.length {
      pinned.push(pinnedNames[j])
      j = j + 1
    }
    const tvN: string[] = []
    const tvV: string[] = []
    // The annotation-driven binding path (`const c: (f64,f64)=>f64 = add`) bakes no callback — the
    // value escapes its call sites, so its body keeps the `call_ref`. Empty → no key/body change.
    const noCb: string[] = []
    return monoMakeInstance(origFe, pinned, tvN, tvV, letInitIx, true, noCb)
  }
  0
}

// Coerce a generic function VALUE (or a composite of them) flowing into the expected type NAMED by
// `tname`. If `exprIx` is an `Ident` naming a generic (un-annotated-param) function and `tname` is a
// CONCRETE function type, materialize the instance for its param types and point the `Ident` at it
// (`monoInstanceFor`). If `exprIx` is an ARRAY LITERAL and `tname` is a closure-array type
// (`((i32,i32)=>i32)[]`), recurse into each element against the element function type. The single
// coercion shared by every typed boundary a generic function value reaches — an annotated binding, a
// concrete function-typed call ARGUMENT, an annotated RETURN, an ARRAY element — so the value carries
// its concrete type wherever it escapes. The checker (`genericFnAssignable`) has already proved the
// instantiation valid; this only emits it.
function monoCoerceFnValueName(exprIx: i32, tname: string, ctx: i32) {
  if exprIx < 0 { return 0 }
  const e = P.nodes[exprIx]
  if e is ArrayLit {
    if nameIsClosureArray(tname) {
      const elemName = monoUnwrapParens(tname.slice(0, tname.length - 2))
      const es = e.arrElems
      let k = 0
      while k < es.length {
        if monoCoerceFnValueName(es[k], elemName, ctx) < 0 { return -1 }
        k = k + 1
      }
    }
    return 0
  }
  if e is Ident {
    // A bare function NAME, or a VALUE BINDING holding a generic function (`const add = (a,b) =>
    // a + b`, or `const g = named`) — resolve the binding to its lifted slot so an escaping lambda
    // binding materializes at the boundary type too, not just a by-name generic function.
    let gfe = fnIndexOf(e.identName)
    if gfe < 0 { gfe = identClosureFe(e.identName, ctx) }
    if gfe >= 0 && gfe < monoGen.length {
      if monoGen[gfe] == 1 {
        const pnames: string[] = []
        if monoFnTypeAnnParamsName(tname, pnames) {
          return monoInstanceFor(gfe, pnames, exprIx)
        }
      }
    }
  }
  0
}

// `monoCoerceFnValueName` keyed on an expected TYPE-annotation node (`-1` / a non-function type is a
// no-op). `ctx` is the enclosing function (-1 = top level), for resolving a value binding.
function monoCoerceFnValue(exprIx: i32, expectedTyIx: i32, ctx: i32) {
  if expectedTyIx < 0 { return 0 }
  return monoCoerceFnValueName(exprIx, tyNameOf(expectedTyIx), ctx)
}

// The written type-annotation node of parameter `i` of the named function `name` (its ORIGINAL
// declaration, before monomorphization may replace the slot), or -1. Lets a call site read the
// concrete function type a callback parameter declares, to coerce a generic function argument.
function monoFnParamTypeAt(name: string, i: i32) {
  const fe = fnIndexOf(name)
  if fe < 0 { return -1 }
  const fn = P.nodes[monoOrigNode[fe]]
  if fn is FuncDecl {
    const ps = fn.fnParams
    if i < ps.length {
      const p = P.nodes[ps[i]]
      if p is Param { return p.parType }
    }
  }
  -1
}

// Instantiate (or reuse) the instance of generic `origFe` for the call at
// `callIx` (whose enclosing function is `ctx`, -1 = top level), and point the
// call site at it. Returns 0, or -1 via `emitFail`.
function monoInstantiate(origFe: i32, callIx: i32, ctx: i32) {
  let c = P.nodes[callIx]
  const fn = P.nodes[monoOrigNode[origFe]]
  if c is Call {
    if fn is FuncDecl {
      const args = c.callArgs
      const params = fn.fnParams
      if args.length != params.length {
        return emitFail(
          "emitProgram: monomorphize: wrong number of arguments calling `" +
            fn.fnName +
            "`",
        )
      }
      // Pin each parameter: an un-annotated param takes its argument's type
      // name; a type-param-riding annotation binds the type param (first use
      // wins, later uses take the binding); a concrete annotation is kept.
      const tvN: string[] = []
      const tvV: string[] = []
      const pinned: string[] = []
      let i = 0
      while i < args.length {
        const p = P.nodes[params[i]]
        if p is Param {
          if p.parType < 0 {
            const an = monoArgTyName(args[i], ctx)
            if an == "" {
              return emitFail(
                "emitProgram: monomorphize: unsupported argument type for `" +
                  p.parName +
                  "` in a call to `" +
                  fn.fnName +
                  "`",
              )
            }
            pinned.push(an)
          } else {
            const ann = tyNameOf(p.parType)
            const tp = monoTyParamOf(ann, fn.fnTyParams)
            if tp == "" {
              // A COMPOSITE annotation riding type params (`Box<T>` — a
              // generic-alias application argument): bind them by matching the
              // pattern against the argument's concrete type name, then pin
              // the substituted annotation. A fully concrete annotation pins
              // unchanged.
              if monoAnnHasTyParam(ann, fn.fnTyParams) {
                // A FUNCTION-TYPE param (`f: (A, T) => A`) binds from the closure
                // argument's function-type NAME (`(i32, i32) => i32`); any other
                // composite (`Box<T>`, `{a:T}`) from its concrete value-type name.
                let anC = ""
                if annArrowAt(ann) >= 1 {
                  anC = monoArgFnTypeName(args[i], ctx)
                } else {
                  anC = monoArgTyName(args[i], ctx)
                }
                if anC == "" {
                  return emitFail(
                    "emitProgram: monomorphize: unsupported argument type for `" +
                      p.parName +
                      "` in a call to `" +
                      fn.fnName +
                      "`",
                  )
                }
                monoBindFromAnn(ann, anC, fn.fnTyParams, tvN, tvV)
                const pinC = monoSubstAnn(ann, fn.fnTyParams, tvN, tvV)
                if pinC == "" {
                  return emitFail(
                    "emitProgram: monomorphize: unsupported argument type for `" +
                      p.parName +
                      "` in a call to `" +
                      fn.fnName +
                      "`",
                  )
                }
                pinned.push(pinC)
              } else {
                pinned.push(ann)
              }
            } else {
              const an2 = monoArgTyName(args[i], ctx)
              if an2 == "" {
                return emitFail(
                  "emitProgram: monomorphize: unsupported argument type for `" +
                    p.parName +
                    "` in a call to `" +
                    fn.fnName +
                    "`",
                )
              }
              let bind = an2
              if ann != tp {
                // `T[]` param: the argument must be an array; its element binds T.
                const an2n = an2.length
                if an2n < 2 {
                  return emitFail(
                    "emitProgram: monomorphize: expected an array argument for `" +
                      p.parName +
                      "` in a call to `" +
                      fn.fnName +
                      "`",
                  )
                }
                if an2[an2n - 2] != '[' {
                  return emitFail(
                    "emitProgram: monomorphize: expected an array argument for `" +
                      p.parName +
                      "` in a call to `" +
                      fn.fnName +
                      "`",
                  )
                }
                bind = an2.slice(0, an2n - 2)
              }
              let b = monoBindOf(tvN, tvV, tp)
              if b == "" {
                tvN.push(tp)
                tvV.push(bind)
              } else {
                bind = b
              }
              if ann != tp {
                pinned.push(bind + "[]")
              } else {
                pinned.push(bind)
              }
            }
          }
        }
        i = i + 1
      }
      // CALLBACK SPECIALIZATION: for each closure-valued argument that is a KNOWN, NON-CAPTURING,
      // NON-GENERIC function (a top-level name `add`, or an in-place lifted lambda literal), record
      // the function's name so this instance bakes a direct call to it (`monoBakeCallback`) and keys
      // on its identity (so `reduce(xs, add, …)` and `reduce(xs, mul, …)` get distinct instances).
      // A capturing callback (needs its live env), a generic one (needs its own instantiation), or
      // any non-resolvable closure value leaves "" → the param keeps its `call_ref` (byte-identical).
      const cbFnNames: string[] = []
      let ci = 0
      while ci < args.length {
        cbFnNames.push(monoSpecializableCallbackName(args[ci], ctx))
        ci = ci + 1
      }
      return monoMakeInstance(origFe, pinned, tvN, tvV, c.callFn, false, cbFnNames)
    }
  }
  0
}

// The callback name to BAKE for a closure-valued argument, or "" when it is not specializable.
// Specializable iff the argument is a closure VALUE resolving to a known function (a bare top-level
// name, or an in-place lifted lambda literal) that CAPTURES NOTHING and is itself NON-GENERIC — so a
// direct by-name `call` (which passes the null env a non-capturing callee wants) is valid. Anything
// else (a capturing lambda, a generic function, a closure read from a binding/union/HOF result, a
// non-closure argument) returns "" and keeps the per-element `call_ref`.
function monoSpecializableCallbackName(argIx: i32, ctx: i32) {
  if !exprIsClosure(argIx, ctx) { return "" }
  const ax = unwrapParen(argIx)
  const an = P.nodes[ax]
  let fe = -1
  if an is FuncDecl { fe = fnStmtsPosOf(ax) }
  else if an is Ident { fe = fnIndexOf(an.identName) }
  if fe < 0 || fe >= fnStmts.length { return "" }
  if captureCountOf(fe) > 0 { return "" }
  if fe < monoGen.length {
    if monoGen[fe] == 1 { return "" }
  }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl { return fn.fnName }
  ""
}

// Does the NON-generic function at `fe` take a closure-typed parameter (`f: (i32,i32)=>i32`)? —
// i.e. is it a concrete higher-order function, a candidate for callback specialization. A `<T>`
// generic is excluded (its callbacks are already baked via `monoInstantiate` + `monoBakeCallback`).
function feHasClosureParam(fe: i32) {
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    if fn.fnTyParams.length > 0 { return false }
    let i = 0
    while i < fn.fnParams.length {
      const p = P.nodes[fn.fnParams[i]]
      if p is Param {
        if p.parType >= 0 {
          if annArrowAt(tyNameOf(p.parType)) >= 0 { return true }
        }
      }
      i = i + 1
    }
  }
  false
}

// Whether the program defines ANY concrete higher-order function — the gate that lets the mono
// pass run for callback specialization even when the program has no `<T>` generic. The compiler
// itself has none (it is closure-free imperative code), so this stays false for it and the pass
// stays skipped → the all-i32 native fixpoint is byte-identical.
function monoHasConcreteHOFParam() {
  let fe = 0
  while fe < fnStmts.length {
    if fe < monoGen.length {
      if monoGen[fe] == 0 {
        if feHasClosureParam(fe) { return true }
      }
    }
    fe = fe + 1
  }
  false
}

// CALLBACK SPECIALIZATION for a CONCRETE (non-generic) HOF. A concrete `reduce(self: i32[], f:
// (i32,i32)=>i32, init)` never goes through `monoInstantiate` (it is not type-parameterized), so its
// body keeps the per-element `call_ref` through `f`. When a call passes a non-capturing concrete
// callback, clone the function with that callback BAKED in as a direct call (`monoBakeCallback`),
// append it as a fresh `<name>$cbN`, and point the call site at it — the concrete analogue of what
// `monoMakeInstance` does for generics, keyed purely on the callback identity (the params carry their
// own annotations, so there is no type pinning / return inference). Unlike a generic template, the
// ORIGINAL concrete function is KEPT (its slot is never replaced): it still serves any non-bakeable
// caller (a capturing lambda, a closure read from a binding/union). The closure VALUE is still passed
// (the param stays), so a callback used in a non-call position keeps working. No bakeable callback →
// returns 0 having changed nothing (byte-identical). Returns 0, or -1 via `emitFail`.
function monoSpecializeConcrete(callIx: i32, fe: i32, ctx: i32) {
  const c = P.nodes[callIx]
  if c is Call {
    const fn = P.nodes[fnStmts[fe]]
    if fn is FuncDecl {
      const params = fn.fnParams
      const args = c.callArgs
      if args.length != params.length { return 0 }
      // Only an ANNOTATED return is specialized. An UN-annotated return is inferred THROUGH the
      // callback param's call (`function applyN(g, x) { return g(x) }`): baking that `g(x)` into a
      // direct `maybeName(x)` re-derives the return via a different inference path, which doesn't
      // re-establish a nullable/union rep on the appended function (so a downstream `?? d` / `is`
      // narrow fails). The annotation pins the rep independent of the body, so it survives the bake.
      // The fold/reduce/search HOFs worth specializing annotate their return anyway; the un-annotated
      // case is the thin `return g(x)` wrapper, which barely benefits. (The generic path has the same
      // un-annotated-return limitation — a shared follow-up.)
      if fn.fnRet < 0 { return 0 }
      // The baked callback (and its param NAME) per position — "" where the argument is not a
      // non-capturing concrete function (a capturing lambda / generic / non-closure stays call_ref).
      const cbFnNames: string[] = []
      const cbParamNames: string[] = []
      let i = 0
      while i < args.length {
        const p = P.nodes[params[i]]
        if p is Param {
          cbParamNames.push(p.parName)
        } else {
          cbParamNames.push("")
        }
        cbFnNames.push(monoSpecializableCallbackName(args[i], ctx))
        i = i + 1
      }
      if !monoAnyBakedCallback(cbFnNames) { return 0 }
      // Key on the callee + each baked callback identity, so `reduce(xs, add, …)` and `reduce(xs,
      // mul, …)` get distinct specializations. The `C` prefix keeps these out of the generic keyspace
      // (which always carries a `#`), so the two registries share storage without colliding.
      let key = "C" + i32ToStr(fe)
      let kc = 0
      while kc < cbFnNames.length {
        if cbFnNames[kc] != "" { key = key + "@" + cbFnNames[kc] }
        kc = kc + 1
      }
      // Registry hit: a prior call already specialized this (callee, callback-set) — reuse it.
      let r = 0
      while r < monoKeys.length {
        if monoKeys[r] == key {
          const cal = P.nodes[c.callFn]
          if cal is Ident { cal.identName = monoInstName[r] }
          return 0
        }
        r = r + 1
      }
      // Fresh specialization. `$cbN` is disambiguated by how many concrete specializations this
      // callee already has (its prior `monoInstOrig` entries).
      let count = 0
      let kk = 0
      while kk < monoInstOrig.length {
        if monoInstOrig[kk] == fe { count = count + 1 }
        kk = kk + 1
      }
      const instBody = monoBakeCallback(fn.fnBody, cbParamNames, cbFnNames)
      const nps: i32[] = []
      let pj = 0
      while pj < params.length {
        const p3 = P.nodes[params[pj]]
        if p3 is Param { nps.push(mkParam(p3.parName, p3.parType, p3.pos)) }
        pj = pj + 1
      }
      const noTP: string[] = []
      const specName = fn.fnName + "$cb" + i32ToStr(count)
      const nfn = mkFunc(specName, noTP, nps, fn.fnRet, instBody, fn.pos)
      fnStmts.push(nfn)
      fnParent.push(-1)
      fnDispNames.push("")
      const instFe = fnStmts.length - 1
      const cal2 = P.nodes[c.callFn]
      if cal2 is Ident { cal2.identName = specName }
      monoKeys.push(key)
      monoInstOrig.push(fe)
      monoInstName.push(specName)
      monoInstFe.push(instFe)
      if monoRebuild() < 0 { return -1 }
      // Walk the ORIGINAL body under this specialization's context so a nested generic call it
      // contains instantiates (idempotent via the registry — the main loop also walks the original).
      if monoWalk(fn.fnBody, nfn) < 0 { return -1 }
      if monoRebuild() < 0 { return -1 }
    }
  }
  0
}

// Walk the statement/expression tree at `ix` (inside function `ctx`, -1 = top
// level) and instantiate every direct call to a generic function. Arguments are
// walked BEFORE their call is classified, so an inner generic call's instance
// (and its now-concrete return kind) is in place when the outer call's argument
// types are read.
function monoWalk(ix: i32, ctx: i32) {
  if ix < 0 { return 0 }
  let n = P.nodes[ix]
  if n is Call {
    const args = n.callArgs
    let i = 0
    while i < args.length {
      if monoWalk(args[i], ctx) < 0 { return -1 }
      i = i + 1
    }
    const callee = P.nodes[n.callFn]
    if callee is Ident {
      // A generic function value passed as an ARGUMENT to a concrete function-typed PARAMETER
      // (`apply(add)` where `apply(f: (i32,i32)=>i32)`): materialize the instance for the
      // parameter's declared function type so the argument closure carries it.
      let ca = 0
      while ca < args.length {
        const pty = monoFnParamTypeAt(callee.identName, ca)
        if pty >= 0 {
          if monoCoerceFnValue(args[ca], pty, ctx) < 0 { return -1 }
        }
        ca = ca + 1
      }
      let fe = fnIndexOf(callee.identName)
      if fe < 0 {
        // A direct call through a VALUE binding to a generic NAMED function (`const g = add;
        // g(3, 4)`): resolve `g` to `add`'s lifted slot and monomorphize per call site, exactly
        // as a by-name call. NAMED functions only — a lambda bound to a closure-typed local
        // (`const f: (i32) => i32 = (x) => …`) is contextually pinned and `call_ref`'d, never
        // monomorphized (`criFnIsAnonLambda` excludes it; the emit-time value floor and the
        // LetDecl direct-call exemption keep the two paths sound).
        const afe = identClosureFe(callee.identName, ctx)
        if afe >= 0 {
          if !criFnIsAnonLambda(afe) {
            fe = afe
          } else if identFnTypeAnnName(callee.identName, ctx) == "" {
            // A lambda bound to an UN-annotated `const` (`const add = (a, b) => a + b`): its params
            // are inference holes — monomorphize it per call exactly like a named generic function.
            // The slot-replacement keeps the binding's closure funcref pointing at the instance, so a
            // CAPTURING lambda's env still rides through the `call_ref`. An ANNOTATED binding
            // (`const f: (i32)=>i32 = …`) is contextually pinned and excluded.
            fe = afe
          }
        }
      }
      if fe >= 0 && fe < monoGen.length {
        if monoGen[fe] == 1 { return monoInstantiate(fe, ix, ctx) }
        // A CONCRETE callee: specialize it per non-capturing callback (no-op if none) — the
        // concrete analogue of `monoInstantiate`'s callback baking.
        return monoSpecializeConcrete(ix, fe, ctx)
      }
      return 0
    }
    return monoWalk(n.callFn, ctx)
  }
  if n is Block {
    const bs = n.blkStmts
    let i2 = 0
    while i2 < bs.length {
      if monoWalk(bs[i2], ctx) < 0 { return -1 }
      i2 = i2 + 1
    }
    return 0
  }
  if n is LetDecl {
    // An ANNOTATED function-typed binding to a generic NAMED function (`const c: (f64,f64)=>f64 =
    // add`): materialize the instance for the ANNOTATION's param types and point the binding at it,
    // so the value carries that concrete type independent of any call — it may ESCAPE (be passed,
    // returned, stored) where call-driven monomorphization can't reach. The annotation also governs
    // its calls (the checker pins them), so the instance the binding holds matches every use.
    if monoCoerceFnValue(n.letInit, n.letType, ctx) < 0 { return -1 }
    return monoWalk(n.letInit, ctx)
  }
  if n is IfStmt {
    if monoWalk(n.ifCond, ctx) < 0 { return -1 }
    if monoWalk(n.ifThen, ctx) < 0 { return -1 }
    return monoWalk(n.ifElse, ctx)
  }
  if n is WhileStmt {
    if monoWalk(n.whileCond, ctx) < 0 { return -1 }
    return monoWalk(n.whileBody, ctx)
  }
  if n is ForRange {
    if monoWalk(n.frFrom, ctx) < 0 { return -1 }
    if monoWalk(n.frTo, ctx) < 0 { return -1 }
    if monoWalk(n.frStep, ctx) < 0 { return -1 }
    return monoWalk(n.frBody, ctx)
  }
  if n is ForIn {
    if monoWalk(n.fiIter, ctx) < 0 { return -1 }
    return monoWalk(n.fiBody, ctx)
  }
  if n is RetStmt {
    // A generic function value RETURNED where the enclosing function declares a concrete function
    // return type (`function mk(): (f64,f64)=>f64 { return add }`): materialize the instance for
    // that return type so the returned value carries it.
    if ctx >= 0 {
      const cf = P.nodes[ctx]
      if cf is FuncDecl {
        if monoCoerceFnValue(n.retArg, cf.fnRet, ctx) < 0 { return -1 }
      }
    }
    return monoWalk(n.retArg, ctx)
  }
  if n is BinExpr {
    if monoWalk(n.binLeft, ctx) < 0 { return -1 }
    return monoWalk(n.binRight, ctx)
  }
  if n is Unary { return monoWalk(n.unArg, ctx) }
  if n is Paren { return monoWalk(n.parInner, ctx) }
  if n is Member { return monoWalk(n.memObj, ctx) }
  if n is OptMember { return monoWalk(n.omObj, ctx) }
  if n is Index {
    if monoWalk(n.idxArr, ctx) < 0 { return -1 }
    return monoWalk(n.idxIndex, ctx)
  }
  if n is IsExpr { return monoWalk(n.isObj, ctx) }
  if n is ArrayLit {
    const es = n.arrElems
    let i3 = 0
    while i3 < es.length {
      if monoWalk(es[i3], ctx) < 0 { return -1 }
      i3 = i3 + 1
    }
    return 0
  }
  if n is ObjLit {
    const fs = n.objFields
    let i4 = 0
    while i4 < fs.length {
      const f = P.nodes[fs[i4]]
      if f is FieldInit {
        if monoWalk(f.fiValue, ctx) < 0 { return -1 }
      }
      i4 = i4 + 1
    }
    return 0
  }
  // A nested FuncDecl's body is walked through its own `fnStmts` slot (it was
  // lambda-lifted); every other node kind has no call-bearing children.
  0
}

// The monomorphization pass: snapshot which lifted functions are generic, then
// walk every top-level statement (program order — a `const ys = get([…])` pins
// `get` before a later `first(ys)` reads its return kind) and every NON-generic
// function body; instance bodies are walked as they are created. Usage-gated:
// a program with no generic declaration returns immediately.
// ── self-method / operator / index-trap dispatch REWRITE (B13 + B14) ─────────
// The HOST resolves these in its type-aware parser; the native parser is
// type-free, so the emitter rewrites the arena BEFORE monomorphization:
//   o.f(args)  → f(o, args)         a free `self`-function, receiver a struct
//                                   that lacks a field `f` (UFCS)
//   a op b     → op(a, b)           a free `self`-function named for the
//                                   operator, struct left operand
//   a op b     → (a."op")(b)        the left operand carries an operator
//                                   closure FIELD ("*", "/", …)
//   o[k]       → (o."[]")(k)        a "[]" trap field (native arrays/maps/
//                                   strings never classify as structs, so they
//                                   keep their fast paths)
//   o[k] = v   → (o."[]=")(k, v)    a "[]=" trap field on the assignment form
// The walk is POST-ORDER (children first, parents store the returned — possibly
// new — child index back into their i32 child fields), so a chained `a[1][2]`
// rewrites its inner trap before the outer looks at its receiver. The rewritten
// forms ride the EXISTING lowerings: plain calls monomorphize per receiver
// shape; field-closure calls use the member-call machinery. Usage-gated: a
// program with none of these shapes rewrites nothing (byte-identical bytes).

// The `fnStmts` index of a free `self`-function `name` of `argc` total params
// (first param NAMED `self`), or -1 — the host's UFCS reachability rule, so a
// non-`self` function is NOT a method (objects/self-method-pollution.vl).
function drwSelfFnOf(name: string, argc: i32) {
  let fe = fnIndexOf(name)
  if fe < 0 { return -1 }
  const fn = P.nodes[fnStmts[fe]]
  if fn is FuncDecl {
    const ps = fn.fnParams
    if ps.length != argc { return -1 }
    if ps.length > 0 {
      const p0 = P.nodes[ps[0]]
      if p0 is Param {
        if p0.parName == "self" { return fe }
      }
    }
  }
  -1
}

// Does struct `si` carry a CLOSURE-valued field `name` (code 14)?
function drwFieldClosure(si: i32, name: string) {
  if si < 0 { return false }
  let fi = sFieldIndex(si, name)
  if fi < 0 { return false }
  sFieldTypeAt(si, fi) == 14
}

// Post-order rewrite of the tree at `ix` (inside function `ctx`, -1 = top
// level). Returns the node index to use in `ix`'s place (usually `ix` itself).
function drwWalk(ix: i32, ctx: i32) {
  if ix < 0 { return ix }
  let n = P.nodes[ix]
  if n is Call {
    const args = n.callArgs
    let i = 0
    while i < args.length {
      args[i] = drwWalk(args[i], ctx)
      i = i + 1
    }
    const callee = P.nodes[n.callFn]
    if callee is Member {
      callee.memObj = drwWalk(callee.memObj, ctx)
      // UFCS (host parser.ts case 2): `o.f(args)` where `f` is a free function
      // whose FIRST parameter is named `self` (arity matching) lowers to the
      // direct call `f(o, args)`. The receiver TYPE does not gate it — string,
      // i32, and value-union receivers dispatch identically to struct ones.
      // The Call node mutates in place: the receiver shifts in as argument 0,
      // the callee becomes a bare Ident, and any named args slide right of the
      // unnamed receiver ("" rides slot 0).
      //
      // The module merge mangles a free `self`-function (`shout` → `shout$m1`)
      // but leaves the call's property plain so field precedence still resolves
      // from the receiver shape; `ufcsAliasOf` maps the plain property to the
      // mangled function, and the rebuilt direct-call Ident carries that name so
      // every downstream pass (string detection, print routing, coercion) sees a
      // normal named call. Identity single-file.
      const uName = ufcsAliasOf(callee.memProp)
      // Precedence, mirroring the host:
      //   • a REAL struct field of that name wins (a value access, not a call);
      //   • a callable FIELD (closure-valued, kind 14) wins as a `call_ref`
      //     member-call (`exprIsClosure`), so it is NOT UFCS-rewritten.
      // A non-struct receiver has no fields, so neither precedence case can
      // apply — the rewrite fires once a matching `self`-function exists.
      let si = structIndexOfExpr(callee.memObj, ctx)
      let ufcs = false
      if si >= 0 {
        if sFieldIndex(si, callee.memProp) < 0 {
          if drwSelfFnOf(uName, args.length + 1) >= 0 { ufcs = true }
        }
      }
      if si < 0 {
        if !exprIsClosure(n.callFn, ctx) {
          if drwSelfFnOf(uName, args.length + 1) >= 0 { ufcs = true }
        }
      }
      if ufcs {
        const recvIx = callee.memObj
        args.push(-1)
        let j = args.length - 1
        while j > 0 {
          args[j] = args[j - 1]
          j = j - 1
        }
        args[0] = recvIx
        // Named-arg parity: the injected receiver is an UNNAMED slot-0
        // positional. Only when the call already carries names does the name
        // list need a leading "" (an all-positional call keeps its empty
        // list, so `hasNamedArgs` stays false downstream).
        if hasNamedArgs(n.callArgNames) {
          let nm = n.callArgNames
          nm.push("")
          let k = nm.length - 1
          while k > 0 {
            nm[k] = nm[k - 1]
            k = k - 1
          }
          nm[0] = ""
        }
        n.callFn = mkIdent(uName, -1)
      }
      return ix
    }
    n.callFn = drwWalk(n.callFn, ctx)
    return ix
  }
  if n is Block {
    const bs = n.blkStmts
    let i2 = 0
    while i2 < bs.length {
      bs[i2] = drwWalk(bs[i2], ctx)
      i2 = i2 + 1
    }
    return ix
  }
  if n is LetDecl {
    n.letInit = drwWalk(n.letInit, ctx)
    return ix
  }
  if n is IfStmt {
    n.ifCond = drwWalk(n.ifCond, ctx)
    n.ifThen = drwWalk(n.ifThen, ctx)
    n.ifElse = drwWalk(n.ifElse, ctx)
    return ix
  }
  if n is WhileStmt {
    n.whileCond = drwWalk(n.whileCond, ctx)
    n.whileBody = drwWalk(n.whileBody, ctx)
    return ix
  }
  if n is ForRange {
    n.frFrom = drwWalk(n.frFrom, ctx)
    n.frTo = drwWalk(n.frTo, ctx)
    n.frStep = drwWalk(n.frStep, ctx)
    n.frBody = drwWalk(n.frBody, ctx)
    return ix
  }
  if n is ForIn {
    n.fiIter = drwWalk(n.fiIter, ctx)
    n.fiBody = drwWalk(n.fiBody, ctx)
    return ix
  }
  if n is RetStmt {
    n.retArg = drwWalk(n.retArg, ctx)
    return ix
  }
  if n is BinExpr {
    // The index WRITE-TRAP form `o[k] = v` — handled BEFORE the general child
    // walk so the assignment-target Index is not first rewritten into a READ
    // trap (host: the assignment parser recovers the object + key).
    if n.binOp == "=" {
      const tgt = P.nodes[n.binLeft]
      if tgt is Index {
        tgt.idxArr = drwWalk(tgt.idxArr, ctx)
        tgt.idxIndex = drwWalk(tgt.idxIndex, ctx)
        n.binRight = drwWalk(n.binRight, ctx)
        const wsi = structIndexOfExpr(tgt.idxArr, ctx)
        if drwFieldClosure(wsi, "[]=") {
          const wargs: i32[] = []
          wargs.push(tgt.idxIndex)
          wargs.push(n.binRight)
          return mkCall(mkMember(tgt.idxArr, "[]=", -1), wargs, -1)
        }
        return ix
      }
    }
    n.binLeft = drwWalk(n.binLeft, ctx)
    n.binRight = drwWalk(n.binRight, ctx)
    if drwDispatchOp(n.binOp) {
      const osi = structIndexOfExpr(n.binLeft, ctx)
      if osi >= 0 {
        // A free `self`-function named for the operator wins (host parser
        // order); else an operator closure FIELD dispatches member-call style.
        if drwSelfFnOf(n.binOp, 2) >= 0 {
          const oargs: i32[] = []
          oargs.push(n.binLeft)
          oargs.push(n.binRight)
          return mkCall(mkIdent(n.binOp, -1), oargs, -1)
        }
        if drwFieldClosure(osi, n.binOp) {
          const fargs: i32[] = []
          fargs.push(n.binRight)
          return mkCall(mkMember(n.binLeft, n.binOp, -1), fargs, -1)
        }
      }
    }
    return ix
  }
  if n is Unary {
    n.unArg = drwWalk(n.unArg, ctx)
    return ix
  }
  if n is Paren {
    n.parInner = drwWalk(n.parInner, ctx)
    return ix
  }
  if n is Member {
    n.memObj = drwWalk(n.memObj, ctx)
    return ix
  }
  if n is OptMember {
    n.omObj = drwWalk(n.omObj, ctx)
    return ix
  }
  if n is Index {
    n.idxArr = drwWalk(n.idxArr, ctx)
    n.idxIndex = drwWalk(n.idxIndex, ctx)
    // The index READ trap: a struct receiver carrying a "[]" closure field.
    const tsi = structIndexOfExpr(n.idxArr, ctx)
    if drwFieldClosure(tsi, "[]") {
      const targs: i32[] = []
      targs.push(n.idxIndex)
      return mkCall(mkMember(n.idxArr, "[]", -1), targs, -1)
    }
    return ix
  }
  if n is IsExpr {
    n.isObj = drwWalk(n.isObj, ctx)
    return ix
  }
  if n is ArrayLit {
    const es = n.arrElems
    let i3 = 0
    while i3 < es.length {
      es[i3] = drwWalk(es[i3], ctx)
      i3 = i3 + 1
    }
    return ix
  }
  if n is ObjLit {
    const fs = n.objFields
    let i4 = 0
    while i4 < fs.length {
      const f = P.nodes[fs[i4]]
      if f is FieldInit { f.fiValue = drwWalk(f.fiValue, ctx) }
      i4 = i4 + 1
    }
    return ix
  }
  ix
}

// The dispatch-rewrite driver: top-level statements, then every lifted
// function's body (a nested FuncDecl was lambda-lifted into `fnStmts`).
function dispatchRewrite(stmts: i32[]) {
  let i = 0
  while i < stmts.length {
    let s = P.nodes[stmts[i]]
    if s is FuncDecl {
    } else if s is LetDecl {
      s.letInit = drwWalk(s.letInit, -1)
    } else if nodeIsTypeDecl(stmts[i]) {
    } else if s is UnionDecl {
    } else {
      const oldIx = stmts[i]
      const newIx = drwWalk(oldIx, -1)
      if newIx != oldIx {
        // The statement node was REPLACED (e.g. `o[k] = v` → the `(o."[]=")(k,v)`
        // write-trap call). `startStmts` captured the OLD arena index during
        // `collectFns` — repoint it so the start function emits the rewritten form.
        stmts[i] = newIx
        let ssj = 0
        while ssj < startStmts.length {
          if startStmts[ssj] == oldIx { startStmts[ssj] = newIx }
          ssj = ssj + 1
        }
      }
    }
    i = i + 1
  }
  let fe = 0
  while fe < fnStmts.length {
    const fn = P.nodes[fnStmts[fe]]
    if fn is FuncDecl { fn.fnBody = drwWalk(fn.fnBody, fnStmts[fe]) }
    fe = fe + 1
  }
  0
}

function monomorphize(stmts: i32[]) {
  monoGen = []
  monoOrigNode = []
  monoKeys = []
  monoInstOrig = []
  monoInstName = []
  monoInstFe = []
  monoProgStmts = stmts
  let any = false
  let fe = 0
  while fe < fnStmts.length {
    monoOrigNode.push(fnStmts[fe])
    if monoIsGenericDecl(fnStmts[fe]) {
      monoGen.push(1)
      any = true
    } else {
      monoGen.push(0)
    }
    fe = fe + 1
  }
  // The pass also runs for callback specialization of a CONCRETE higher-order function (no `<T>`
  // generic needed). Gated on the program actually defining one, so a generic-free, HOF-free
  // program (the compiler itself) still skips the pass entirely → byte-identical.
  if !any {
    if monoHasConcreteHOFParam() { any = true }
  }
  if !any { return 0 }
  // Top-level statements first, in source order (global inits + start stmts).
  let i = 0
  while i < stmts.length {
    let s = P.nodes[stmts[i]]
    if s is FuncDecl {
    } else if s is LetDecl {
      // Walk the LetDecl NODE (not just its init) so the annotated-function-typed-binding
      // materialization in `monoWalk`'s `LetDecl` arm reaches a TOP-LEVEL binding too; the arm
      // still recurses into the init, so the existing behavior is unchanged for every other let.
      if monoWalk(stmts[i], -1) < 0 { return -1 }
    } else if nodeIsTypeDecl(stmts[i]) {
    } else if s is UnionDecl {
    } else {
      if monoWalk(stmts[i], -1) < 0 { return -1 }
    }
    i = i + 1
  }
  // Then every non-generic lifted function's body. (A generic original's body
  // is only ever walked through an instance; an instance appended during this
  // loop extends `fnStmts`, but its body was already walked on creation —
  // `monoGen` is frozen at the pre-pass length, and appended slots are past it.)
  let fe2 = 0
  const nDecl = monoGen.length
  while fe2 < nDecl {
    if monoGen[fe2] == 0 {
      const fn = P.nodes[fnStmts[fe2]]
      if fn is FuncDecl {
        if monoWalk(fn.fnBody, fnStmts[fe2]) < 0 { return -1 }
      }
    }
    fe2 = fe2 + 1
  }
  // PRUNE the un-instantiated `<T>` generics. A type-parameterized decl that NO call site
  // reached still holds its template node — `monoInstantiate` REPLACES the slot on the first
  // instance (count 0), so a generic slot still equal to its captured original was never
  // called. Emitting it as-is would try to lower an un-instantiated `T` parameter
  // ("only i32, …, or string parameters are supported"). This is routine: importing a module
  // for SOME of its generics pulls in ALL of them, so the unused ones (`std:array`'s
  // `reduce`/`count` when a program uses only `indexOf`) arrive as never-called templates.
  // Replace each with a concrete no-op STUB (same name, no params, void body) — valid dead
  // code; nothing references it (any reference would have instantiated it).
  //
  // GATED on type params (`<T>`), NOT the broader `monoGen` (which also flags un-annotated-
  // param functions): a lifted lambda (`(x) => x * 2`) has an un-annotated param but is
  // invoked as a function VALUE through `call_ref`, never via `monoInstantiate`, so its slot
  // also stays un-replaced — stubbing it would silently no-op the callback. A `<T>` decl
  // cannot be a lambda (anonymous literals take no type params) and is only ever reached by
  // instantiation, so this gate prunes exactly the dead templates.
  let gp = 0
  while gp < nDecl {
    if fnStmts[gp] == monoOrigNode[gp] {
      const gfn = P.nodes[fnStmts[gp]]
      if gfn is FuncDecl {
        if gfn.fnTyParams.length > 0 {
          const noTP: string[] = []
          const noPs: i32[] = []
          fnStmts[gp] = mkFunc(gfn.fnName, noTP, noPs, -1, mkBlock([], gfn.pos), gfn.pos)
        }
      }
    }
    gp = gp + 1
  }
  0
}

// Give each un-annotated parameter the concrete scalar/string type the checker recorded for
// it (`nodeTyName`) — a contextually-inferred callback param (`xs.map((x) => x * 2.0)` ⇒
// `x: f64`) whose annotation the emitter otherwise defaults to i32 (`checkParams`), so an
// f64/string-element callback mis-lowered. Emit-time, post-check (fmt untouched); a generic
// hole / already-annotated / non-scalar param yields "" and is left as-is.
// Resolve a checker-rendered type-shape NAME to the emitter's NOMINAL form: a struct shape
// (`{x: i32}`) to its declared name (matched by field-set), a variant shape to its variant name,
// and — RECURSIVELY — a ref-array shape to `<resolved element>[]` at any depth. A scalar / closure
// / already-nominal name passes through. One recursive resolver, so a new container shape (a
// nested list, a list-of-lists) falls out instead of being special-cased per depth.
function resolveShapeToNominal(name: string) {
  if name == "" { return "" }
  if nameIsArray(name) {
    const inner = resolveShapeToNominal(name.slice(0, name.length - 2))
    if inner == "" { return "" }
    return inner + "[]"
  }
  const si = structIndexOfTypeName(name)
  if si >= 0 { return sNames[si] }
  const vti = variantIndexOfTypeName(name)
  if vti >= 0 { return uVariants[vti] }
  name
}

// Pin every un-annotated lambda that returns a UNION to that union, by CONSUMING the contextual return
// type the CHECKER already computed — instead of re-deriving it per boundary in the emitter.
//
// An un-annotated lambda's body-inferred return for a union join (`if … { aCat } else { aDog }`)
// collapses to ONE arm (a struct / string), so its emitted functype result and `$fnsig` key (`i>s0;` /
// `i>S`) disagree with a call site's `i>u` — leaving the value call un-interned and the body un-boxed.
// Pinning `fnRet` to the union makes the lambda emit the boxed-union result (like an annotated `: Cat |
// Dog` function): it interns `i>u`, boxes each arm via `emitReturnValue`'s `retUNm`, and the call's
// `ref.cast` + `is`-narrow resolve. The checker proved the union the lambda returns AT ITS BOUNDARY
// (binding / function-return / struct field / array element / call argument) and recorded it under a
// node-index sentinel (`inferRetNameByNode`, the #533 channel) — so reading it pins the return at EVERY
// position UNIFORMLY, with no per-boundary walk (the abstraction the emitter's syntactic re-derivation
// otherwise lacks). Runs BEFORE monomorphization (a HOF-bound clone inherits `nret = fnRet`) and the
// shape passes (the union's box + variants intern for the return). A non-union recorded return / an
// already-annotated lambda is left untouched → byte-identical (the compiler has no union-returning
// lambdas, so the native fixpoint is unaffected).
function synthRetAnnots() {
  if !fnValUsed { return 0 }
  let fe = 0
  while fe < fnStmts.length {
    const lamIx = fnStmts[fe]
    const fn = P.nodes[lamIx]
    if fn is FuncDecl {
      if fn.fnRet < 0 {
        const ctx = inferRetNameByNode(lamIx)
        if ctx != "" {
          if isUName(ctx) || isValueUnionName(ctx) {
            fn.fnRet = mkTypeRef(ctx, -1)
          } else if nullablePartOf(ctx) != "" {
            // A NULLABLE-ref return (`P | null`, `string | null`) the checker proved at the lambda's
            // boundary — pin it so the lambda's `$fnsig` result keys the nullable token (`>n<idx>;` /
            // `>N`), matching the value call's key. The niche/nullable-struct lowering already exists
            // for the annotated form; this routes the anonymous lambda through it. (Nullable dual of
            // the union pin.)
            fn.fnRet = mkTypeRef(ctx, -1)
          }
        }
      }
    }
    fe = fe + 1
  }
  0
}

function synthParamAnnots() {
  let fe = 0
  while fe < fnStmts.length {
    let fn = P.nodes[fnStmts[fe]]
    if fn is FuncDecl {
      const ps = fn.fnParams
      let pi = 0
      while pi < ps.length {
        let p = P.nodes[ps[pi]]
        if p is Param {
          if p.parType < 0 && nodeTyIsUnion(ps[pi]) && unNames.length > 0 {
            // An un-annotated UNION-element callback param (`xs.filter((a) => a is Cat)`):
            // the checker typed it as a value union. Pin it to a declared union alias so
            // its `is`-narrowing and closure `$fnsig` param token (kind 4) resolve. All
            // unions share `$uBox` and program-global variant tags, so any declared alias
            // routes emission identically; the checker already validated the precise type.
            p.parType = mkTypeRef(unNames[0], -1)
          } else if p.parType < 0 {
            const tn = nodeTyName(ps[pi])
            if tn != "" {
              // Resolve the checker's shape name to the emitter's nominal form — a struct / variant
              // shape to its declared name, a ref-array shape recursively to `<element>[]` — so
              // `checkParams` / the struct- and ref-list-param machinery key on it. A scalar /
              // string / closure name passes through.
              p.parType = mkTypeRef(resolveShapeToNominal(tn), -1)
            }
          }
        }
        pi = pi + 1
      }
    }
    fe = fe + 1
  }
  0
}

// ── captured-MUTATION boxing ──────────────────────────────────────────────────────────────
// Closures capture by VALUE (the env struct copies each captured local), so a local MUTATED
// inside a closure cannot be reflected back — and a bare `c = …` in the closure has no local
// slot, failing at emit ("assignment target is not a parameter, local, or global"). The fix is
// a pure AST rewrite, done before monomorphization so instances inherit it: a captured-mutated
// local is boxed as a LENGTH-1 ARRAY (a shared heap ref both scopes index). `let c = init`
// becomes `let c = [init]`, and EVERY use of `c` (read OR assignment target) becomes `c[0]`, so
// the closure's `c = c + 1` lowers to the indexed write `c[0] = c[0] + 1` into the shared array,
// visible in the maker. Arrays are already capturable + index-assignable through a closure.
//
// Conservative: only a DIRECT `let` of the maker that is assigned INSIDE a nested lambda and is
// NOT shadowed by any nested binding (param / let / loop var) is boxed. Anything else is left
// untouched, falling back to the existing loud error rather than risking a mis-rewrite.

// One scan of a maker body: `dlets` = the maker's own `let` names (depth 0); `alam` = names
// ASSIGNED inside a nested lambda (depth > 0); `ndecls` = every binding declared inside a nested
// lambda (params / lets / loop vars) — the shadow set.
function cboxScan(
  ix: i32,
  depth: i32,
  dlets: string[],
  alam: string[],
  ndecls: string[],
) {
  if ix < 0 { return 0 }
  const n = P.nodes[ix]
  if n is FuncDecl {
    const ps = n.fnParams
    let pi = 0
    while pi < ps.length {
      const p = P.nodes[ps[pi]]
      if p is Param {
        if !capHas(ndecls, p.parName) { ndecls.push(p.parName) }
      }
      pi = pi + 1
    }
    return cboxScan(n.fnBody, depth + 1, dlets, alam, ndecls)
  }
  if n is LetDecl {
    if depth == 0 {
      if !capHas(dlets, n.letName) { dlets.push(n.letName) }
    } else {
      if !capHas(ndecls, n.letName) { ndecls.push(n.letName) }
    }
    return cboxScan(n.letInit, depth, dlets, alam, ndecls)
  }
  if n is Block {
    const bs = n.blkStmts
    let i = 0
    while i < bs.length {
      cboxScan(bs[i], depth, dlets, alam, ndecls)
      i = i + 1
    }
    return 0
  }
  if n is BinExpr {
    if n.binOp == "=" {
      if depth > 0 {
        const t = P.nodes[n.binLeft]
        if t is Ident {
          if !capHas(alam, t.identName) { alam.push(t.identName) }
        }
      }
    }
    cboxScan(n.binLeft, depth, dlets, alam, ndecls)
    return cboxScan(n.binRight, depth, dlets, alam, ndecls)
  }
  if n is IfStmt {
    cboxScan(n.ifCond, depth, dlets, alam, ndecls)
    cboxScan(n.ifThen, depth, dlets, alam, ndecls)
    return cboxScan(n.ifElse, depth, dlets, alam, ndecls)
  }
  if n is WhileStmt {
    cboxScan(n.whileCond, depth, dlets, alam, ndecls)
    return cboxScan(n.whileBody, depth, dlets, alam, ndecls)
  }
  if n is ForRange {
    if !capHas(ndecls, n.frVar) { ndecls.push(n.frVar) }
    cboxScan(n.frFrom, depth, dlets, alam, ndecls)
    cboxScan(n.frTo, depth, dlets, alam, ndecls)
    cboxScan(n.frStep, depth, dlets, alam, ndecls)
    return cboxScan(n.frBody, depth, dlets, alam, ndecls)
  }
  if n is ForIn {
    if !capHas(ndecls, n.fiVar) { ndecls.push(n.fiVar) }
    cboxScan(n.fiIter, depth, dlets, alam, ndecls)
    return cboxScan(n.fiBody, depth, dlets, alam, ndecls)
  }
  if n is RetStmt { return cboxScan(n.retArg, depth, dlets, alam, ndecls) }
  if n is Unary { return cboxScan(n.unArg, depth, dlets, alam, ndecls) }
  if n is Paren { return cboxScan(n.parInner, depth, dlets, alam, ndecls) }
  if n is Member { return cboxScan(n.memObj, depth, dlets, alam, ndecls) }
  if n is OptMember { return cboxScan(n.omObj, depth, dlets, alam, ndecls) }
  if n is Index {
    cboxScan(n.idxArr, depth, dlets, alam, ndecls)
    return cboxScan(n.idxIndex, depth, dlets, alam, ndecls)
  }
  if n is IsExpr { return cboxScan(n.isObj, depth, dlets, alam, ndecls) }
  if n is Call {
    cboxScan(n.callFn, depth, dlets, alam, ndecls)
    const args = n.callArgs
    let ci = 0
    while ci < args.length {
      cboxScan(args[ci], depth, dlets, alam, ndecls)
      ci = ci + 1
    }
    return 0
  }
  if n is ArrayLit {
    const es = n.arrElems
    let ei = 0
    while ei < es.length {
      cboxScan(es[ei], depth, dlets, alam, ndecls)
      ei = ei + 1
    }
    return 0
  }
  if n is ObjLit {
    const fs = n.objFields
    let fi = 0
    while fi < fs.length {
      const f = P.nodes[fs[fi]]
      if f is FieldInit { cboxScan(f.fiValue, depth, dlets, alam, ndecls) }
      fi = fi + 1
    }
    return 0
  }
  0
}

// Rewrite the maker body (and its nested lambda bodies): a USE of a boxed name → `c[0]`, and a
// boxed `let c = init` → `let c = [init]`. Returns the (possibly replaced) node index so parents
// reassign — mirrors `drwWalk`, plus descending into `FuncDecl` bodies.
function cboxWalk(ix: i32, boxed: string[]) {
  if ix < 0 { return ix }
  let n = P.nodes[ix]
  if n is Ident {
    if capHas(boxed, n.identName) {
      return mkIndex(mkIdent(n.identName, -1), mkNum("0", -1), -1)
    }
    return ix
  }
  if n is FuncDecl {
    n.fnBody = cboxWalk(n.fnBody, boxed)
    return ix
  }
  if n is Block {
    const bs = n.blkStmts
    let i = 0
    while i < bs.length {
      bs[i] = cboxWalk(bs[i], boxed)
      i = i + 1
    }
    return ix
  }
  if n is LetDecl {
    n.letInit = cboxWalk(n.letInit, boxed)
    if capHas(boxed, n.letName) {
      // Convert a SCALAR annotation to its array form so the boxed length-1 list classifies as the
      // matching list type (`let c: f64` → `let c: f64[]`; an `f32` annotation is what makes the
      // `[0.0]` literal build f32, not the f64 default). An UN-annotated local needs no conversion —
      // the `[init]` literal infers its element type (`let c = 0` → i32[], `= 0.0` → f64[]).
      if n.letType >= 0 {
        const lt = P.nodes[n.letType]
        if lt is TypeRef { n.letType = mkTypeRef(lt.tyName + "[]", -1) }
      }
      const els: i32[] = []
      els.push(n.letInit)
      n.letInit = mkArrayLit(els, -1)
    }
    return ix
  }
  if n is BinExpr {
    n.binLeft = cboxWalk(n.binLeft, boxed)
    n.binRight = cboxWalk(n.binRight, boxed)
    return ix
  }
  if n is IfStmt {
    n.ifCond = cboxWalk(n.ifCond, boxed)
    n.ifThen = cboxWalk(n.ifThen, boxed)
    n.ifElse = cboxWalk(n.ifElse, boxed)
    return ix
  }
  if n is WhileStmt {
    n.whileCond = cboxWalk(n.whileCond, boxed)
    n.whileBody = cboxWalk(n.whileBody, boxed)
    return ix
  }
  if n is ForRange {
    n.frFrom = cboxWalk(n.frFrom, boxed)
    n.frTo = cboxWalk(n.frTo, boxed)
    n.frStep = cboxWalk(n.frStep, boxed)
    n.frBody = cboxWalk(n.frBody, boxed)
    return ix
  }
  if n is ForIn {
    n.fiIter = cboxWalk(n.fiIter, boxed)
    n.fiBody = cboxWalk(n.fiBody, boxed)
    return ix
  }
  if n is RetStmt {
    n.retArg = cboxWalk(n.retArg, boxed)
    return ix
  }
  if n is Unary {
    n.unArg = cboxWalk(n.unArg, boxed)
    return ix
  }
  if n is Paren {
    n.parInner = cboxWalk(n.parInner, boxed)
    return ix
  }
  if n is Member {
    n.memObj = cboxWalk(n.memObj, boxed)
    return ix
  }
  if n is OptMember {
    n.omObj = cboxWalk(n.omObj, boxed)
    return ix
  }
  if n is Index {
    n.idxArr = cboxWalk(n.idxArr, boxed)
    n.idxIndex = cboxWalk(n.idxIndex, boxed)
    return ix
  }
  if n is IsExpr {
    n.isObj = cboxWalk(n.isObj, boxed)
    return ix
  }
  if n is Call {
    n.callFn = cboxWalk(n.callFn, boxed)
    const args = n.callArgs
    let ci = 0
    while ci < args.length {
      args[ci] = cboxWalk(args[ci], boxed)
      ci = ci + 1
    }
    return ix
  }
  if n is ArrayLit {
    const es = n.arrElems
    let ei = 0
    while ei < es.length {
      es[ei] = cboxWalk(es[ei], boxed)
      ei = ei + 1
    }
    return ix
  }
  if n is ObjLit {
    const fs = n.objFields
    let fi = 0
    while fi < fs.length {
      const f = P.nodes[fs[fi]]
      if f is FieldInit { f.fiValue = cboxWalk(f.fiValue, boxed) }
      fi = fi + 1
    }
    return ix
  }
  return ix
}

// The INIT of the maker's direct `let name` (searching statements, NOT descending into a nested
// lambda or an expression), or -1. Used to gate boxing on a known element type.
function cboxInitOf(ix: i32, name: string) {
  if ix < 0 { return -1 }
  const n = P.nodes[ix]
  if n is LetDecl {
    if n.letName == name { return n.letInit }
    return -1
  }
  if n is Block {
    const bs = n.blkStmts
    let i = 0
    while i < bs.length {
      const r = cboxInitOf(bs[i], name)
      if r >= 0 { return r }
      i = i + 1
    }
    return -1
  }
  if n is IfStmt {
    const rt = cboxInitOf(n.ifThen, name)
    if rt >= 0 { return rt }
    return cboxInitOf(n.ifElse, name)
  }
  if n is WhileStmt { return cboxInitOf(n.whileBody, name) }
  if n is ForRange { return cboxInitOf(n.frBody, name) }
  if n is ForIn { return cboxInitOf(n.fiBody, name) }
  -1
}

// True if `initIx` is a SCALAR LITERAL — an integer (`i32`/`i64`), float (`f64`, or `f32` via the
// annotation), or string. A captured-mutated local with such an init boxes cleanly into a length-1
// list of the matching scalar type: `cboxWalk` converts the annotation to its array form, the list
// type is collected (`cboxForceListUse`), and the CLOSURE classifies the captured env field's list
// kind (`capturedKindOf`, consulted by `exprF64Array`/`exprI64Array`/`exprF32Array`/
// `exprStringArray`). Covers the counter/accumulator case at every scalar type. A non-scalar-literal
// init (struct / closure / call) is left to the loud error rather than mis-lowered.
function cboxInitScalar(initIx: i32) {
  if initIx < 0 { return false }
  const n = P.nodes[initIx]
  if n is NumLit { return true }
  if n is StrLit { return true }
  false
}

// Per top-level function: box each direct `let` that is assigned inside a nested lambda and not
// shadowed (and, for now, has an i32 integer init). Usage-gated — a program with no such local
// rewrites nothing (identical bytes).
function captureBoxRewrite(stmts: i32[]) {
  let fe = 0
  while fe < fnStmts.length {
    const fn = P.nodes[fnStmts[fe]]
    if fn is FuncDecl {
      const dlets: string[] = []
      const alam: string[] = []
      const ndecls: string[] = []
      cboxScan(fn.fnBody, 0, dlets, alam, ndecls)
      const boxed: string[] = []
      let di = 0
      while di < dlets.length {
        const nm = dlets[di]
        if capHas(alam, nm) {
          if !capHas(ndecls, nm) {
            if cboxInitScalar(cboxInitOf(fn.fnBody, nm)) { boxed.push(nm) }
          }
        }
        di = di + 1
      }
      if boxed.length > 0 { fn.fnBody = cboxWalk(fn.fnBody, boxed) }
    }
    fe = fe + 1
  }
  0
}

export function emitProgram(rootIx: i32) {
  emitFailed = false
  emitErr = ""
  narrowNames = []
  narrowVariants = []
  narrowTop = 0
  if rootIx < 0 { return emitFail("emitProgram: empty arena (root index < 0)") }
  const root = P.nodes[rootIx]
  if root is Program {
    const stmts = root.progStmts
    if stmts.length < 1 {
      return emitFail("emitProgram: expected at least one top-level statement")
    }
    // Collect the union alias FIRST (so `collectS` knows whether the program's
    // structs are union variants vs a single direct struct), then the (single)
    // struct type, so param/return/local checks can recognize its name, then the
    // function list (FuncDecls only), then the name→index map. Forward references and
    // recursion resolve because every name is mapped before any body is emitted.
    resetLitAtoms()
    if collectU(stmts) < 0 { return -1 }
    if collectS(stmts) < 0 { return -1 }
    if collectA(stmts) < 0 { return -1 }
    if collectFns(stmts) < 0 { return -1 }
    if fnStmts.length < 1 && startStmts.length < 1 {
      return emitFail(
        "emitProgram: expected at least one top-level function or statement",
      )
    }
    if buildFnMap(stmts) < 0 { return -1 }
    computeVoidFns()
    computeRetInference()
    // Dispatch rewrite (UFCS `self`-methods, operator overloads, index traps):
    // resolve `o.f(args)` / `a op b` / `o[k]` shapes into the plain-call /
    // member-call forms the existing lowerings (and the monomorphizer, next)
    // already handle. Must run BEFORE monomorphization so a rewritten call
    // instantiates per receiver shape. Usage-gated: no such shape → no rewrite.
    dispatchRewrite(stmts)
    // Box captured-MUTATION locals as shared length-1 arrays (a closure mutating a captured
    // local needs a shared cell — captures are by-value). Runs BEFORE monomorphization so
    // instances inherit the rewrite; usage-gated → identical bytes when nothing is boxed.
    captureBoxRewrite(stmts)
    // Give a lambda bound to an annotated closure type a UNION return annotation from it. Runs
    // BEFORE monomorphization: a union-returning lambda that flows into a HOF param is monomorphized
    // (its `fnStmts` slot REPLACED by an instance cloned with `nret = fnRet`), so its return must be
    // pinned first or the instance keeps `fnRet < 0` and emits a single-arm struct `$fnsig` result
    // (`i>s-1;`) that the call-site `ref.cast` to `i>u` rejects. Also before the shape passes, so the
    // union's box + variants intern for the return like a named `: Cat | Dog` function. The union
    // registry (`collectU`, above) is already populated, so an alias return (`(i32) => Animal`)
    // resolves via `isUName`. Covers struct / alias / value unions (a value union's narrowed result
    // unboxes via `paramUnionRetName` in the HOF body), and the BOUND case (no mono) alike.
    synthRetAnnots()
    // Monomorphize: resolve every direct call to a generic (`<T>` / un-annotated
    // param) function into a concretely-annotated instance (cloned per distinct
    // call shape, host `instantiate` parity) BEFORE signatures and types are
    // collected. Usage-gated: zero instances → byte-identical output.
    if monomorphize(stmts) < 0 { return -1 }
    // Instance-pinned annotations minted DURING monomorphization (`Box<i32>`
    // applications, `{first:string,second:i32}` structural returns) postdate
    // the `collectS` arena scan — rescan so they intern too, then refresh the
    // name→index tables that resolve against the struct table (an instance's
    // `fRetStructIdx` needs its just-interned return shape). All passes are
    // idempotent and usage-gated (no new TypeRef → no new shape → identical
    // bytes).
    collectGenAliasShapes()
    collectAnnShapes()
    if collectA(stmts) < 0 { return -1 }
    if buildFnMap(stmts) < 0 { return -1 }
    // Synthesize an un-annotated CALLBACK param's annotation from the checker's recorded type
    // (`xs.map((x) => x * 2.0)` over `f64[]` ⇒ `x: f64`), so its functype valtype follows the
    // contextually-inferred element instead of defaulting to i32. Runs after monomorphization
    // (so an instance's pinned params are in place) and BEFORE the `$fnsig` / map-filter
    // collection that reads param valtypes. Usage-gated: a param with no recorded scalar type
    // (generic hole, or already annotated) is left untouched → byte-identical.
    synthParamAnnots()
    computeVoidFns()
    computeRetInference()
    // `.map`/`.filter` sites flip `fnValUsed` (the callback is a function value) and
    // force the RESULT list's types; the `$fnsig` signature set is then collected
    // (both need the inferred return kinds, so they run after `computeRetInference`).
    collectMapFilterUse()
    collectFnValUse()
    collectCloSigs()
    // Detect `print(...)` anywhere in the program: any use pulls in the 4-import
    // print family (imports shift every local function's wasm index, so this is
    // decided up front; a print-free program emits no import section at all).
    gImports = 0
    gNeedsI64Print = false
    gNeedsF64Print = false
    gF64PrintIdx = 0
    gNeedsF32Print = false
    gF32PrintIdx = 0
    memUsed = false
    memLogUsed = false
    let pscan = 0
    let sawI64Ann = false
    let sawF64 = false
    let sawF32 = false
    while pscan < P.nodes.length {
      const pn = P.nodes[pscan]
      if pn is Call {
        const pcallee = P.nodes[pn.callFn]
        if pcallee is Ident {
          if pcallee.identName == "print" { gImports = 4 }
          // The linear-memory intrinsics: any store/load forces the module-defined
          // memory; `__log__` additionally forces the synthetic decoder function,
          // which prints through `__print_i32__` — so it pulls in the print-import
          // family exactly as a `print(...)` call does.
          if (
            pcallee.identName == "__store_i32__" ||
            pcallee.identName == "__load_i32__"
          ) {
            memUsed = true
          }
          if pcallee.identName == "__log__" {
            memUsed = true
            memLogUsed = true
            gImports = 4
          }
        }
      }
      // Any `i64` type annotation anywhere flags the program as i64-using. Combined
      // with `print`, it pulls in the `__print_i64__` import. (An over-approximation:
      // a program with an i64 binding but no `print(<i64>)` would carry one unused
      // import — harmless, and never the case for the existing byte-identical goldens,
      // none of which name `i64`.)
      if pn is TypeRef {
        // ANY annotation mentioning i64 — bare `i64`, `i64[]`, an `i64 | …` value union, a
        // `{[…]: i64}` map — implies an i64 value may be printed; pull in the `__print_i64__`
        // import (an over-approximation, harmless if unused; no existing golden names i64).
        // Without the union/array forms a `print(u)` over `u: i64 | string` narrowed to i64
        // routed `fbCall(4)` to a non-existent import — invalid wasm.
        if strContains(pn.tyName, "i64") { sawI64Ann = true }
        if pn.tyName == "f64" { sawF64 = true }
        // ANY annotation mentioning f32 — bare `f32`, `f32[]`, an `f32 | …` union, a `{[…]:
        // f32}` map — implies an f32 value may be printed; pull in the f32 print import (an
        // over-approximation, harmless if unused; no existing golden names f32).
        if strContains(pn.tyName, "f32") { sawF32 = true }
      }
      // A float `.` literal flags the program as f64-using (the checker types it f64).
      // An INTEGER literal past the i32 range flags it as i64-using (the checker
      // types it i64 — the host `defaultIntegerType` rule), so `print(0xDEAD_BEEF)`
      // pulls in the `__print_i64__` import even with no `i64` annotation.
      if pn is NumLit {
        if numTextIsFloat(pn.numText) { sawF64 = true }
        else if !numLexFitsI32(pn.numText) { sawI64Ann = true }
      }
      pscan = pscan + 1
    }
    // When the program both prints (gImports > 0, i.e. == 4) and names an i64 type,
    // add the 5th `__print_i64__` import. (Bumped from the proven `gImports > 0` form;
    // a direct `gImports == 4` is avoided — the host bootstrap typechecker mishandles
    // the literal comparison on this reassigned module global.)
    if gImports > 0 {
      if sawI64Ann {
        gImports = gImports + 1
        gNeedsI64Print = true
      }
      // Then `__print_f64__` (at the next index — 4 or 5). The f64 import always
      // trails the i64 one so the i64 print index (4) is unchanged. (Slice 3.)
      if sawF64 {
        gF64PrintIdx = gImports
        gImports = gImports + 1
        gNeedsF64Print = true
      }
      // Then `__print_f32__` (at the next index — 4/5/6). It always TRAILS the i64 and
      // f64 imports so their indices are unchanged. (Slice 5.)
      if sawF32 {
        gF32PrintIdx = gImports
        gImports = gImports + 1
        gNeedsF32Print = true
      }
    }
    // Every function's parameters must be i32 or the struct type before we commit.
    let i = 0
    while i < fnStmts.length {
      if checkParams(fnStmts[i]) < 0 { return -1 }
      i = i + 1
    }
    let rc = emitModule(stmts)
    if rc < 0 { return rc }
    // An `emitFail` whose -1 a deep helper swallowed (e.g. inside a valtype write)
    // must still fail the WHOLE emit: a failed module never reaches instantiation.
    if emitFailed { return -1 }
    return rc
  }
  emitFail("emitProgram: root node is not a Program")
}
