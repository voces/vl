{
  "name": "vital-vscode",
  "displayName": "Vital",
  "description": "Language support for Vital (VL): diagnostics, type-aware hover and completion, go-to-definition, find references, inlay hints, formatting, quick-fixes, semantic highlighting, and run.",
  "version": "0.0.1",
  "publisher": "verit",
  "engines": {
    "vscode": "^1.58.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "main": "dist/extension",
  "activationEvents": [
    "onLanguage:vital"
  ],
  "contributes": {
    "configuration": {
      "title": "Vital",
      "properties": {
        "vital.compilerWasm": {
          "type": "string",
          "default": "",
          "description": "Path to the self-hosted compiler wasm. Empty = <workspace>/build/vl-compiler.wasm."
        },
        "vital.compilerPath": {
          "type": "string",
          "default": "",
          "description": "Path to the native `vl` binary used by \"Run Current File\" (relative paths resolve against the project root). Empty = `vl` on your PATH."
        }
      }
    },
    "languages": [
      {
        "id": "vital",
        "aliases": [
          "Vital",
          "vl"
        ],
        "extensions": [
          ".vl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vital",
        "scopeName": "source.vital",
        "path": "./syntaxes/vital.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "vital.runFile",
        "title": "Run Current File",
        "category": "Vital",
        "icon": "$(play)"
      }
    ],
    "keybindings": [
      {
        "command": "vital.runFile",
        "key": "ctrl+f5",
        "when": "editorLangId == vital"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "vital.runFile",
          "when": "editorLangId == vital",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "vital.runFile",
          "when": "editorLangId == vital",
          "group": "navigation"
        }
      ]
    }
  }
}
