{
  "name": "vital-vscode",
  "displayName": "Vital",
  "description": "Syntax highlighting for Vital",
  "version": "0.0.1",
  "publisher": "verit",
  "engines": {
    "vscode": "^1.58.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "dist/extension",
  "activationEvents": [
    "onLanguage:vital"
  ],
  "contributes": {
    "languages": [
      {
        "id": "vital",
        "aliases": [
          "Vital",
          "vl"
        ],
        "extensions": [
          ".vl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "vital",
        "scopeName": "source.vital",
        "path": "./syntaxes/vital.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "vital.runFile",
        "title": "Run Current File",
        "category": "Vital",
        "icon": "$(play)"
      }
    ],
    "keybindings": [
      {
        "command": "vital.runFile",
        "key": "ctrl+f5",
        "when": "editorLangId == vital"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "vital.runFile",
          "when": "editorLangId == vital",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "vital.runFile",
          "when": "editorLangId == vital",
          "group": "navigation"
        }
      ]
    }
  }
}
