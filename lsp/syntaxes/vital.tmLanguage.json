{
  "scopeName": "source.vital",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#numbers" },
    { "include": "#calls" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.vital", "match": "//.*" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.vital",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.vital",
              "match": "\\\\[\"\\\\]"
            }
          ]
        },
        {
          "name": "string.quoted.single.vital",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.vital",
              "match": "\\\\['\\\\]"
            }
          ]
        }
      ]
    },    
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.vital",
          "match": "\\b(function|if|then|else|elseif|while|for|to|step|in|return|await|break|continue|not|from|type)\\b"
        },
        {
          "name": "constant.language.boolean.vital",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.vital",
          "match": "\\bnull\\b"
        },
        {
          "name": "support.type.primitive.vital",
          "match": "\\b(string|i32|i64|f32|f64|boolean|never)\\b"
        },
        {
          "name": "storage.type",
          "match": "\\b(const|let)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.vital",
          "match": "\\+\\+|--|&&|\\|\\||!|==|>=|<=|>|<|\\+|-|\\\\|/|%|\\^|=|!="
        }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.vital", "match": "[\\(\\)\\{\\}\\[\\],.:]" }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.vital",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "calls": {
      "patterns": [
        {
          "name": "entity.name.function.vital",
          "match": "\\b([a-zA-Z_][\\w]*)\\s*(?=\\()"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.vital",
          "match": "\\b[a-zA-Z_][a-zA-Z_0-9]*\\b"
        }
      ]
    }
  },
  "fileTypes": ["vl"]
}
