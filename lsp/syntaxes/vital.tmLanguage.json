{
  "scopeName": "source.vital",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#function-declaration" },
    { "include": "#type-declaration" },
    { "include": "#type-annotation" },
    { "include": "#generic-arguments" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#primitive-types" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#calls" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.vital", "match": "//.*$" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.vital",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.vital",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.vital",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.vital",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "function-declaration": {
      "match": "\\b(function)\\s+([a-zA-Z_][a-zA-Z_0-9]*)",
      "captures": {
        "1": { "name": "keyword.control.vital" },
        "2": { "name": "entity.name.function.vital" }
      }
    },
    "type-declaration": {
      "match": "\\b(type)\\s+([a-zA-Z_][a-zA-Z_0-9]*)",
      "captures": {
        "1": { "name": "keyword.control.vital" },
        "2": { "name": "entity.name.type.vital" }
      }
    },
    "type-annotation": {
      "begin": ":",
      "end": "(?=[,(){}\\[\\]=]|$)",
      "beginCaptures": {
        "0": { "name": "punctuation.separator.colon.vital" }
      },
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#primitive-types" },
        { "include": "#generic-arguments" },
        {
          "name": "keyword.operator.union.vital",
          "match": "\\|"
        },
        {
          "name": "entity.name.type.vital",
          "match": "\\b[a-zA-Z_][a-zA-Z_0-9]*\\b"
        },
        { "include": "#punctuation" }
      ]
    },
    "generic-arguments": {
      "begin": "(?<=[a-zA-Z_0-9>\\]])(<)(?![<=])",
      "end": ">",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.generic.begin.vital" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.generic.end.vital" }
      },
      "patterns": [
        { "include": "#numbers" },
        { "include": "#primitive-types" },
        {
          "name": "keyword.other.vital",
          "match": "\\b(extends)\\b"
        },
        { "include": "#generic-arguments" },
        {
          "name": "keyword.operator.union.vital",
          "match": "[|=]"
        },
        {
          "name": "entity.name.type.vital",
          "match": "\\b[a-zA-Z_][a-zA-Z_0-9]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.import.vital",
          "match": "\\b(import|export|from|as)\\b"
        },
        {
          "name": "keyword.control.vital",
          "match": "\\b(if|else|elseif|while|for|return|await|break|continue)\\b"
        },
        {
          "name": "keyword.control.vital",
          "match": "\\b(function|type)\\b"
        },
        {
          "name": "keyword.operator.is.vital",
          "match": "\\bis\\b"
        },
        {
          "name": "storage.type.vital",
          "match": "\\b(const|let)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.vital",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.vital",
          "match": "\\bnull\\b"
        }
      ]
    },
    "primitive-types": {
      "patterns": [
        {
          "name": "support.type.primitive.vital",
          "match": "\\b(string|boolean|never|void|i32|i64|u32|u64|f32|f64|bigint|decimal)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.vital",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.compound.vital",
          "match": "(\\+|-|\\*|/|%|\\^)="
        },
        {
          "name": "keyword.operator.bitwise.vital",
          "match": ">>>|<<|>>|~|\\^"
        },
        {
          "name": "keyword.operator.comparison.vital",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.vital",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.increment.vital",
          "match": "\\+\\+|--"
        },
        {
          "name": "keyword.operator.optional.vital",
          "match": "\\?\\?|\\?\\."
        },
        {
          "name": "keyword.operator.arithmetic.vital",
          "match": "\\+|-|\\*|/|%|\\^"
        },
        {
          "name": "keyword.operator.assignment.vital",
          "match": "="
        },
        {
          "name": "keyword.operator.union.vital",
          "match": "\\|"
        }
      ]
    },
    "calls": {
      "patterns": [
        {
          "match": "([a-zA-Z_][a-zA-Z_0-9]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.vital" }
          }
        }
      ]
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.section.parens.begin.vital", "match": "\\(" },
        { "name": "punctuation.section.parens.end.vital", "match": "\\)" },
        { "name": "punctuation.section.braces.begin.vital", "match": "\\{" },
        { "name": "punctuation.section.braces.end.vital", "match": "\\}" },
        { "name": "punctuation.section.brackets.begin.vital", "match": "\\[" },
        { "name": "punctuation.section.brackets.end.vital", "match": "\\]" },
        { "name": "punctuation.separator.comma.vital", "match": "," },
        { "name": "punctuation.accessor.vital", "match": "\\." },
        { "name": "punctuation.separator.colon.vital", "match": ":" }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.vital",
          "match": "\\b[a-zA-Z_][a-zA-Z_0-9]*\\b"
        }
      ]
    }
  },
  "fileTypes": ["vl"]
}
